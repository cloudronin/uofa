# syntax=docker/dockerfile:1
#
# UofA concept appliance (Phase A). One self-contained, air-gap-faithful image:
# open core + the surrogate pack + the JRE + a bundled stock explainer (Qwen 2.5
# 7B via Ollama). It takes the inputs SIP accepts, runs to firings + signed
# verdict-free evidence, and explains the flags as labeled reference-annotation.
#
# The bundled model (~4.7 GB) is the LAST layer so every earlier layer caches
# across iterations. It is the ship-target size (SLM spec §4): the appliance
# baseline and the bakeoff-gate model are deliberately the same artifact.

# ── Stage 1: build the Jena rule-engine JAR ──────────────────────────────────
FROM maven:3-eclipse-temurin-17 AS jar
WORKDIR /build
COPY src/weakener-engine/ ./src/weakener-engine/
RUN cd src/weakener-engine && mvn -q -DskipTests package

# ── Stage 2: build the wheel with the JAR bundled in (force-includes packs/ + specs/) ──
FROM python:3.11-slim-bookworm AS wheel
WORKDIR /build
COPY . .
# Place the maven-built JAR where the UOFA_BUNDLE_JAR=1 hook reads it.
COPY --from=jar /build/src/weakener-engine/target/uofa-weakener-engine-0.1.0.jar \
     src/weakener-engine/target/uofa-weakener-engine-0.1.0.jar
RUN pip install --no-cache-dir hatchling \
 && UOFA_BUNDLE_JAR=1 pip wheel --no-deps -w /wheels .

# ── Stage 3: the appliance runtime ───────────────────────────────────────────
FROM python:3.11-slim-bookworm
ENV PYTHONUNBUFFERED=1 \
    OLLAMA_HOST=127.0.0.1:11434 \
    OLLAMA_MODELS=/root/.ollama/models \
    PHYSICSNEMO_URL=http://physicsnemo:8000

# JRE for the rule engine (paths.java_executable() falls back to system java),
# plus curl + zstd to fetch the pinned Ollama runtime.
RUN apt-get update && apt-get install -y --no-install-recommends \
        openjdk-17-jre-headless curl ca-certificates zstd procps \
 && rm -rf /var/lib/apt/lists/*

# Ollama runtime, pinned to build-config/ollama_manifest.toml (v0.21.2, MIT).
# Arch-aware (TARGETARCH is set by buildkit) so it builds native on both an
# arm64 dev box (Apple Silicon) and an amd64 server — no qemu emulation.
ARG TARGETARCH
RUN set -eu; \
    case "${TARGETARCH}" in \
      amd64) OLLAMA_ARCH=amd64 ;; \
      arm64) OLLAMA_ARCH=arm64 ;; \
      *) echo "unsupported TARGETARCH=${TARGETARCH}" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/ollama/ollama/releases/download/v0.21.2/ollama-linux-${OLLAMA_ARCH}.tar.zst" \
        -o /tmp/ollama.tar.zst \
 && tar -I zstd -xf /tmp/ollama.tar.zst -C /usr/local \
 && rm /tmp/ollama.tar.zst \
 && ollama --version

# Bake the ship-target stock model right after the Ollama runtime — it rarely
# changes, so iterating the app/demo layers below never re-pulls the ~4.7 GB
# model. Self-contained + air-gap-faithful (no model pull at run time).
RUN set -eu; \
    ollama serve >/tmp/ollama-build.log 2>&1 & \
    for _ in $(seq 1 60); do curl -sf http://127.0.0.1:11434/api/version >/dev/null 2>&1 && break; sleep 1; done; \
    ollama pull qwen2.5:7b; \
    pkill -f "ollama serve" || true

# Install the appliance: core + surrogate pack (in the wheel) + SIP + explain.
COPY --from=wheel /wheels/ /wheels/
RUN pip install --no-cache-dir --retries 5 --timeout 60 "$(echo /wheels/uofa-*.whl)[interrogate,extract]"

# Demo assets: the SIP adapters (not force-included in the wheel), the appliance
# project config ([llm] → in-container Ollama), and the demo orchestration.
WORKDIR /work
COPY examples/ /app/examples/
COPY docker/appliance/uofa.toml /work/uofa.toml
COPY docker/appliance/demo_scope.json /app/docker/appliance/demo_scope.json
COPY docker/appliance/sip_to_cou.py /app/docker/appliance/sip_to_cou.py
COPY docker/appliance/run-demo.sh /usr/local/bin/run-demo.sh
RUN chmod +x /usr/local/bin/run-demo.sh

ENTRYPOINT ["/usr/local/bin/run-demo.sh"]
