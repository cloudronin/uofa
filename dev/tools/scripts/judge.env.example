# Phase 3 Stage 2 production credentials (spec Part 3.4).
# Copy to ~/.uofa/judge.env and `chmod 600 ~/.uofa/judge.env`.
# Do NOT commit the real file (it is outside the repo and gitignored anyway).
#
# IMPORTANT: Judge C (Llama-4-Maverick) is served via OpenRouter and reads
# OPENROUTER_API_KEY (re-routed 2026-07-16 after SambaNova deprecated the model).
# SAMBANOVA_API_KEY is no longer used for new judging.

OPENAI_API_KEY=sk-REPLACE_ME
GEMINI_API_KEY=REPLACE_ME
OPENROUTER_API_KEY=sk-or-REPLACE_ME
MISTRAL_API_KEY=REPLACE_ME
