# Phase 3 Stage 2 production credentials (spec Part 3.4).
# Copy to ~/.uofa/judge.env and `chmod 600 ~/.uofa/judge.env`.
# Do NOT commit the real file (it is outside the repo and gitignored anyway).
#
# IMPORTANT: Judge C (Llama-4-Maverick via SambaNova) reads SAMBANOVA_API_KEY.
# It does NOT fall back to HF_TOKEN — a wrong/old HF_TOKEN entry fails Judge C
# silently for the whole run.

OPENAI_API_KEY=sk-REPLACE_ME
GEMINI_API_KEY=REPLACE_ME
SAMBANOVA_API_KEY=REPLACE_ME
MISTRAL_API_KEY=REPLACE_ME
