  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-ansys-fda-verified-release",
      "rationale": "All three FEA codes (Ansys Mechanical 2022 R2, FDA in-house solver, DePuy Synthes proprietary FEA) operate under documented software quality assurance plans. Ansys is a commercially validated solver with ISO 9001 certification; the FDA in-house solver is governed by FDA CDRH SQA procedures; DePuy Synthes FEA environment operates under a 21 CFR Part 820-compliant design control system. Version control, regression test suites, and change-control records are on file. Achieved Gradation 3 exceeds required Gradation 2 for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-benchmark-suite",
      "rationale": "Each solver was exercised against ASME V&V 10 benchmark problems relevant to structural mechanics (patch test, cantilever beam, Hertz contact). All three codes reproduced analytical solutions within 0.5% for linear elastic cases and within 2% for nonlinear contact problems. Code verification records are archived and traceable to solver version identifiers used in the validation study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/mesh-convergence-gci-lt2pct",
      "rationale": "A systematic mesh refinement study was conducted using three mesh densities (coarse ~180k elements, medium ~420k elements, fine ~910k elements) for the pedicle screw-rod construct. Grid Convergence Index (GCI) was computed per Roache (1998); GCI for stiffness QoI = 0.9%, yield force QoI = 1.4%, force-at-40mm QoI = 1.7%. All GCI values below the 2% acceptance threshold. Medium mesh adopted for production runs, balancing accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Numerical solver error is scoped out because all three FEA codes employ well-established direct sparse solvers (PARDISO, MUMPS) with iterative residual checks enforcing convergence tolerances of 1e-6 on force and displacement norms. For the quasi-static, geometrically nonlinear structural problem considered here, solver-induced numerical error is demonstrably negligible relative to discretization and material model uncertainty, which are quantified separately. Scoping out is consistent with ASME V&V 40 guidance permitting exclusion of factors whose contribution to total uncertainty is bounded below 0.1% by documented solver verification activities already captured under Numerical code verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Use error is scoped out on the basis that model setup, boundary condition application, and post-processing were performed by a single experienced analyst team following a documented modeling protocol (SOP-FEA-001 Rev C), with independent peer review of all model inputs by a second qualified engineer prior to each simulation run. The modeling protocol was frozen before any experimental data were unblinded, eliminating analyst-driven tuning. Under these controlled conditions, the residual probability of consequential use error is judged negligible and does not materially affect the credibility conclusion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-bilinear-isotropic-hardening-justified",
      "rationale": "Ti-6Al-4V screw and rod material behavior is represented by a bilinear isotropic hardening plasticity model calibrated from uniaxial tensile coupon data. The UHMWPE vertebral body surrogate is modeled as linear elastic, consistent with the low strains experienced at the surrogate-screw interface under the F1717 protocol. Contact between screw shaft and rod clamp is modeled with Coulomb friction (mu=0.25), consistent with published tribological data for Ti-Ti interfaces. Model form choices are justified by literature precedent and sensitivity analyses confirming that higher-fidelity constitutive options (e.g., Chaboche kinematic hardening) alter QoI predictions by less than 1.5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-material-geometry-measured",
      "rationale": "Geometry inputs were derived from CMM measurements of production pedicle screws (n=5) and rods (n=5), with dimensional tolerances propagated as input uncertainty. Material properties (elastic modulus, yield strength, tangent modulus) were measured from tensile coupons machined from the same material lot as the test constructs (n=3 per lot). Boundary conditions replicate ASTM F1717 fixture geometry and applied displacement ramp as specified in the test protocol. Input uncertainty was propagated via Latin Hypercube Sampling (1000 samples) to characterize QoI sensitivity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-n11-production-lot-traceable",
      "rationale": "Eleven constructs (n=6 at Laboratory 1, n=5 at Laboratory 2) were assembled from production-representative pedicle screws and rods drawn from a single manufacturing lot, ensuring material and geometric consistency. Dimensional inspection records confirm all components within drawing tolerances. Sample size of N=11 provides sufficient statistical power to characterize inter-specimen variability and supports the experimental uncertainty estimate used in E/uval calculations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-f1717-single-load-case",
      "rationale": "Testing was conducted strictly per ASTM F1717 under a single load configuration (compression-bending at 5 mm/min displacement rate, ambient temperature). While the standardized protocol ensures reproducibility across laboratories, only one test condition was evaluated, limiting the ability to characterize model behavior across the full COU envelope. This factor is assessed at Gradation 2 against a required Gradation 3, representing the one identified shortfall. The decision record acknowledges this gap and documents the compensating rationale: the COU is explicitly bounded to the F1717 load case, and the model is not extrapolated beyond validated conditions.",
      "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/factor/test-conditions"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters is scoped out because the validation study was designed as a direct one-to-one comparison: FEA model inputs (geometry, material properties, boundary conditions) were derived from measurements taken on the identical physical constructs used in bench testing, with no surrogate or representative-population substitution required. There is no parameter mapping uncertainty to assess — the simulation inputs are not inferred from a separate population or proxy dataset but are measured directly from the test articles. This eliminates the conceptual basis for this factor's assessment in the present COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-eval-metric-euval-lt196",
      "rationale": "Three QoIs (construct stiffness, yield force, force at 40 mm displacement) were compared using both a percentage-difference metric (<10% threshold) and the ASME V&V 40 validation metric E/uval. Experimental uncertainty (uval) was computed from inter-specimen standard deviation and inter-laboratory bias. E/uval values of 0.83, 1.41, and 1.67 all fall below the 1.96 threshold, indicating no statistically significant disagreement between FEA and experiment for any QoI. Output comparison methodology was pre-specified in the validation plan prior to data collection."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-f1717-regulatory-precedent",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the standard performance metrics prescribed by ASTM F1717 and accepted by FDA as relevant indicators of pedicle screw construct mechanical integrity. These QoIs directly inform the clinical risk of construct failure under physiological loading. Their relevance to the COU is established by regulatory precedent (FDA guidance on spinal implant testing) and the direct mechanistic link between the predicted quantities and the failure modes of concern (fatigue precursor yielding, gross deformation)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-direct-f1717-comparison",
      "rationale": "The validation activity directly replicates the COU: the same non-cannulated 7.5 mm pedicle screw geometry, the same ASTM F1717 test configuration, and the same QoIs are used in both validation and the intended regulatory submission context. No extrapolation in geometry, load type, or material system is required between the validation domain and the COU. The multi-laboratory design (two independent test facilities) further strengthens the relevance assessment by demonstrating reproducibility of both experimental results and FEA predictions across independent implementations."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated pedicle screw compression-bending FEA) is accepted at Medium assurance level based on the following structured findings. Of 13 V&V 40 factors, 10 were formally assessed and 3 were scoped out with documented rationale. Among assessed factors: 9 meet or exceed their required credibility level (Software QA: 3≥2; Numerical code verification: 3≥2; Discretization error: 3≥2; Model form: 3≥3; Model inputs: 3≥3; Test samples: 3≥2; Output comparison: 4≥3; QoI relevance: 3≥2; Validation activity relevance: 3≥3). One assessed factor — Test conditions — achieved Gradation 2 against a required Gradation 3, reflecting the single-load-case limitation of the F1717 protocol. This shortfall is accepted because the COU is explicitly scoped to the F1717 compression-bending configuration; the model is not claimed to generalize beyond this validated load case; and the quantitative validation metrics (E/uval < 1.96 for all three QoIs) demonstrate adequate predictive accuracy within the validated domain. The three scoped-out factors (Numerical solver error, Use error, Equivalency of input parameters) are excluded on defensible technical grounds documented in their respective rationale fields, and their exclusion does not diminish confidence in the overall credibility conclusion. The provenance chain from raw experimental data through uncertainty quantification to E/uval computation is complete and traceable. The decision is Accepted with the condition that any future use of this FEA framework outside the F1717 compression-bending configuration requires a new or updated credibility assessment.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/offset/test-conditions",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/factor/test-conditions",
      "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
    }
  },
