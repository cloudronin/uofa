    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/constraint/vad-cfd-applicability-001",
      "type": "ApplicabilityConstraint",
      "name": "CFD Hemolysis Model Applicability Constraints",
      "description": "Explicit constraints bounding the domain in which the CFD model predictions are considered valid. Use outside these constraints requires re-validation.",
      "constraints": [
        {
          "constraintId": "AC-01",
          "parameter": "Blood rheology",
          "assumption": "Newtonian fluid approximation (constant dynamic viscosity 0.0035 Pa·s)",
          "justification": "Valid for shear rates > 100 s⁻¹ prevalent in centrifugal pump passages; non-Newtonian effects assessed as negligible at operating hematocrit range 35–45%.",
          "scope": "Within declared hematocrit and flow envelope only"
        },
        {
          "constraintId": "AC-02",
          "parameter": "Impeller deformation",
          "assumption": "Rigid impeller; fluid-structure interaction not modeled",
          "justification": "Material stiffness of titanium impeller yields maximum tip deflection < 0.02 mm under operating loads, confirmed by FEA. Negligible effect on flow field.",
          "scope": "Operating pressure differential < 120 mmHg"
        },
        {
          "constraintId": "AC-03",
          "parameter": "Blood damage model",
          "assumption": "Power-law hemolysis model (Giersiepen-Wurzinger correlation) calibrated to bovine blood",
          "justification": "Correlation coefficients validated against human blood data within declared hematocrit range; extrapolation beyond Ht 45% is not supported.",
          "scope": "Hematocrit 35–45% only"
        }
      ]
    }
