  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cfd-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-001",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump achieves or exceeds required credibility levels on all 13 assessed factors under the declared operating envelope (flow 3–6 L/min, speed 2400–3600 RPM, hematocrit 35–45%). The operating envelope is explicitly bounded with concrete numerical limits, and the validation dataset provides dense coverage of this envelope via 15 operating points selected by Latin Hypercube design. Applicability constraints (Newtonian rheology, rigid impeller, power-law hemolysis model) are formally documented and confirmed valid within the declared envelope. Monte Carlo uncertainty quantification (n=500–1000 samples) demonstrates that 95% prediction intervals for NIH bracket all experimental measurements. The area validation metric of 0.91 exceeds the pre-specified threshold of 0.80. All acceptance criteria defined a priori are met. The model is accepted for use in predicting absolute hemolysis index values for the Class III VAD device within the declared operating envelope and subject to the documented applicability constraints.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
