  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 3. Achieved credibility levels meet or exceed required levels for every factor: 9 factors achieved Gradation 3 (exceeding the required Gradation 2) and 4 factors achieved Gradation 2 (meeting the required Gradation 2). No factor deficit exists. Three independent ValidationResults (PIV velocity comparison, NIH hemolysis comparison, pressure-rise comparison) are documented with quantitative agreement metrics, full provenance chains, and Monte Carlo uncertainty quantification linking to traceable experimental datasets. Software quality assurance, code verification, and discretization error assessments confirm numerical credibility. Model form uncertainty evaluated via turbulence-model sensitivity study. Input uncertainty propagated via Monte Carlo (N=2000). The totality of structured evidence supports the conclusion that the CFD model is credible for predicting absolute hemolysis levels within the defined COU envelope. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
