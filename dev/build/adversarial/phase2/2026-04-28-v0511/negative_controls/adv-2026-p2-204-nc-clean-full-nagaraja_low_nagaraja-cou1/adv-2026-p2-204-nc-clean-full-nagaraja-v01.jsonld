      "https://uofa.net/synth/data/nagaraja-f1717-bench-n11",
      "https://uofa.net/synth/data/nagaraja-mesh-convergence-study",
      "https://uofa.net/synth/data/nagaraja-material-props-ti6al4v"
    ],
