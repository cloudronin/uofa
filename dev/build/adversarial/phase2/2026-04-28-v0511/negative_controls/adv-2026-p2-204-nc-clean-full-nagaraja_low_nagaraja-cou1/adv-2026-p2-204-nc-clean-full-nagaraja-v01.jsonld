  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-level2",
      "rationale": "The FEA codes (Ansys Mechanical 2022 R2, FDA in-house solver) are operated under formal software quality assurance plans conforming to 21 CFR Part 11 and ISO 9001. Version control, change management, and regression test suites are documented. DePuy Synthes solver validation records confirm SQA Level 2 compliance. Achieved level equals required level for MRL 3 medium-influence COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/ncv-level2",
      "rationale": "Benchmark problems from the ASME V&V 10 suite (patch test, cantilever beam bending, contact Hertz problem) were executed in all three solver environments. Results matched analytical solutions within 0.5% for linear elastic cases and within 2% for nonlinear contact. Code verification is documented in solver qualification reports archived at FDA OSEL and DePuy Synthes engineering records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/disc-error-level2",
      "rationale": "A systematic mesh convergence study was conducted using three mesh densities (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements) for both the screw and the UHMWPE block. Richardson extrapolation yielded a Grid Convergence Index (GCI) of 1.8% for peak von Mises stress at the screw-rod junction and 0.9% for global construct stiffness. The production mesh (medium density) was selected, achieving discretization error well below the 5% threshold. Achieved level 3 exceeds required level 2, providing additional confidence.",
      "evidenceReference": "https://uofa.net/synth/data/nagaraja-mesh-convergence-study"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-level2",
      "rationale": "Iterative convergence was confirmed for all simulation runs: force residuals converged below 1×10⁻⁴ and displacement residuals below 1×10⁻⁵ within 150 increments. Load stepping was verified to be path-independent for the quasi-static compression-bending scenario. Solver error is estimated at <0.3% of QoI values based on residual monitoring logs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-level2",
      "rationale": "Model setup was performed by two independent analysts (FDA OSEL and DePuy Synthes) following a pre-specified modeling protocol. A third analyst (Ansys consulting team) performed an independent verification of boundary conditions, material assignments, and contact definitions. Discrepancies between analysts were resolved through documented adjudication. No material use errors were identified in the final production models."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-level2",
      "rationale": "The model employs linear elastic constitutive behavior for the Ti-6Al-4V screw and rod (justified by the predominantly elastic response at yield-force levels), with a bilinear isotropic hardening model applied beyond yield. The UHMWPE test block is modeled as a rigid fixture consistent with ASTM F1717 test setup. Contact between screw head and rod is modeled using augmented Lagrangian frictionless contact, consistent with the polished test hardware. Model form assumptions are documented and justified against published material characterization data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-level2",
      "rationale": "Material properties (elastic modulus 114 GPa, yield strength 880 MPa, UTS 950 MPa for Ti-6Al-4V ELI) were sourced from ASTM F136 and confirmed by tensile coupon testing on material from the same lot as the test constructs. Geometric inputs were derived from calibrated CMM measurements of production screws and rods (tolerance ±0.01 mm). Input uncertainty was propagated through a Monte Carlo analysis (n=1000 samples) contributing ±2.1% to QoI uncertainty budget.",
      "evidenceReference": "https://uofa.net/synth/data/nagaraja-material-props-ti6al4v"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-level2",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (FDA OSEL Rockville and DePuy Synthes Warsaw IN). All constructs were drawn from a single production lot with documented dimensional inspection. Sample size provides adequate statistical power (>80% at α=0.05) to detect a 10% difference in mean stiffness. Inter-laboratory variability was characterized and incorporated into the validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-level2",
      "rationale": "Testing was conducted under a single ASTM F1717 static compression-bending condition (load rate 5 mm/min, ambient temperature 23°C, standard UHMWPE block). Only one loading condition was evaluated; dynamic, fatigue, and off-axis conditions were not included in this validation activity. Achieved level 1 is below required level 2, representing the one identified gap in this COU. This gap is accepted because the device submission is limited to static structural assessment and the regulatory decision consequence is classified as Medium (revision surgery, not life-threatening failure). A compensating argument is provided in the decision record.",
      "gapAcknowledged": true,
      "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026/factor/test-conditions"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/equiv-inputs-level2",
      "rationale": "A formal parameter equivalency mapping was performed between the physical test setup and the FEA boundary conditions. Fixture geometry, screw insertion depth, rod diameter (6.35 mm), and block material properties were verified to be equivalent within measurement uncertainty. The mapping table is documented in the V&V plan and confirmed by the independent analyst review. No unresolved parameter discrepancies were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-level2",
      "rationale": "Quantitative output comparison was performed using the ASME V&V 40 validation metric E/uval for all three QoIs (stiffness, yield force, force at 40 mm). All three E/uval values (1.31, 1.54, 1.72) fall below the 1.96 threshold. Additionally, a Bayesian model updating analysis was performed to confirm posterior predictive coverage. Force-displacement curves from FEA were overlaid with experimental envelopes across all 11 specimens, showing consistent agreement throughout the loading range. Achieved level 3 exceeds required level 2.",
      "evidenceReference": "https://uofa.net/synth/validation/nagaraja-vr-stiffness"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-level2",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 and are the regulatory endpoints used by FDA to evaluate pedicle screw construct structural performance. These QoIs are mechanistically linked to the clinical failure modes of concern (screw fracture, rod fracture, set-screw loosening under cyclic loading). The mapping from QoI to clinical risk is documented in the risk analysis per ISO 14971."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/val-relevance-level2",
      "rationale": "The validation activity directly replicates the COU: the same FEA modeling framework, the same screw design (non-cannulated 7.5 mm), the same test standard (ASTM F1717 static compression-bending), and the same regulatory decision context (510(k) substantial equivalence). The validation samples are production-representative constructs from the same manufacturing lot as the submission device. The validation activity is therefore fully relevant to the COU with no extrapolation required beyond the single-condition limitation noted under Test conditions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated pedicle screw compression-bending FEA prediction) is accepted at Medium assurance level for MRL 3. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single identified gap — Test conditions (achieved level 1 vs. required level 2) — is accepted based on the following compensating arguments: (1) the regulatory submission scope is limited to static structural performance under ASTM F1717, for which only the single standard test condition is required; (2) the decision consequence is classified as Medium (revision surgery, not patient death), consistent with the established risk tolerance for this COU; (3) all three primary QoIs (stiffness, yield force, force at 40 mm displacement) satisfy the pre-specified quantitative acceptance criterion of E/uval < 1.96, with values of 1.31, 1.54, and 1.72 respectively; (4) the validation was conducted across two independent laboratories with N=11 constructs, providing robust inter-laboratory confirmation; (5) independent analyst review confirmed no use errors or parameter equivalency discrepancies. The provenance chain is complete from raw experimental data through uncertainty quantification to validation metric computation. The model risk level 3 classification is consistent with the moderate complexity of the FEA framework and the availability of direct experimental comparators. On balance, the structured evidence supports the conclusion that the FEA modeling framework is sufficiently credible for its intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z",
