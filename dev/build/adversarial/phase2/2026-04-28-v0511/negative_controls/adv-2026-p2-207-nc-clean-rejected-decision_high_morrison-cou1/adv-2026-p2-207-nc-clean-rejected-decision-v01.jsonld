  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis, MRL 2) is Not accepted based on the structured factor evidence. Two factors failed to meet their required levels: (1) Discretization error achieved level 2 against a required level 3 — the GCI of 6.8% on the production mesh marginally exceeds the 5% threshold in the acceptance criteria, and the fine-mesh sensitivity study did not reduce the error sufficiently to satisfy level 3; (2) Model form achieved level 2 against a required level 3 — the multi-model turbulence comparison yielded a 12% spread in peak shear stress predictions against a 10% acceptance threshold, and no physics-based compensating argument was found to bridge the 2-percentage-point gap. The remaining 11 factors all met or exceeded their required levels, and the provenance chain is complete. However, per the MRL 2 assessment protocol for a High-consequence decision, all assessed factors must meet their required levels for the package to be accepted. The team considered whether the conservative bias of the SST model (systematically higher shear stress, hence conservative hemolysis predictions) could justify acceptance despite the model-form shortfall, but concluded that a quantitative resolution is required before regulatory submission. Recommended remediation: (a) refine the production mesh to achieve GCI ≤ 5% for the hemolysis QoI, and (b) conduct an additional turbulence model comparison (e.g., Reynolds Stress Model or LES on a reduced geometry) or acquire near-wall PIV data to bound model-form uncertainty to within 10%. Upon completion of these activities, the package may be resubmitted for re-assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
