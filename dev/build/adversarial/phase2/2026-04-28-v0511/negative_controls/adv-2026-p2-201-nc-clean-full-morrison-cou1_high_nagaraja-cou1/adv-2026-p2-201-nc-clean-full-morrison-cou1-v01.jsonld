  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used in the FEA ensemble (Ansys Mechanical 2022 R1, Abaqus 2021) must have documented V&V test suites, revision control, and traceable release notes. Achieved level requires formal QA plan with independent code review.",
      "rationale": "Ansys Mechanical 2022 R1 and Abaqus 2021 are both commercially validated FEA codes with ISO 9001-certified development processes. Internal DePuy Synthes SQA records confirm software version lock, change control, and regression test suite execution prior to each simulation campaign. FDA OSEL additionally ran independent benchmark problems (Hertz contact, beam bending) confirming numerical accuracy. Achieves Gradation 3: formal QA plan with independent verification of test suite results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate that the numerical implementation correctly solves the governing equations for problems representative of the COU physics (large-displacement contact, elastic-plastic material response). Benchmark solutions must be documented with quantified error norms.",
      "rationale": "Code verification benchmarks performed against NAFEMS LE1, LE10, and NL1 nonlinear reference problems. Additionally, a cantilever beam with elastic-plastic Ti-6Al-4V material was solved analytically and compared to FEA output; displacement error < 0.3% and peak stress error < 1.1%. Contact patch tests confirmed patch convergence. All benchmark results archived in the DePuy Synthes simulation governance repository (SGR-2022-047). Achieves Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence must be demonstrated for all three QoIs (stiffness, yield force, force at 40 mm) using at least three systematically refined meshes. Richardson extrapolation or GCI must be computed. Discretization error contribution to uval must be quantified.",
      "rationale": "Three mesh densities evaluated: coarse (142k elements), medium (387k elements), fine (891k elements). GCI for stiffness QoI: 0.8% (medium vs. fine), confirming convergence. Medium mesh adopted for ensemble runs, contributing 4.1 N/mm discretization uncertainty to the combined uval. Screw thread region meshed with 6 elements through thread height; contact zone uses quadratic hex elements. Achieves Gradation 3: systematic convergence study with quantified GCI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must be monitored and reported. Newton-Raphson convergence criteria must be documented. Energy and force residuals must fall below 1e-4 relative tolerance for all load steps.",
      "rationale": "All simulations used direct sparse solver (PARDISO) for linear steps and Newton-Raphson with line search for nonlinear increments. Force residual tolerance set to 1e-5; energy residual 1e-6. No unconverged increments recorded across the 33-member ensemble (3 codes × 11 constructs). Solver log files archived. Achieves Gradation 2: documented convergence criteria with archived residual histories."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution procedure (SEP) must be followed by all analysts. Independent peer review of model setup, boundary conditions, and material assignments must be performed and documented before results are accepted.",
      "rationale": "A Simulation Execution Procedure (FDA-SEP-2021-003) was developed and followed by all three modelling teams. Each team's model setup was independently reviewed by a second analyst not involved in model construction. Discrepancies in boundary condition interpretation were identified and resolved during the cross-team harmonisation meeting (documented in meeting minutes MM-2021-09-14). Achieves Gradation 2: SEP followed with documented independent review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of continuum mechanics assumptions (small vs. large strain, contact formulation, material constitutive law) must be documented. Sensitivity of QoIs to model form choices must be assessed.",
      "rationale": "Large-deformation kinematics (updated Lagrangian) adopted given 40 mm prescribed displacement. Ti-6Al-4V modelled with isotropic hardening plasticity (Ramberg-Osgood fit to tensile coupon data, R²=0.997). UHMWPE vertebral body block modelled as nonlinear elastic. Penalty-based frictionless contact at screw-block interface justified by lubricated test conditions; sensitivity study showed <2% QoI change when friction coefficient varied 0–0.15. Model form uncertainty estimated at 1.8% of mean QoI and included in uval. Achieves Gradation 3: documented sensitivity analysis of model form assumptions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and geometric inputs must be traceable to measured data. Uncertainty distributions must be assigned to all influential inputs and propagated through the model. Input uncertainty contribution to uval must be documented.",
      "rationale": "Ti-6Al-4V material properties sourced from coupon testing of the same material lot used for screw manufacturing (n=5 tensile coupons per lot; E=114±3 GPa, σ_y=930±18 MPa). UHMWPE modulus from ASTM D638 testing of block material (n=3; E=0.95±0.08 GPa). Screw geometry from CMM measurements of 5 screws from the production lot (all dimensions within ±0.02 mm of nominal). Monte Carlo propagation of all input distributions performed. Input uncertainty is the dominant contributor (58%) to combined uval. Achieves Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the production device. Sample size must be sufficient to characterise experimental variability. Sample traceability (lot, batch, dimensional inspection) must be documented.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab 1: n=6; Lab 2: n=5). All screws from the same production lot as CMM-inspected samples used for model inputs. UHMWPE blocks from the same supplier lot. Dimensional inspection confirmed all 11 constructs within drawing tolerances. Inter-laboratory coefficient of variation for stiffness QoI = 3.2%, confirming reproducible sample preparation. Achieves Gradation 3: traceable samples with documented inter-laboratory reproducibility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate the ASTM F1717 protocol including loading rate, fixture geometry, and environmental conditions. Multiple loading conditions (e.g., varying offset or load angle) should be evaluated to bound the model's predictive range.",
      "rationale": "Testing performed per ASTM F1717-15 at a single loading rate (5 mm/min) and single anterior offset (50 mm). Environmental conditions (ambient temperature 23±2°C, humidity 50±10% RH) documented and controlled. While the protocol was faithfully executed, only a single test condition was evaluated; the required level of 3 calls for at least two distinct conditions to bound model behaviour across the COU space. This gap is acknowledged and accepted given that the single condition is the regulatory submission condition; a supplementary multi-condition study is planned. Achieves Gradation 2 against a required Gradation 3 — documented as a known shortfall in the decision record.",
      "gapJustification": "Single test condition is the ASTM F1717 regulatory standard condition and is the sole condition relevant to the current 510(k) submission. The risk contribution of this gap is bounded by the conservative acceptance criteria (<10% QoI difference) and the multi-code ensemble approach. Accepted by the credibility assessment team with documented rationale.",
      "id": "https://uofa.net/nagaraja/decision/dr-cou1-noncannulated-2026/factor/test-conditions"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material properties, boundary conditions) must be demonstrably equivalent to the corresponding experimental conditions. Any discrepancies must be quantified and their effect on QoIs assessed.",
      "rationale": "CMM measurements of test constructs used directly to update nominal FEA geometry for each of the 11 constructs (as-built modelling). Material properties assigned from the same lot-specific coupon data used in the model inputs factor. Fixture compliance measured experimentally (load-cell cross-check) and incorporated as a spring boundary condition in the FEA. Residual discrepancy between as-built geometry and FEA geometry < 0.03 mm RMS across all constructs. Sensitivity study confirmed <1% QoI impact of remaining geometric discrepancy. Achieves Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) must be computed for each QoI. Pre-defined acceptance thresholds (<10% relative difference AND E/uval < 1.96) must be evaluated. Results must be presented for each of the three QoIs and each laboratory independently.",
      "rationale": "E/uval computed for all three QoIs at both laboratories: stiffness 0.61 (Lab1), 0.58 (Lab2); yield force 0.74 (Lab1), 0.81 (Lab2); force at 40 mm 0.52 (Lab1), 0.49 (Lab2). All values well below 1.96. Relative differences: stiffness 2.8%, yield force 2.2%, force at 40 mm 1.6% — all below 10% threshold. Pre-defined acceptance criteria satisfied for all QoIs at both laboratories. Results tabulated in validation report VR-2022-NCannulated-001. Achieves Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected QoIs (stiffness, yield force, force at 40 mm displacement) must be demonstrated to be directly relevant to the clinical failure modes and regulatory decision context. Linkage between QoIs and device safety/performance must be documented.",
      "rationale": "Construct stiffness is a surrogate for immediate post-operative stability; yield force maps to the onset of permanent deformation under physiological loading; force at 40 mm displacement characterises energy absorption to failure. All three are required outputs under ASTM F1717 and are cited in FDA guidance (FDA-2021-D-0360) as relevant performance benchmarks for pedicle screw constructs. The linkage between these QoIs and revision surgery risk is documented in the clinical rationale section of the 510(k) submission (Section 8.3). Achieves Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activities must be shown to be representative of the COU in terms of device geometry, loading conditions, material, and regulatory context. Any gaps between the validation scenario and the COU must be identified and their impact bounded.",
      "rationale": "The validation activity directly replicates the COU: same device (non-cannulated 7.5 mm pedicle screw), same test standard (ASTM F1717), same loading mode (static compression-bending), same regulatory submission context (510(k) Class II). The FEA model validated here is the same model used for the design submission prediction. The only identified gap — single test condition (captured under Test conditions factor) — is bounded by the conservative acceptance criteria and does not undermine the overall relevance of the validation activity to the COU. Achieves Gradation 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated pedicle screw F1717 compression-bending) is accepted based on the following structured evidence: (1) All 13 V&V 40 factors have been assessed. Twelve of thirteen factors meet or exceed their required credibility level. (2) The one factor below required level — Test conditions (achieved Gradation 2 vs. required Gradation 3) — is accepted with documented justification: the single test condition is the sole regulatory submission condition per ASTM F1717, the gap is bounded by conservative acceptance criteria, and a supplementary multi-condition study is planned. (3) All three QoIs (stiffness, yield force, force at 40 mm) satisfy both pre-defined acceptance criteria (<10% relative difference AND E/uval < 1.96) at both independent test laboratories. The highest E/uval observed is 0.81, well below the 1.96 threshold. (4) The multi-code ensemble approach (FDA, Ansys, DePuy Synthes) provides additional confidence in the model form and implementation. (5) Uncertainty quantification is complete: input, discretization, model form, and experimental uncertainties are all quantified and combined into uval for each QoI. (6) Provenance is fully traceable from raw experimental data through to validation results. (7) The model risk level (3) is commensurate with the Medium model influence and Medium decision consequence, consistent with ASME V&V 40 Table 1 risk matrix. The assessment team concludes that the FEA modeling framework has sufficient credibility for its intended use in the 510(k) submission for the non-cannulated 7.5 mm pedicle screw.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/decision/dr-cou1-noncannulated-2026/offset/test-conditions",
