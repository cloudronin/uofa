  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-level2-documented-version-control",
      "rationale": "All three FEA platforms (FDA in-house code, Ansys 2022 R2, DePuy Synthes proprietary solver) are under formal version control with documented release notes. Software validation records confirm V&V activities per 21 CFR Part 820 quality system requirements. Test scripts and input decks are archived in a controlled repository with audit trail. SQA Level 2 achieved and meets required level for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-benchmark-suite",
      "rationale": "Numerical code verification was performed using NAFEMS benchmark problems relevant to structural mechanics (linear elastic beam bending, contact mechanics). All three solver implementations passed benchmark suite with errors below 1% relative to analytical solutions. Patch test and convergence studies confirm correct implementation of element formulations used in the pedicle screw model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-gci-less-5pct",
      "rationale": "Mesh convergence study conducted across three refinement levels (coarse: ~18k elements, medium: ~72k elements, fine: ~288k elements) using the Grid Convergence Index (GCI) methodology per Roache. GCI for stiffness QoI: 2.1%; for yield force: 3.4%; for force at 40 mm: 2.8%. All below the 5% acceptance threshold. Richardson extrapolation confirms apparent order of convergence of 1.9, consistent with quadratic element formulation. Medium mesh selected for production runs as convergence is demonstrated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-residual-tolerance",
      "rationale": "Nonlinear solver convergence monitored via force and displacement residual norms. All load steps converged to relative residual tolerance of 1e-6. No load step divergence or unconverged increments observed across the 11-construct ensemble. Iterative linear solver (preconditioned conjugate gradient) residual tolerance set at 1e-8. Solver log files archived and reviewed for anomalies. Achieved level exceeds required minimum."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-independent-review",
      "rationale": "Model setup, boundary condition application, and post-processing procedures were independently reviewed by a second analyst not involved in original model construction. A documented modeling protocol specifying load application, contact definitions, and output extraction was followed for all 11 constructs. Discrepancies identified during review were resolved and documented. Independent verification of three randomly selected constructs confirmed identical QoI values to within floating-point precision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-physics-justification",
      "rationale": "Linear elastic material models are justified for the titanium alloy (Ti-6Al-4V) screw and stainless steel rod under sub-yield loading regimes. Nonlinear geometric effects (large displacement) are included given the 40 mm displacement range. Frictional contact (Coulomb, mu=0.3) between screw-rod interface is physically motivated and consistent with published tribological data for dry metallic contact. Bone substitute (UHMWPE block) modeled as elastic-perfectly plastic, calibrated against published material characterization data. Model form is appropriate for the intended QoIs and loading regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-sensitivity-and-traceability",
      "rationale": "All material properties (elastic modulus, Poisson's ratio, yield strength) sourced from ASTM-compliant material certificates for the specific material lots used in testing. Geometric inputs derived from calibrated CMM measurements of test specimens with documented uncertainty. Sensitivity analysis (one-at-a-time) identified elastic modulus of UHMWPE block and friction coefficient as most influential parameters; uncertainty in these inputs propagated to QoI uncertainty estimates included in E/uval calculation. Input traceability matrix links each model parameter to its source measurement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-lot-traceability",
      "rationale": "N=11 constructs assembled from production-equivalent components with full lot traceability. Six constructs tested at Laboratory 1 (FDA CDRH), five at Laboratory 2 (independent ISO 17025-accredited facility). All components sourced from the same manufacturing lot as the device under review. Dimensional inspection records confirm components within drawing tolerances. Statistical analysis of inter-specimen variability (CV < 8% for all QoIs) confirms acceptable sample homogeneity for validation purposes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-astm-f1717-compliance",
      "rationale": "Testing performed per ASTM F1717-21 standard protocol at a single loading rate (5 mm/min quasi-static) and ambient temperature (23±2°C). Required level 3 calls for multiple test conditions (e.g., varied loading rates or environmental conditions) to bracket physiological variability; only a single test condition was employed. This shortfall is acknowledged and documented. The gap is accepted given that the COU is limited to quasi-static structural performance prediction and the single condition is directly representative of the regulatory submission scenario. Residual uncertainty is captured in the overall E/uval metric.",
      "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/factor/test-conditions"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mapping-table",
      "rationale": "A formal input equivalency mapping table documents correspondence between experimental measurements and model input parameters for all 11 constructs. CMM-measured geometry is used directly in each construct-specific model. Material properties assigned from lot-specific certificates. Torque-controlled assembly procedure replicated in model via pre-tension in fastener elements, calibrated against assembly torque measurements. No unresolved equivalency gaps identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-euval-less-1p96",
      "rationale": "Quantitative output comparison performed using the ASME V&V 40 validation metric E/uval for all three QoIs across all 11 constructs. Results: stiffness E/uval = 0.87 (mean percent difference 4.2%); yield force E/uval = 1.12 (mean percent difference 6.8%); force at 40 mm E/uval = 1.43 (mean percent difference 7.1%). All E/uval values below the pre-established acceptance threshold of 1.96 (95% confidence). All percent differences below 10% bound. Validation metric calculations documented with full uncertainty budget including experimental measurement uncertainty, model parameter uncertainty, and numerical solution uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-clinical-linkage",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly specified by ASTM F1717 and represent the regulatory standard for spinal implant mechanical performance characterization. Clinical linkage is established: construct stiffness relates to load-sharing behavior post-implantation; yield force identifies onset of permanent deformation; force at 40 mm represents ultimate structural integrity under worst-case displacement. These QoIs are the same metrics used in the 510(k) submission performance testing, confirming direct relevance to the regulatory decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-cou-mapping",
      "rationale": "Validation activities directly replicate the COU scenario: same device geometry (non-cannulated 7.5 mm pedicle screw), same loading configuration (ASTM F1717 compression-bending), same material lot, same assembly procedure, and same QoIs as the regulatory submission. Testing conducted across two independent ISO 17025-accredited laboratories to confirm reproducibility. The validation domain fully encompasses the COU domain with no extrapolation required. Multi-laboratory design provides additional confidence in experimental reference data quality."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated 7.5 mm pedicle screw compression-bending prediction) is accepted at Medium assurance level. All 13 V&V 40 factors have been assessed. Twelve of thirteen factors meet or exceed their required credibility levels. One factor (Test conditions) achieved Level 2 against a required Level 3; this shortfall is accepted because (1) the COU is explicitly limited to quasi-static performance at the ASTM F1717 standard condition, (2) the single test condition is directly representative of the regulatory submission scenario, and (3) the residual uncertainty from this limitation is fully captured within the E/uval uncertainty budget. Quantitative validation results demonstrate that all three QoIs (stiffness, yield force, force at 40 mm) satisfy pre-established acceptance bounds: all E/uval values below 1.96 and all percent differences below 10%. The multi-laboratory experimental dataset (N=11 across two ISO 17025-accredited facilities) provides high-confidence reference data. Software quality assurance, numerical verification, and discretization error assessments confirm that computational errors are well-controlled and do not materially affect the validation conclusion. The FEA modeling framework is accepted as credible for supporting the regulatory submission decision for this device and loading condition.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/offset/test-conditions",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/factor/test-conditions",
      "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
    }
  },
