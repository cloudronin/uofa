  "signature": "ed25519:f5e5cfc3b776285ae979bf37b184881a3b0f372887cc8d5180d9916cac693856c09b33df731265e9a3cfd61f7240412bdf60c59db9b2fc24424a4e43d8e3ef0a",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "SQA plan documented; version-controlled code repository with tagged release; regression test suite executed prior to each simulation campaign; all three FEA solvers (FDA in-house, Ansys 2021 R2, DePuy Synthes validated solver) covered by institutional SQA protocols.",
      "rationale": "All three FEA codes used in the ensemble are subject to formal SQA programs. The FDA in-house solver is governed by FDA CDRH software quality management procedures; Ansys 2021 R2 is a commercially validated code with documented QA per ISO 9001:2015; DePuy Synthes internal solver is covered by their design assurance SQA plan (document DS-SQA-2019-007). Version tags (FDA-FEA-v3.4.1, Ansys-2021R2, DS-FEA-v2.1.0) are recorded in the simulation log. Regression test suites with 47 benchmark cases were executed prior to the validation campaign with zero failures. Required level 2 (basic documentation and version control) is exceeded; achieved level 3 reflects additional regression testing and multi-code redundancy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Each solver verified against at least two analytic benchmark solutions relevant to structural mechanics (Euler-Bernoulli beam bending, Hertzian contact); maximum deviation from analytic solution less than 1% for all benchmarks.",
      "rationale": "Code verification was performed for all three solvers against (1) an Euler-Bernoulli cantilever beam under end-point load (analytic solution available in closed form) and (2) a Hertzian contact problem between a sphere and flat plate. Deviations from analytic solutions were 0.31%, 0.47%, and 0.28% for the FDA, Ansys, and DePuy Synthes codes respectively for the beam benchmark, and 0.62%, 0.55%, and 0.71% for the contact benchmark — all well within the 1% acceptance threshold. Additionally, a manufactured solution verification (Method of Manufactured Solutions) was applied to the FDA solver for the nonlinear material subroutine, confirming second-order convergence in the L2 norm. Achieved level 3 reflects the MMS verification in addition to standard benchmark comparisons."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Mesh convergence study demonstrates that QoI values (stiffness, yield force, force at 40 mm) change by less than 2% upon halving element edge length from the production mesh; discretization error estimated via Richardson extrapolation and reported as a fraction of total validation uncertainty.",
      "rationale": "A systematic mesh convergence study was conducted using four mesh densities (coarse: 18k elements, medium: 52k elements, fine: 148k elements, very fine: 421k elements). Richardson extrapolation applied to the fine and very fine meshes yielded an estimated discretization error of 0.9% for stiffness, 1.1% for yield force, and 1.3% for force at 40 mm — all below the 2% threshold. The production mesh (fine, 148k elements) was selected as the best balance of accuracy and computational cost. Discretization error contributes 12% of total validation uncertainty budget. Tetrahedral elements with mid-side nodes (TET10) used throughout; contact interfaces meshed with 0.15 mm characteristic length at screw-rod interface. Achieved level 3 reflects formal Richardson extrapolation with error budget integration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative solver convergence criteria documented; residual norm tolerance set to 1e-6 or tighter; energy norm convergence monitored at each load step; solver error estimated to be less than 0.5% of QoI.",
      "rationale": "All simulations used a Newton-Raphson iterative solver with displacement and force residual convergence tolerances of 1e-7 and 1e-6 respectively. Energy norm convergence was monitored at each of 200 equal load increments; no convergence failures occurred across the 33 simulation runs (11 constructs × 3 codes). Solver error was estimated by comparing solutions at tolerance 1e-6 versus 1e-8 for three representative constructs; maximum QoI difference was 0.18%, confirming solver error is negligible relative to total uncertainty. Achieved level 2 meets the required level; escalation to level 3 was not warranted given the dominance of other uncertainty sources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Simulation inputs reviewed by independent analyst; input deck version-controlled and archived; pre-simulation checklist completed and signed for each run; cross-code comparison used to detect operator-induced inconsistencies.",
      "rationale": "A formal use-error mitigation program was implemented. Each simulation input deck was independently reviewed by a second analyst not involved in deck preparation; discrepancies were resolved prior to execution. Input decks are stored in a version-controlled repository (Git, commit hashes recorded in simulation log). A 42-item pre-simulation checklist (boundary conditions, material assignments, contact definitions, load application, output requests) was completed and digitally signed for each of the 33 runs. Cross-code comparison served as an additional use-error detection mechanism: QoI discrepancies exceeding 3% between any two codes triggered a mandatory input review. Two such discrepancies were identified and traced to incorrect titanium alloy density assignment in one Ansys run; the run was corrected and re-executed. Achieved level 3 reflects the independent review, checklist, and cross-code verification protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Model form assumptions documented and justified; sensitivity of QoI to model form choices (contact formulation, material model, geometric nonlinearity) assessed; model form uncertainty included in total uncertainty budget.",
      "rationale": "The model form includes: (1) bilinear isotropic hardening plasticity for Ti-6Al-4V screw and rod (justified by uniaxial tensile characterization data); (2) frictionless contact at screw-rod interface with augmented Lagrangian formulation (justified by lubricated test conditions per ASTM F1717 protocol); (3) geometric nonlinearity (large displacement) activated given expected deflections up to 40 mm. Model form sensitivity analysis compared bilinear vs. Ramberg-Osgood plasticity: QoI differences of 1.2–2.4%, within uncertainty bounds. Frictionless vs. frictional contact (mu=0.15) comparison showed 0.8% difference in stiffness, 1.6% in yield force. Model form uncertainty estimated as 2.1% of mean QoI and included in the total uncertainty budget. The ensemble of three independent codes using consistent model form assumptions provides additional confidence. Required level 3 (model form uncertainty quantified and included in budget) is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "All material properties and geometric inputs sourced from traceable measurements; input uncertainty characterized with probability distributions; sensitivity analysis identifies dominant input contributors; input uncertainty propagated to QoI uncertainty.",
      "rationale": "Material inputs for Ti-6Al-4V (elastic modulus, yield strength, tangent modulus) were derived from 15 tensile coupon tests performed per ASTM E8; distributions fit as normal (E: mean 114.2 GPa, CV 1.8%; yield strength: mean 896 MPa, CV 2.3%). Geometric inputs (screw outer diameter, core diameter, thread pitch, rod diameter) were characterized from coordinate measuring machine (CMM) measurements of 20 production screws and rods; tolerances consistent with device drawing specifications. UHMWPE block modulus sourced from supplier data sheet with 5% uncertainty. Sobol sensitivity indices identified screw core diameter (S1=0.31) and Ti-6Al-4V yield strength (S1=0.27) as dominant contributors to yield force uncertainty. Total input uncertainty contributes 58% of the total validation uncertainty budget. All input distributions are archived in dataset https://uofa.net/synth/data/nagaraja-material-characterization. Required level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Test samples are production-representative; sample dimensions measured and recorded pre-test; N>=10 samples; sample-to-sample variability characterized and incorporated into validation uncertainty.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested; all samples were production-representative devices drawn from the same manufacturing lot as the commercial product (lot number NC-7.5-2017-L04). Pre-test CMM measurements confirmed all 11 constructs met dimensional specifications; measured dimensions were used as direct inputs to the corresponding FEA models, enabling specimen-specific simulation. Sample-to-sample variability in stiffness was 4.1% CV across the 11 constructs; this variability is captured in the experimental uncertainty term. Two independent laboratories (FDA CDRH Biomedical Physics Branch and DePuy Synthes Biomechanics Lab) each tested a subset (Lab A: n=6, Lab B: n=5); inter-laboratory agreement was within 3.2% for all QoI, confirming reproducibility. Achieved level 3 reflects specimen-specific simulation and dual-laboratory testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Test conditions match COU conditions; multiple loading rates or environmental conditions explored; test condition uncertainty quantified.",
      "rationale": "Testing was conducted strictly per ASTM F1717 static compression-bending protocol at a single displacement rate of 5 mm/min at ambient temperature (23 +/- 2 degrees C). While the test conditions are fully standardized and reproducible, only a single loading rate and temperature condition was explored, limiting the achieved level to 2. The required level for this COU at model risk level 3 is 3; this factor therefore does not fully meet the required level. This known gap is documented in the decision record and accepted on the basis that: (1) the ASTM F1717 protocol is the regulatory standard and the COU is explicitly limited to static F1717 conditions; (2) rate-dependence is negligible for quasi-static titanium alloy testing; (3) the decision consequence is Medium and the model influence is Medium, so the overall credibility of the package is maintained by the strong performance of the remaining 12 factors. This constitutes the single documented below-requirement factor referenced in the COU description.",
      "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/factor/test-conditions"
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "FEA inputs demonstrably equivalent to experimental conditions; boundary conditions, loading, and fixation replicated in model; equivalency documented for each input parameter.",
      "rationale": "A parameter-by-parameter equivalency assessment was conducted for all 23 model input parameters against their experimental counterparts. Boundary conditions (fixed UHMWPE block base, applied displacement at superior fixture) are replicated exactly in the FEA model using kinematic coupling constraints. Applied displacement rate in FEA is quasi-static (implicit solver, rate-independent material model), consistent with the 5 mm/min experimental rate at which inertial effects are negligible (verified by ratio of kinetic to strain energy < 0.001). Fixture stiffness was measured experimentally (1840 N/mm) and incorporated as a spring element in the FEA model. Screw-rod assembly torque was not replicated in the model (contact assumed fully engaged); sensitivity analysis showed <0.5% effect on QoI. All 23 parameters documented in equivalency matrix (archived as supplementary material to dataset https://uofa.net/synth/data/nagaraja-fea-outputs-ensemble). Achieved level 3 reflects the comprehensive equivalency matrix and fixture stiffness characterization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; total validation uncertainty uval computed per ASME V&V 40 methodology; comparison passes E/uval < 1.96 for all QoI; percentage difference less than 10% for all QoI.",
      "rationale": "Output comparison was performed using the validation metric E/uval as defined in ASME V&V 40 Section 6. For each of the three QoI: stiffness (E/uval = 0.87, percentage difference 4.2%), yield force (E/uval = 1.27, percentage difference 6.1%), force at 40 mm (E/uval = 1.54, percentage difference 7.8%). All three QoI pass both acceptance criteria (E/uval < 1.96 and percentage difference < 10%). Total validation uncertainty uval was computed as the root-sum-square of experimental measurement uncertainty (u_exp), model input uncertainty (u_input), model form uncertainty (u_form), and discretization error (u_disc) per ASME V&V 40 Appendix B. Ensemble agreement across three independent codes (mean inter-code spread 1.8% for stiffness, 2.3% for yield force, 2.9% for force at 40 mm) provides additional confidence in the comparison. Required level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoI directly linked to COU decision; clinical relevance of each QoI documented; QoI selection justified against regulatory requirements and failure modes.",
      "rationale": "Three QoI were selected: construct stiffness (N/mm), yield force (N), and force at 40 mm displacement (N). Their relevance is established as follows: (1) Construct stiffness is the primary regulatory QoI per FDA guidance for pedicle screw 510(k) submissions and directly relates to load-sharing between implant and bone graft. (2) Yield force marks the onset of permanent deformation; exceeding yield in vivo leads to progressive deformation and potential fatigue failure, making it directly relevant to device safety. (3) Force at 40 mm displacement characterizes post-yield structural reserve, relevant to catastrophic failure assessment. All three QoI are explicitly required by ASTM F1717 and referenced in FDA guidance document K143ggg. Clinical failure mode analysis (FMEA, document NM-FMEA-2017-003) confirms these QoI are the dominant predictors of in vivo mechanical failure. Achieved level 3 reflects the documented FMEA linkage and regulatory traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation activity conditions match COU conditions; any differences between validation and COU documented and justified; validation activity directly supports the intended use claim.",
      "rationale": "The validation activity (ASTM F1717 static compression-bending of N=11 non-cannulated 7.5 mm pedicle screw constructs) is directly aligned with the COU (FEA prediction of F1717 static compression-bending for the same device). The device tested is identical to the device in the COU (same lot, same geometry, same material specification). The loading mode (compression-bending), boundary conditions (ASTM F1717 fixture), and QoI (stiffness, yield force, force at 40 mm) in the validation activity are identical to those in the COU. The only difference is that the validation activity uses production-equivalent samples rather than in-service implants, which is appropriate and expected for a pre-market credibility assessment. This difference is documented and accepted. The COU explicitly states that the model is used to support the 510(k) submission for the non-cannulated design; the validation activity directly provides the evidence required to support this claim. Dual-laboratory execution increases the generalizability of the validation evidence. Required level 3 is met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 credibility factors for COU1 (non-cannulated 7.5 mm pedicle screw F1717 compression-bending prediction). Twelve of thirteen factors meet or exceed their required credibility levels. The single exception is the Test conditions factor (required level 3, achieved level 2), attributable to testing at a single displacement rate and temperature per ASTM F1717 protocol. This gap is accepted on the following grounds: (1) the ASTM F1717 protocol is the applicable regulatory standard and the COU is explicitly scoped to static F1717 conditions only — rate and temperature variation are outside the intended use; (2) quasi-static rate-independence of titanium alloy mechanical behavior at ambient temperature is well-established in the literature, rendering multi-rate testing non-informative for this COU; (3) the overall model risk level is 3 (medium), and the combination of medium model influence and medium decision consequence means that strong performance across the remaining 12 factors is sufficient to establish adequate credibility for the regulatory decision. The quantitative validation results are compelling: all three QoI (stiffness, yield force, force at 40 mm displacement) pass both acceptance criteria (E/uval < 1.96 and percentage difference < 10%) across N=11 constructs tested in two independent laboratories. The FEA ensemble of three independent codes (FDA, Ansys, DePuy Synthes) provides redundancy that further strengthens confidence. Uncertainty quantification is complete, traceable, and integrated across all uncertainty sources per ASME V&V 40 Appendix B. The decision is Accepted; the FEA modeling framework is deemed credible for its intended use in supporting the 510(k) submission for the non-cannulated pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/offset/test-conditions",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/factor/test-conditions",
      "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
    }
  },
