  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5",
      "rationale": "CFD solver (ANSYS Fluent 2023R2) operates under a documented software quality management plan compliant with FDA 21 CFR Part 11. Version control, regression test suite (1,200 cases), and change management records are current. Independent SQA audit completed 2024-01. Achieved Gradation 3 meets the MRL-5 required level of 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Manufactured-solution verification completed for the Navier-Stokes solver and the modified power-law hemolysis transport equation. Observed order of accuracy (1.97 for velocity, 1.89 for scalar hemolysis) is consistent with the nominal second-order scheme. Code verification report archived at https://uofa.net/synth/evidence/code-verification-report-2024. Achieved level 4 exceeds required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5",
      "rationale": "Three-level mesh refinement study performed (5.2M, 14.7M, 38.1M cells) following ASME V&V 20 Richardson extrapolation protocol. Grid convergence index (GCI) for hemolysis index: 3.1% on fine mesh. Temporal discretization verified with three time-step levels; GCI_time < 1.8%. Discretization uncertainty fully quantified and propagated into the Monte Carlo UQ ensemble. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "Bench test conditions (fluid temperature 37±0.5°C, hematocrit 33±1%, inlet flow rates ±0.5 L/min, rotational speed ±10 RPM) are documented in the experimental test plan and traceable to NIST-calibrated instrumentation. Five operating points span the clinical VAD operating envelope. Measurement uncertainty quantified per ISO GUM and included in UQ propagation. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "Quantitative comparison performed using ASME V&V 20 validation metric. For hemolysis index across 5 operating points: mean absolute relative error 6.8%, all predictions within combined simulation and experimental uncertainty intervals. Validation metric U_val computed; model form error estimated. Pressure rise: MARE 2.3%. PIV velocity: normalized RMS error 4.1%. All comparisons documented in validation report https://uofa.net/synth/evidence/validation-report-2024. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "The primary QOI — normalized index of hemolysis (NIH, g/100L) — is the clinically accepted metric for VAD hemolysis assessment per ASTM F1841. Secondary QOIs (pump head, flow-weighted shear stress exposure) are mechanistically linked to hemolysis prediction. QOI traceability matrix maps each simulation output to a clinical decision criterion. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry — the same geometry as the COU — with bovine blood at physiological hematocrit under the same 5 flow-speed operating points. Geometric fidelity: identical CAD. Fluid analogy: bovine blood power-law parameters within 5% of human blood. Operating conditions: fully within COU envelope. Validation relevance matrix completed per Morrison framework Table 4. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence monitored via residual norms (all < 1e-6) and integrated QOI stabilization (< 0.1% change over final 500 iterations). Round-off error assessed negligible for double-precision arithmetic at operating mesh sizes. Solver error budget documented and shown to be sub-dominant relative to discretization and model-form uncertainty. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "Simulation setup reviewed by an independent analyst not involved in model construction. Checklist-based review covers boundary condition specification, turbulence model selection, hemolysis model coefficient sourcing, and post-processing scripts. Two minor discrepancies identified and corrected prior to final simulation runs. Review record archived at https://uofa.net/synth/evidence/use-error-review-2024. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "Model form uncertainty assessed for (a) turbulence closure: SST k-ω selected based on benchmark comparisons; sensitivity to RSM and k-ε models quantified (±9% hemolysis index); (b) hemolysis model: Giersiepen-Wurzinger vs. Arora model comparison shows ±12% spread, incorporated as model-form uncertainty interval; (c) non-Newtonian rheology: Carreau model vs. Newtonian sensitivity ±3%. All model-form uncertainties propagated through Monte Carlo ensemble. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "All 14 model input parameters assigned probability distributions based on literature data and experimental measurements. Key uncertain inputs: hematocrit (Beta distribution, mean 33%, CV 3%), blood viscosity coefficients (log-normal, CV 8%), hemolysis model exponents (uniform ±15% of nominal). Monte Carlo ensemble of 5,000 runs propagates full input uncertainty to hemolysis index predictions. Sensitivity indices (Sobol first-order) computed; top three inputs account for 78% of output variance. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5",
      "rationale": "Bench hemolysis experiments conducted with n=6 independent blood samples per operating point (total 30 test runs). Sample-to-sample variability quantified (CV < 11% for NIH). Samples sourced from three donors to capture inter-donor variability. Statistical power analysis confirms adequate sample size to detect a 15% hemolysis difference at 80% power. Experimental uncertainty reported as 95% confidence intervals. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5",
      "rationale": "Boundary conditions applied in simulation are derived directly from experimentally measured inlet velocity profiles (LDV data) and outlet pressure conditions. Rotational speed and flow rate are matched to bench test values within measurement uncertainty. Fluid property parameters (density, viscosity curve) are matched to the bovine blood batch used in experiments via rheometry. Input equivalency matrix completed and reviewed. Achieved level 3 meets required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed. In every case the achieved credibility level meets or exceeds the required level for Model Risk Level 5. Specifically: discretization error, output comparison, relevance of validation activities, model form, and model inputs — the five factors carrying required level 4 — all achieved level 4 or above. The remaining eight factors required at level 3 were all achieved at level 3 or higher. Monte Carlo uncertainty quantification (5,000 runs) propagates input, model-form, and discretization uncertainties; the 95th-percentile hemolysis prediction remains below the absolute clinical threshold (NIH < 0.01 g/100L) at all 5 operating points. Validation metric U_val demonstrates model predictions are within combined uncertainty at all validation points. Independent use-error review and software quality audit are current. The evidence body is complete, traceable, and sufficient to support regulatory submission for the Class III VAD indication. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
