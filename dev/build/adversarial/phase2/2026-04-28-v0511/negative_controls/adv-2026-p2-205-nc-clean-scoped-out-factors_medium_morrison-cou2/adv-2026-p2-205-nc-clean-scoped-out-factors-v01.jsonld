  "signature": "ed25519:3cf9afc04a08c6d0a67ced086eff530eb201332ffc33490242c06a04e90f64677d4bd1b4148d1e3603247913475e488b08a71393c12c2c468b46128e0a038d0a",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-level4",
      "rationale": "The CFD solver (OpenFOAM v9) is under version-controlled configuration management. A complete audit trail of solver build, dependency hashes, and regression test suite (>200 test cases, 100% pass rate) was reviewed against FDA guidance for Class III device software. All defect reports are tracked in a formal issue register with documented resolution. Achieved Level 4 satisfies the MRL-5 required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/ncv-mrl5-level4",
      "rationale": "Method of manufactured solutions (MMS) was applied to the incompressible Navier-Stokes solver and the scalar hemolysis transport equation. Observed order of accuracy (2.01 ± 0.05) is consistent with the theoretical second-order spatial discretization. Temporal discretization verified to first order via temporal refinement study. Independent code-to-code comparison against Fluent 2023R2 at two operating points yielded velocity field differences below 0.8% RMS. Achieved Level 5 exceeds the MRL-5 required Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/disc-error-mrl5-level4",
      "rationale": "Three systematically refined meshes (3.2M, 12.8M, 51.2M cells, refinement ratio 1.587) were used for Richardson extrapolation. Grid Convergence Index (GCI) at the fine mesh is 1.3% for hemolysis index at the design operating point and below 2.1% across all five operating conditions. Wall y+ values are maintained below 1.0 on all blood-contacting surfaces. Achieved Level 4 meets the MRL-5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5-level4",
      "rationale": "Bench test conditions (inlet flow rate, impeller speed, fluid temperature, inlet pressure) were matched to CFD boundary conditions within documented tolerances: flow rate ±0.5%, rotational speed ±0.2%, temperature ±0.5°C. All five operating points in the COU envelope are represented in the experimental dataset. Measurement uncertainty for each boundary condition was propagated into the CFD inputs via Monte Carlo. Achieved Level 4 meets the MRL-5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5-level5",
      "rationale": "CFD-predicted hemolysis index (HI) was compared against experimental measurements at all five operating points using porcine blood. Mean absolute error is 6.2% across operating points. All CFD predictions fall within the 95% experimental uncertainty band. Bland-Altman analysis shows no systematic bias (mean difference 0.0003, limits of agreement ±0.0021). Monte Carlo prediction intervals (10,000 samples) fully encompass experimental scatter. Achieved Level 5 meets the MRL-5 required Level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5-level4",
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is the same scalar used in the regulatory submission and maps directly to the clinical endpoint (plasma-free hemoglobin accumulation). Sensitivity analysis confirms that NIH is the dominant output governing the accept/reject decision; secondary QoIs (wall shear stress distribution, recirculation zone volume) are documented as supporting evidence. The QoI chain from CFD output to clinical harm is fully documented. Achieved Level 4 meets the MRL-5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/val-relevance-mrl5-level4",
      "rationale": "Validation experiments used the identical FDA generic centrifugal pump geometry at the same five flow-speed combinations defined in the COU. Fluid was porcine blood (hematocrit 35 ± 2%), which is an accepted surrogate for human blood in hemolysis studies per ASTM F1841. The validation domain fully overlaps the COU operating envelope with no extrapolation required. Gap analysis documents minor differences in inlet cannula geometry (COU uses patient-specific cannula) and assigns residual uncertainty bounds accordingly. Achieved Level 4 meets the MRL-5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-scoped-out",
      "rationale": "Numerical solver error (iterative convergence and round-off contributions) is scoped out because the solver's iterative residuals are driven below 1×10⁻⁸ for all equations at every operating point, placing solver error at least two orders of magnitude below the discretization error quantified under the Discretization Error factor. The contribution to total numerical uncertainty is therefore negligible relative to the GCI-based discretization bound. This scope-out is consistent with ASME V&V 40 guidance that permits omission of a factor when its contribution is demonstrably dominated by another quantified factor; the dominating factor (Discretization Error) is fully assessed at Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-scoped-out",
      "rationale": "Use error is scoped out on the basis that all simulation activities are executed under a formal simulation governance procedure (SGP-CFD-003 rev B) that mandates independent peer review of all boundary condition inputs, mesh setup, and post-processing scripts prior to result acceptance. The SGP includes a mandatory independent re-run check at one operating point per study. These procedural controls are documented in the Software Quality Assurance factor (assessed at Level 4) and eliminate the class of operator-induced errors that the Use Error factor is designed to capture. Scoping out Use Error is therefore non-duplicative and justified by the existing SQA coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5-level5",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger correlation) was assessed against three alternative constitutive models (Arora, Taskin, and Zhang formulations) at all five operating points. Sensitivity of predicted HI to model-form choice was quantified; the power-law model produces predictions within 8% of the ensemble mean across all formulations. Model-form uncertainty is explicitly included in the Monte Carlo UQ as an additive epistemic term bounded by the inter-model spread. The turbulence model (SST k-ω) was validated against PIV velocity field data from the FDA benchmark dataset (mean velocity error < 4%). Achieved Level 5 meets the MRL-5 required Level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5-level4",
      "rationale": "All model input parameters (fluid viscosity, density, hemolysis model coefficients, rotational speed, flow rates) were characterized with documented uncertainty distributions. Viscosity was measured at 37°C for each blood batch (CV < 3%). Hemolysis model coefficients were drawn from a curated literature ensemble of 12 independent calibration datasets; coefficient uncertainty is represented as a multivariate normal distribution. Monte Carlo propagation (10,000 samples) of all input uncertainties yields 95% prediction intervals that are reported alongside point predictions. Achieved Level 4 meets the MRL-5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5-level4",
      "rationale": "Experiments used freshly collected porcine blood from a single abattoir source, processed within 4 hours of collection and characterized for hematocrit (35 ± 2%), plasma-free hemoglobin baseline (< 5 mg/dL), and osmolality (290 ± 10 mOsm/kg). Three independent blood batches were used across the five operating points to assess inter-batch variability. Batch-to-batch HI variability was 7.1% (CV), which is incorporated into the experimental uncertainty bands used for output comparison. Achieved Level 4 meets the MRL-5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/equiv-inputs-scoped-out",
      "rationale": "Equivalency of input parameters between the validation experiment and the COU is scoped out as a standalone factor because the Test Conditions factor (assessed at Level 4) and the Model Inputs factor (assessed at Level 4) together provide comprehensive coverage of this concern. The Test Conditions factor documents that all five COU operating points are represented in the validation dataset with boundary conditions matched within stated tolerances, while the Model Inputs factor quantifies and propagates all parametric uncertainties via Monte Carlo. No additional input parameters exist in the COU that are absent from the validation activity; therefore a separate Equivalency of Input Parameters assessment would be entirely redundant with already-assessed evidence and is formally scoped out to avoid double-counting."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-nc5-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 ASME V&V 40 factors for the Morrison COU2 VAD hemolysis prediction at Model Risk Level 5. Ten factors were fully assessed: all achieved levels meet or exceed the required levels for MRL 5, including Output Comparison and Model Form at the maximum Level 5. Three factors (Numerical Solver Error, Use Error, and Equivalency of Input Parameters) were formally scoped out with documented rationale demonstrating that each is either dominated by a quantified sibling factor or fully subsumed by the combined coverage of two assessed factors. No factor was left unaddressed without justification. Monte Carlo uncertainty quantification (10,000 samples) was performed propagating input, model-form, and boundary condition uncertainties; all 95% prediction intervals for hemolysis index remain below the absolute clinical threshold across all five COU operating points. The provenance chain is complete from raw experimental measurements through post-processing to final HI predictions. The panel concludes that the body of evidence provides sufficient credibility for the CFD model to support the regulatory submission for the Class III VAD device, and the decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
