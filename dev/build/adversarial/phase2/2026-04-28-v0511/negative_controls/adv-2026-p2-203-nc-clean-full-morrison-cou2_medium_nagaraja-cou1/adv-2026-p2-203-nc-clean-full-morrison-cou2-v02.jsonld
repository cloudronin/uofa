  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-level5-full-iso9001-vv-plan",
      "rationale": "The FEA solver suite (Ansys Mechanical 2024 R1, FDA in-house FEA code v4.2) operates under ISO 9001:2015-certified quality management systems. All solver versions are under formal configuration control with SHA-256-tagged release artefacts. A dedicated V&V plan document (VVP-2024-001) covers test matrices for linear statics, contact mechanics, and large-deformation plasticity. Independent code-to-code comparisons against three published benchmark problems (NAFEMS LE1, LE10, and the Hertz contact patch benchmark) are archived. Audit trails are complete and traceable to individual analyst sign-offs. Achieves Gradation 5 per ASME V&V 40 Table 5-1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-level5-manufactured-solution",
      "rationale": "Method of Manufactured Solutions (MMS) was applied to the elastoplastic constitutive model used for Ti-6Al-4V. Observed convergence rates match theoretical rates (2nd-order spatial, 1st-order temporal for quasi-static implicit) within 0.3 % across three mesh refinement levels. Code-to-code agreement between the FDA solver and Ansys for the identical mesh and boundary conditions is within 0.12 % for all QoIs. Formal verification report VR-CODE-2024-003 is archived and peer-reviewed. Achieves Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-level5-richardson-extrapolation",
      "rationale": "Richardson extrapolation was performed on three systematically refined meshes (coarse: 28 k elements, medium: 112 k elements, fine: 448 k elements; refinement ratio r=2). Grid Convergence Index (GCI) for construct stiffness: GCI_fine = 0.18 %, GCI_medium = 0.72 %. Asymptotic range confirmed (GCI_fine/r^p × GCI_medium ≈ 1.01). The production mesh (112 k elements, hex-dominant with 20-node serendipity elements at the screw-rod interface) is validated at the medium level with a documented discretization uncertainty of ±0.72 % incorporated into the total uncertainty budget. Achieves Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-level5-iterative-tolerance-study",
      "rationale": "Iterative solver convergence tolerance was systematically varied from 1×10⁻⁴ to 1×10⁻⁸ for the nonlinear Newton-Raphson loop. QoI sensitivity to solver tolerance is less than 0.05 % between 1×10⁻⁶ and 1×10⁻⁸; production runs use 1×10⁻⁷. Residual force norms and energy norms are both monitored and archived for every production analysis. Contact penetration is bounded at 0.001 mm. All solver logs are retained in the project data management system. Achieves Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-level5-independent-reanalysis",
      "rationale": "An independent analyst (not involved in model development) performed a full re-analysis using only the archived input decks and the documented modelling protocol (MP-2024-002). Results agreed with primary analyst outputs within 0.4 % for all three QoIs. A formal checklist (CL-USE-2024-001) covering boundary condition assignment, material property mapping, contact pair definition, and load application sequence was completed and signed off by two reviewers. All deviations from the checklist were documented and resolved prior to submission. Achieves Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-level5-physics-justification-and-sensitivity",
      "rationale": "The constitutive model (isotropic J2 plasticity with bilinear hardening for Ti-6Al-4V; linear elastic for UHMWPE test blocks) was selected based on a documented physics-justification memo (PJ-2024-001) that reviewed four candidate material models. A model-form uncertainty study compared J2 plasticity against a Chaboche kinematic-hardening model; QoI differences were less than 1.8 % for monotonic loading, confirming that model-form uncertainty is small relative to experimental scatter. Frictional contact (μ=0.2, Coulomb) was verified against torque-displacement measurements from a dedicated sub-model experiment. Achieves Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-level5-measured-distributions-uq",
      "rationale": "All material properties (E, σ_y, tangent modulus) were measured from Lot A Ti-6Al-4V coupons (n=10 tensile tests per ASTM E8) and characterised as probability distributions (E: Normal, μ=114.2 GPa, σ=1.8 GPa; σ_y: Normal, μ=924 MPa, σ=12 MPa). Geometric tolerances were measured via CMM on all 11 test constructs and incorporated as input uncertainty distributions. A 10 000-sample Monte Carlo propagation was executed using the characterised input distributions; results are archived as dataset uq-monte-carlo-10k-runs. All input data are traceable to calibrated instruments with current NIST-traceable calibration certificates. Achieves Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-level5-representative-lot-traceability",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested: six at Laboratory 1 (ISO 17025 accredited) and five at Laboratory 2 (ISO 17025 accredited). All constructs were manufactured from the same production lot as the design-submission device, with full dimensional inspection reports (CMM, n=11) confirming conformance to drawing tolerances. Material certificates (mill certs, chemical composition, mechanical properties) are archived. Sample size is sufficient to characterise inter-construct variability for the three QoIs; coefficient of variation for stiffness across the 11 constructs is 4.2 %. Achieves Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-level5-protocol-fidelity-and-env",
      "rationale": "Testing was conducted strictly per ASTM F1717-21 at both laboratories. Load frame calibration (NIST-traceable, ±0.5 % accuracy class), displacement transducer calibration (±0.01 mm), and environmental conditions (23 ± 2 °C, ambient humidity) are documented in the laboratory test reports. A protocol-fidelity checklist was completed at each laboratory prior to testing. Inter-laboratory reproducibility was assessed: mean QoI differences between Lab 1 and Lab 2 are less than 2.1 % for all three QoIs, confirming consistent test execution. All raw load-displacement data are archived in the project DMS with full audit trails. Achieves Gradation 5. Note: the COU1 Nagaraja package identified a single-test-condition limitation; the present MRL-5 package addresses this by demonstrating protocol fidelity across two independent laboratories and confirming that the single ASTM F1717 condition is the appropriate and complete scope for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-level5-direct-measurement-mapping",
      "rationale": "A formal input-equivalency matrix (IEM-2024-001) maps every FEA model input parameter to its experimentally measured counterpart. Geometric inputs were taken directly from CMM measurements of the tested constructs (not nominal CAD values). Material properties were taken from the same lot-specific coupon tests used to characterise input distributions. Boundary conditions (fixture stiffness, load application point) were measured from the test machine compliance characterisation report. No assumed or literature-derived values were used for primary model inputs; all secondary inputs (e.g., UHMWPE block modulus) were verified against supplier data sheets and sensitivity-analysed. Achieves Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-level5-quantitative-metric-with-uq",
      "rationale": "Quantitative validation metrics were computed for all three QoIs using the ASME V&V 20 area metric and the normalised validation metric E/u_val. For stiffness: E/u_val = 0.042 (pass, threshold 1.96). For yield force: relative error = 0.087 % (pass, threshold 10 %). For force at 40 mm: E/u_val = 1.31 (pass, threshold 1.96). Total uncertainty u_val incorporates experimental measurement uncertainty (Type A and Type B), model input uncertainty (from UQ propagation), and numerical discretization uncertainty (from GCI analysis). All metric calculations are documented in the validation assessment report VAR-2024-001 and independently reviewed. Achieves Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-level5-clinical-linkage-documented",
      "rationale": "A formal QoI-to-clinical-endpoint linkage document (QCL-2024-001) demonstrates that construct stiffness, yield force, and force at 40 mm displacement are the mechanically governing quantities for the clinical failure modes of interest (fatigue crack initiation, screw-rod interface loosening, and gross plastic deformation). The linkage was reviewed and endorsed by a clinical biomechanics subject matter expert (SME). The three QoIs are identical to those specified in the pre-submission FDA Q-Submission feedback (Q-Sub 2023-Q-004521). No surrogate or proxy quantities are used. Achieves Gradation 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-level5-cou-alignment-matrix",
      "rationale": "A COU-alignment matrix (CAM-2024-001) maps every dimension of the COU (device geometry, material, loading mode, boundary conditions, QoIs, patient population surrogate) to the corresponding validation activity. The validation constructs are from the same production lot as the submission device. The ASTM F1717 test protocol is the regulatory standard for spinal implant construct testing and is directly applicable to the clinical loading scenario. The FEA model geometry was built from the identical CAD files used for device manufacturing. No extrapolation beyond the validated domain is required for the COU. The alignment matrix was reviewed by the lead V&V engineer and the regulatory affairs lead. Achieves Gradation 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-mrl5-accepted-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors at the rigor level required for Model Risk Level 5 (High consequence, High model influence). All 13 factors achieved Gradation 5, meeting or exceeding the required level. Key evidence supporting acceptance: (1) All three QoIs (construct stiffness, yield force, force at 40 mm displacement) pass their pre-established quantitative acceptance criteria with comfortable margin — E/u_val values of 0.042 and 1.31 against a threshold of 1.96, and a relative error of 0.087 % against a 10 % threshold. (2) The total uncertainty budget is fully characterised, incorporating experimental measurement uncertainty (Type A and B), model input uncertainty from a 10 000-sample Monte Carlo propagation, and numerical discretization uncertainty from Richardson extrapolation (GCI_fine = 0.18 %). (3) Global sensitivity analysis (Sobol indices) confirms that the dominant uncertainty contributors are well-understood physical parameters (elastic modulus, screw geometry) with no unexpected high-order interactions. (4) The validation dataset spans two independent ISO 17025-accredited laboratories with inter-laboratory QoI agreement within 2.1 %, providing strong evidence of test reproducibility. (5) An independent re-analysis confirmed model reproducibility within 0.4 % for all QoIs, demonstrating robustness against use error. (6) The COU-alignment matrix confirms that no extrapolation beyond the validated domain is required. (7) The QoI-to-clinical-endpoint linkage is documented and endorsed by a clinical biomechanics SME, and the QoI set is consistent with FDA Q-Submission feedback. The credibility assessment team unanimously concludes that the simulation evidence is sufficiently credible to support the intended regulatory decision for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
