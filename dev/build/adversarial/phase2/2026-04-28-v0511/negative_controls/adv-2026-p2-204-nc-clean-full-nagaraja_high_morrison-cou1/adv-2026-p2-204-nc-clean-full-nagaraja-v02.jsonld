  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-ortho-cou1-tibial",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray cementless fixation (Class II TKA)",
    "description": "A finite element analysis (FEA) model is used to evaluate the sensitivity of tibial tray micromotion to variations in implant geometry and bone density for a cementless TKA device. Model influence is MEDIUM (bench and cadaveric testing confirm relative rankings); decision consequence is HIGH (incorrect fixation tolerance decision could lead to aseptic loosening and revision surgery). Model Risk Level 3.",
    "intendedUse": "Use FEA to identify worst-case micromotion conditions across 6 loading scenarios for a Class II cementless TKA tibial tray. Results compared against cadaveric benchmark micromotion data using relative micromotion index (peak interface micromotion < 150 µm acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
