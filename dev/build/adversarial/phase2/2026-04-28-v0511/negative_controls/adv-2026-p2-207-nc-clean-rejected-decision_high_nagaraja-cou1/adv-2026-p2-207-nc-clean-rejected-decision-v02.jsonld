  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/sqa-gradation2",
      "rationale": "Ansys Mechanical 2022 R2 employed under a validated installation qualification and operational qualification (IQ/OQ) protocol. Version-controlled input decks maintained in Git repository with audit trail. Software used under documented commercial license with regression test suite confirming solver behavior for linear and nonlinear structural analyses. Gradation 2 required and achieved: formal IQ/OQ documented, version control in place, but independent third-party audit not performed (not required at Gradation 2 for Medium model risk)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/ncv-gradation2",
      "rationale": "Code verification performed via comparison of Ansys FEA predictions against analytical solutions for beam bending (Euler-Bernoulli) and contact patch problems. Maximum deviation from analytical solution 1.3% for beam stiffness and 2.1% for contact pressure, both within the pre-established 5% tolerance. Published Ansys verification manuals (Section 4.2, structural) referenced as supplementary evidence. Gradation 2 achieved: benchmark problems solved, deviations documented and within tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/disc-error-gradation2",
      "rationale": "Mesh convergence study conducted on the pedicle screw shank and rod-screw interface regions, which govern the QoIs. Three mesh densities evaluated (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements). Richardson extrapolation applied; Grid Convergence Index (GCI) for stiffness QoI = 1.4% (fine-to-medium), confirming solution in the asymptotic range. Final production mesh uses medium density, balancing accuracy and computational cost. Discretization error contribution to total uncertainty budget: 1.4%. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/solver-error-gradation2",
      "rationale": "Nonlinear solver (Newton-Raphson with line search) convergence monitored via force and displacement residual norms. Convergence tolerance set to 0.1% (force norm) and 0.5% (displacement norm) per ASME guidance. All 11 simulation runs converged within tolerance; no divergence or unconverged increments recorded. Iterative solver residual contributions estimated at <0.1% of QoI values. Gradation 2 achieved: solver convergence documented for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/use-error-gradation2",
      "rationale": "Model setup reviewed by a second analyst (independent review) against the documented modeling protocol. Boundary conditions, load application points, and material assignments verified against the ASTM F1717 test fixture specification and CAD geometry. No discrepancies identified. Input deck version controlled; diff review performed prior to each production run. Gradation 2 achieved: independent review completed, no use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-form-gradation2",
      "rationale": "Continuum FEA with nonlinear material model (bilinear isotropic hardening, Ti-6Al-4V) selected to capture post-yield behavior. Contact between screw head and rod modeled with penalty-based frictional contact (mu=0.2, consistent with published tribological data for Ti-Ti interfaces). Geometric nonlinearity (large deformation) enabled. Model form assumptions documented and justified against the physical mechanisms governing the QoIs. Sensitivity analysis confirms model form contributes ~4% to total prediction uncertainty. Gradation 2 achieved: model form assumptions documented with physics justification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-inputs-gradation2",
      "rationale": "Material properties (elastic modulus, yield strength, tangent modulus) sourced from coupon tensile testing of the same Ti-6Al-4V bar stock used in screw manufacture (N=6 coupons). Geometric inputs derived from CMM measurements of production screws (N=5). Input uncertainty distributions characterized and propagated via Monte Carlo sampling (N=1000 draws). Total input uncertainty contribution to stiffness QoI: 5.2%. Gradation 2 achieved: input uncertainties characterized from physical measurements and propagated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-samples-gradation2",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH and DePuy Synthes internal test facility). Constructs assembled from production-representative components with documented lot traceability. Interlaboratory variability assessed; coefficient of variation for stiffness 4.8%, yield force 6.1%, force at 40 mm 7.3%. Sample size sufficient for Gradation 2 (N≥10 required); Gradation 3 would require N≥20. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-conditions-gradation2",
      "rationale": "Testing performed under a single test condition: ASTM F1717 standard configuration (anterior load application, 35 mm lever arm, displacement rate 5 mm/min, ambient temperature 23±2°C). No variation in lever arm length, loading rate, or temperature was explored. Gradation 2 requires at least two distinct test conditions or parametric variation of at least one boundary condition parameter. Only one condition tested; achieved level is Gradation 1. This is the primary driver of the Not accepted decision: the single-condition experimental dataset insufficiently constrains model prediction uncertainty across the COU operating envelope, and the resulting narrow experimental uncertainty band inflates the E/uval ratio for yield force and force at 40 mm displacement above the 1.96 threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/equiv-inputs-gradation2",
      "rationale": "FEA model inputs (geometry, material properties, boundary conditions) verified to be equivalent to the physical test configuration through direct measurement and documented correspondence. Screw geometry in FEA derived from CMM data of tested lot. Material properties from same bar stock. Boundary conditions replicate ASTM F1717 fixture geometry within 0.5 mm positional tolerance. Equivalency table provided in supporting documentation. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/output-comparison-gradation2",
      "rationale": "Quantitative output comparison performed using the ASME V&V 40 validation metric (E/uval). Experimental uncertainty (uexp) computed from N=11 sample statistics (95% CI on mean). Simulation uncertainty (usim) computed from combined discretization, solver, input, and model form contributions via RSS. E = |mean_FEA - mean_exp|. Results: stiffness E/uval=1.88 (pass), yield force E/uval=2.03 (fail, marginally above 1.96), force at 40 mm E/uval=2.11 (fail). Percent difference also computed: stiffness 8.4% (pass), yield force 11.2% (fail), force at 40 mm 12.7% (fail). Two of three QoIs fail both acceptance criteria. Gradation 2 achieved for the comparison methodology itself (quantitative metric with uncertainty), but acceptance criteria not met for two QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/qoi-relevance-gradation2",
      "rationale": "Three QoIs selected (construct stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 and correspond to the regulatory submission requirements for pedicle screw construct performance characterization. QoIs are directly measurable in both simulation and experiment without transformation. Clinical relevance documented: stiffness governs load sharing with bone, yield force defines onset of permanent deformation, force at 40 mm represents post-yield structural integrity. Gradation 2 achieved: QoIs are standard, measurable, and clinically motivated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/val-activity-relevance-gradation2",
      "rationale": "Validation activities directly replicate the COU: the same screw design, same test standard (ASTM F1717), same loading mode (compression-bending), and same measurement outputs as the intended regulatory use. No surrogate geometry or scaled model used. Testing performed at two independent laboratories increases confidence in experimental reference data. The validation scenario is a direct (not analogous) match to the COU. Gradation 2 achieved: direct correspondence between validation scenario and COU confirmed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-not-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment team finds that the FEA modeling framework does NOT achieve sufficient credibility for the non-cannulated 7.5 mm pedicle screw compression-bending COU at this time. The decision is based on the following structured evidence: (1) Test conditions factor achieved Gradation 1 against a required Gradation 2. Only a single ASTM F1717 test condition was evaluated; the protocol required at least two parametric variations to characterize the model's predictive capability across the COU operating envelope. This deficiency directly reduces the experimental uncertainty characterization, inflating the E/uval metric. (2) As a consequence of the single-condition testing, the validation metric E/uval exceeds the pre-established threshold of 1.96 for two of three QoIs: yield force (E/uval=2.03) and force at 40 mm displacement (E/uval=2.11). The percent difference acceptance criterion (<10%) is also exceeded for these two QoIs (11.2% and 12.7% respectively). Construct stiffness meets both criteria (E/uval=1.88, 8.4% difference). (3) The exceedances are marginal but consistent in direction: both failing QoIs involve post-yield material response, where the bilinear hardening model's tangent modulus assumption is most sensitive to the limited calibration data. The team acknowledges that 11 of 13 credibility factors meet or exceed their required levels, and that the stiffness QoI passes all acceptance criteria. However, the ASME V&V 40 framework requires ALL QoIs to meet acceptance criteria for an Accepted decision. The team recommends: (a) conduct additional testing at a minimum of two lever arm lengths (e.g., 35 mm and 50 mm) to achieve Gradation 2 for Test conditions; (b) refine the post-yield material model using the expanded dataset; (c) resubmit for credibility assessment upon completion. The rejection threshold of 1.96 was established a priori in the validation plan and is not adjusted post-hoc.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
