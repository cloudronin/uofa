  "signature": "ed25519:dd1f40250a12e32eecdce051ae26e19cff96c872ca59462401d122b4b7ab6740050c38c7bd91d3e2c3c600b5879d3332cc970633bd69fa3d9376e7ca2b1f0109",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5",
      "rationale": "CFD solver (ANSYS Fluent 2024R1) operates under a documented software quality assurance plan compliant with FDA guidance. Version control, regression test suite (>2000 cases), and change management logs are current. SQA audit completed 2025-03-10 with no open findings. Achieved level 4 meets required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and power-law hemolysis transport equations. Observed convergence order (1.97 for velocity, 1.89 for hemolysis scalar) is consistent with second-order spatial discretization. Code verification package archived at https://uofa.net/synth/evidence/mms-report-2025. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5",
      "rationale": "Three-level mesh refinement study performed on the FDA generic centrifugal pump geometry (coarse 3.2M, medium 8.7M, fine 22.1M cells). Grid Convergence Index (GCI) for hemolysis index at design point: GCI_fine = 1.4%. Richardson-extrapolated hemolysis index used as reference. Temporal discretization verified via time-step halving study; temporal GCI < 0.8%. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "Experimental validation tests conducted at five flow-speed combinations spanning the clinical operating envelope (3–6 L/min, 2400–3600 RPM). Test fluid (porcine blood, hematocrit 35±2%) and temperature (37±0.5°C) match intended COU conditions. Test facility calibration records traceable to NIST standards. Achieved level 4 exceeds required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against experimental measurements at all 5 operating points. Mean absolute error: 6.8%; maximum error: 11.2% at highest speed/lowest flow condition. Comparison metric (E_rms) = 0.074 g/100L, within the pre-specified acceptance band of ±15%. Uncertainty intervals from Monte Carlo UQ overlap experimental uncertainty bands at all points. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH, g/100L) — is the FDA-recognized clinical endpoint for blood pump hemolysis assessment and directly maps to the COU decision threshold. Secondary QoIs (shear stress distribution, exposure time histogram) are documented as supporting evidence. Clinical relevance confirmed by independent clinical advisory review (2025-01-15). Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "Validation activities performed on the FDA generic centrifugal pump — the same geometry class as the VAD device under assessment. Operating conditions in validation experiments span and bound the clinical COU envelope. Fluid properties, boundary conditions, and hemolysis model parameters are matched between validation and COU simulations. Validation relevance matrix documented in https://uofa.net/synth/evidence/validation-relevance-matrix-2025. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence monitored via residual norms (all < 1e-6) and global force/moment imbalance (< 0.01%). Round-off error assessed via double-precision arithmetic throughout; no mixed-precision operations in hemolysis scalar transport. Solver error contribution estimated at < 0.5% of total numerical uncertainty budget. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "Simulation setup reviewed by a second qualified CFD engineer independent of the analyst (two-person review protocol). Boundary condition assignments, material property inputs, and solver settings verified against the approved simulation plan (SP-VAD-2025-001). No setup errors identified in review. Analyst training records current (annual CFD competency assessment passed 2025-02-20). Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "Turbulence modeled using SST k-omega with low-Reynolds-number correction; selection justified by published benchmark comparisons on rotating blood-contacting devices. Hemolysis predicted via the Giersiepen-Wurzinger power-law model with Lagrangian particle tracking for exposure time. Model form uncertainty quantified by comparing against two alternative turbulence closures (RSM, k-epsilon realizable); sensitivity of NIH to model form < 9%. Model form uncertainty included in Monte Carlo UQ budget. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "All 14 model input parameters characterized with probability distributions derived from experimental measurements or literature meta-analysis. Blood viscosity, density, and hemolysis model coefficients (alpha, beta, C) assigned log-normal distributions with documented mean and standard deviation. Monte Carlo sampling (N=5000 Latin hypercube) propagates input uncertainty to NIH predictions. Sensitivity indices (Sobol first-order) identify hemolysis model coefficients as dominant contributors (S_i > 0.45). Input uncertainty budget archived at https://uofa.net/synth/evidence/uq-input-characterization-2025. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5",
      "rationale": "Validation experiments conducted using n=6 independent blood samples per operating point (total n=30 across 5 points). Sample-to-sample variability characterized; coefficient of variation for NIH < 12% across all points. Statistical power analysis confirmed n=6 sufficient to detect a 15% difference in NIH at 80% power (alpha=0.05). Sample provenance and storage conditions documented in laboratory notebook LN-2025-047. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5",
      "rationale": "Equivalency between validation experiment input parameters and COU simulation inputs assessed via parameter mapping table. Inlet flow waveform, rotational speed, fluid temperature, and hematocrit match within stated tolerances. Geometric fidelity of CFD model to physical pump confirmed by CMM measurement report (dimensional deviations < 50 microns). Residual parameter differences quantified and included in the overall uncertainty budget. Achieved level 3 meets required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achieved levels meet or exceed required levels for Model Risk Level 5. The CFD model predicts absolute hemolysis index (NIH) with a maximum error of 11.2% across five clinical operating points, within the pre-specified ±15% acceptance band. Monte Carlo uncertainty quantification (N=5000) demonstrates that the 95th-percentile NIH prediction remains below the clinical threshold of 0.1 g/100L at all operating conditions. Software quality assurance, code verification, and discretization error assessments confirm numerical errors are bounded and quantified. Validation activities are directly relevant to the COU geometry and operating envelope. Independent two-person review confirmed no use errors. The structured evidence base, complete provenance chain, and quantified uncertainty budget provide sufficient credibility for regulatory submission supporting Class III VAD device approval. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
