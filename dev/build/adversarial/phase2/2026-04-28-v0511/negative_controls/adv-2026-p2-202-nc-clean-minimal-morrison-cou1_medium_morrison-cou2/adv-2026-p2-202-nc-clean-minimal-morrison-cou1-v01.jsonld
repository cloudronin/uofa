  "signature": "ed25519:a14b87a81de90def4c2e5c23d2e73a32d0bca499404e6fc9ad184534c04a09b352a95ccbb2959d8e3efb5bc1c0f5b693ee770e9db6f347499cf6f857324d140d",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-version-control-testing",
      "rationale": "CFD solver (OpenFOAM v9) operates under documented software quality assurance plan including version control (Git), automated regression testing suite covering 47 hemolysis-relevant test cases, and configuration management records. SQA plan reviewed and approved by independent QA auditor. Achieved level 3 meets MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mms-benchmark",
      "rationale": "Method of Manufactured Solutions (MMS) applied to the Navier-Stokes solver and power-law hemolysis transport equation. Observed order of convergence (OOC) confirmed at 1.94 for velocity and 1.87 for hemolysis scalar, consistent with second-order spatial discretization. Code verification report archived at revision-controlled repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-gci-threshold",
      "rationale": "Systematic mesh refinement study conducted across three mesh densities (2.1M, 8.4M, 33.6M cells). Grid Convergence Index (GCI) computed per Celik et al. (2008); GCI for hemolysis index at all five operating points is below 4.2%, satisfying the MRL 5 threshold of 5%. Time-step refinement study confirms temporal discretization error below 1.8% for all QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-vad-experimental-protocol",
      "rationale": "Experimental test conditions replicate VAD operating envelope: blood analog fluid (glycerol-water, viscosity 3.5 mPa·s ± 0.1 mPa·s), temperature controlled at 37 °C ± 0.5 °C, five flow-speed combinations covering clinical operating range. Test protocol documented per ASTM F1841 with full traceability of fluid lot, temperature calibration records, and flow meter calibration certificates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mape-threshold",
      "rationale": "Quantitative comparison of predicted vs. measured normalized index of hemolysis (NIH) across all five operating points. Mean absolute percentage error (MAPE) = 7.3%; maximum point error = 11.8% at the lowest flow condition. Comparison conducted with propagated experimental uncertainty bands; all predictions fall within combined model + experimental uncertainty intervals. Validation metric satisfies MRL 5 acceptance threshold of MAPE ≤ 15%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-absolute-nih",
      "rationale": "Primary QoI is the absolute NIH value, which is the direct clinical decision variable for hemolysis acceptance. Secondary QoIs (shear stress distribution, exposure time histogram) directly feed the power-law hemolysis model. All QoIs are mechanistically linked to the COU decision; no surrogate or proxy quantities are used as primary decision basis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-cou-mapping",
      "rationale": "Validation activities performed on the FDA generic centrifugal pump geometry — the same geometry class as the COU device. Operating conditions span the full clinical envelope defined in the COU. Blood analog fluid properties match COU physiological conditions within documented tolerance. Geometric fidelity, flow regime (Re 2,400–18,000), and hemolysis mechanism are all directly representative of COU; no extrapolation beyond validated domain is required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-residual-convergence",
      "rationale": "Iterative convergence monitored via normalized residuals; all momentum and continuity residuals reach 1×10⁻⁶ before solution extraction. Round-off error assessed via double-precision arithmetic throughout. Solver error contribution to hemolysis QoI estimated at <0.5% via perturbation analysis, well below discretization error contribution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-independent-review",
      "rationale": "Independent simulation review conducted by a second qualified CFD analyst who reproduced the mesh generation, boundary condition assignment, and post-processing workflow from documented simulation plan. No discrepancies identified. Simulation plan, run scripts, and post-processing macros are version-controlled and peer-reviewed. Use error mitigation documented in simulation governance record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-turbulence-hemolysis-justification",
      "rationale": "Turbulence modeled with SST k-ω; model selection justified by comparative study against LES reference data for rotating impeller flows showing mean velocity error <8%. Power-law hemolysis model (Giersiepen-Wurzinger coefficients) selected with documented justification over competing models; sensitivity of NIH prediction to model-form choice quantified via Monte Carlo with ±15% coefficient uncertainty, resulting in NIH prediction interval of ±18%. Model form uncertainty explicitly propagated to decision metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-uq-monte-carlo",
      "rationale": "Monte Carlo uncertainty quantification performed over 1,000 samples spanning uncertain input parameters: fluid viscosity (±3%), inlet velocity profile shape (±5%), rotational speed (±0.5%), and hemolysis model coefficients (±15%). Latin hypercube sampling used for efficiency. Input PDFs derived from calibration records and literature. 95th-percentile NIH prediction remains below clinical threshold, confirming robustness of acceptance decision under input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-replication-statistics",
      "rationale": "Experimental hemolysis data collected from n=6 independent pump specimens per operating point, with n=3 repeat runs per specimen (18 total measurements per operating point). Inter-specimen variability (CV < 9%) and intra-run repeatability (CV < 4%) documented. Sample size sufficient to estimate population mean NIH within ±12% at 95% confidence, meeting MRL 5 statistical adequacy requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mapping-table",
      "rationale": "Parameter equivalency table prepared mapping each experimental input (fluid viscosity, pump geometry, rotational speed, flow rate) to corresponding simulation input with documented source and tolerance. All parameters match within specified tolerances; no unresolved discrepancies between experimental and simulation input spaces. Equivalency assessment reviewed and signed off by lead validation engineer."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at Model Risk Level 5. Achieved levels meet or exceed required levels across all factors: discretization error, output comparison, relevance of validation activities, model form, and model inputs each achieved level 4 against a level-4 requirement; remaining factors achieved level 3 against level-3 requirements. Monte Carlo uncertainty quantification over 1,000 samples confirms that the 95th-percentile predicted NIH remains below the absolute clinical hemolysis threshold across all five VAD operating points. Independent simulation review eliminated use-error concerns. Validation activities performed on the same pump geometry class under representative physiological conditions with full parameter equivalency documentation. The structured evidence base — comprising code verification via MMS, systematic GCI mesh refinement study, multi-specimen experimental dataset, and complete provenance chain from raw experimental records through post-processed validation metrics — provides sufficient credibility for the intended regulatory decision. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
