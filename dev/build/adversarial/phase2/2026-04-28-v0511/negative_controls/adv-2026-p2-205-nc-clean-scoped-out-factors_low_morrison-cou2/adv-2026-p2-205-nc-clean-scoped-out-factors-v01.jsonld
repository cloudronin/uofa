  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-mrl5",
      "rationale": "The CFD solver (ANSYS Fluent 2023R2) is operated under a documented software quality assurance plan conforming to FDA guidance on software validation. Version control, regression test suite (450 test cases), and change management records are archived. SQA audit completed 2024-11 with no critical findings. Achieved level 4 meets required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-mrl5",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and scalar transport equations governing hemolysis. Observed order of accuracy (p_obs = 1.97) consistent with nominal second-order spatial discretization. Code verification report reviewed and approved by independent analyst. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-mrl5",
      "rationale": "Three-level structured mesh refinement study with refinement ratio r = 2 applied at all 5 operating conditions. GCI values for NIH quantity of interest ranged 0.8–2.1%, well within the 5% acceptance threshold. Richardson extrapolation confirms asymptotic convergence. Achieved level 5 exceeds required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-mrl5",
      "rationale": "In vitro experimental conditions (fluid viscosity, density, temperature, inlet flow waveform) are documented with full traceability to NIST-traceable calibration records. Experimental uncertainty in NIH measurement is ±6.2% (k=2), characterised via ISO GUM methodology. Test conditions replicate the 5 COU operating points. Achieved level 4 exceeds required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-mrl5",
      "rationale": "Quantitative validation metric E_rms computed per ASME V&V 20 for velocity fields (0.063 m/s, 7.4% of bulk velocity) and NIH (mean signed error −3.1%). Validation uncertainty U_val calculated and reported. All 5 operating-point NIH predictions fall within combined simulation and experimental uncertainty intervals at 95% confidence. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-mrl5",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH, g/100L) — directly maps to the clinical acceptance threshold cited in the COU. Secondary QoIs (wall shear stress distribution, scalar hemolysis exposure time) are documented as supporting evidence. QoI traceability matrix links each simulated output to the regulatory decision criterion. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-mrl5",
      "rationale": "Validation experiments performed on the FDA generic centrifugal pump geometry — the same geometry used in the COU simulations. Operating conditions span the full COU envelope (2–6 L/min, 2500–4500 RPM). Fluid analog (glycerol-water, matched viscosity) is the same as used in the COU experimental reference. Geometric fidelity confirmed via coordinate metrology. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence monitored via residual norms (all < 1×10⁻⁶) and QoI plateau criterion (NIH change < 0.05% over final 500 iterations). Round-off error assessed via double-precision arithmetic verification. Solver error contribution to total numerical uncertainty estimated at < 0.3% NIH. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-scoped",
      "rationale": "Use error as defined in ASME V&V 40 pertains to errors introduced by the end-user operating the simulation software in a manner inconsistent with its intended use (e.g., incorrect boundary condition type selection, inappropriate turbulence model activation by an untrained analyst). In the present COU, all simulations are executed by a single qualified analyst team operating under a documented simulation governance procedure (SGP-CFD-2024-01) that mandates peer review of all boundary condition setups, turbulence model selections, and post-processing scripts prior to result acceptance. The SGP was reviewed and approved by the laboratory quality manager. Because the procedural controls fully eliminate the pathways through which use error could manifest as a credibility gap — and because the governance procedure itself is subject to the SQA factor already assessed at level 4 — separately scoring use error would be redundant and would not yield additional credibility information. This factor is therefore scoped out of the quantitative assessment. The scoping decision was reviewed and approved by the independent credibility assessor on 2025-09-12 and is documented in assessment record ACR-COU2-USE-2025."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-mrl5",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) is the accepted industry standard for CFD hemolysis prediction in rotary blood pumps and is cited in FDA guidance. Model form uncertainty assessed via comparison of three alternative hemolysis sub-models (Heuser-Opitz, Zhang) at all 5 operating points; NIH spread < 12% across models. The primary model selected based on best agreement with in vitro data. Model form uncertainty contribution included in Monte Carlo UQ budget. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-mrl5",
      "rationale": "All model inputs (fluid density, dynamic viscosity, inlet velocity profiles, rotational speed, hemolysis model constants) are assigned probability distributions based on measurement data and literature. Monte Carlo sampling (N = 10,000 LHS samples) propagates input uncertainty to NIH output. Sensitivity indices (Sobol first-order and total-order) computed; viscosity and rotational speed identified as dominant contributors. Input uncertainty budget documented in UQ report UQ-COU2-2025. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-mrl5",
      "rationale": "In vitro hemolysis measurements performed on n = 6 replicate pump units per operating condition (30 total test runs). Statistical analysis confirms no significant unit-to-unit variability (one-way ANOVA, p = 0.31). Sample size sufficient to characterise experimental mean and standard deviation for use in validation metric calculation. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/input-equivalency-scoped",
      "rationale": "Equivalency of input parameters addresses the degree to which the input parameters used in validation experiments match those that will be used in the COU deployment environment. In this assessment, the validation experiments and the COU simulations share identical geometry (FDA generic centrifugal pump, CAD file revision 3.1), identical fluid analog (37% glycerol-water solution, matched to blood analog viscosity at 37°C), and identical operating-condition envelope (2–6 L/min, 2500–4500 RPM at five discrete points). Because the validation and COU input spaces are coextensive — no extrapolation beyond the validated envelope is performed — there is no residual equivalency gap to score. The equivalency assessment is therefore subsumed within the 'Relevance of validation activities to the COU' factor (assessed at level 4) and the 'Model inputs' factor (assessed at level 4), both of which explicitly address the correspondence between validation and deployment input parameters. Scoring equivalency of input parameters as a separate factor would double-count evidence already captured in those two factors and would not change the overall credibility conclusion. This scoping decision is documented in assessment record ACR-COU2-EQV-2025, reviewed by the independent assessor on 2025-09-14."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, Class III, MRL 5) is accepted on the basis of the following structured evidence. Eleven of the thirteen ASME V&V 40 credibility factors were formally assessed; all eleven achieved levels meeting or exceeding required levels for MRL 5. The two remaining factors — Use error and Equivalency of input parameters — were scoped out with documented, peer-reviewed rationale: Use error is fully mitigated by the simulation governance procedure SGP-CFD-2024-01 (itself covered under the SQA factor assessed at level 4), and Equivalency of input parameters is subsumed within the Relevance of validation activities (level 4) and Model inputs (level 4) factors, which together demonstrate coextensive validation and COU input spaces with no extrapolation gap. Validation evidence comprises PIV velocity field comparison (E_rms = 7.4% of bulk velocity), absolute NIH comparison across all 5 operating points (mean signed error −3.1%, all predictions within 95% combined uncertainty bounds), and a three-level mesh convergence study (GCI < 2.1%). Monte Carlo uncertainty quantification (N = 10,000 LHS samples) propagated all dominant input uncertainties through the hemolysis model; the 95th-percentile NIH prediction remains below the clinical acceptance threshold with margin > 18%. The provenance chain is complete from foundational experimental datasets through validation activities to this assessment record. No weakeners are identified. The assessment team concludes that the computational model provides sufficient credibility to support the regulatory submission for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
