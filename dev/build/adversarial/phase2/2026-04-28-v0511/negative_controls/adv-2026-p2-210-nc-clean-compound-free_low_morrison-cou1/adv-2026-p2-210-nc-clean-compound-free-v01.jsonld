  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted for the COU of identifying worst-case hemolysis operating conditions under CPB conditions at MRL 2. All seven assessed credibility factors meet or exceed their required gradation levels: software QA (2/2), code verification (3/2), discretization error (2/2), test conditions (2/2), output comparison (2/2), QoI relevance (2/2), and validation relevance (2/2). Six factors are appropriately scoped out or deemed not applicable at MRL 2 with documented rationale. The model correctly identifies the worst-case operating condition in agreement with experimental rank ordering, with a mean absolute percentage error of 4.2% on the hemolysis index across all five operating points. The relative hemolysis index RH < 1 criterion is satisfied at the worst-case condition with sufficient margin (RH = 0.73, combined uncertainty ±0.09). The provenance chain is complete from foundational experimental datasets through validation activities to this assessment. The decision consequence is High and model influence is Medium (MRL 2); the structured evidence base provides adequate credibility for regulatory submission supporting the Class II CPB device tolerance analysis.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
