  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated 7.5 mm pedicle screw, ASTM F1717 static compression-bending) is accepted at Medium assurance level commensurate with model risk level 3. Twelve of thirteen V&V 40 credibility factors met or exceeded required levels. The single factor below required level — Test conditions (achieved 2, required 3) — reflects the use of a single ASTM F1717 load case. This gap is accepted on the following grounds: (1) the single load case is the regulatory standard and the precise condition relevant to the COU; (2) sensitivity analyses demonstrate QoI robustness to loading rate variation within physiologically plausible bounds; (3) the output comparison metric (E/uval < 1.96 for all three QoIs) and percentage differences (all < 6%) provide strong quantitative evidence of model fidelity; (4) the two-laboratory experimental design with N=11 specimens provides robust statistical grounding; and (5) independent re-run verification eliminates use-error risk. The provenance chain from raw experimental data through uncertainty quantification to the final validation metric is complete and traceable. The FEA modeling framework is assessed as fit for the stated regulatory purpose.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision-2024/offset/test-conditions",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision-2024/factor/test-conditions",
      "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
    }
  },
