  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for Morrison COU1 (CFD hemolysis prediction for Class II CPB device at Model Risk Level 2) is accepted based on the following structured evidence: (1) All 13 ASME V&V 40 credibility factors have been assessed with achieved levels meeting or exceeding required levels. (2) Three independent validation results demonstrate CFD-predicted NIH agrees with in-vitro measurements within combined uncertainty at all 5 operating points (mean relative error 8.3%, maximum 12.7%, all within ±15% combined uncertainty band). (3) Discretization error is quantified at GCI = 2.1% for the production mesh, well below the 5% acceptance threshold. (4) Model form uncertainty estimated at ±12% NIH from power-law constant variability; combined with numerical uncertainty, total NIH uncertainty is ±18%, which when applied to the worst-case predicted NIH still yields RH < 1.0 vs. predicate device. (5) UQ performed via 500-sample Latin hypercube sampling over full geometric tolerance space confirms all operating points remain below acceptance criterion with 95% confidence. (6) Independent analyst review confirmed zero setup errors. (7) Software QA, version control, and regression testing are fully documented under ISO 9001-registered QMS. The model is fit for the intended use of identifying worst-case hemolysis operating conditions for regulatory 510(k) submission. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
