  "signature": "ed25519:2acc3369a45f87101b5cf7f1a979c5013097e30767b5934c3061a49662fbc1acf9f56427bc33443abb60cde93a66afa3540d936152da5d4253495a9e4626eb0f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-class3",
      "rationale": "Software quality assurance activities completed per ASME V&V 40 Gradation 3 requirements. The CFD solver (OpenFOAM v9) is version-controlled, regression-tested against benchmark cases, and deployed in a validated computational environment. Configuration management records and build verification logs are archived. Achieved level equals required level for MRL 5 cardiovascular application."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Numerical code verification performed via method of manufactured solutions (MMS) for the incompressible Navier-Stokes and power-law hemolysis transport equations. Observed convergence rates match theoretical rates (2nd order spatial, 1st order temporal). Unit and integration tests cover all active solver modules. Achieved level 4 exceeds required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-gci-mrl5",
      "rationale": "Grid convergence index (GCI) study performed on three systematically refined meshes (4.2M, 12.6M, 37.8M cells) following Roache methodology. GCI for hemolysis index QoI is 4.8% on the fine mesh, within the 5% acceptance threshold for Gradation 3. Temporal discretization error assessed via time-step halving study confirming <1% change in cycle-averaged hemolysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-invitro-mrl5",
      "rationale": "In-vitro experimental test conditions documented with full traceability: fluid viscosity (3.5 cP glycerol-water), temperature (37°C ± 0.5°C), inlet flow rates (2–6 L/min), rotational speeds (2000–3500 RPM). All five operating points replicated in CFD boundary conditions with deviations less than 2% of target values. Test condition uncertainty propagated into UQ ensemble."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-hemolysis-absolute",
      "rationale": "Quantitative output comparison performed using normalized index of agreement (NIA) and root-mean-square error (RMSE) metrics across all five operating points. CFD-predicted normalized index of hemolysis (NIH) values fall within ±15% of measured values at all operating points, meeting Gradation 4 threshold. Uncertainty intervals from Monte Carlo UQ overlap experimental measurement uncertainty bands at 95% confidence for all five points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-hemolysis-vad",
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is directly the clinical decision variable for VAD acceptance. The hemolysis power-law model outputs are mapped directly to the absolute clinical threshold without transformation. Secondary QoIs (shear stress distribution, residence time) are tracked as supporting evidence. QoI relevance is rated Gradation 4 because the model output directly corresponds to the regulatory acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-cou2-vad",
      "rationale": "Validation activities performed on the FDA generic centrifugal pump geometry under hemolytic flow conditions matching the COU operating envelope. Blood analog fluid properties, pump geometry, and flow regime (Reynolds number range 800–4200) all match COU conditions. Validation dataset is the FDA-sponsored benchmark dataset (Stewart et al. 2012), widely accepted as the reference standard for this device class. Relevance rated Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/na-rationale-numerical-solver-error",
      "rationale": "This factor as defined in certain NASA verification frameworks addresses round-off error accumulation in iterative solvers under high-precision aerospace trajectory computations. For the present cardiovascular CFD application using double-precision arithmetic on a well-conditioned incompressible flow problem, round-off error is demonstrably negligible relative to discretization and model-form uncertainty (ratio < 1e-8). The ASME V&V 40-2018 standard subsumes solver round-off considerations within the Numerical Code Verification factor, which has been assessed at Gradation 4. Separate treatment as a standalone factor is therefore not applicable to this COU and would constitute double-counting under the V&V 40 framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/na-rationale-use-error",
      "rationale": "The 'Use error' factor as enumerated in certain NASA-derived credibility frameworks addresses operator misapplication of simulation tools in contexts where end-users are non-specialist field personnel (e.g., flight operations crew running real-time trajectory tools). In this COU, the CFD model is executed exclusively by credentialed computational fluid dynamics engineers under a documented simulation governance protocol with mandatory peer review of all boundary condition inputs and post-processing scripts. Human-in-the-loop use error pathways applicable to operational NASA software tools are not present in this controlled laboratory submission context. This factor is not applicable under ASME V&V 40-2018 for the present COU; operator qualification is addressed under the Software Quality Assurance factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-hemolysis-powerlaw",
      "rationale": "Model form uncertainty assessed for the power-law hemolysis model (Giersiepen et al. parameters) and the SST k-omega turbulence closure. Sensitivity analysis across three published hemolysis model parameter sets (Giersiepen, Zhang-Bhagat, Taskin) quantifies model-form spread of ±22% on NIH predictions. This spread is included in the Monte Carlo UQ ensemble. Turbulence model sensitivity assessed via comparison of SST k-omega against realizable k-epsilon; differences in NIH are within 8%. Model form uncertainty is explicitly characterized and bounded, meeting Gradation 4 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-uq-mrl5",
      "rationale": "All model input parameters characterized with probability distributions for Monte Carlo UQ: fluid viscosity (±5% CV), inlet velocity profile (±3% CV), rotational speed (±1% CV), hemolysis model coefficients (uniform distributions spanning published ranges). 5000-sample Monte Carlo ensemble propagates input uncertainty to NIH output distributions. Input sensitivity indices (Sobol first-order) computed; hemolysis model coefficient C and alpha exponent account for 68% of output variance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/na-rationale-test-samples",
      "rationale": "The 'Test samples' factor as formulated in certain NASA credibility frameworks addresses statistical characterization of physical test article variability across a production sample population — a concern for aerospace hardware where manufacturing variability across units must be statistically characterized. For this CFD validation study, the FDA generic centrifugal pump is a single canonical reference geometry with no manufacturing variability; the in-vitro experiments use a single precision-machined acrylic test article. Sample-to-sample variability is therefore structurally absent from this COU. Physical hardware variability for the actual VAD device is addressed separately in the device verification and validation plan outside the scope of this simulation credibility assessment. This factor is not applicable under ASME V&V 40-2018 for the present COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-cou2-vad",
      "rationale": "Equivalency of input parameters between validation experiments and COU conditions assessed systematically. Fluid properties (viscosity, density) match within 3% between glycerol-water analog and blood at 37°C. Reynolds number ranges overlap across all five operating points. Geometric equivalency confirmed: validation uses identical FDA generic pump CAD geometry as COU model. Inlet turbulence intensity estimated from experimental PIV data and matched in CFD boundary conditions. All equivalency assessments documented in the simulation plan with quantitative deviation metrics meeting Gradation 3 thresholds."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-nc6-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-cardiovascular",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40-2018 credibility factors for this MRL 5 Class III VAD hemolysis prediction COU. Ten factors were assessed: all achieved levels meet or exceed required levels, with Output Comparison, Relevance of QoI, Relevance of Validation Activities, and Model Form all meeting the elevated Gradation 4 requirement appropriate for high-consequence Class III device decisions. Three factors — Numerical Solver Error, Use Error, and Test Samples — were determined not-applicable to this COU with fully documented rationale. Numerical Solver Error is subsumed by the assessed Numerical Code Verification factor under V&V 40 and is negligible for double-precision incompressible CFD. Use Error as defined in NASA-derived frameworks does not apply to this controlled expert-executed laboratory submission context; operator qualification is captured under Software Quality Assurance. Test Samples as a population-variability factor is inapplicable to a single canonical reference geometry validation study. The not-applicable designations are conservative and do not represent gaps: each excluded factor either maps to an assessed factor or is structurally absent from the COU. Monte Carlo UQ with 5000 samples demonstrates that CFD-predicted NIH values remain below the absolute clinical hemolysis threshold at the 95th percentile of the input uncertainty distribution across all five operating points. The provenance chain is complete from foundational PIV and in-vitro datasets through validation activities to this credibility determination. The assessment team concludes that the simulation evidence provides sufficient credibility for the intended regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
