  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis model under CPB COU1 conditions is accepted at Model Risk Level 2. Seven of 13 credibility factors were formally assessed; all seven meet or exceed their required levels. Six factors were appropriately scoped out per MRL 2 requirements with documented rationale. The primary credibility concern — the marginal asymptotic range condition in the GCI mesh convergence study (ratio 0.97, outside ideal band of 1.0±0.05) — was explicitly identified, quantified, and documented rather than suppressed. The resulting conservative discretization uncertainty of 6.8% was propagated through to the RHI comparison, yielding a worst-case upper bound RHI = 0.87 against an acceptance criterion of RH < 1.0. This provides a margin of 0.13 (13% of the criterion threshold), which is deemed sufficient given the medium model influence designation and the corroborating evidence from pressure-flow validation (MAE 2.9%) and code verification (MMS, observed order 1.97). The turbulence model sensitivity (±4.1%) is incorporated in the combined uncertainty bound. All validation results are traceable to their generating activities and reference datasets. The provenance chain is complete. The decision is grounded in the structured evidence and the explicitly-documented uncertainty bounds support the conclusion that the model is fit for the intended COU at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
