      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/cou2/discretization-error",
        "type": "AcceptanceCriteria",
        "name": "GCI < 5% on hemolysis index at all operating points",
        "description": "Grid Convergence Index (GCI) for the normalized hemolysis index must be below 5% at all five COU operating points using a minimum three-level Richardson extrapolation study."
      },
      "rationale": "Three-level mesh refinement study (coarse 2.1M, medium 6.8M, fine 18.4M cells) yielded GCI values of 2.1–4.7% across all five operating points. Requirement met at level 4."
    },
    {
