  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors achieved their required levels (requiredLevel ≤ achievedLevel across Software QA, Numerical Code Verification, Discretization Error, Test Conditions, Output Comparison, Relevance of QoI, and Relevance of Validation Activities). Six factors were determined not-applicable with documented rationale: Numerical Solver Error (subsumed by GCI analysis), Use Error (controlled by SQA process), Model Form (addressed by output comparison evidence), Model Inputs (fully characterised by Monte Carlo UQ), Test Samples (no meaningful sample variability in the FDA pump benchmark), and Equivalency of Input Parameters (direct experiment-to-COU correspondence eliminates equivalency gap). Monte Carlo uncertainty quantification confirms NIH prediction uncertainty is within the 15% output comparison tolerance. The provenance chain from raw CFD outputs through experimental comparison to this UofA is complete. The assessment team concludes that the CFD model provides sufficient credibility evidence to support the absolute hemolysis acceptance decision for COU2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
