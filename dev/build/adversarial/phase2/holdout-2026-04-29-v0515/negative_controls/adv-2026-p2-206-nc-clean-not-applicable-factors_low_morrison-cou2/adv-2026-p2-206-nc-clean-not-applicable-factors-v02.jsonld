  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/morrison/factor/software-quality-assurance",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/sqa",
        "type": "AcceptanceCriteria",
        "name": "Software quality assurance acceptance criteria — MRL 5",
        "description": "The CFD solver (ANSYS Fluent 2023R2) must have documented version control, regression test suite with >95% pass rate, and traceable build configuration. All user-defined functions (UDFs) implementing the hemolysis power-law model must be under source control with documented unit tests. Achieved: solver QA documentation complete; UDF repository tagged and tested against 12 benchmark cases."
      },
      "rationale": "At MRL 5 the solver and all custom hemolysis UDFs must be under formal software quality assurance. ANSYS Fluent is operated under an FDA-recognized SQA plan; the power-law hemolysis UDF is version-controlled in a traceable repository with documented unit tests. Required level 4 is met."
    },
    {
      "id": "https://uofa.net/morrison/factor/numerical-code-verification",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/ncv",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criteria — MRL 5",
        "description": "Order-of-accuracy verification must be demonstrated via manufactured solution on a canonical rotating-frame problem. Observed order must be within 10% of formal order for velocity and pressure. Achieved: second-order convergence confirmed (observed p=1.94) on a rotating Couette flow MMS; hemolysis scalar transport verified to first order as expected for the upwind discretisation."
      },
      "rationale": "Code verification via the method of manufactured solutions confirms that the discretisation of the Navier-Stokes and hemolysis scalar transport equations is correctly implemented. Observed convergence rates are consistent with formal order, satisfying the MRL 5 requirement."
    },
    {
      "id": "https://uofa.net/morrison/factor/discretization-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/disc-error",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria — MRL 5",
        "description": "Richardson extrapolation-based GCI must be performed on three systematically refined meshes (refinement ratio r≥1.3). GCI on hemolysis index must be <5%. Achieved: three meshes (2.1M, 5.8M, 14.2M cells); GCI_fine = 3.7% for normalised hemolysis index, confirming mesh-independent solution."
      },
      "rationale": "A three-level mesh refinement study following ASME V&V 20 GCI methodology demonstrates that discretization error in the hemolysis index is below the 5% acceptance threshold. The fine-mesh solution is used for all subsequent validation comparisons."
    },
    {
      "id": "https://uofa.net/morrison/factor/test-conditions",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria — MRL 5",
        "description": "Experimental test conditions (flow rate, rotational speed, blood analogue viscosity, temperature) must be documented with measurement uncertainty. Test matrix must span the COU operating envelope (2–6 L/min, 2400–3600 RPM). Achieved: five operating points fully characterised; temperature maintained at 37±0.5°C; viscosity measured with cone-and-plate rheometer; flow rate uncertainty ±0.05 L/min."
      },
      "rationale": "All experimental conditions used for validation are traceable to calibrated instrumentation with documented uncertainties. The five-point test matrix spans the COU operating envelope, ensuring that validation evidence directly supports the intended prediction domain."
    },
    {
      "id": "https://uofa.net/morrison/factor/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria — MRL 5",
        "description": "Predicted normalised index of haemolysis (NIH) must agree with experimental values within combined simulation and experimental uncertainty bands at all five operating points. Quantitative metric: E_rel < 15% at each point. Achieved: maximum E_rel = 11.3% at 6 L/min / 3600 RPM; all five points within uncertainty bands."
      },
      "rationale": "Quantitative comparison of predicted NIH against experimental measurements at all five operating points shows agreement within the pre-specified 15% relative error threshold. Uncertainty bands from Monte Carlo propagation overlap experimental uncertainty intervals at every point."
    },
    {
      "id": "https://uofa.net/morrison/factor/relevance-qoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/relevance-qoi",
        "type": "AcceptanceCriteria",
        "name": "Relevance of QoI acceptance criteria — MRL 5",
        "description": "The validation QoI (NIH) must be directly mapped to the COU decision QoI (absolute hemolysis index below clinical threshold). A documented QoI mapping table must exist. Achieved: QoI mapping table links NIH to clinical hemolysis threshold per ASTM F1841; direct correspondence confirmed."
      },
      "rationale": "The normalised index of haemolysis used in validation experiments is the same quantity required for the COU decision. The QoI mapping table confirms direct correspondence between the validation observable and the clinical decision threshold, satisfying the relevance requirement at level 3."
    },
    {
      "id": "https://uofa.net/morrison/factor/relevance-validation-activities",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/relevance-validation-activities",
        "type": "AcceptanceCriteria",
        "name": "Relevance of validation activities acceptance criteria — MRL 5",
        "description": "Validation experiments must use the FDA generic centrifugal pump geometry (or a certified replica), human blood or a validated analogue, and operating conditions within the COU envelope. Achieved: experiments conducted on certified FDA generic pump replica; porcine blood with documented rheology used; all five operating points within COU envelope."
      },
      "rationale": "Validation activities were conducted on the identical pump geometry specified in the COU using physiologically relevant blood and operating conditions that span the COU envelope. The high relevance of validation activities to the COU is confirmed at required level 4."
    },
    {
      "id": "https://uofa.net/morrison/factor/numerical-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Numerical solver error as a distinct credibility factor addresses iterative convergence errors and floating-point arithmetic errors in solvers that lack formal verification suites — a concern primarily for in-house or research codes. ANSYS Fluent 2023R2 is a commercially validated solver with documented iterative convergence criteria enforced to residual levels below 1×10⁻⁶ for all transport equations. The solver's internal arithmetic and iterative error characteristics are fully addressed under the Numerical Code Verification factor (assessed at level 4), which explicitly covers the MMS-based order-of-accuracy demonstration. Separating solver error as an additional factor would constitute double-counting of evidence already captured in code verification. Per ASME V&V 40-2018 §6.3.2, when code verification subsumes solver error assessment for a commercially validated code, the standalone solver error factor is not applicable."
    },
    {
      "id": "https://uofa.net/morrison/factor/use-error",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Use error addresses the risk that an analyst misapplies the simulation tool through incorrect boundary condition specification, inappropriate physics model selection, or procedural mistakes. In this assessment, all simulation inputs and boundary conditions are defined through a formally controlled simulation plan document (SPD-VAD-2026-01) reviewed and approved by an independent CFD expert prior to execution. The SPD mandates specific turbulence model selection (SST k-ω), inlet velocity profiles derived from PIV measurements, and wall boundary conditions consistent with the experimental setup. Independent review of the simulation setup against the SPD was completed and documented in review record RR-2026-03. Because the risk of use error has been eliminated through procedural controls that are themselves part of the software quality assurance framework (assessed at level 4), this factor does not add independent credibility evidence and is not applicable as a standalone assessment item."
    },
    {
      "id": "https://uofa.net/morrison/factor/model-form",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Model form uncertainty relates to the adequacy of the mathematical representation of the underlying physics — in this case, the choice of turbulence closure and the power-law hemolysis damage accumulation model. For this COU, model form uncertainty is not assessed as a standalone credibility factor because it is fully subsumed within the Output Comparison factor (assessed at level 4): the quantitative agreement between CFD predictions and experimental NIH measurements at all five operating points directly characterises the aggregate effect of model form error on the QoI. ASME V&V 40-2018 §6.4.1 notes that when validation evidence directly bounds the combined model form and numerical error for the QoI, a separate model form factor assessment is redundant. The 11.3% maximum relative error observed in output comparison already reflects any model form inadequacy, and this is within the pre-specified acceptance threshold."
    },
    {
      "id": "https://uofa.net/morrison/factor/model-inputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Model inputs uncertainty covers uncertainty in material properties, geometric parameters, and boundary condition values propagated through the simulation. This factor is not applicable as a standalone item because Monte Carlo uncertainty quantification (500-sample LHS ensemble) was performed propagating uncertainties in blood viscosity (±8%), pump rotational speed (±10 RPM), inlet flow rate (±0.05 L/min), and hemolysis model constants (±15% per published sensitivity data). The resulting prediction intervals are reported with every validation result and directly incorporated into the Output Comparison acceptance criteria. Treating model inputs as a separate factor would duplicate evidence already quantified and reported through the UQ ensemble. The UQ activity is documented in UQ-VAD-2026-01 and linked to the validation results in this package."
    },
    {
      "id": "https://uofa.net/morrison/factor/test-samples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Test samples as a credibility factor pertains to the representativeness and characterisation of physical specimens used in experiments — particularly relevant for solid mechanics or material characterisation studies where specimen variability is a primary uncertainty source. In this CFD hemolysis study, the 'test sample' is a blood analogue fluid (porcine blood, batch-characterised) and the FDA generic pump geometry (precision-machined certified replica). Fluid rheology variability is captured within the model inputs Monte Carlo ensemble (viscosity uncertainty ±8%). Pump geometry dimensional inspection confirms conformance to the FDA generic pump specification within ±0.05 mm tolerance. Because there is no population of physical specimens whose variability must be separately characterised — the fluid is batch-uniform and the geometry is a single certified artefact — the test samples factor does not apply to this assessment context."
    },
    {
      "id": "https://uofa.net/morrison/factor/equivalency-input-parameters",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Equivalency of input parameters addresses the degree to which simulation input parameters match those of the validation experiment — a factor that is particularly salient when the validation case differs substantially from the COU (e.g., a scaled or surrogate experiment). In this assessment, the validation experiments were conducted on the identical FDA generic centrifugal pump geometry at the same operating conditions as the COU (same flow rates, rotational speeds, fluid properties, and temperature). There is no surrogate geometry, scaling transformation, or analogue fluid substitution that would introduce input parameter non-equivalency. The Test Conditions factor (assessed at level 4) already documents the characterisation and traceability of all experimental inputs. Because the validation and COU share identical input parameters by design, the equivalency of input parameters factor is not applicable as a distinct assessment item."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026-04",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors achieve their required credibility levels under ASME V&V 40-2018 at Model Risk Level 5. Software quality assurance, numerical code verification, discretization error, test conditions, output comparison, relevance of QoI, and relevance of validation activities are each assessed at level 4 or higher, meeting or exceeding MRL 5 requirements. Six factors (numerical solver error, use error, model form, model inputs, test samples, equivalency of input parameters) are marked not-applicable with documented rationale explaining that each is either subsumed by another assessed factor, addressed through procedural controls already captured in SQA, or structurally inapplicable to the CFD-hemolysis-fluid assessment context. Monte Carlo uncertainty quantification (500-sample LHS ensemble) provides quantified prediction intervals that overlap experimental uncertainty bands at all five operating points. The maximum relative error of 11.3% is within the pre-specified 15% acceptance threshold. The provenance chain is complete from foundational experimental data through validation activities to this assurance package. On the basis of this structured evidence, the CFD model is accepted for predicting absolute hemolysis levels for the Class III VAD device within the documented operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
