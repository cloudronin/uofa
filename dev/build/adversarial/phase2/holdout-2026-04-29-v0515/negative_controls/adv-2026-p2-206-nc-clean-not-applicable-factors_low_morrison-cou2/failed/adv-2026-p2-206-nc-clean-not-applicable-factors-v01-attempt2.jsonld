  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/morrison/factor/cou2-sqa",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/cou2-sqa",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criteria for MRL 5 CFD solver",
        "description": "Commercial CFD solver must hold a current ISO 9001-certified QMS; version control and regression test suite covering blood pump operating range must be documented; solver release notes must confirm no known defects affecting hemolysis-relevant physics."
      },
      "rationale": "ANSYS Fluent 2023R2 is used under an ISO 9001-certified QMS. Version control records and regression test suite outputs confirming coverage of rotating-frame and species-transport (hemolysis scalar) physics were reviewed. No open defects affecting hemolysis predictions were identified in the release errata. Required level 3 achieved."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-ncv",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/cou2-ncv",
        "type": "AcceptanceCriteria",
        "name": "Code verification acceptance criteria",
        "description": "Manufactured-solution or benchmark convergence tests must demonstrate second-order spatial accuracy for velocity and scalar transport; results must be documented in a solver verification report traceable to the current solver version."
      },
      "rationale": "Published ANSYS Fluent manufactured-solution convergence studies confirm second-order accuracy for the velocity and passive-scalar transport equations used in the hemolysis model. Convergence rates documented in solver verification report VR-2023R2-001. Required level 3 achieved."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-disc",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/cou2-disc",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria",
        "description": "Richardson extrapolation-based GCI must be computed on three systematically refined meshes; GCI on hemolysis index must be < 5% at all five operating points; near-wall y+ must be < 1 for the wall-resolved SST k-omega model."
      },
      "rationale": "Three meshes (4.2M, 8.7M, 17.1M cells) were generated by systematic 1.26× linear refinement. Richardson extrapolation GCI values for hemolysis index ranged 1.8–4.3% across all five operating points, satisfying the < 5% criterion. Area-averaged y+ < 0.8 on impeller and volute walls. Required level 4 achieved."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-testcond",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/cou2-testcond",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria",
        "description": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol, flow rate, rotational speed) must be documented with calibrated instrumentation and traceable uncertainty budgets; deviations from ISO 10993-4 must be justified."
      },
      "rationale": "FDA experimental data were collected under ISO 10993-4 protocols with porcine blood at 37 °C ± 0.5 °C, 33 ± 2% hematocrit. Flow rates and rotational speeds were measured with calibrated Coriolis meters (±0.2%) and optical encoders (±0.05%). Full uncertainty budgets provided in experimental report FDA-PUMP-EXP-2019. Required level 3 achieved."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-outcomp",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/cou2-outcomp",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria",
        "description": "Normalized index of agreement (NIA) for hemolysis index must be >= 0.85 across all five operating points; model prediction intervals (95% CI from Monte Carlo) must overlap experimental uncertainty bands at each point."
      },
      "rationale": "NIA for hemolysis index was 0.91 across five operating points. Monte Carlo 95% prediction intervals overlapped experimental uncertainty bands at all five points. Largest absolute error was 8.3% at the 6 L/min, 2400 RPM condition, within the declared acceptance threshold. Required level 4 achieved."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-qoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/cou2-qoi",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criteria",
        "description": "The primary QoI (normalized index of hemolysis, NIH) must be the same scalar used in clinical risk thresholds; secondary QoIs (shear stress distributions, exposure time histograms) must be demonstrably linked to the hemolysis power-law model inputs."
      },
      "rationale": "Primary QoI is NIH as defined in ASTM F1841, directly used in the clinical acceptance threshold. Secondary QoIs (volume-averaged shear stress, Lagrangian exposure-time distributions) are the direct inputs to the Giersiepen-Wurzinger hemolysis power-law integrated in the CFD solver. Linkage documented in model description report MDR-COU2-001. Required level 3 achieved."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-valrel",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/cou2-valrel",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance acceptance criteria",
        "description": "Validation experiments must use the same FDA generic pump geometry; operating points must span the clinical flow-speed envelope; blood analogue or porcine blood must be used; hemolysis measurement technique must be photometric plasma-free hemoglobin."
      },
      "rationale": "Validation used the identical FDA generic centrifugal pump STL geometry. Five operating points (4–8 L/min, 2000–2800 RPM) span the declared VAD clinical envelope. Porcine blood with photometric plasma-free hemoglobin measurement (Drabkin's reagent, 540 nm) was used, matching the clinical measurement standard. Required level 4 achieved."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-nse",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Numerical solver error as a distinct credibility factor addresses iterative convergence errors arising in time-domain or stochastic solvers with explicit time-stepping error budgets (e.g., NASA-STD-7009 ODE integration residuals). The present analysis uses a steady-state RANS solver with algebraic multigrid convergence monitored to residuals < 1e-6 for all equations; iterative convergence is subsumed within the Discretization Error factor assessment (GCI methodology). No separate solver-error budget is meaningful or required under ASME V&V 40 for steady-state RANS CFD. This factor is therefore not applicable to this COU."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-useerr",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Use error as a standalone credibility factor is applicable when an AI/ML model or decision-support tool is operated by clinical end-users who may misinterpret outputs (cf. FDA AI/ML SaMD guidance). In this COU, the CFD model is operated exclusively by trained simulation engineers under a documented SQA plan; outputs are reviewed by a credibility assessment team before informing any regulatory submission. There is no direct clinician-facing interface. User-facing error modes are therefore outside the scope of ASME V&V 40 credibility assessment for this simulation and this factor is not applicable."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-modelform",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Model form uncertainty as a separate credibility factor is invoked when competing mathematical formulations exist and a selection must be justified (e.g., choice among turbulence closure families, or between continuum and particle-based hemolysis models). In this assessment, the hemolysis power-law (Giersiepen-Wurzinger) and SST k-omega turbulence closure were fixed by the FDA-sponsored round-robin protocol that defines the COU; no model-form selection is within the scope of this submission. Model form is therefore not applicable as an independent credibility factor; sensitivity to the fixed model form is addressed within the Output Comparison and Validation Relevance factors."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-modelinputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "The Model Inputs factor targets cases where uncertain or variable patient-specific boundary conditions (e.g., cardiac output waveforms, aortic impedance spectra) are propagated through the simulation. For the FDA generic pump round-robin, all boundary conditions (inlet flow rate, outlet pressure, rotational speed, fluid properties) are prescribed from controlled experimental measurements with documented uncertainty budgets addressed under the Test Conditions factor. There are no free or patient-specific input parameters requiring separate credibility treatment; this factor is therefore not applicable to this COU."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-testsamples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Test Samples as a credibility factor addresses variability across a population of physical specimens (e.g., device-to-device manufacturing variation in a bench test campaign). The FDA generic centrifugal pump validation dataset was generated from a single reference pump geometry fabricated by stereo-lithography to a single nominal CAD file; there is no device-to-device sample population. Sample variability is therefore structurally absent from this validation activity and the factor is not applicable. Manufacturing tolerance sensitivity is partially addressed within the Discretization Error factor via geometry perturbation studies."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2-equivinput",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Equivalency of Input Parameters is applicable when validation experiments are conducted on a surrogate or scaled geometry and a mapping to the COU geometry must be justified (e.g., a 1:5 scale water tunnel model mapped to a full-scale blood pump via Reynolds and Stokes number equivalence). In this COU, the validation experiments and the COU simulation both use the identical FDA generic pump geometry at full scale with the same fluid (porcine blood) and the same operating conditions. No surrogate-to-COU parameter mapping is required and this factor is therefore not applicable."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels under ASME V&V 40 at Model Risk Level 5. Discretization error GCI < 5% across all operating points; output comparison NIA = 0.91 with overlapping uncertainty bands; validation activities used the identical FDA pump geometry at full scale. Six factors were determined not applicable based on documented structural arguments: numerical solver error is subsumed in the GCI assessment; use error does not apply to engineer-operated simulation tools; model form was fixed by the FDA round-robin protocol; model inputs are fully prescribed from controlled experiments; test samples are absent (single-geometry validation); and equivalency of input parameters is moot given identical geometry and conditions. Monte Carlo uncertainty quantification confirms that 95% prediction intervals remain below the clinical hemolysis threshold across the full operating envelope. The credibility package is accepted for regulatory submission supporting the Class III VAD 510(k) hemolysis claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
