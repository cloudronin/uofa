  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All eleven assessed credibility factors meet or exceed their required levels at MRL 5. Grid convergence index is below 5% at all operating points; Monte Carlo UQ with 1000 samples confirms NIH prediction intervals remain below the clinical threshold. Validation against the FDA benchmark demonstrates agreement within 14% across all five COU operating points. Two factors (Use error and Equivalency of input parameters) are scoped out with documented rationale: Use error is controlled by the assessed SQA framework; Equivalency of input parameters is rendered tautological by the co-extensive design of the validation and COU input spaces. The structured evidence record, provenance chain to foundational experimental data, and sensitivity analysis on turbulence model selection collectively support acceptance of the CFD hemolysis model for the Class III VAD COU.",
