  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for CPB Class II device at MRL 2) is accepted based on the following structured evidence: (1) All 11 assessed credibility factors meet or exceed their required Gradation levels — discretization error exceeds requirements at Gradation 3 via formal GCI study. (2) Two factors (Use Error, Test Samples) are scoped out with documented rationale: use error is inapplicable given controlled SOP-governed operation with independent review; test samples is inapplicable given the FDA reference geometry and subsumed fluid property uncertainty. (3) CFD-predicted NIH agrees with ASTM F1841 in-vitro experiments within 15% across all five operating points, with RH < 1.0 confirming the regulatory acceptance criterion. (4) The provenance chain is complete: validation results trace to archived experimental datasets, mesh convergence data, and solver configuration records. (5) Sensitivity analysis (hasSensitivityAnalysis) confirms that ±10% variation in power-law hemolysis model coefficients produces < 8% change in NIH, supporting model robustness. No offset rationale is required as all assessed factors meet required levels.",
    "decidedAt": "2026-04-19T00:00:00Z"
