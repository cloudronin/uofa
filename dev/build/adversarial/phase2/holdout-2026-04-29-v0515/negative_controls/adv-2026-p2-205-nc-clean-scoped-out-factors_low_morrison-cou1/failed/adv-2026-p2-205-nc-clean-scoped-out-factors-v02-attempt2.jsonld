      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-mf-ac-010",
        "type": "AcceptanceCriteria",
        "name": "Model form Gradation 2 — turbulence and hemolysis sub-model selection",
        "description": "The SST k-omega turbulence model was selected based on published literature demonstrating superior performance in rotating blood-contacting device flows relative to k-epsilon variants. The power-law hemolysis model (Giersiepen et al., modified by Heuser-Opitz) is the accepted standard for CFD hemolysis prediction in rotary blood pumps. Model form choices are documented with literature justification. Gradation 2 requires documented rationale for model form selection — satisfied."
      },
      "rationale": "SST k-omega and power-law hemolysis model selections are supported by peer-reviewed literature and documented in the simulation plan, meeting Gradation 2."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-mi-011",
      "type": "CredibilityFactor",
