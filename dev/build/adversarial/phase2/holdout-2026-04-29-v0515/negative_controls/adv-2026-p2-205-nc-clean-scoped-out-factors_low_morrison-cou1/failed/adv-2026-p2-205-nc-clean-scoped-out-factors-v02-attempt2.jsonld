      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-mi-ac-011",
        "type": "AcceptanceCriteria",
        "name": "Model inputs Gradation 2 — boundary conditions and material properties",
        "description": "All boundary conditions (inlet flow rate, outlet pressure, rotational speed) are derived from the experimental test matrix with documented measurement uncertainties. Blood viscosity is modeled as a Newtonian fluid with dynamic viscosity 0.0035 Pa·s (consistent with ASTM F1841 bovine blood analog). Pump geometry is reconstructed from manufacturer CAD files with dimensional tolerances ±0.05 mm. Gradation 2 requires documented input sources with traceability — satisfied."
      },
      "rationale": "All model inputs are traceable to experimental measurements or manufacturer specifications with documented uncertainties, meeting Gradation 2."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-ts-012",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Test samples is scoped out because this COU employs a purely computational study in which no physical test specimens are fabricated or destructively evaluated. The validation experiments used bovine blood sourced from a single certified supplier batch per ASTM F1841, and sample-to-sample variability in blood properties was characterised as part of the experimental uncertainty budget (±2% hematocrit, ±0.0002 Pa·s viscosity) rather than treated as a discrete credibility factor. The pump geometry used in both CFD and experiment is the FDA-published reference geometry, which is a defined computational artifact rather than a manufactured test article subject to production variability. Consequently, the concept of test sample credibility — which concerns representativeness of physical specimens relative to the intended-use device population — does not apply to this computational-experimental pairing. This determination is consistent with ASME V&V 40 guidance that test sample factors are not required when the model input geometry is a canonical reference artifact and fluid property variability is subsumed within the documented experimental uncertainty."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-eip-013",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
