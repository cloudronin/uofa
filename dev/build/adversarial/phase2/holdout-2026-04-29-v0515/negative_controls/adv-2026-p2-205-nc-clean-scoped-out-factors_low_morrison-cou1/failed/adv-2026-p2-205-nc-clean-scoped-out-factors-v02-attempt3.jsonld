  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model under CPB conditions is accepted at Medium assurance level. Eleven of thirteen credibility factors have been formally assessed, with all assessed factors meeting or exceeding their required gradation levels for MRL 2. Two factors (Model inputs and Equivalency of input parameters) are scoped out with documented technical justifications: the former because input uncertainty is bounded by adjacent assessed factors at MRL 2, and the latter because the validation and COU domains are identical, making a formal equivalency mapping exercise vacuous. The validation results demonstrate agreement between CFD-predicted relative hemolysis index and experimental measurements within combined uncertainty at all five operating points. The discretization error study confirms GCI < 2% for the primary QoI. The software quality assurance and code verification factors confirm the solver is fit for purpose. The decision consequence is HIGH and model influence is MEDIUM, consistent with MRL 2. No offset rationale is required because all assessed factors meet their required levels.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
