    {
      "id": "https://uofa.net/morrison/factor/model-inputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "At Model Risk Level 2, a full parametric uncertainty propagation for all model inputs is not required. The primary input uncertainties (fluid viscosity, pump geometry tolerances) are bounded by the experimental test conditions factor and the discretization error study. The geometry used in the CFD model was derived directly from the FDA-released CAD files with dimensional verification, and the blood analog viscosity was measured at the test temperature with a traceable viscometer. A formal probabilistic input uncertainty analysis would require Monte Carlo sampling across the full geometry tolerance space, which is disproportionate to the decision consequence at MRL 2 and is deferred to MRL 3 assessments. Scoping is consistent with ASME V&V 40 Table 3 guidance for MRL 2 credibility requirements."
    },
    {
      "id": "https://uofa.net/morrison/factor/test-samples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
