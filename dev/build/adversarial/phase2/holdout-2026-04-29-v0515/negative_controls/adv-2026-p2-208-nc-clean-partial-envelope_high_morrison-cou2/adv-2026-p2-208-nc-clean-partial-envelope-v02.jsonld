  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision/accepted-bounded-envelope-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors assessed with achieved levels meeting or exceeding required levels within the explicitly bounded operating envelope (flow rate 1–7 L/min, rotational speed 2000–5000 RPM, hematocrit 35–45%, temperature 36–38 °C, tip clearance 0.25 ± 0.05 mm). Monte Carlo uncertainty quantification (N=2000) demonstrates 95th-percentile NIH = 0.0034 g/100 L, well below the clinical threshold of 0.008 g/100 L. Validation experiments cover 8 of 35 envelope cells; coverage gaps in the remaining 27 cells are documented and bounded by interpolated CFD predictions with quantified uncertainty. The assessment team concludes the CFD model is credible for predicting absolute hemolysis levels within the declared bounded envelope and accepts the model for the Class III VAD submission under these constraints.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
