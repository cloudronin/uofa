    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/envelope",
      "type": "OperatingEnvelope",
      "name": "VAD centrifugal pump operating envelope — bounded flow and speed",
      "description": "Flow rate: 1–7 L/min; rotational speed: 2000–4000 RPM; inlet static pressure: 5–20 mmHg; outlet back-pressure: 60–120 mmHg; blood hematocrit: 35–45%; fluid temperature: 36–38 °C; impeller tip clearance tolerance: ±0.05 mm. All CFD simulations and bench validation experiments were conducted within these bounds. Extrapolation beyond any stated bound is explicitly out of scope."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint — Class III VAD, FDA generic centrifugal pump geometry",
      "description": "Model applicability is constrained to the FDA generic centrifugal pump geometry (hub diameter 30 mm, blade count 5) operating as a left ventricular assist device in adult patients (BSA 1.5–2.2 m²). The hemolysis constitutive model (power-law Giersiepen–Wurzinger) is valid only for shear exposure times less than 700 ms and shear stresses below 400 Pa. Results are not applicable to axial-flow pumps, paediatric patients, or non-Newtonian blood analogues."
    }
  },
