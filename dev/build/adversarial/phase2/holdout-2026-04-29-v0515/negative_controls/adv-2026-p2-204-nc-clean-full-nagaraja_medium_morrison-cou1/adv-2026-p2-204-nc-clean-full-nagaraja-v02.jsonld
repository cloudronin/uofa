  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-orthopedic-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-panel",
    "role": "Credibility assessment team — orthopedic CFD",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel accepts the CFD model for COU1 (TKR wear-debris transport, Class II, MRL 3) based on the following structured evidence: (1) Software quality assurance achieved Gradation 3 (required: 2), demonstrating robust solver provenance and analyst qualification. (2) Numerical code verification achieved Gradation 2 (required: 2) via three benchmark problems with errors below specified thresholds. (3) Discretization error achieved Gradation 3 (required: 3) with GCI_fine = 2.8% and confirmed second-order spatial accuracy. (4) Test conditions achieved Gradation 2 (required: 2) per ISO 14243-1 with all control parameters within specified tolerances. (5) Output comparison achieved Gradation 3 (required: 3) with MAPE = 6.3% and 92% spatial predictions within experimental uncertainty. (6) QoI relevance achieved Gradation 3 (required: 2) with documented mapping to clinically relevant osteolysis endpoint. (7) Validation relevance achieved Gradation 3 (required: 3) using production-representative components and two independent experimental datasets. Six factors are scoped out with documented rationale appropriate for MRL 3. Sensitivity analysis confirms RAI output is robust to ±15% viscosity and ±10% gap geometry perturbations. No factor has achievedLevel < requiredLevel. The provenance chain is complete from foundational experimental datasets through validation activities to this assessment. The panel concludes the model provides adequate credibility evidence to support identification of worst-case wear-debris accumulation sites for the Class II TKR device within the documented operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
