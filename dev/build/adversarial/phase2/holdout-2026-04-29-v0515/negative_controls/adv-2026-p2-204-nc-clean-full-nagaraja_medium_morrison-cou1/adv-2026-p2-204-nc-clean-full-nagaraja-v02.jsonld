    "name": "COU1: Total knee replacement wear-debris transport (Class II)",
    "description": "A CFD model is used to evaluate synovial fluid flow patterns and wear-particle transport within the joint space of a total knee replacement implant under physiological gait loading. Model influence is MEDIUM (in vitro wear-simulator data confirm relative particle accumulation trends); decision consequence is HIGH (incorrect prediction of debris hotspots could impact clinical osteolysis outcomes). Model Risk Level 3.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case wear-debris accumulation sites across five representative gait cycle phases for a Class II TKR device. Results compared against in vitro wear-simulator particle-distribution data using relative accumulation index (RAI < 1.15 acceptance criterion).",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/nagaraja-cou1-orthopedic/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "TKR orthopedic domain applicability constraint",
      "description": "Model applicability is restricted to cobalt-chromium on ultra-high-molecular-weight polyethylene (CoCr-on-UHMWPE) TKR implants operating under physiological gait loading (0.5–3.0 BW axial force). Excludes revision implants, metal-on-metal articulation, and non-ambulatory loading regimes. Patient population limited to adults (BMI 18–40) with primary osteoarthritis; pediatric and rheumatoid arthritis cases are out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/nagaraja-cou1-orthopedic/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "TKR physiological operating envelope",
      "description": "Synovial fluid dynamic viscosity: 1.0–50.0 mPa·s (shear-rate-dependent Carreau model, shear rates 0.1–1000 s⁻¹). Axial joint load: 500–3000 N (0.5–3.0 BW for 70 kg patient). Flexion angle: 0–120°. Implant gap clearance: 0.05–0.30 mm. Wear-particle diameter: 0.1–10 µm. Gait cycle frequency: 0.5–1.2 Hz. Temperature: 36–38 °C. All boundary conditions derived from ISO 14243-1 and published in vivo kinematic datasets."
    }
  },
