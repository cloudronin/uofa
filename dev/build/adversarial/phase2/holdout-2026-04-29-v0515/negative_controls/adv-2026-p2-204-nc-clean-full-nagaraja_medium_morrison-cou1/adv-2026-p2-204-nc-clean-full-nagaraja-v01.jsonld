      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-ortho-ac-07-relvalact",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance: validation experiments conducted within COU operating envelope bounds",
        "description": "At least 80% of validation experiments must be conducted within the COU operating envelope (BMI 18–40 kg/m², cadence 60–120 steps/min, load 1.5–3.5× BW, sizes 1–7). Extrapolation experiments outside the envelope must be explicitly flagged and their contribution to overall credibility discounted."
      },
      "rationale": "All 15 validation experiments were conducted within the COU operating envelope. Fluid temperature, load magnitude, cadence, and insert geometry all fell within the specified bounds. The validation matrix was designed a priori to span the envelope corners and centre point, ensuring representative coverage. Required and achieved levels both at 3."
    },
