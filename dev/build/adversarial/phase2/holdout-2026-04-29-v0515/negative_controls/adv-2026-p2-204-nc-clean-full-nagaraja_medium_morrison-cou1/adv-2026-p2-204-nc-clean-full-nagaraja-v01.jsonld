  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-ortho-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/nagaraja-orthopedic-credibility-team",
    "role": "Credibility assessment team — orthopedic CFD lead and independent reviewer",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (tibial tray fluid-film wear prediction, Class II, MRL 3) is accepted on the basis of the following structured evidence: (1) All 9 assessed CredibilityFactors meet or exceed their required levels, with no shortfall gaps. (2) Discretization error (GCI_fine = 1.4%) and output comparison (mean NWF deviation 6.3%, max 13.8%) both satisfy quantitative acceptance criteria with documented uncertainty quantification via Monte Carlo propagation (1000 samples). (3) The validation activity matrix spans the full COU operating envelope with 15 experiments, all within the specified bounds of BMI 18–40 kg/m², cadence 60–120 steps/min, and load 1.5–3.5× BW. (4) Three factors (Model form, Test samples, Equivalency of input parameters) are scoped out with documented rationale referenced to project risk register and V&V plan entries; these scoping decisions are consistent with MRL 3 expectations for a Class II device. (5) Sensitivity analysis confirms that peak fluid film pressure is most sensitive to synovial fluid viscosity (±9.2% response to ±1 SD viscosity variation) and least sensitive to cadence within the operating envelope (±1.8%), supporting the robustness of worst-case identification. (6) Software quality assurance and use error factors achieved above-minimum levels (3 and 2 respectively), providing additional confidence in simulation integrity. The overall evidence package is judged sufficient to support the regulatory claim that the CFD model reliably identifies worst-case hemolysis operating conditions for the Class II tibial tray device under the defined COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
