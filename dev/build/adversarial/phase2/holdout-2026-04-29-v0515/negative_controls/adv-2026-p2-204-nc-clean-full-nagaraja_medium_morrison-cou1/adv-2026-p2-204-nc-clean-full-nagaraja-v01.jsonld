    "name": "COU1: Tibial tray fluid-film wear prediction (Class II orthopedic)",
    "description": "A CFD model is used to evaluate fluid film pressure distribution and peak contact stress under physiological gait loading cycles for a Class II total knee replacement tibial tray. The model identifies worst-case wear operating conditions across a matrix of patient body mass index (BMI 18–40 kg/m²), gait cadence (60–120 steps/min), and tibial component sizing (size 1–7). Model influence is MEDIUM (bench wear testing confirms relative rankings); decision consequence is HIGH (incorrect identification of worst-case wear could lead to accelerated clinical failure). Model Risk Level 3.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case fluid film pressure and contact area conditions across a 5×3×7 matrix of gait, BMI, and sizing combinations for a Class II tibial tray implant. Results compared against pin-on-disc wear coupon data using normalized wear factor (NWF < 1.15 acceptance criterion).",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-placeholder",
      "type": "ApplicabilityConstraint",
      "name": "Scope constraint: cemented tibial tray, UHMWPE bearing, physiological gait only",
      "description": "The credibility assessment applies exclusively to cemented tibial tray configurations with UHMWPE bearing inserts under standard physiological gait loading. Cementless fixation, metal-on-metal articulations, high-flexion activities (>120° knee flexion), and stair-climbing or running profiles are outside the scope of this COU and must be assessed under a separate COU with dedicated validation evidence."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/envelope-placeholder",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: gait cadence 60–120 steps/min, BMI 18–40 kg/m², axial load 1.5–3.5× BW, component sizes 1–7",
      "description": "The model is validated within the following quantitative bounds: gait cadence 60–120 steps/min; patient BMI 18–40 kg/m²; peak axial tibio-femoral load 1.5–3.5× body weight; tibial tray sizes 1 through 7 per manufacturer sizing chart; synovial fluid viscosity 1.5–4.0 mPa·s at 37 °C; UHMWPE insert thickness 8–12 mm. Extrapolation beyond any single bound requires documented sensitivity analysis and re-validation."
    }
