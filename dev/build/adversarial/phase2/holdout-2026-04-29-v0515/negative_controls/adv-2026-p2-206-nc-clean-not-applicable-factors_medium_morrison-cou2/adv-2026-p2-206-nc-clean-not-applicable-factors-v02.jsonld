  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All eleven assessed credibility factors meet or exceed their required gradation levels at MRL 5. Two factors (Numerical solver error, Use error) are marked not-applicable with documented rationale referencing an independent NAFEMS V&V certificate and an ISO 13485-audited QMS respectively; these exclusions are compliant with ASME V&V 40 Section 5.3. Monte Carlo UQ (5000 samples) propagates input, model-form, and boundary-condition uncertainty to the hemolysis QoI; the 95% CI of predicted NIH lies entirely below the clinical threshold of 0.8 g/100 L across all 5 operating points. Validation NRMSE of 9.3% is within the pre-specified 15% acceptance criterion, and Monte Carlo confidence intervals overlap experimental uncertainty bands at all operating points. The provenance chain is complete from raw experimental data through CFD runs to the validation results. No credibility gaps remain; the structured evidence supports acceptance of the claim that the CFD model can predict absolute hemolysis levels for this Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
