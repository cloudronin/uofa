  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5. Twelve factors achieve their required gradation level; one factor (Output Comparison) exceeds its required level (achieved Gradation 5 vs. required 4). No factor falls below its required level; therefore no offset rationale is required. Monte Carlo UQ (N=5000) confirms that the 95% prediction interval for normalised hemolysis index lies below the clinical threshold at all five operating points within the defined operating envelope. Sensitivity analysis identifies hemolysis model coefficient A as the dominant uncertainty contributor (43% of output variance), followed by Carreau-Yasuda parameter n (21%); both are constrained by experimental data. The provenance chain is complete: validation results link to experimental datasets, UQ activities, and CFD production runs. The structured evidence base supports acceptance of the claim that the CFD model can reliably predict absolute hemolysis levels for this Class III VAD device within the defined COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
