  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5; achieved levels meet or exceed required levels across all factors. Discretization error GCI < 2% on fine mesh; numerical solver convergence to residuals < 5×10⁻⁷; SQA certification confirmed. Hemolysis predictions within 18% of experimental values at all five operating points (acceptance threshold ±25%). Monte Carlo UQ (2000 samples) confirms 95th-percentile NIH prediction remains below clinical threshold. Sensitivity analysis identifies hemolysis model coefficients α and β as dominant uncertainty contributors (combined 61% of output variance); these are bounded by the Morrison 2022 corpus. Validation dataset is independent, multi-laboratory, and spans the full COU operating envelope. No credibility factor shortfalls; no offset rationale required. The body of evidence is sufficient to support use of the CFD model as the primary basis for hemolysis acceptance in the Class III VAD regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
