  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision/accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-vv40-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5. Achieved levels meet or exceed required levels for all factors: SQA (4≥4), NCV (4≥4), DE (4≥4), TC (5≥4), OC (4≥4), RQOI (4≥4), RVAC (5≥4), NSE (4≥3), UE (3≥3), MF (4≥4), MI (4≥4), TS (3≥3), EIP (4≥4). No credibility gaps exist. Monte Carlo UQ with 5000 LHS samples demonstrates hemolysis index 95th-percentile prediction remains 23% below clinical threshold across all 5 operating points. Sensitivity analysis identifies power-law model constants as dominant uncertainty contributors (Sobol total-order index 0.61); these are bounded by literature calibration uncertainty. Validation evidence is directly relevant to the COU (same geometry, same QoI, same operating envelope). The complete absence of factor shortfalls at MRL 5 supports unconditional acceptance of the CFD model for absolute hemolysis prediction in the VAD COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
