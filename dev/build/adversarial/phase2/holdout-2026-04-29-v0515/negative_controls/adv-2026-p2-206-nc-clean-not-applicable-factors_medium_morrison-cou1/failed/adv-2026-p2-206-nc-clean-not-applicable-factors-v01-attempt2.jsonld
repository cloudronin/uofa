  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-division-of-applied-mechanics",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump under CPB conditions is accepted as credibly supporting the COU decision (identification of worst-case hemolysis operating conditions) at Model Risk Level 2. Seven factors were formally assessed: all seven achieved their required credibility levels, with Discretization Error exceeding the requirement (achieved Gradation 3 vs. required Gradation 2). Four factors were not-assessed, consistent with MRL 2 credibility goals per ASME V&V 40-2018 Table 1. Two factors (Test Samples, Equivalency of Input Parameters) were marked not-applicable with documented rationale: the single-specimen FDA reference pump eliminates test sample variability, and the identical validation and COU domains eliminate the need for input parameter equivalency mapping. No factor shortfalls exist; no offset rationale is required. The structured evidence base — mesh convergence study (GCI 2.3%), multi-point output comparison (max deviation 11.2%, all RH < 1.0), and documented SQA and code verification — provides sufficient credibility for a Class II device at MRL 2 under the Medium model influence and High decision consequence profile.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
