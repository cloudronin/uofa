  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/principal-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels at MRL 2 for this Class II CPB device. The discretization error factor exceeded its required level (achieved Gradation 3 vs. required Gradation 2), providing additional confidence in numerical accuracy. Four factors were not-assessed in accordance with the MRL 2 scoping decision documented in the credibility assessment plan — this is consistent with ASME V&V 40 guidance that not all factors require formal assessment at every risk level. Two factors (Test samples, Equivalency of input parameters) were determined not-applicable with documented rationale: the GCBP reference geometry eliminates sample variability concerns, and the validation conditions directly match the COU envelope without requiring bridging arguments. The validation results demonstrate NIH predictions within 8–13% of experimental measurements across all five operating points, satisfying the RH < 1 acceptance criterion relative to the predicate device. The provenance chain from foundational experimental data through CFD simulation to the credibility decision is complete and traceable. The credibility evidence is sufficient to support regulatory submission for the intended CPB use.",
    "decidedAt": "2026-04-19T00:00:00Z"
