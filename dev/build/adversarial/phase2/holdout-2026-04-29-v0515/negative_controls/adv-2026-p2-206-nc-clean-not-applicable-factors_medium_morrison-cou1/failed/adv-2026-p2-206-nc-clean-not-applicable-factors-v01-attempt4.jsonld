  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis prediction, MRL 2) is accepted based on the following structured evidence: (1) All 11 assessed factors meet or exceed their required credibility levels — no shortfalls exist. (2) The two not-applicable factors (Model Form and Test Samples) are excluded with documented rationale appropriate for an empirical damage-index model and a single-artifact validation dataset, respectively; their exclusion is consistent with ASME V&V 40 Table 3 guidance for MRL 2. (3) Discretization error GCI < 5% and iterative convergence below 1e-6 confirm numerical solution quality. (4) NIH predictions agree with in-vitro measurements within 8–13%, satisfying the 15% acceptance criterion at all five operating points. (5) The validation geometry, operating envelope, and fluid properties are directly relevant to the CPB COU. (6) Independent peer review of simulation setup and input parameter uncertainty analysis are complete. The totality of evidence provides sufficient confidence that the CFD model can reliably identify worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
