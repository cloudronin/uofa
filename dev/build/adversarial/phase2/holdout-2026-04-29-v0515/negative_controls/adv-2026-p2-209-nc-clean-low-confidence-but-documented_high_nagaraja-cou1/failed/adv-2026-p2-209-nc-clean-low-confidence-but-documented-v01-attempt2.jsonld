    {
      "id": "https://uofa.net/synth/cf/nagaraja-tc",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-tc-ac",
        "type": "AcceptanceCriteria",
        "name": "Test conditions Gradation 2 criteria (shortfall from required Gradation 3)",
        "description": "Gradation 3 would require testing at multiple load rates and environmental conditions. Only a single quasi-static load rate (1 mm/min, ambient temperature 23±2°C) was used. Gradation 2 achieved: test conditions fully documented, calibrated equipment, and traceable to ASTM F1717 standard protocol. The shortfall is honestly documented with a wide uncertainty bound on load-rate sensitivity."
      },
      "rationale": "ASTM F1717 specifies a single quasi-static load rate (1 mm/min); no multi-rate or thermal conditioning variants were conducted. This limits Gradation to 2 rather than the required 3. The load-rate sensitivity of Ti-6Al-4V construct stiffness is well-characterized in the literature (rate effect <2% over 0.1–10 mm/min range at ambient temperature); this published evidence partially compensates for the missing experimental variation. Wide uncertainty bound of ±5% applied to test-condition contribution to QoI uncertainty and propagated into E/uval calculation. The limitation is explicitly flagged in the assessment report (Section 4.3) and in the offset rationale supporting the Accepted decision."
    },
