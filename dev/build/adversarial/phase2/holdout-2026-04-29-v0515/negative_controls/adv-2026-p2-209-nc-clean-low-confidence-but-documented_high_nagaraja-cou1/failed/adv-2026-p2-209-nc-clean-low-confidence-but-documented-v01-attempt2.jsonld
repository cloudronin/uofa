      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-oc-ac",
        "type": "AcceptanceCriteria",
        "name": "Output comparison Gradation 3 criteria",
        "description": "Quantitative comparison using E/uval metric per ASME V&V 40. Acceptance bound: E/uval < 1.96 AND mean absolute error < 10% for all three QoIs. Uncertainty in validation metric (uval) accounts for both experimental and model uncertainty."
      },
      "rationale": "E/uval computed for all three QoIs: stiffness 0.84 (pass), yield force 1.31 (pass), force at 40 mm 1.61 (pass). Mean absolute errors: stiffness 4.2%, yield force 7.6%, force at 40 mm 8.9% — all within the <10% pre-specified bound. Validation uncertainty (uval) incorporates experimental repeatability (inter-lab CV), model input uncertainty (Monte Carlo), and the explicitly-flagged test-condition uncertainty contribution (±5%). All three QoIs pass both acceptance criteria. Gradation 3 achieved for output comparison."
