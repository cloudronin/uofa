  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2025",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at Model Risk Level 5. Achieved levels meet or exceed required levels across all factors. Key evidence: (1) Discretization error: GCI_fine = 0.87%, achieving Gradation 5 against a requirement of 4. (2) Output comparison: hemolysis index within ±12% at all five operating points, within validation uncertainty band. (3) Model form: SST k-ω turbulence model justified by systematic literature review and alternative model comparison. (4) Monte Carlo UQ with 2000 samples characterizes prediction uncertainty; 95th percentile hemolysis prediction remains below clinical threshold (MIH < 0.8 mg/dL vs. threshold of 1.5 mg/dL). (5) Sensitivity analysis identifies hemolysis model constants (β exponent) as dominant uncertainty source, with ±5% variation producing ±11% hemolysis index variation — within acceptable bounds. Full provenance chain documented from foundational experimental data (Hariharan et al., 2011, FDA benchmark) through verification, validation, and UQ activities. No credibility gaps remain. Decision: Accepted for regulatory submission supporting Class III VAD 510(k) premarket notification.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
