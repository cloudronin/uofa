  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been fully assessed at Model Risk Level 5. Achieved levels meet or exceed required levels for all factors: seven factors meet required levels exactly (Software QA: 4/4, Numerical Code Verification: 4/4, Discretization Error: 4/4, Test Conditions: 4/4, Relevance of QoI: 4/4, Relevance of Validation Activities: 4/4, Model Form: 4/4, Model Inputs: 4/4, Equivalency of Input Parameters: 4/4, Use Error: 3/3, Test Samples: 3/3), and two factors exceed required levels (Output Comparison: 5 achieved vs. 4 required; Numerical Solver Error: 4 achieved vs. 3 required). Monte Carlo uncertainty quantification (N=10,000 samples) demonstrates that CFD-predicted NIH values remain below the clinical threshold of 0.1 g/100L across the full operating envelope at 95% confidence. Sensitivity analysis identifies scalar shear stress magnitude and Lagrangian exposure time as dominant contributors to NIH uncertainty (combined 78% of total variance). The validation evidence base is grounded in experiments using the identical pump geometry, physiological blood, and COU-representative operating conditions. No credibility gaps remain. The package satisfies all MRL 5 requirements under ASME V&V 40-2018 and supports regulatory submission for the Class III VAD indication.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
