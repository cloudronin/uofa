  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "decisionConsequence": "High",
    "modelInfluence": "High",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Class III centrifugal VAD applicability domain",
      "description": "Applicable to continuous-flow centrifugal blood pumps operating as left ventricular assist devices (LVADs) in adult patients. Scope is restricted to the FDA generic pump geometry with rotor speeds between 2000 and 3500 RPM and flow rates between 2 and 8 L/min. Excludes pulsatile pumps, axial-flow devices, and pediatric LVAD configurations. Hemolysis predictions are valid only for Newtonian blood rheology assumptions at 37 °C with haematocrit 40 ± 5%."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/envelope",
      "type": "OperatingEnvelope",
      "name": "VAD operating envelope — flow, speed, and pressure bounds",
      "description": "Flow rate: 2–8 L/min (±0.1 L/min measurement uncertainty). Rotor speed: 2000–3500 RPM (±10 RPM). Inlet pressure: 5–15 mmHg. Outlet pressure: 80–120 mmHg. Blood temperature: 36–38 °C. Haematocrit: 35–45%. Geometry tolerance: ±0.05 mm on all wetted surfaces relative to nominal FDA generic pump CAD. Five representative operating points (Q=3 L/min/2500 RPM, Q=4 L/min/2500 RPM, Q=5 L/min/2800 RPM, Q=6 L/min/3000 RPM, Q=7 L/min/3200 RPM) span the clinical operating range."
    }
  },
