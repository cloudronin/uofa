  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision/accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been fully assessed at Model Risk Level 5. Every factor achieves a level meeting or exceeding the required level for this MRL: 11 factors achieve exactly their required level (Gradation 4), and 2 factors (Numerical Code Verification, Relevance of QoI) achieve Gradation 5 — one level above requirement. No offset rationale is required as no factor exhibits a shortfall. Monte Carlo uncertainty quantification (10,000 samples) demonstrates that CFD hemolysis index predictions remain below the absolute clinical threshold (HI < 0.01%) with 97.3% probability across the full operating envelope. Sensitivity analysis identifies impeller tip clearance and inlet turbulence intensity as the two dominant uncertainty drivers, both of which are directly controlled in the experimental validation. The validation dataset (Hariharan et al. 2011 FDA benchmark) provides five independent replicates at each of five operating points spanning the full COU envelope, with hemolysis agreement within the ±30% acceptance band at all points. The provenance chain is complete: experimental data, CFD predictions, UQ samples, and post-processing scripts are all archived with traceable identifiers. The credibility evidence is sufficient to support regulatory submission for the Class III VAD device hemolysis claim. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
