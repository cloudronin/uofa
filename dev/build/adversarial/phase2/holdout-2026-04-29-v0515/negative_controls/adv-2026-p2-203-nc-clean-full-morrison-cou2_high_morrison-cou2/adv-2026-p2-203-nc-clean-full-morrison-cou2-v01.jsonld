  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision/accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 5. Twelve factors meet or exceed their required gradation levels; one factor (QoI Relevance) exceeds its requirement by a full gradation (achieved 5 vs. required 4), providing additional confidence margin. Monte Carlo uncertainty quantification (2 000 Latin hypercube samples) demonstrates that the 95th-percentile hemolysis index prediction remains below the clinical acceptance threshold across all five operating points. Grid convergence is confirmed (fine-grid GCI = 1.4%). Independent reproduction of the simulation pipeline found no use errors. The validation dataset uses the identical FDA generic pump geometry under matched operating conditions. The combined weight of structured evidence across computational, experimental, and uncertainty-quantification activities supports acceptance of the CFD model for predicting absolute hemolysis levels in the Class III VAD COU. No credibility gaps remain unaddressed.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
