  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-fda-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending is accepted as sufficiently credible for the intended regulatory use. Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — arises from the single-configuration ASTM F1717 test matrix. This shortfall is offset by: (1) the high fidelity of the constitutive model form validated against lot-specific material data; (2) E/uval < 1.96 for all three QoIs, indicating that model predictions are consistent with experimental scatter even under the single test condition; and (3) the conservative 10% QoI acceptance bound, which provides margin against uncharacterized loading-condition sensitivity. The offset rationale is documented in hasOffsetRationale.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/nagaraja-cou1-tc-offset",
      "type": "OffsetRationale",
      "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs. required 3)",
      "refersToFactor": "https://uofa.net/synth/factor/nagaraja-cou1-tc",
      "justification": "The Test conditions factor achieved Gradation 2 (single ASTM F1717 load configuration) against a required Gradation 3 (multiple load levels or angulation angles). This shortfall is offset by three compensating strengths: (1) E/uval ratios for all three QoIs fall well below the 1.96 acceptance threshold (max 1.62), demonstrating that prediction error is small relative to combined experimental and simulation uncertainty even at the single tested condition; (2) a parametric sensitivity study on friction coefficient (±0.05) and fixture stiffness (±500 N/mm) showed QoI variation < 3%, indicating low sensitivity to boundary condition perturbations that would be expected across additional test configurations; and (3) the ASTM F1717 standard specifies a single canonical test configuration for regulatory submission, making the single-condition test matrix the accepted industry norm for this device class. Collectively, these factors provide sufficient confidence that model predictions would remain within acceptance bounds under the range of conditions relevant to the COU."
    }
  },
