  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble satisfies all primary acceptance criteria: E/uval < 1.96 and QoI difference < 10% for all three quantities of interest (stiffness, yield force, force at 40 mm displacement) across N=11 production-representative specimens at two independent laboratories. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions (achieved level 2 vs. required level 3) — is addressed by the offset rationale below. The overall evidence package demonstrates adequate credibility for a Class II MRL 3 device at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/tc-shortfall",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/factor/tc",
      "justification": "The Test conditions factor achieved level 2 against a required level 3 because only the static compression-bending configuration was evaluated; torsion and tension-bending modes were not tested. This shortfall is accepted for the following reasons: (1) the COU is explicitly scoped to compression-bending only, which is the dominant failure mode for non-cannulated pedicle screw constructs under physiological loading; (2) FDA guidance for 510(k) submissions for spinal implants identifies compression-bending as the primary benchmark test; (3) the three QoIs selected (stiffness, yield force, force at 40 mm) are all compression-bending-specific metrics with no cross-mode ambiguity; (4) the high relevance scores on all other factors (model form, model inputs, test samples, output comparison) provide compensating confidence. The risk associated with the single-condition limitation is documented in risk analysis RA-2023-003 and judged acceptable for the stated COU."
    }
  },
