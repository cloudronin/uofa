  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-mrl5-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw ASTM F1717 static compression-bending COU is accepted at MRL 5 based on the following structured evidence: (1) All 13 V&V 40 credibility factors assessed; 12 of 13 achieve or exceed required Gradation 4 level. (2) All three regulatory QoIs (stiffness, yield force, force at 40 mm) pass the pre-established ASME V&V 20 area metric with E/uval < 1.96 and relative error < 10%. (3) Mesh convergence GCI < 1% across all QoIs confirms discretization error is controlled. (4) Specimen-specific FEA inputs (CMM geometry, lot-specific material) ensure equivalency. (5) Sensitivity analysis (report SA-2024-004) confirms model outputs are robust to ±20% variation in hardening slope and ±0.05 friction coefficient. (6) The single shortfall — Test conditions factor achieving Gradation 3 vs. required Gradation 4 — is offset by the narrow operating envelope (single F1717-prescribed configuration), the high reproducibility across two independent laboratories (CV < 5%), and the conservative acceptance bounds (E/uval threshold 1.96 vs. achieved maximum 1.78). The residual risk from single-condition testing is judged acceptable for a Class II device with Medium decision consequence, where bench testing remains the primary regulatory evidence and model influence is Medium.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-gradation3",
        "type": "OffsetRationale",
        "name": "Offset rationale: Test conditions Gradation 3 vs. required Gradation 4",
        "description": "The Test conditions factor achieves Gradation 3 (single fully-characterised loading condition) rather than the required Gradation 4 (≥2 distinct loading conditions). This shortfall is offset by three compensating strengths: (a) The COU is strictly bounded to the single ASTM F1717 configuration; no other loading condition is claimed or needed for the regulatory submission. (b) Inter-laboratory reproducibility across Lab-A (FDA CDRH) and Lab-B (DePuy Synthes) with CV < 5% for all QoIs confirms that the single condition is characterised with high fidelity. (c) All three QoIs achieve E/uval ≤ 1.78, well below the 1.96 threshold, indicating that the model's predictive capability is not limited by the single-condition test design. The assurance team and regulatory affairs lead concur that the evidence base is sufficient for a Class II device with Medium decision consequence, and that multi-condition testing would not materially reduce residual uncertainty within the defined COU scope."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-mrl5-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
