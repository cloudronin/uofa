  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed their required level. The single shortfall — Test conditions (achieved 3, required 4) — is attributable to the ASTM F1717 protocol prescribing a single displacement rate; this is a standard-imposed constraint rather than an analytical deficiency. The shortfall is offset by the high sample count (N=11 across two independent laboratories), the conservative nature of the single-condition protocol, and the fact that all three QoIs satisfy both the E/uval < 1.96 and < 10% absolute difference acceptance criteria simultaneously. Sensitivity analysis confirms QoI response is dominated by material yield strength variability (±3.8%) rather than loading-rate effects. The FEA ensemble (FDA, Ansys, DePuy Synthes) demonstrates consistent predictive performance across all three QoIs and both laboratories. The overall credibility evidence package is sufficient to support regulatory submission under the Medium model influence and Medium decision consequence classification.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/nagaraja-cou1-tc-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (achieved 3, required 4)",
        "description": "The Test conditions factor achieved Gradation 3 (single displacement rate per ASTM F1717) against a required Gradation 4 (two or more independent test conditions). This shortfall is offset by: (1) N=11 constructs across two independent laboratories providing high statistical confidence in the single-condition results; (2) sensitivity analysis demonstrating < 1% QoI sensitivity to ±10% variation in displacement rate, confirming the single-rate protocol is not a material limitation; (3) all three QoIs satisfying the primary E/uval < 1.96 acceptance criterion with margin (maximum E/uval = 1.78); and (4) the ASTM F1717 protocol being the FDA-recognised standard for this device class, meaning the single-condition constraint is regulatory-standard-imposed rather than analyst-chosen. The residual risk from this shortfall is assessed as Low and does not affect the fitness-for-purpose determination."
      },
      {
        "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/offset/nagaraja-cou1-tc",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/cf/nagaraja-cou1-tc",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
