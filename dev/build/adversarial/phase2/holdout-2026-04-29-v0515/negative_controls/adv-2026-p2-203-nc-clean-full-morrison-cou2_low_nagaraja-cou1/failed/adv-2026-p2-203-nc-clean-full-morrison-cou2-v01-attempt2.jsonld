  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nc3-mrl5-noncannulated-f1717-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "Twelve of thirteen ASME V&V 40 credibility factors meet or exceed their required gradation levels at MRL 5 (Complete profile). Quantitative validation metrics for all three QoIs satisfy both the <10% percentage difference criterion and the E/uval < 1.96 criterion, with maximum values of 2.3% and 1.42 respectively. UQ propagation (Monte Carlo N=10000) confirms model predictions are robust to input parameter uncertainty within the documented operating envelope. The single shortfall — Test conditions (achieved Gradation 3 vs. required Gradation 4) — is addressed by the offset rationale below. The complete provenance chain from raw experimental data through validated model outputs is documented and traceable. The credibility assessment team unanimously accepts this package for regulatory submission support.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/nc3-tc-offset",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/factor/nc3-tc",
      "justification": "The Test conditions factor achieved Gradation 3 (single loading rate, single temperature) against a required Gradation 4. This shortfall is offset by three compensating strengths: (1) ASTM F1717 is a standardized static test protocol with no clinically meaningful rate dependence for Ti-6Al-4V at quasi-static rates — published literature (Nagaraja et al. 2012, Goel et al. 2006) confirms stiffness and yield force vary < 2% across 1–25 mm/min; (2) the sensitivity analysis demonstrates that loading rate is not a dominant uncertainty contributor (Sobol index S_i = 0.02); and (3) the validation dataset spans two independent laboratories, providing environmental robustness evidence that partially compensates for the absence of formal multi-condition testing. The residual risk from the single test condition is therefore judged acceptable for the Medium decision consequence context.",
      "name": "Offset rationale for Test conditions shortfall (Gradation 3 vs. required 4)"
    }
  },
