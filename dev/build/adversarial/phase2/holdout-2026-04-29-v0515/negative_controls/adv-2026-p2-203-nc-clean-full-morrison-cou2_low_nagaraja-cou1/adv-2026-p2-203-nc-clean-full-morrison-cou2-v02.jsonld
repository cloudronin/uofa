  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-mrl5",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "All 13 ASME V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels (MRL 5 Complete profile). Three QoIs (stiffness, yield force, force at 40 mm) satisfy E/uval < 1.96 and < 10% QoI difference acceptance criteria across N=11 constructs and two independent laboratories. Sensitivity analysis confirms dominant uncertainty sources are material property scatter and friction coefficient; neither invalidates the validation conclusion. One factor (Test conditions) achieved Gradation 3 vs required Gradation 4; offset rationale documents that loading-rate sensitivity is negligible for quasi-static metallic constructs and the single-condition dataset is sufficient for the stated COU. Overall credibility is sufficient for the intended regulatory use (510(k) computational evidence package).",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/test-conditions-single-rate",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
      "justification": "Test conditions factor achieved Gradation 3 (single loading rate) versus required Gradation 4 (≥2 loading rate variants). This shortfall is offset by: (1) published literature (Rohlmann et al. 2001; Goel et al. 1998) demonstrating rate-independent quasi-static response for Ti-6Al-4V spinal constructs at rates 1–10 mm/min; (2) the FEA model is rate-independent (static analysis) and therefore insensitive to this variable; (3) all three QoIs satisfy E/uval < 1.96 at the single tested rate, providing direct empirical confirmation of model fidelity without requiring multi-rate data. The residual risk from single-condition testing is judged Low given the metallic quasi-static nature of the COU.",
      "name": "Offset rationale: single loading rate for quasi-static metallic construct"
    }
  },
