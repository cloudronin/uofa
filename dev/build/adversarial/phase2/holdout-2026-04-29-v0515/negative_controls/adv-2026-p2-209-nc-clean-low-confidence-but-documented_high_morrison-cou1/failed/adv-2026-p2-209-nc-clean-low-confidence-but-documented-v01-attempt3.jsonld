  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-dr-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The Morrison COU1 credibility assessment is accepted at Medium assurance level for MRL 2. Seven of thirteen factors were formally assessed; all seven meet or exceed their required Gradation 2 levels (Discretization error achieved Gradation 3). Six factors were scoped out or deemed not applicable, consistent with ASME V&V 40-2018 Table 3 guidance for MRL 2 Class II devices with medium model influence. The one explicitly-flagged confidence gap — the wide uncertainty on the hemolysis power-law exponent alpha (±12%) — is honestly documented in the Model inputs factor and in the validation result uncertainty quantification. LHS propagation demonstrates that even at the upper bound of alpha uncertainty, the worst-case NIH prediction satisfies the RH < 1 regulatory threshold with 97.3% probability, providing adequate confidence margin for the intended decision. The marginal agreement at OP-3 (overlap ratio 0.91) is noted but does not invalidate the worst-case identification objective, as OP-3 is not the worst-case operating point. The provenance chain is complete: simulation outputs are traceable to the FDA generic centrifugal pump benchmark dataset, validation activities are attributed to the Morrison credibility assessment team, and all uncertainty contributions are quantified. The structured evidence supports acceptance of the claim that the CFD model can reliably identify worst-case hemolysis operating conditions for this Class II CPB device.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/morrison-cou1-cpb-or-01",
      "type": "OffsetRationale",
      "description": "No factor shortfall exists in this package: all assessed factors achieve their required level. The hasOffsetRationale is provided to document the explicitly-flagged wide uncertainty on the power-law exponent alpha, which does not constitute a level shortfall but is accepted as residual epistemic risk. The 97.3% probability of satisfying RH < 1 across the full alpha uncertainty range, combined with the conservative worst-case identification objective and the medium model influence classification, provides sufficient justification for acceptance without requiring additional model form assessment at MRL 2."
    }
  },
