  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-division-of-applied-mechanics",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels at MRL 2. The 6 remaining factors are appropriately scoped out or not applicable with documented rationale. The one explicitly-flagged gap — low confidence in blood viscosity input bounds — has been fully characterised through Monte Carlo uncertainty propagation. The 95% upper-bound RH prediction of 0.91 remains below the acceptance threshold of 1.0 with a margin of 9%, providing sufficient confidence that the worst-case hemolysis claim is supported. The decision accepts the viscosity uncertainty as residual risk on the basis of: (1) the upper-bound prediction satisfies the regulatory acceptance criterion; (2) the sensitivity analysis confirms no other input contributes comparably to prediction variance; and (3) a targeted viscosity characterisation study is recommended as a post-market commitment. The provenance chain is complete from experimental data through validation activities to this assurance package.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/morrison/offset/viscosity-gap-offset",
      "type": "OffsetRationale",
      "name": "Offset rationale for blood viscosity input uncertainty gap",
      "description": "The low-confidence blood viscosity bounds (±12% from literature) represent the sole documented shortfall in input characterisation confidence. This is offset by three compensating factors: (1) Monte Carlo propagation demonstrates the 95% upper-bound RH remains below 1.0 at all operating points; (2) the GCI study independently confirms discretization error is negligible (1.3%), ensuring the uncertainty budget is dominated by physics rather than numerics; and (3) experimental validation at all 5 COU operating points provides direct empirical grounding for the model predictions. The residual risk from viscosity uncertainty is judged acceptable for a Class II device at MRL 2 with medium model influence."
    }
  },
