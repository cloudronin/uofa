  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-v4",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation 2 levels under MRL 2. Six factors are appropriately scoped out or not applicable with documented rationale. The one explicitly flagged uncertainty — blood rheology input variability (±15% in viscosity and hematocrit) — has been honestly quantified via Monte Carlo propagation. The resulting 95th-percentile RH prediction interval of [0.71, 0.94] remains entirely below the regulatory acceptance threshold of RH < 1.0, providing a margin of 0.06 at the upper bound. The low-confidence input gap is accepted as bounded residual risk: the uncertainty is quantified, its effect on the decision criterion is demonstrably non-critical, and no unexamined epistemic gaps remain. Provenance is complete from raw experimental data through validation results to this decision. The credibility package is accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/morrison/offset/model-inputs-blood-rheology",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/morrison/factor/model-inputs",
      "justification": "The blood rheology input uncertainty (±15% viscosity/hematocrit, low confidence due to inter-donor variability) was propagated via Monte Carlo simulation. The 95th-percentile upper bound of the RH prediction interval is 0.94, which is 6% below the RH < 1.0 acceptance threshold. This margin is sufficient to accept the limitation as residual risk without additional data collection at MRL 2. The uncertainty is fully documented, quantified, and bounded; it does not invalidate the credibility claim."
    }
  },
