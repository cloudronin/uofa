  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-modeling-simulation",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted as credible for identifying worst-case hemolysis operating conditions under CPB use at MRL 2. Seven of thirteen credibility factors were formally assessed; all seven meet or exceed their required gradation levels. Six factors are appropriately scoped-out or not-applicable at MRL 2 with documented rationale. The one explicitly-flagged epistemic gap — wide uncertainty (±18% CI) on the Giersiepen hemolysis model coefficients — is fully documented in ValidationResult hemolysis-index-comparison and reflected in the conservative Model Form achievedLevel of 2. This gap does not undermine the decision because: (1) all five operating-point RH predictions remain below 0.82, providing an 18-percentage-point margin against the RH < 1.0 acceptance criterion that exceeds the uncertainty band; (2) physical hemolysis testing at three of five operating points corroborates the rank-ordering of worst-case conditions; (3) the GCI on the hemolysis QoI is 1.7%, confirming that discretization error does not compound the model-form uncertainty. The provenance chain is complete: simulation inputs trace to FDA-published CAD and ASTM fluid property standards; validation data trace to the peer-reviewed FDA GCBP benchmark dataset; the decision is grounded in structured evidence from all thirteen factors. No weakeners are present. The package is accepted without offset rationale because all assessed factors meet their required levels.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
