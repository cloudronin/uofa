  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six scoped-out or not-applicable factors are appropriately justified for this risk level. The single explicitly-flagged gap — wide 95% confidence interval on blood viscosity power-law parameter k (0.0035–0.0058 Pa·s^n) driving ±11% of the total ±18% RH uncertainty — has been fully characterised through a documented one-factor-at-a-time sensitivity sweep. The sensitivity analysis demonstrates that rank-ordering of worst-case hemolysis operating conditions is preserved across the entire sampled parameter space, which is the primary COU claim. The absolute RH uncertainty (±18%) is wider than would be ideal, but is accepted as residual risk because: (1) the COU claim is about rank-ordering, not absolute RH magnitude; (2) the predicate device comparison uses the same viscosity parameter assumptions, so the uncertainty is symmetric and does not bias the relative comparison; (3) physical testing at 5 operating points provides an independent confirmation of the CFD rank-ordering. The provenance chain is complete from raw PIV and hemolysis index measurements through validation results to this assurance package. No weakeners are expected to fire.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
