  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 5. Every factor achieves its required credibility level: five factors at level 4, three at level 5, three at level 3, and two at level 4 (all meeting or exceeding their respective required levels). Monte Carlo uncertainty quantification (2 000 samples) demonstrates that the 95th-percentile NIH prediction interval of ±0.0031 g/100 L is within the regulatory acceptance band of ±0.005 g/100 L. Grid-convergence index on NIH is 2.1%, well below the 5% threshold. Model form uncertainty (power-law hemolysis model) is bounded at 6.2% of NIH. Output comparison across all 5 VAD operating points yields normalised RMS error of 9.3%, within the 15% acceptance criterion. The provenance chain is complete from raw experimental data (FDA interlaboratory study) through data processing, CFD execution, and uncertainty propagation to the final NIH predictions. No credibility gaps remain. The assessment team unanimously concludes that the CFD model is sufficiently credible to support the regulatory decision that absolute hemolysis levels predicted for this Class III VAD device are below the clinical threshold.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
