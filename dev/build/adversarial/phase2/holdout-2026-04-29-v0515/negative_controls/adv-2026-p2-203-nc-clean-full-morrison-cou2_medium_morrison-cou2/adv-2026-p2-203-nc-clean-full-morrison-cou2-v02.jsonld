  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been fully assessed at MRL 5 rigor. All achievedLevels meet or exceed requiredLevels: 11 factors achieve exactly the required level and 2 factors (Output comparison, Numerical solver error) exceed the required level by one gradation, providing additional confidence margin. The Monte Carlo uncertainty quantification ensemble (2 000 runs) demonstrates that the 95th-percentile NIH prediction (0.0743 g/100L) remains below the absolute clinical threshold of 0.1 g/100L with a safety margin of 25.7%. Sensitivity analysis confirms that the dominant uncertainty contributors (fluid viscosity, hemolysis model coefficient C, rotational speed) are well-characterised and their combined effect is bounded within the validation uncertainty band. The validation evidence is directly relevant to the COU: same geometry, same QoI, all five operating points covered. No credibility factor gaps exist; no offset rationale is required. The credibility assessment team unanimously accepts the CFD hemolysis prediction model for use in the Class III VAD regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
