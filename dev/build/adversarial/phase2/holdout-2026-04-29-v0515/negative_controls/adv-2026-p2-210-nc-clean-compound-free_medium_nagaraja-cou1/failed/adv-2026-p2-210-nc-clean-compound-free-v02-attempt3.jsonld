  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — is addressed by the offset rationale below. Output comparison metrics (E/uval < 1.96 and QoI differences < 10%) are satisfied for all three primary quantities of interest across N=11 production-representative specimens tested at two independent laboratories. Software QA, mesh convergence, and model form factors all achieved Gradation 3, providing additional confidence margin. The overall credibility evidence is judged sufficient to support the Medium assurance level claim for the non-cannulated 7.5 mm pedicle screw FEA framework under ASTM F1717 static compression-bending.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/nagaraja-cou1-tc-offset",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs. 3)",
        "description": "The Test conditions factor achieved Gradation 2 because only a single ASTM F1717 standardized condition was evaluated (quasi-static, room temperature, 6.35 mm rod, 44 mm spacing). The shortfall is offset by three compensating strengths: (1) the ASTM F1717 protocol is the FDA-recognized standard for pedicle screw construct characterization, making the single condition the most clinically relevant; (2) the Output comparison factor achieved Gradation 3 with E/uval well below 1.96 for all QoIs, demonstrating robust predictive accuracy within the tested condition; and (3) the Test samples factor achieved Gradation 3 with N=11 specimens across two laboratories, ensuring the single-condition results are statistically reliable. The residual uncertainty from the single test condition is bounded by the sensitivity analysis, which showed < 3% QoI variation across the plausible input parameter space. The assessment team judges this offset sufficient for the Medium decision consequence and Medium model influence of COU1."
      },
      {
        "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026/offset/nagaraja-cou1-tc",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/factor/nagaraja-cou1-tc",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
