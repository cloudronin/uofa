  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for the non-cannulated pedicle screw compression-bending FEA model. Twelve factors were formally assessed: all twelve achieved their required gradation level, with Output Comparison exceeding the required level (Gradation 4 achieved vs. Gradation 3 required). The thirteenth factor (Test Conditions) was determined not-applicable due to the normatively fixed single-condition ASTM F1717 protocol; this determination was reviewed and concurred with by the regulatory affairs representative. The quantitative validation metric E/uval was below 1.96 for all three QoIs across both independent laboratories (E/uval: 0.83 stiffness, 1.12 yield force, 0.97 force at 40 mm), confirming that simulation uncertainty-normalized prediction error is within acceptable bounds. Provenance is fully documented from raw experimental data through the comparison activity to the validation results. No weakeners were identified. The overall credibility of the FEA model for the stated COU is assessed as sufficient to support the regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z",
