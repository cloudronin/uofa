  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-orthopedic-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-orthopedic-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors assessed at MRL 3. Seven factors meet required levels exactly (Gradation 3); two factors (Output comparison, Numerical solver error) exceed required levels (Gradation 4 and 3 respectively against requirements of 3 and 2). No factor achievedLevel falls below requiredLevel. Sensitivity analysis over tibial component alignment (±3° varus/valgus) and contact-area uncertainty confirms wear volume predictions remain within acceptance bounds across the full operating envelope. Validation results demonstrate FE-predicted wear volume within 8.3% of bench mean (acceptance criterion ±12%) and contact pressure within 7.1% (acceptance criterion ±10%). Provenance chain is complete from foundational material test data through simulation runs to validation results. The credibility evidence is sufficient to support the regulatory claim that the TKA FE wear model identifies worst-case operating conditions for a Class II device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
