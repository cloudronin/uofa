    "type": "ContextOfUse",
    "name": "COU1: Total knee arthroplasty tibial insert wear (Class II)",
    "description": "A finite-element contact-mechanics model is used to predict polyethylene tibial insert wear volume and distribution under ISO 14243-1 gait loading for a Class II TKA device. Model influence is MEDIUM (bench wear testing confirms simulation results); decision consequence is HIGH (incorrect wear prediction could lead to premature implant failure or under-designed tibial geometry). Model Risk Level 3.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use FE contact-mechanics simulation to identify worst-case wear operating conditions across five tibial component alignment and loading combinations for a Class II TKA device. Results compared against ISO 14243-1 pin-on-disc and knee simulator bench data using wear factor ratio (WFR < 1.15 acceptance criterion).",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/nagaraja-cou1-orthopedic/applicability",
      "type": "ApplicabilityConstraint",
      "name": "TKA tibial insert applicability constraint — MRL 3 in-scope domain",
      "description": "Model is applicable to fixed-bearing, cruciate-retaining TKA tibial inserts manufactured from GUR 1020 UHMWPE with cross-linked radiation doses between 50 and 100 kGy, implanted in patients with BMI ≤ 40 and neutral mechanical axis alignment within ±5°. Revision TKA, mobile-bearing designs, and unicompartmental devices are explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/nagaraja-cou1-orthopedic/envelope",
      "type": "OperatingEnvelope",
      "name": "ISO 14243-1 gait operating envelope for TKA wear simulation",
      "description": "Operating envelope bounds: axial compressive load 0–2600 N (peak); flexion–extension angle −5° to 135°; tibial internal–external rotation ±10°; anterior–posterior displacement ±5 mm; gait cycle frequency 1 Hz; simulation duration equivalent to 5 × 10⁶ cycles; tibial component alignment tolerance ±3° varus/valgus and ±3° posterior slope. Conditions outside these bounds require a separate COU assessment."
    }
  },
