      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-tka-test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria — cadaveric RSA experimental fidelity",
        "description": "Cadaveric RSA validation specimens must span Singh grades II–III (n ≥ 6 specimens). Applied loads in bench test must match FEA boundary conditions within ±5% for axial force and ±3° for flexion angle. Bone preparation protocol (resection angle, component sizing) must be documented and replicated in the FEA geometry."
      },
      "rationale": "Eight cadaveric tibiae (Singh grades II–III, n=8) tested under servo-hydraulic loading frame. Load cell calibration traceable to NIST. Axial force replication within 3.1%; flexion angle within 1.8°. Bone preparation documented per surgical technique guide and reproduced in FEA geometry reconstruction from CT."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-tka-output-comparison",
      "type": "CredibilityFactor",
