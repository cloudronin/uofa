  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-tka-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed at MRL 3. Every factor achievedLevel meets or exceeds requiredLevel: discretization error and numerical solver error both exceeded minimum required levels (achieved 4 and 3 vs required 3 and 2, respectively). Validation against 8 cadaveric specimens yielded NRMSE of 11.7% and all individual predictions within ±25 µm acceptance band. Sensitivity analysis confirmed model outputs insensitive to interface friction coefficient (µ ∈ [0.4, 0.6]) and to implant size variation (sizes 3–7, < 8% QoI variation). Parameter equivalency gap (implant size range) formally bridged by supplemental simulation. Software quality assurance under ISO 13485-aligned QMS with NAFEMS benchmark verification. The structured evidence base, complete provenance chain from cadaveric RSA validation through CT-based geometry reconstruction to production CAD, and absence of any factor shortfall collectively support acceptance of the FEA model for identifying worst-case tibial tray fixation conditions for the Class II TKA device regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
