    "type": "ContextOfUse",
    "name": "COU1: Total knee arthroplasty tibial tray fixation (Class II)",
    "description": "A finite-element model is used to evaluate the sensitivity of cementless tibial tray micromotion to variations in bone density and surgical alignment for a Class II TKA device under physiological gait loading. Model influence is MEDIUM (cadaveric bench testing confirms relative ranking of fixation performance); decision consequence is HIGH (incorrect fixation design decision could lead to aseptic loosening and revision surgery). Model Risk Level 3.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use FEA to identify worst-case micromotion and interface stress conditions across a matrix of bone density grades (Singh I–IV) and axial load magnitudes (1500–3000 N) for a Class II cementless tibial tray. Results compared against cadaveric micromotion measurements using relative micromotion index (peak micromotion < 150 µm acceptance criterion).",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/nagaraja-cou1-tka/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "TKA tibial tray applicability constraint — cementless Class II implants in primary arthroplasty",
      "description": "Model applicability is constrained to primary cementless total knee arthroplasty in skeletally mature patients (bone density Singh grade I–IV). Revision arthroplasty, cemented fixation constructs, unicompartmental devices, and pediatric populations are explicitly out of scope. Cortical bone thickness must be ≥ 3 mm at the resection plane as confirmed by pre-operative CT."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/nagaraja-cou1-tka/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "TKA tibial tray FEA operating envelope — physiological gait loading",
      "description": "Axial compressive load: 1500–3000 N (1× to 2× body weight for 75 kg patient). Anterior-posterior shear: 0–300 N. Internal-external tibial rotation: ±5°. Bone density: Singh grade I–IV (Young's modulus 100–2000 MPa trabecular, 10–18 GPa cortical). Tibial component size range: size 3–7 per manufacturer sizing guide. Stem offset: 0–4 mm. Analyses outside these bounds require supplemental justification."
    }
  },
