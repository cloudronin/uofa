  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors (Software quality assurance, Numerical code verification, Discretization error, Test conditions, Output comparison, Relevance of QoI, Relevance of validation activities) achieved required levels at Gradation 3 or above, with no shortfalls. Six factors (Numerical solver error, Use error, Model form, Model inputs, Test samples, Equivalency of input parameters) are documented as scoped-out with substantive rationale, each supported by cross-references to the SQA documentation, UQ analysis, or validation relevance assessment that renders the factor redundant or not applicable. Monte Carlo UQ was performed across the full input parameter space; the resulting output uncertainty envelope is reported in the validation results and confirms that hemolysis predictions remain below the clinical acceptance threshold across all operating points even at the 95th percentile of the UQ distribution. The decision to accept is grounded in the complete structured evidence chain: PIV velocity field validation, NIB hemolysis benchmark comparison, mesh convergence study, and code verification results, all traceable to the archived project data management system.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
