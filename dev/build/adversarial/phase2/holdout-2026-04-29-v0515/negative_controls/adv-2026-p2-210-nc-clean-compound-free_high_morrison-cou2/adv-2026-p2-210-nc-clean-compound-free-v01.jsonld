  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at Model Risk Level 5 have achieved levels meeting or exceeding required levels. Software quality assurance (3/3), numerical code verification (3/3), and use error (3/3) confirm the computational infrastructure is fit for purpose. Discretization error GCI < 5% (4/4) and numerical solver error (3/3) establish numerical solution quality. Output comparison (4/4) demonstrates quantitative agreement within combined uncertainty at all five operating points. Validation activity relevance (4/4) confirms the validation dataset is directly applicable to the COU without geometric or fluid extrapolation. Model form uncertainty (4/4) assessed via multi-model comparison with spread within validation uncertainty band. Model inputs (4/4) assessed via 1,000-sample Monte Carlo UQ with P95 NIH = 0.072 g/100 L, providing 28% margin below the 0.1 g/100 L clinical threshold. Test conditions (3/3), QoI relevance (3/3), test samples (3/3), and input parameter equivalency (3/3) complete the evidence base. No credibility gaps remain. The structured evidence supports acceptance of the CFD model for predicting absolute hemolysis levels in the Class III VAD COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
