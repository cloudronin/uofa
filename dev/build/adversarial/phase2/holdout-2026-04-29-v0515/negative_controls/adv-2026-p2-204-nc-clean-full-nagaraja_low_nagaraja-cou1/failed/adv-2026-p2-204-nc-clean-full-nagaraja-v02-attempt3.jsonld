  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2023",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2023-11-15T00:00:00Z",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — reflects the use of a single standardised loading rate per ASTM F1717 rather than multiple rates. The offset rationale below documents why this shortfall does not undermine the overall credibility conclusion. The formal E/uval metric is satisfied for all three QoIs (maximum 1.21 < 1.96), percent differences are below 10% for all QoIs, the model input uncertainty has been fully propagated, and the validation domain is co-extensive with the COU. The overall credibility evidence is judged sufficient to support the claim that the FEA ensemble reliably predicts ASTM F1717 compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/tc-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "description": "The Test conditions factor achieved Gradation 2 (single standardised ASTM F1717 loading rate at 23 °C) against a Gradation 3 requirement (multiple loading rates or environmental conditions). This shortfall is offset by the following compensating strengths: (1) ASTM F1717 specifies a single quasi-static loading rate as the regulatory standard, making the single-rate design the regulatory norm rather than a limitation; (2) the E/uval metric is satisfied with substantial margin for all three QoIs, demonstrating that model predictions are robust within the tested condition; (3) sensitivity analysis (documented separately) shows that varying loading rate ±50% changes predicted stiffness by < 2%, confirming that the single-rate condition is not a material source of model uncertainty; and (4) the decision consequence is classified as Medium (revision surgery, not mortality), reducing the impact of any residual uncertainty from untested loading rates. The assessment team therefore judges the overall credibility package sufficient for the intended regulatory submission."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2023/offset/tc",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/cf/tc",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
