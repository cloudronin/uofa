    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis prediction applicability domain",
      "description": "Applicability is restricted to centrifugal blood pump geometries derived from the FDA generic pump benchmark with impeller tip clearances between 0.15 mm and 0.35 mm, operating hematocrit values between 30% and 45%, and blood viscosity values between 2.8 mPa·s and 4.2 mPa·s. The power-law hemolysis model (Giersiepen–Wurzinger coefficients) is applicable only within the validated shear-stress range of 10–800 Pa and exposure times of 1–500 ms. Extrapolation beyond these bounds requires additional validation activities."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/envelope",
      "type": "OperatingEnvelope",
      "name": "VAD operating envelope — flow rate, rotational speed, and pressure head",
      "description": "The validated operating envelope spans volumetric flow rates of 3–8 L/min, impeller rotational speeds of 2400–3600 RPM, and pressure head outputs of 60–130 mmHg. Inlet blood temperature is held at 37 ± 1 °C. Outlet back-pressure boundary conditions are fixed between 80 and 120 mmHg to replicate physiological afterload. Five representative operating points (Q = 3, 4, 5, 6, 8 L/min at corresponding design-point speeds) constitute the primary test matrix; all five points lie strictly within these bounds."
    }
  },
