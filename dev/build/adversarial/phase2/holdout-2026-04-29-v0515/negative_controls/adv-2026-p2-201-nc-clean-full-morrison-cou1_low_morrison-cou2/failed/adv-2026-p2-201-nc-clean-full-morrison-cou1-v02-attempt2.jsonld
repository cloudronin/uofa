  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 5 for the Class III VAD hemolysis prediction COU. Every factor achieves its required credibility level or higher: discretization error and equivalency of input parameters each achieve one level above the requirement, reflecting the additional rigour applied to the highest-risk device class. Monte Carlo uncertainty quantification with 2000 Latin Hypercube samples demonstrates that predicted hemolysis index values lie within the 95% combined uncertainty band at all five operating points. Sensitivity analysis identifies the hemolysis model coefficients as the dominant uncertainty source, and a targeted experimental programme to reduce that uncertainty is underway. Independent reproducibility of the primary result has been confirmed. The provenance chain from raw PIV and hemolysis bench data through validation results to the credibility factors is complete and traceable. On the basis of this structured evidence, the credibility assessment team concludes that the CFD model is sufficiently credible for its intended use in the COU2 regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
