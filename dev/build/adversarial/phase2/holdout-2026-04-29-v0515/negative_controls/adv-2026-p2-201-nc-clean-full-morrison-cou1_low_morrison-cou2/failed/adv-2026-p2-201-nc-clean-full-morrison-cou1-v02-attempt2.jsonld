      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/cou2/test-samples",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria",
        "description": "Hemolysis measurements must be performed with at least three independent blood analogue batches per operating point. Batch-to-batch variability in measured IH must be characterised and reported. The test sample preparation protocol must be documented and traceable to a standard operating procedure."
      },
      "rationale": "Three independent glycerol–water analogue batches were prepared per operating point following SOP-HEM-004 (revision 3). Batch-to-batch variability in measured IH ranged from 3.1% to 5.7% across operating points, characterised as a uniform distribution and included in the experimental uncertainty budget. Batch preparation records, including reagent lot numbers and rheometry certificates, are archived in the study file."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2/equivalency-input-parameters",
      "type": "CredibilityFactor",
