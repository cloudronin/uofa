      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/cou2/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria",
        "description": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, fluid viscosity) must be measured and reported with calibrated instrumentation traceable to NIST standards. Measurement uncertainty for flow rate must be ≤2% of reading; pressure uncertainty ≤1 mmHg. Fluid rheology must be characterised for each test batch."
      },
      "rationale": "Bench tests used a glycerol–water blood analogue at 37 °C with viscosity 3.5 ± 0.1 mPa·s measured by a calibrated cone-and-plate rheometer (NIST-traceable). Flow rates were set and verified with a Coriolis mass flow meter (±0.5% accuracy). Inlet and outlet pressures were measured with calibrated pressure transducers (±0.5 mmHg). All five operating points were held within ±1% of target values for the duration of each 30-minute test run, exceeding the ≤2% requirement."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
