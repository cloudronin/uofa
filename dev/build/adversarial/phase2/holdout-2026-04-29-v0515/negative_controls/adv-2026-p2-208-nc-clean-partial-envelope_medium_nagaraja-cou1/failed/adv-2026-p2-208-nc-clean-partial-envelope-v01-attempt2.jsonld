  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA model ensemble demonstrates adequate credibility for the COU. Twelve of thirteen V&V 40 factors meet or exceed required gradation levels. All three QoIs pass the pre-established acceptance criteria (E/uval < 1.96; absolute difference < 10%). The operating envelope is explicitly bounded (axial load 0–2500 N, bending moment 0–25 N·m, geometry tolerances ±0.05 mm) and validation experiments confirm model fidelity at envelope boundary points. The single shortfall — Test conditions at Gradation 1 vs. required Gradation 2 — is offset by the standardized ASTM F1717 protocol and boundary-point coverage, as documented in the offset rationale below.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/nagaraja-tc-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 1 vs. required 2)",
        "description": "The Test conditions factor achieved Gradation 1 because only a single nominal axial compressive load (1200 N) was applied in the primary validation campaign. This shortfall is offset by three mitigating factors: (1) ASTM F1717 specifies a standardized, industry-accepted test protocol that constrains variability in test conditions; (2) supplementary FEA runs at envelope boundary points (500 N and 2400 N axial load; 2 N·m and 23 N·m bending moment) confirm model fidelity across the declared operating envelope without experimental anomalies; and (3) the model influence is MEDIUM and decision consequence is MEDIUM, yielding a model risk level of 3, for which Gradation 1 on a single factor with documented boundary-point coverage is judged acceptable by the credibility assessment team. The overall evidence base, including Gradation 3 output comparison and full provenance traceability, supports acceptance."
      },
      {
        "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted/offset/nagaraja-tc",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/factor/nagaraja-tc",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
