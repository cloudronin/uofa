  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA ensemble for non-cannulated 7.5 mm pedicle screw compression-bending prediction is accepted as credible for the declared COU. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions (achieved 2, required 3) — is offset by: (1) the large experimental sample (N=11 across two independent laboratories), (2) E/uval metrics well below 1.96 for all three QoIs, (3) comprehensive input uncertainty propagation via LHS (n=200), and (4) explicit boundary-point coverage of the declared operating envelope. The ContextOfUse declares a concrete operating envelope (screw OD 7.4–7.6 mm, load 0–2500 N, Ti-6Al-4V only) and applicability constraint (non-cannulated geometry, 5.5 mm rod, quasi-static loading only), both as structured inline objects with quantitative bounds. Validation experiments cover the declared envelope including boundary points. The provenance chain is complete from foundational bench data through uncertainty quantification to the structured output comparison. The decision is Accepted with the documented offset rationale for the Test conditions shortfall.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/nagaraja-tc-offset",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (achieved 2, required 3)",
        "description": "The Test conditions factor achieved level 2 against a required level of 3 because only a single ASTM F1717 monotonic compression-bending protocol was applied. This shortfall is accepted on the basis of four compensating strengths: (1) N=11 production-representative specimens tested across two independent laboratories, providing inter-laboratory reproducibility evidence; (2) E/uval validation metrics are 0.83, 1.12, and 0.97 for the three QoIs — all substantially below the 1.96 threshold, indicating robust predictive accuracy within the tested condition; (3) Latin hypercube input uncertainty propagation (n=200 runs) confirms QoI sensitivity to input variation is low (< 5% spread); and (4) the declared operating envelope explicitly bounds the applicable load range (0–2500 N) and the single test condition falls within this range. The risk of accepting a model with limited test-condition coverage is mitigated by the conservative operating envelope restriction to quasi-static monotonic loading only."
      },
      {
        "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001/offset/nagaraja-tc",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/factor/nagaraja-tc",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
