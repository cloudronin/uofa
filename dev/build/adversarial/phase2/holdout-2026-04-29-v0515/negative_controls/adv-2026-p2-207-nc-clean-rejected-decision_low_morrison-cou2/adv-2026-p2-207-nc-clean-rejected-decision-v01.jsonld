  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-vv40-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The COU2 credibility assessment is Not accepted based on documented shortfalls across three assessed credibility factors at Model Risk Level 5. (1) Discretization error (required Gradation 4, achieved Gradation 3): GCI-based error estimates of 8.3–14.7% on the hemolysis QoI exceed the 5% threshold required at MRL 5, introducing unacceptable numerical uncertainty in absolute hemolysis predictions. (2) Output comparison (required Gradation 5, achieved Gradation 3): CFD over-predicts hemolysis by 22–38% at four of five operating points, exceeding combined uncertainty bands; no TOST analysis was performed; the two-level shortfall is the primary rejection driver. (3) Relevance of validation activities to the COU (required Gradation 4, achieved Gradation 3): two of the five COU2 operating points fall outside the validated envelope, meaning predictions at those conditions are extrapolations without direct experimental support. No offset rationale is claimed. The Not-accepted decision is the appropriate response to these structured, documented shortfalls at MRL 5, where no waiver pathway exists without satisfying the required credibility levels. Six factors are scoped out with documented rationale; their exclusion does not affect the rejection decision. Corrective actions required before resubmission: (a) perform additional mesh refinement to achieve GCI < 5% at all operating points; (b) conduct validation experiments at the two uncovered operating points; (c) perform TOST analysis and characterise systematic bias with a non-conservatism argument or model recalibration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
