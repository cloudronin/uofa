      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/cou2/discretization-error",
        "type": "AcceptanceCriteria",
        "name": "Discretization error Gradation 4 — GCI-based error estimate < 5% on hemolysis QoI",
        "description": "Grid Convergence Index (GCI) study across at least three systematically refined meshes must yield a discretization error estimate below 5% on the normalised hemolysis index at all five COU2 operating points. Richardson extrapolation must be applied and reported."
      },
      "rationale": "A three-level mesh refinement study was completed. GCI-based error estimates on the hemolysis index range from 8.3% to 14.7% across the five operating points, exceeding the 5% threshold at Gradation 4. The achieved level is Gradation 3 (error characterised but above threshold). This shortfall directly undermines confidence in absolute hemolysis prediction."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2/test-conditions",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/cou2/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions Gradation 4 — bench conditions match COU operating envelope with documented traceability",
        "description": "Experimental hemolysis measurements must be conducted at flow rates and rotational speeds matching the five COU2 operating points within ±2%, with fluid temperature, hematocrit, and anticoagulant protocol documented and traceable to the simulation boundary conditions."
      },
      "rationale": "FDA bench hemolysis measurements were conducted at all five COU2 operating points. Temperature (37 ± 0.5 °C), hematocrit (30 ± 1%), and anticoagulant protocol are fully documented and traceable to CFD boundary conditions. Test conditions requirement satisfied at Gradation 4."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/cou2/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison Gradation 5 — quantitative agreement within combined experimental and simulation uncertainty bands",
        "description": "Predicted absolute hemolysis index must agree with bench measurements within the combined 95% confidence interval of experimental uncertainty and simulation uncertainty at all five operating points. Statistical equivalence test (TOST) must be passed. Systematic bias must be characterised and shown to be non-conservative."
      },
      "rationale": "CFD predictions overestimate hemolysis by 22–38% relative to bench measurements at four of five operating points. While the direction of bias is conservative (over-prediction), the magnitude exceeds the combined uncertainty bands. A TOST analysis was not performed. Achieved level is Gradation 3 (qualitative agreement with documented discrepancy). The two-level shortfall from required Gradation 5 is a primary driver of the Not-accepted decision."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2/relevance-qoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
