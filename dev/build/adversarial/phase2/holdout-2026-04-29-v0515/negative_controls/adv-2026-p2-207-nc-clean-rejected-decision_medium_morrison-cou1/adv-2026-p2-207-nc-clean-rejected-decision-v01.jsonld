  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-notaccepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction under CPB conditions, MRL 2) is Not Accepted. The primary basis for rejection is the documented shortfall in the Discretization Error credibility factor: the required level is Gradation 2 (GCI < 5% on the relative hemolysis index QoI with three systematically refined meshes demonstrating monotonic convergence), but only Gradation 1 was achieved (GCI = 11.3% from two mesh levels, no third mesh available). This shortfall has direct consequences for the intended use: the worst-case operating point identification relies on accurate prediction of peak RH values, and an 11.3% GCI uncertainty on RH — propagating to ±0.11 RH units — is sufficient to alter the ranking of operating points and potentially misidentify the worst-case condition. No offset is claimed for this shortfall. The assessment team determined that the magnitude of the discretization uncertainty, combined with its direct influence on the primary QoI, precludes acceptance at this time. The package will be resubmitted once the third mesh level (target 6.2M cells) is completed and a GCI < 5% is demonstrated. All other assessed factors (SQA, NCV, Test Conditions, Output Comparison, QoI Relevance, Validation Relevance) meet or exceed their required levels. Six factors are appropriately scoped out or marked not-applicable with documented rationale consistent with MRL 2 guidance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
