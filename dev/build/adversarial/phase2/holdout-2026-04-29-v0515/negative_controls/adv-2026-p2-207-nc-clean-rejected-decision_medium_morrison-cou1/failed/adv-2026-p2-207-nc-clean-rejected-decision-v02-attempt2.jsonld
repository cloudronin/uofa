  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-nc7-notaccepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment is not accepted due to a documented shortfall in the Discretization error factor. The required Gradation 2 mandates a systematic three-level mesh refinement study with a quantified Grid Convergence Index (GCI) for the primary QoI (relative hemolysis index). Only two mesh levels were evaluated (4.2 M and 8.7 M cells), and non-monotonic convergence behaviour at the impeller tip gap precludes reliable Richardson extrapolation. Consequently, the discretization uncertainty on the hemolysis index prediction is unquantified, and the model cannot be shown to be operating in the asymptotic convergence regime. All other six assessed factors met or exceeded their required gradation levels, and six factors were appropriately scoped out with documented justification. The shortfall in Discretization error is not offset by any compensating evidence; remediation requires generation of a third, systematically coarser or finer mesh and demonstration of GCI < 5% for RH at all five operating points before the assessment can be re-submitted for acceptance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
