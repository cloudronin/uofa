  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/synth/factor/cou2-sqa",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-sqa",
        "type": "AcceptanceCriteria",
        "name": "SQA Gradation 4 — documented V&V plan, controlled release, regression suite",
        "description": "The CFD solver must have a documented software quality assurance plan covering version control, regression testing covering at least 90% of relevant physics modules, and a controlled release process with documented change history. Gradation 4 requires all elements present and independently audited."
      },
      "rationale": "The commercial CFD solver (ANSYS Fluent 2023 R1) is supplied under an FDA-recognized SQA plan. Version control, regression suite coverage (94%), and controlled release documentation were independently audited by the sponsor QA group. SQA Gradation 4 is fully met; no shortfall identified."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-ncv",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-ncv",
        "type": "AcceptanceCriteria",
        "name": "NCV Gradation 4 — order-of-accuracy verification on benchmark problems",
        "description": "Numerical code verification must demonstrate observed order of accuracy consistent with the formal order of the discretization scheme on at least two benchmark problems relevant to rotating-frame turbomachinery flows. Gradation 4 requires documented results with quantified observed order."
      },
      "rationale": "Order-of-accuracy tests on the Taylor–Green vortex and a rotating-channel benchmark confirmed second-order spatial accuracy (observed p = 1.97 ± 0.04). Documentation is complete and traceable to the solver release notes. NCV Gradation 4 achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-de",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-de",
        "type": "AcceptanceCriteria",
        "name": "DE Gradation 4 — GCI < 2% on hemolysis QoI with three-mesh Richardson extrapolation",
        "description": "A formal Grid Convergence Index study using at least three systematically refined meshes must yield GCI < 2% on the primary hemolysis index quantity of interest. Gradation 4 requires the GCI to be computed on the QoI directly, not a surrogate. Gradation 3 is accepted only if GCI < 5% and the extrapolated value is within 3% of the finest-mesh result."
      },
      "rationale": "Three-mesh GCI study (coarse 4.2 M, medium 11.8 M, fine 32.5 M cells) yielded GCI = 3.8% on the hemolysis index at the worst-case operating point. This satisfies Gradation 3 (GCI < 5%) but falls marginally short of the Gradation 4 threshold of 2%. The fine mesh was the largest feasible on available HPC allocation; further refinement is not currently possible. Achieved level 3 is below the required level 4 — this shortfall contributes to the Not-accepted decision."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-tc",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-tc",
        "type": "AcceptanceCriteria",
        "name": "TC Gradation 4 — full characterisation of inlet/outlet boundary conditions with uncertainty bounds",
        "description": "Test conditions must be fully characterised with documented uncertainty bounds on all boundary conditions (flow rate ±1%, rotational speed ±0.5%, fluid viscosity ±2%). Gradation 4 requires traceability of each boundary condition value to a calibrated measurement with stated expanded uncertainty (k=2)."
      },
      "rationale": "Inlet flow rate and rotational speed boundary conditions were characterised with calibrated instrumentation (flow rate ±1.2%, speed ±0.3%). However, the blood analogue viscosity was assigned a nominal value without a formal uncertainty characterisation traceable to a calibrated rheometer measurement — only a manufacturer certificate of analysis was available. This omission places the factor at Gradation 3. The gap is marginal but sufficient to prevent Gradation 4 from being claimed."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-oc",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-oc",
        "type": "AcceptanceCriteria",
        "name": "OC Gradation 4 — quantitative agreement metric with uncertainty-band overlap on primary QoI",
        "description": "Output comparison must use a quantitative agreement metric (e.g. validation metric per ASME V&V 20) that accounts for both numerical and experimental uncertainty. Gradation 4 requires the validation metric to show agreement within the combined uncertainty band for all five operating points."
      },
      "rationale": "The ASME V&V 20 validation metric was computed for all five operating points. Four of five points showed agreement within the combined uncertainty band. At the highest flow-rate condition (6 L/min, 3500 rpm) the predicted hemolysis index exceeded the upper experimental uncertainty bound by 8%, placing this operating point outside the acceptance criterion. A single non-conforming point prevents the full Gradation 4 claim; Gradation 3 (majority of points within band) is achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-rqoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-rqoi",
        "type": "AcceptanceCriteria",
        "name": "RQOI Gradation 4 — direct QoI correspondence between validation and COU",
        "description": "The quantity of interest used in validation activities must be the same scalar (or directly derived from the same scalar) as the quantity used for the regulatory decision. Gradation 4 requires documented traceability from validation QoI to decision QoI with no intermediate transformation that introduces unquantified uncertainty."
      },
      "rationale": "The validation QoI (normalised index of hemolysis, NIH) is identical to the regulatory decision QoI. No intermediate transformation is applied. Traceability is documented in the V&V plan. Gradation 4 fully achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-rvac",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-rvac",
        "type": "AcceptanceCriteria",
        "name": "RVAC Gradation 4 — validation geometry and operating conditions match COU within stated tolerances",
        "description": "Validation activities must use the same pump geometry (within manufacturing tolerances ±0.05 mm on critical dimensions) and operating conditions spanning the full COU envelope. Gradation 4 requires the validation envelope to encompass all five COU operating points without extrapolation."
      },
      "rationale": "The FDA generic pump geometry used in validation is geometrically representative but is not the sponsor's proprietary impeller design. While the hydraulic diameter and blade angle are within 5% of the COU device, the tip clearance differs by 12%, which is outside the ±0.05 mm tolerance on a critical dimension. Validation activities therefore represent a near-but-not-identical geometry, limiting the relevance claim to Gradation 3."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-nse",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Numerical solver error is scoped out because the commercial solver (ANSYS Fluent 2023 R1) provides documented iterative convergence monitoring with residual targets of 1e-6 for all equations. Solver-level floating-point and iterative errors are bounded by the SQA-verified solver and are considered negligible relative to discretization error at MRL 5. This scoping decision is consistent with the ASME V&V 40 guidance that permits exclusion of solver error when a verified commercial code is used and iterative convergence is demonstrated."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-ue",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Use error is scoped out because the simulation was executed by a single operator following a documented simulation protocol with mandatory peer review of all setup files before execution. The protocol was version-controlled and all deviations were logged; no deviations were recorded. Under these controlled conditions, the residual use-error risk is considered negligible and the factor is formally scoped out per the team's risk-based scoping rationale documented in the V&V plan (§4.3.2)."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-mf",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-mf",
        "type": "AcceptanceCriteria",
        "name": "MF Gradation 5 — hemolysis model validated against species-specific RBC fragility data with uncertainty",
        "description": "At MRL 5 for a Class III device, the hemolysis constitutive model must be validated against species-specific (human) red blood cell fragility data from at least two independent experimental sources, with uncertainty bounds propagated through the power-law damage accumulation integral. Gradation 5 requires both sources to be in agreement within their combined uncertainty and the model constants to be calibrated to human data."
      },
      "rationale": "The Giersiepen–Wurzinger power-law hemolysis model was calibrated to bovine RBC data (the standard FDA pump dataset). A secondary calibration against human RBC data from Heuser & Opitz (1980) was performed, but the two calibrations yielded model constants differing by 18% in the critical exponent, exceeding the ±10% consistency threshold for Gradation 5. The model form is well-established (Gradation 4) but the species-specific uncertainty prevents Gradation 5 from being claimed. This is the primary driver of the Not-accepted decision at MRL 5."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-mi",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-mi",
        "type": "AcceptanceCriteria",
        "name": "MI Gradation 4 — all primary model inputs characterised with documented uncertainty distributions",
        "description": "All primary model inputs (geometry, fluid properties, boundary conditions, turbulence model constants) must have documented uncertainty distributions used in the Monte Carlo UQ. Gradation 4 requires at least the top five sensitivity-ranked inputs to have distributions derived from experimental measurement rather than expert elicitation."
      },
      "rationale": "Monte Carlo UQ was performed with 2000 samples. The top five sensitivity-ranked inputs (flow rate, rotational speed, fluid density, dynamic viscosity, hemolysis model exponent) all have uncertainty distributions derived from experimental measurements with documented provenance. Gradation 4 fully achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-ts",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Test samples is scoped out because the validation dataset uses the FDA generic centrifugal pump, which is a standardised reference geometry rather than a manufactured production device. Sample-to-sample geometric variability is therefore not applicable; the geometry is defined analytically and reproduced by the experimental facility to a documented tolerance. This scoping decision is documented in the V&V plan (§5.1.1) and is consistent with FDA guidance on use of the generic pump as a reference standard."
    },
    {
      "id": "https://uofa.net/synth/factor/cou2-eip",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters is scoped out because the validation experiment and the COU simulation use identical nominal boundary conditions (flow rates and rotational speeds) drawn from the same FDA test protocol. No transformation between experimental and simulation input spaces is required. The scoping rationale is that equivalency is trivially satisfied by protocol design, making a formal equivalency assessment uninformative at MRL 5. Documented in V&V plan §5.2.4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU2 (absolute hemolysis prediction, Class III VAD, MRL 5) yields a Not-accepted decision based on three documented shortfalls in the structured factor evidence. (1) Model form [achieved 4, required 5]: The hemolysis constitutive model calibration constants differ by 18% between bovine and human RBC data, exceeding the ±10% consistency threshold required for Gradation 5 at MRL 5. This is the primary driver: the model's predictive fidelity for human hemolysis cannot be established at the level required for a Class III regulatory decision. (2) Discretization error [achieved 3, required 4]: GCI of 3.8% on the hemolysis QoI marginally exceeds the 2% Gradation 4 threshold; further mesh refinement is not feasible on current HPC allocation. (3) Output comparison [achieved 3, required 4]: One of five operating points falls outside the combined uncertainty band, preventing the full Gradation 4 agreement claim. Test conditions [achieved 3, required 4] and relevance of validation activities [achieved 3, required 4] also exhibit marginal shortfalls. No offset rationale is advanced: the team judges that the cumulative evidence gaps — particularly the model-form species uncertainty — cannot be compensated by the documented strengths in SQA, NCV, RQOI, and model inputs. The model is not rejected on procedural grounds; the rejection is grounded in the quantitative evidence record. Resubmission is contingent on (a) human-RBC calibration data reducing the model-constant discrepancy below 10%, and (b) a finer-mesh GCI study demonstrating GCI < 2%.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
