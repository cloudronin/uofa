  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The COU2 credibility assessment concludes Not accepted based on documented shortfalls across three assessed credibility factors at Model Risk Level 5. (1) Discretization error: GCI on the finest mesh is 7.3% against a required threshold of 5%, yielding achieved level 3 versus required level 4. (2) Output comparison: the u-pooling validation metric is 0.74 against a required threshold of 0.80, and CFD predictions fall outside combined uncertainty at the highest operating point, yielding achieved level 4 versus required level 5. (3) Relevance of validation activities to the COU: the hematocrit mismatch between validation conditions (35%) and COU patient population (40–45%) is not quantified as an extrapolation uncertainty, yielding achieved level 4 versus required level 5. Additionally, the model form factor achieves level 4 versus required level 5 because model-form uncertainty is reported as a range rather than a formal probability distribution. Each shortfall is individually marginal — no single gap is catastrophic — but the combination of four factors below threshold at MRL 5, where the decision consequence is HIGH and the model is the primary basis for hemolysis acceptance, means the aggregate credibility evidence is insufficient to support a regulatory submission claim of absolute hemolysis prediction. No offset rationale is claimed. The assessment team recommends (a) refining the production mesh to achieve GCI below 5%, (b) conducting additional validation experiments at matched hematocrit, and (c) quantifying model-form uncertainty via Bayesian model averaging before resubmission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
