  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/chief-credibility-officer",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed with achieved levels meeting or exceeding required levels under MRL 5 constraints. Monte Carlo UQ (2500 samples) performed across all uncertain model inputs with results propagated to hemolysis index QoI. Hemolysis index predictions within 11.8% of experimental values at all five VAD operating points with overlapping uncertainty intervals. GCI <2% confirms discretization error is controlled. Independent peer review resolved all identified use errors. Sensitivity analysis confirmed that hemolysis model coefficient uncertainty dominates the output variance (72% of total variance), and this uncertainty is fully characterized and within acceptable bounds. The structured evidence across all 13 factors provides sufficient credibility for the claim that the CFD model can predict absolute hemolysis levels for the Class III VAD device within the defined operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
