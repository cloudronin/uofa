  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed. Every factor achieves its required credibility level: discretization error exceeds requirement (achieved 5 vs. required 4); test conditions, numerical solver error, and equivalency of input parameters each achieve one gradation above requirement. The primary QoI (NIH) is validated against bench measurements with NRMSE 9.4% across five COU operating points, within the 15% acceptance criterion. Monte Carlo uncertainty quantification (N=2000) confirms 95th-percentile NIH predictions remain below the clinical hemolysis threshold of 0.1 g/100 L at all operating points. Sensitivity analysis demonstrates that model predictions are robust to plausible input perturbations. Software quality assurance, code verification, and use-error controls are all documented and independently verified. No credibility gaps exist. The model is accepted as sufficiently credible for predicting absolute hemolysis levels for Class III VAD regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
