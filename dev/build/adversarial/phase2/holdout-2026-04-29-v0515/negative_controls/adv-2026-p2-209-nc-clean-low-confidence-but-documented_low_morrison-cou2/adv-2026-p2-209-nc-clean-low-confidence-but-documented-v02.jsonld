  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors achieve their required levels (requiredLevel <= achievedLevel in every case). Six factors are scoped out with documented rationale traceable to the Morrison assessment plan. Evidence confidence is explicitly low (~50%) across all assessed factors, with wide Monte Carlo uncertainty bounds (95% CI half-width ±38% on NIH) honestly reported in the validation result records and UQ reports. The decision to accept is grounded in the following structured evidence: (1) GCI <5% at the critical operating point satisfies the discretization error criterion despite non-monotonic convergence at secondary points; (2) CFD NIH predictions fall within the 95% prediction interval at 4 of 5 operating points and systematic bias is 14% (<20% threshold); (3) all boundary conditions are matched within stated experimental uncertainty; (4) the power-law hemolysis model limitation is explicitly acknowledged and reflected in the wide uncertainty bounds rather than suppressed. The accepting authority acknowledges that the ~50% confidence level represents a residual epistemic risk that is acceptable given: (a) hemolysis predictions are conservative (CFD over-predicts NIH at 3 of 5 points), (b) the clinical threshold provides a 2.3x safety margin above the upper bound of the 95% prediction interval, and (c) the Monte Carlo UQ campaign fully propagates all identified uncertainty sources. No weakener conditions are present in this package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
