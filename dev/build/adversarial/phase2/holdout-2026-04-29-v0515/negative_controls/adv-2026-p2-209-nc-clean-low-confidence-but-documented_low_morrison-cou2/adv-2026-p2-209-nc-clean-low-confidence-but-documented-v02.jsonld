      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/cou2/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria — COU2",
        "description": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity, temperature) must be documented with measurement uncertainty; CFD boundary conditions must match experimental values within stated uncertainty."
      },
      "rationale": "FDA generic pump experimental dataset documents all boundary conditions with traceable calibration records. CFD inlet velocity profiles match experimental values within ±3% (within stated measurement uncertainty of ±4%). Blood analog viscosity is documented at 37°C ±0.5°C. Confidence is approximately 50% because temperature control during hemolysis experiments showed drift of ±1.2°C in two of five test runs; this is flagged in the experimental report and propagated through the Monte Carlo UQ. Achieved level 2 meets required level 2."
    },
    {
