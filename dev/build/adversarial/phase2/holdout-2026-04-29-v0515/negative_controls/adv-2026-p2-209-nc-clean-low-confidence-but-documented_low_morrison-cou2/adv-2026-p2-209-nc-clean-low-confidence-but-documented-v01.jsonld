  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-low-assurance",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-simulation-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepts the CFD hemolysis prediction model for COU2 at Low assurance level. All seven assessed credibility factors meet their required gradation levels (gradation 2 or 3 as applicable). Four factors are formally scoped out with documented rationale appropriate to the Low assurance level and MRL 5 context. Evidence confidence is approximately 50% across most factors, driven primarily by wide Monte Carlo uncertainty bounds (HI output CV 35–60%), small experimental sample sizes (n=3 replicates per operating point), and reliance on the FDA generic pump surrogate geometry. These limitations are documented honestly throughout the assessment and are the direct basis for constraining the assurance level to Low rather than Medium or High. The Monte Carlo uncertainty ensemble (n=500 runs) provides a complete uncertainty budget that is propagated to the decision. The decision team judges that the Low assurance level is appropriate for the intended use (screening-level hemolysis assessment to support early-stage design iteration) and that the documented uncertainty bounds are sufficient to inform the regulatory submission with explicit caveats. No weakeners are expected; all gaps are either resolved at the required gradation or formally scoped out.",
    "decidedAt": "2026-04-19T00:00:00Z"
