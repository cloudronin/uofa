    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis CFD applicability domain",
      "description": "The CFD model is applicable to adult CPB circuits with steady-state or quasi-steady rotational speeds between 1500 and 3500 RPM, blood flow rates between 2.0 and 6.0 L/min, inlet haematocrit 30–45%, and pump geometries within ±10% of the FDA generic centrifugal blood pump reference dimensions. The model is not applicable to paediatric circuits, pulsatile flow modes, or geometries with non-Newtonian blood rheology corrections beyond the Carreau–Yasuda model implemented."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB operating envelope — FDA GCBP COU1",
      "description": "Rotational speed: 1500–3500 RPM (nominal 2500 RPM). Volumetric flow rate: 2.0–6.0 L/min. Inlet pressure: 5–20 mmHg. Outlet pressure: 60–150 mmHg. Blood temperature: 28–37 °C. Haematocrit: 30–45%. Component dimensional tolerances: impeller tip clearance 0.15–0.35 mm, volute gap 0.8–1.2 mm. All five evaluated flow-speed operating points (2 L/min × 2500 RPM; 3 L/min × 2000 RPM; 4 L/min × 2500 RPM; 5 L/min × 3000 RPM; 6 L/min × 3500 RPM) lie within this envelope."
    }
  },
