  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed with achievedLevel ≥ requiredLevel at MRL 2. The primary QoI (NIH and RH) meets the regulatory acceptance threshold (E_val < 0.15) at all five COU operating points. Discretization error (cf-03) exceeds the required Gradation 2, achieving Gradation 3, providing additional confidence in numerical accuracy. The three-level GCI study, independent peer review of simulation setup, NIST-traceable experimental conditions, and multi-laboratory experimental replication collectively establish a robust evidence base. The sensitivity analysis (SA-2025-01) confirms that NIH predictions are most sensitive to hemolysis model constants (±15% input variation → ±18% NIH variation) and least sensitive to geometric tolerances (±0.05 mm → ±2% NIH variation); these sensitivities are within the validation uncertainty envelope and do not alter the worst-case operating point ranking. No offset rationale is required as no factor has achievedLevel < requiredLevel. The credibility assessment team unanimously accepts the CFD model for COU1 use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
