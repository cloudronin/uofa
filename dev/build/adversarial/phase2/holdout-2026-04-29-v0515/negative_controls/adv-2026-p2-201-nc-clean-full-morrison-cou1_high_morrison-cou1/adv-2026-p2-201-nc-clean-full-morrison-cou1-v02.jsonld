    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: FDA generic centrifugal blood pump under CPB flow conditions",
      "description": "The model is applicable to the FDA generic centrifugal blood pump geometry operating in continuous-flow CPB mode at cardiac outputs between 2.0 and 6.0 L/min and impeller speeds between 1500 and 3500 RPM. Blood analog fluid properties (viscosity 0.0035 Pa·s, density 1060 kg/m³) apply. The model is not applicable to pulsatile VAD duty cycles, pediatric pump geometries, or non-Newtonian flow regimes with hematocrit outside 35–45%."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: CPB hemolysis CFD conditions",
      "description": "Flow rate: 2.0–6.0 L/min (nominal 4.0 L/min). Impeller speed: 1500–3500 RPM (nominal 2500 RPM). Inlet pressure: 0–20 mmHg. Outlet pressure: 60–120 mmHg. Fluid temperature: 20–37 °C. Geometric tolerances: impeller tip clearance 0.15–0.35 mm, volute gap 0.5–1.5 mm. Mesh resolution: y+ < 5 at all wetted walls. Turbulence model: SST k-ω. Hemolysis sub-model: power-law Giersiepen–Wurzinger with Lagrangian particle tracking over ≥ 500 representative streamlines per operating point."
    }
  },
