  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at or above their required gradation levels for Model Risk Level 2. Discretization error (CF-03) exceeds requirement (achieved Gradation 3 vs. required 2). Numerical solver error (CF-08) and use error (CF-09) both achieved Gradation 2 against Gradation 1 requirements, providing additional confidence margin. Validation results demonstrate E/D ≤ 0.06 for both pressure head and NIH across all 5 operating points, within combined measurement and numerical uncertainty. Sensitivity analysis confirms NIH response is dominated by impeller tip clearance (±18% NIH per ±0.1 mm) and is robust to sub-model coefficient variation (±11%). The COU operating envelope is 87% covered by validation experiments; boundary extrapolation uncertainty is quantified and bounded. The RH acceptance criterion (RH < 1) is met at all 5 COU operating points with margin. No factor shortfalls exist; no offset rationale is required. The credibility evidence package is sufficient to support regulatory submission for a Class II CPB device at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
