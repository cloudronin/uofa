      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/criteria/morrison-nc2/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison MRL 2 acceptance criteria",
        "description": "Predicted hemolysis index and pressure-flow curves compared quantitatively against experimental measurements. Agreement within ±15% for hemolysis index across all operating points."
      },
      "rationale": "CFD-predicted relative hemolysis index values were compared against experimental measurements at all five operating points. Maximum deviation was 12.4%, within the ±15% acceptance band. Pressure-flow curve predictions agree within experimental uncertainty bands, confirming adequate output comparison fidelity at MRL 2."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-nc2/relevance-qoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
