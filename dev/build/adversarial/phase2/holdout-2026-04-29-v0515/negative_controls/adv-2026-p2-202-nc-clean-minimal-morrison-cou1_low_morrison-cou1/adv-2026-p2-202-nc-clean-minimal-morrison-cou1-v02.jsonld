      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/criteria/morrison-nc2/relevance-validation",
        "type": "AcceptanceCriteria",
        "name": "Relevance of validation activities MRL 2 acceptance criteria",
        "description": "Validation experiments performed on the same FDA GCBP geometry at overlapping operating conditions (flow rate, rotational speed) as the COU simulations."
      },
      "rationale": "Validation experiments were conducted on the identical FDA generic centrifugal blood pump geometry at four of the five COU operating points. Fluid properties and boundary conditions match the COU. The validation domain therefore substantially overlaps the COU domain, satisfying MRL 2 relevance requirements."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-nc2/numerical-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "At MRL 2 for a Class II CPB device with medium model influence, separate numerical solver error quantification beyond the discretization error and code verification activities is not required. Iterative convergence was monitored and residuals reduced below 1e-5 for all equations; no solver-specific error sources were identified that would materially affect the hemolysis QoI."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-nc2/use-error",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Use error assessment is scoped out at MRL 2 for this COU. Simulations were performed by experienced CFD analysts following a documented simulation protocol. Peer review of model setup and boundary condition specification was completed, providing adequate assurance against use error at this risk level."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-nc2/model-form",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Formal model form uncertainty quantification is scoped out at MRL 2. The SST k-omega turbulence model and Giersiepen power-law hemolysis model are established choices for centrifugal blood pump CFD, supported by published literature comparisons. Model form assumptions are documented and acknowledged as a limitation of the current assessment level."
    },
    {
