  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-nc2-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2: Software QA (2/2), Numerical Code Verification (2/2), Discretization Error (3/2), Test Conditions (2/2), Output Comparison (2/2), Relevance of QoI (2/2), and Relevance of Validation Activities (2/2). The six scoped-out factors (Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, Equivalency of Input Parameters) are appropriately deferred at MRL 2 given the medium model influence and availability of corroborating experimental data. The CFD model correctly identifies the worst-case hemolysis operating condition (3500 RPM, 2 L/min) consistent with experimental observations. Relative hemolysis index predictions fall within ±15% of experimental measurements across all five operating points. The structured evidence base, including a three-level GCI mesh convergence study, traceable experimental boundary conditions, and quantitative output comparison against FDA GCBP data, provides sufficient credibility for the intended regulatory submission supporting Class II CPB device tolerance analysis.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
