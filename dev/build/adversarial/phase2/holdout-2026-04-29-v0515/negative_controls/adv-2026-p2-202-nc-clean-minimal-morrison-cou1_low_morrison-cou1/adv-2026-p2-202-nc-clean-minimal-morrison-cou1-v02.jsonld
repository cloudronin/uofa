      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/criteria/morrison-nc2/disc-error",
        "type": "AcceptanceCriteria",
        "name": "Discretization error MRL 2 acceptance criteria",
        "description": "Grid convergence index (GCI) computed on three systematically refined meshes (3.2M, 8.1M, 18.6M cells) per Celik et al. 2008. GCI < 5% for hemolysis index QoI at all five operating points."
      },
      "rationale": "Three-level mesh refinement study following Celik et al. (2008) GCI methodology was performed. GCI values for the hemolysis index ranged from 1.8% to 4.3% across the five operating points, all below the 5% acceptance threshold. Achieved level 3 reflects formal Richardson extrapolation with uncertainty banding documented."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-nc2/test-conditions",
      "type": "CredibilityFactor",
