  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The 13-factor ASME V&V 40-2018 credibility assessment for the FDA generic centrifugal pump CFD model under CPB conditions is accepted at assurance level Medium. Seven factors were formally assessed: Software quality assurance (2/2), Numerical code verification (2/2), Discretization error (3/2 — exceeds requirement), Test conditions (2/2), Output comparison (2/2), Relevance of quantities of interest (2/2), and Relevance of validation activities to COU (2/2). All assessed factors meet or exceed their required gradation levels for MRL 2. Six factors (Numerical solver error, Use error, Model form, Model inputs, Test samples, Equivalency of input parameters) are appropriately scoped out or not applicable at MRL 2 per ASME V&V 40-2018 Table 1, with documented rationale for each. The validation dataset (FDA pump experimental campaign) is directly relevant to the COU operating envelope; quantitative output comparison yielded MAPE of 8.4% against the 15% threshold. No factor shortfalls exist; no offset rationale is required. The model is judged credible for its intended use of identifying worst-case hemolysis operating conditions for a Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
