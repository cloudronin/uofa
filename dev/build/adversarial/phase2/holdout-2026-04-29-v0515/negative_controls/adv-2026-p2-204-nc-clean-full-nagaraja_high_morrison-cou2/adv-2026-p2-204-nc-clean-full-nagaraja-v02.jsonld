    "name": "COU1: Cementless tibial tray primary stability — total knee arthroplasty",
    "description": "A finite-element model is used to predict peak micromotion at the tibial tray–bone interface under ISO 14243-1 gait loading for a cementless Class II TKA device. Model influence is MODERATE (FE predictions supplement cadaveric bench data); decision consequence is MODERATE (incorrect prediction could lead to under-powered press-fit specification but post-market surveillance provides safety net). Model Risk Level 3.",
    "deviceClass": "Class II",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "intendedUse": "Use FE analysis to predict peak tibial tray micromotion (µm) across three gait phases (heel-strike, mid-stance, toe-off) and two bone density strata (normal and osteopenic). Results must remain below 150 µm absolute threshold per published osseointegration literature.",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-tka/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Cementless TKA tibial tray applicability domain",
      "description": "Constraint limits applicability to cementless tibial trays with porous titanium coating, implanted in patients with bone mineral density T-score > −2.5 (non-osteoporotic). Cemented fixation, unicompartmental implants, and revision TKA configurations are explicitly out of scope. Loading is restricted to level-gait ISO 14243-1 profiles; stair-climbing and stumble loads are excluded from this COU."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-tka/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "TKA tibial tray FE operating envelope",
      "description": "Axial compressive load: 1.5–3.0 kN (1×–2× body weight for 75 kg patient). Anterior-posterior shear: 0–350 N. Tibial cortical bone elastic modulus: 12–22 GPa (mean 17 GPa). Cancellous bone elastic modulus: 0.1–1.5 GPa (density-dependent power law). Press-fit interference: 0.05–0.20 mm radial. Implant–bone friction coefficient: 0.4–0.8. Gait cycle frequency: 1 Hz. Temperature: 37 °C ± 2 °C (in-vitro bath conditions)."
    }
  },
