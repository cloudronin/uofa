  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-cou1-tka-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/computational-biomechanics-group",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 3 for the cementless TKA tibial tray micromotion FE model. Achieved levels meet or exceed required levels across all factors: software quality assurance (3≥2), numerical code verification (2≥2), discretization error (3≥2), test conditions (2≥2), output comparison (3≥2), QoI relevance (2≥2), validation relevance (2≥2), numerical solver error (2≥2), use error (2≥1), model form (2≥2), model inputs (3≥2), test samples (2≥2), and equivalency of input parameters (2≥2). No credibility gaps exist. Monte Carlo uncertainty quantification demonstrates that the 95th-percentile peak micromotion (138 µm) remains below the 150 µm osseointegration threshold even under worst-case bone property and press-fit combinations. Cadaveric validation against six specimens spanning the target patient population shows mean absolute error of 18 µm (14% relative) with no systematic bias. The evidence base is sufficient to support the primary stability claim for the Class II device. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
