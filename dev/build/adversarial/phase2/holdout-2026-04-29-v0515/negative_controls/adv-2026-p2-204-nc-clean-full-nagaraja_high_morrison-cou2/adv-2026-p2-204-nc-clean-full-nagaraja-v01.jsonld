  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-tka-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-orthopedic-credibility-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were fully assessed at Model Risk Level 3 for the TKA tibial tray comparative stress assessment (Class II device). Every factor achieved a level meeting or exceeding the required level: 7 factors achieved their required level exactly (levels 2–2) and 6 factors exceeded requirements (achieved level 3 vs. required level 2), providing positive margin across the assessment. Monte Carlo uncertainty quantification (n=1000) confirmed combined input uncertainty of ±4.1% on peak von Mises stress (95th percentile), well within the ±10% comparative design decision threshold. Sensitivity analysis demonstrated that elastic modulus variation (±5 GPa) is the dominant input contributor (62% of output variance), with all other inputs contributing < 15% individually. Strain gauge validation (R² = 0.97, n=8 gauge locations) and ISO 14243-1 fatigue test correlation provide independent experimental confirmation. The provenance chain is complete from raw CMM and coupon test data through validated simulation outputs. No credibility gaps or shortfalls were identified. The model is accepted as fit for purpose for comparative tibial tray stress ranking under the defined operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
