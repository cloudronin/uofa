    "name": "COU1: Total knee arthroplasty tibial tray comparative stress assessment (Class II)",
    "description": "A finite-element model is used to predict peak von Mises stress distributions in the tibial tray of a TKA implant system under physiological gait loading (heel-strike through toe-off). Model influence is MODERATE (model informs comparative design ranking; bench fatigue testing provides independent confirmation); decision consequence is MODERATE (design selection affects implant longevity but predicate device performance is available for comparison). Model Risk Level 3.",
    "deviceClass": "Class II",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tka/applicability",
      "type": "ApplicabilityConstraint",
      "name": "TKA tibial tray applicability constraint",
      "description": "Assessment is applicable to cemented, fixed-bearing tibial tray designs in UHMWPE-on-CoCr articulation with a tibial stem offset ≤ 4 mm from the tray centroid. Cementless, mobile-bearing, and unicompartmental designs are explicitly excluded from scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tka/envelope",
      "type": "OperatingEnvelope",
      "name": "TKA tibial tray operating envelope",
      "description": "Axial compressive load: 1.0–3.5 × body weight (500–2450 N for 70 kg reference patient); flexion angle: 0°–120°; medial-lateral load sharing ratio: 55–70 % medial; tibial component size: size 3–7 per ISO 7207-1; material: Ti-6Al-4V tray (E = 110 ± 5 GPa, ν = 0.33); UHMWPE insert thickness: 8–12 mm. Loads outside these bounds require re-assessment."
    }
  },
