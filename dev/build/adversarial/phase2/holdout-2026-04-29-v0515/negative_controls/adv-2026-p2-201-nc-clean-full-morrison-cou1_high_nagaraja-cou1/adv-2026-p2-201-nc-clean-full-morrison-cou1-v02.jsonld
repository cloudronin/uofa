  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "12 of 13 V&V 40 credibility factors meet or exceed their required gradation levels. All three QoIs (stiffness, yield force, force at 40 mm displacement) satisfy the pre-defined acceptance criterion E/uval < 1.96, with values of 0.83, 1.12, and 0.61 respectively. The single shortfall — Test conditions achieving Gradation 2 against a Gradation 3 requirement — is offset by the high fidelity of the output comparison (Gradation 4 achieved), the use of N=11 production constructs across two independent laboratories, and the conservative nature of the single-condition ASTM F1717 protocol, which bounds the worst-case clinical loading scenario. The overall evidence body supports acceptance of the FEA model for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
      "justification": "The Test conditions factor achieves Gradation 2 (single loading condition, single spacer height) against a Gradation 3 requirement. This shortfall is accepted because: (1) ASTM F1717 compression-bending at 45 mm spacer height represents the most conservative loading configuration per FDA guidance; (2) the output comparison factor achieves Gradation 4, providing high confidence that the model accurately reproduces the tested condition; (3) the validation dataset (N=11 across two laboratories) substantially exceeds the minimum sample size, reducing uncertainty attributable to test condition variability; and (4) the COU is explicitly scoped to the 45 mm spacer height condition, so generalizability to other heights is not claimed and does not constitute a gap for this COU.",
      "name": "Offset rationale for Test conditions Gradation 2 vs. required Gradation 3"
    }
  },
