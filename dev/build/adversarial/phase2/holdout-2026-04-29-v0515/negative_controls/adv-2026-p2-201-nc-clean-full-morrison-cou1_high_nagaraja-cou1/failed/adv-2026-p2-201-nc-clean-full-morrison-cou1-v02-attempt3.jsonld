  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "All 13 ASME V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed their required levels. The single shortfall — Test conditions (achieved=2, required=3) — reflects that testing was performed at a single crosshead rate and temperature per ASTM F1717 protocol. The offset rationale documents why this shortfall does not undermine the overall credibility conclusion: (1) ASTM F1717 is a standardized, single-condition protocol accepted by FDA for pedicle screw 510(k) submissions; (2) sensitivity analysis confirms QoI response is insensitive to ±20% variation in crosshead rate (stiffness change < 1.5%, yield force change < 2.0%); (3) the model risk level is 3 (Medium) and model influence is Medium, consistent with a Medium assurance level; (4) all three QoIs satisfy both quantitative acceptance criteria (E/u_val < 1.96 and |diff| < 10%) simultaneously. The credibility evidence is sufficient to support the regulatory claim that FEA reliably predicts ASTM F1717 compression-bending performance for the non-cannulated 7.5 mm pedicle screw design.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-single-rate",
        "type": "OffsetRationale",
        "name": "Offset for Test conditions shortfall (achieved=2, required=3)",
        "description": "Test conditions factor achieved level 2 against required level 3 because only a single crosshead rate (5 mm/min) and single temperature (23 °C) were evaluated, per ASTM F1717. This shortfall is offset by three compensating factors: (1) ASTM F1717 is a standardized FDA-recognized consensus standard specifying exactly these conditions for pedicle screw evaluation, so the single condition is the regulatory norm rather than a limitation; (2) sensitivity analysis (varied crosshead rate 1–25 mm/min, temperature 18–37 °C) demonstrates that stiffness and yield force QoIs change by less than 2% across the full operating envelope, confirming the model is not sensitive to the untested conditions; (3) the decision consequence is Medium (revision surgery, not mortality), and model influence is Medium, so the overall risk profile does not require multi-condition validation for this COU."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2024/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
