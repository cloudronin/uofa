  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cbp-hemolysis-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment is Not accepted based on documented shortfalls in two assessed factors at MRL 2. (1) Discretization error: the Grid Convergence Index on peak shear stress at the worst-case operating point (6 L/min, 3500 RPM) is 4.2%, exceeding the 2% acceptance threshold. The medium mesh used for production runs was selected due to computational resource constraints and does not satisfy the required convergence criterion. achievedLevel 1 < requiredLevel 2. (2) Output comparison: predicted relative hemolysis index deviates from experimental measurements by 22% at the worst-case operating point and 18% at the secondary critical point, both exceeding the 15% acceptance threshold. Uncertainty bounds do not overlap at these operating conditions. achievedLevel 1 < requiredLevel 2. These two shortfalls are causally linked: the insufficient mesh resolution identified in the Discretization error factor propagates directly into the hemolysis index overprediction documented in the Output comparison factor. No offset rationale is claimed. The assessment team concludes that the model, as currently configured and validated, does not provide sufficient credibility to support regulatory use for worst-case hemolysis identification under the stated COU. Recommended remediation: (a) refine mesh to achieve GCI < 2% at all five operating points, and (b) re-execute validation comparison against FDA benchmark dataset.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
