  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achievedLevels meet or exceed requiredLevels for MRL 5. The assessment explicitly documents wide uncertainty bounds at one operating point: the 95% CI on predicted hemolysis index reaches ±18%, driven primarily by epistemic uncertainty in the power-law hemolysis model exponent α (Sobol index 0.61 from the Monte Carlo sensitivity analysis). This wide bound is not concealed; it is fully quantified, its dominant driver is identified, and it is propagated through the decision. The upper bound of the CI (0.082 g/100 mL) remains below the clinical acceptance threshold of 0.1 g/100 mL at all five operating points, providing a positive margin of 18% even under the most conservative uncertainty realisation. Turbulence model sensitivity (±9%) and mesh discretization error (GCI 5.2%) are also included in the ensemble. The Monte Carlo UQ study (10,000 samples) is fully documented and the sensitivity analysis identifies α as the primary driver of output variability, providing a clear path for future model improvement. Given that all credibility factors are met, all uncertainty sources are explicitly characterised, and the upper CI bound remains below the clinical threshold with positive margin, the model is accepted for predicting absolute hemolysis levels for the Class III VAD COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
