  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "All 13 credibility factors have been assessed and achieve their required levels. The model-form factor (Giersiepen-Wurzinger power-law) carries explicitly documented LOW confidence due to known limitations in applying Couette-flow-calibrated exponents to centrifugal pump shear histories. This low confidence is honestly reflected in wide Monte Carlo uncertainty bounds (factor of 2.5 at 95th percentile on NIH). Despite these wide bounds, the 95th-percentile NIH predictions remain below the absolute clinical hemolysis threshold at all five operating points, providing a conservative safety margin. The decision to Accept is therefore grounded in the structured evidence: all factor levels are met, the uncertainty is fully propagated and documented, and the worst-case prediction remains within the acceptable clinical range. No credibility gaps or shortfalls exist that would require an offset rationale.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/morrison-cou2-model-form-offset",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/factor/morrison-cou2-model-form",
      "justification": "The model-form factor achieves its required level (achievedLevel 2 equals requiredLevel 2) and therefore does not represent a shortfall requiring an offset. This OffsetRationale is included as supplementary documentation of the explicitly-low confidence in the Giersiepen-Wurzinger power-law exponents: the low confidence is fully propagated through Monte Carlo UQ, the resulting wide uncertainty bounds are honestly reported, and the 95th-percentile NIH predictions remain below the absolute clinical threshold at all operating points. The combination of honest uncertainty documentation and conservative margin to threshold provides sufficient assurance to support the Accepted decision without any unresolved credibility gap."
    }
  },
