  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-nc9-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at Gradation 3 or above, meeting or exceeding required levels for MRL 5. The explicitly-flagged low-confidence limitation in the hemolysis model-form power-law exponents (wide uncertainty in Giersiepen-Wurzinger alpha and beta, CV up to 34% at peak shear) is fully documented and does not undermine the acceptance decision: Monte Carlo uncertainty quantification (N=5000) over the joint exponent distribution demonstrates that the 95th-percentile predicted GHI remains 18% below the clinical threshold of 0.8 g/dL. The conservative UQ envelope was specifically designed to absorb the model-form parametric uncertainty. The honest documentation of this confidence limitation — rather than suppression — is consistent with the NC-9 archetype: low confidence scores are reported transparently, the sensitivity of GHI to exponent variation is quantified, and the decision is grounded in the structured evidence. No weakener fires on this package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
