  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors are assessed with achieved levels meeting or exceeding required levels at MRL 5. One factor — Model form — carries explicitly documented low confidence in the power-law hemolysis model coefficients, reflecting genuine epistemic uncertainty in the Giersiepen-Wurzinger model. This limitation is documented honestly: Monte Carlo sampling over the full published coefficient range yields a worst-case 95% CI upper bound on NIH of 0.071 g/100L, which remains below the clinical threshold of 0.1 g/100L with a 29% margin. The low-confidence gap is accepted as residual risk because (a) the safety margin is preserved even under pessimistic coefficient assumptions, (b) no alternative hemolysis model with higher-confidence coefficients is available for this COU, and (c) the wide bounds are conservative by construction. Provenance is complete: all validation results are linked to experimental comparators, generating activities, and uncertainty quantification records. The package is accepted for regulatory submission with the model-form uncertainty explicitly disclosed.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/morrison/offset/model-form-low-confidence",
      "type": "OffsetRationale",
      "name": "Offset rationale for model-form low-confidence gap",
      "description": "The Model form factor achieved level 3 equals required level 3, so no shortfall exists in the scored assessment. However, the low-confidence flag on the power-law coefficients represents a qualitative epistemic gap beyond the numerical score. This offset rationale documents that the gap is accepted because the Monte Carlo 95% CI upper bound on NIH (0.071 g/100L) remains below the clinical threshold (0.1 g/100L) with sufficient margin, and because the uncertainty is conservatively characterized by sampling the full published coefficient range from the literature."
    }
  },
