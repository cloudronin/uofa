      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-samples",
        "type": "AcceptanceCriteria",
        "name": "Test samples Level 4 — minimum 3 independent experimental replicates per operating point",
        "description": "Each of the 5 operating points must have at least 3 independent experimental replicates to characterize experimental variability; coefficient of variation must be reported."
      },
      "rationale": "All 5 operating points have 5 independent replicates. Coefficient of variation for hemolysis index ranges from 4.2% to 9.7% across operating points. Experimental variability fully characterized and incorporated into uncertainty bounds. Achieved level 4."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2/equivalency-inputs",
