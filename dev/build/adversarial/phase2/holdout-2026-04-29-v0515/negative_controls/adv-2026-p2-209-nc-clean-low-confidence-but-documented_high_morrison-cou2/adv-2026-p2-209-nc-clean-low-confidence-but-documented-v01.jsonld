        "type": "AcceptanceCriteria",
        "name": "SQA Level 4 — version-controlled solver with regression test suite",
        "description": "Solver must be under version control, have a documented regression test suite covering hemolysis-relevant flow regimes, and have release notes traceable to test outcomes."
      },
      "rationale": "ANSYS Fluent 2023 R2 is used under FDA CDRH SQA protocol. Version control, regression suite (247 test cases), and release documentation all verified. Achieved level 4 is commensurate with MRL 5 requirements; no gap."
    },
    {
      "id": "https://uofa.net/morrison/factor/cou2/ncv",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
