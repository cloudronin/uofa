  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "Despite five factors achieving levels below their required levels (NCV: 3 vs 4; Discretization Error: 3 vs 4; Output Comparison: 3 vs 4; Validation Relevance: 4 vs 5; Model Form: 3 vs 5; Model Inputs: 3 vs 4), the package is accepted because: (1) all shortfalls are honestly documented with quantified uncertainty bounds; (2) the model consistently over-predicts hemolysis in the non-conforming direction (conservative for patient safety); (3) the Monte Carlo UQ ensemble propagates all wide uncertainty bounds to the final NIH prediction, and the upper 95th-percentile NIH prediction remains below the clinical acceptance threshold of 0.8 g/100L; (4) the model-form uncertainty in hemolysis power-law coefficients (±31% on NIH) is the dominant uncertainty source, is fully characterized, and does not alter the accept/reject decision at the clinical threshold; (5) the pressure-condition gap in validation relevance introduces less than 3% effect on NIH, within experimental variability. The cumulative weight of conforming evidence, the conservative prediction bias, and the clinical safety margin collectively justify acceptance at Low assurance level for this COU.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/morrison/offset/cou2-multi-factor-2026",
        "type": "OffsetRationale",
        "name": "Multi-factor offset rationale — conservative bias and clinical safety margin",
        "description": "Factors NCV (achieved 3, required 4), Discretization Error (achieved 3, required 4), Output Comparison (achieved 3, required 4), Validation Relevance (achieved 4, required 5), Model Form (achieved 3, required 5), and Model Inputs (achieved 3, required 4) all fall short of required levels. The offset is justified by three converging lines of evidence: (a) all CFD predictions are conservative (over-predict hemolysis), so the shortfalls do not create an unconservative risk; (b) the 95th-percentile NIH from the 10,000-sample Monte Carlo ensemble is 0.61 g/100L, providing a 24% safety margin below the clinical threshold of 0.80 g/100L even under the widest uncertainty bounds; (c) the dominant uncertainty source (hemolysis power-law coefficient epistemic uncertainty, ±31%) is fully characterized and bounded, and does not change the accept/reject decision at any sampled coefficient value within the literature range. These offsets are specific to the Low assurance level decision and would not be sufficient to support a higher assurance level claim."
      },
      {
