      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-de",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria — MRL 2",
        "description": "Grid convergence index (GCI) for the primary QoI (volume-averaged scalar stress) must be ≤ 5% on the fine grid. Richardson extrapolation must demonstrate monotonic convergence across three systematically refined meshes."
      },
      "rationale": "A three-level mesh refinement study (coarse 1.2 M, medium 3.1 M, fine 7.8 M cells) was conducted. The GCI on the fine grid for volume-averaged scalar stress is 8.4%, exceeding the 5% acceptance threshold. Convergence is monotonic but the asymptotic range has not been fully achieved — the apparent order of accuracy (p = 1.61) is below the theoretical value of 2.0 by more than the allowable 20% margin. This marginal shortfall is not offset by any compensating evidence; the factor achievedLevel (1) is below the requiredLevel (2)."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-tc",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
