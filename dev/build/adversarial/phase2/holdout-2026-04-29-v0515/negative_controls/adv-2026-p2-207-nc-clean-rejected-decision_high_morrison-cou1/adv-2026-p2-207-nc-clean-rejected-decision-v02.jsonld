      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-rva",
        "type": "AcceptanceCriteria",
        "name": "Relevance of validation activities acceptance criteria — MRL 2",
        "description": "Validation experiments must use the same FDA generic centrifugal blood pump geometry, the same blood analogue fluid, and operating conditions spanning the COU envelope."
      },
      "rationale": "Validation experiments used the FDA GCBP geometry (identical CAD to simulation), a 36% glycerol-water blood analogue (viscosity matched to whole blood at 37°C), and all 5 COU operating points. The validation activity is therefore directly relevant to the COU with no geometry or fluid extrapolation required."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-nse",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Numerical solver error is scoped out at MRL 2 for a Class II device when the solver is used without modification and the code verification factor (Numerical code verification) has been assessed and met. The ASME V&V 40-2018 framework permits scoping out this factor under these conditions, as residual solver error is bounded by the code verification evidence. This scoping decision is documented and reviewed by the credibility assessment team."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-ue",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Use error is scoped out at MRL 2 because the simulation workflow is executed by a single analyst team using a validated, version-controlled simulation template with peer review of all setup parameters. No novel user customisation is applied. The SQA factor covers the procedural controls that bound use error risk at this risk level."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-mf",
      "type": "CredibilityFactor",
