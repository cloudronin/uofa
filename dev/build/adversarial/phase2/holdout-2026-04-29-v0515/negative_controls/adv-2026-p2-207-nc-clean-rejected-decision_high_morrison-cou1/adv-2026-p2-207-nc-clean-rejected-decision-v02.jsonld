  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40-2018 factors at Model Risk Level 2 for the Class II CPB COU. Two assessed factors failed to meet their required levels: (1) Discretization error achieved Gradation 1 against a required Gradation 2, because the GCI on the fine grid (8.4%) exceeded the 5% acceptance threshold and the apparent order of accuracy (p=1.61) was below the theoretical value by more than the allowable margin; (2) Output comparison achieved Gradation 1 against a required Gradation 2, because the CFD-predicted RH at operating point OP-4 (1.09) exceeded the k=2 combined uncertainty upper bound (1.05) consistently across three mesh realisations. No offset rationale is claimed for either shortfall. The seven scoped-out factors were excluded on documented grounds consistent with MRL 2 practice. The remaining five assessed factors all met or exceeded their required levels. The two shortfalls, taken together, are judged sufficient to preclude acceptance of the model for the stated COU. The team recommends (a) mesh refinement to achieve GCI ≤ 5% and asymptotic convergence, and (b) investigation of the hemolysis model coefficient sensitivity at OP-4 before resubmission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
