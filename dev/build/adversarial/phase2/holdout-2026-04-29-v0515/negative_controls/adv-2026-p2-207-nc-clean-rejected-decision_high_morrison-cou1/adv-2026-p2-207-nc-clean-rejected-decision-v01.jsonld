  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-sqa",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-sqa-ac",
        "type": "AcceptanceCriteria",
        "name": "SQA Gradation 2 acceptance criteria",
        "description": "The CFD solver (ANSYS Fluent 2023R1) is a commercially validated code with documented version control, regression test suite, and release notes. Gradation 2 requires documented use of a verified commercial solver with traceable version history. All runs were executed under a documented computational protocol with version-locked solver settings."
      },
      "rationale": "ANSYS Fluent 2023R1 is a commercially distributed solver subject to the vendor's internal V&V program. The project maintained a version-locked solver environment; all simulation runs were executed from a single controlled installation. Regression tests provided by the vendor for rotating-machinery and scalar-transport modules were reviewed and confirmed passing. Gradation 2 is achieved and meets the MRL 2 required level."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-ncv",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-ncv-ac",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification Gradation 2 acceptance criteria",
        "description": "Gradation 2 requires that the solver has been verified against at least one canonical benchmark relevant to the physics of interest. Order-of-accuracy confirmation for the discretisation scheme in use must be documented."
      },
      "rationale": "The Fluent pressure-based coupled solver was verified against the Taylor-Green vortex benchmark for incompressible flow, confirming second-order spatial accuracy. For the scalar hemolysis transport equation, a manufactured-solution test was executed and documented, confirming residual convergence to machine precision. Gradation 2 is achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-de",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-de-ac",
        "type": "AcceptanceCriteria",
        "name": "Discretization error Gradation 3 acceptance criteria",
        "description": "Gradation 3 requires a formal grid convergence study using at least three systematically refined meshes with Richardson extrapolation and a reported Grid Convergence Index (GCI) for the primary quantity of interest. The GCI for the relative hemolysis index must be below 5% on the fine mesh."
      },
      "rationale": "A three-mesh convergence study (coarse 4.2 M, medium 11.7 M, fine 28.4 M cells) was conducted. Richardson extrapolation yielded GCI values of 8.3% on the fine mesh for the relative hemolysis index at the worst-case operating point (3500 RPM, 5 L/min). This exceeds the Gradation 3 threshold of 5% GCI. The study is otherwise formally structured and documented, qualifying for Gradation 2 (systematic mesh study without GCI below threshold). The shortfall is marginal — 3.3 percentage points above the acceptance threshold — and arises primarily from high shear gradients near the impeller-volute gap, a region identified as geometrically sensitive. Remediation would require a locally refined mesh in the gap region and re-running the full convergence study. The assessment team judged this shortfall non-trivial given the decision consequence rating of HIGH, and no offset is claimed."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-tc",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-tc-ac",
        "type": "AcceptanceCriteria",
        "name": "Test conditions Gradation 2 acceptance criteria",
        "description": "Gradation 2 requires that boundary conditions applied in the CFD model are traceable to experimental measurements with documented uncertainty. Gradation 3 additionally requires that inlet velocity profiles were measured rather than assumed uniform."
      },
      "rationale": "Inlet velocity profiles were measured via particle image velocimetry (PIV) at the pump inlet plane for all five operating points. Fluid temperature, viscosity, and density were measured and reported with calibrated uncertainty. Boundary conditions were applied directly from the experimental measurements, with interpolation documented. Gradation 3 is achieved, exceeding the MRL 2 requirement of Gradation 2."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-oc",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-oc-ac",
        "type": "AcceptanceCriteria",
        "name": "Output comparison Gradation 3 acceptance criteria",
        "description": "Gradation 3 requires that the comparison between model predictions and experimental data is performed using a formal metric (e.g. validation uncertainty interval or area validation metric) that accounts for both experimental uncertainty and simulation numerical uncertainty. The comparison must cover all primary quantities of interest across the full operating envelope."
      },
      "rationale": "Output comparison was performed using a direct point-by-point relative error metric for the relative hemolysis index (RH) across all five operating points. Experimental uncertainty was quantified and reported. However, the comparison did not incorporate numerical uncertainty (GCI) into a combined validation uncertainty interval as required for Gradation 3; the numerical uncertainty budget was treated separately rather than being propagated into the comparison metric. This omission places the factor at Gradation 2. The shortfall is methodologically straightforward to address — combining the GCI-derived numerical uncertainty with the experimental uncertainty band in a single validation uncertainty interval — but was not completed prior to the submission deadline. Together with the discretization error shortfall, this constitutes a second unresolved gap. The assessment team determined that two concurrent Gradation-2 achievements against Gradation-3 requirements, in a HIGH decision-consequence context, are insufficient to support an Accepted outcome."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-rqi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-rqi-ac",
        "type": "AcceptanceCriteria",
        "name": "Relevance of QoI Gradation 2 acceptance criteria",
        "description": "Gradation 2 requires that the QoI used in the simulation is directly linked to the clinical or regulatory endpoint, with documented justification. Gradation 3 additionally requires sensitivity analysis demonstrating that the QoI is the most discriminating metric for the intended decision."
      },
      "rationale": "The relative hemolysis index (RH) is the primary QoI, directly mapped to the FDA guidance on hemolysis testing for CPB devices. A sensitivity analysis was conducted varying the hemolysis power-law exponent (Giersiepen model parameters) and confirming that RH is the most discriminating metric across the five operating points relative to alternative scalar outputs (e.g. shear stress magnitude). Gradation 3 is achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-rvac",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-rvac-ac",
        "type": "AcceptanceCriteria",
        "name": "Relevance of validation activities Gradation 2 acceptance criteria",
        "description": "Gradation 2 requires that the validation experiments share the same fluid, geometry family, and flow regime as the COU, with documented mapping between validation scenario and intended use."
      },
      "rationale": "Validation experiments used the FDA generic centrifugal blood pump geometry with bovine blood analog fluid (glycerol-water, matched viscosity) at the same rotational speeds and flow rates as the COU operating envelope. The mapping between validation scenario and COU is documented in the validation plan. Gradation 2 is achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-nse",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Numerical solver error as a distinct factor (separate from discretization error and numerical code verification) addresses floating-point arithmetic errors and iterative convergence residuals. At MRL 2 with a commercially verified solver, this factor is scoped out per project agreement: the vendor's internal test suite and the project's own residual convergence monitoring (all residuals below 1e-6) are judged sufficient. The factor is not separately assessed; its contribution is subsumed within the Software Quality Assurance and Numerical Code Verification assessments."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-ue",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Use error addresses operator-induced deviations from the validated simulation protocol. This factor is scoped out because all simulations were executed by a single experienced analyst using a locked, documented computational protocol with independent peer review of setup files prior to each run. The risk of undetected use error is considered negligible at MRL 2 under these procedural controls, and the project risk register documents this scoping decision with sign-off from the project technical lead."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-mf",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Model form credibility addresses the appropriateness of the governing equations and turbulence closure for the COU physics. At MRL 2, a full model-form uncertainty quantification is not required. The project adopted the SST k-omega turbulence model, which has published validation evidence for rotating blood-contacting devices in the open literature (referenced in the validation plan). The model-form choice is documented and justified by reference to published benchmarks; a separate credibility factor assessment is scoped out per the MRL 2 factor applicability table in ASME V&V 40-2018 Table 3."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-mi",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Model inputs uncertainty (distinct from test conditions) addresses parametric uncertainty in material properties and geometric dimensions used in the simulation. At MRL 2, this factor is scoped out because the geometric dimensions are taken directly from the FDA reference geometry (nominal, no manufacturing variation), and fluid properties are measured quantities with uncertainty reported under Test Conditions. A separate model-inputs credibility assessment is not required at MRL 2 per the project's factor applicability determination, documented in the assessment plan."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-ts",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Test samples as a credibility factor addresses variability across physical test articles. The FDA generic centrifugal blood pump is a reference geometry manufactured to tight tolerances for research use; a single reference pump was used for all validation experiments. Sample-to-sample variability is therefore not applicable to this validation activity. The factor is scoped out with documented acknowledgement that clinical device manufacturing variation is addressed separately in the regulatory submission's manufacturing controls section."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-eip",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters addresses the degree to which the simulation input parameters match those of the physical test. This factor is scoped out because the validation scenario and the COU share identical geometry, fluid properties, and operating conditions by design — the FDA generic pump was selected as the validation platform precisely because it replicates the COU geometry. No extrapolation of input parameters between validation and COU is required, making a separate equivalency assessment redundant. This scoping decision is documented in the assessment plan with concurrence from the regulatory affairs representative."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-notaccepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-credibility-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction, Class II CPB device, MRL 2) concludes with a Not Accepted decision based on two concurrent, documented shortfalls in assessed credibility factors: (1) Discretization Error achieved Gradation 2 against a required Gradation 3, with a GCI of 8.3% on the fine mesh for the relative hemolysis index at the worst-case operating point, exceeding the 5% acceptance threshold by 3.3 percentage points. The shortfall is localized to the impeller-volute gap region and is technically remediable through targeted mesh refinement and re-running the convergence study. (2) Output Comparison achieved Gradation 2 against a required Gradation 3, because the comparison metric did not incorporate numerical uncertainty (GCI) into a combined validation uncertainty interval alongside experimental uncertainty. These two shortfalls are evaluated in the context of a decision consequence rating of HIGH — an incorrect tolerance decision could directly impact clinical hemolysis levels in patients undergoing cardiopulmonary bypass surgery. The assessment team determined that accepting the submission with two concurrent Gradation-2 achievements against Gradation-3 thresholds, without offset justification, would not be consistent with the risk-proportionate credibility standards of ASME V&V 40-2018 at this consequence level. No offset is claimed. Both shortfalls have clear, documented remediation paths: (a) refine the mesh in the impeller-volute gap region and repeat the three-mesh GCI study targeting GCI < 5%, and (b) propagate the GCI-derived numerical uncertainty into the output comparison metric to form a complete validation uncertainty interval. Resubmission is recommended following completion of these two remediation activities. All other assessed factors (Software Quality Assurance, Numerical Code Verification, Test Conditions, Relevance of QoI, Relevance of Validation Activities) meet or exceed their required gradation levels. Six factors are scoped out with documented rationale consistent with MRL 2 applicability. The provenance chain is complete: all validation results trace to the FDA generic pump experimental dataset (DOI 10.1115/1.4035258) and the CFD mesh study dataset.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
