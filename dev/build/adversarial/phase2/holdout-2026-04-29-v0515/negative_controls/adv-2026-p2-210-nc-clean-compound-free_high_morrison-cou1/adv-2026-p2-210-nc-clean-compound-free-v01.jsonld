  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis worst-case identification, Class II, MRL 2) is accepted based on the following structured evidence: (1) Seven credibility factors were formally assessed; all seven achieved levels meet or exceed required levels (discretization error achieved Gradation 3 against a Gradation 2 requirement). (2) Six factors were scoped out or designated not-applicable under the MRL 2 tailoring provisions of ASME V&V 40 Table 3, each with documented rationale. (3) Two validation results (NHI comparison, pressure-rise comparison) demonstrate agreement within experimental uncertainty bands across the full COU operating envelope, with GCI < 5% confirming numerical solution quality. (4) The primary QoI (NHI) is directly linked to the regulatory acceptance criterion (RH < 1 vs. predicate device) per ASTM F1841 and FDA guidance. (5) Provenance is traceable from the foundational experimental dataset (FDA GCBP round-robin, DOI:10.1115/1.4043659) through the validation activities to this assurance package. No factor shortfall exists; no offset rationale is required. The totality of evidence supports the claim that the CFD model provides adequate credibility for identifying worst-case hemolysis operating conditions at the stated model risk level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
