      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/numerical-code-verification-ac",
        "type": "AcceptanceCriteria",
        "name": "Code verification: manufactured-solution or benchmark test passed",
        "description": "Solver passes at least one published benchmark (e.g., lid-driven cavity, Taylor-Couette) with documented order-of-accuracy confirmation at Gradation 2."
      },
      "rationale": "ANSYS Fluent has been independently verified against the FDA nozzle benchmark (Stewart et al. 2012) and internal Taylor-Couette rotating-flow benchmark. Observed spatial order of accuracy is 1.92 ± 0.08 for the velocity field, consistent with the second-order discretisation scheme. Gradation 2 requirement met."
    },
    {
      "id": "https://uofa.net/morrison/factor/discretization-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
