      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/relevance-validation-activities-ac",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance: validation domain overlaps COU domain for geometry, flow regime, and fluid",
        "description": "Validation activities must use the same device geometry (FDA GCBP), same blood analogue fluid, and operating conditions spanning the COU envelope (2–6 L/min, 2500–3500 RPM). Gradation 2 requires documented overlap between validation and COU domains."
      },
      "rationale": "Validation experiments (FDA GCBP round-robin, Hariharan et al. 2011; supplementary in-house tests) use the identical device geometry, the same glycerol-water blood analogue (viscosity matched), and operating conditions that fully span the COU envelope. No extrapolation beyond the validated domain is required for the COU decision. Gradation 2 requirement met."
    },
    {
      "id": "https://uofa.net/morrison/factor/numerical-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Numerical solver error as a distinct factor from discretization error applies when iterative convergence or round-off error is a primary uncertainty source separate from mesh refinement. For this steady-state RANS simulation, residuals converged to < 1×10−6 for all equations, and double-precision arithmetic was used throughout. Solver error is therefore negligible relative to discretization and model-form uncertainties and is not applicable as a separate assessment factor at MRL 2."
    },
    {
      "id": "https://uofa.net/morrison/factor/use-error",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Use error assessment at Gradation 2 or above requires a formal human-factors review of the simulation workflow. At MRL 2 for a Class II device with medium model influence, ASME V&V 40 Table 3 does not require a standalone use-error assessment when SQA (version control, peer review of inputs) is in place. This factor is scoped out in accordance with the MRL 2 tailoring decision documented in the credibility plan (Morrison et al. 2024, Appendix B)."
    },
    {
      "id": "https://uofa.net/morrison/factor/model-form",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Model-form uncertainty (turbulence model selection, non-Newtonian rheology assumptions) is acknowledged but scoped out of the formal credibility factor assessment at MRL 2. The SST k-ω turbulence model was selected based on published comparative studies for rotary blood pumps (Fraser et al. 2011); sensitivity to model-form choices is partially captured in the output-comparison factor. A full model-form uncertainty quantification is deferred to MRL 3 activities per the credibility plan."
    },
    {
      "id": "https://uofa.net/morrison/factor/model-inputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Formal uncertainty propagation for model inputs (geometric tolerances, fluid property variability) is scoped out at MRL 2. Nominal input values are taken from the FDA GCBP specification and the blood analogue characterisation report. Sensitivity of NHI to ±3% geometric perturbations was assessed informally and showed < 4% NHI variation, supporting the scope-out decision. Full probabilistic input uncertainty quantification is planned for MRL 3."
    },
    {
      "id": "https://uofa.net/morrison/factor/test-samples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Test samples as a credibility factor addresses variability across multiple physical device specimens. The FDA GCBP is a standardised reference geometry; the round-robin validation study (Hariharan et al. 2011) used nominally identical specimens across six laboratories. Sample-to-sample variability is therefore characterised by the inter-laboratory spread already incorporated into the experimental uncertainty bounds used in the output-comparison factor. A separate test-samples assessment is not applicable."
    },
    {
      "id": "https://uofa.net/morrison/factor/equivalency-input-parameters",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters (formal mapping from experimental to simulation inputs with uncertainty) is scoped out at MRL 2. The test-conditions factor (assessed, Gradation 2) documents that boundary conditions are reproduced within ±5%. A formal equivalency analysis with propagated uncertainty is deferred to MRL 3 per the credibility plan (Morrison et al. 2024, Appendix B, Item 6)."
    }
