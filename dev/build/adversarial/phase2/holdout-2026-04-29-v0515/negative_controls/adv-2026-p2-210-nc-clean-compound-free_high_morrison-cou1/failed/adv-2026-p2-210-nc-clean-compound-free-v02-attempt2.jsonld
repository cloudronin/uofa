  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels for MRL 2: Software QA (2/2), Numerical Code Verification (2/2), Discretization Error (3/2, exceeds), Test Conditions (2/2), Output Comparison (2/2), Relevance of QoI (2/2), and Relevance of Validation to COU (2/2). The 6 scoped-out factors (Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, Equivalency of Input Parameters) are each documented with rationale consistent with ASME V&V 40-2018 Table 3 guidance for MRL 2. The CFD model predicts NIH values within the combined U95 uncertainty band at all 5 COU operating points, and the relative hemolysis index RH < 1 is satisfied, confirming the pump design meets the predicate device comparison criterion. No credibility gaps or shortfalls identified. The package is accepted as providing sufficient credibility evidence to support the regulatory submission for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
