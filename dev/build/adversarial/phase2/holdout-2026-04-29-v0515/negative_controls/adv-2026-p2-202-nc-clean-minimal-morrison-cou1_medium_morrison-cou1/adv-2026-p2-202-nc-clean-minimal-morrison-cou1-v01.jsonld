  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-division-of-applied-mechanics",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for hemolysis prediction of the FDA generic centrifugal blood pump under CPB conditions is accepted as credible for the stated COU at MRL 2. Seven of thirteen ASME V&V 40 credibility factors were assessed; all seven meet or exceed their required levels (Software QA: 2/1; Code Verification: 2/1; Discretization Error: 3/2; Test Conditions: 2/2; Output Comparison: 2/2; QoI Relevance: 2/2; Validation Relevance: 2/2). The six remaining factors (Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, Equivalency of Input Parameters) are formally scoped out at MRL 2 with documented rationale. The primary acceptance criterion — relative hemolysis index RH < 1 at all five COU operating points relative to the predicate device — is satisfied with a mean absolute percentage error of 12.4% against the FDA GCBP experimental benchmark, well within the ±25% tolerance. The validation domain fully brackets the COU operating envelope. No credibility factor shortfalls exist; no offset rationale is required. The model is approved for use in identifying worst-case hemolysis operating conditions to support the Class II CPB device 510(k) submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
