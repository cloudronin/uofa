  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-division-of-applied-mechanics",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for FDA GCBP under CPB conditions, MRL 2) is accepted based on the following structured evidence: (1) All seven assessed credibility factors meet or exceed their required levels — Software QA (2/2), Numerical Code Verification (2/2), Discretization Error (3/2, exceeds requirement), Test Conditions (2/2), Output Comparison (2/2), Relevance of QoI (2/2), and Relevance of Validation Activities (2/2). (2) Six factors are scoped out with documented rationale consistent with MRL 2 requirements per ASME V&V 40 Table 3 — Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, and Equivalency of Input Parameters. (3) Two independent validation results are on record: pressure-flow curve validation (GCI < 2.1% across all operating points) and RHI comparison against FDA experimental data (worst-case relative error 11.8%, within the 20% acceptance threshold). Both validation results carry uncertainty quantification. (4) The provenance chain is complete: the package is derived from the peer-reviewed Morrison et al. (2017) FDA GCBP study (DOI 10.1115/1.4037497) and attributed to the FDA CDRH Division of Applied Mechanics. (5) No factor shows achievedLevel below requiredLevel; therefore no offset rationale is required. The model is judged fit for the stated COU at MRL 2 with Medium assurance level."
  },
