  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed for COU2 at Model Risk Level 5. Achieved levels meet or exceed required levels across all factors: discretization error (4/4), output comparison (4/4), relevance of validation activities (4/4), model form (4/4), and model inputs (4/4) meet the elevated requirements driven by MRL 5 and Class III device classification. Monte Carlo UQ (n=2000) confirms the 95th-percentile hemolysis index remains below the clinical threshold of 0.010 g/100 mL. Independent analyst reproducibility and SQA controls are in place. The provenance chain is complete from raw experimental data through validated simulation results. The credibility evidence is sufficient to support the claim that the CFD model can predict absolute hemolysis levels for this VAD application with acceptable confidence. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
