  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA ensemble for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as credible for the stated COU. Eleven of thirteen V&V 40 factors met or exceeded required gradation levels. Two factors (Numerical solver error, Use error) are not-applicable due to the deterministic implicit-solver design and locked shared analysis protocol respectively. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3; this shortfall is offset by the multi-laboratory test design and the explicit scoping of the COU to the ASTM F1717 protocol. All three QoIs passed the E/uval < 1.96 and <10% difference acceptance criteria across both laboratories. The provenance chain from raw experimental data through uncertainty quantification to the validation metric is fully documented.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs required 3)",
        "description": "The Test conditions factor achieved Gradation 2 (single standardised ASTM F1717 condition) against a required Gradation 3 (multiple conditions spanning the COU envelope). This shortfall is acceptable because: (1) the COU is explicitly bounded to the ASTM F1717 static compression-bending protocol, making additional load-rate or environmental variation outside the intended use scope; (2) the multi-laboratory design (two independent labs, N=11 constructs) provides strong evidence of reproducibility within the single condition; and (3) all three QoIs passed the quantitative E/uval acceptance threshold with margin, indicating the model is not sensitive to the untested condition variations at the COU boundary."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
