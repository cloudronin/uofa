      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-cou1-mf",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria — constitutive law justification",
        "description": "The constitutive model and contact formulation must be justified by reference to published literature or prior validation studies for titanium alloy implants under quasi-static loading. Gradation 2 requires documented justification."
      },
      "rationale": "Ti-6Al-4V screw and UHMWPE block material behavior is represented by bilinear isotropic hardening plasticity, calibrated from tensile coupon data reported in the Nagaraja et al. study. Augmented Lagrange contact with a friction coefficient of 0.2 (Ti-Ti) is consistent with published tribological data. Model form choices are documented in the simulation protocol and justified by reference to prior FDA pedicle screw FEA studies."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-cou1-mi",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
