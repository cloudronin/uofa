      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-cou1-ts-ac",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria",
        "description": "N=11 production pedicle screw constructs tested across two independent laboratories. Sample traceability confirmed via lot number and CoC. Between-laboratory variability assessed via ANOVA (p>0.05 for all QoIs)."
