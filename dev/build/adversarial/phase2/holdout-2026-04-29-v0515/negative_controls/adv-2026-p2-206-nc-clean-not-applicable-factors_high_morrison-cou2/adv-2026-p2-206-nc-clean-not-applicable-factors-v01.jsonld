      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou2-ncv",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criteria",
        "description": "Order-of-accuracy verification using the Method of Manufactured Solutions (MMS) must demonstrate second-order spatial convergence for the incompressible Navier-Stokes solver and the scalar hemolysis transport equation on at least two mesh families."
      },
      "rationale": "MMS verification was performed on Cartesian and body-fitted structured meshes. The incompressible NS solver achieved 1.97-order spatial convergence (target ≥ 1.8); the hemolysis scalar transport equation achieved 1.95-order convergence. Temporal convergence was verified at second order for the BDF2 scheme used in all transient runs."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou2-de",
      "type": "CredibilityFactor",
