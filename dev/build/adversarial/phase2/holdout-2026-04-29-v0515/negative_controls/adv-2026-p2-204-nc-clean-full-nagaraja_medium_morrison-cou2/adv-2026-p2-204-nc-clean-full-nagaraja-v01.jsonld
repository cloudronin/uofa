    "name": "COU1: Tibial tray peak stress prediction under physiological loading (Class II orthopedic)",
    "description": "A finite-element model is used to predict peak von Mises stress and fatigue life in a cobalt-chromium tibial tray under physiological knee loading. Model influence is MODERATE (model informs design acceptance alongside bench testing); decision consequence is MODERATE (incorrect prediction could lead to premature implant fatigue failure requiring revision surgery). Model Risk Level 3.",
    "deviceClass": "Class II",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-orthopedic/applicability",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: cobalt-chromium tibial tray under ISO 14243 loading",
      "description": "Assessment applies only to cobalt-chromium alloy tibial tray components conforming to ISO 14243-1 loading profiles, for patients with BMI ≤ 40 and no severe osteoporosis (T-score > -2.5). Titanium alloy trays, unicompartmental designs, and revision implant geometries are explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-orthopedic/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: physiological loading bounds for tibial tray FE model",
      "description": "Axial compressive load: 700–2100 N (1–3× body weight for 70 kg patient). Anteroposterior shear: 0–350 N. Tibial rotation: -5° to +10°. Cortical bone elastic modulus: 15–22 GPa. Implant-bone interface friction coefficient: 0.1–0.6. Operating temperature: 37 °C ± 1 °C. Model is not valid outside these bounds."
    }
  },
