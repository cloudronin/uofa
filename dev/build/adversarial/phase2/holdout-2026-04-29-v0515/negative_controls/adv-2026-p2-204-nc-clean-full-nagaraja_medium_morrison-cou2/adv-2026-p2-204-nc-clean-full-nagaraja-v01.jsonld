  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-orthopedic-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at MRL 3 for a Class II orthopedic tibial tray stress prediction model. Every factor achieves its required credibility level (achievedLevel ≥ requiredLevel in all cases). Mesh convergence (GCI 1.4%) and output comparison (95th percentile strain error 11.3%) both satisfy their acceptance criteria. Sensitivity analysis confirmed that cortical bone modulus is the dominant uncertainty driver, contributing 68% of peak stress variance, and the Monte Carlo 95th percentile peak stress (531 MPa) remains below 51% of CoCr yield strength, preserving the linear elastic model form justification. The provenance chain from foundational cadaveric data through validation activities to the final stress predictions is complete and documented. The model is accepted for use in predicting peak von Mises stress and fatigue life for the Class II tibial tray under the defined operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
