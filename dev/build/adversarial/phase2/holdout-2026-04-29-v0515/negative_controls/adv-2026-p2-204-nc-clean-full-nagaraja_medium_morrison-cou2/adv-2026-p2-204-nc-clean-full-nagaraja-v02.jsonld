    "name": "COU1: Total knee arthroplasty tibial insert contact stress (Class II)",
    "description": "An FE model is used to predict peak contact stress and contact area on a UHMWPE tibial insert under ISO 14243-1 gait loading. Model influence is MODERATE (model supplements physical wear testing); decision consequence is MODERATE (incorrect prediction informs design iteration, not direct patient release). Model Risk Level 3.",
    "deviceClass": "Class II",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "intendedUse": "Use FE simulation to predict peak contact stress (MPa) and contact area (mm²) across five ISO 14243-1 gait cycle phases for a Class II TKA tibial insert. Predictions must agree with optical pressure-film measurements to within ±15% to support design-iteration decisions.",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-orthopedic/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: UHMWPE tibial inserts under ISO 14243-1 gait loading",
      "description": "This assessment applies exclusively to compression-moulded UHMWPE tibial inserts (GUR 1020 or GUR 1050 resin) articulating against CoCr femoral components under ISO 14243-1 displacement-controlled gait loading at body weights 600–1000 N. It does not extend to highly cross-linked polyethylene variants, unicompartmental designs, or loading profiles outside the ISO 14243-1 envelope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-orthopedic/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: gait loading and geometry bounds for TKA FE model",
      "description": "Axial compressive load: 600–1000 N; flexion angle: 0–60°; tibial rotation: ±5°; insert thickness: 8–12 mm; femoral condyle radius of curvature: 20–35 mm; UHMWPE elastic modulus: 800–1100 MPa; Poisson ratio: 0.46 ± 0.01; contact surface roughness Ra ≤ 0.05 µm. Predictions outside these bounds are not covered by this assurance package."
    }
  },
