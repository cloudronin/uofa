  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 5. For each factor, the achieved credibility level meets or exceeds the required level. Monte Carlo uncertainty quantification (1000 samples) demonstrates that the 95th percentile hemolysis prediction remains below the clinical acceptance threshold across all five operating points. Validation results show CFD NIH predictions within the experimental uncertainty band at all operating points with maximum systematic bias of 9.2%. Grid convergence is confirmed (GCI < 5%). Independent peer review of the simulation setup found no use errors. Model form selection is justified through comparative model analysis. The complete evidence chain from foundational experimental data through UQ to the regulatory decision metric is documented and traceable. The credibility body of evidence is sufficient to support acceptance of the CFD hemolysis model for the Class III VAD COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
