  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at MRL 2 and all achievedLevel values meet or exceed their requiredLevel. Software QA (Gradation 2), numerical code verification (Gradation 2), discretization error (Gradation 3, GCI_fine = 1.8%), test conditions (Gradation 2), output comparison (Gradation 2, NIH MAE = 0.0018 g/100L), QoI relevance (Gradation 2), and validation relevance (Gradation 2) form the core validation evidence chain. Numerical solver error, use error, and test samples each achieved Gradation 2, exceeding MRL 2 minima. Model form, model inputs, and equivalency of input parameters all satisfied at Gradation 2. The sensitivity analysis demonstrates that NIH predictions vary by less than 8% across the full operating envelope when impeller tip clearance is varied ±0.10 mm and viscosity varied ±15%, confirming robustness of the worst-case identification. The provenance chain is complete from raw PIV and bench-test data through validation results to this decision. No factor shortfalls exist; hasOffsetRationale is not required. The model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device under the defined COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
