  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-cbp-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed with achievedLevel meeting or exceeding requiredLevel at MRL 2. Key findings: (1) Discretization error GCI of 2.8% is well below the 5% threshold (DE Gradation 3 vs. required 2); (2) Output comparison shows velocity RMS errors of 4–8% and hemolysis index predictions within 9–13% of experimental means across all five operating points (OC Gradation 3 vs. required 2); (3) Validation activities directly cover all five COU operating points using the identical pump geometry and blood analog fluid; (4) Independent analyst review confirmed simulation setup correctness; (5) Sensitivity analysis confirmed that ±10% variation in hemolysis model coefficients produces less than ±6% change in the RH decision metric, supporting robustness of the acceptance conclusion. The model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device at MRL 2. No shortfall factors exist; hasOffsetRationale is not required.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
