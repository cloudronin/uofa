  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: FDA generic centrifugal blood pump under CPB operating conditions",
      "description": "Applicability is restricted to the FDA generic centrifugal blood pump geometry operated within the CPB flow regime (2–6 L/min, 2000–3500 RPM). The model is not applicable to pulsatile assist devices, axial-flow pumps, or operating points outside the validated flow-speed envelope. Blood rheology is modeled as a non-Newtonian fluid with hematocrit 35–45%; results are not applicable outside this range."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB operating envelope: flow 2–6 L/min, speed 2000–3500 RPM, hematocrit 35–45%",
      "description": "Validated operating envelope spans volumetric flow rates of 2.0–6.0 L/min and rotational speeds of 2000–3500 RPM, corresponding to the five flow-speed test points in the FDA benchmark dataset. Inlet pressure is 0–20 mmHg; outlet pressure 60–120 mmHg. Blood temperature is 35–37 °C. Geometric tolerances on impeller blade clearance are ±0.05 mm relative to the nominal CAD. Simulations outside these bounds require re-assessment."
    }
  },
