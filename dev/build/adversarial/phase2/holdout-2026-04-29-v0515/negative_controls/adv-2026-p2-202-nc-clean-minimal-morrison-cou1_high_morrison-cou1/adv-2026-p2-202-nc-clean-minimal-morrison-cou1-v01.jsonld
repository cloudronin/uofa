  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead-engineer",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) All seven assessed credibility factors meet or exceed their required gradation levels — Software QA (2/2), Numerical Code Verification (2/1 — exceeds requirement), Discretization Error (2/2, mean GCI 2.3%), Test Conditions (2/2), Output Comparison (3/2 — exceeds requirement, NRMSE 8.4% on RH index), Relevance of QoI (2/2), Relevance of Validation Activities (2/2). (2) Six factors are appropriately scoped out or marked not-applicable with documented rationale consistent with MRL 2 expectations: iterative solver error is demonstrably negligible at achieved residual convergence levels; use error is controlled by documented protocol and peer review; model form and model input uncertainties were informally bounded by sensitivity sweeps showing less than 4% and 3% QoI variation respectively; test samples and equivalency of input parameters are structurally not applicable to this reference-geometry validation campaign. (3) Validation results demonstrate quantitative agreement well within acceptance thresholds at all five operating points, with uncertainty quantification confirming that 95th-percentile RH index remains below the regulatory threshold of 1.0. (4) The provenance chain is complete: simulation results are traceable to documented experimental datasets (TR-CBP-2024-003), mesh convergence studies, and the published Morrison et al. (2019) FDA pump benchmark. No factor shortfalls exist; hasOffsetRationale is not required.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
