  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels at MRL 2 for this Class II CPB device: Software quality assurance (2/2), Numerical code verification (2/2), Discretization error (3/2, exceeds requirement), Test conditions (2/2), Output comparison (2/2), Relevance of QoI (2/2), and Relevance of validation activities to COU (2/2). The six remaining factors (Numerical solver error, Use error, Model form, Model inputs, Test samples, Equivalency of input parameters) are appropriately scoped out at MRL 2 with documented rationale for each. The CFD model predicts NIH within 18% of experimental means across all 5 operating points, satisfying the ±25% acceptance criterion. GCI analysis confirms discretization error is controlled below 5% on the primary QoI. The validation dataset (FDA GCBP) is directly representative of the COU geometry and operating envelope. The relative hemolysis index RH < 1 at all evaluated operating points supports the conclusion that the device does not present elevated hemolysis risk relative to the predicate. The structured evidence base, complete provenance chain, and all assessed factors meeting required levels collectively support acceptance of the computational model for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
