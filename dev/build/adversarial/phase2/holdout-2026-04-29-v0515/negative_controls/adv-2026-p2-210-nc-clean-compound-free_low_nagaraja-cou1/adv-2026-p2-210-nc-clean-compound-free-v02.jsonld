  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-acceptance-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending COU is accepted as credible for regulatory submission. Twelve of thirteen ASME V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — is addressed by the offset rationale below: the ASTM F1717 standard specifies a single standardized test configuration, and the regulatory claim is explicitly bounded to that configuration; multi-condition generalizability is not required for the stated COU. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy the quantitative acceptance criteria (E/uval < 1.96; percent difference < 10%) across all 11 constructs tested at two independent laboratories. Uncertainty in both simulation predictions and experimental measurements has been fully characterized and propagated. The overall evidence package is assessed as sufficient to support a Medium assurance level conclusion for a Model Risk Level 3, Class II device.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/nagaraja-cou1-tc-offset",
      "type": "OffsetRationale",
      "name": "Offset rationale for Test conditions shortfall",
      "refersToFactor": "https://uofa.net/synth/factor/nagaraja-cou1-tc",
      "justification": "The Test conditions factor achieved Gradation 2 (single test condition) against a required Gradation 3 (multi-condition coverage). This shortfall is accepted because: (1) ASTM F1717 prescribes a single standardized compression-bending configuration as the regulatory performance benchmark; (2) the regulatory claim in the 510(k) submission is explicitly scoped to the F1717 standard configuration at 44 mm offset and 5.5 mm rod diameter — no claim of generalizability to other configurations is made; (3) the high performance of the model on all three QoIs across N=11 constructs at two laboratories provides strong evidence of model fidelity within the stated COU boundary; and (4) sensitivity analyses confirm that model predictions are robust to small perturbations in offset distance (±2 mm) and rod diameter (±0.1 mm), providing partial evidence of local generalizability. The residual risk from single-condition testing is judged acceptable given the explicit COU scoping and the strength of the quantitative validation evidence."
    }
  },
