  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required gradation levels. E/uval < 1.96 for all three QoIs; percent differences < 10% for stiffness, yield force, and force at 40 mm displacement. Sensitivity analysis (Monte Carlo, 1000 samples) confirms QoI robustness to ±10% perturbation in material properties. The single shortfall — Test conditions (Gradation 1 achieved vs. Gradation 2 required) — is offset by the strong quantitative agreement across N=11 constructs at two independent laboratories and by the fact that ASTM F1717 itself specifies a single loading rate; variation of loading rate is therefore not within scope of the regulatory standard. The combined evidence supports acceptance of the FEA model for predicting compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct for 510(k) submission purposes.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/test-conditions-gradation-shortfall",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
      "justification": "Test conditions factor achieved Gradation 1 (single loading rate, single ambient temperature) against a required Gradation 2. This shortfall is offset by three considerations: (1) ASTM F1717 prescribes a single standardized loading rate (5 mm/min) and ambient condition, making multi-condition variation non-standard for this regulatory pathway; (2) inter-laboratory reproducibility across Lab A and Lab B demonstrates robustness of experimental results under nominally identical conditions, providing indirect evidence of test condition stability; and (3) sensitivity analysis (Monte Carlo, ±10% perturbation on all model inputs) shows that QoI predictions are insensitive to plausible environmental variation, with stiffness changing < 1.5% across the parameter space. The risk associated with this shortfall is therefore judged acceptable for a Class II device at Model Risk Level 3.",
      "name": "Offset rationale — Test conditions Gradation 1 vs. required Gradation 2"
    }
  },
