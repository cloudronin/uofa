  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as sufficiently credible for the stated COU at MRL 3. Twelve of thirteen V&V 40 factors meet or exceed their required gradation levels. All three pre-specified QoI validation metrics (E/u_val: stiffness 0.91, yield force 1.14, force at 40 mm 1.32) satisfy the E/u_val < 1.96 threshold. Discretization error, model inputs, and output comparison factors exceed requirements. The single shortfall — Test conditions (achieved Gradation 1 vs. required Gradation 2) — is addressed by the offset rationale below and does not undermine overall model credibility for the intended decision.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/tc-shortfall",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/factor/tc",
      "justification": "The Test conditions factor achieved Gradation 1 (single crosshead rate, ambient environment) against a required Gradation 2. This shortfall is accepted for three reasons: (1) ASTM F1717 is a standardised single-condition protocol and the test conditions used are normative for regulatory submissions, providing regulatory precedent for their adequacy; (2) ambient temperature testing is conservative relative to in vivo conditions (37 °C saline), which reduces titanium alloy yield strength by approximately 3–5 %, meaning the ambient bench result bounds the in vivo case; (3) the multi-laboratory design (two independent facilities, N=11 samples) provides inter-laboratory reproducibility evidence that partially compensates for the absence of parametric rate variation. The combined weight of evidence from the remaining twelve factors — particularly the pre-specified E/u_val metric passing for all QoIs — is sufficient to support the Accepted decision at MRL 3."
    }
  },
