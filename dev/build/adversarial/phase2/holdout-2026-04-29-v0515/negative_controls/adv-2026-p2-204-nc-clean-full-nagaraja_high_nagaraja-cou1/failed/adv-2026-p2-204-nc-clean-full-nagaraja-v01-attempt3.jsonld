  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA modeling framework for the non-cannulated 7.5 mm pedicle screw construct is accepted as sufficiently credible for regulatory submission under ASME V&V 40. Twelve of thirteen credibility factors meet or exceed their required levels. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both quantitative acceptance criteria (<10% mean difference, E/uval < 1.96) across N=11 specimens at two independent laboratories. Software QA, code verification, discretization error, solver convergence, use error, model form, model inputs, test samples, input equivalency, output comparison, QoI relevance, and validation activity relevance are all assessed at or above required levels. The single shortfall — Test conditions factor achieved level 2 vs. required level 3 — is addressed by the offset rationale below. The complete provenance chain from raw experimental data through FEA runs to QoI comparison is documented and archived.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (achieved 2, required 3)",
        "description": "The Test conditions factor achieved level 2 (single loading rate, ambient temperature only) against a required level of 3. This shortfall is accepted because: (1) ASTM F1717 is a quasi-static standard protocol and does not require rate variation for conformance testing; (2) titanium alloy and cobalt-chrome rod materials are rate-insensitive in the quasi-static regime (strain rates <0.01 s⁻¹), as documented in published materials literature; (3) the clinical use environment does not involve dynamic loading at rates outside the quasi-static regime for the compression-bending failure mode; (4) the shortfall is offset by the above-required-level performance on Output comparison (E/uval < 1.96 for all QoIs), Test samples (dual-lot, dual-laboratory), and Validation activity relevance (direct validation with no extrapolation). The residual risk from this single-condition testing is judged low given the material rate-insensitivity and the strength of the remaining 12 factors."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
