  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as credible for the stated COU. Twelve of 13 V&V 40 credibility factors meet or exceed their required levels. The validation metric E/uval is below 1.96 for all three QoIs across all 11 specimens at two independent laboratories. Software QA, discretization error, model inputs, test samples, equivalency of input parameters, QoI relevance, and validation activity relevance all exceed their required levels. One factor — Test conditions — achieved Gradation 2 against a required Gradation 3 due to testing under a single loading condition (compression-bending only). The offset rationale documents that this shortfall is acceptable given the COU scope, which is limited to ASTM F1717 compression-bending performance prediction, and that the single tested condition is fully representative of the intended use. The structured evidence base, complete provenance chain, and quantified uncertainty budget support the acceptance decision at Medium assurance level for this Class II device at MRL 3.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
      "justification": "The Test conditions factor achieved Gradation 2 (single standardized loading condition) against a required Gradation 3 (multiple loading conditions). This shortfall is accepted because the COU is explicitly scoped to ASTM F1717 static compression-bending prediction only; torsional and lateral bending performance are outside the stated COU and are addressed by separate validation activities. The single compression-bending condition is fully representative of the intended regulatory submission use case. Additionally, the high achieved levels on Output comparison (E/uval < 1.96 for all QoIs), Test samples (N=11 across two laboratories), and Equivalency of input parameters provide compensating evidence that the model is well-characterized within the tested loading regime. The residual risk from the single-condition limitation is bounded by the operating envelope constraint requiring ASTM F1717 protocol compliance."
    }
  },
