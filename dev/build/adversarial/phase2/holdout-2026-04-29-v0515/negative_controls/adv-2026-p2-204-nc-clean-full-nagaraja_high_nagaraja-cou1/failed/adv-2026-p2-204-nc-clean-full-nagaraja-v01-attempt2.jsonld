      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria",
        "description": "Quantitative comparison using ASME V&V 40 validation metric E/uval. E/uval < 1.96 for all three QoIs (stiffness, yield force, force at 40 mm). Percentage difference |FEA - experiment| / experiment < 10% for all 11 specimens. Achieves Gradation 3: formal validation metric with uncertainty quantification."
      },
      "rationale": "Validation metric E/uval computed for all three QoIs across all 11 specimens. Results: stiffness E/uval = 1.31, yield force E/uval = 1.44, force at 40 mm E/uval = 1.18 — all below the 1.96 threshold. Maximum percentage difference across all specimens and QoIs was 8.7%, within the 10% acceptance criterion. Uncertainty quantification accounts for experimental measurement uncertainty, input parameter uncertainty, and model form uncertainty."
    },
    {
