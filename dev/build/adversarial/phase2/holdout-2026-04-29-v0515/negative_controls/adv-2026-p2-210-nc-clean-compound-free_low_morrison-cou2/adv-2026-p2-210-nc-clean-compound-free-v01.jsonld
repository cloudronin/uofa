  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at Model Risk Level 5 have achieved levels meeting or exceeding required levels. The Monte Carlo uncertainty quantification (n=2000, LHS) propagates all 14 input uncertainties to NIH and pressure-head QoIs, yielding 95% prediction intervals of ±11% against a ±15% acceptance threshold. GCI on production mesh is 3.1% for NIH, below the 5% threshold. Output comparison across all 5 operating points shows maximum NIH deviation of 9.3%, within the ±15% acceptance criterion. Validation activities are fully relevant to the COU: identical geometry, matched fluid analogue, and operating envelope spanning the COU. Software QA, code verification, and use-error controls are all at Gradation 4 or 3 as required for MRL 5. The structured evidence base supports the claim that the CFD model can predict absolute hemolysis levels for the Class III VAD device with sufficient credibility for regulatory submission. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
