  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 5. Achieved levels meet or exceed required levels for every factor: discretization error (GCI 3.2% < 5% threshold, level 4/4), output comparison (max 14% NIH deviation within 20% criterion, level 4/4), model form (turbulence model sensitivity study completed, level 4/4), model inputs (all five uncertain inputs characterised with full PDFs, level 4/4), validation relevance (identical geometry and operating points, level 4/4), test conditions (NIST-traceable instrumentation with full uncertainty budgets, level 4/4), and all remaining factors at or above their required levels. Monte Carlo UQ ensemble (N=2000 LHS samples) propagated all input uncertainties through the hemolysis model; 95th-percentile NIH prediction remains below the absolute clinical threshold of 0.8 g/100L. No credibility gaps remain. The evidence base is sufficient to support regulatory submission for the Class III VAD indication.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
