  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 10 assessed credibility factors meet or exceed their required Gradation levels for an MRL-2 Class II CPB device. The three scoped-out factors (Use Error, Test Samples, Equivalency of Input Parameters) are each supported by documented rationale consistent with ASME V&V 40 Table 1 expectations at MRL 2. The CFD model predicts the relative hemolysis index within ±12% of experimental measurements across all 5 operating points, satisfying the RH < 1 regulatory acceptance criterion relative to the predicate device. Discretization error is quantified via a three-level GCI study with GCI < 5%. Model form choices are grounded in published literature for rotating blood-contacting devices. The provenance chain from raw experimental data through validation results to this assurance package is complete. No achievedLevel falls below requiredLevel; no offset rationale is required.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
