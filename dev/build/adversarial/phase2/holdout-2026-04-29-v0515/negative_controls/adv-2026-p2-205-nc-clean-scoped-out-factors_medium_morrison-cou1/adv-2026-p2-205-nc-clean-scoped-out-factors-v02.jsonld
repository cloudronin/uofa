  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepts the CFD hemolysis model for COU1 (identification of worst-case hemolysis operating conditions for the FDA GCBP Class II CPB device at MRL 2) based on the following structured evidence: (1) Ten of thirteen ASME V&V 40 credibility factors have been assessed, with all ten meeting or exceeding their required gradation levels — no factor shortfall exists. (2) Three factors (Numerical solver error, Use error, Equivalency of input parameters) are formally scoped out with documented rationale that is consistent with MRL 2 requirements and the MEDIUM model influence classification; each scoping decision is grounded in either procedural controls, redundancy with other assessed factors, or explicit ASME V&V 40 Table 3 provisions. (3) Discretization error was demonstrated to achieve gradation 3 (GCI 3.2%), exceeding the MRL 2 requirement, providing additional confidence in numerical accuracy. (4) Both primary validation results (PIV velocity field and bench hemolysis index) meet their quantitative acceptance criteria across all five operating points. (5) The sensitivity analysis documents that turbulence model selection is the dominant source of model-form uncertainty and that SST k-ω minimises this uncertainty for the hemolysis QoI. (6) The provenance chain is complete: all evidence is traceable to the FDA GCBP benchmark dataset (DOI 10.1115/1.4035672) and the on-file bench-test records. No offset rationale is required because no factor shortfall exists.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
