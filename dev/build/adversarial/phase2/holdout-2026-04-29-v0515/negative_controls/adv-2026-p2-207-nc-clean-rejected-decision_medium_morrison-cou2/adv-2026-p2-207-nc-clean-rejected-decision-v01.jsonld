  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/morrison/factor/sqa",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/sqa",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criteria — MRL 5 Class III",
        "description": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; change-control log traceable to regulatory submission. Achieved level 4 satisfies the MRL-5 requirement of 4 for this factor."
      },
      "rationale": "The CFD solver (OpenFOAM v9.1) is maintained under ISO 9001-aligned version control. A 47-case regression suite covering turbulent pipe flow, rotating-frame flows, and scalar transport was executed and all cases passed within tolerance. Change-control records are complete and traceable. SQA meets the required gradation for MRL 5."
    },
    {
      "id": "https://uofa.net/morrison/factor/ncv",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/ncv",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criteria",
        "description": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and scalar hemolysis transport equations; observed order of accuracy within 10% of theoretical order."
      },
      "rationale": "MMS verification confirmed second-order spatial accuracy (observed p=1.93 vs theoretical 2.0) for velocity and pressure fields, and first-order accuracy for the hemolysis scalar transport equation consistent with the upwind scheme employed. Code verification is complete and meets the required level."
    },
    {
      "id": "https://uofa.net/morrison/factor/disc-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/disc-error",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria — MRL 5",
        "description": "Grid convergence index (GCI) reported for all five operating points; GCI on hemolysis index < 5% on fine grid; three systematically refined meshes with refinement ratio >= 1.3."
      },
      "rationale": "GCI analysis was performed on three mesh levels (2.1M, 5.8M, 14.2M cells) for all five operating points. The fine-grid GCI for hemolysis index ranged from 4.1% to 11.3% across operating points, with two of five points exceeding the 5% acceptance threshold. The refinement ratio of 1.28 fell marginally below the required 1.3 at one level. Achieved level 3 against a required level of 4: this factor is the primary driver of the Not Accepted decision. The discretization error in the high-shear impeller region is insufficiently controlled for an absolute hemolysis prediction at MRL 5."
    },
    {
      "id": "https://uofa.net/morrison/factor/test-conditions",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria",
        "description": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity, temperature) documented with measurement uncertainty; conditions bracket the COU operating range."
      },
      "rationale": "All five experimental test points were conducted with calibrated Coriolis flow meters (±0.5% FS), torque transducers (±0.3% FS), and temperature-controlled blood analog fluid (glycerol-water, viscosity matched to 37°C whole blood). Conditions bracket the COU operating envelope. Test conditions meet the required level."
    },
    {
      "id": "https://uofa.net/morrison/factor/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria — absolute hemolysis MRL 5",
        "description": "Quantitative comparison metric (e.g., E_rel or NRMSE) computed for hemolysis index across all five operating points; metric reported with experimental and simulation uncertainty bounds; statistical equivalence test performed."
      },
      "rationale": "Relative error on normalized index of hemolysis (NIH) ranged from 8% to 34% across the five operating points, with the 34% outlier occurring at the lowest flow/highest speed condition where secondary flow structures dominate. A Wilcoxon signed-rank test did not reject the null of systematic bias (p=0.07), but the wide error range and absence of a formal statistical equivalence test (TOST) at the required alpha level prevent achieving level 5. Achieved level 4 against required level 5."
    },
    {
      "id": "https://uofa.net/morrison/factor/qoi-relevance",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/qoi-relevance",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criteria",
        "description": "Validation QoI (NIH) is the same scalar as the COU decision QoI; no surrogate or proxy quantity used."
      },
      "rationale": "The normalized index of hemolysis (NIH) computed in the validation study is identical to the regulatory decision metric specified in the COU. No surrogate quantity is employed. The hemolysis power-law model (Giersiepen-Wurzinger) is applied consistently between validation and COU predictions. QoI relevance meets the required level."
    },
    {
      "id": "https://uofa.net/morrison/factor/val-relevance",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/val-relevance",
        "type": "AcceptanceCriteria",
        "name": "Validation activity relevance acceptance criteria",
        "description": "Validation geometry is the FDA generic centrifugal pump benchmark; operating conditions overlap the COU envelope; fluid properties match within specified tolerance."
      },
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry — the same geometry as the COU device. Operating points span 2–6 L/min flow and 2500–3500 RPM, fully overlapping the COU envelope of 3–5 L/min and 2800–3200 RPM. Blood analog viscosity was matched within 4% of target. Validation relevance meets the required level."
    },
    {
      "id": "https://uofa.net/morrison/factor/solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Numerical solver error is scoped out because the solver (OpenFOAM v9.1) employs direct algebraic solvers (GAMG with absolute tolerance 1e-8) for pressure and bounded linear schemes for scalar transport. Iterative convergence to machine-precision residuals is achieved at every time step and verified by residual monitoring logs. Solver error is therefore analytically bounded below the discretization error and does not constitute an independent credibility gap at this model risk level. The scoping decision was reviewed and approved by the lead V&V engineer."
    },
    {
      "id": "https://uofa.net/morrison/factor/use-error",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Use error is scoped out because the COU specifies that CFD simulations are executed exclusively by credentialed computational engineers following a controlled simulation protocol (SOP-CFD-003 Rev B). The simulation protocol mandates peer review of case setup files, boundary condition specification, and post-processing scripts prior to result acceptance. Under this controlled execution environment, operator-induced use error is systematically mitigated and does not represent a residual credibility gap requiring independent assessment at this stage."
    },
    {
      "id": "https://uofa.net/morrison/factor/model-form",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Model form uncertainty is scoped out of the current assessment cycle. The hemolysis power-law model (Giersiepen-Wurzinger coefficients) is a regulatory convention for this device class and is applied uniformly across all submissions in this product family. A separate model-form sensitivity study comparing three hemolysis constitutive models is documented under activity https://uofa.net/morrison/activity/model-form-sensitivity-2025-08 and will be incorporated in the next assessment cycle. For the current COU2 assessment, model-form uncertainty is acknowledged as a known epistemic contributor but is excluded from the factor scoring to avoid double-counting with the output comparison factor."
    },
    {
      "id": "https://uofa.net/morrison/factor/model-inputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/criteria/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria",
        "description": "All model inputs (geometry, boundary conditions, material properties) documented with source, value, and uncertainty; Monte Carlo UQ propagates input uncertainty to NIH output."
      },
      "rationale": "Geometry was reconstructed from manufacturer-supplied CAD (tolerance ±0.05 mm verified by CMM). Fluid properties (density, viscosity, red blood cell concentration) were sourced from peer-reviewed literature with documented uncertainty ranges. Monte Carlo UQ (n=500 Latin hypercube samples) propagated input uncertainty through the hemolysis model, yielding 95% prediction intervals on NIH at each operating point. Model inputs meet the required level."
    },
    {
      "id": "https://uofa.net/morrison/factor/test-samples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Test samples factor is scoped out because the validation study used a single FDA generic centrifugal pump unit fabricated to the published benchmark geometry. Patient-to-patient blood property variability is addressed through the Monte Carlo UQ on model inputs rather than through replicate physical test samples. Acquiring multiple pump units for destructive hemolysis testing was outside the scope and budget of the current study. This scoping decision is consistent with the FDA benchmark protocol, which specifies a single reference geometry."
    },
    {
      "id": "https://uofa.net/morrison/factor/equiv-inputs",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters between the validation experiment and the COU is scoped out as a separate factor because the assessment of this equivalency is fully subsumed within the Relevance of Validation Activities factor (https://uofa.net/morrison/factor/val-relevance), which explicitly documents the quantitative match between validation and COU boundary conditions, geometry, and fluid properties. Scoring this factor independently would duplicate the evidence already credited under val-relevance and is therefore excluded to maintain factor independence per ASME V&V 40 Section 5.3 guidance."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026-04",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The COU2 credibility assessment concludes Not Accepted based on two factors with achieved levels below the required level for Model Risk Level 5. Primary driver: Discretization Error (factor https://uofa.net/morrison/factor/disc-error) achieved level 3 against a required level of 4. The GCI on hemolysis index exceeded the 5% acceptance threshold at two of five operating points (peak GCI 11.3%), and the mesh refinement ratio fell below the required 1.3 at one refinement level. For an absolute hemolysis prediction used as the primary regulatory basis for a Class III VAD, this level of uncontrolled discretization error in the high-shear impeller region is not acceptable. Secondary contributor: Output Comparison (factor https://uofa.net/morrison/factor/output-comparison) achieved level 4 against a required level of 5. The 34% relative error at the critical low-flow/high-speed operating point, combined with the absence of a formal TOST statistical equivalence test, prevents demonstrating the quantitative agreement required at MRL 5 for absolute hemolysis prediction. No offset rationale is claimed. The assessment team determined that the shortfalls represent genuine credibility gaps that must be resolved through additional mesh refinement studies and expanded statistical validation, not through compensating evidence. The package is resubmittable upon completion of a fine-grid mesh campaign targeting GCI < 5% at all operating points and a formal TOST equivalence test at alpha=0.05.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
