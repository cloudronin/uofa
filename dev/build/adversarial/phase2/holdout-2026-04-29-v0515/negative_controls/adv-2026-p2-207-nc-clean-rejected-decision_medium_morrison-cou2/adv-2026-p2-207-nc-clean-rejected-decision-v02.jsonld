  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-model-form",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/vv40-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The COU2 credibility assessment is Not Accepted on the basis of a critical shortfall in the Model Form credibility factor. The Giersiepen-Wurzinger power-law hemolysis constitutive model achieves Gradation 2 against a required Gradation 4 at Model Risk Level 5 for a Class III VAD device. Specifically: (1) the model has been validated against only a single experimental dataset, failing the requirement for cross-validation against at least three independent datasets spanning the COU shear-stress and exposure-time space; (2) the power-law exponents have not been recalibrated against modern red blood cell damage data; and (3) sensitivity analysis demonstrates that NIH predictions vary by a factor of 2.3 across the plausible range of published exponent values, which exceeds the ±20% acceptance threshold by more than an order of magnitude. At MRL 5 with HIGH decision consequence and HIGH model influence, this two-gradation shortfall in the constitutive law governing the primary QoI cannot be offset by the strong performance of the remaining 10 assessed factors. The package is rejected pending re-calibration of the hemolysis model against multiple independent experimental datasets and a demonstrated reduction in constitutive-law parametric sensitivity to within the acceptance threshold.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
