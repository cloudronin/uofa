  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, Class III, MRL 5) is accepted on the basis of the following structured evidence: (1) All 12 assessed credibility factors achieve levels meeting or exceeding their required levels — no shortfall gaps exist. (2) The single scoped-out factor (Equivalency of input parameters) is supported by a thorough documented rationale demonstrating that the scientific concern is fully mitigated by the Gradation 4 Model Inputs UQ treatment, which propagates blood property variability through the Monte Carlo ensemble. (3) Quantitative output comparison shows agreement within the combined U95 uncertainty interval at all 5 VAD operating points, with mean absolute error of 6.2%. (4) The 5,000-sample Monte Carlo UQ ensemble provides a complete probabilistic characterisation of hemolysis index predictions, confirming that the 97.5th-percentile prediction remains below the clinical threshold with margin. (5) The provenance chain is complete: all validation results are traceable to archived experimental datasets, the CFD solver version, and the UQ activity record. (6) Software quality assurance, code verification, and discretization error are all at Gradation 4, providing a rigorous computational foundation appropriate for a Class III device at MRL 5. The assessment team finds no unresolved credibility gaps and concludes that the CFD model provides sufficient evidence to support the claim that predicted absolute hemolysis levels are credible for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
