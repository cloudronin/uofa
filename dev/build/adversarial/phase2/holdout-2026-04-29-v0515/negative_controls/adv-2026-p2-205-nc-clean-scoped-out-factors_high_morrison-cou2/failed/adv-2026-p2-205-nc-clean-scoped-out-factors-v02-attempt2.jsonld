  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors are assessed at MRL 5 with achieved levels meeting or exceeding required levels across all ASME V&V 40 factor categories. The thirteenth factor — Equivalency of input parameters — is formally scoped-out with documented rationale: the FDA generic pump is a canonical reference geometry with no physical test article, making the standard equivalency assessment inapplicable by construction rather than by omission. Monte Carlo uncertainty quantification (1000 samples) is completed and the NIH uncertainty envelope overlaps experimental measurements at all five operating points. GCI is below 2% across all operating points. Independent peer review of simulation setup is complete with no unresolved discrepancies. The provenance chain is fully documented from raw experimental data through model runs to the decision record. All acceptance criteria are met or formally scoped-out with documented justification. The package is accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
