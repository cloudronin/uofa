  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA ensemble for non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending is accepted as sufficiently credible for its intended regulatory use. Ten of thirteen V&V 40 factors were formally assessed; three (Numerical solver error, Use error, Relevance of QoIs) were scoped out with documented justification that does not introduce credibility risk. Of the ten assessed factors, nine achieved or exceeded their required gradation level. One factor (Test conditions) achieved Gradation 2 against a Gradation 3 requirement due to single-condition ASTM F1717 testing; this shortfall is accepted per the offset rationale below. All three QoIs pass both the E/uval < 1.96 and < 10% percent-difference acceptance criteria across N=11 production-representative constructs tested at two independent laboratories. The overall evidence base is consistent with Medium assurance level for a Class II device with medium model influence and medium decision consequence.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions Gradation 2 shortfall",
        "description": "The Test conditions factor achieved Gradation 2 (single ASTM F1717 configuration) against a Gradation 3 requirement (multi-condition coverage). This shortfall is accepted because: (1) ASTM F1717 prescribes a single standardized test configuration as the regulatory standard of care, and multi-condition testing is not required for 510(k) clearance; (2) the FEA model's sensitivity to boundary condition variation was characterized via parametric analysis (±10% fixture stiffness, ±5-degree angle) with < 4% QoI change, demonstrating robustness across the plausible operating envelope; (3) the medium model influence and medium decision consequence classification for this COU does not require Gradation 3 test condition coverage to maintain adequate overall credibility. The shortfall is offset by the high confidence in output comparison results (E/uval < 1.2 for all QoIs) and the production-representative test samples."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
