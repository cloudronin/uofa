  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-v3",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required Gradation 2 levels for MRL 2. Six factors are appropriately scoped out or not applicable per ASME V&V 40 Table 1. The output comparison factor achieves Gradation 2 despite an explicitly documented low-confidence NRMSE of 18% (95% CI: 11–27%), because Gradation 2 requires quantitative comparison with documented uncertainty bounds rather than a specific accuracy threshold. The wide uncertainty bounds are driven primarily by hemolysis model parameter uncertainty (power-law exponent ±12%) and blood viscosity variability (±15%), as documented in the Monte Carlo UQ. This residual uncertainty is accepted because: (1) the model is used comparatively (RH < 1 relative to predicate) rather than for absolute NIH prediction, reducing sensitivity to absolute accuracy; (2) the pressure-rise validation (NRMSE 4.2%, medium confidence) confirms the underlying flow field is well-predicted; (3) physical testing will confirm the worst-case operating point identification prior to final design freeze. The decision is Accepted with documented residual risk.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/oc-wide-uncertainty-v1",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/factor/oc-v1",
      "justification": "The Output Comparison factor achieves Gradation 2 with an NRMSE of 18% and a wide 95% CI (11–27%) reflecting low confidence in the hemolysis model parameter estimates. This shortfall in predictive precision is offset by three compensating controls: (1) the acceptance criterion is comparative (RH < 1 vs. predicate device) rather than absolute, so systematic model bias cancels in the ratio; (2) the flow-field validation via pressure rise achieves high confidence (GCI 4.2%, NRMSE within experimental uncertainty), confirming the shear stress environment driving hemolysis is accurately captured; and (3) a physical bench test of the worst-case operating point is mandated as a post-simulation confirmation step before regulatory submission. These offsets collectively justify accepting the wide hemolysis prediction uncertainty without re-assessment at a higher gradation."
    }
  },
