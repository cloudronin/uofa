  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels at MRL 2. Six factors are appropriately scoped out or not applicable with documented justification. The hemolysis index validation result carries an explicitly wide 95% prediction interval (RH = 0.71 ± 0.19) reflecting limited characterisation of patient-specific blood rheology; this low-confidence result is honestly disclosed in the ValidationResult and UncertaintyQuantification records rather than suppressed. The central estimate (RH = 0.71) is within the experimental uncertainty band (0.68 ± 0.08) and below the regulatory threshold (RH < 1), providing adequate margin. Blade-tip WSS discrepancy (13% of PIV windows outside combined uncertainty) is documented as a low-confidence zone; its localised nature and absence of effect on the global hemolysis index support acceptance. The medium model-influence classification means that physical testing will confirm the CFD-identified worst-case condition prior to regulatory submission, providing a corroborating evidence layer that offsets the residual uncertainty in the hemolysis prediction. The decision to accept is grounded in the complete structured evidence chain, the honest documentation of uncertainty bounds, and the corroborating experimental data at all five operating points.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/morrison/offset/hemolysis-wide-pi",
      "type": "OffsetRationale",
      "description": "The wide hemolysis index prediction interval (±0.19 at 95%) does not trigger a shortfall in achievedLevel vs requiredLevel (both at Gradation 2), but is documented here as a residual risk offset. The offset is justified by: (1) central estimate within experimental uncertainty; (2) RH margin of 0.29 below regulatory threshold; (3) medium model influence classification requiring confirmatory physical testing; and (4) sensitivity analysis confirming that even at the upper bound of the PI (RH = 0.90), the device remains below the RH < 1 acceptance criterion."
    }
  },
