  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required Gradation 2 levels for MRL 2. Six factors are appropriately scoped out or not applicable per ASME V&V 40 Table 3 guidance for a Class II device with medium model influence. The assessment explicitly documents low confidence in two validation outputs: (1) PIV velocity comparison normalised RMS error of 8.2% ± 4.1% (95% CI), driven by PIV measurement uncertainty in the impeller region and turbulence model sensitivity; and (2) RH prediction within ±35% of bench measurements, driven by power-law hemolysis model coefficient uncertainty (CV ~20%). These wide bounds are accepted as residual risk because: (a) the rank ordering of worst-case operating points is robust across the uncertainty range — the 6 L/min, 3500 RPM condition is identified as worst-case in all Monte Carlo realisations; (b) the RH criterion (RH < 1) is met with margin even at the upper uncertainty bound; (c) bench testing confirms the worst-case prediction, reducing reliance on the CFD result alone; and (d) MRL 2 does not require tight quantitative agreement, only documented quantitative comparison. The decision to accept is grounded in the totality of structured evidence and the conservative nature of the RH < 1 acceptance criterion relative to the observed uncertainty bounds.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": []
