      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/qoi-relevance",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criteria — MRL 2",
        "description": "The selected QoIs (RH index, pressure head) must be directly linked to the regulatory decision question and must be computable from the CFD output fields without additional unvalidated post-processing."
      },
      "rationale": "Relative hemolysis index is the primary regulatory metric per ASTM F1841 and FDA guidance. Pressure head directly characterises pump performance relevant to CPB circuit design. Both QoIs are computed directly from CFD velocity and stress fields using the validated Giersiepen power-law integration."
    },
    {
