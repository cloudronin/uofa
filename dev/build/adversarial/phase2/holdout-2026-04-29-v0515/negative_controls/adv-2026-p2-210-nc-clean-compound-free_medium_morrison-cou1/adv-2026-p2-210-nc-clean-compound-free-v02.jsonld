      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria — MRL 2",
        "description": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature) must be reproduced in simulation within ±2% of measured values; test fluid properties documented."
      },
      "rationale": "All five operating points (2–6 L/min, 2000–3500 RPM) were reproduced in simulation using measured inlet velocity profiles and fluid viscosity from the experimental log. Deviations from nominal conditions were < 1.2% for all parameters. AAMI blood analogue properties applied."
    },
    {
      "id": "https://uofa.net/morrison/factor/output-comparison",
