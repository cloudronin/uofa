  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors (Software quality assurance, Numerical code verification, Discretization error, Test conditions, Output comparison, Relevance of QoIs, Relevance of validation activities) achieved their required Gradation 2 levels. GCI on primary QoI (RH index) was 2.1%, well within the 5% threshold. Simulated RH index agreed with experimental data within 9.3% across all five operating points, satisfying the ±15% acceptance criterion. The worst-case operating point was correctly identified by the model. Six factors were scoped out per ASME V&V 40-2018 Table 3 guidance for MRL 2 Class II devices, with documented rationale for each. No shortfalls exist between achieved and required levels. The structured evidence record supports the claim that the CFD model is sufficiently credible to identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions. Decision consequence is HIGH and model influence is MEDIUM, consistent with MRL 2 assignment. The credibility assessment team accepts the model for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
