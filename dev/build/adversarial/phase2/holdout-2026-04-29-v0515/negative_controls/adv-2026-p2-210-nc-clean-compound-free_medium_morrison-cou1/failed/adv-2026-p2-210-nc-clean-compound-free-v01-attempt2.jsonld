  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-division-of-applied-mechanics",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for the FDA generic centrifugal blood pump under CPB conditions) is accepted at Medium assurance level based on the following structured evidence: (1) All 7 assessed credibility factors meet or exceed their required gradation levels at MRL 2, with discretization error achieving Gradation 3 via a three-level GCI study (GCI = 2.3%). (2) The 6 scoped-out or not-applicable factors are appropriately justified by MRL 2 requirements per ASME V&V 40-2018 Table 3 and COU-specific applicability arguments. (3) Validation results demonstrate agreement between predicted and measured relative hemolysis index within combined U95 uncertainty bounds at all 5 operating points. (4) The provenance chain is complete from foundational experimental data (Morrison et al. 2012, DOI:10.1115/1.4034918) through simulation activities to validation results. (5) No credibility factor exhibits an achieved level below its required level; therefore no offset rationale is required. The computational model is judged credible for its intended use in identifying worst-case hemolysis operating conditions for Class II CPB device tolerance decisions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
