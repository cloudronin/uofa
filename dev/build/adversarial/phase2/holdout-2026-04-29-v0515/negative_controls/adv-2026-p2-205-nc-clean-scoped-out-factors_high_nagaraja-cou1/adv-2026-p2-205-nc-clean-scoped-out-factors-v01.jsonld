      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-cou1-equiv-inputs-ac",
        "type": "AcceptanceCriteria",
        "name": "Equivalency of input parameters acceptance criteria — Gradation 3",
        "description": "Model geometry, material properties, boundary conditions, and loading protocol must be demonstrably equivalent to the physical test configuration. Any discrepancy > 2% in a geometric dimension or > 5% in a material property must be documented and its influence on QoIs quantified."
      },
      "rationale": "Model geometry was constructed directly from CMM inspection data of the tested components. Boundary conditions replicate F1717 fixture constraints (pin-pin, 100 mm span). Loading applied as displacement-controlled ramp matching the 5 mm/min experimental rate (quasi-static, inertia effects < 0.1%). No geometric or material discrepancies exceeding acceptance thresholds were identified. Equivalency confirmed at Gradation 3."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-cou1-output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-cou1-output-comparison-ac",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria — Gradation 3 quantitative metric with uncertainty",
        "description": "Validation metric E/uval (normalised error) computed for stiffness, yield force, and force at 40 mm. All three QoIs must satisfy |E/uval| < 1.96 (95% confidence). Percentage difference between ensemble mean prediction and experimental mean must be < 10% for all QoIs."
      },
      "rationale": "Ensemble mean predictions vs. experimental means: stiffness 4.2% difference (E/uval=0.81), yield force 3.7% difference (E/uval=0.64), force at 40 mm 6.1% difference (E/uval=1.18). All three QoIs satisfy both the < 10% and |E/uval| < 1.96 acceptance criteria. The quantitative validation metric with full uncertainty decomposition (model, numerical, experimental) elevates this factor to Gradation 4."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-cou1-qoi-relevance",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-cou1-qoi-relevance-ac",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criteria — Gradation 2 direct correspondence",
        "description": "Validation QoIs (stiffness, yield force, force at 40 mm displacement) must directly correspond to the QoIs used in the COU decision (same physical quantities, same measurement locations, same definition of failure). No surrogate QoIs permitted."
      },
      "rationale": "The three validation QoIs (construct stiffness, yield force, force at 40 mm displacement) are identical to the QoIs reported in the regulatory submission and used in the design acceptance decision. Stiffness characterises elastic load transfer; yield force identifies onset of permanent deformation; force at 40 mm represents post-yield structural capacity per F1717. No surrogate quantities used. Direct correspondence confirmed; Gradation 3 achieved due to documented traceability from QoI definition to decision criterion."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-cou1-val-activity-relevance",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
