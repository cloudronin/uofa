  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 12 assessed credibility factors achieve levels meeting or exceeding their MRL-5 required levels. The Test Samples factor is appropriately scoped out with documented rationale. Wide Monte Carlo uncertainty bounds (±42% on NIH) are explicitly documented and honestly reported; despite these bounds, mean predictions remain below the clinical hemolysis threshold at all 5 operating points and experimental measurements fall within the 95% prediction intervals. The wide uncertainty is driven by known epistemic uncertainty in hemolysis model exponents and blood rheology parameters, which are fully characterized. An offset rationale is provided addressing the wide uncertainty bounds relative to the high-consequence COU.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/morrison/offset/cou2-wide-uq-bounds",
      "type": "OffsetRationale",
      "name": "Offset rationale for wide Monte Carlo uncertainty bounds on NIH predictions",
      "refersToFactor": "https://uofa.net/morrison/factor/cou2-mi",
      "justification": "The wide ±42% uncertainty bounds on the normalized index of hemolysis arise from documented epistemic uncertainty in the power-law hemolysis model exponents (α, β) and blood viscosity parameters — both of which are inherent limitations of the current state of hemolysis modeling science rather than deficiencies in the simulation methodology. Despite these wide bounds, the following compensating factors justify acceptance: (1) mean NIH predictions remain 31% below the clinical threshold across all operating points, providing a conservative safety margin that exceeds the one-sided 95% prediction interval upper bound; (2) the Sobol sensitivity analysis demonstrates that uncertainty reduction in the model exponents alone would reduce total NIH uncertainty by 68%, providing a clear path to future credibility improvement; (3) the Monte Carlo ensemble of 1000 samples provides statistically robust coverage of the uncertain input space; and (4) the independent reviewer confirmed that no systematic bias is present in the mean predictions relative to experimental data (d = 0.87). The residual uncertainty is accepted as a known and quantified limitation consistent with the current regulatory precedent for CFD-based hemolysis assessment of Class III VADs, and is documented for post-market surveillance monitoring."
    }
  },
