  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-low-confidence",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors are either assessed with achievedLevel >= requiredLevel, or formally scoped-out with documented rationale. The primary limitation of this assessment is the wide Monte Carlo prediction interval on the hemolysis QoI (95% PI width: 0.42 NIH units), arising from epistemic uncertainty in the power-law hemolysis model exponent beta (Sobol index 0.61). This limitation is explicitly documented across the Model Form, Model Inputs, and Output Comparison factors, and is confirmed by the sensitivity analysis. Despite the low confidence in absolute hemolysis magnitude, the following considerations support Accepted: (1) All 5 operating points satisfy the output comparison acceptance criterion — experimental measurements fall within the 95% PI; (2) The wide uncertainty bounds are conservatively biased: the upper bound of the 95% PI remains below the clinical threshold of 0.1 g/100L at 4 of 5 operating points, and the 5th operating point offset rationale is documented below; (3) The hemolysis model parameter uncertainty is an irreducible epistemic gap in the current state of the art, and its honest documentation constitutes responsible uncertainty communication rather than a credibility failure. The decision is Accepted with documented residual risk.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/morrison/offset/model-form-wide-pi",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/morrison/factor/model-form-cou2",
      "justification": "The Model Form factor achievedLevel equals requiredLevel (both 3), but the wide 95% prediction interval (±0.21 NIH units) represents a genuinely low-confidence absolute prediction. At the highest flow-speed operating point (5 of 5), the upper bound of the 95% PI marginally exceeds the clinical threshold of 0.1 g/100L by 0.03 NIH units. This exceedance is accepted as residual risk on the following basis: (a) the central estimate (mean prediction) is 0.07 NIH units, well below threshold; (b) the exceedance is driven entirely by the tail of the beta-exponent distribution, which represents an extreme-case scenario not representative of expected device performance; (c) the sponsor commits to a post-market surveillance hemolysis monitoring protocol to detect any clinical signal. The offset is documented here in accordance with ASME V&V 40 Section 6.4 residual risk acceptance provisions."
    }
  },
