  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/cardiovascular-simulation-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The COU2 credibility assessment at MRL 5 is accepted based on the following structured evidence: (1) All 13 ASME V&V 40 credibility factors have been assessed, with achievedLevel meeting or exceeding requiredLevel in every case. (2) Numerical verification is rigorous: MMS-confirmed second-order convergence, GCI < 1.4% for all QoIs at the production mesh, and cross-solver verification against OpenFOAM. (3) Validation against FDA experimental data demonstrates quantitative agreement within combined uncertainty bounds (Uval) for both primary QoIs (NIH error 9.8% < Uval 14.2%; pressure rise error 3.1% < Uval 5.1%) at all 5 operating points. (4) Input uncertainty has been formally propagated via 500-sample LHS ensemble; Sobol analysis identifies tip clearance, flow rate, and hemolysis constant α as dominant contributors, and the sensitivity analysis confirms NIH 95th-percentile predictions remain below the regulatory threshold with factor-of-safety F=1.25 applied. (5) Model form uncertainty from turbulence and hemolysis model selection has been quantified and is within the experimental uncertainty budget. (6) Test samples are CMM-inspected production-representative specimens; experimental conditions are ASTM F1841-compliant with full metrological traceability. (7) The complete provenance chain from raw experimental data through UQ ensemble to validation results is archived and traceable. No shortfalls in achievedLevel relative to requiredLevel exist; no offset rationale is required.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
