  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepts the CFD hemolysis prediction model for regulatory submission under ASME V&V 40 at Model Risk Level 5. All 13 credibility factors have been assessed; all achieve their required credibility levels or above. Key evidence: (1) GCI-based discretization error < 2% at all operating points; (2) NIH predictions within experimental uncertainty band (mean ± 2σ) at all 5 operating points with NRMSE 8.7% and R² 0.974; (3) 500-sample Monte Carlo UQ confirms 95% prediction interval spans ±0.0018 g/100 L against experimental NIH of 0.0042 g/100 L; (4) SST k-ω turbulence model selected after documented comparison with two alternative closures; (5) dual-analyst independent review eliminates use-error risk; (6) SQA plan independently audited March 2025. No credibility factor falls below its required level; no offset rationale is required. The model is fit for purpose for absolute hemolysis index prediction in support of a Class II CPB device regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
