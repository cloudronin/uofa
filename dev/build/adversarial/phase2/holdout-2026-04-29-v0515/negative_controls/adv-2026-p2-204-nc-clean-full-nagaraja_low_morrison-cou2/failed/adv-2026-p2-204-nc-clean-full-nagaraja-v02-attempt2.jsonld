      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-cou1-nse-ac",
        "type": "AcceptanceCriteria",
        "name": "Solver error: iterative convergence residuals < 1e-5 and energy balance error < 0.1%",
        "description": "All implicit FE increments must converge to force and displacement residuals below 1×10⁻⁵ of the reference norm. Global energy balance error must remain below 0.1% across the full gait simulation."
