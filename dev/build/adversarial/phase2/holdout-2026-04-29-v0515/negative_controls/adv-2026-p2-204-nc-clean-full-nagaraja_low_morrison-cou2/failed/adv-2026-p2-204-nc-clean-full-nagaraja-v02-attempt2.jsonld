    "name": "COU1: Total knee replacement tibial insert wear prediction (Class II)",
    "description": "An FE model is used to predict relative polyethylene wear volume in a TKR tibial insert under standard ISO 14243-1 gait loading. Model influence is MODERATE (model informs but does not solely determine regulatory submission); decision consequence is MODERATE (incorrect prediction could lead to under-designed wear resistance but clinical surveillance provides backstop). Model Risk Level 3.",
    "deviceClass": "Class II",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tkr/applicability",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: standard gait loading on cemented TKR tibial inserts",
      "description": "Applicable to cemented total knee replacement tibial inserts fabricated from GUR 1050 UHMWPE under standard ISO 14243-1 gait cycles (0.5–1.2 Hz, 1000 N peak load). Excludes high-flexion activities, revision implants, and cementless fixation designs."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tkr/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ISO 14243-1 gait conditions for TKR wear simulation",
      "description": "Axial load range 300–1200 N; flexion-extension angle 0–60 degrees; AP displacement ±5 mm; IE rotation ±3 degrees; gait cycle frequency 0.5–1.2 Hz; tibial insert thickness 8–12 mm; contact area 200–600 mm²; wear coefficient range 1×10⁻⁷ to 5×10⁻⁷ mm³/(N·mm)."
    }
  },
