  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achieved levels meet or exceed required levels for Model Risk Level 3 (Class II orthopedic device). Software quality assurance (3≥2), discretization error (3≥2), output comparison (3≥2), model form (3≥2), and model inputs (3≥2) demonstrate above-threshold performance. The remaining eight factors all achieve their required level 2. Sensitivity analysis over wear coefficient (±2σ) and contact geometry (±0.1 mm) confirms that predicted wear volume varies by ±22% — within the accepted clinical tolerance band. Monte Carlo UQ (n=10,000 samples) yields a 95% prediction interval that encloses the experimental confidence interval. Provenance chain is complete from raw material test data through simulator experiments to FE validation results. No credibility gaps exist; the package provides sufficient evidence to support regulatory submission for the intended COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
