  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-tkr-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team — computational modelling and V&V lead",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors assessed at MRL 3. Achieved levels meet or exceed required levels for all factors: seven factors achieved Level 3 (exceeding MRL 3 requirement of Level 2), six factors achieved Level 2 (meeting MRL 3 requirement). Primary validation metric NRMSE = 0.061 on cumulative wear volume satisfies acceptance criterion of ≤ 0.10. Contact pressure validation NRMSE = 0.028 satisfies secondary acceptance criterion. Monte Carlo UQ (n=1000) confirms 95% prediction interval encloses experimental mean for both QoIs. Sensitivity analysis identifies UHMWPE elastic modulus as dominant uncertainty driver (±12% wear volume response to ±10% modulus variation); this uncertainty is bounded by lot-specific material testing documented in MI-2024-02. Model form selection (Archard with cross-shear correction) is well-supported by published literature for equivalent loading conditions. Independent peer review of model setup completed per QP-SIM-07. No credibility gaps remain at MRL 3. The credibility evidence is sufficient to support the COU1 decision: use of the FE wear model to rank candidate TKR tibial insert geometries by predicted wear volume prior to physical wear simulator testing. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
