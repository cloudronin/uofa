  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-tkr",
    "type": "ContextOfUse",
    "name": "COU1: Total knee replacement tibial insert wear prediction (Class II)",
    "description": "A finite-element model is used to predict relative polyethylene wear volume of a TKR tibial insert under ISO 14243-1 gait loading over a simulated 5-million-cycle test. Model influence is MEDIUM (model supplements physical wear simulator data); decision consequence is MEDIUM (incorrect prediction could lead to suboptimal design selection but clinical risk is mitigated by subsequent physical testing). Model Risk Level 3.",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "intendedUse": "Use FE wear model to rank candidate tibial insert geometries by predicted wear volume relative to predicate design under standard gait conditions. Results inform design selection prior to physical wear simulator testing.",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-tkr/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: UHMWPE tibial inserts under ISO 14243-1 gait",
      "description": "Model is applicable only to fixed-bearing UHMWPE tibial inserts with conformity ratio between 0.85 and 0.98, loaded under ISO 14243-1 displacement-controlled gait cycle. Mobile-bearing designs, metal-backed inserts with thin polyethylene (<6 mm), and high-flexion activities (>120° flexion) are outside the validated applicability domain."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-tkr/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ISO 14243-1 gait loading bounds",
      "description": "Peak axial compressive force: 2.0–3.0 kN (normalized to 80 kg body weight ±10%). Flexion-extension range: 0–60° per ISO 14243-1. Anterior-posterior displacement: ±5 mm. Internal-external rotation: ±3°. Cycle rate: 1 Hz. UHMWPE yield strength: 20–25 MPa; elastic modulus: 600–1000 MPa (GUR 1020/1050 grades). Cobalt-chrome femoral component surface roughness Ra ≤ 0.05 µm. Sterilization method: gamma irradiation in inert atmosphere only."
    }
  },
  "hasSensitivityAnalysis": true,
