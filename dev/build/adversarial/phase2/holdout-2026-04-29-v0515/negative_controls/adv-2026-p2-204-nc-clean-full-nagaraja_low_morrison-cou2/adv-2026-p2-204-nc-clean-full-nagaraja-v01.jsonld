      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs: Material properties from lot-specific testing; wear coefficient from literature meta-analysis",
        "description": "UHMWPE elastic modulus and yield strength sourced from lot-specific tensile testing (n=5 specimens per lot, GUR 1050 gamma-irradiated). Archard wear coefficient sourced from meta-analysis of 12 published pin-on-disc studies for equivalent UHMWPE grade and surface roughness. CoCr surface roughness measured by profilometry on actual femoral components. Monte Carlo uncertainty propagation performed on all three primary inputs. Achieved Level 3 reflects lot-specific material testing and documented UQ."
      },
      "rationale": "Lot-specific tensile testing provided elastic modulus 812 ± 43 MPa and yield strength 22.1 ± 0.8 MPa (mean ± SD, n=5). Wear coefficient k = 1.2×10⁻⁷ mm³/N·mm (95% CI: 0.9–1.6×10⁻⁷) from meta-analysis. Surface roughness Ra = 0.032 µm measured on three femoral components. All inputs documented in model input report MI-2024-02."
    },
