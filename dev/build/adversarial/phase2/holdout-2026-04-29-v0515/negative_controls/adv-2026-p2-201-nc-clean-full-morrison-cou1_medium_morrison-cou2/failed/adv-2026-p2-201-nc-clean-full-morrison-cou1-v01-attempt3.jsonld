  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed at MRL 5. Each factor achieves a level meeting or exceeding the required level: discretization error and numerical solver error exceed requirements by one gradation. Monte Carlo UQ (500-run ensemble) quantifies total hemolysis prediction uncertainty at ±14% (U95), within the ±15% acceptance criterion. Sensitivity analysis confirms model form (turbulence model selection) is the dominant uncertainty contributor (38% of output variance), followed by hemolysis model coefficients (27%) and blood viscosity (18%). Grid convergence index of 0.8% demonstrates negligible discretization error. Independent review of simulation setup and post-processing eliminates use-error concerns. The validation evidence — conducted on the identical FDA generic pump geometry across all five COU operating points with bovine blood — is directly relevant to the COU. On the basis of complete, consistent, and well-documented credibility evidence across all 13 factors, the CFD model is accepted for predicting absolute hemolysis levels for Class III VAD regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
