  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 5. Every factor achieves a level meeting or exceeding its required level: seven factors at Gradation 4 (required 4), three factors at Gradation 3 (required 3), one factor at Gradation 5 (required 4), one factor at Gradation 4 (required 3), and one factor at Gradation 4 (required 4). Monte Carlo uncertainty quantification (2000 LHS samples) confirms that CFD-predicted hemolysis index is below the absolute clinical threshold at all five operating points with 95% confidence. Sensitivity analysis demonstrates that flow rate and zero-shear viscosity are the dominant uncertainty drivers; both are well-characterized from experimental data. PIV velocity validation and in-vitro hemolysis validation provide direct experimental support for model form and output comparison factors. The complete provenance chain from raw experimental data through surrogate model construction to final hemolysis prediction is documented and archived. No credibility gaps remain. The model is accepted as fit for purpose for predicting absolute hemolysis levels in the Class III VAD COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
