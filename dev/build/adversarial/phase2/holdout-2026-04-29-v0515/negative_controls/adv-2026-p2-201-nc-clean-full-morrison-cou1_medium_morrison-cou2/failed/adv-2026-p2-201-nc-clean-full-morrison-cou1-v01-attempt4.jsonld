  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed at MRL 5 for the Class III VAD COU. Every factor achieves its required gradation level or higher: output comparison exceeds requirements (Gradation 5 vs required 4); all verification factors (SQA, NCV, discretization error, numerical solver error) meet or exceed Gradation 4; all validation relevance and model-form factors meet Gradation 4; use error and test samples meet Gradation 3 as required. Monte Carlo UQ (1000-sample LHS) and sensitivity analysis are documented. No factor shortfalls exist. The credibility body of evidence is sufficient to support the claim that the CFD model predicts absolute hemolysis index within clinically acceptable bounds for the defined operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
