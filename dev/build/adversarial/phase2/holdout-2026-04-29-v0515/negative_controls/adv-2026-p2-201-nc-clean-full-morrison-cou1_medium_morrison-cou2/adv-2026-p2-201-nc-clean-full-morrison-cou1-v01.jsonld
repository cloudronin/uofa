  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 5 for the Class III VAD hemolysis COU. Every factor achieves a level meeting or exceeding the required level: discretization error (5 ≥ 4), numerical code verification (4 ≥ 4), software QA (4 ≥ 4), test conditions (4 ≥ 4), output comparison (4 ≥ 4), QoI relevance (4 ≥ 4), validation activity relevance (4 ≥ 4), numerical solver error (4 ≥ 3), use error (3 ≥ 3), model form (4 ≥ 4), model inputs (4 ≥ 4), test samples (3 ≥ 3), and equivalency of input parameters (4 ≥ 4). Monte Carlo uncertainty quantification (2 000 runs) demonstrates that NIH predictions remain below the ISO 10993-4 clinical threshold at 95th percentile across the full operating envelope. Sensitivity analysis confirms the Giersiepen–Wurzinger coefficient α as the dominant uncertainty driver; targeted calibration has reduced its contribution to within acceptance bounds. The complete provenance chain from raw experimental data through simulation logs to the credibility assessment is documented and independently reviewed. No offset rationale is required; no credibility gaps remain. The assessment team concludes that the CFD model provides adequate credibility for regulatory submission supporting absolute hemolysis acceptance for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
