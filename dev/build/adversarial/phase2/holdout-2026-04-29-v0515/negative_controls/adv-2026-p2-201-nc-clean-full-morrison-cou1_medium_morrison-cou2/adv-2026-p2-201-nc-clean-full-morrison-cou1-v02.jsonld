  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed with achieved levels meeting or exceeding required levels at Model Risk Level 5. Software QA (4/4), numerical code verification (4/4), discretization error (5/4), test conditions (4/3), output comparison (4/4), QoI relevance (4/4), validation activity relevance (4/4), numerical solver error (3/3), use error (3/3), model form (4/4), model inputs (4/4), test samples (3/3), and equivalency of input parameters (4/4) are all satisfied. Monte Carlo uncertainty quantification (N=5000 LHS) confirms that the 95th-percentile NIH prediction remains below the clinical threshold of 0.01 g/100 L at all five operating points. Sensitivity analysis identifies hemolysis correlation coefficients and inlet shear stress as dominant uncertainty drivers, and demonstrates that the model is not critically sensitive to any single input within the validated operating envelope. The complete provenance chain from foundational FDA bench measurements through validated CFD predictions is documented. The assessment team unanimously accepts this package as sufficient credibility evidence for the COU2 regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
