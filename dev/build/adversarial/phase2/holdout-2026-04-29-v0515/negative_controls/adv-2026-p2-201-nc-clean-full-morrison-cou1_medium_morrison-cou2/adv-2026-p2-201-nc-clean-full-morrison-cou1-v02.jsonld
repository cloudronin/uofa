      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria",
        "description": "All model input parameters (fluid properties, boundary conditions, hemolysis correlation coefficients) must be traceable to measured data or peer-reviewed literature with documented uncertainty ranges. Monte Carlo UQ must propagate input uncertainties through the model."
