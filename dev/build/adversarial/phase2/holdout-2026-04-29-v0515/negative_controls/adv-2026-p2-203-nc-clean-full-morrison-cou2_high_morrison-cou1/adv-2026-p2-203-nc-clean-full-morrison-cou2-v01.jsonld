  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The UofA for Morrison COU1 at MRL 5 is accepted on the basis of a fully assessed 13-factor credibility evaluation. All 13 factors achieved their required level (Gradation 4 or above): Software QA (4/4), Numerical Code Verification (5/4), Discretization Error (4/4), Test Conditions (4/4), Output Comparison (4/4), Relevance of QoI (5/4), Relevance of Validation Activities (4/4), Numerical Solver Error (4/4), Use Error (4/4), Model Form (4/4), Model Inputs (5/4), Test Samples (4/4), and Equivalency of Input Parameters (4/4). No factor fell below its required level; therefore no offset rationale is required. Validation error on the primary QoI (NIH) ranged 4.2–12.8% across all five COU operating points, within the pre-specified 15% acceptance threshold. Monte Carlo uncertainty propagation (n=1000 LHS samples) confirmed NIH 95% CI ±6.2% at worst case. Sensitivity analysis identified impeller tip clearance and rotational speed as dominant contributors to NIH variability (combined Sobol index 0.71). The provenance chain is complete from raw experimental data through GLP-witnessed protocols to archived simulation outputs. The assessment team concludes that the model is sufficiently credible to support the intended regulatory decision (worst-case hemolysis operating condition identification for a Class II CPB device).",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
