  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-osel-dbad",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The 13-factor ASME V&V 40 credibility assessment for the FDA generic centrifugal blood pump CFD model at MRL 2 / Class II CPB use is accepted. Seven factors are formally assessed: Software quality assurance (achieved 2 ≥ required 2), Numerical code verification (achieved 2 ≥ required 1), Discretization error (achieved 2 ≥ required 2), Test conditions (achieved 2 ≥ required 2), Output comparison (achieved 2 ≥ required 2), Relevance of QoIs (achieved 2 ≥ required 2), and Relevance of validation activities to the COU (achieved 2 ≥ required 2). All seven assessed factors meet or exceed their required gradation levels; no shortfall exists and no offset rationale is needed. Six factors (Numerical solver error, Use error, Model form, Model inputs, Test samples, Equivalency of input parameters) are scoped out with documented rationale consistent with the MRL 2 credibility table in ASME V&V 40-2018. Validation results demonstrate CFD-predicted relative hemolysis index within 8.3% of bench measurements across all five CPB operating points, and PIV velocity RMSE of 0.031 m/s. The model satisfies the RH < 1 acceptance criterion at all operating points. The provenance chain is complete from foundational experimental data (FDA GCBP PIV and bench hemolysis datasets) through validation activities to this assurance package. The overall evidence base supports Medium assurance at MRL 2 for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
