      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria — MRL 2",
        "description": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity, temperature) match CFD inputs within stated measurement uncertainty for all 5 operating points."
      },
      "rationale": "Bench test conditions for the five CPB operating points (2.5–5.0 L/min, 2000–3500 rpm) are fully documented in lab notebook LN-GCBP-2024. Fluid temperature held at 37 ± 0.5 °C; viscosity of porcine blood surrogate (glycerol–water) measured at each test point. CFD boundary conditions reproduce experimental values within combined measurement uncertainty. Correspondence verified in test-condition mapping table TCM-01."
    },
    {
      "id": "https://uofa.net/morrison/factor/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria — MRL 2",
        "description": "Predicted relative hemolysis index RH within ±15% of bench-measured value at all 5 operating points; velocity field RMSE < 0.05 m/s against PIV data."
      },
      "rationale": "CFD-predicted RH values range from 0.61 to 0.89 across the five operating points; bench-measured values range from 0.58 to 0.92. Maximum absolute error is 8.3%, well within the ±15% acceptance band. PIV velocity RMSE is 0.031 m/s. Both metrics satisfy Gradation 2 output-comparison requirements. Detailed comparison tables and Bland–Altman plots are in validation report VR-GCBP-2024-01."
    },
    {
      "id": "https://uofa.net/morrison/factor/qoi-relevance",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/qoi-relevance",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criteria — MRL 2",
        "description": "The normalised hemolysis index (NIH) and relative hemolysis index (RH) are the primary QoIs; both are directly linked to the regulatory submission metric and clinical endpoint."
      },
      "rationale": "The normalised index of hemolysis (NIH) and relative hemolysis index (RH < 1 criterion) are the quantities required by FDA guidance for blood-contacting device submissions (FDA 2017 hemolysis guidance). These QoIs directly map to the clinical endpoint (red-blood-cell destruction) and to the regulatory acceptance criterion. No surrogate or proxy quantity is used. QoI traceability documented in requirements matrix RM-GCBP-001."
    },
    {
      "id": "https://uofa.net/morrison/factor/val-relevance",
      "type": "CredibilityFactor",
