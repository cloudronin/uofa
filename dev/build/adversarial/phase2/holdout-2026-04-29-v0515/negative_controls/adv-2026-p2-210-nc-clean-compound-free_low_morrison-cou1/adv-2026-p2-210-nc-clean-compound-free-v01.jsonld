      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/relevance-validation-001",
        "type": "AcceptanceCriteria",
        "name": "Validation activities conducted on the same device geometry and operating range as the COU",
        "description": "Validation experiments must use the same FDA generic centrifugal pump geometry and span the same flow rate and rotational speed range as the intended COU operating envelope."
      },
      "rationale": "Validation experiments were performed on the identical FDA generic centrifugal blood pump geometry used in the COU simulations. The experimental operating range (2–6 L/min, 2000–3500 RPM) fully encompasses the COU operating envelope. Blood analog fluid properties match those used in the computational model. The validation activities are therefore directly relevant to the COU with no extrapolation required."
    },
    {
      "id": "https://uofa.net/synth/factor/numerical-solver-error-001",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "At MRL 2, numerical solver error is addressed through the software quality assurance and numerical code verification factors. Separate quantification of iterative solver error is not required at this model risk level. Residuals were monitored to convergence (< 1e-5 for all equations) as a standard practice, but formal solver error budgeting is scoped out per the ASME V&V 40 MRL 2 credibility table."
    },
    {
