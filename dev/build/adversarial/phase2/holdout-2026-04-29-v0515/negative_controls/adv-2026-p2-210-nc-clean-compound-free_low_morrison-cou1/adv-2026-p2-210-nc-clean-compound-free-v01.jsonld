  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the FDA generic centrifugal blood pump CFD hemolysis model under CPB conditions (COU1) is accepted at Medium assurance level. Seven of thirteen ASME V&V 40 credibility factors were formally assessed; all seven achieved levels meeting or exceeding their required levels at MRL 2 (Software QA: 2/2, Code Verification: 2/2, Discretization Error: 3/2, Test Conditions: 2/2, Output Comparison: 2/2, QoI Relevance: 2/2, Validation Relevance: 2/2). The remaining six factors were appropriately scoped out per the MRL 2 credibility requirements in ASME V&V 40 Table 3, with documented rationale for each. The primary QoI (relative hemolysis index) was predicted within 11.3% of experimental measurements across all five operating points, satisfying the ±15% acceptance criterion. Grid convergence was demonstrated with GCI of 2.1%. The validation activities were conducted on the identical device geometry and operating envelope as the COU, eliminating extrapolation uncertainty. No factor shortfalls exist; no offset rationale is required. The structured evidence base supports the claim that the CFD model can reliably identify worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
