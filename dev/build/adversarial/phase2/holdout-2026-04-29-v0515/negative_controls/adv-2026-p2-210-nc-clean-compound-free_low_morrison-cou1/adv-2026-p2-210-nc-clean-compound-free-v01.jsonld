      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/test-conditions-001",
        "type": "AcceptanceCriteria",
        "name": "Experimental test conditions documented and traceable",
        "description": "All experimental boundary conditions (flow rate, rotational speed, fluid properties) are documented in the test protocol and traceable to calibrated instrumentation."
      },
      "rationale": "The experimental validation dataset was collected under controlled laboratory conditions with calibrated flow meters (±1% accuracy) and torque sensors (±0.5%). Fluid properties (bovine blood analog, 37°C, viscosity 3.5 cP) are documented in the test protocol. All five operating points used in the CFD study are represented in the experimental dataset."
    },
    {
      "id": "https://uofa.net/synth/factor/output-comparison-001",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/output-comparison-001",
        "type": "AcceptanceCriteria",
        "name": "RH index within 15% of experimental mean across all 5 operating points",
        "description": "The relative hemolysis index predicted by CFD must fall within 15% of the experimental mean at each of the 5 operating points to be considered a passing comparison."
      },
      "rationale": "CFD-predicted relative hemolysis index values were compared against experimental measurements at all 5 operating points. Maximum deviation was 11.3% at the highest flow-speed combination, with a mean deviation of 6.7%. All points satisfy the ±15% acceptance criterion. Uncertainty quantification via Monte Carlo propagation of inlet boundary condition uncertainty yielded 95% confidence intervals that encompass experimental measurements at all operating points."
    },
    {
      "id": "https://uofa.net/synth/factor/relevance-qoi-001",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/relevance-qoi-001",
        "type": "AcceptanceCriteria",
        "name": "QoI (RH index) directly linked to clinical hemolysis endpoint",
        "description": "The relative hemolysis index must be demonstrably linked to clinically relevant plasma-free hemoglobin levels through a validated power-law damage accumulation model."
      },
      "rationale": "The primary QoI — relative hemolysis index (RH) — is computed from the Giersiepen-Wurzinger power-law model applied to the Lagrangian particle stress history. RH < 1 relative to the predicate device is the regulatory acceptance criterion for Class II CPB devices. The QoI is directly relevant to the clinical endpoint of plasma-free hemoglobin elevation and is the standard metric used in FDA guidance for blood-contacting device CFD submissions."
    },
    {
      "id": "https://uofa.net/synth/factor/relevance-validation-001",
      "type": "CredibilityFactor",
