    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB centrifugal pump operating envelope — bounded flow and speed",
      "description": "Flow rate: 1.0–7.0 L/min (five discrete test points: 1.5, 2.5, 3.5, 5.0, 6.5 L/min). Rotational speed: 1500–3500 RPM (three nominal speeds: 1750, 2500, 3250 RPM). Inlet pressure: 0–20 mmHg. Outlet back-pressure: 40–120 mmHg. Blood viscosity: 0.0035–0.0045 Pa·s (37 °C, hematocrit 35–45%). Impeller gap tolerance: ±0.05 mm on five geometric variants. Fluid temperature: 35–38 °C. All CFD simulations and experimental comparisons are constrained to this envelope; extrapolation beyond these bounds is explicitly out of scope."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB device applicability constraint — Class II centrifugal pumps",
      "description": "Applicable to centrifugal blood pumps of the FDA generic pump geometry family (impeller diameter 40–60 mm, volute design consistent with the 2012 FDA benchmark geometry) used exclusively in adult CPB circuits. Excludes pediatric applications (body surface area < 1.0 m²), ventricular assist device (VAD) configurations, and axial-flow pump geometries. Hemolysis model (power-law Giersiepen–Wurzinger formulation) is applicable only within the shear-stress range 1–700 Pa and exposure times 0.001–1.0 s, consistent with the declared operating envelope."
    }
