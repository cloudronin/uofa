  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis worst-case identification, Class II, MRL 2) is accepted based on the following structured evidence: (1) All seven assessed CredibilityFactors meet or exceed their required levels — no shortfalls exist. (2) The operating envelope is explicitly bounded (flow 1–7 L/min, speed 1500–3500 RPM, hematocrit 35–45%, tip clearance ±0.05 mm) and the applicability constraint restricts scope to adult normothermic/mild-hypothermic CPB with Newtonian rheology above 100 s⁻¹ shear rate. (3) Validation results VR-01 through VR-03 collectively demonstrate NIH agreement within ±18% (mean 9.3%), pressure-head agreement within 4.1%, and GCI of 3.2% — all satisfying their acceptance criteria. (4) The single coverage gap (7 L/min, 3500 RPM corner point lacking experimental data) is documented, uncertainty-quantified, and accepted on the basis of conservative RH margins at the four adjacent validated points. (5) Six factors are scoped-out or not-applicable with documented rationale consistent with MRL 2 requirements for a Class II device. (6) The provenance chain is complete: simulation outputs traceable to archived dataset IRIs, validation comparisons traceable to the FDA GCBP 2013 experimental dataset (DOI: 10.1115/1.4034998), and all scripts under version control. No offset rationale is required as no assessed factor falls below its required level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
