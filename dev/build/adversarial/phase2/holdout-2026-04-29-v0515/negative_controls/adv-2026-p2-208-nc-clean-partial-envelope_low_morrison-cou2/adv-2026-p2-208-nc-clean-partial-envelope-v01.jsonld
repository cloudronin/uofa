  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/dr-patricia-morrison",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors assessed at MRL 5 for a Class III VAD device. Every factor achieves its required credibility level: four factors at Gradation 4 (Discretization error, Output comparison, Relevance of validation activities to COU, Model form, Model inputs) and the remaining nine at Gradation 3. No factor falls below its required level. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 2 000–4 500 RPM, hematocrit 35–45 %, temperature 36–38 °C, pressure 60–120 mmHg) and the 25-point validation dataset provides 88 % envelope coverage. Monte Carlo UQ (1 000 LHS samples) quantifies prediction uncertainty; 95 % prediction intervals reported for all QoI. Independent analyst reproduction confirms use-error control. The structured evidence chain — from foundational code verification through PIV validation to Monte Carlo UQ — supports the claim that the CFD model predicts absolute hemolysis index within 15 % error across the declared envelope. The credibility body of evidence is sufficient to accept the model for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
