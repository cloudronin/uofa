  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-mrl5-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at the rigor levels required for MRL 5. No factor achievedLevel falls below its requiredLevel. Key evidence: (1) GCI < 1% on production mesh confirms negligible discretization error; (2) MAPE 3.2% and normalised index of agreement 0.97 across all 5 operating points demonstrate strong predictive accuracy; (3) Monte Carlo UQ ensemble (N=2000) with Sobol sensitivity analysis identifies impeller tip clearance and rotational speed as dominant uncertainty drivers, with 95th-percentile RH = 0.87 remaining below the acceptance threshold of RH < 1; (4) SST k-ω turbulence model selected after comparative validation; model form uncertainty ±8% incorporated into UQ bounds; (5) Independent analyst review, NIST-traceable instrumentation, and ISO 9001:2015 SQA provide high confidence in simulation fidelity. The complete provenance chain from raw experimental data through mesh convergence, UQ ensemble, and output comparison is archived and traceable. The credibility evidence collectively supports the claim that the CFD model can reliably identify worst-case hemolysis operating conditions for the Class II CPB device at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
