      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/cf-08-se-ac",
        "type": "AcceptanceCriteria",
        "name": "Iterative convergence to 1e-7; round-off error negligible relative to discretization error",
        "description": "All solution residuals must converge to 1e-7 or below. Round-off error estimated via double vs. quad precision comparison must be at least one order of magnitude below GCI-estimated discretization error."
      },
      "rationale": "All production runs converged to 1e-7 on continuity, momentum, and scalar transport residuals. Double vs. quad precision comparison on representative operating point shows round-off contribution 0.003% vs. GCI 1.4% — ratio 0.002, well below 0.1 threshold. Solver error negligible."
    },
