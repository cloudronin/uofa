      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/cf-11-mi-ac",
        "type": "AcceptanceCriteria",
        "name": "All material and geometric inputs characterized with uncertainty; 95th-percentile NIH within acceptance band",
        "description": "Fluid viscosity, density, hemolysis model coefficients, and geometry tolerances must each be characterized with documented uncertainty distributions. Monte Carlo propagation (N≥1000) must show 95th-percentile NIH prediction remains within the RH < 1 acceptance band."
      },
      "rationale": "Viscosity: 3.5±0.2 mPa·s (log-normal, CV 5.7%); density: 1055±5 kg/m³ (normal); hemolysis coefficients: literature-derived distributions from 8 published datasets. Geometry: ±0.15 mm uniform on all wetted surfaces. Monte Carlo N=2000: 95th-percentile NIH 0.0048 mg/100L; RH 0.87 < 1.0. Acceptance criterion met with 13% margin."
    },
