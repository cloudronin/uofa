  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5 rigor; all 13 achieve requiredLevel 5 with achievedLevel 5. Discretization error (GCI 1.4%) and solver error are negligible relative to model form uncertainty (4.2% NIH). Monte Carlo UQ (N=2000) demonstrates 95th-percentile NIH yields RH=0.87, providing a 13% margin against the RH<1 acceptance criterion. Independent reproduction by a second analyst confirms use error is negligible (< 0.6% NIH deviation). Validation experiments conducted on the same geometry and operating envelope as the COU with dynamic similarity confirmed (Re, Stk, Eu all within 5%). No factor shortfalls; no offset rationale required. The totality of structured evidence supports the conclusion that the CFD model is sufficiently credible to identify worst-case hemolysis operating conditions for the Class II CPB device at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
