  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA model ensemble is accepted as credible for predicting ASTM F1717 static compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct. Eleven of thirteen V&V 40 credibility factors are assessed at or above required level; two factors (Numerical solver error, Use error) are scoped out with documented technical rationale. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3; this shortfall is addressed in the offset rationale below. All three QoIs satisfy both the E/uval < 1.96 and <10% percent-difference acceptance criteria. The provenance chain is complete from foundational material data through bench testing to FEA outputs. The credibility assessment team unanimously recommends acceptance for the stated COU.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/nagaraja-cou1-tc-offset",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs. required 3)",
        "description": "The Test conditions factor achieved Gradation 2 (single standardized loading condition) against a required Gradation 3. This shortfall is accepted on the following grounds: (1) The COU is explicitly scoped to ASTM F1717 static compression-bending prediction; no claim is made regarding torsional, fatigue, or combined-loading performance. The single test condition is therefore sufficient to validate the model within the declared COU boundary. (2) ASTM F1717 is the FDA-accepted standard protocol for pedicle screw regulatory submissions; testing under this single condition is the regulatory norm and is not a limitation relative to the submission requirement. (3) All three QoIs pass both quantitative acceptance criteria (E/uval < 1.96 and <10% difference) under this condition, providing strong evidence of model fidelity within the scoped regime. (4) The two-laboratory design partially compensates for the single-condition limitation by demonstrating that the model is not tuned to a single test environment. The credibility assessment team judges that the combination of factors (2), (3), and (4) adequately offsets the Gradation 2 achievement for this factor within the stated COU."
      },
      {
        "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted/offset/nagaraja-cou1-tc",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/factor/nagaraja-cou1-tc",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
