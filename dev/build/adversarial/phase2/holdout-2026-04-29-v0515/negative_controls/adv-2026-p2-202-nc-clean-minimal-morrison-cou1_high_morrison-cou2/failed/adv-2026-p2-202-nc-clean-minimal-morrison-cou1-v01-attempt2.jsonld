  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/morrison/cou2/factor/software-qa",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac/software-qa",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criteria — MRL 5 CFD solver",
        "description": "CFD solver must be under version control with documented regression test suite covering turbulence and transport models relevant to hemolysis prediction. Test coverage ≥ 95% of critical code paths. All known defects affecting hemolysis QoI must be resolved or formally waived."
      },
      "rationale": "The commercial CFD solver (ANSYS Fluent 2023 R2) is under formal SQA per ISO 9001:2015. Regression test suite covers 312 benchmark cases including rotating machinery and non-Newtonian transport. All open defect reports affecting the hemolysis scalar transport module were reviewed; zero unresolved critical defects identified. Achieved Gradation 4 per ASME V&V 40 Table 5."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/numerical-code-verification",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac/numerical-code-verification",
        "type": "AcceptanceCriteria",
        "name": "Code verification acceptance criteria — manufactured solution",
        "description": "Method of manufactured solutions (MMS) applied to the hemolysis power-law transport equation. Observed order of accuracy must be within 10% of formal order. Residuals must converge to machine precision on at least one verification case."
      },
      "rationale": "MMS verification performed on the Giersiepen–Wurzinger hemolysis transport model implemented in the CFD solver. Observed spatial order of accuracy: 1.93 (formal: 2.0), within tolerance. Temporal order: 1.98. Residuals converge to 1e-12. Achieved Gradation 4."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/discretization-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac/discretization-error",
        "type": "AcceptanceCriteria",
        "name": "GCI-based discretization error acceptance — hemolysis index QoI",
        "description": "Richardson extrapolation / GCI analysis performed on three systematically refined meshes (coarse ~3M, medium ~9M, fine ~27M cells). GCI on hemolysis index must be < 5% at all 5 operating points. Grid convergence index must be reported with safety factor 1.25."
      },
      "rationale": "Three-level mesh refinement study conducted at all 5 VAD operating points. Maximum GCI across all points: 1.87% (at 6000 RPM, 5 L/min). All points satisfy < 5% threshold. Asymptotic range check confirmed (ratio 0.98–1.02). Achieved Gradation 4."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/test-conditions",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Experimental test condition fidelity acceptance criteria",
        "description": "Experimental hemolysis measurements must be conducted in a closed-loop flow circuit with bovine blood (hematocrit 33 ± 2%), temperature controlled at 37 ± 0.5°C, and priming volume ≥ 500 mL. Operating points must match CFD boundary conditions within ±2% on flow rate and ±50 RPM on rotational speed."
      },
      "rationale": "FDA benchmark experimental data acquired under controlled conditions: bovine blood at 33% hematocrit, 37°C, closed-loop circuit. Flow rate match: all 5 points within ±1.1%. Speed match: all within ±30 RPM. Temperature stability: ±0.3°C. Achieved Gradation 4."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Hemolysis index output comparison acceptance — absolute prediction error",
        "description": "Mean absolute percentage error (MAPE) on normalized index of hemolysis (NIH) must be ≤ 25% across all 5 operating points when compared to experimental measurements. Uncertainty intervals from Monte Carlo UQ must overlap experimental uncertainty bands at ≥ 4 of 5 points."
      },
      "rationale": "MAPE on NIH across 5 operating points: 14.3% (range 7.1%–21.8%). Monte Carlo 95% CI overlaps experimental uncertainty band at all 5 points. Systematic over-prediction of 8% at highest flow rate is within accepted model form uncertainty. Achieved Gradation 4."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/relevance-qoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac/relevance-qoi",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance — hemolysis index clinical linkage",
        "description": "The primary QoI (NIH, g/100L) must be directly linked to the clinical endpoint (chronic hemolysis risk). A documented mapping from NIH to clinical hemolysis threshold (plasma free hemoglobin > 50 mg/dL) must be present in the evidence package."
      },
      "rationale": "NIH is the FDA-recognized surrogate for chronic hemolysis risk in VAD devices. Clinical mapping documented per ASTM F1841-97 (reapproved 2017): NIH < 0.005 g/100L corresponds to clinically acceptable plasma free hemoglobin levels. QoI directly actionable for regulatory submission. Achieved Gradation 3."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/relevance-validation-activities",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac/relevance-validation-activities",
        "type": "AcceptanceCriteria",
        "name": "Validation activity relevance acceptance — COU2 VAD conditions",
        "description": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump) and cover at least 4 of the 5 COU operating points. Blood analogue or bovine blood must be used. Geometric and dynamic similarity must be documented."
      },
      "rationale": "Validation activities used the identical FDA generic centrifugal pump geometry. All 5 COU operating points covered in the experimental campaign. Bovine blood used (consistent with COU). Reynolds number and specific speed similarity confirmed. Achieved Gradation 3."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/numerical-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Numerical solver error is subsumed by the Numerical Code Verification factor for this assessment. The MMS verification directly bounds solver implementation error for the hemolysis transport equation. Separate solver error quantification would be redundant and is therefore scoped out per Morrison COU2 assessment plan, Section 4.2."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/use-error",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Use error is scoped out because the CFD analyses are performed by a single, dedicated simulation team operating under a documented simulation governance plan (SGP-2024-VAD-001). The SGP mandates peer review of all boundary condition inputs and mesh generation decisions. Independent use error assessment is therefore not warranted at this stage of the assessment."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/model-form",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Model form uncertainty for the hemolysis power-law model (Giersiepen–Wurzinger) is acknowledged as a known epistemic gap at MRL 5 but is scoped out of the quantitative credibility factor assessment because no validated alternative hemolysis model exists for this geometry at these operating conditions. The output comparison factor implicitly captures model form error through the MAPE metric. Formal model form assessment deferred to future work with Arora–Bludszuweit model comparison."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/model-inputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model input uncertainty acceptance — blood rheology and pump geometry",
        "description": "All model inputs with sensitivity index > 0.05 (Sobol first-order) must have documented probability distributions derived from measurement data or literature. Blood viscosity, density, and hemolysis model constants must be included. Geometric tolerances on pump dimensions must be characterized."
      },
      "rationale": "Monte Carlo UQ (N=2000 samples, Latin hypercube sampling) propagated uncertainty in: blood viscosity (CV 4.2%), hemolysis model exponent α (CV 8.1%), hemolysis model constant C (CV 12.3%), and pump clearance gap (±0.05 mm). Sobol indices computed; all inputs with Si > 0.05 have documented distributions from peer-reviewed sources. Achieved Gradation 4."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/test-samples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Test samples factor is scoped out because the validation dataset uses a single blood source (pooled bovine blood, single vendor) and inter-sample variability is captured within the experimental uncertainty bounds reported in the FDA benchmark dataset. A formal test sample variability study across multiple blood sources is deferred to the Phase II device-specific validation campaign."
    },
    {
      "id": "https://uofa.net/morrison/cou2/factor/equivalency-input-parameters",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters is scoped out because the validation experiment and the COU use identical pump geometry, identical blood type (bovine), and identical operating point definitions. No parameter translation or equivalency mapping is required. This factor is not applicable when the validation scenario is a direct analogue of the COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision/accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven actively assessed credibility factors achieve their required credibility levels (Gradations 3–4 as appropriate for MRL 5). Monte Carlo UQ (N=2000) demonstrates that 95% confidence intervals on NIH overlap experimental uncertainty bands at all 5 VAD operating points. MAPE of 14.3% is well within the 25% acceptance threshold. The six scoped-out factors are each accompanied by documented rationale explaining why they do not represent unmitigated gaps: numerical solver error is bounded by MMS verification; use error is controlled by the simulation governance plan; model form error is captured implicitly in the output comparison metric; test sample variability is within FDA benchmark experimental uncertainty; and equivalency of input parameters is not required given direct analogue validation conditions. The provenance chain from raw experimental data through mesh convergence, UQ propagation, and output comparison is complete and traceable. The assessment team concludes that the evidence base is sufficient to support regulatory submission of the CFD hemolysis prediction for this Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
