  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-vv40-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achieve or exceed their required credibility levels for Model Risk Level 5. Software quality assurance (4/4), numerical code verification (4/4), discretization error (5/4 — exceeds requirement), test conditions (4/4), output comparison (4/4), QoI relevance (3/3), validation activity relevance (4/4), numerical solver error (4/4), use error (3/3), model form (4/4), model inputs (4/4), test samples (3/3), and equivalency of input parameters (4/4) are all satisfied. Monte Carlo UQ with 2000 samples propagates all 8 identified uncertain inputs; NIH predictions fall within 2σ experimental bounds at all five operating points. GCI < 2% on all mesh levels. The complete provenance chain from raw experimental measurements through CFD execution to validation results is documented. The credibility evidence base is sufficient to support the claim that the CFD model can reliably predict absolute hemolysis levels for a Class III VAD device within the defined operating envelope. The package is accepted without offset rationale as no shortfalls exist.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
