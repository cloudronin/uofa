  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at Model Risk Level 5. Achieved levels meet or exceed required levels across every factor: 11 factors achieve exactly their required level (levels 3–4), and two factors (Relevance of QoI) exceed the required level (achieved 5 vs required 4). Monte Carlo uncertainty quantification (1000-sample LHS) documents NIH prediction uncertainty at ±12% (95th percentile CI), which is within the clinical decision margin. The validation evidence base — PIV velocity comparisons and bench hemolysis measurements across all five COU operating points — is complete and traceable to NIST-calibrated instrumentation. Software quality assurance, numerical code verification, and discretization error controls are all at level 4, providing high confidence in numerical fidelity. The parameter equivalency matrix confirms that CFD-to-experiment input alignment is within tolerance at all operating points. No credibility gaps remain. The model is accepted as sufficiently credible to support the Class III VAD hemolysis submission claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
