  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as sufficiently credible for its intended use in regulatory decision-making. Twelve of 13 V&V 40 credibility factors meet or exceed their required gradation levels: Software QA (3≥2), Numerical code verification (2≥2), Discretization error (3≥3), Numerical solver error (2≥2), Use error (3≥2), Model form (3≥3), Model inputs (3≥3), Test samples (3≥3), Equivalency of inputs (3≥3), Output comparison (4≥3), Relevance of QoIs (3≥3), Relevance of validation activities (3≥3). The single shortfall — Test conditions (achieved 2, required 3) — is addressed by the OffsetRationale below. All three primary QoIs satisfy the pre-specified quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%). The provenance chain is complete from raw experimental data through FEA ensemble predictions to the validation metric computation. Uncertainty quantification via Monte Carlo and Latin hypercube sampling has been performed for all QoIs. The sensitivity analysis confirms that material property uncertainty and geometric tolerances are the dominant drivers of prediction variability, and that the model response is well-characterized within the operating envelope. The overall evidence base is sufficient to support the claim that the FEA framework reliably predicts ASTM F1717 static compression-bending performance for this device design.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
      "justification": "The Test conditions factor achieved Gradation 2 (single ASTM F1717 configuration) against a required Gradation 3 (two or more distinct loading configurations). This shortfall is accepted for the following reasons: (1) ASTM F1717 is the sole regulatory-recognized test standard for pedicle screw construct mechanical performance, and the single configuration tested represents the worst-case bending scenario mandated by the standard; (2) the high quantitative agreement between FEA and experiment across all three QoIs (E/uval range 1.42–1.78, all well below 1.96) demonstrates robust model performance under the tested condition; (3) a parametric sensitivity analysis varying span length (35–45 mm) and UHMWPE block modulus (±20%) showed that FEA predictions scale consistently with experimental trends, providing indirect evidence of model validity across a limited configuration space; (4) the device's clinical use is dominated by the compression-bending loading mode captured by F1717, and the model risk level (3) and decision consequence (Medium) do not mandate multi-configuration validation for this COU. The residual risk from the single-condition limitation is judged acceptable given the totality of the evidence."
    }
