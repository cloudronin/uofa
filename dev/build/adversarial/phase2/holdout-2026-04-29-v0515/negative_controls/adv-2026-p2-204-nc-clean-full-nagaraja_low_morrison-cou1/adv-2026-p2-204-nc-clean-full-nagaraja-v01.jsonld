  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-orthopedic-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-review-board",
    "role": "Credibility assessment review board",
    "outcome": "Accepted",
    "rationale": "The COU1 credibility assessment for CFD-based wear-particle transport prediction in the tibial tray TKR application is accepted at Model Risk Level 3 under the Complete profile. All 12 assessed CredibilityFactors meet or exceed their required levels: Discretization Error and Numerical Solver Error both achieved one level above requirement, providing additional confidence margin. The Test Samples factor is appropriately scoped out with documented rationale and deferred to COU2. Three independent validation datasets (µPIV accumulation index, contact pressure, velocity profiles) all satisfy quantitative acceptance criteria with E_n < 1.0. Monte Carlo uncertainty propagation (N=2000) confirms the 95% CI on RAI [0.92, 1.08] remains below the clinical threshold of 1.15 across the full operating envelope. Sensitivity analysis demonstrates robustness of conclusions to ±20% variation in synovial viscosity and ±15% variation in particle size distribution. The provenance chain is complete: experimental data traceable to ISO 14243-3 and NIST-calibrated instrumentation, simulation scripts under version control, and all post-processing documented in SOP-CFD-TKR-001 Rev B. The credibility review board unanimously concludes that the computational model provides sufficient evidence to support the design decision regarding worst-case hemolysis-analog (wear-particle accumulation) operating conditions for the Class II tibial tray device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
