      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-cou1-mi-ac",
        "type": "AcceptanceCriteria",
        "name": "Model inputs Level 3 — all critical inputs characterized with uncertainty quantification",
        "description": "All inputs with sensitivity index Si > 0.05 (Sobol first-order) must be characterized with probability distributions derived from experimental data or published literature. Input uncertainty must be propagated to output uncertainty via Monte Carlo sampling (N ≥ 1000)."
      },
      "rationale": "Sobol sensitivity analysis identified 5 critical inputs: synovial viscosity (Si=0.31), particle diameter distribution (Si=0.28), tibial tray surface roughness (Si=0.14), gait load magnitude (Si=0.11), flexion angle (Si=0.09). All 5 characterized with probability distributions from experimental data (n ≥ 30 measurements each). Monte Carlo propagation (N=2000) yields 95% CI on RAI of [0.92, 1.08], well below 1.15 threshold. Level 3 achieved."
    },
