      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-cou1-rvac-ac",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance Level 3 — validation conditions match COU within documented similarity parameters",
        "description": "Validation experiments must use the same tibial tray geometry (or documented scaled analog), the same ISO 14243-3 gait waveform, and synovial fluid simulant within the operating envelope bounds. Geometric similarity ratio must be 1:1 or deviations documented with sensitivity analysis."
      },
      "rationale": "Validation experiments used a 1:1 silicone phantom of the production tibial tray geometry (CT-scan derived, dimensional tolerance ±0.1 mm). ISO 14243-3 gait waveform applied. Synovial fluid simulant viscosity 15 mPa·s matches mid-range of operating envelope. Sensitivity analysis (see hasSensitivityAnalysis) confirms RAI predictions are insensitive to ±20% viscosity variation. Validation activities are directly relevant to COU1. Level 3 achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-cou1-nse",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
