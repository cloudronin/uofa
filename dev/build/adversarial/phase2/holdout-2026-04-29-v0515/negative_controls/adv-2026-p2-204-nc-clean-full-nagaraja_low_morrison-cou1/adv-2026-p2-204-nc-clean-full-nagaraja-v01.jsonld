      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-cou1-rqoi-ac",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance Level 3 — QoI directly linked to clinical endpoint via documented pathway",
        "description": "The relative accumulation index (RAI) must be directly linked to periprosthetic osteolysis risk via a documented mechanistic or empirical pathway. The linkage must reference at least one peer-reviewed publication establishing the RAI–osteolysis correlation."
      },
      "rationale": "RAI is linked to osteolysis risk via the established pathway: wear particle accumulation → macrophage activation → osteoclast stimulation → bone resorption (Purdue et al., J Bone Joint Surg, 2007; Hallab & Jacobs, J Long-Term Eff Med Implants, 2009). The RAI < 1.15 threshold is derived from a clinical correlation study on 47 TKR patients with 5-year radiographic follow-up. QoI is directly relevant to the decision question. Level 3 achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-cou1-rvac",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
