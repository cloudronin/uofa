  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-orthopedic-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "All 12 assessed CredibilityFactors meet or exceed their required levels at MRL 3: SQA (3/3), Numerical Code Verification (3/2), Discretization Error (3/3), Test Conditions (3/3), Output Comparison (3/3), Relevance of QoIs (4/3), Relevance of Validation Activities (3/3), Numerical Solver Error (3/2), Use Error (2/2), Model Form (3/3), Model Inputs (3/3), and Equivalency of Input Parameters (3/3). The Test Samples factor is appropriately scoped out with documented rationale referencing the uncertainty budget. The sensitivity analysis confirms that synovial viscosity and tibial tray gap tolerance are the dominant sources of QoI variability, and both are bounded within the operating envelope. Validation results demonstrate centroid agreement within 0.87 mm and DSC = 0.84, both satisfying acceptance criteria. The provenance chain is complete from raw experimental data through validation results to this assurance package. The package is accepted for use in regulatory submission supporting worst-case particulate accumulation zone identification for the Class II TKR tibial tray device.",
    "decidedAt": "2026-04-19T00:00:00Z"
