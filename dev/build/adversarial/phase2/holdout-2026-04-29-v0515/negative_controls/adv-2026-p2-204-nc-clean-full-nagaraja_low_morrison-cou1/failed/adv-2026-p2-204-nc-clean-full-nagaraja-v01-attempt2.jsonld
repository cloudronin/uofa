  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-orthopedic-nc4-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 3. Seven factors achieved levels meeting or exceeding required levels: Software QA (achieved 3, required 2), Numerical Code Verification (achieved 2, required 2), Discretization Error (achieved 3, required 3), Test Conditions (achieved 3, required 3), Output Comparison (achieved 3, required 3), Relevance of QoI (achieved 3, required 2), Relevance of Validation Activities (achieved 3, required 3), Numerical Solver Error (achieved 2, required 2), Use Error (achieved 2, required 2), Model Form (achieved 3, required 3), Model Inputs (achieved 3, required 3), Test Samples (achieved 2, required 2), and Equivalency of Input Parameters (achieved 3, required 2). No factor has achievedLevel below requiredLevel. The CFD model demonstrated < 8% error in peak wear-particle concentration and > 87% spatial overlap with experimental data. Sensitivity analysis confirmed robustness to geometric tolerances and fluid property uncertainty. The structured evidence base supports the claim that the model can reliably identify worst-case particulate accumulation zones for the Class II TKR tibial tray under the defined operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
