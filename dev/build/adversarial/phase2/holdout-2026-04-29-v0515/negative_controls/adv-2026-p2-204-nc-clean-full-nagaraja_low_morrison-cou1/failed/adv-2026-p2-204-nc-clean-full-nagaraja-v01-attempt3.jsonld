    "name": "COU1: Orthopedic tibial tray use (Class II TKR)",
    "description": "A CFD model is used to evaluate synovial fluid flow and wear-particle transport around the tibial tray of a total knee replacement device under physiological gait loading. Model influence is MEDIUM (bench testing confirms worst-case zones); decision consequence is HIGH (incorrect identification of accumulation zones could affect clinical wear outcomes). Model Risk Level 3.",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-orthopedic/applicability",
      "type": "ApplicabilityConstraint",
      "name": "TKR tibial tray in-scope domain constraint",
      "description": "Applicable to cemented and cementless Class II tibial tray designs with UHMWPE bearing inserts operating under standard physiological gait cycles (ISO 14243-1). Excludes revision implants, unicompartmental devices, and non-standard activity profiles (e.g. high-impact sports loading). Synovial fluid viscosity must fall within 1–10 mPa·s; particle size distribution limited to 0.1–10 µm diameter UHMWPE debris."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-orthopedic/envelope",
      "type": "OperatingEnvelope",
      "name": "Physiological gait operating envelope for TKR CFD model",
      "description": "Tibial tray geometry: medial-lateral width 70–85 mm, anterior-posterior depth 45–60 mm, tray thickness 6–10 mm. Gait cycle: stance-phase knee flexion 0–20°, swing-phase 20–65°, cycle frequency 0.8–1.2 Hz. Axial compressive load: 1.0–3.5 × body weight (500–2450 N for 70 kg patient). Synovial fluid flow rate: 0.05–0.5 mL/s. Operating temperature: 36–38 °C. Reynolds number regime: laminar (Re < 100). Particle volume fraction: ≤ 0.5% v/v."
    }
  },
