  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-orth-dr01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-orthopedic-credibility-lead",
    "role": "Credibility assessment lead",
    "outcome": "Accepted",
    "rationale": "All 12 assessed CredibilityFactors meet or exceed their required levels at MRL 3. The Test Samples factor is documented as scoped-out with explicit rationale grounded in the use of ISO 14243-1 standardized bench specimens appropriate to the COU scope. Validation evidence demonstrates particle accumulation index agreement within 9.3% against bench measurements (acceptance criterion: 15%), GCI of 1.3% (criterion: 2%), and domain coverage of 85% of the COU parameter space (criterion: 80%). The Carreau-Yasuda non-Newtonian rheology model is validated against synovial fluid viscometry data (R²=0.987) and outperforms alternative model forms. Sensitivity analysis confirms that the worst-case accumulation zone identification is robust to ±15% variation in synovial fluid viscosity and ±10% variation in particle size distribution, with worst-case zone rank order unchanged across all perturbations. The provenance chain is complete from foundational experimental datasets through model development, verification, and validation activities. The assessment team concludes that the computational model provides adequate credibility for the intended use of identifying worst-case particulate accumulation zones for the Class II TKR tibial tray device.",
    "decidedAt": "2026-04-19T00:00:00Z"
