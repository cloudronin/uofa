    "name": "COU1: Tibial tray gait loading — Class II TKA cement stress prediction",
    "description": "A finite element analysis (FEA) model is used to evaluate the sensitivity of bone-cement interface stress to variations in tibial tray geometry and cement mantle thickness under physiological gait loading for a Class II cemented TKA device. Model influence is MEDIUM (bench testing and cadaveric experiments confirm relative rankings); decision consequence is HIGH (incorrect worst-case identification could lead to premature aseptic loosening in vivo). Model Risk Level 3.",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "intendedUse": "Use FEA to identify worst-case bone-cement interface stress conditions across 6 tibial tray geometry variants and 3 cement mantle thickness levels under ISO 14243-1 gait loading. Results compared against cadaveric experimental strain-gauge measurements; acceptance criterion: predicted peak interface stress within 15% of experimental mean.",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-tibial-tray/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Cemented Class II TKA tibial component applicability scope",
      "description": "Model applicability is constrained to cemented tibial tray designs for Class II total knee arthroplasty devices with tibial plateau coverage between 85% and 100%, cement mantle thickness 2–5 mm, and bone quality Hounsfield Unit range 200–700 HU (osteopenic to normal cortical). Cementless, unicompartmental, and revision TKA designs are explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-tibial-tray/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "ISO 14243-1 gait loading envelope for tibial tray FEA",
      "description": "Operating envelope: axial compressive load 500–2500 N (ISO 14243-1 gait cycle peak), anterior-posterior shear 0–350 N, internal-external tibial rotation ±10°, flexion angle 0–120°. Tibial tray outer diameter 62–82 mm, stem length 40–80 mm, cement mantle thickness 2–5 mm. Bone elastic modulus assigned from CT-derived Hounsfield units (200–700 HU). Strain rates corresponding to normal walking cadence (0.8–1.2 Hz) only; running or impact loading is excluded."
    }
  },
