  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-tibial-tray-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/dr-s-nagaraja-principal-engineer",
    "role": "Credibility assessment team lead — orthopedic biomechanics",
    "outcome": "Accepted",
    "rationale": "The COU1 credibility assessment for the tibial tray FEA model is accepted at Model Risk Level 3 based on the following structured evidence: (1) All 13 V&V 40 credibility factors have been assessed, with achievedLevel meeting or exceeding requiredLevel in every case. (2) Discretization error achieved Level 4 (GCI 2.1%), exceeding the Level 3 requirement, providing additional confidence in numerical accuracy. (3) The primary QoI (peak bone-cement interface tensile stress) is directly linked to the clinically relevant failure mode (aseptic loosening) via the ISO 5833 cement fatigue limit; the worst-case predicted stress of 3.8 MPa (90th-percentile Monte Carlo) maintains a safety factor of 1.18 against the 4.5 MPa fatigue limit. (4) Cadaveric validation achieved MAPE of 9.3% against the 15% acceptance criterion across all 6 geometry variants spanning the COU design space. (5) U-validation metric (ASME V&V 20) confirms model predictions are within the experimental uncertainty band at all validation points. (6) Monte Carlo sensitivity analysis identified cement elastic modulus as the dominant uncertainty source (Sobol index 0.61); this uncertainty is characterized and bounded within the COU operating envelope. (7) Independent analyst review confirmed simulation setup integrity. (8) Provenance chain is complete: experimental data (NGL-2024-003), simulation records (repository tag v3.2-production), and design verification report (DVR-TKA-2024-001) are all documented and traceable. The model is fit for the intended use of identifying worst-case cement mantle failure conditions for Class II cemented TKA tibial tray design optimization.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
