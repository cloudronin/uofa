  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed under ASME V&V 40-2018 at Model Risk Level 5. Every factor achieves a level meeting or exceeding the required level: seven factors at requiredLevel 4 all achieve achievedLevel 4; three factors at requiredLevel 3 all achieve achievedLevel 3. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 2000–3500 RPM) and validation data cover all envelope boundary points. Monte Carlo UQ (1000 LHS samples) quantifies combined input and model-form uncertainty at ±13.2% (95th percentile), which remains within the ±15% output comparison acceptance criterion. Sensitivity analysis confirms NIH predictions are most sensitive to impeller clearance and blood viscosity, both of which are bounded by the applicability constraint. The provenance chain is complete from raw PIV and benchtop haemolysis data through validation results to this assurance package. The structured evidence is sufficient to support the claim that the CFD model predicts absolute hemolysis index within the declared envelope at the required credibility level for a Class III device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
