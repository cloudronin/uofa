  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision/nc8-clean-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed; achieved levels meet or exceed required levels in every case (10 factors at parity, 3 factors exceeding requirement). The operating envelope is explicitly bounded (flow 1–7 L/min, speed 2000–4500 RPM, temperature 37 ± 1 °C, hematocrit 35–45 %, inlet pressure 5–15 mmHg) and validation experiments cover both boundary and interior points of the declared envelope. Monte Carlo uncertainty quantification (N = 5000) confirms the 95 % prediction interval on NIH remains below the clinical acceptance threshold across the full envelope. Grid convergence GCI < 3.1 % and model form uncertainty ± 12 % NIH are within acceptable bounds for a Class III MRL 5 assessment. The provenance chain is complete from raw experimental data through CFD simulation to the hemolysis index QoI. No credibility gaps remain; the claim that CFD can predict absolute hemolysis levels for this VAD configuration within the declared operating envelope is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
