  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/synth/factor/nagaraja-sqa",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-sqa-ac",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criteria",
        "description": "Commercial FEA solver (Ansys Mechanical 2022 R2) holds ISO 9001 certification and FDA-recognized validation documentation. FDA in-house solver version-controlled under 21 CFR Part 11-compliant repository with audit trail. Required Gradation 2; achieved Gradation 3 through additional regression test suite."
      },
      "rationale": "Ansys Mechanical and the FDA in-house FEA code both operate under documented SQA programs. Ansys holds ISO 9001 certification; FDA code is version-controlled with automated regression testing against NAFEMS benchmarks. DePuy Synthes solver validated under design-control procedures per 21 CFR 820. Gradation 3 achieved because all three codes carry traceable verification test suites beyond the minimum required."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-ncv",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-ncv-ac",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criteria",
        "description": "Each solver must demonstrate correct implementation of linear elastic and elasto-plastic constitutive routines against at least two NAFEMS or equivalent analytic benchmarks. Patch test passed for all element types used."
      },
      "rationale": "All three FEA codes verified against NAFEMS LE1 and LE10 linear elastic benchmarks and a Ramberg-Osgood plasticity patch test. Results agree with analytic solutions to within 0.5%. Gradation 2 requirement met."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-disc-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-disc-ac",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria",
        "description": "Mesh convergence study must demonstrate QoI change of less than 2% between the production mesh and a uniformly refined mesh. Richardson extrapolation-based GCI must be reported and must be below 3% for all primary QoIs."
      },
      "rationale": "A three-level mesh convergence study was conducted (coarse ~80k elements, medium ~320k elements, fine ~1.28M elements). Stiffness QoI varied by 1.4% between medium and fine meshes; yield force by 1.8%. GCI values: stiffness 1.9%, yield force 2.2%, force at 40 mm 1.6%. All below 3% threshold. Production mesh is the medium-density mesh. Gradation 3 achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-solver-ac",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error acceptance criteria",
        "description": "Iterative solver residuals must converge below 1e-6 for force and displacement norms. Arc-length or displacement-controlled nonlinear incrementation must be documented with step-size sensitivity check."
      },
      "rationale": "All nonlinear analyses used displacement-controlled incrementation with 200 equal load steps. Newton-Raphson convergence achieved with force residual norm below 1e-7 in all increments. A step-size halving study confirmed QoI insensitivity (< 0.3% change). Gradation 2 requirement met."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-use-error",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Use error addresses errors introduced by end-user operation of the simulation tool in a clinical or deployment context. This UofA covers a controlled bench-validation activity conducted by trained simulation engineers at FDA/CDRH and DePuy Synthes under documented modeling protocols. There is no end-user deployment of the FEA model in a clinical workflow; the model output is used exclusively for internal design verification. Accordingly, the use-error factor is not applicable to this COU."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-model-form",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-mf-ac",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria",
        "description": "Model form selection must be documented with justification for constitutive law choice (bilinear isotropic hardening or Ramberg-Osgood), contact formulation (penalty or augmented Lagrangian), and geometric nonlinearity treatment. Sensitivity of QoIs to model form assumptions must be quantified."
      },
      "rationale": "Bilinear isotropic hardening plasticity was selected based on uniaxial tensile coupon data for Ti-6Al-4V ELI (ASTM F136). Contact between screw and UHMWPE block modeled with augmented Lagrangian formulation; friction coefficient 0.2 ± 0.05 per literature. Geometric nonlinearity (large deformation) enabled given displacements up to 40 mm. Model form sensitivity analysis varied constitutive law (Ramberg-Osgood vs. bilinear): QoI difference < 4%. Gradation 3 achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-model-inputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-mi-ac",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria",
        "description": "Material properties must be sourced from traceable coupon tests or certified material data sheets. Geometric inputs must be derived from CMM-measured dimensions of the tested constructs. Uncertainty in key inputs (E, yield stress, geometry) must be documented and propagated."
      },
      "rationale": "Ti-6Al-4V ELI elastic modulus (114 GPa ± 3 GPa) and yield strength (795 MPa ± 15 MPa) sourced from lot-specific tensile coupon tests per ASTM E8. UHMWPE block dimensions measured by CMM on each of the 11 test specimens; mean ± SD reported. Monte Carlo uncertainty propagation (n=1000 samples) performed across material and geometric inputs; 95th-percentile prediction interval reported for all QoIs. Gradation 3 achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-test-samples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-ts-ac",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria",
        "description": "Test specimens must be production-representative (same material lot, manufacturing process, and dimensional tolerances as the commercial device). Sample size must be sufficient to characterize inter-specimen variability (N ≥ 5 per laboratory)."
      },
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (n=6 Lab A, n=5 Lab B). All specimens from a single production lot, manufactured to commercial drawing tolerances. CMM inspection confirmed dimensional conformance. Inter-specimen CV for stiffness: 4.2%; yield force: 5.1%. Sample size exceeds minimum N=5 per lab. Gradation 3 achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-test-conditions",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-tc-ac",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria",
        "description": "Test conditions must replicate the COU loading environment. Multiple load levels or configurations should be tested to characterize model behavior across the operating envelope. Environmental conditions (temperature, humidity) must be documented."
      },
      "rationale": "Testing conducted at a single load configuration (ASTM F1717 standard compression-bending setup, 5 mm/min displacement rate, ambient temperature 23 ± 2 °C). Only one test condition was applied; the required Gradation 3 calls for at least two distinct loading configurations to characterize model response across the envelope. Achieved Gradation 2 because conditions are fully documented and replicated across two laboratories, but the single-condition limitation is acknowledged. Offset rationale provided in the decision record."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-equiv-inputs",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-eip-ac",
        "type": "AcceptanceCriteria",
        "name": "Equivalency of input parameters acceptance criteria",
        "description": "FEA model inputs (geometry, material properties, boundary conditions) must be demonstrably equivalent to the physical test configuration. Any deviations must be documented and their effect on QoIs quantified."
      },
      "rationale": "FEA boundary conditions replicate the ASTM F1717 fixture geometry; screw insertion depth and angulation matched to CMM measurements of each physical specimen. Material properties derived from same production lot as tested devices. Deviations: idealized UHMWPE block geometry used (no surface roughness); sensitivity study showed < 1.5% QoI effect. Gradation 3 achieved, exceeding required Gradation 2."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-oc-ac",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria",
        "description": "Quantitative comparison metric E/uval must be below 1.96 for all primary QoIs, where E is the model-experiment difference and uval is the combined validation uncertainty. Additionally, percentage difference between mean FEA prediction and mean experimental result must be below 10%."
      },
      "rationale": "E/uval values: stiffness 0.83, yield force 1.21, force at 40 mm 1.07 — all below 1.96 threshold. Percentage differences: stiffness 3.8%, yield force 6.2%, force at 40 mm 4.9% — all below 10%. Comparison conducted for all three FEA codes; results consistent across ensemble. Gradation 3 achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-relevance-qoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-rqoi-ac",
        "type": "AcceptanceCriteria",
        "name": "Relevance of QoIs acceptance criteria",
        "description": "QoIs selected for validation must be directly linked to the clinical risk (fracture, loosening) and must be measurable in both the FEA model and the physical test. Traceability from QoI to failure mode must be documented."
      },
      "rationale": "Three QoIs selected: construct stiffness (linked to subsidence risk), yield force (linked to permanent deformation and loosening), and force at 40 mm displacement (linked to catastrophic fracture). All three are directly measurable in ASTM F1717 testing and directly extractable from FEA output. Traceability matrix from QoI to clinical failure mode documented in the V&V plan. Gradation 3 achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/nagaraja-relevance-va",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/nagaraja-rva-ac",
        "type": "AcceptanceCriteria",
        "name": "Relevance of validation activities acceptance criteria",
        "description": "The validation scenario (geometry, loading, material, scale) must be representative of the COU. Differences between the validation scenario and the COU must be documented and their impact on model credibility assessed."
      },
      "rationale": "Validation activity directly tests the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 compression-bending, which is the COU scenario. Same device geometry, same material lot, same loading protocol. No extrapolation from a surrogate geometry or scaled model is required. Validation scenario is identical to the COU scenario. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-002",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors are assessed at or above their required levels. The Use error factor is marked not-applicable with documented rationale (controlled engineering validation context, no clinical end-user deployment). All three primary QoIs (stiffness, yield force, force at 40 mm) satisfy both the E/uval < 1.96 criterion and the < 10% percentage-difference criterion across all three FEA codes in the ensemble. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — is offset by cross-laboratory replication across two independent test facilities, which provides equivalent confidence that the model behavior is not an artifact of a single laboratory setup. The offset rationale is documented and referenced to the Test conditions factor. Overall credibility is assessed as sufficient to support a Medium assurance level for a Class II device decision with medium model influence and medium decision consequence.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/nagaraja-test-conditions-offset",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/factor/nagaraja-test-conditions",
      "justification": "The Test conditions factor achieved Gradation 2 (single documented test condition) against a required Gradation 3 (multiple loading configurations). This shortfall is offset by the fact that testing was independently replicated across two laboratories (Lab A n=6, Lab B n=5) under identical ASTM F1717 conditions, providing inter-laboratory reproducibility evidence that exceeds the typical single-laboratory Gradation 2 scenario. The ASTM F1717 standard specifies a single standardised compression-bending configuration, making multi-condition testing atypical for this device type. The cross-laboratory agreement (CV < 5% for all QoIs between labs) provides confidence that the single test condition is robustly characterised. The credibility team judges this offset sufficient to accept the package at Medium assurance level."
    }
  },
