    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB centrifugal pump operating envelope (bounded)",
      "description": "Volumetric flow rate: 1.0–7.0 L/min; pump rotational speed: 2000–3500 RPM; blood viscosity: 2.7–3.5 mPa·s (hematocrit 35–45%); inlet pressure: 5–20 mmHg; impeller tip clearance: nominal ±0.05 mm; fluid temperature: 35–37 °C. All CFD simulations and experimental validation runs were conducted within these bounds at five (flow, speed) operating points spanning the envelope."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB device applicability constraint",
      "description": "Model applicability is restricted to Class II centrifugal blood pumps geometrically similar to the FDA generic pump benchmark (impeller diameter 52 ± 2 mm, five-blade configuration). Results are not applicable to axial-flow VAD designs, paediatric pumps (flow < 1 L/min), or operating speeds outside 2000–3500 RPM. Haemolysis predictions are valid only when the relative haemolysis index (RH) is used as the QoI and compared against a predicate device under identical boundary conditions."
    }
  },
