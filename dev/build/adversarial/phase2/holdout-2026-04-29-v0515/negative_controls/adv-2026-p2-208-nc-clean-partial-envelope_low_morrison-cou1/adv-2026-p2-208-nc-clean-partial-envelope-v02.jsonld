  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation levels at MRL 2. Discretization error achieves Gradation 3 (exceeds requirement). Output comparison yields normalised RMSE of 0.07 for the primary QoI (RH) across five operating points spanning the full declared envelope (1–7 L/min, 2000–3500 RPM). Validation experiments use identical pump geometry at 1:1 scale with blood-mimicking fluid matched to clinical viscosity. Six factors are legitimately scoped-out or not-applicable per ASME V&V 40-2018 Table 1 MRL 2 guidance, each with documented rationale. The operating envelope is explicitly bounded with concrete numerical limits and validation coverage is dense across the envelope. The structured ApplicabilityConstraint restricts claims to geometrically similar Class II centrifugal pumps. No factor shortfall exists; no offset rationale is required. The evidence base is sufficient to support the claim that the CFD model can identify worst-case haemolysis operating conditions for the Class II CPB device within the declared envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
