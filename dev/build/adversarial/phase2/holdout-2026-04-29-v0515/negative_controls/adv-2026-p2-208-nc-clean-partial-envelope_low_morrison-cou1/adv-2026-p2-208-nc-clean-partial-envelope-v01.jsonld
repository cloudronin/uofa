    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB hemolysis CFD operating envelope — bounded flow, speed, and geometry",
      "description": "The model is valid within the following explicitly bounded operating conditions: volumetric flow rate 1–7 L/min (5 discrete operating points at 2, 3, 4, 5, 6 L/min); rotational speed 1500–3500 RPM (increments of 500 RPM); impeller tip clearance 0.15–0.45 mm (nominal 0.30 mm ± 0.15 mm manufacturing tolerance band); inlet hematocrit 35–45% (nominal 40%); blood temperature 36–38 °C; inlet pressure 0–30 mmHg. All five experimental validation runs were conducted within this envelope. Extrapolation beyond these bounds is explicitly excluded from the claim."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: Class II CPB centrifugal pumps, adult patients, steady-state hemolysis QoI only",
      "description": "The credibility claim applies exclusively to: (1) centrifugal blood pumps of the FDA generic geometry family used in adult CPB procedures; (2) steady-state (time-averaged) hemolysis index as the sole quantity of interest — pulsatile or transient hemolysis dynamics are out of scope; (3) blood analogue fluids with viscosity 3.0–4.5 cP; (4) rigid-wall pump housing assumption — compliant-wall pumps are excluded. Paediatric CPB and ventricular assist device (VAD) applications are outside this constraint boundary."
    }
  },
