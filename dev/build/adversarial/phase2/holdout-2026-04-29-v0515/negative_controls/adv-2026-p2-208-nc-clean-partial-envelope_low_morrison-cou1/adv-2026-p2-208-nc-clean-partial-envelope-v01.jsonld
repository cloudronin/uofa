  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels at MRL 2: Software quality assurance (2/2), Numerical code verification (2/2), Discretization error (3/2 — exceeds requirement), Test conditions (2/2), Output comparison (2/2), Relevance of QoI (2/2), and Relevance of validation activities (2/2). The six remaining factors are appropriately scoped-out or not-applicable with documented rationale consistent with MRL 2 expectations. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 1500–3500 RPM, tip clearance 0.15–0.45 mm, hematocrit 35–45%) and all five validation operating points fall within this envelope, providing dense coverage with no extrapolation. CFD hemolysis index predictions agree with experimental measurements within ±20% at all operating points (acceptance criterion ±25%), and GCI is below 2% on the primary QoI. The applicability constraint correctly limits the claim to adult CPB applications using the FDA generic centrifugal pump geometry family with steady-state hemolysis as the sole QoI. No factor shortfalls exist; no offset rationale is required. The evidence chain is complete from foundational experimental data through validated CFD results to the credibility claim. The decision to accept the claim is well-supported by the structured evidence.",
    "decidedAt": "2026-04-19T00:00:00Z"
