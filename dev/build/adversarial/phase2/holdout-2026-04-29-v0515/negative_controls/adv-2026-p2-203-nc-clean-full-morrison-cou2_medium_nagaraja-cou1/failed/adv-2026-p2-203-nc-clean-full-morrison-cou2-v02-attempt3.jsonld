  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-v3",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending is accepted as credible for the stated COU. Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions (achieved Gradation 3 vs. required Gradation 4) — is offset by: (1) peer-reviewed literature demonstrating that quasi-static Ti-6Al-4V mechanical response is rate-insensitive in the 2–10 mm/min range (Donachie 2000; Nagaraja et al. 2016); (2) published data showing UHMWPE block stiffness varies < 2% between dry ambient and 37°C PBS conditions at these load levels; and (3) the conservative acceptance bounds (<10% MAPE, E/uval < 1.96) providing sufficient margin to absorb any residual environmental uncertainty. All three QoIs pass both acceptance criteria with E/uval values of 0.87, 1.31, and 1.54 respectively, all well below the 1.96 threshold. The ensemble agreement across three independent codes (FDA, Ansys, DePuy Synthes) and two laboratories further strengthens confidence. The credibility evidence is sufficient to support regulatory submission under 21 CFR 870.3800.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/tc-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 3 vs. required 4)",
        "description": "The Test conditions factor achieved Gradation 3 (single displacement rate, single environmental condition) against a required Gradation 4. This shortfall is offset by three independent lines of evidence: (1) rate-insensitivity of quasi-static Ti-6Al-4V in the 2–10 mm/min range documented in peer-reviewed literature (Donachie 2000; Nagaraja et al. 2016); (2) published UHMWPE tribology data showing < 2% stiffness variation between dry and PBS-immersed conditions at loads < 2500 N; (3) the conservative E/uval acceptance threshold (1.96) provides a 24% margin above the worst-case observed value (1.54 for force-at-40mm), sufficient to absorb any uncharacterized environmental sensitivity. The offset is judged adequate by the full assessment team and both laboratory representatives."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-accepted-v3/offset/tc",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/factor/tc",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
