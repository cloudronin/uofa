  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA modeling framework for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as credible for the stated COU at modelRiskLevel 5. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions (achieved level 3 vs. required level 4) — is addressed by the offset rationale below. The three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) all satisfy the pre-established acceptance bounds (E/uval < 1.96 and <10% error) across all N=11 specimens from two manufacturing lots and two independent laboratories. The provenance chain is complete from raw experimental data through validated FEA outputs. The sensitivity analysis confirms that model form and input uncertainty do not materially alter the acceptance decision. The credibility assessment team unanimously recommends acceptance.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/test-conditions-offset",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
      "justification": "The Test conditions factor achieved level 3 (single crosshead displacement rate) against a required level 4 (multiple rates or conditions). This shortfall is offset by three converging lines of evidence: (1) published literature on quasi-static mechanical testing of Ti-6Al-4V (Donachie 2000, Boyer 1994) demonstrates rate-insensitivity in the 1–10 mm/min range relevant to ASTM F1717; (2) the sensitivity analysis (Sobol indices) shows that crosshead rate contributes <0.5% variance to stiffness and yield force QoIs relative to geometric and material input uncertainty; and (3) the inter-laboratory reproducibility (CV=3.1% on stiffness across two independent labs) confirms that the single test condition was applied consistently and reproducibly. The residual uncertainty introduced by the single-rate limitation is fully captured within the E/uval uncertainty budget and does not cause any specimen to exceed the 10% QoI error bound. The assessment team judges the shortfall to be non-material to the acceptance decision."
    }
  },
