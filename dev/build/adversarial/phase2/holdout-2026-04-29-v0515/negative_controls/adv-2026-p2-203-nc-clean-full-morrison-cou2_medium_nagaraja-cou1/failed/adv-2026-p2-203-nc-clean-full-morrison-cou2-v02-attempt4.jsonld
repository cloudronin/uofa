  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-v4",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending is accepted as sufficiently credible for the stated COU. Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for MRL 5. All three QoIs (stiffness, yield force, force at 40 mm) satisfy both the ASME V&V 10.1 normalised error criterion (E/u_val < 1.96) and the pre-specified <10% mean difference bound. Software QA, code verification, mesh convergence, solver convergence, use-error controls, model form justification, input traceability, sample representativeness, input equivalency, output comparison methodology, QoI clinical relevance, and validation activity relevance are all assessed at Gradation 4, meeting the MRL 5 required level. The single shortfall — Test conditions assessed at Gradation 3 against a required Gradation 4 — is addressed in the offset rationale below, which documents that the single-configuration limitation does not materially affect credibility given the direct correspondence between the validation activity and the COU, the tight inter-laboratory agreement, and the sensitivity analysis confirming low sensitivity to moment-arm variation within the ASTM F1717 operating envelope.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
      "justification": "The Test conditions factor achieved Gradation 3 against a required Gradation 4 because testing was performed under a single ASTM F1717 load configuration (60 mm moment arm) rather than the two or more configurations required for Gradation 4. This shortfall is offset by three compensating strengths: (1) The validation activity is identical to the COU — there is no extrapolation from a surrogate configuration, so the single tested configuration is precisely the configuration of interest. (2) Sensitivity analysis (Sobol indices, n=5000 MC samples) demonstrates that moment-arm variation within ±5 mm of the nominal 60 mm produces QoI variation of < 2%, well within measurement uncertainty, confirming that the untested configurations would not have revealed model deficiencies. (3) Inter-laboratory agreement between Lab A and Lab B (mean stiffness difference 1.8%) confirms that the single configuration is reproducibly characterised. The credibility assessment team, including an independent biomechanical reviewer, unanimously concluded that these offsets are sufficient to justify acceptance at the stated assurance level."
    }
  },
