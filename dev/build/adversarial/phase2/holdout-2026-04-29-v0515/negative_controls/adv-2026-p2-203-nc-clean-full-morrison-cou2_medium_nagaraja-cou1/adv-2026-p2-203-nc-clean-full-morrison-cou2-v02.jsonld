  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "decidedAt": "2026-04-19T00:00:00Z",
    "rationale": "The FEA credibility assessment for non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending is accepted at High assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels: software quality assurance (4/4), numerical code verification (4/4), discretization error (4/4), numerical solver error (4/3 — exceeds), use error (4/4), model form (4/4), model inputs (5/4 — exceeds), test samples (4/4), equivalency of input parameters (4/4), output comparison (4/4), relevance of QoIs (4/4), and relevance of validation activities (4/4). All three primary QoIs satisfy the pre-established validation metric threshold E/uval < 1.96, with maximum observed value 1.41. QoI differences range 3.4–7.1%, all within the <10% acceptance bound. The single shortfall — Test conditions factor achieving level 3 against required level 4 due to a single ASTM F1717 test configuration — is addressed by the offset rationale below. The structured evidence base, comprising lot-specific material characterization, CMM-verified specimen geometry, three-code ensemble validation, cross-laboratory reproducibility, and full Monte Carlo uncertainty propagation, provides a comprehensive and technically rigorous foundation for this acceptance decision.",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall-noncannulated",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions factor shortfall (achieved 3, required 4)",
        "description": "The Test conditions factor achieves gradation level 3 (single test configuration) against a required level 4 (multiple configurations). This shortfall is offset by four compensating strengths: (1) ASTM F1717 is a standardised regulatory test protocol with a fixed configuration, making multi-configuration testing neither standard practice nor required by FDA guidance for 510(k) submission; (2) the operating envelope is tightly bounded and the single test condition is centrally located within it, as confirmed by the sensitivity analysis showing < 8% QoI variation across the full envelope span; (3) the three-code ensemble provides independent replication that compensates for the absence of multi-condition testing by demonstrating model-form robustness; and (4) all three QoI validation metrics (E/uval max 1.41) demonstrate substantial margin below the 1.96 acceptance threshold, indicating conservative model predictions. The residual risk from the test conditions shortfall is assessed as Low and does not affect the overall Medium decision consequence classification."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/offset/test-conditions-noncannulated",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions-noncannulated",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
