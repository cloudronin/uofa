  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump under CPB conditions is accepted as credible for the stated COU at MRL 2. Seven credibility factors were formally assessed: all seven meet or exceed their required levels (discretization error achieves Gradation 3, exceeding the Gradation 2 requirement). Six factors are scoped-out or not-applicable per ASME V&V 40-2018 MRL 2 guidance, each with documented rationale. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 1500–3500 RPM) and validation datasets cover all five operating points including both boundary points. The relative hemolysis index predictions agree with experimental measurements within ±15% at all points, meeting the ±20% acceptance criterion. The worst-case operating point (7 L/min, 3500 RPM) is correctly identified by the model. No credibility factor has achievedLevel < requiredLevel; no offset rationale is required. The structured evidence base, complete provenance chain, and concrete bounded applicability constraint collectively support acceptance of this model for regulatory submission purposes.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
