    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/envelope",
      "type": "OperatingEnvelope",
      "name": "CPB centrifugal pump operating envelope — bounded",
      "description": "Volumetric flow rate: 1–7 L/min (five tested points: 1, 2, 4, 6, 7 L/min). Rotational speed: 1500–3500 RPM (five tested points: 1500, 2000, 2500, 3000, 3500 RPM). Inlet pressure: 5–15 mmHg. Outlet pressure head: 100–350 mmHg. Blood haematocrit: 35–45%. Temperature: 35–37 °C. Impeller tip clearance: 0.10–0.25 mm. All five flow-speed boundary operating points are covered by experimental validation datasets."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Adult CPB single-stage centrifugal pump applicability constraint",
      "description": "Model applies to adult patients (body surface area 1.5–2.2 m²) undergoing cardiopulmonary bypass with a single-stage centrifugal blood pump conforming to the FDA generic pump geometry (impeller diameter 50 ± 2 mm, volute width 8 ± 0.5 mm). Paediatric circuits, axial-flow pumps, and LVAD configurations are explicitly out of scope. Blood rheology modelled as non-Newtonian (Carreau-Yasuda) with haematocrit bounded as stated in the operating envelope."
    }
  },
