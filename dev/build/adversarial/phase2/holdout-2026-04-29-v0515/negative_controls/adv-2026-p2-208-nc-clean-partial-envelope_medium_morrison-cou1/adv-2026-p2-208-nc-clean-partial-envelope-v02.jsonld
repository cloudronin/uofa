  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2 (each achievedLevel equals requiredLevel = 2). The six remaining factors are appropriately scoped out or not applicable with documented rationale consistent with ASME V&V 40 MRL 2 guidance for a Class II device. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 1500–3500 RPM, tip clearance 0.10–0.30 mm) and validation activities cover boundary operating points. The relative hemolysis index predictions agree with FDA experimental data within ±12% across all operating points, satisfying the ±15% acceptance criterion. The pressure-rise curve NMAE of 3.1 mmHg is well within the 5 mmHg acceptance criterion. No credibility factor shortfall exists; no offset rationale is required. The structured evidence base, complete provenance chain, and fully bounded applicability constraint collectively support acceptance of the CFD model for identifying worst-case hemolysis operating conditions for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
