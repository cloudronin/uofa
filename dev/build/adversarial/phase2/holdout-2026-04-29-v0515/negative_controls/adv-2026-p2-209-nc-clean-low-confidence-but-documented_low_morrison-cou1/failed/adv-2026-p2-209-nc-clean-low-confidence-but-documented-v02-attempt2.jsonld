      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-de-ac",
        "type": "AcceptanceCriteria",
        "name": "GCI < 5% on hemolysis index QoI — Gradation 2",
        "description": "Grid Convergence Index computed on three systematically refined meshes (2.1 M, 5.8 M, 14.2 M cells). GCI on hemolysis index QoI must be < 5%. Wide uncertainty bounds (±40% on GCI estimate) are disclosed due to non-monotonic convergence at two operating points."
      },
      "rationale": "Three-mesh Richardson extrapolation yields GCI = 3.8% on the peak hemolysis index, satisfying the < 5% criterion. Non-monotonic convergence was observed at 3500 RPM / 4 L/min; GCI at that point carries ±40% uncertainty. This is honestly documented with the raw convergence data provided as supplementary evidence. Achieved level 2 meets the required level 2 despite the wide bounds at one operating point."
    },
    {
      "id": "https://uofa.net/synth/factor/morrison-cou1-tc",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": {
