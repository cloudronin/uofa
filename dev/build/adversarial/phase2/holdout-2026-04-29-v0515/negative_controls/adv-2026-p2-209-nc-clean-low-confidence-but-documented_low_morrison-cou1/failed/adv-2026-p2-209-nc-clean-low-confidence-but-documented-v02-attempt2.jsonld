      "achievedLevel": 2,
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-oc-ac",
        "type": "AcceptanceCriteria",
        "name": "Relative hemolysis index RH within ±25% of experimental — Gradation 2",
        "description": "CFD-predicted RH must lie within ±25% of bench-measured RH at each of 5 operating points. Wide prediction interval (±30% at one point) is disclosed with rationale."
      },
      "rationale": "CFD predictions of relative hemolysis index agree with bench measurements within ±18% at 4 of 5 operating points. At 5000 RPM / 6 L/min, the prediction interval widens to ±30%, exceeding the nominal ±25% criterion. This exceedance is honestly documented; the operating point is not the worst-case condition and the overall ranking of worst-case conditions is preserved. Confidence in output comparison completeness is ~50% due to limited repeat experimental runs (n=2 per point)."
    },
    {
