  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-nc9-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead-2024",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for Morrison COU1 is Accepted at MRL 2 for a Class II CPB device. All 7 assessed factors meet or exceed their required gradation levels (required levels 1–2; achieved levels 2). Six factors are appropriately scoped out or not applicable at MRL 2 per ASME V&V 40 Table 1 guidance. Critically, low evidence confidence (~50%) is honestly documented throughout: (1) viscosity uncertainty of ±8% propagates to ±12% HI uncertainty and is disclosed in the Test Conditions and Output Comparison rationales; (2) Giersiepen-Wurzinger model coefficient uncertainty of ±50% is disclosed in the QoI Relevance rationale; (3) GCI non-monotonic convergence at one operating point carries ±40% uncertainty and is disclosed in the Discretization Error rationale; (4) experimental sampling covers only 5 of 25 possible operating points, disclosed in Validation Relevance. Despite these wide uncertainty bounds, the decision is Accepted because: (a) the COU decision is rank-ordering of worst-case conditions, not absolute HI prediction, and the rank order is preserved across all uncertainty bounds; (b) the worst-case operating point (3500 RPM / 4 L/min) is consistently identified as worst-case across all sensitivity perturbations; (c) the relative hemolysis index RH < 1 criterion is met with margin at the worst-case point even under the upper uncertainty bound; (d) all limitations are transparently disclosed with quantified bounds, enabling informed regulatory review. No weakeners are expected to fire on this package.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": []
  },
