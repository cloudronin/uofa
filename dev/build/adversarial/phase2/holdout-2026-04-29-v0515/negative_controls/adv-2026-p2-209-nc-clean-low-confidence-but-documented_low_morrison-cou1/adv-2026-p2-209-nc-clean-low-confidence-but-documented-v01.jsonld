  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "The 13-factor credibility assessment at MRL 2 is accepted at Medium assurance level. Seven factors are assessed and all meet their required Gradation 2 levels; six factors are appropriately scoped out or not applicable at MRL 2. The assessment explicitly documents ~50% confidence in the hemolysis power-law coefficients (exponent α range 0.62–0.85) and wide uncertainty bounds on the RH index (±25%), arising from limited bench replicates (n=4) and blood analogue substitution. These limitations are not concealed: they are recorded in ValidationResult UQ objects, in the Model Inputs credibility factor rationale, and in the Test Conditions rationale. Despite the low confidence in hemolysis model form, the RH < 1 acceptance criterion is satisfied at the upper uncertainty bound for all 5 operating points, providing a conservative margin. The decision consequence is HIGH and model influence is MEDIUM; bench testing is confirmed as a complementary control that reduces reliance on the CFD prediction alone. The residual uncertainty is commensurate with the MRL 2 classification and the sponsor's risk management framework. No weakener conditions are triggered: all assessed factors meet required levels, all scoped-out factors carry documented rationale, and the provenance chain is complete.",
    "decidedAt": "2026-04-19T00:00:00Z"
