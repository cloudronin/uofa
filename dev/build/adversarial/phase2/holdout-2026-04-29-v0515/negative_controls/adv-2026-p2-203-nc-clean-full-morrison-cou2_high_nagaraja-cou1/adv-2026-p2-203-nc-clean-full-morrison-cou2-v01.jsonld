  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou2-nc3-mrl5-accepted-2026-04",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team — ASME V&V 40 lead analyst and independent reviewer",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble model for non-cannulated 7.5 mm pedicle screw compression-bending has been assessed against all 13 ASME V&V 40 credibility factors at the rigor level commensurate with Model Risk Level 5. All 13 factors achieve their required level or higher: 11 factors at Level 4 and 2 factors (Discretization error, Output comparison) at Level 5. No factor falls below its required level; therefore no offset rationale is needed. The normalised validation metric E/uval < 0.75 for all three QoIs (stiffness, yield force, force-at-40mm), and all percent differences are < 1.5%, providing strong quantitative evidence that the FEA framework is fit for the stated COU. Sensitivity analysis identified material elastic modulus and friction coefficient as dominant uncertainty contributors; both are controlled within the operating envelope. The provenance chain is complete: experimental data are traceable to NIST-calibrated instrumentation and lot-specific material certificates; FEA predictions are traceable to version-controlled model files and a peer-reviewed simulation execution protocol. The decision consequence is MEDIUM and model influence is MEDIUM, consistent with the Medium assurance level designation at MRL 5. The assessment team unanimously recommends acceptance of the FEA modeling framework for its stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
