  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the non-cannulated 7.5 mm pedicle screw FEA model under ASTM F1717 compression-bending is accepted at Medium assurance level. All 13 V&V 40 factors have been assessed. Twelve of thirteen factors meet or exceed their required credibility levels. The single exception — Test conditions (achieved Gradation 2, required Gradation 3) — is accepted because the COU is explicitly bounded to the single ASTM F1717 standard test condition, and no extrapolation to other loading conditions is claimed. The quantitative validation metric (E/uval) is below the 1.96 threshold for all three QoIs, with maximum percent difference of 6.2%, well within the pre-established 10% bound. Provenance is complete: model inputs are traceable to lot-specific material testing and CMM geometry characterization; experimental data are traceable to two independent laboratories; uncertainty quantification covers both experimental and simulation sources. The model risk level (3) is commensurate with the Medium assurance level and Medium decision consequence. The FEA modeling framework is accepted as credible for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
