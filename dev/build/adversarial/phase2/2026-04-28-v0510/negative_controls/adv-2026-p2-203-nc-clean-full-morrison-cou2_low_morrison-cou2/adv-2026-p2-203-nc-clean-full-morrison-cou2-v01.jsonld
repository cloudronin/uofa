  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5",
      "rationale": "Full ISO 9001-compliant SQA plan in place. Version-controlled source with tagged releases, automated regression test suite (>2000 tests, 100% pass), independent code review records, and change-control logs all archived. Solver vendor audit certificate current. Achieved level 5 satisfies MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Method of manufactured solutions (MMS) applied to all governing equation sets including the power-law hemolysis transport equation. Observed order of accuracy matches theoretical order (p_obs=1.97 vs p_theory=2.0) across three mesh refinement levels. All benchmark problems from ASME V&V 20 suite pass. Code verification report archived at activity https://uofa.net/synth/activity/mms-verification-v2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5",
      "rationale": "Three-level structured mesh refinement study performed. GCI fine-grid = 1.2% for hemolysis index QoI (well below 5% threshold). Asymptotic range confirmed (GCI ratio = 1.03). Temporal discretization verified via time-step halving with <0.5% change in hemolysis index. Results linked to ValidationResult https://uofa.net/synth/validation/mesh-convergence-gci."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "Experimental test conditions (flow rate, rotational speed, fluid viscosity, temperature, hematocrit) documented with calibrated measurement uncertainty for all 5 operating points. Traceability to NIST standards confirmed. Environmental conditions (temperature ±0.5°C, hematocrit ±1%) within specified tolerances. Test protocol peer-reviewed and archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "Quantitative comparison metrics include MAPE (7.8%), normalized RMSE (4.3%), and u-pooled uncertainty overlap at all 5 operating points. Agreement assessed using ASME V&V 20 validation metric with combined experimental and simulation uncertainty. All comparisons fall within validation acceptance band. Linked to ValidationResults https://uofa.net/synth/validation/piv-velocity-comparison and https://uofa.net/synth/validation/hemolysis-index-comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "Primary QoI is absolute normalized index of hemolysis (NIH) in mg/dL, which is the direct clinical decision quantity. Secondary QoIs (shear stress distribution, residence time) are mechanistically linked to hemolysis damage model. QoI mapping to COU2 decision criterion documented. No surrogate QoIs used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "Validation experiments performed on the same FDA generic centrifugal pump geometry under identical operating envelope (2–8 L/min, 2500–4500 RPM). Blood analog fluid (glycerin-water, matched viscosity) used with validated hemolysis correlation. Geometric fidelity confirmed via CMM measurements. COU2 operating conditions are a proper subset of validation envelope. No extrapolation beyond validated range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence monitored via residual norms (all <1e-6) and QoI stabilization (<0.1% change over final 500 iterations). Solver round-off error estimated at machine precision level (double precision, 64-bit). Parallel decomposition independence verified across 4 and 16 core configurations. Solver error contribution to total simulation uncertainty quantified as <0.3% of hemolysis index."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "Simulation execution governed by documented Standard Operating Procedure (SOP-CFD-VAD-002, rev 3). Independent analyst re-ran two of five operating points and achieved results within 1.2% of primary analyst. Checklist-based review of boundary condition setup, material property assignment, and post-processing steps completed and archived. User qualification records on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "RANS k-omega SST turbulence closure selected based on systematic comparison of five turbulence models against PIV data; SST yielded lowest velocity RMSE (4.3%). Power-law hemolysis damage model (Giersiepen et al., calibrated by Heuser & Opitz) selected after literature review of six candidate models. Model form uncertainty quantified via ensemble of three turbulence models contributing ±9% to hemolysis index prediction, incorporated into total uncertainty budget. Linked to GSA results at https://uofa.net/synth/validation/sensitivity-sobol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "All 14 model input parameters assigned probability distributions based on measured data or literature meta-analysis. Monte Carlo propagation with 5000 Latin hypercube samples performed; 95% confidence interval on hemolysis index is ±11%. Sobol first-order indices sum to 0.91, indicating dominant inputs identified (viscosity, rotational speed, hemolysis model coefficients). Input uncertainty dataset archived at https://uofa.net/synth/data/mc-uq-ensemble-5000runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5",
      "rationale": "Hemolysis bench tests conducted with n=6 replicate runs per operating point (30 total) using fresh porcine blood within 6-hour collection window. Hematocrit normalized to 33±1%. Sample preparation protocol (anticoagulant type, storage temperature, centrifugation) documented per ASTM F1841. Intra-run and inter-run variability quantified; coefficient of variation <8% across all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5",
      "rationale": "Computational boundary conditions matched to experimental conditions via direct measurement mapping: inlet velocity profiles from PIV, outlet pressure from transducer readings, wall roughness from profilometry. Dimensionless parameter equivalency confirmed: Reynolds number (Re=4200–11800), Taylor number, and hemolysis-relevant stress exposure time all within 2% of experimental values across all 5 operating points. Mapping table archived and reviewed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors assessed at the required level 5 for MRL 5, with achieved levels meeting or exceeding requirements in every case. Software quality assurance meets ISO 9001 with full regression testing. Code verification via MMS confirms second-order accuracy. Discretization error quantified at GCI=1.2%, well below threshold. Validation experiments performed on the identical pump geometry under the identical operating envelope with n=6 replicates per point; hemolysis index MAPE of 7.8% falls within the combined uncertainty band. Monte Carlo UQ (5000 samples) yields a 95% CI of ±11% on the hemolysis index, and the upper bound of the CI remains below the clinical hemolysis threshold of 0.8 mg/dL (predicted mean 0.31 mg/dL, 97.5th percentile 0.35 mg/dL). Global sensitivity analysis identifies viscosity and rotational speed as dominant uncertainty drivers, and targeted experimental characterization has reduced their distributions. Model form uncertainty from turbulence model selection (±9%) is explicitly included in the total uncertainty budget. Use error controls (independent re-run, SOP compliance, checklist review) are documented. The provenance chain from raw PIV and hemolysis bench data through post-processing to the final credibility conclusion is complete and archived. On the basis of this comprehensive structured evidence, the credibility assessment team unanimously accepts the CFD model for COU2 use in support of the Class III VAD regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
