  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 5 for COU2 (VAD hemolysis prediction). Achieved levels meet or exceed required levels for all factors: 11 of 13 factors achieved Gradation 5 (required 4), and 2 of 13 achieved Gradation 4 (required 4). Monte Carlo uncertainty quantification (N=2000 LHS samples) demonstrates that 95th-percentile hemolysis index predictions remain below the absolute clinical threshold across all 5 operating points, with prediction intervals enclosing all experimental measurements. Global sensitivity analysis (Sobol indices) identifies inlet flow rate, rotational speed, and fluid viscosity as dominant uncertainty drivers, and confirms that model form uncertainty is not a dominant contributor. Code verification via MMS confirms second-order spatial accuracy. Grid convergence index below 2.1% on the production mesh. Independent reviewer found no use errors. Validation activities directly replicate the COU operating envelope on the identical pump geometry. The totality of structured evidence supports acceptance of the CFD model for predicting absolute hemolysis levels in this Class III VAD application at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
