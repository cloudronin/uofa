  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-mrl2",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) operates under a documented software quality assurance plan including version control, regression testing, and release validation. Solver version is locked for this study. SQA documentation reviewed and confirmed compliant with MRL 2 requirements. Achieved Gradation 2 exceeds the required Gradation 1 for this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-mrl2",
      "rationale": "Numerical code verification was performed using the method of manufactured solutions (MMS) for the Navier-Stokes solver and the power-law hemolysis transport equation. Convergence rates confirmed to be consistent with theoretical second-order accuracy. Results documented in the code verification report (CVR-2025-07). Achieved Gradation 2 satisfies the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-mrl2",
      "rationale": "Grid convergence index (GCI) analysis performed on three systematically refined meshes (4.2M, 10.8M, and 26.1M elements) following Celik et al. (2008) guidelines. GCI for the hemolysis index QoI was 3.1% on the fine mesh, below the 5% threshold established in the acceptance criteria. Spatial order of convergence confirmed at 1.87. Temporal discretization verified with three time-step refinements; temporal GCI < 1.5%. Achieved Gradation 3 exceeds the required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-mrl2",
      "rationale": "Experimental test conditions for validation experiments are documented and traceable to the FDA benchmark pump test protocol. Blood analog fluid properties (glycerol-water mixture, 36% hematocrit equivalent viscosity) are characterized with uncertainty bounds. Flow rates and rotational speeds span the 5 COU operating points. Temperature maintained at 37 ± 0.5°C. Achieved Gradation 2 meets the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-mrl2",
      "rationale": "Quantitative output comparison performed using normalized index of agreement (NIA) and root-mean-square error (RMSE) metrics for hemolysis index predictions across all 5 operating points. NIA = 0.94 (threshold ≥ 0.85). RMSE for normalized hemolysis index = 0.042 (threshold ≤ 0.10). Comparison includes experimental uncertainty bars derived from triplicate measurements. Statistical significance of agreement confirmed via two-sample t-test (p > 0.05 for all operating points). Achieved Gradation 3 exceeds the required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-mrl2",
      "rationale": "The primary QoI — normalized hemolysis index (NIH) and relative hemolysis index (RH) — are directly relevant to the COU decision criterion (RH < 1). These QoIs are the same metrics used in predicate device regulatory submissions and align with FDA guidance on hemolysis assessment for blood-contacting devices. Secondary QoIs (wall shear stress, velocity profiles) support mechanistic understanding of hemolysis generation sites. Achieved Gradation 2 meets the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-mrl2",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal blood pump geometry, which is the same device geometry used in the COU. Operating conditions in the validation experiments span the full COU operating envelope (2–6 L/min, 2000–3500 RPM). Blood analog fluid properties are representative of clinical CPB conditions. The validation hierarchy progresses from component-level (impeller) to system-level (assembled pump) validation, providing confidence across scales relevant to the COU. Achieved Gradation 2 meets the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-mrl2",
      "rationale": "Iterative convergence verified by monitoring residuals to below 1×10⁻⁵ for all transport equations and confirming mass imbalance < 0.01%. Round-off error assessed by running double-precision calculations and comparing to single-precision results; differences < 0.1% for all QoIs. Solver settings documented and frozen for the study. Achieved Gradation 2 exceeds the required Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-mrl2",
      "rationale": "The Reynolds-Averaged Navier-Stokes (RANS) model with SST k-omega turbulence closure is selected based on literature evidence for rotating blood pump flows. The power-law hemolysis damage accumulation model (Giersiepen-Wurzinger) is the established formulation for CFD hemolysis prediction. Model form assumptions (Newtonian blood analog, rigid walls, steady-state MRF approach for impeller) are documented and justified for the COU operating conditions where non-Newtonian effects are secondary at the relevant shear rates (> 100 s⁻¹). Achieved Gradation 2 meets the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-mrl2",
      "rationale": "All model inputs are characterized with documented uncertainty bounds. Geometric inputs derived from CMM-measured pump dimensions (tolerance ± 0.02 mm). Fluid properties (density, viscosity) measured at test temperature with ± 2% uncertainty. Boundary conditions (inlet flow rate, outlet pressure, wall rotational speed) are traceable to experimental setup documentation. Sensitivity analysis performed on the five most influential input parameters using one-at-a-time perturbation; hemolysis index sensitivity to each input documented. Achieved Gradation 2 meets the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-scoped",
      "rationale": "Use error assessment is scoped out for this COU because the CFD analysis is performed by a single experienced team of computational fluid dynamicists operating under a documented simulation governance procedure (SGP-2024-03). The simulation workflow is executed through a validated, locked analysis template with mandatory peer-review checkpoints at mesh generation, boundary condition setup, and post-processing stages. The governance procedure includes independent technical review of all inputs and outputs prior to submission. At MRL 2 with medium model influence, the structured peer-review process provides sufficient assurance that use errors are controlled without requiring a formal separate use-error factor assessment. This scope exclusion is reviewed and approved by the credibility assessment team lead."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-scoped",
      "rationale": "Test samples factor is scoped out because the validation experiments use a blood analog fluid (glycerol-water mixture) rather than biological blood samples. The use of a blood analog is a deliberate and documented design choice consistent with FDA guidance for in-vitro hemolysis testing, eliminating sample-to-sample biological variability as a confounding factor. Fluid characterization is performed on the prepared analog batch with documented rheological properties. The absence of biological sample variability means the test samples factor is not applicable as a credibility concern for this validation activity; the relevant uncertainty is instead captured under the Model Inputs factor (fluid properties with ± 2% uncertainty bounds). This scoping decision is documented in the validation plan (VP-2025-02)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/equivalency-inputs-scoped",
      "rationale": "Equivalency of input parameters between the validation scenario and the COU is scoped out as a separate factor because the validation experiments are conducted on the identical FDA generic centrifugal blood pump geometry at the identical operating conditions specified in the COU (same flow rates, same rotational speeds, same fluid temperature). There is no extrapolation of model inputs between the validation domain and the COU domain; the simulation boundary conditions are set directly from the experimental measurements. Any residual input parameter differences (e.g., minor manufacturing tolerances between test articles) are bounded and documented within the Model Inputs factor assessment. Treating equivalency as a separate factor would be redundant given the direct correspondence between validation and COU conditions, and this redundancy is documented in the credibility assessment plan (CAP-2025-01, Section 4.3)."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for the FDA generic centrifugal blood pump under CPB conditions) is accepted at Model Risk Level 2. Ten of thirteen credibility factors were formally assessed; all ten achieved levels meet or exceed the required levels for MRL 2. Three factors (Use Error, Test Samples, Equivalency of Input Parameters) were scoped out with documented rationale reviewed and approved by the assessment team lead. The scoping decisions are grounded in the specific characteristics of this COU: a locked simulation governance procedure controls use error risk; blood analog fluid eliminates biological sample variability addressed by the test samples factor; and direct correspondence between validation and COU operating conditions renders a separate equivalency assessment redundant. Key quantitative evidence supporting acceptance includes: GCI < 3.1% on the fine mesh confirming discretization error control; NIA = 0.94 and RMSE = 0.042 for hemolysis index predictions across all 5 operating points, both meeting acceptance thresholds; and MMS-confirmed second-order code convergence. The relative hemolysis index RH < 1 acceptance criterion is met at all 5 COU operating points with margin. Uncertainty quantification is complete and traceable for all three validation results. The provenance chain is complete from foundational experimental data through validation activities to this credibility determination. The assessment team concludes that the CFD model provides sufficient credibility to support the regulatory decision regarding worst-case hemolysis operating conditions for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
