  "signature": "ed25519:86fffdcfcaf992e4b14c84065b0a873beb2e436fa03b87ab3ea608a43c5fced6067f422e0e7a6fd39608e708c897ffbccd2343ea4d2ae6ee10c2ce01a9b34909",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-mrl5",
      "rationale": "Software quality assurance activities include version control, regression testing suite covering 87% of solver code paths, and documented build procedures. However, formal independent V&V of the hemolysis damage model subroutine has not been completed; the subroutine was introduced in v2.1 and carries no independent audit trail. MRL 5 requires Gradation 4 (independent SQA audit with traceability to requirements); achieved level is Gradation 3 (internal QA with partial traceability). Gap of one gradation level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-mrl5",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes solver confirms spatial order of accuracy (1.92 observed vs 2.0 theoretical). MMS has not been applied to the power-law hemolysis damage accumulation model integrated along pathlines; that sub-model has been verified only against published tabular benchmarks at three operating points. MRL 5 requires MMS verification of all coupled sub-models; the hemolysis sub-model gap reduces achieved level to Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-mrl5",
      "rationale": "Richardson extrapolation on a three-level mesh refinement study yields a Grid Convergence Index of 6.2% on NIH at the fine mesh (19.2M elements). MRL 5 acceptance criterion requires GCI < 2% on the quantity of interest. The fine mesh required for GCI < 2% (estimated ~77M elements) is computationally intractable for the Monte Carlo ensemble; a medium mesh (4.8M elements, GCI ~14%) was used for the UQ runs. Achieved Gradation 2 reflects documented GCI on fine-mesh single-point runs only; ensemble runs carry higher discretization error. Gap of two gradation levels against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-mrl5",
      "rationale": "Experimental test conditions replicate 4 of 5 target operating points within ±3% of nominal flow rate and ±1% of rotational speed. The fifth operating point (4 L/min, 3600 RPM) was tested at 3580 RPM due to motor controller limitations; a 0.6% speed deviation produces an estimated 2.1% NIH difference per sensitivity analysis. Fluid temperature was controlled at 37±0.5°C. Blood analog viscosity matched to within 4% of target. MRL 5 requires all five operating points within ±2% for all boundary conditions; one point marginally outside tolerance reduces achieved level to Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-mrl5",
      "rationale": "CFD-predicted NIH compared against experimental measurements using area validation metric (AVM). Mean signed error is +38% across 5 operating points; systematic over-prediction at high-flow conditions suggests model-form inadequacy in the shear stress damage exponent. Prediction intervals from Monte Carlo UQ bracket 4 of 5 experimental points at 95% confidence, but the 95th-percentile prediction exceeds the clinical threshold at 2 operating points. MRL 5 requires Gradation 5 (AVM < 10%, all prediction intervals bracket experimental data, no systematic bias). Achieved Gradation 3 reflects bracketing of most data but unacceptable systematic bias and threshold exceedance. Gap of two gradation levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-mrl5",
      "rationale": "The primary quantity of interest (NIH, normalized index of hemolysis) is the clinically accepted metric for hemolysis assessment and directly maps to the COU decision threshold. However, the model predicts bulk-averaged NIH; spatial distribution of hemolysis hotspots near impeller blades is not resolved at the mesh density used for UQ runs. MRL 5 requires QoI relevance at Gradation 4 (direct correspondence between modeled QoI and clinical decision metric including spatial resolution); achieved Gradation 3 reflects correct metric selection but insufficient spatial fidelity for absolute threshold decisions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-mrl5",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry, which closely approximates the COU device geometry. Blood analog (glycerol-water, 37% hematocrit equivalent) was used in place of actual blood; prior literature indicates NIH predictions with blood analogs may underestimate hemolysis by 10–20% relative to fresh human blood. The validation dataset covers 5 operating points spanning the COU operating envelope. MRL 5 requires validation with actual blood or a demonstrated equivalent; the blood analog substitution introduces unquantified systematic bias reducing achieved level to Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence of the CFD solver was monitored via residual norms (target 1e-6 for continuity and momentum). However, formal quantification of iterative solver error contribution to NIH uncertainty has not been performed; the interaction between iterative convergence tolerance and hemolysis damage accumulation along pathlines was not assessed. This factor is flagged as an epistemic gap at MRL 5. Required Gradation 3; no evidence supports a claim above Gradation 1 (monitoring only, no quantification)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-mrl5",
      "rationale": "No formal user qualification study or simulation governance audit was conducted. The CFD analyst team has documented internal operating procedures, but independent review of model setup decisions (boundary condition assignment, turbulence model selection, pathline seeding density) has not been performed. Use error is an epistemic gap at MRL 5; required Gradation 3 (documented qualification and independent review) is not achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-mrl5",
      "rationale": "The power-law hemolysis damage model (Giersiepen-Wurzinger correlation) is known to have limited generalizability across pump geometries and operating regimes. No systematic model-form uncertainty analysis has been conducted; alternative hemolysis models (e.g., strain-based, energy dissipation) were not evaluated. The 38% systematic over-prediction in output comparison is consistent with model-form inadequacy but has not been formally attributed. MRL 5 requires Gradation 4 (model-form uncertainty bounded and included in total uncertainty budget); this factor is an epistemic gap. Achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-mrl5",
      "rationale": "Monte Carlo UQ propagates uncertainty in inlet flow rate, rotational speed, and blood viscosity. However, uncertainty in the hemolysis damage model coefficients (C, alpha, beta in the power-law formulation) has not been included in the UQ ensemble; these coefficients carry substantial inter-study variability in the literature (coefficient of variation ~30%). Omission of model parameter uncertainty from the UQ budget is an epistemic gap; required Gradation 3 is not achieved. Achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-mrl5",
      "rationale": "Experimental hemolysis measurements were obtained from a single test rig with a single pump specimen. Inter-specimen variability (manufacturing tolerances, surface roughness) and inter-laboratory variability have not been characterized. MRL 5 requires Gradation 3 (multiple specimens or demonstrated equivalence, with inter-specimen variability quantified). Single-specimen testing is an epistemic gap. Achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/input-equivalency-mrl5",
      "rationale": "Boundary conditions applied in the CFD model (velocity inlet profile, outlet pressure boundary) were derived from bulk flow measurements; the inlet velocity profile was assumed fully developed turbulent (1/7th power law) rather than measured. Equivalency between the assumed inlet profile and the actual pump inlet conditions in the test rig has not been demonstrated. MRL 5 requires Gradation 3 (demonstrated equivalency of all boundary conditions between simulation and experiment); assumed inlet profile is an unverified simplification. Achieved Gradation 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, MRL 5) results in a 'Not accepted' decision based on structured evidence across all 13 credibility factors. Seven factors were formally assessed; all seven achieved levels fall below required levels. Six factors were not assessed and are documented as epistemic gaps at MRL 5. The most consequential deficiencies are: (1) Discretization error: achieved Gradation 2 against required Gradation 4 — the GCI of 6.2% on fine-mesh single-point runs exceeds the MRL 5 threshold of 2%, and the UQ ensemble was necessarily run at medium mesh (GCI ~14%), compounding the gap; (2) Output comparison: achieved Gradation 3 against required Gradation 5 — systematic over-prediction of 38% NIH and threshold exceedance at 2 of 5 operating points in the 95th-percentile UQ envelope directly undermines the absolute hemolysis acceptance decision; (3) Model form: not assessed, required Gradation 4 — the power-law damage model's known limitations and the observed systematic bias have not been formally bounded in the uncertainty budget. The Monte Carlo UQ, while demonstrating parametric uncertainty propagation, captures only three input variables and explicitly excludes model-form and model-parameter uncertainty, leaving the total uncertainty budget incomplete. For a Class III device at MRL 5 where the model is the primary basis for hemolysis acceptance and incorrect prediction could result in chronic patient hemolysis, the structured evidence does not provide sufficient credibility to support a regulatory submission. The decision threshold requires all assessed factors to meet required levels and all epistemic gaps to be resolved or formally scoped out with documented justification; neither condition is satisfied. The 'Not accepted' decision is warranted and proportionate to the evidence.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
