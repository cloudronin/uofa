  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the tibial tray FEA model at MRL 3 is accepted. All 13 V&V 40 credibility factors have been fully assessed. Achieved credibility levels meet or exceed required levels for MRL 3 across all factors: software quality assurance (3≥2), numerical code verification (2≥2), discretization error (3≥2), test conditions (2≥2), output comparison (2≥2), relevance of QOIs (3≥2), relevance of validation activities (2≥2), numerical solver error (2≥2), use error (2≥1), model form (2≥2), model inputs (3≥2), test samples (2≥2), and equivalency of input parameters (2≥2). The validation evidence base is complete with four ValidationResult records providing quantitative comparisons against independent experimental datasets. Uncertainty quantification has been performed for all ValidationResults through sensitivity analysis and GCI-based discretization error estimation. The provenance chain is fully documented from raw experimental data through validation activities to credibility factor assessments. No credibility gaps remain at MRL 3 for this Class II orthopedic application. The model is accepted for use in predicting relative peak von Mises stress distributions in the tibial tray under the five physiological loading scenarios defined in COU1.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
