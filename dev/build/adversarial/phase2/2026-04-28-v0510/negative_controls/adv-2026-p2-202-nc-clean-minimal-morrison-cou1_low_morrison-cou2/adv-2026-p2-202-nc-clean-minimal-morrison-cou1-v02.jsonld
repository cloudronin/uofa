  "signature": "ed25519:ed22bb10d021a2f4c85db2f19ee43f54c4a8716beea5ace23ee2cbfb292ce4e0dbfdb8d8ca18c1722db6cd9c2a91e6e9c787424f2196f034eb515758919e7d04",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-class3",
      "rationale": "CFD solver (ANSYS Fluent 2024R1) operates under an ISO 9001:2015 quality management system. Version-controlled source, regression test suite of 847 cases, and documented change management records satisfy Gradation 3 SQA requirements for MRL 5 hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and scalar hemolysis transport equations. Observed convergence rates match theoretical order for second-order spatial discretization. Code verification package archived under configuration control."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5",
      "rationale": "Richardson extrapolation performed across three systematically refined meshes (6.2M, 18.7M, 52.1M cells). Grid convergence index (GCI) for hemolysis index is 2.1% at the fine-mesh level, well below the 5% acceptance threshold. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "Experimental test conditions (flow rate, rotational speed, fluid viscosity, temperature) are documented with calibrated measurement uncertainty. Five operating points span the clinical VAD envelope. Boundary conditions in CFD are matched to measured values within stated experimental uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "Quantitative comparison metrics (E_rel, NRMSE) computed for hemolysis index, velocity magnitude, and pressure rise at all five operating points. Mean E_rel for hemolysis index is 8.3% across operating points, within the 15% acceptance threshold established for MRL 5 absolute hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is the same metric used in the regulatory submission and clinical acceptance criterion. Secondary QoIs (velocity field, shear stress distribution) directly support the hemolysis model inputs. QoI traceability matrix links each model output to the COU decision need."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "Validation activities performed on the FDA generic centrifugal pump geometry, which is the same device class and flow regime as the VAD COU. Operating conditions in validation bracket the full clinical operating envelope. Fluid analogue (40% glycerol-water) closely matches blood viscosity; correction factors are documented and bounded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence monitored via residual norms (< 1e-6 for all equations) and global mass/momentum balances (< 0.01%). Double-precision arithmetic used throughout. Solver error contribution to total numerical uncertainty is quantified as < 0.5% of hemolysis index, well below discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "Simulation execution follows a documented simulation plan reviewed by an independent analyst. Boundary condition setup, turbulence model selection, and post-processing scripts are version-controlled and peer-reviewed. No deviations from the approved simulation plan were recorded during the COU2 assessment runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "RANS k-omega SST turbulence model selected based on published benchmark studies for rotating hemolysis-relevant geometries. Power-law hemolysis damage model (Giersiepen et al., modified by Heuser-Opitz) is the standard for regulatory CFD submissions. Model form uncertainty estimated via comparison with LES sub-model at design point; difference < 12% in hemolysis index."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "Monte Carlo uncertainty propagation performed with 10,000 samples across all uncertain input parameters (fluid viscosity, inlet flow rate, rotational speed, hemolysis model coefficients). Input distributions derived from calibrated measurement uncertainty and published material property ranges. Resulting 95th-percentile hemolysis index remains below clinical acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5",
      "rationale": "In vitro hemolysis measurements performed on n=6 pump specimens per operating point, consistent with ASTM F1841 guidance. Specimen-to-specimen variability quantified and incorporated into experimental uncertainty bands used for output comparison. Sample size sufficient to characterize inter-unit variability at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5",
      "rationale": "Dimensional analysis confirms dynamic similarity between validation test conditions and COU operating conditions. Reynolds number, flow coefficient, and head coefficient are matched within 3% across all five operating points. Fluid property differences between blood analogue and whole blood are documented with sensitivity analysis confirming < 5% impact on hemolysis index predictions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achievedLevel values meet or exceed the requiredLevel for Model Risk Level 5. Monte Carlo uncertainty quantification confirms that the 95th-percentile hemolysis index prediction remains below the clinical acceptance threshold across all five VAD operating points. Discretization error (GCI 2.1%) and solver error (< 0.5% contribution) are well-controlled. Validation activities on the FDA generic centrifugal pump geometry are directly relevant to the COU, with quantitative output comparison metrics within acceptance bounds (mean E_rel 8.3% against 15% threshold). Model form uncertainty has been bounded via LES comparison. The provenance chain from foundational PIV and hemolysis in vitro datasets through simulation activities to validation results is complete and traceable. The credibility evidence package is sufficient to support the regulatory decision that CFD-predicted absolute hemolysis levels are credible for the Class III VAD submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
