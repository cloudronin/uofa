  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/applicability-noncannulated-only",
      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated design restriction",
      "description": "Model applicability is restricted to non-cannulated pedicle screw designs. Cannulated variants introduce internal geometry that alters stress distribution in the screw shank and has not been validated under this COU. Any extension to cannulated designs requires a separate V&V activity.",
      "constraintExpression": "screwDesign = 'non-cannulated' AND screwDiameter_mm IN [7.4, 7.6]"
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/operating-envelope-f1717",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 static compression-bending operating envelope",
      "description": "Defines the bounded parameter space within which the FEA model has been validated and is considered applicable. Parameters outside these bounds have not been assessed and the model must not be used without additional validation evidence.",
      "bounds": [
        {
          "parameter": "Axial compressive load",
          "minimum": 0,
          "maximum": 3000,
          "unit": "N",
          "note": "Loads above 3000 N approach ultimate failure; model is elastic-plastic but plasticity calibration covers only up to 2800 N experimentally. Upper bound set conservatively."
        },
        {
          "parameter": "Bending moment at construct",
          "minimum": 0,
          "maximum": 25,
          "unit": "N·m",
          "note": "Corresponds to actuator displacement range 0–40 mm per ASTM F1717 fixture geometry."
        },
        {
          "parameter": "Screw outer diameter",
          "minimum": 7.45,
          "maximum": 7.55,
          "unit": "mm",
          "note": "Manufacturing tolerance band for the 7.5 mm nominal design; validated specimens all fell within this range."
        },
        {
          "parameter": "Test block material",
          "allowedValues": [
            "UHMWPE per ASTM F1717 Annex A1"
          ],
          "note": "Model material properties calibrated against UHMWPE coupon data. Other block materials not validated."
        },
        {
          "parameter": "Loading rate",
          "minimum": 1,
          "maximum": 25,
          "unit": "mm/min",
          "note": "Quasi-static regime; rate-dependent effects not modelled. Validation performed at 5 mm/min; sparse coverage at 1 and 25 mm/min acknowledged as gap."
        }
      ],
      "coverageGapStatement": "Validation specimens provide sparse coverage at the extremes of the loading-rate and bending-moment bounds. N=2 constructs tested at 1 mm/min and N=1 at 25 mm/min. All QoI comparisons remain within acceptance bounds at these extremes, but the sparse sample count is documented as a residual uncertainty. The operating envelope bounds are not expanded beyond the tested range."
    }
  },
