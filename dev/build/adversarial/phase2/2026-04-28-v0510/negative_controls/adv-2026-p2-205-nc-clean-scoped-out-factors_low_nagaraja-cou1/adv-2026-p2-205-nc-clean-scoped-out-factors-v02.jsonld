  "hash": "sha256:22ee8f2206c3480f816a449d8c7c8d3f14a53ba0ab652462ba7c253af0b7d56a",
  "signature": "ed25519:6dcebe56803abe629eacd2b5dc24c67bc10a51c092ebb2aaac4f3f481233e9bac7c9d5fefc51ca3176a0828a4cad19d49d5f32d578cfc8bc9e74b883796d970e",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/sqa-level2",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated finite element solver with documented V&V procedures. FDA in-house Python pre/post-processing scripts are version-controlled in a Git repository with tagged releases and peer-reviewed commit history. DePuy Synthes provided solver configuration files under document-controlled release. All three modeling teams maintained traceable software versions and executed regression test suites prior to study runs. Achieved Gradation 3 reflects independent cross-team software checks beyond the minimum required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/code-verification-level2",
      "rationale": "Ansys element formulations (SOLID186, CONTA174) are verified through the Ansys Verification Manual benchmark suite, including patch tests and single-element analytical comparisons. FDA team reproduced three canonical beam-bending benchmarks to within 0.3% of analytical solutions. Code verification is documented in FDA technical memo TM-2022-NCV-01. Required and achieved levels are both Gradation 2, consistent with use of a commercial solver with published verification documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/discretization-level3",
      "rationale": "A three-level mesh refinement study was performed on the pedicle screw geometry (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements). Richardson extrapolation yielded a Grid Convergence Index (GCI) of 1.4% for construct stiffness and 2.1% for yield force at the medium mesh density selected for production runs. The medium mesh was adopted as the production mesh, providing a balance between accuracy and computational cost. GCI values are below the 5% threshold specified in the acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Numerical solver error is scoped out of this credibility assessment on the basis that the nonlinear static solution employs the Ansys sparse direct solver (SPARSE) with full Newton-Raphson iteration and tight convergence tolerances (force residual < 0.1%, displacement residual < 0.1%). The sparse direct solver does not accumulate iterative round-off error in the manner of iterative solvers, and the convergence tolerances applied are two orders of magnitude below the QoI acceptance threshold of 10%. Independent verification of solver residuals was confirmed across all 11 simulation runs; no convergence warnings or divergence events were recorded. Given the deterministic nature of the sparse direct method and the confirmed tight convergence, numerical solver error contributes negligibly to total simulation uncertainty and does not materially affect the credibility conclusion. Scoping this factor out is consistent with ASME V&V 40-2018 guidance that factors with negligible influence on the QoI need not be fully assessed provided the rationale is documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/use-error-level2",
      "rationale": "Model setup procedures were documented in a detailed simulation protocol (FDA-SOP-FEA-2022-07) reviewed and approved by two independent senior analysts. Boundary conditions, contact definitions, material assignments, and load application were cross-checked against the protocol by a second analyst before each production run. No deviations from protocol were recorded. The three-team ensemble structure provides an additional safeguard against systematic user error, as independent teams applied the same protocol without coordination on intermediate results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-form-level3",
      "rationale": "The continuum FEA model employs bilinear isotropic hardening plasticity for the titanium alloy screw (Ti-6Al-4V) and linear elastic behavior for the UHMWPE vertebral body surrogate, consistent with published material characterization data. Frictional contact (μ=0.2) is applied at screw-rod and rod-block interfaces, calibrated against independent coupon-level friction experiments. Model form assumptions were evaluated through sensitivity analyses varying friction coefficient (±50%) and plasticity hardening modulus (±20%), yielding QoI sensitivity of <4%, supporting adequacy of the selected model form for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-inputs-level3",
      "rationale": "Material properties (elastic modulus, yield stress, ultimate tensile strength, hardening modulus) for Ti-6Al-4V were sourced from lot-specific tensile coupon testing performed on material from the same production lot as the test constructs (n=5 coupons per lot). UHMWPE surrogate block properties were taken from supplier certificates of conformance supplemented by in-house compression testing (n=3 per batch). Geometric dimensions were measured from coordinate measuring machine (CMM) data on three representative screws and rods. Input uncertainty was propagated via Latin hypercube sampling (1000 samples) to quantify QoI sensitivity, documented in UQ report FDA-UQ-2022-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-samples-level2",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (Lab 1: n=6, Lab 2: n=5). All constructs were assembled from the same production lot of screws and rods, with dimensional conformance verified by CMM prior to testing. UHMWPE vertebral body surrogates were from the same supplier batch. Sample traceability records (lot numbers, assembly dates, pre-test dimensional measurements) are archived in study file FDA-SF-2022-F1717-NC."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-conditions-level2",
      "rationale": "Testing was conducted under a single loading condition (ASTM F1717 static compression-bending at 5 mm/min crosshead speed, ambient temperature 23±2°C). Only one test configuration was evaluated, which limits the breadth of validation evidence and results in an achieved level of Gradation 1 against the required Gradation 2. This shortfall is acknowledged in the overall credibility assessment and is mitigated by the high consistency of results across the two independent laboratories (CV < 5% for all QoIs) and by the direct correspondence between the single test condition and the regulatory submission scenario. The overall credibility assessment remains Accepted because all other factors meet or exceed required levels and the test conditions shortfall is bounded by the inter-laboratory consistency data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters is scoped out because the validation activity is a direct simulation-to-experiment comparison in which the FEA model inputs are explicitly derived from measurements taken on the physical test constructs (lot-specific material testing, CMM geometry, same boundary conditions as the test fixture). There is therefore no meaningful distinction between 'simulation inputs' and 'test inputs' that would require a separate equivalency assessment — the inputs are the same by construction. This approach is consistent with ASME V&V 40-2018 guidance that this factor applies primarily when simulation and experimental inputs are derived from independent sources. The direct traceability of all model inputs to physical measurements of the tested constructs is documented in FDA technical memo TM-2022-EIP-01, and the input-output mapping is auditable in the archived simulation input decks. Scoping out this factor does not introduce unquantified uncertainty into the credibility conclusion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/output-comparison-level3",
      "rationale": "Quantitative output comparison was performed using the ASME V&V 10.1 validation metric E/uval for each QoI (stiffness, yield force, force at 40 mm). All three QoIs yielded E/uval < 1.96, indicating that the model-experiment difference is within combined simulation and experimental uncertainty at the 95% confidence level. Percentage differences were 3.2% (stiffness), 4.7% (yield force), and 6.1% (force at 40 mm), all within the pre-specified 10% acceptance bound. Results are tabulated in FDA-VR-2022-F1717-NC Table 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/qoi-relevance-level2",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 and correspond to the clinically relevant mechanical performance parameters used in the regulatory submission. Construct stiffness characterizes the load-sharing behavior relevant to bone healing; yield force characterizes the onset of permanent deformation relevant to device integrity; force at 40 mm characterizes post-yield energy absorption relevant to failure mode. The QoIs are identical between the validation activity and the COU, providing direct relevance without extrapolation. Achieved Gradation 3 reflects the explicit mapping of each QoI to a specific clinical failure mode documented in the design risk analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/validation-relevance-level3",
      "rationale": "The validation activity replicates the COU in all material respects: the same non-cannulated 7.5 mm screw geometry, the same ASTM F1717 test configuration, the same loading modality (static compression-bending), and the same QoIs. The FEA boundary conditions are defined to match the physical test fixture geometry as measured by CMM. The two-laboratory design provides evidence of result reproducibility beyond single-site testing. No extrapolation of validation evidence is required to apply the credibility conclusion to the COU. The ensemble of three independent modeling teams (FDA, Ansys, DePuy Synthes) further strengthens the relevance claim by demonstrating that the result is not dependent on a single analyst's modeling choices."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated pedicle screw compression-bending FEA) is accepted at Medium assurance level. Of the 13 ASME V&V 40 factors, 11 were formally assessed and 2 (Numerical solver error; Equivalency of input parameters) were scoped out with documented rationale establishing their negligible influence on the credibility conclusion. Among the 11 assessed factors, 10 met or exceeded their required credibility levels. One factor (Test conditions) achieved Gradation 1 against a required Gradation 2, reflecting the use of a single loading condition. This shortfall is bounded and mitigated: inter-laboratory coefficient of variation was below 5% for all QoIs, the single test condition is identical to the regulatory submission scenario, and all three QoIs passed the pre-specified acceptance bounds (E/uval < 1.96; percentage difference < 10%). The ensemble modeling approach across three independent teams (FDA, Ansys, DePuy Synthes) with N=11 physical constructs across two laboratories provides robust validation evidence. The overall body of evidence supports the conclusion that the FEA modeling framework adequately reproduces experimental compression-bending behavior of the non-cannulated 7.5 mm pedicle screw construct for the intended regulatory decision context.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
