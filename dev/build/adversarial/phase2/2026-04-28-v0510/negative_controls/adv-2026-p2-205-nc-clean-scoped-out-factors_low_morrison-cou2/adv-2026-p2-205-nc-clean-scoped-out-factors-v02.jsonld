  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5",
      "rationale": "Software quality assurance activities were conducted in accordance with ASME V&V 40 Gradation 3 requirements. The CFD solver (OpenFOAM v9) is under version control with documented release testing. A formal SQA plan covering code review, regression testing, and change management was executed and archived. All solver modifications for hemolysis transport were independently reviewed and unit-tested. Achieved level equals required level for MRL 5 at this decision consequence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Numerical code verification was performed using the Method of Manufactured Solutions (MMS) for the Navier-Stokes and hemolysis transport equations. Order-of-accuracy tests confirmed second-order spatial convergence on three systematically refined grids. Results were documented and archived in the project verification report. The hemolysis power-law source term implementation was independently verified against an analytical benchmark. Achieved Gradation 3 meets the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5",
      "rationale": "Discretization error was quantified using the Grid Convergence Index (GCI) methodology on three systematically refined meshes (4.2M, 12.6M, and 37.8M cells). GCI values for velocity magnitude and hemolysis index were computed at all five operating points. The fine-grid GCI for hemolysis index was below 3.2% across all conditions, satisfying the Gradation 4 threshold. Uncertainty bounds from discretization error were propagated into the Monte Carlo UQ framework. Results are documented in the mesh convergence validation result (https://uofa.net/synth/validation/mesh-convergence-study)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "Experimental test conditions for the FDA generic centrifugal pump were replicated in the CFD boundary conditions with documented fidelity. Flow rates, rotational speeds, fluid properties (blood analog: 40% glycerin-water), and temperature were matched to the experimental protocol. Inlet velocity profiles were specified using measured PIV data at the pump inlet plane. All five flow-speed combinations (2.5 L/min at 2500 RPM through 6 L/min at 3500 RPM) were simulated with boundary conditions within 1.5% of experimental set points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "Quantitative output comparison was performed between CFD predictions and experimental measurements for both velocity fields (PIV) and hemolysis index values. The validation metric used was the normalized root-mean-square error (NRMSE) with experimental uncertainty bounds explicitly incorporated. Velocity field NRMSE was 4.8% across all operating points. Hemolysis index predictions fell within the experimental uncertainty band (±18%) for 4 of 5 operating conditions; the fifth condition showed 21% deviation, within the expanded uncertainty when model-form uncertainty is included. Formal validation uncertainty analysis was completed per ASME V&V 20."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "The quantities of interest (QoI) in the validation activities — normalized index of hemolysis (NIH) and velocity magnitude distributions — are directly relevant to the COU decision quantity. NIH is the primary regulatory acceptance metric for hemolysis in VAD devices per FDA guidance. Velocity field comparison provides mechanistic evidence that the flow physics driving hemolysis (shear stress distribution, recirculation zones) are correctly predicted. The mapping from validation QoIs to COU decision QoIs is documented in the credibility assessment plan with no intermediate inference steps requiring additional justification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump geometry — the same geometry class as the device in the COU — under operating conditions spanning the full VAD operating envelope. The blood analog fluid (40% glycerin-water) has been shown to reproduce hemolytic shear response within 8% of porcine blood in prior literature. Validation was performed at the same spatial scales and flow regimes (turbulent, Re 4,000–18,000) as the COU. The achieved Gradation 4 exceeds the required Gradation 3, providing additional confidence margin for this high-consequence decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence was monitored for all simulations with residual targets of 1×10⁻⁶ for continuity and momentum equations and 1×10⁻⁷ for the hemolysis transport scalar. Convergence was confirmed by monitoring QoI values (NIH, area-averaged wall shear stress) across iterations until variation was below 0.1% over the final 500 iterations. Round-off error was assessed as negligible given double-precision arithmetic. Solver error contribution to total numerical uncertainty was quantified and incorporated into the UQ framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "Use error was controlled through a documented simulation protocol specifying mesh generation procedures, boundary condition assignment, solver settings, and post-processing steps. Two independent analysts executed the simulation workflow on separate workstations; results were compared and discrepancies resolved before final submission. Analyst qualifications (PhD-level CFD experience, minimum 5 years in cardiovascular device simulation) were documented. The simulation protocol was reviewed by a third-party subject matter expert prior to execution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "Model form uncertainty was assessed for the turbulence closure (k-ω SST) and hemolysis power-law model (Giersiepen-Wurzinger correlation). Three alternative turbulence models (k-ε realizable, RSM, LES on coarse grid) were run at two representative operating points; spread in NIH predictions was 14%, which was incorporated as model-form uncertainty in the Monte Carlo UQ. The hemolysis model form uncertainty was assessed by comparing three published power-law correlations; the 95th-percentile bound on NIH remained below the clinical threshold. Model form uncertainty is the dominant uncertainty contributor and is explicitly characterized at Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "Model input uncertainty was characterized for fluid viscosity (±5%), density (±1%), rotational speed (±0.5%), and inlet flow rate (±2%). Probability distributions were assigned based on manufacturer specifications and experimental measurement uncertainty documentation. Monte Carlo propagation (N=2,000 samples, Latin hypercube sampling) was used to propagate input uncertainties to NIH predictions. The 95th-percentile NIH remained 12% below the clinical acceptance threshold across all five operating conditions, confirming that input uncertainty does not invalidate the acceptance decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5",
      "rationale": "The Test samples factor addresses variability in physical test specimens used in validation experiments (e.g., pump-to-pump geometric variability, surface finish variation, assembly tolerances). This factor has been scoped out of the present credibility assessment on the following basis: (1) The FDA generic centrifugal pump used in all validation experiments is a standardized reference geometry manufactured by a single vendor to tight tolerances (±0.05 mm on all critical dimensions), with dimensional inspection reports confirming that all three physical specimens used in PIV and hemolysis experiments fell within this tolerance band. Pump-to-pump geometric variability is therefore negligible relative to other uncertainty sources. (2) The validation dataset was generated using a single well-characterized specimen for hemolysis measurements and a separate geometrically verified specimen for PIV; cross-specimen comparison at two overlapping operating points showed NIH agreement within 3.1%, confirming specimen-to-specimen reproducibility. (3) Incorporating a formal Test samples gradation assessment would require a dedicated multi-specimen experimental campaign that is outside the scope and resource envelope of this COU2 assessment; the existing evidence is sufficient to bound specimen variability contribution to total uncertainty at less than 5% of the NIH prediction interval. This scoping decision is consistent with ASME V&V 40 Section 6.4 guidance permitting factor scoping when the factor contribution to decision uncertainty is demonstrably negligible and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/equivalency-inputs-mrl5",
      "rationale": "The Equivalency of input parameters factor addresses whether the input parameters used in validation experiments are equivalent to those in the COU (i.e., whether the validation and COU share sufficiently similar boundary conditions, fluid properties, and operating regimes to support extrapolation of validation evidence). This factor has been scoped out on the following basis: (1) The validation experiments were conducted on the FDA generic centrifugal pump at operating conditions that directly overlap with the five COU flow-speed combinations; no extrapolation beyond the validated operating envelope is required. The COU operating points (2.5–6 L/min, 2500–3500 RPM) are fully bracketed by the validation dataset, making a separate equivalency assessment redundant with the Relevance of validation activities factor (assessed at Gradation 4 above). (2) Fluid property equivalency between the blood analog (40% glycerin-water) and clinical blood has been established in the peer-reviewed literature cited in this assessment (DOI: 10.1115/1.4034830), which provides viscometric and hemolytic shear-response equivalency data. Repeating this literature-established equivalency determination as a standalone gradation exercise would not add new information to the credibility argument. (3) The scoping of this factor is bounded: if future COU revisions extend the operating envelope beyond the validated range, or substitute a different blood analog, this factor must be reinstated and formally assessed. This condition is documented in the credibility assessment plan as a re-evaluation trigger. The scoping decision is consistent with ASME V&V 40 Section 6.4 and does not reduce the overall credibility argument given the overlapping coverage provided by the assessed Relevance factors."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis absolute prediction, MRL 5, Class III) is accepted on the following grounds. Eleven of thirteen credibility factors were formally assessed; all eleven achieved levels meeting or exceeding required levels for MRL 5. Two factors — Test samples and Equivalency of input parameters — were scoped out with documented rationale establishing that their contribution to decision uncertainty is negligible and that existing evidence bounds their influence. The scoping rationale for both factors was reviewed by the assessment team and an independent subject matter expert and found consistent with ASME V&V 40 Section 6.4 guidance. Monte Carlo uncertainty quantification (N=2,000, LHS) was performed propagating input, discretization, solver, and model-form uncertainties to the NIH prediction. The 95th-percentile NIH across all five operating conditions remained at least 12% below the absolute clinical acceptance threshold, providing a positive credibility margin. Validation evidence from PIV velocity comparison (NRMSE 4.8%) and hemolysis index comparison (within experimental uncertainty for 4/5 conditions, within expanded uncertainty including model-form for 5/5 conditions) supports the conclusion that the CFD model is fit for the intended use. The provenance chain from raw experimental data through validation results to this UoA is complete and archived. The decision is Accepted; the model may be used as the primary basis for hemolysis acceptance submission for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
