  "signature": "ed25519:49b35a3db2332abc1a79803df214524fe1ab27c559058b2938dd0c69aaf7dd2cae0f180ae0aec4ecd4cbb064ecaa1678199f1d33e64430ff19125828ead96904",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-criteria-001",
      "rationale": "CFD solver (ANSYS Fluent 2023 R1) operates under ISO 9001:2015 QMS. Full V&V test suite with regression testing documented in vendor quality plan. In-house pre- and post-processing scripts version-controlled in Git with automated unit tests achieving 94% code coverage. Independent code review completed by second analyst. Achieved level 4 exceeds required level 3 for MRL 5 with high-consequence decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5-criteria-001",
      "rationale": "Method of manufactured solutions (MMS) applied to Navier-Stokes solver confirming second-order spatial convergence. Benchmark cases from FDA critical path initiative (nozzle, backward-facing step) reproduced within published tolerances. Hemolysis power-law implementation verified against analytical solutions for simple shear flows. All verification activities documented in code verification report CVR-2024-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5-criteria-001",
      "rationale": "Three-level mesh refinement study conducted with coarse (2.1M), medium (8.4M), and fine (33.6M) element meshes. Richardson extrapolation applied; GCI fine = 1.3% for NIH, 1.8% for wall shear stress. Meshes confirmed in asymptotic convergence range (ratio 1.02). Temporal convergence verified with CFL < 0.8 throughout domain. Discretization uncertainty formally quantified and propagated to final hemolysis predictions via Monte Carlo ensemble."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5-criteria-001",
      "rationale": "In-vitro hemolysis experiments conducted at all 5 target flow-speed combinations (3, 4.5, 6 L/min at 2400 RPM; 4.5, 6 L/min at 3200 RPM). Blood analog fluid properties (viscosity, density) measured and matched to computational inputs within 1.5%. Pump geometry confirmed via CMM inspection against CAD nominal. Inlet and outlet boundary conditions measured with calibrated transducers (NIST-traceable). Environmental conditions (temperature 37±0.5°C) controlled and logged throughout testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5-criteria-001",
      "rationale": "Quantitative comparison metrics computed for all 5 operating points: mean absolute error 11.2% for NIH, RMSE 0.0023 g/100L. Validation uncertainty (Uval) computed per ASME V&V 20 combining experimental and numerical uncertainties. E/Uval < 1 at all operating points confirming predictions within combined uncertainty. Separate comparison of velocity profiles against PIV data shows R² > 0.97 at all measurement planes. Achieved level 5 reflects comprehensive quantitative comparison with formal uncertainty-based acceptance metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5-criteria-001",
      "rationale": "Primary QOI is normalized index of hemolysis (NIH) in g/100L, the clinically accepted metric for blood pump hemolysis assessment per ASTM F1841. Secondary QOIs (wall shear stress distribution, exposure time histograms) directly inform hemolysis mechanism. NIH is the regulatory-accepted surrogate for in-vivo hemolysis. QOI traceability matrix links each computational output to clinical acceptance criterion. Sensitivity analysis confirms NIH is the dominant factor in regulatory decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5-criteria-001",
      "rationale": "Validation experiments performed on identical pump geometry (FDA generic centrifugal pump) under identical operating conditions to COU. Blood analog fluid (glycerin-water) properties matched to physiologic blood at 37°C. All 5 COU operating points directly validated — no extrapolation required. Validation hierarchy spans from component level (impeller passage) to system level (full pump assembly). Relevance gap analysis documents no unvalidated physics pathways for the COU hemolysis prediction task."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5-criteria-001",
      "rationale": "Iterative convergence monitored for all simulations; residuals reduced by 6 orders of magnitude and all monitored quantities (NIH, pressure rise, torque) stable to < 0.1% over final 500 iterations. Floating-point precision: double precision throughout. Round-off error estimated via interval arithmetic to be negligible (< 0.01% of discretization error). Solver log files archived for all 5 operating point simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5-criteria-001",
      "rationale": "Simulation setup reviewed independently by second qualified CFD analyst. Boundary condition application, turbulence model selection (SST k-ω), and hemolysis model implementation verified against documented simulation plan SP-2024-002. Checklist-based review protocol applied per internal SOP-CFD-007. No discrepancies identified. Results reproducibility confirmed by independent re-run of one operating point by second analyst, achieving < 0.5% difference in NIH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5-criteria-001",
      "rationale": "SST k-ω turbulence model selected based on literature benchmark showing best performance for confined rotating flows relevant to centrifugal pumps. Power-law hemolysis model (Giersiepen et al. modified by Heuser-Opitz) validated against published RBC lysis data across relevant shear stress and exposure time ranges. Model form uncertainty quantified by comparing three turbulence models (SST k-ω, realizable k-ε, RSM); spread in NIH predictions < 8% incorporated into total uncertainty budget. Rotating reference frame (MRF) approach validated against full sliding mesh for steady operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5-criteria-001",
      "rationale": "All model inputs characterized with probability distributions for Monte Carlo UQ: fluid viscosity (normal, CV=2%), fluid density (normal, CV=0.5%), hemolysis model coefficients (uniform bounds from literature range), inlet velocity profile (normal, CV=3%), rotational speed (normal, CV=0.5%). 10,000-sample Monte Carlo ensemble executed on HPC cluster. Input uncertainty propagation yields 95% CI on NIH of ±18% at worst-case operating point. All inputs traceable to NIST-calibrated measurement records or peer-reviewed literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5-criteria-001",
      "rationale": "Three independent hemolysis test replicates performed at each of the 5 operating points (15 total experiments). Fresh porcine blood used within 6 hours of collection; hematocrit 33±2% confirmed by centrifugation. Inter-replicate coefficient of variation < 12% across all operating points. Sample preparation protocol follows ASTM F1841-97 guidance. Statistical power analysis confirmed n=3 replicates sufficient to detect 20% difference in NIH at 80% power."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5-criteria-001",
      "rationale": "Computational input parameters mapped to experimental conditions via equivalency matrix. Fluid rheology: blood analog viscosity matched to physiologic blood at 37°C within 3%. Geometry: pump CAD model confirmed against manufactured part via CMM (max deviation 0.08 mm). Operating conditions: flow rate and rotational speed set to match computational boundary conditions within 1% using calibrated flow meters and tachometers. Equivalency gaps documented and their contribution to validation uncertainty formally quantified."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and achieved levels meet or exceed required levels for Model Risk Level 5. The CFD model demonstrates sufficient credibility to predict absolute hemolysis levels for the Class III VAD device across all 5 target operating conditions. Key evidence: (1) Quantitative output comparison shows E/Uval < 1 at all operating points with formal uncertainty accounting per ASME V&V 20; (2) Monte Carlo UQ with 10,000 samples propagates all identified input uncertainties through the model; (3) 95% confidence interval upper bounds on NIH predictions remain below the clinical acceptance threshold at all operating points; (4) Mesh convergence confirmed with GCI < 2%; (5) Independent analyst review confirms no use errors; (6) Validation activities directly cover all COU operating conditions with no extrapolation. The structured evidence chain from foundational verification through system-level validation supports the decision to accept the model for the stated context of use. No credibility gaps remain unresolved.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
