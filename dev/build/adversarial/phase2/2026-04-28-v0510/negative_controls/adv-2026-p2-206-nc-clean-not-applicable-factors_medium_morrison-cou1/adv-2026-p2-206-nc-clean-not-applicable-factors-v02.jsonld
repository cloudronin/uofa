  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-mrl2",
      "rationale": "ANSYS Fluent 2023 R1 is a commercially validated CFD solver with documented V&V reports, release notes, and regression test suites. Version control and configuration management procedures are documented in the project quality plan. SQA level 2 achieved, exceeding MRL 2 requirement of level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-mrl2",
      "rationale": "Solver verification performed via method-of-manufactured-solutions (MMS) for the incompressible Navier-Stokes equations. Spatial and temporal convergence confirmed at second-order accuracy. Published ANSYS verification benchmarks for rotating machinery supplement in-house MMS results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-mrl2",
      "rationale": "Grid convergence index (GCI) study performed on three systematically refined meshes (4.2M, 11.8M, 31.4M cells) following Celik et al. (2008) procedure. GCI for hemolysis index QoI is 4.1% on the fine mesh. Wall y+ maintained below 5 on all blood-contacting surfaces. Richardson extrapolation confirms asymptotic convergence. Achieved level 3 exceeds required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-mrl2",
      "rationale": "Bench-loop hemolysis experiments conducted at 37 °C with porcine blood (hematocrit 33 ± 2%) under ISO 10628-compliant conditions. Five operating points (3–6 LPM, 2500–3500 RPM) match the CFD boundary conditions within documented uncertainty bounds. Temperature, viscosity, and density uncertainty quantified and propagated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-mrl2",
      "rationale": "Normalized index of hemolysis (NIH) predicted by CFD compared against bench measurements using validation metric U_val per ASME V&V 20. Agreement within combined experimental and numerical uncertainty bands at all five operating points. Maximum relative error 8.3%, within the 15% acceptance threshold established in the validation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-mrl2",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) and relative hemolysis index (RH) — directly correspond to the regulatory acceptance criterion (RH < 1 versus predicate device). Secondary QoI (shear stress distribution, exposure time histogram) provide mechanistic traceability. QoI selection reviewed and approved by the clinical team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-mrl2",
      "rationale": "Validation experiments performed on the identical FDA generic pump geometry under physiologically representative CPB flow conditions. Validation domain fully overlaps the COU operating envelope (flow rates 3–6 LPM, speeds 2500–3500 RPM). Fluid properties (porcine blood, 37 °C) are representative of clinical use. Achieved level 3 reflects high geometric and operational fidelity between validation and COU contexts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-mrl2",
      "rationale": "Iterative convergence confirmed by monitoring residuals to below 1e-5 for all transport equations and by tracking integrated QoI (NIH, torque, pressure head) to less than 0.1% change over final 500 iterations. Round-off error assessed as negligible at double-precision arithmetic. Solver error contribution to total uncertainty budget is less than 0.5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-mrl2",
      "rationale": "Simulation setup reviewed by a second qualified analyst following the project simulation plan. Boundary condition inputs, turbulence model selection (SST k-omega), and hemolysis power-law model parameters independently verified against published literature values. Checklist-based review completed and archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-mrl2",
      "rationale": "Reynolds-averaged Navier-Stokes (RANS) with SST k-omega turbulence closure selected based on published benchmark performance for confined rotating flows. Giersiepen-Wurzinger hemolysis power-law model calibrated to porcine blood data. Model form uncertainty estimated via comparison with LES results at one operating point; RANS NIH within 11% of LES, within accepted tolerance for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-mrl2",
      "rationale": "All model input parameters (fluid density, viscosity, pump geometry, rotational speed, inlet flow rate) sourced from traceable measurements with documented uncertainty. Sensitivity analysis performed via one-at-a-time perturbation across ±2-sigma input ranges. Viscosity and hematocrit identified as most influential inputs; their uncertainty contributions are explicitly included in the total uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-na",
      "rationale": "This factor addresses patient-population or implant-sample variability characterization required under NASA-STD-7009 and certain structural fatigue V&V frameworks. In the present ASME V&V 40 medical-device CFD context, the validation experimental program uses a single well-characterized pump geometry with controlled fluid properties; no multi-sample population inference is performed. The factor is therefore outside the scope of this assessment and is marked not-applicable per Section 5.3 of ASME V&V 40-2018."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/equivalency-inputs-na",
      "rationale": "Equivalency of input parameters as a standalone credibility factor applies primarily to multi-physics co-simulation environments where separate codes exchange boundary data and parameter equivalency across code interfaces must be demonstrated. This assessment involves a single-code CFD simulation with no inter-solver coupling; all inputs are directly specified and verified within the single simulation environment. The factor is therefore not applicable to this COU per ASME V&V 40-2018 Section 5.3 scoping guidance."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) All 11 assessed credibility factors meet or exceed their required levels — no factor falls below its MRL-2 threshold. Three factors (discretization error, relevance of validation activities, numerical code verification) exceed requirements, providing additional confidence margin. (2) Two factors (test samples, equivalency of input parameters) are marked not-applicable with documented rationale confirming they are outside the scope of this single-code, single-geometry V&V 40 assessment; this scoping decision is consistent with ASME V&V 40-2018 Section 5.3 and does not represent an unassessed gap. (3) The validation evidence base is complete and traceable: three ValidationResults (PIV velocity field, hemolysis bench comparison, pressure-head curve) each carry comparedAgainst references to measured datasets, provenance links to the generating activities, and uncertainty quantification records. Maximum hemolysis prediction error of 8.3% falls within the pre-specified 15% acceptance threshold. (4) The GCI-based discretization uncertainty (4.1%) and the propagated input uncertainty (dominated by viscosity and hematocrit, combined 6.2%) are explicitly quantified and included in the total uncertainty budget, confirming that the NIH predictions remain below the RH < 1 acceptance criterion even at the 95th-percentile uncertainty bound. (5) Provenance is fully documented from raw PIV and bench-loop measurements through data reduction, simulation execution, and QoI extraction to the final comparison metrics. The assessment team concludes that the model has sufficient credibility for its intended use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
