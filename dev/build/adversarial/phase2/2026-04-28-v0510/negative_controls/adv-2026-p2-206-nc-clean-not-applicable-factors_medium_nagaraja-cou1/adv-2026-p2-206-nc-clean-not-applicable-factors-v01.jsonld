  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-level2",
      "rationale": "Ansys Mechanical 2022 R2 and the FDA in-house FEA code are both operated under documented software quality assurance plans conforming to 21 CFR Part 820 and ISO 9001. Version-controlled input decks, regression test suites, and release notes are archived. Achieved Gradation 2: documented SQA plan with regression testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-level2",
      "rationale": "Benchmark patch tests and manufactured-solution comparisons were executed for both the FDA and Ansys solvers on beam-column and contact problems representative of the pedicle screw geometry. Results match analytical solutions to within 0.3% for linear elastic cases and 1.1% for nonlinear contact, confirming Gradation 2 code verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-level2",
      "rationale": "Mesh convergence study performed across three refinement levels (coarse 0.8 mm, medium 0.5 mm, fine 0.3 mm element size at screw-rod interface). Richardson extrapolation yields a Grid Convergence Index of 1.4% for stiffness QoI and 1.9% for yield force, both below the 5% threshold. Production mesh uses medium refinement. Achieved Gradation 3: formal GCI-based convergence documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-level1",
      "rationale": "Iterative solver residuals monitored per load step; force and displacement residuals converge below 1e-5 relative tolerance. Nonlinear Newton-Raphson iterations reach equilibrium within 8 iterations per step. No divergence or spurious oscillations observed across all 11 model instances. Achieved Gradation 2, exceeding required Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-level2",
      "rationale": "Model setup checklist and independent peer review conducted by a second analyst at FDA OSEL. Boundary conditions, material assignments, contact definitions, and load application reviewed against ASTM F1717 test fixture geometry. No discrepancies identified. Gradation 2: independent review completed and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-level2",
      "rationale": "Linear elastic titanium alloy (Ti-6Al-4V) material model with nonlinear contact at screw-rod and rod-block interfaces. Model form justified by prior literature showing elastic-dominant response below yield; plasticity model evaluated and shown to add <2% change in stiffness QoI. Frictional contact coefficients from published tribology data. Gradation 2: model form assumptions documented with supporting evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-level2",
      "rationale": "Material properties (E = 114 GPa, nu = 0.34) sourced from coupon testing of the same Ti-6Al-4V bar stock used in manufacturing. Geometry from calibrated CMM measurements of 3 production screws (mean dimensions used; variability propagated via sensitivity analysis). Torque preload on set screws measured per ASTM F1717 protocol. Gradation 3: inputs from direct measurement with uncertainty quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-level2",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested; all from the same manufacturing lot as the design under evaluation. Sample traceability documented with lot numbers and dimensional inspection records. Two independent laboratories conducted testing to assess inter-laboratory variability. Gradation 2: representative production samples with documented traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-level2",
      "rationale": "Testing conducted under a single loading condition (ASTM F1717 standard compression-bending configuration at 5 mm/min crosshead speed, ambient temperature). Only one test condition explored; no variation in loading rate, temperature, or fixture offset was included. This limits the factor to Gradation 1, which is below the required Gradation 2. This shortfall is noted and accepted given that ASTM F1717 is a standardized regulatory test and the COU is specifically scoped to this single configuration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/equivalency-inputs-level2",
      "rationale": "Model input parameters (geometry, material properties, boundary conditions, applied torque) verified to correspond to the physical test specimens via direct measurement comparison. CMM data for each of the 11 test specimens compared to model geometry; maximum deviation 0.04 mm. Torque preload verified with calibrated torque wrench records. Gradation 2: systematic parameter equivalency verification documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-level2",
      "rationale": "Quantitative comparison using the ASME V&V 40 validation metric E/uval. For all three QoIs: stiffness E/uval = 0.87 (< 1.96), yield force E/uval = 1.12 (< 1.96), force at 40 mm E/uval = 1.44 (< 1.96). Percentage differences: stiffness 4.2%, yield force 6.8%, force at 40 mm 8.1%, all within the pre-established 10% acceptance bound. Gradation 3: formal validation metric with uncertainty quantification applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-level2",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the primary outputs specified in ASTM F1717 and directly relevant to the regulatory submission claim. These QoIs are clinically meaningful as they characterize the structural performance envelope of the pedicle screw system under worst-case physiological loading analogs. Gradation 2: QoIs formally justified against COU requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-level2",
      "rationale": "The validation activity directly replicates the COU: the same non-cannulated 7.5 mm screw design, same ASTM F1717 test configuration, same loading regime, and same FEA modeling framework are used in both the validation and the intended regulatory submission. No extrapolation from a surrogate geometry or different loading mode is required. Gradation 2: direct correspondence between validation activity and COU documented."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated 7.5 mm pedicle screw, ASTM F1717 compression-bending) is accepted at Medium assurance level based on the following structured evidence: (1) All three primary QoIs meet the pre-established acceptance bounds with E/uval values of 0.87, 1.12, and 1.44, all below the 1.96 threshold, and percentage differences of 4.2%, 6.8%, and 8.1%, all below the 10% bound. (2) Eleven of thirteen V&V 40 factors meet or exceed their required gradation levels. (3) One factor (Test conditions) is below required level at Gradation 1 vs. required Gradation 2; this shortfall is accepted because the COU is explicitly scoped to the single ASTM F1717 standardized configuration and no regulatory or clinical need exists to validate across multiple loading conditions for this submission. (4) Two factors were evaluated for applicability: 'Numerical solver error' and 'Use error' were both assessed (not scoped out) and met requirements. The provenance chain is complete from bench test raw data through FEA simulation outputs to the validation metric computation. The decision consequence is Medium and model influence is Medium, yielding a Model Risk Level of 3, which is consistent with the Medium assurance level achieved. The assessment team concludes the FEA modeling framework is sufficiently credible for its intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
