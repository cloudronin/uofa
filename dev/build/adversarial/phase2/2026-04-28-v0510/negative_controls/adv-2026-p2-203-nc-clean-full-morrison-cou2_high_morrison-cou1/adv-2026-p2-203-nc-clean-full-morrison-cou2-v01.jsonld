  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-mrl5-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the Morrison COU2 CFD hemolysis prediction model at MRL 5 is accepted based on the following structured evidence: (1) All 13 ASME V&V 40 credibility factors have been assessed and achieve requiredLevel 5. No factor is scoped out or not-assessed. (2) Software quality assurance is at the highest level with full IQ/OQ documentation, version control, and automated regression testing. (3) Code verification via MMS demonstrates second-order spatial convergence for all governing equations, confirming correct numerical implementation. (4) Discretization error is rigorously bounded: GCI_fine = 0.8% for the primary QoI; the production mesh is confirmed in the asymptotic convergence range. (5) Iterative and round-off solver errors are negligible relative to discretization error; all residuals converge to < 1×10⁻⁶. (6) Model form uncertainty is quantified via Bayesian model averaging; the selected SST k-ω / Zhang hemolysis model combination achieves the best validation performance across all QoIs. (7) All model inputs are characterised with probability distributions from experimental data; global sensitivity analysis (Sobol indices, N=2000) identifies hemolysis exponent α and clearance gap as dominant contributors and confirms no unexpected input sensitivities. (8) Validation activities are conducted on the identical device geometry under COU-representative operating conditions, achieving quantitative validation metric V ≥ 0.90 for all primary QoIs. (9) The 95th-percentile HI from the full UQ ensemble (RH = 0.87) remains below the regulatory acceptance criterion (RH < 1.0) with margin. (10) All provenance chains are complete: every ValidationResult links to its experimental dataset, generating activity, and UQ record. (11) Use error controls (automated workflow, four-eyes review, 47-item checklist) are documented and executed. (12) Three independently manufactured specimens provide statistical coverage of manufacturing variability; inter-specimen HI variability (CV = 4.1%) is within the UQ budget. The totality of evidence supports a high-confidence acceptance decision for the intended regulatory use of this CFD model to identify worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
