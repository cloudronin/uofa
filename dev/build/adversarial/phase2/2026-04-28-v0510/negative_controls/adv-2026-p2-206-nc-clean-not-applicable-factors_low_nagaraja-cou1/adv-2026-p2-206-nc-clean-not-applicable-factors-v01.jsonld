  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/sqa-level2",
      "rationale": "The FEA software (Ansys Mechanical 2022 R2) is commercially validated, FDA-recognized, and operated under a documented software quality management plan conforming to 21 CFR Part 820 and ISO 13485. Version-controlled input files and output logs are archived. Achieved Gradation 3 (formal SQA plan with documented testing) against required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/code-verification-level2",
      "rationale": "Benchmark problems from the Ansys Verification Manual (VM1, VM6, VM12) covering linear elastic beam bending were executed and results compared against analytical solutions. All benchmark errors were below 0.5%, confirming correct implementation of the solver for the relevant physics. Required and achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/discretization-error-level2",
      "rationale": "A formal mesh convergence study was conducted using three systematically refined meshes (coarse: 85k elements, medium: 340k elements, fine: 1.36M elements) following ASME V&V 10.1 Richardson extrapolation. The Grid Convergence Index (GCI) for stiffness QoI was 0.8%, well below the 5% threshold. Production mesh is the medium refinement. Achieved Gradation 3 against required Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/solver-error-level1",
      "rationale": "Static implicit analysis with direct sparse solver (SPARSE) was used; no iterative convergence tolerance issues apply. Force and displacement residuals monitored; all solutions converged with residual norms below 1e-8. Contact stabilization energy verified to be less than 0.1% of total strain energy. Required Gradation 1; achieved Gradation 2 due to explicit residual monitoring documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/use-error-level2",
      "rationale": "Model setup was performed by a credentialed FEA analyst and independently reviewed by a second analyst. Boundary conditions, material assignments, and contact definitions were documented in a model setup checklist and cross-checked against the ASTM F1717 test fixture geometry. No discrepancies found. Achieved Gradation 2 as required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-form-level3",
      "rationale": "Continuum linear-elastic model with nonlinear contact is appropriate for the titanium alloy pedicle screw construct under monotonic quasi-static loading to yield. Large-deformation formulation (NLGEOM ON) captures geometric nonlinearity at 40 mm displacement. Material model validated against coupon tensile data; Ti-6Al-4V elastic modulus 114 GPa ± 3 GPa consistent with literature. Plasticity model (bilinear isotropic hardening) calibrated to manufacturer material certificates. Required and achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-inputs-level3",
      "rationale": "All geometric inputs derived from calibrated CMM measurements of the physical test specimens (tolerance ±0.005 mm). Material properties sourced from manufacturer material certificates and independently confirmed via coupon testing. UHMWPE block properties (E = 1.0 GPa, ν = 0.4) taken from published ASTM F648 data. Sensitivity analysis performed on ±10% perturbation of all material inputs; QoI sensitivity coefficients documented. Required and achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-samples-level3",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA OSEL and contract lab). All specimens from the same production lot; dimensional inspection confirmed conformance to drawing. Sample size justification based on ASTM E122 power analysis targeting 80% power to detect 10% QoI difference. Required and achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-conditions-level3",
      "rationale": "Testing performed strictly per ASTM F1717 at a single loading rate (5 mm/min) and single environmental condition (ambient temperature, dry). While the standard specifies a single test condition, Gradation 3 would require multi-condition characterization. Only one test condition was explored; this factor is below the required level. Risk accepted by the credibility assessment team given the deterministic nature of the standard and the conservative single-condition comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/equivalency-inputs-level3",
      "rationale": "A formal mapping table was constructed linking each model input parameter to its experimental counterpart. Geometric dimensions, material properties, boundary condition displacements, and fixture stiffness were all confirmed to be equivalent between model and experiment within measurement uncertainty. Fixture compliance was measured and incorporated into the model as a spring element. Required and achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/output-comparison-level3",
      "rationale": "Quantitative comparison performed using the ASME V&V 40 validation metric E/uval for all three QoIs (stiffness, yield force, force at 40 mm). All E/uval values below 1.96 (95% confidence threshold). Additionally, full load-displacement curves compared graphically and via area-under-curve metric. Prediction intervals computed and experimental data confirmed to lie within model 95% prediction bounds. Achieved Gradation 4 against required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/qoi-relevance-na",
      "rationale": "This factor addresses whether the QoIs selected for the validation activity are relevant to the clinical or regulatory decision. In COU1, the validation activity IS the regulatory submission artifact: the QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly mandated by ASTM F1717 and FDA guidance for pedicle screw submissions. There is no additional layer of clinical translation required — the standard defines the QoIs as the acceptance criteria for device clearance. Accordingly, this factor is not-applicable in the sense that QoI relevance is externally fixed by the applicable standard and regulatory pathway; no further assessment is needed or possible within this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/validation-relevance-na",
      "rationale": "This factor is intended to assess whether validation activities conducted in a different context (e.g., a prior study, a surrogate geometry, or a different loading mode) are sufficiently relevant to be extrapolated to the COU. In COU1, the validation activity is conducted directly on the identical device geometry, material, and loading protocol as the COU itself — there is no extrapolation from a separate validation context. The validation IS the COU activity. Therefore, this factor does not apply: the question of cross-context relevance is moot when validation and use context are identical by construction."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Eleven factors were formally assessed: ten met or exceeded their required gradation levels, and one (Test conditions) achieved Gradation 2 against a required Gradation 3. This shortfall was accepted because ASTM F1717 mandates a single test condition, making multi-condition characterization infeasible within the standard's scope, and the single-condition comparison is conservative for the intended regulatory use. Two factors (Relevance of the quantities of interest; Relevance of the validation activities to the COU) were marked not-applicable with explicit rationale: QoI relevance is externally fixed by ASTM F1717 and FDA guidance, and validation-to-COU relevance is moot because the validation activity is conducted in an identical context to the COU with no extrapolation required. All three ValidationResults (stiffness, yield force, force at 40 mm displacement) satisfy the pre-specified acceptance bounds: QoI differences below 10% and E/uval below 1.96. Provenance is complete from foundational bench data through FEA predictions to quantitative comparison metrics. The overall credibility of the FEA model for the stated COU is assessed as sufficient to support regulatory submission at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
