  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-level2",
      "rationale": "Ansys Mechanical 2022 R2 employed under ISO 9001-compliant QMS with documented installation qualification, version control, and regression test suite covering all element types used. FDA FEA tool independently verified. Achieved Level 3 exceeds required Level 2 for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-level2",
      "rationale": "Benchmark verification performed against NAFEMS standard problems LE1 and LE10 for solid continuum elements and beam-contact benchmarks. Residual norms confirmed below 1e-6. Achieved Level 3 satisfies the Level 2 requirement for this risk tier."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-level3",
      "rationale": "Systematic mesh convergence study conducted with three refinement levels (coarse, medium, fine) for screw shank, head, and rod geometry. Richardson extrapolation applied; GCI < 1.2% for stiffness QoI and < 2.1% for yield force QoI. Final mesh selected at medium refinement where further refinement changes QoI by < 0.5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-level2",
      "rationale": "Nonlinear static analysis with arc-length continuation. Force and displacement residuals monitored; convergence tolerance 1e-4 (force) and 1e-5 (displacement). Energy balance checked at each load step. No divergence events observed across all 11 simulation replicates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-level2",
      "rationale": "Model built and run by two independent analysts following a documented simulation protocol (SOP-FEA-001). Independent peer review of boundary conditions, material assignments, and contact definitions performed. Discrepancies resolved prior to final submission. Achieved Level 3 through dual-analyst independent execution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-level3",
      "rationale": "Continuum elastoplastic constitutive model (bilinear isotropic hardening) selected for Ti-6Al-4V screw and rod. Model form justified by published tensile coupon data and prior FDA validation studies. Friction-based contact at screw-rod and rod-block interfaces validated against published contact benchmarks. Sensitivity analysis confirms QoI insensitive to ±10% variation in tangent modulus."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-level3",
      "rationale": "Material properties (E = 114 GPa, σ_y = 880 MPa, E_t = 5 GPa) sourced from ASTM F136-13 and manufacturer certificates of conformance. Geometric inputs derived from calibrated CMM measurements of test articles (±0.01 mm). Friction coefficient (μ = 0.2) from published UHMWPE-titanium tribology literature. Parametric sensitivity study performed; stiffness QoI uncertainty ±3.2% from combined input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-level3",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH biomechanics lab, DePuy Synthes test facility). Constructs manufactured from same production lot; dimensional verification by CMM confirms all within drawing tolerances. Coefficient of variation for stiffness across specimens is 4.1%, consistent with expected manufacturing variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-level3",
      "rationale": "Testing performed per ASTM F1717-15 protocol at a single load rate (5 mm/min quasi-static) and single environmental condition (ambient, 23°C). Only one test configuration assessed; multi-condition coverage not achieved. Achieved Level 2 is below the required Level 3, representing a documented credibility gap acknowledged in the decision record. The gap is accepted given that the COU is restricted to quasi-static ambient conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/equivalency-inputs-level3",
      "rationale": "Direct correspondence established between FEA model inputs and experimental test article parameters. CMM measurements used to set FEA geometry; material certificates used to set constitutive parameters. Fixture geometry in FEA matches ASTM F1717 fixture drawings verified against laboratory fixture CMM data. All 11 specimen-specific FEA models initialized with specimen-specific dimensional measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-level3",
      "rationale": "Quantitative comparison metric E/uval computed for all three QoIs (stiffness, yield force, force at 40 mm). All E/uval values below 1.96 acceptance threshold: stiffness E/uval = 1.21, yield force E/uval = 0.87, force-at-40mm E/uval = 1.43. Percentage differences all below 10% pre-specified bound. Graphical force-displacement overlay confirms shape agreement throughout loading history."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-level3",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the predicate device 510(k) submission and directly correspond to the regulatory decision criteria for pedicle screw mechanical performance. QoI selection justified by biomechanical rationale linking construct stiffness to clinical fusion outcomes and yield force to implant fracture risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-level3",
      "rationale": "Validation activities directly replicate the COU: same device geometry (non-cannulated 7.5 mm pedicle screw), same test standard (ASTM F1717), same loading mode (static compression-bending), same QoIs. No extrapolation beyond validated domain required for the regulatory submission. COU boundary conditions are a proper subset of the validation experimental conditions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated 7.5 mm pedicle screw, ASTM F1717 static compression-bending) is accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed their required credibility levels. The single shortfall — Test conditions (achieved Level 2 vs. required Level 3) — is accepted because the COU is explicitly bounded to quasi-static ambient conditions matching the single test configuration employed; no regulatory claim is made for other loading rates or environmental conditions. All three QoIs (stiffness, yield force, force at 40 mm displacement) satisfy the pre-specified acceptance bounds: E/uval < 1.96 and percentage difference < 10%. The validation dataset spans N=11 specimens across two independent laboratories, providing adequate statistical power for the Medium consequence decision. Provenance is fully traceable from raw experimental records through uncertainty quantification to final comparison metrics. The FEA modeling framework is deemed credible for supporting the 510(k) regulatory submission for the non-cannulated pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
