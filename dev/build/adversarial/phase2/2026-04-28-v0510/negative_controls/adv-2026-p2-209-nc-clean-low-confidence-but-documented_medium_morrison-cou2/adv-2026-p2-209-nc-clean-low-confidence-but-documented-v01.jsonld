  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-class3",
      "rationale": "SQA documentation confirms version-controlled solver (ANSYS Fluent 2023 R2), regression test suite with 94% pass rate, and audit trail for all simulation inputs. Achieved Gradation 3 satisfies MRL 5 requirement. Confidence is moderate given that one regression test category (non-Newtonian rheology) has limited coverage; this gap is documented in the SQA report and accepted as residual risk with compensating controls (manual verification of rheology inputs per run)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Method of manufactured solutions (MMS) applied to Navier-Stokes solver; observed order of accuracy 1.92 (expected ~2.0 for second-order scheme). Marginal deviation from theoretical order documented honestly; attributed to boundary treatment at curved walls. Achieved level 3 meets required level 3. Confidence explicitly rated LOW-MODERATE; the 4% order-of-accuracy deficit is flagged as a known numerical artefact and monitored through mesh refinement studies."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5",
      "rationale": "GCI on fine mesh = 6.8% for NIH, 4.1% for bulk velocity. Richardson extrapolation performed across three mesh levels with asymptotic convergence confirmed (GCI ratio 1.04). Wide uncertainty bounds arise from turbulence model sensitivity (k-omega SST vs. RSM yields ±9% spread in NIH); this is documented explicitly in the UQ report. Achieved level 3 meets required level 3. Residual discretization uncertainty accepted given conservative bias direction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "Bench test conditions (fluid temperature 37±0.5°C, hematocrit 33±2%, anticoagulant protocol) documented with full traceability to laboratory protocols. Confidence rated MODERATE: temperature control uncertainty contributes ±3% to viscosity and ±5% to NIH per sensitivity analysis. All test condition uncertainties propagated through Monte Carlo UQ; resulting wide NIH prediction intervals (±38% at 95% CI) are reported transparently. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "NIH predictions compared against 5 bench operating points using quantitative metrics: mean absolute percentage error 14.2%, maximum error 31.7% at low-flow high-speed condition. Confidence explicitly LOW at low-flow condition due to recirculation zone sensitivity. All comparisons include 95% CI bands from Monte Carlo UQ. Conservative over-prediction bias (+12% mean) documented and accepted as protective. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH), which is the regulatory QoI for VAD hemolysis submissions. Secondary QoIs (wall shear stress, exposure time distribution) directly feed the power-law hemolysis model. Confidence rated MODERATE: power-law model form uncertainty is the dominant source of wide prediction intervals. QoI relevance is high; uncertainty in QoI prediction is documented and propagated. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the same geometry as the COU device. Operating conditions span the VAD clinical range (3–8 LPM, 2000–3500 RPM). Confidence rated MODERATE-LOW: validation data sourced from a single laboratory; inter-laboratory variability not characterised. This limitation is documented explicitly; single-laboratory provenance accepted as residual risk with recommendation for multi-site validation in post-market phase. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence monitored via residual drop to 1e-6 for continuity and momentum; mass imbalance < 0.01%. Round-off error assessed as negligible (double-precision arithmetic). Confidence HIGH for solver error specifically; this factor achieves level 2 which meets the required level 2 at MRL 5 for this sub-factor. Solver error contribution to total NIH uncertainty is < 0.5% per UQ decomposition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "Simulation setup reviewed by independent analyst; boundary condition assignments, material property inputs, and solver settings verified against documented simulation plan. Two minor discrepancies identified during review (inlet turbulence intensity specification) and corrected before final runs. Confidence MODERATE; use error residual risk accepted as low given independent review protocol. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger) selected with acknowledged limitations: model coefficients derived from bovine blood, applied to human blood analogue. Model form uncertainty is the primary driver of wide NIH prediction intervals (±38% at 95% CI). This limitation is documented explicitly with quantified sensitivity: coefficient variation of ±25% propagated through Monte Carlo. Conservative over-prediction bias provides protective margin. Achieved level 3 meets required level 3; model form uncertainty accepted as residual risk with post-market monitoring plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "All model inputs (geometry, boundary conditions, material properties, hemolysis model coefficients) assigned probability distributions for Monte Carlo UQ. Input uncertainty sources: geometry tolerance ±0.05 mm, viscosity ±4% (temperature sensitivity), hemolysis coefficients ±25% (literature range). Confidence rated LOW for hemolysis coefficients due to sparse human-blood calibration data; this is documented with full provenance. Total input uncertainty contribution to NIH = ±31% at 95% CI. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5",
      "rationale": "Bench tests conducted with n=3 replicate samples per operating point (15 total measurements). Sample-to-sample variability (CV 8.4%) documented and incorporated into UQ as aleatory uncertainty. Confidence MODERATE; sample size is limited but sufficient for level 2 requirement. Recommendation for expanded n=6 replicates in post-market validation documented. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5",
      "rationale": "Correspondence between simulation inputs and bench test conditions established for all five operating points. Fluid properties (viscosity, density) matched to within 3% of bench values. Inlet flow waveform in simulation matches bench pump controller output within ±2% flow rate. Confidence MODERATE: rotational speed equivalency verified via tachometer (±15 RPM); this contributes ±2.1% to NIH per sensitivity analysis. All equivalency gaps quantified and propagated through UQ. Achieved level 3 meets required level 3."
    }
