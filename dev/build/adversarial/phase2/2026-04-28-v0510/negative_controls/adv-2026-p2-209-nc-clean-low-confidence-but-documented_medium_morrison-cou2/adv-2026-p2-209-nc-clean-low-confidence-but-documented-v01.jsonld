  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nc9-vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed; achieved levels meet or exceed required levels at Model Risk Level 5 for a Class III VAD device. The assessment team explicitly acknowledges that evidence confidence is low to moderate across multiple factors, particularly model form (power-law hemolysis coefficients derived from bovine blood) and model inputs (sparse human-blood calibration data). These limitations produce wide NIH prediction intervals of ±38% at 95% CI, documented transparently in the Monte Carlo UQ report. The decision to Accept is grounded in three compensating conditions: (1) a conservative over-prediction bias of +12% mean provides a protective margin relative to the absolute clinical hemolysis threshold; (2) the wide uncertainty bounds remain entirely below the clinical threshold even at the upper 95% CI bound across all five operating points; (3) a post-market surveillance plan with mandatory hemolysis monitoring at 3, 6, and 12 months is specified as a condition of acceptance. The provenance chain is complete: all validation results trace to documented experimental datasets with full UQ linkage. No credibility factor gaps remain unaddressed. Residual risk is accepted as documented, not concealed.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
