  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-f1717-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-vv40-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 compression-bending achieves overall credibility sufficient for regulatory submission at Medium model risk level. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs required 3) is addressed by the offset rationale: titanium quasi-static plasticity is rate-insensitive (< 0.5% per decade), the single test condition (5 mm/min, 22 °C) is the ASTM F1717 standard condition, and acceptance bounds are conservative (10% vs observed 2% max deviation). All three QoIs satisfy both percent difference (< 2.1%) and E/uval (< 0.72) acceptance criteria across N=11 specimens from two independent laboratories. The operating envelope is explicitly bounded with concrete geometric and load parameters, and validation specimens cover boundary points. The decision to accept is grounded in the structured evidence chain from bench data through uncertainty quantification to model output comparison.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/or-testconditions-noncannulated",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "refersToFactor": "https://uofa.net/synth/factor/test-conditions-noncannulated",
        "justification": "The Test conditions factor achieved Gradation 2 (single test condition) against a required Gradation 3 (multiple conditions). This shortfall is accepted because: (1) Ti-6Al-4V quasi-static plasticity is rate-insensitive at physiologically relevant strain rates — literature data (Donachie 2000, ASTM STP 1162) show < 0.5% yield strength variation per decade of strain rate in the 0.001–0.1/s range encompassing the test rate; (2) the single test condition (5 mm/min, 22 °C) is the normative ASTM F1717 condition and the regulatory standard for spinal implant bench testing; (3) the acceptance bounds adopted (< 10% QoI difference, E/uval < 1.96) are conservative relative to the observed maximum deviation of 2.0%, providing a 5× safety margin on the acceptance criterion; (4) the model risk level (3) and decision consequence (Medium) do not require exhaustive multi-condition validation for this specific material-loading combination. The residual uncertainty from single-condition testing is bounded and does not undermine the overall credibility conclusion.",
        "description": "Offset rationale addressing the Test conditions factor shortfall (achievedLevel 2 < requiredLevel 3) for the non-cannulated F1717 compression-bending COU."
      },
      {
        "id": "https://uofa.net/synth/decision/dr-noncannulated-f1717-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/dr-noncannulated-f1717-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
