  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending achieves sufficient credibility for the declared medium model risk level. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single shortfall — Test conditions achieving Gradation 1 against a required Gradation 2 — is offset by: (1) inter-laboratory replication across two independent facilities providing confidence in experimental representativeness; (2) the explicitly bounded operating envelope restricting applicability to 25 ± 2 mm/min load rate and 20–25 °C, eliminating the need for multi-condition validation; and (3) all three QoIs passing both the 10% error and E/uval < 1.96 acceptance thresholds with margin. The structured operating envelope and applicability constraint ensure no extrapolation beyond validated conditions. The credibility evidence is sufficient to support the regulatory decision.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions Gradation 1 shortfall",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "The Test conditions factor achieves Gradation 1 (single load rate, single temperature) against a required Gradation 2. This shortfall is justified by three compensating strengths: first, the operating envelope explicitly bounds the applicable load rate to 25 ± 2 mm/min and temperature to 20–25 °C, so the single test condition covers the entire declared scope; second, inter-laboratory replication (N=6 at Lab A, N=5 at Lab B) provides a form of condition variation confirming robustness to laboratory-to-laboratory environmental differences; third, all QoI comparisons pass with E/uval values of 1.31, 1.74, and 1.88 — all below the 1.96 threshold — demonstrating that model accuracy is not marginal. The combination of a tightly bounded COU and strong quantitative agreement offsets the absence of multi-rate testing."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2024/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-accepted-2024/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
