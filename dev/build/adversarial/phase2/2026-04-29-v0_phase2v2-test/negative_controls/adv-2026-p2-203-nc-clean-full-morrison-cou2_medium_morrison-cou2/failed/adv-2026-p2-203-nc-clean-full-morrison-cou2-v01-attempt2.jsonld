    "type": "SensitivityAnalysis",
    "name": "Monte Carlo global sensitivity analysis for CFD hemolysis prediction",
    "description": "A variance-based Sobol sensitivity analysis was conducted over 4096 Latin-hypercube samples varying blood viscosity (±15%), pump rotational speed (±3%), inlet flow rate (±8%), and the Giersiepen–Wurzinger power-law exponent (±20%). The hemolysis index output variance was dominated by the power-law exponent (first-order Sobol index S1 = 0.61) and inlet flow rate (S1 = 0.22), with viscosity and rotational speed contributing less than 5% each; total-order indices confirmed negligible higher-order interactions beyond the exponent–flow-rate pair (ST interaction = 0.09).",
    "method": "Variance-based Sobol decomposition with Latin-hypercube sampling",
    "dominantFactors": [
      "Giersiepen-Wurzinger power-law exponent",
      "inlet flow rate"
    ],
    "sampleSize": 4096
  },
