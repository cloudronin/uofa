  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision/accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluidics-lab/lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5 with achieved levels meeting or exceeding required levels. Key findings: (1) Discretization error (GCI 2.1%) and model inputs (full Monte Carlo UQ, N=5000) achieved Level 5, exceeding MRL 5 requirements. (2) Validation comparison error E/U_val < 1.0 at all five operating points confirms model is within validation uncertainty across the full COU operating envelope. (3) Sensitivity analysis identifies power-law exponent as dominant uncertainty driver (58% total variance); this parameter is characterized with a full probability distribution traceable to three independent calibration datasets. (4) 95th-percentile hemolysis prediction remains 18% below clinical threshold with 97.3% probability, providing adequate margin under uncertainty. (5) Independent peer review and reproduction run confirm no use errors. (6) Validation conducted on the FDA reference geometry at COU-equivalent operating conditions; no extrapolation required. The combined weight of structured quantitative evidence across all 13 factors, the absence of any credibility factor shortfall, and the demonstrated probabilistic margin to the clinical hemolysis threshold collectively support acceptance of the CFD model for the COU2 decision context.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
