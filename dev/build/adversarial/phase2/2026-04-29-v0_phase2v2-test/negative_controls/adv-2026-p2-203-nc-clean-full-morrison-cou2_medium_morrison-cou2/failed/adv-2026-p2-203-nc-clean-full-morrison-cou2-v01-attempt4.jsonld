    "type": "SensitivityAnalysis",
    "name": "Morris screening and Sobol variance-based sensitivity analysis for VAD hemolysis CFD",
    "description": "A two-stage sensitivity analysis was conducted: Morris elementary-effects screening (r=50 trajectories, k=12 input parameters) identified red blood cell damage exponent, bulk viscosity, and inlet velocity profile as dominant drivers of hemolysis index variance. Sobol first- and total-order indices were subsequently computed from a 5000-sample quasi-random (Saltelli) ensemble; the power-law exponent accounted for 58% of total output variance, inlet turbulence intensity for 21%, and fluid viscosity for 11%, with remaining parameters contributing less than 3% each.",
    "method": "Morris elementary-effects screening followed by Sobol variance decomposition (Saltelli sampling, N=5000)",
    "dominantFactors": [
      "RBC damage power-law exponent",
      "inlet turbulence intensity",
      "dynamic viscosity"
    ],
    "sampleSize": 5000
  },
