  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/biofluid-simulation-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at Model Risk Level 5 with achieved levels meeting or exceeding required levels. The CFD model achieves MRL 5 validation relevance (factor achieved level 5 of 5), complete model form uncertainty quantification incorporating three turbulence model comparisons, and Monte Carlo UQ across all uncertain inputs (N = 10,000). The primary QoI (NIH) is predicted below the clinical threshold at the 95th percentile of the Monte Carlo ensemble with a 34% margin. Discretization error (GCI 3.1%) and iterative convergence errors are bounded and small relative to total uncertainty. Independent analyst replication confirms absence of use error. The validation evidence base — PIV velocity fields and bench hemolysis measurements across 5 operating points on the FDA generic centrifugal pump benchmark — is directly relevant to the COU. The systematic 9% under-prediction of NIH relative to bench measurements is conservative (model under-predicts hemolysis) and is incorporated into the uncertainty budget. The credibility evidence is sufficient to support the regulatory claim that the CFD model can predict absolute hemolysis levels for the Class III VAD device within the documented operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
