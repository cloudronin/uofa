  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: centrifugal blood pump hemolysis domain",
      "description": "Model applicability is restricted to centrifugal rotary blood pumps with impeller tip speeds between 3 m/s and 12 m/s, operating with human whole blood at hematocrit 35–45%, temperature 37 ± 1 °C, and flow rates 2–8 L/min. The Giersiepen-Wurzinger power-law hemolysis model is applicable only within these shear-stress and exposure-time ranges validated against published erythrocyte fragility data. Extrapolation beyond these bounds is not supported by the evidence base."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: FDA generic centrifugal pump VAD conditions",
      "description": "Flow rate: 2.5–6.0 L/min (five discrete operating points: 2.5, 3.5, 4.5, 5.0, 6.0 L/min). Rotational speed: 2000–3500 RPM. Inlet pressure: 5–15 mmHg. Outlet pressure: 60–120 mmHg. Fluid: Newtonian blood analog (glycerol-water, viscosity 3.5 cP) for bench validation; non-Newtonian whole blood model for predictive runs. Geometry: FDA generic centrifugal pump benchmark geometry with impeller outer diameter 60 mm ± 0.5 mm. All five operating points lie within the validated shear-stress envelope (τ < 400 Pa, t_exposure < 2 ms per pass)."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/sensitivity/cou2-monte-carlo",
    "type": "SensitivityAnalysis",
    "name": "Monte Carlo global sensitivity analysis — COU2 hemolysis index",
    "description": "A Sobol-sequence Monte Carlo sensitivity analysis (N = 10,000 samples) was performed varying eight uncertain input parameters: blood viscosity (±15%), power-law hemolysis model coefficients C and α (±20% each based on inter-laboratory scatter in Giersiepen et al.), inlet velocity profile shape factor (±8%), impeller surface roughness (Ra ± 30%), turbulent Schmidt number (0.7–1.3), and time-step size (factor of 2). First-order and total-order Sobol indices were computed; the hemolysis model coefficient C dominates with a total-order index of 0.61, followed by blood viscosity (0.18) and the power-law exponent α (0.14). The 95th-percentile hemolysis index prediction remains 34% below the clinical threshold across all sampled parameter combinations, providing adequate margin despite parametric uncertainty."
  },
