  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The Morrison COU2 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under VAD conditions is accepted at Model Risk Level 5. All 13 credibility factors have been assessed; all achieved levels meet or exceed required levels. Key evidence supporting acceptance: (1) Validation metric E_val ≤ 0.089 at all five operating points, well below the 0.15 acceptance threshold, demonstrating quantitative predictive accuracy for the primary clinical QoI (NIH). (2) Monte Carlo UQ (N=2000 per operating point) with full Sobol sensitivity decomposition demonstrates that 95% confidence intervals on predicted NIH encompass experimental measurements at all operating points, and that predicted NIH remains below the clinical hemolysis threshold (NIH < 0.06 g/100L per ASTM F1841) with 97.3% probability at the worst-case operating point. (3) Discretization error (GCI_fine ≤ 2.1%) and solver convergence (residuals < 10^-6) are well-controlled and included in the total uncertainty budget. (4) Validation experiments conducted on the identical pump geometry at coincident operating conditions with NIST-traceable instrumentation, providing direct relevance to the COU. (5) Model form selection justified by comparative turbulence model study; hemolysis damage model calibrated with pump-specific experimental data. (6) Independent dual-analyst execution with cross-verification eliminates use error as a significant uncertainty source. The integrated evidence chain from foundational code verification through system-level hemolysis validation, combined with comprehensive UQ demonstrating margin to clinical thresholds, provides sufficient credibility for regulatory decision-making at MRL 5 for this Class III VAD application.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
