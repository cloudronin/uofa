    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated 7.5 mm pedicle screw under quasi-static F1717 loading",
      "description": "The FEA model is applicable only to non-cannulated pedicle screw constructs with nominal outer diameter 7.5 mm, Ti-6Al-4V alloy, polyaxial head, and UHMWPE vertebral body surrogate blocks per ASTM F1717. The model is not applicable to cannulated variants, screws with outer diameter outside 6.5–8.5 mm, dynamic fatigue loading, or in vivo bone substrates. Geometric deviations beyond +/-0.05 mm from nominal CAD dimensions invalidate the applicability of this assessment."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ASTM F1717 quasi-static compression-bending regime",
      "description": "Valid operating domain: axial compressive preload 0–100 N; bending moment arm 40 mm per F1717 fixture; displacement rate 5 mm/min (quasi-static); ambient temperature 23 +/- 2 degrees C; relative humidity 50 +/- 10%; construct span two-level (L4-L5 surrogate); screw insertion torque 4.0 +/- 0.2 Nm. Quantities of interest bounded to stiffness 50–300 N/mm, yield force 200–1200 N, and force at 40 mm displacement 100–900 N. Extrapolation outside these bounds is not supported by this credibility assessment."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/nagaraja/sa/cou1-sensitivity",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time sensitivity analysis of material and contact parameters on construct stiffness and yield force",
    "description": "A one-at-a-time parameter sweep varied Ti-6Al-4V elastic modulus (+/-5%), screw-rod friction coefficient (0.1 to 0.4), UHMWPE block compressive modulus (+/-15%), and set-screw torque preload (+/-20%) independently across 48 FEA runs. Construct stiffness showed less than 3% variation to all parameters except UHMWPE modulus (8.2% range), while yield force was most sensitive to friction coefficient (11.4% range), confirming that contact interface fidelity is the dominant uncertainty driver and motivating the targeted experimental characterization of friction reported in the model inputs factor assessment."
  },
