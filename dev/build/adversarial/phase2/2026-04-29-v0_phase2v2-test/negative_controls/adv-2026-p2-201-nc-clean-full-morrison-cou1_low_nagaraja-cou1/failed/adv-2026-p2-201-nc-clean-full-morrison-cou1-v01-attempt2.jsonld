  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/nagaraja/cf/software-qa",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated FEA solver with ISO 9001-certified QMS and documented V&V test suite. The FDA in-house Python preprocessing scripts are version-controlled in Git (commit hashes logged), subject to peer code review, and tested against analytical benchmarks (cantilever beam, Hertzian contact). DePuy Synthes provided solver configuration files with change-log history. All three ensemble members passed regression testing against the NAFEMS benchmark set LE1 and LE10. Achieved Level 3 reflects documented QMS plus independent benchmark verification beyond the minimum Level 2 requirement of commercial solver use alone.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/software-qa",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criteria",
        "description": "Acceptance requires: (1) commercial solver with documented QMS or equivalent; (2) version-controlled preprocessing scripts with peer review; (3) passage of at least two independent NAFEMS benchmarks. All three criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/numerical-code-verification",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Code verification was performed by comparison of FEA-predicted deflection and stress for a cantilever beam of identical material (Ti-6Al-4V) against closed-form Euler-Bernoulli solutions. Relative error in tip deflection was 0.08% and in maximum bending stress was 0.31%, both well within the 1% threshold. Additionally, a manufactured solution verification (MMS) was executed for the contact pressure distribution at the screw-rod interface, confirming second-order spatial convergence. These activities exceed the Level 2 requirement of single benchmark comparison and achieve Level 3 through MMS confirmation of convergence order.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/numerical-code-verification",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criteria",
        "description": "Acceptance requires: relative error vs. analytical solution < 1% for primary QoI; convergence order confirmed >= 1.8 via MMS or Richardson extrapolation. Both criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/discretization-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "A three-level mesh refinement study was conducted on the screw shank and screw-rod contact region using element edge lengths of 0.8 mm (coarse), 0.4 mm (medium), and 0.2 mm (fine). Grid Convergence Index (GCI) was computed per Roache (1998) for construct stiffness (GCI_fine = 1.2%), yield force (GCI_fine = 1.8%), and force at 40 mm (GCI_fine = 1.5%). All GCI values are below the 2% acceptance threshold. The observed order of convergence p = 1.94 confirms near-theoretical second-order behavior for the hexahedral-dominant mesh. Production runs used the medium mesh (0.4 mm) as the balance of accuracy and computational cost, with GCI applied as a numerical uncertainty contribution to uval.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/discretization-error",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria",
        "description": "Acceptance requires: three-level mesh refinement study completed; GCI_fine < 2% for all three QoIs; observed convergence order p >= 1.8. All criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/numerical-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Nonlinear solver convergence was monitored via force residual norm (tolerance 1e-4) and displacement increment norm (tolerance 1e-5) for all load steps. No load steps required bisection beyond two levels, and all analyses converged within 120 iterations per load step. Iterative linear solver (PCG with incomplete Cholesky preconditioner) residual was below 1e-8 for all steps. These controls satisfy the Level 2 requirement for documented convergence monitoring with quantified tolerances.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/numerical-solver-error",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error acceptance criteria",
        "description": "Acceptance requires: nonlinear force residual norm < 1e-3 and displacement norm < 1e-4 at convergence; linear solver residual < 1e-6; no unconverged load steps. All criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/use-error",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "A documented simulation plan (SP-COU1-001 Rev B) was prepared prior to analysis execution, specifying boundary conditions, material assignments, contact definitions, load application sequences, and QoI extraction procedures. Two independent analysts (FDA and DePuy Synthes) executed the simulation plan independently and cross-checked results; discrepancies exceeding 0.5% triggered root-cause investigation. One discrepancy (0.8% in stiffness) was traced to a boundary condition interpretation difference and resolved by plan amendment. The peer-review process and documented simulation plan satisfy Level 2 requirements.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/use-error",
        "type": "AcceptanceCriteria",
        "name": "Use error acceptance criteria",
        "description": "Acceptance requires: documented simulation plan prior to execution; independent analyst cross-check; all discrepancies > 0.5% investigated and resolved. All criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/model-form",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "The FEA model employs an isotropic linear-elastic constitutive law for Ti-6Al-4V (Young's modulus 114 GPa, Poisson's ratio 0.34) and a bilinear isotropic hardening plasticity model (tangent modulus 1.8 GPa, yield stress 880 MPa) for the post-yield regime. The UHMWPE surrogate blocks are modeled as neo-Hookean hyperelastic material calibrated from uniaxial compression coupon data. Frictional contact (Coulomb, mu = 0.25) is applied at screw-rod and rod-block interfaces. Model form choices were justified by literature review (Goel et al. 2006; Rohlmann et al. 2009) and by comparison of load-displacement curve shape to experimental data across all 11 specimens. The ensemble of three independent FEA implementations (FDA, Ansys, DePuy Synthes) provides epistemic coverage of model form uncertainty beyond the single-model Level 2 requirement.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/model-form",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria",
        "description": "Acceptance requires: constitutive model choice justified by literature; plasticity model included for post-yield regime; contact formulation documented; ensemble of >= 2 independent implementations. All criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/model-inputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Material properties for Ti-6Al-4V were sourced from ASTM B265 certified mill certificates for the specific screw lot, supplemented by in-house tensile coupon testing (N=5, CV < 2%). UHMWPE block properties were characterized by uniaxial compression testing at 5 mm/min (N=6 blocks per lot, two lots). Friction coefficients were measured by pin-on-flat tribometry (N=8 pairs) under dry conditions matching the test environment. Geometric inputs were derived from CMM measurements of three representative screws (dimensional tolerance +/-0.01 mm). All input distributions were propagated through a Monte Carlo analysis (N=1000 samples) to quantify input-driven output uncertainty, which was incorporated into uval. This level of input characterization exceeds Level 2 (literature values acceptable) and achieves Level 3 through lot-specific experimental characterization.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria",
        "description": "Acceptance requires: material properties from certified sources or in-house testing; friction characterized experimentally; geometric inputs from CMM; Monte Carlo propagation of input uncertainty. All criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/test-samples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested, drawn from a single production lot (lot 2021-NC-7.5-A) to minimize inter-lot variability. Constructs were assembled by a trained technician per the surgical technique guide (torque-controlled to 4.0 Nm). Sample size of N=11 was determined by power analysis targeting 80% power to detect a 10% difference in mean stiffness at alpha = 0.05, given historical CV of 4%. All 11 specimens were dimensionally verified by CMM prior to testing. Two specimens were tested at each of two independent laboratories (labs 1 and 2) for inter-laboratory reproducibility assessment; the remaining seven were tested at lab 1. This satisfies Level 2 requirements for documented sample selection and dimensional verification.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/test-samples",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria",
        "description": "Acceptance requires: N >= 10 specimens; single production lot; power analysis documented; CMM verification of all specimens; inter-laboratory testing at >= 2 labs. All criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/test-conditions",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "All testing was conducted under a single set of ASTM F1717 test conditions (ambient temperature 23 +/- 2 degrees C, displacement rate 5 mm/min, two-level construct geometry). Only one test condition variant was evaluated, which constitutes the minimum required by F1717 and satisfies Level 2 for this risk level. The limitation of single-condition testing is acknowledged: no variation of displacement rate, temperature, or construct geometry was explored. This gap is addressed by the offset rationale in the decision record, which notes that the single condition is the regulatory standard condition and that the model's intended use is limited to this condition as stated in the operating envelope.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria",
        "description": "Acceptance requires: compliance with ASTM F1717 specified test conditions; environmental controls documented; displacement rate and temperature recorded for all specimens. All criteria met at the single-condition Level 2 threshold."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/equivalency-input-parameters",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "A formal equivalency mapping table was prepared documenting each experimental input parameter and its FEA counterpart. Screw geometry was taken from CMM measurements of the tested specimens, not nominal CAD, ensuring geometric fidelity. Material properties were taken from the same lot as tested specimens. Boundary conditions (fixture geometry, load application point, constraint locations) were measured from the test fixture and replicated in the FEA boundary condition definitions to within 0.5 mm. Assembly torque was converted to an equivalent preload stress state in the FEA using a torque-tension relationship validated by strain gauge measurement on two sacrificial assemblies. This systematic equivalency documentation exceeds Level 2 and achieves Level 3.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/equivalency-input-parameters",
        "type": "AcceptanceCriteria",
        "name": "Equivalency of input parameters acceptance criteria",
        "description": "Acceptance requires: formal equivalency mapping table; specimen-specific geometry inputs from CMM; fixture geometry measured and replicated; assembly preload characterized. All criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Quantitative output comparison was performed for all three QoIs (stiffness, yield force, force at 40 mm) using the ASME V&V 40 validation metric E/uval. All three E/uval values (0.61, 0.84, 0.72) are below the 1.96 threshold. Additionally, full load-displacement curve shape agreement was assessed by computing the area metric (Ferson et al. 2008) for each of the 11 specimen curves; all area metric values were below 0.08 (threshold 0.15). Graphical overlays of FEA ensemble bounds versus experimental corridor were prepared and reviewed. The combination of scalar QoI comparison, area metric, and curve overlay achieves Level 3.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria",
        "description": "Acceptance requires: E/uval < 1.96 for all three QoIs; area metric < 0.15 for all 11 specimen curves; graphical load-displacement overlay reviewed and documented. All criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/relevance-qoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the quantities specified by ASTM F1717 as the primary performance metrics for spinal implant constructs and are directly linked to the regulatory decision (510(k) substantial equivalence demonstration). Stiffness characterizes the elastic load-sharing behavior relevant to adjacent segment mechanics. Yield force is the failure threshold directly related to the risk of intraoperative or early postoperative construct failure. Force at 40 mm displacement characterizes post-yield energy absorption. The mapping from QoIs to clinical risk was documented in a QoI-to-risk traceability matrix reviewed by the clinical team. This traceability exceeds Level 2 and achieves Level 3.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/relevance-qoi",
        "type": "AcceptanceCriteria",
        "name": "Relevance of QoI acceptance criteria",
        "description": "Acceptance requires: QoIs specified in regulatory standard (F1717); QoI-to-clinical-risk traceability matrix documented; clinical team review of traceability. All criteria met."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/relevance-validation-activities",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "The validation activities are directly relevant to the COU: the same screw design (non-cannulated 7.5 mm, same lot), same loading mode (compression-bending per F1717), same surrogate material (UHMWPE blocks per F1717), and same measurement instrumentation as the intended regulatory submission context. The validation domain (bench test per F1717) is identical to the intended use domain. No extrapolation from a surrogate validation domain is required. The use of two independent laboratories increases the generalizability of the validation evidence beyond a single-site study. The ensemble of three independent FEA implementations provides additional confidence that the validation result is not implementation-specific. These features collectively achieve Level 3 relevance.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/relevance-validation-activities",
        "type": "AcceptanceCriteria",
        "name": "Relevance of validation activities acceptance criteria",
        "description": "Acceptance requires: validation uses same screw lot and loading mode as COU; no domain extrapolation required; >= 2 independent laboratories; >= 2 independent FEA implementations. All criteria met."
      }
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for non-cannulated 7.5 mm pedicle screw compression-bending under ASTM F1717 is accepted as sufficiently credible to support the regulatory submission decision. All 13 V&V 40 credibility factors have been assessed at or above their required levels for Model Risk Level 3 / Medium assurance. Quantitative validation metrics (E/uval) for all three QoIs (stiffness 0.61, yield force 0.84, force at 40 mm 0.72) are well below the 1.96 acceptance threshold, indicating that model predictions are consistent with experimental data within combined validation uncertainty. The ensemble approach across three independent FEA implementations (FDA, Ansys, DePuy Synthes) provides robustness against implementation-specific artifacts. Sensitivity analysis identified UHMWPE modulus and screw-rod friction as dominant uncertainty drivers; both were characterized experimentally and their uncertainty propagated through the validation metric. The test conditions factor was assessed at Level 2 (achieved = required), reflecting the single-condition F1717 protocol; this is appropriate given that the operating envelope is explicitly bounded to this condition. The decision is supported by complete provenance tracing from raw experimental data through QoI extraction to validation metric computation, with all intermediate steps documented in simulation report SR-COU1-2026-Rev2.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/decision/cou1-offset-test-conditions",
      "type": "OffsetRationale",
      "name": "Offset rationale: test conditions at minimum required level",
      "description": "The test conditions factor achieved Level 2, equal to the required Level 2 for this model risk level. No gap exists between required and achieved levels. This offset rationale is included for transparency to document that the single-condition testing limitation was considered: the operating envelope explicitly restricts the COU to the F1717 standard condition (23 +/- 2 degrees C, 5 mm/min), so the absence of multi-condition testing does not introduce unmitigated risk beyond the stated scope. The decision to accept at Level 2 for this factor is consistent with the ASME V&V 40 framework for Medium model influence and Medium decision consequence.",
