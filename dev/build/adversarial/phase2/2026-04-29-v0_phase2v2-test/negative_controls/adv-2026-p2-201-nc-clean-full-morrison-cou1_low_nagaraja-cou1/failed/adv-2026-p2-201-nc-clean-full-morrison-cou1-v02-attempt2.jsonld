  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "deviceClass": "Class II",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated 7.5 mm titanium pedicle screw — ASTM F1717 static compression-bending domain",
      "description": "The credibility assessment applies exclusively to non-cannulated 7.5 mm diameter titanium-alloy (Ti-6Al-4V) pedicle screw constructs tested under quasi-static compression-bending per ASTM F1717. The model is not applicable to cannulated variants, screws of different diameter or alloy, dynamic fatigue loading, or in vivo biomechanical scenarios. Geometric deviations beyond ±0.05 mm from the nominal CAD profile invalidate the applicability boundary."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 static compression-bending operating envelope for non-cannulated 7.5 mm construct",
      "description": "Axial compressive load applied at 10 mm/min crosshead displacement rate; load range 0–2500 N; bending moment arm fixed at 60 mm per ASTM F1717 fixture geometry; ambient temperature 23 ± 2 °C; relative humidity 50 ± 10%; screw insertion torque 8 ± 0.5 N·m into UHMWPE block; rod diameter 5.5 mm CoCr; construct span L5-S1 equivalent (44 mm interbody distance). Predictions valid only within these bounds; extrapolation beyond 2500 N or outside the specified temperature window is not supported."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-noncannulated",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Sobol sensitivity analysis for non-cannulated pedicle screw FEA model",
    "description": "A one-at-a-time (OAT) sensitivity study varied six key model inputs — Ti-6Al-4V Young's modulus (±5%), screw thread friction coefficient (0.1–0.3), UHMWPE block modulus (±15%), rod-to-screw interface contact stiffness (±20%), crosshead displacement rate (8–12 mm/min), and mesh density (element edge length 0.3–0.8 mm) — against the three primary QoIs: construct stiffness, yield force, and force at 40 mm displacement. A subsequent Sobol first-order and total-order variance decomposition (1024 quasi-random samples, Saltelli scheme) confirmed that UHMWPE modulus and thread friction coefficient together account for 61% of QoI variance; Young's modulus and contact stiffness contribute 28%; mesh density and displacement rate contribute less than 11% combined. The dominant sensitivity to UHMWPE modulus motivated the material characterisation sub-study (tensile coupons, N=5) whose results feed directly into the validated model input uncertainty bounds."
  },
