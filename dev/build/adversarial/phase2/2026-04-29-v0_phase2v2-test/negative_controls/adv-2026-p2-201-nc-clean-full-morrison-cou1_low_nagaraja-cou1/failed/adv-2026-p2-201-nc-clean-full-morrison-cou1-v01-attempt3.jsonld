  "hasSensitivityAnalysisObject": {
    "id": "https://uofa.net/nagaraja/sensitivity/cou1-noncannulated",
    "type": "SensitivityAnalysis",
    "name": "Parametric sensitivity analysis for non-cannulated pedicle screw FEA model",
    "description": "Material elastic modulus (Ti-6Al-4V, ±10%), cortical bone block modulus (±20%), and frictional contact coefficient (0.1–0.4) were varied independently in a one-at-a-time study across the full F1717 load range. Construct stiffness QoI showed less than 4% variation to modulus perturbations and less than 7% variation to contact coefficient changes, confirming that the dominant uncertainty source is experimental fixture compliance rather than material property scatter. Yield force predictions were insensitive (< 2%) to bone block modulus variation within the specified range."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated 7.5 mm pedicle screw under quasi-static F1717 loading",
      "description": "This credibility assessment applies exclusively to non-cannulated titanium alloy (Ti-6Al-4V) pedicle screws with nominal outer diameter 7.5 mm and thread pitch 2.0 mm, evaluated under quasi-static ASTM F1717 compression-bending loading at displacement rates not exceeding 5 mm/min. The model is not applicable to cannulated variants, screws with outer diameter outside 6.5–8.5 mm, dynamic fatigue loading, or materials other than Ti-6Al-4V. Clinical in vivo loading scenarios are outside the scope of this COU."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: F1717 quasi-static compression-bending test conditions",
      "description": "Valid operating domain is defined by: axial compressive load 0–2500 N; bending moment arm per ASTM F1717 geometry (L1 = 25 mm, L2 = 42 mm); crosshead displacement rate 1–5 mm/min; ambient temperature 20–25 °C; relative humidity 40–60%; UHMWPE test block modulus 800–1100 MPa; screw insertion torque 6–8 N·m; inter-laboratory reproducibility confirmed at two independent facilities. FEA mesh density: minimum 4 elements through screw thread root radius. Contact penalty stiffness factor 0.1–10.0 (dimensionless, Ansys default 1.0)."
    }
  },
