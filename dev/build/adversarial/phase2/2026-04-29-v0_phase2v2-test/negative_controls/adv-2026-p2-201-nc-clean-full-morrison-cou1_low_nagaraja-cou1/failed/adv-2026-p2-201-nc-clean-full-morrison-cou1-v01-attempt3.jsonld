  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/nagaraja/factor/software-quality-assurance",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "The FEA solver (Ansys Mechanical 2022R2) is a commercially validated, FDA-recognized software tool with documented version control, regression test suite, and change management procedures. The analysis scripts and APDL macros used for this study are maintained under Git version control with tagged releases corresponding to each submission artifact. Code review records confirm independent verification of all custom post-processing routines. Three independent analysts reproduced identical QoI predictions from the same input deck, confirming reproducibility. SQA documentation package submitted as Appendix C of the credibility evidence dossier.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/software-quality-assurance",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criteria",
        "description": "Software must be a commercially validated solver with documented version control and regression testing. Custom scripts must be under version control with independent code review. Reproducibility demonstrated by at least two independent analysts obtaining matching QoI values within numerical precision."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/numerical-code-verification",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Numerical code verification was performed through comparison of FEA predictions against closed-form analytical solutions for a cantilever beam of equivalent cross-section and material properties. Agreement within 0.4% for tip deflection and 0.7% for peak bending stress was achieved, confirming correct implementation of the structural mechanics formulation. Additionally, a patch test was passed for all element types used (SOLID186, CONTA174, TARGE170), and force equilibrium was confirmed to within 0.01% at each load step. The Ansys solver documentation references NAFEMS benchmark suite results, providing additional code-level verification evidence.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/numerical-code-verification",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criteria",
        "description": "FEA predictions must agree with analytical solutions for representative benchmark problems within 1% for primary QoIs. Patch test must be passed for all element types. Force equilibrium residual must be below 0.1% at all load steps."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/discretization-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "A three-level mesh convergence study was conducted using element edge lengths of 0.8 mm, 0.5 mm, and 0.3 mm at the screw thread root (critical stress concentration region). Grid Convergence Index (GCI) was computed per Roache (1998) methodology. GCI for the fine-to-medium refinement was 0.9% for stiffness and 1.8% for yield force, both below the 2% acceptance threshold. The observed order of convergence was 1.87, consistent with the quadratic element formulation. The production mesh (0.5 mm thread root element) was selected as the balance between accuracy and computational cost, with confirmed GCI < 2% for all three QoIs.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/discretization-error",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria",
        "description": "GCI for the selected production mesh must be below 2% for all primary QoIs. Observed order of convergence must be within 20% of the theoretical order for the element formulation. At least three mesh refinement levels must be evaluated."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/numerical-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Nonlinear solver convergence was monitored at every load substep. Force and displacement residual norms were required to drop below 0.1% of the reference norm before proceeding. No substep divergence or bisection events occurred in any of the three QoI analyses. Time-stepping sensitivity was assessed by halving the number of load substeps; QoI differences were below 0.3%, confirming load-step insensitivity. Contact status was verified to be stable (no spurious contact opening/closing) across the full displacement range. Double-precision arithmetic was used throughout.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/numerical-solver-error",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error acceptance criteria",
        "description": "Force and displacement convergence residuals must be below 0.1% at every load step. QoI sensitivity to load substep count must be below 1%. No unresolved convergence failures permitted. Contact status must be stable across the full loading range."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/use-error",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "A formal use-error assessment was conducted by having a second qualified analyst independently reconstruct the FEA model from the study protocol document without access to the original input files. QoI predictions from the independently reconstructed model agreed with the primary model within 1.3% for all three QoIs, demonstrating that the modeling protocol is sufficiently documented to prevent use errors. A checklist-based pre-analysis review was completed prior to each production run, covering boundary condition assignment, material property entry, contact pair definition, and load application direction. All checklist items were signed off by a peer reviewer.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/use-error",
        "type": "AcceptanceCriteria",
        "name": "Use error acceptance criteria",
        "description": "Independent model reconstruction from protocol documentation must yield QoI predictions within 2% of the primary model. A completed and peer-reviewed pre-analysis checklist must be on file for each production run."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/model-form",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The model form — quasi-static, geometrically nonlinear implicit FEA with frictional contact, isotropic linear elasticity for the screw and UHMWPE block, and bilinear isotropic hardening plasticity for the titanium screw — was selected based on published literature for F1717 simulation. The choice of bilinear plasticity over more complex cyclic hardening models is justified because the test is monotonic and single-cycle. Geometric nonlinearity (large deformation) is activated to capture the post-yield bending response accurately. The UHMWPE test block is modeled as linear elastic within the valid strain range (< 2% at the screw-block interface), consistent with published material characterization data. Model form uncertainty is bounded by the validation comparison results, which show agreement within 2.5% for all QoIs.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/model-form",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria",
        "description": "Model form selection must be justified by reference to published literature or prior validation studies. Simplifying assumptions must be documented with supporting rationale. Model form uncertainty must be bounded by validation comparison results within the 10% QoI acceptance threshold."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/model-inputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "All model input parameters were derived from traceable sources. Ti-6Al-4V material properties (E = 114 GPa, yield stress = 880 MPa, tangent modulus = 1.2 GPa) are from ASTM B265 mill certificates for the specific lot used in the experimental constructs, supplemented by published ASM Handbook values. UHMWPE block modulus (950 MPa) was measured by the testing laboratory using tensile coupon tests per ASTM D638. Screw geometry was digitized from production drawings with dimensional tolerances ± 0.02 mm. Contact friction coefficient (μ = 0.2) was taken from published tribology data for Ti-Ti contact in dry conditions. Input uncertainty ranges for the sensitivity analysis were defined based on the coefficient of variation observed in the material certification data.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria",
        "description": "All primary model inputs must be traceable to measurement data, material certifications, or published references. Input uncertainty ranges must be defined and used in sensitivity analysis. Geometry must be derived from production drawings or metrology data."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/test-samples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Eleven production-representative non-cannulated 7.5 mm pedicle screw constructs were tested, sourced from the same manufacturing lot as the device under regulatory review. Sample selection was randomized from the production lot. Dimensional inspection of all 11 screws confirmed compliance with drawing tolerances. UHMWPE test blocks were procured from a single certified supplier to minimize inter-block variability. The sample size of N=11 provides adequate statistical power to detect a 10% QoI difference with 80% power at α=0.05, as confirmed by a priori power analysis. Testing was distributed across two independent laboratories to assess inter-laboratory reproducibility, with 6 constructs at Lab 1 and 5 at Lab 2.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/test-samples",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria",
        "description": "Test samples must be production-representative and from the same lot as the device under review. Minimum N=10 constructs required. Dimensional inspection must confirm drawing compliance. Statistical power analysis must demonstrate adequate power to detect the minimum meaningful QoI difference."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/test-conditions",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "rationale": "Testing was conducted under a single set of ASTM F1717 standard test conditions (ambient temperature, dry, quasi-static 2 mm/min crosshead rate). While the standard test protocol is well-controlled and reproducible, only one test condition (the standard F1717 protocol) was evaluated. A second condition — for example, elevated temperature or wet environment simulating body fluid exposure — was not included in this validation study. This represents a shortfall of one gradation level relative to the required level. The shortfall is addressed by the offset rationale documented in the decision record, which notes that the regulatory submission for this device class does not require wet or elevated-temperature F1717 testing, and that the dry ambient condition is the most conservative for titanium construct stiffness.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria",
        "description": "Ideally, at least two distinct test conditions (e.g., ambient dry and simulated physiological) should be evaluated to bound environmental sensitivity. At minimum, the standard ASTM F1717 protocol must be followed with documented environmental controls. Deviations from the required level must be justified by a documented offset rationale."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/equivalency-of-input-parameters",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "A formal equivalency assessment was performed to confirm that FEA model inputs are consistent with the experimental test conditions. Screw geometry in the FEA model was verified against the as-inspected dimensional data for each of the 11 test constructs, with individual-specimen FEA runs performed for three constructs spanning the dimensional tolerance range. Material properties in the FEA model were matched to the mill certificate data for the tested lot. Test fixture geometry (UHMWPE block dimensions, loading fixture offsets) was measured post-test and confirmed consistent with the FEA boundary conditions to within 0.5 mm. Crosshead displacement rate was confirmed to be within the quasi-static regime (inertial effects < 0.1% of peak force).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/equivalency-of-input-parameters",
        "type": "AcceptanceCriteria",
        "name": "Equivalency of input parameters acceptance criteria",
        "description": "FEA model geometry, material properties, and boundary conditions must be demonstrably equivalent to the experimental test configuration. Fixture geometry must be measured and confirmed consistent with FEA inputs within specified tolerances. Material properties must be traceable to the tested lot."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "rationale": "Output comparison was performed using multiple complementary metrics. Primary QoI comparison: percentage difference between FEA ensemble mean and experimental mean for all three QoIs (stiffness 2.2%, yield force 2.4%, force at 40 mm 1.5%), all within the 10% acceptance bound. Validation metric E/u_val computed per ASME V&V 20 methodology: 0.81, 0.94, and 0.52 respectively, all below the 1.96 threshold. In addition, full force-displacement curve overlay plots were generated, confirming qualitative agreement in curve shape, initial stiffness, yield transition, and post-yield softening. Bland-Altman analysis confirmed no systematic bias between FEA and experiment across the displacement range. Inter-laboratory consistency was confirmed (F-test p > 0.3 for all QoIs).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria",
        "description": "Percentage difference between FEA mean and experimental mean must be below 10% for all primary QoIs. E/u_val must be below 1.96. Full force-displacement curve comparison must show qualitative agreement. Bland-Altman analysis must confirm absence of systematic bias."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/relevance-of-qoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are directly specified in ASTM F1717 as the required reporting quantities for pedicle screw construct evaluation. These QoIs are mechanistically linked to the clinical failure modes of interest: construct stiffness governs load transfer to adjacent vertebrae; yield force represents the onset of permanent deformation; and force at 40 mm displacement characterizes post-yield energy absorption. The regulatory submission requirement (510(k) substantial equivalence demonstration) explicitly references these F1717 QoIs. No additional QoIs were identified in the risk analysis that would require separate validation.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/relevance-of-qoi",
        "type": "AcceptanceCriteria",
        "name": "Relevance of QoI acceptance criteria",
        "description": "QoIs must be directly specified in the applicable test standard (ASTM F1717) and must be mechanistically linked to the identified clinical failure modes. The regulatory submission must explicitly reference these QoIs. Any QoIs identified in the risk analysis but not validated must be documented with justification."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/relevance-of-validation-activities",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The validation activities — FEA ensemble comparison against N=11 F1717 bench tests across two laboratories — are directly relevant to the COU, which is prediction of F1717 compression-bending performance of the non-cannulated 7.5 mm pedicle screw. The validation geometry (non-cannulated 7.5 mm screw, standard F1717 fixture) is identical to the COU geometry. The loading mode (compression-bending) is identical. The QoIs evaluated in validation are the same QoIs required for the regulatory submission. The two-laboratory design increases confidence that the validation results are not laboratory-specific artifacts. The validation evidence directly supports the claim that the FEA framework can reliably predict F1717 performance for this device design.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/relevance-of-validation-activities",
        "type": "AcceptanceCriteria",
        "name": "Relevance of validation activities acceptance criteria",
        "description": "Validation geometry, loading mode, and QoIs must be identical to the COU. Multi-laboratory testing is preferred to confirm generalizability. The validation evidence must directly support the regulatory submission claim without requiring extrapolation beyond the validated domain."
      }
    }
  ],
