  ],
  "hasSensitivityAnalysis": true,
  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/nagaraja/sensitivity/cou1-sa-01",
    "type": "SensitivityAnalysis",
    "name": "COU1 Parametric Sensitivity Analysis — Material and Contact Parameters",
    "description": "A one-at-a-time sensitivity study varied titanium alloy elastic modulus (±10%), cortical bone modulus (±15%), and rod-screw interface friction coefficient (0.1–0.4) across the FEA ensemble. Construct stiffness QoI showed less than 4% variation to modulus perturbations and less than 6% variation to friction coefficient changes, confirming that the model response is not dominated by any single uncertain parameter and that the accepted ±10% QoI acceptance bound is robust to plausible input uncertainty."
  },
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034495",
