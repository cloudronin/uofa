    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "COU1 Applicability Constraint — Non-cannulated titanium pedicle screw, F1717 static regime",
      "description": "The credibility assessment applies exclusively to non-cannulated titanium alloy (Ti-6Al-4V ELI) pedicle screws with nominal outer diameter 7.5 mm and polyaxial head design, tested under ASTM F1717 static compression-bending protocol. The FEA model is not applicable to cannulated variants, screws with diameter outside 6.5–8.5 mm, dynamic fatigue loading, or materials other than Ti-6Al-4V. Clinical loading conditions beyond the F1717 test fixture geometry are explicitly outside scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "COU1 Operating Envelope — Geometric and Loading Bounds",
      "description": "Valid operating domain: screw outer diameter 7.0–8.0 mm; screw length 40–55 mm; rod diameter 5.5 mm ± 0.1 mm; applied compressive load 0–2500 N; crosshead displacement 0–45 mm; test temperature 23 ± 2 °C; lubricant: none (dry bench). Titanium alloy elastic modulus 110–120 GPa; yield strength 820–900 MPa. Cortical bone surrogate (Sawbones) density 0.32 g/cm³ ± 5%. Inter-laboratory fixture alignment tolerance ≤ 0.5°. Predictions outside these bounds require re-assessment of model credibility."
    }
  },
