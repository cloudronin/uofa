  "signature": "ed25519:b4e8d3f2a1c7e9b5d0f6a2c4e8b1d3f7a9c2e5b8d1f4a7c0e3b6d9f2a5c8e1b4",
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
