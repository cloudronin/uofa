  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/nagaraja/factor/software-quality-assurance",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "The FEA software (Ansys Mechanical 2022 R2) is used under a validated installation qualified per FDA 21 CFR Part 11 and ISO 13485 QMS. Software version control is maintained in a GxP-compliant repository; all simulation scripts are under revision control with audit trail. A formal software qualification protocol (IQ/OQ/PQ) was executed and documented. Internal benchmark problems (cantilever beam, Hertzian contact) were solved and compared against analytical solutions to within 0.1%, confirming correct installation. The achieved level of 3 reflects documented qualification with independent benchmark verification, exceeding the required level of 2 for a medium-risk model.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-sqa",
        "type": "AcceptanceCriteria",
        "name": "SQA Acceptance Criteria",
        "description": "Software must be used under a documented QMS with version control and qualification testing. Benchmark problems must reproduce analytical solutions to within 0.5%. Required level 2 (documented QMS); achieved level 3 (independent benchmark suite executed and passed)."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/numerical-code-verification",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Code verification was performed by solving the F1717 fixture geometry using three independent FEA implementations: FDA in-house code, Ansys Mechanical, and a DePuy Synthes proprietary solver. All three solvers produced stiffness predictions within 1.3% of each other for identical geometry and boundary conditions, providing strong evidence that numerical implementation errors are negligible. Additionally, the Ansys solver has been verified against NAFEMS benchmark problems LE1 and LE10 (linear elasticity) and the Hertz contact benchmark, all passing at better than 0.5% error. Achieved level 3 exceeds the required level of 2.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-ncv",
        "type": "AcceptanceCriteria",
        "name": "Numerical Code Verification Acceptance Criteria",
        "description": "Cross-code comparison must yield QoI agreement within 2% across all three FEA implementations. NAFEMS benchmark problems must pass at <1% error. Required level 2; achieved level 3."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/discretization-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "A systematic mesh convergence study was performed on the pedicle screw shank and rod-screw interface regions, which are the highest-stress zones. Four mesh densities were evaluated (element edge lengths 0.8, 0.5, 0.3, and 0.15 mm at the screw shank). Richardson extrapolation was applied to the stiffness and yield force QoIs. The grid convergence index (GCI) for the selected mesh (0.3 mm) is 0.8% for stiffness and 1.2% for yield force, both well below the 2% acceptance threshold. The discretization error is formally bounded and documented in the verification report VR-DISC-2023-01. Achieved level 3 (formal GCI computed and reported) exceeds required level 2.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-disc",
        "type": "AcceptanceCriteria",
        "name": "Discretization Error Acceptance Criteria",
        "description": "GCI for all QoIs on the selected mesh must be <2%. Richardson extrapolation must be applied with at least three mesh densities spanning a factor of 2 in element size. Required level 2; achieved level 3."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/numerical-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Iterative solver convergence was monitored for all load steps. The nonlinear residual norm was driven below 1×10⁻⁴ (force norm) and 1×10⁻⁵ (displacement norm) for every increment. Contact stabilization energy was confirmed to be less than 0.1% of total strain energy, indicating that contact stabilization did not artificially stiffen the model. Time-step sensitivity was assessed by halving the load increment size; QoI changes were less than 0.3%. These checks confirm that iterative and time-stepping errors are negligible at the required level 2.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-nse",
        "type": "AcceptanceCriteria",
        "name": "Numerical Solver Error Acceptance Criteria",
        "description": "Nonlinear residual norm must converge below 1×10⁻⁴. Contact stabilization energy must be <0.1% of total strain energy. Load-step sensitivity check must show <1% QoI change on halving increment. Required level 2; achieved level 2."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/use-error",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "An independent analyst (not the original model developer) performed a blind re-execution of the FEA model from the archived input files, following the documented simulation protocol (SP-FEA-NONCANN-2023-01). Results from the independent re-execution agreed with the original predictions to within 0.4% for all three QoIs, demonstrating that the simulation protocol is sufficiently detailed to prevent use errors. The simulation protocol includes explicit checks for unit consistency, boundary condition assignment, and material property mapping. Achieved level 3 (independent blind re-execution) exceeds required level 2.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-ue",
        "type": "AcceptanceCriteria",
        "name": "Use Error Acceptance Criteria",
        "description": "Independent blind re-execution of the model from archived inputs must reproduce QoIs within 1%. Simulation protocol must be documented sufficiently for an independent analyst to execute without guidance. Required level 2; achieved level 3."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/model-form",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The FEA model employs a nonlinear large-displacement formulation with elastic-plastic material behavior (bilinear isotropic hardening for Ti-6Al-4V) and frictional contact (Coulomb, μ=0.2) at the rod-screw interface and screw-bone surrogate interface. The choice of constitutive model was justified by comparison against uniaxial coupon test data for the titanium alloy (agreement within 3% up to 5% strain) and literature values for Sawbones cortical bone surrogate. Geometric nonlinearity is activated for all analyses given the large displacements at 40 mm crosshead travel. The model form is judged appropriate for the QoIs of interest (stiffness, yield force, force at 40 mm) at the required level 3, which demands documented justification of all major modeling assumptions.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-mf",
        "type": "AcceptanceCriteria",
        "name": "Model Form Acceptance Criteria",
        "description": "All major modeling assumptions (constitutive model, contact formulation, geometric nonlinearity) must be documented and justified by reference to experimental data or literature. Constitutive model must reproduce coupon test data within 5%. Required level 3; achieved level 3."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/model-inputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "All model input parameters (geometry, material properties, boundary conditions) were derived from traceable sources. Screw and rod geometry were taken from the manufacturer's nominal drawings with dimensional verification by CMM measurement of three production samples (agreement within ±0.03 mm). Material properties for Ti-6Al-4V were sourced from ASTM F136 certificate of conformance and supplemented by in-house tensile coupon testing (N=3 coupons, E=114 GPa, σ_y=862 MPa). Sawbones surrogate properties were taken from the manufacturer's published data sheet (density 0.32 g/cm³, compressive modulus 2.14 GPa). Friction coefficients were taken from published literature (Shirazi-Adl 1992) and confirmed by the sensitivity analysis to have low impact on QoIs. All input parameters are documented in the model input record MIR-NONCANN-2023-01 with traceability to source documents.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-mi",
        "type": "AcceptanceCriteria",
        "name": "Model Inputs Acceptance Criteria",
        "description": "All model inputs must be traceable to measurement data or published sources. Geometric inputs must be verified by CMM or equivalent to within ±0.05 mm. Material properties must be sourced from test certificates or in-house testing. Required level 3; achieved level 3."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/test-samples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (N=6 at Lab 1, N=5 at Lab 2). All constructs were assembled from production-intent components with lot traceability documented. Pre-test dimensional inspection confirmed screw diameter 7.50 ± 0.02 mm and rod diameter 5.50 ± 0.01 mm for all specimens. The Sawbones bone surrogates were from the same manufacturing lot (lot 2023-A) to minimize inter-specimen variability. The sample size of N=11 provides sufficient statistical power to characterize the experimental mean and standard deviation for comparison with FEA predictions. Inter-laboratory variability was assessed and found not statistically significant (p=0.38), supporting pooling of results.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-ts",
        "type": "AcceptanceCriteria",
        "name": "Test Samples Acceptance Criteria",
        "description": "Minimum N=10 production-intent specimens with dimensional inspection and lot traceability. Inter-laboratory variability must be assessed. Required level 3; achieved level 3 (N=11, two labs, lot-controlled)."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/test-conditions",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "rationale": "Testing was conducted under a single ASTM F1717 static compression-bending condition (5° anterior angulation, 10 mm offset, 50 mm vertebral body height surrogate). While this condition is the standard F1717 protocol and is directly relevant to regulatory submission, only one test condition was evaluated. The required level of 3 for a medium-risk model would normally require testing under multiple load configurations (e.g., varying angulation or offset) to characterize model performance across the operating envelope. The shortfall is acknowledged and addressed by an offset rationale in the decision record: the single F1717 condition is the regulatory standard and is the only condition relevant to the intended use claim; the sensitivity analysis demonstrates low sensitivity of QoIs to geometric perturbations within the operating envelope.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-tc",
        "type": "AcceptanceCriteria",
        "name": "Test Conditions Acceptance Criteria",
        "description": "Required level 3 would require testing under at least two distinct load configurations. Achieved level 2 reflects a single F1717 standard condition. Shortfall is offset by the regulatory relevance of the single condition and the sensitivity analysis demonstrating robustness."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/equivalency-of-input-parameters",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "A formal equivalency mapping was performed between the experimental test conditions and the FEA model inputs. The mapping document (EQM-NONCANN-2023-01) traces each experimental parameter (screw geometry, rod geometry, fixture dimensions, applied displacement rate, temperature) to the corresponding FEA input. All geometric parameters were verified by CMM to within ±0.03 mm of the nominal model values. The quasi-static loading rate (1 mm/min) was confirmed to be within the quasi-static regime for titanium (strain rate < 10⁻³ s⁻¹), justifying the rate-independent elastic-plastic material model. Temperature was controlled at 23 ± 2 °C in both laboratories and in the model (room-temperature material properties used). No unmapped discrepancies between experimental and model inputs were identified.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-eip",
        "type": "AcceptanceCriteria",
        "name": "Equivalency of Input Parameters Acceptance Criteria",
        "description": "All experimental parameters must be mapped to FEA inputs with documented traceability. Geometric parameters must agree within ±0.05 mm. Loading rate must be confirmed quasi-static. No unmapped discrepancies permitted at required level 3. Required level 3; achieved level 3."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Quantitative output comparison was performed for all three QoIs (stiffness, yield force, force at 40 mm displacement) using the validation metric E/uval (ratio of model-experiment difference to combined validation uncertainty). All three QoIs passed the pre-specified acceptance threshold of E/uval < 1.96 (corresponding to 95% confidence interval overlap): stiffness E/uval = 0.74 (Lab 1) and 1.01 (Lab 2); yield force E/uval = 0.82 (pooled); force at 40 mm E/uval = 0.97 (pooled). Percent differences were all below the 10% pre-specified bound. Force-displacement curves were also compared graphically and showed excellent agreement in both linear and post-yield regimes. The output comparison is fully documented in the validation report VR-NONCANN-2023-01.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-oc",
        "type": "AcceptanceCriteria",
        "name": "Output Comparison Acceptance Criteria",
        "description": "E/uval < 1.96 for all QoIs. Percent difference < 10% for all QoIs. Force-displacement curve comparison must be documented. Required level 3; achieved level 3 (all thresholds met for all QoIs)."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/relevance-qoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the primary performance metrics specified in ASTM F1717 and are directly cited in the FDA guidance for spinal implant 510(k) submissions. Construct stiffness characterizes the elastic load-sharing behavior relevant to adjacent segment effects. Yield force characterizes the onset of permanent deformation, which is directly linked to implant fatigue life. Force at 40 mm displacement characterizes post-yield energy absorption, relevant to catastrophic failure risk. All three QoIs are mechanistically linked to the clinical failure modes of interest (screw fracture, rod fracture, construct loosening) and are the quantities that the FEA model is specifically designed to predict for the intended regulatory use.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-rqoi",
        "type": "AcceptanceCriteria",
        "name": "Relevance of QoI Acceptance Criteria",
        "description": "All QoIs must be traceable to ASTM F1717 performance metrics and FDA guidance. Mechanistic linkage to clinical failure modes must be documented. Required level 3; achieved level 3."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/factor/relevance-validation-activities",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The validation activities (ASTM F1717 static compression-bending bench testing of production-intent non-cannulated 7.5 mm pedicle screw constructs) are directly representative of the intended use context. The test fixture, loading configuration, bone surrogate, and implant design are identical to those described in the COU operating envelope. The two-laboratory design provides evidence of reproducibility beyond a single test facility. The validation dataset spans the full range of the operating envelope for the single tested condition. The validation activities are judged highly relevant to the COU at required level 3, as the experimental conditions closely replicate the intended use scenario without requiring extrapolation of the model beyond its validated domain.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/ac-rva",
        "type": "AcceptanceCriteria",
        "name": "Relevance of Validation Activities Acceptance Criteria",
        "description": "Validation test conditions must be representative of the COU (same implant design, same fixture, same loading protocol). Multi-laboratory testing required for level 3. Required level 3; achieved level 3."
      }
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as credible for the stated COU. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. All three QoIs (construct stiffness, yield force, force at 40 mm displacement) pass the pre-specified quantitative acceptance criteria (E/uval < 1.96 and percent difference < 10%) across N=11 experimental specimens at two independent laboratories. The single shortfall — Test conditions factor achieving level 2 against a required level of 3 — is addressed by the offset rationale: the ASTM F1717 single-condition protocol is the regulatory standard and the only condition relevant to the 510(k) submission claim; the sensitivity analysis demonstrates that QoI predictions are robust to geometric perturbations within the operating envelope; and the two-laboratory design provides reproducibility evidence that partially compensates for the single test configuration. The overall credibility of the model is sufficient to support a Medium assurance level conclusion for a Class II device with Medium model influence and Medium decision consequence, consistent with the ASME V&V 40 risk-informed framework.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/or-test-conditions",
      "type": "OffsetRationale",
      "name": "Offset Rationale — Test Conditions Factor Shortfall",
      "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
      "justification": "The Test conditions factor achieves level 2 (single F1717 standard condition) against a required level of 3 (multiple load configurations). This shortfall is accepted because: (1) ASTM F1717 static compression-bending at the standard 5° anterior angulation and 10 mm offset is the sole condition specified in the FDA guidance for non-cannulated pedicle screw 510(k) submissions, making additional test conditions outside the regulatory scope of the intended use claim; (2) the parametric sensitivity analysis (varied friction coefficient 0.1–0.4, modulus ±15%, geometry ±0.05 mm) demonstrates that QoI predictions vary by less than 6% across the operating envelope, indicating that the model is not strongly sensitive to the parameters that would differ across test configurations; (3) the two-laboratory design (N=6 + N=5) provides inter-facility reproducibility evidence that partially offsets the single-condition limitation; and (4) the model risk level 3 with Medium model influence and Medium decision consequence does not require the highest level of test condition coverage when other factors are at or above required levels. The residual risk from the single test condition is judged acceptable given these compensating factors."
    }
  },
