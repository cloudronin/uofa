  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed the required levels (Gradation 3) for Model Risk Level 5. Monte Carlo uncertainty quantification (N=1000) confirms that the 95th-percentile NIH prediction remains below the clinical threshold across all 5 operating points. Validation against FDA generic pump PIV data and independent bench hemolysis measurements demonstrates adequate predictive accuracy (NRMSE 9.3%). Independent peer review confirmed no use errors. The evidence chain is complete and traceable from foundational experimental data through model calibration, verification, and validation to the final decision criterion. The credibility package is accepted for regulatory submission supporting the Class III VAD hemolysis claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
