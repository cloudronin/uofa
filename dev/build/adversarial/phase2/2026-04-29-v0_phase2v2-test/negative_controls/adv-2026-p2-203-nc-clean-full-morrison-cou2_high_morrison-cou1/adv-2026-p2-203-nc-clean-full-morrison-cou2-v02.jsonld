    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis CFD applicability domain",
      "description": "The CFD hemolysis model is applicable to single-stage centrifugal blood pumps with impeller tip diameters between 40 mm and 60 mm, operating at rotational speeds between 1500 RPM and 3500 RPM, and blood flow rates between 2 L/min and 7 L/min. The model is restricted to Newtonian blood rheology approximation (hematocrit 35–45%). Predictions outside these bounds require re-assessment of model form and boundary conditions. The model is not applicable to axial-flow pumps, pulsatile devices, or patients with sickle-cell anaemia."
    },
    "hasOperatingEnvelope": {
