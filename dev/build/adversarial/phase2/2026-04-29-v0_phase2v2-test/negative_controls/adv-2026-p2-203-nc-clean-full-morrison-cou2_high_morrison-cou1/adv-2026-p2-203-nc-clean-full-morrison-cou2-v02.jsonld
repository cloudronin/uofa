  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model (COU2, MRL 5) is accepted on the basis of the following structured evidence: (1) All 13 credibility factors have been assessed at Gradation 5, meeting or exceeding the required level for MRL 5 across all ASME V&V 40 factor categories. (2) Discretisation error is well-controlled (GCI_fine = 1.8%), numerical solver error is negligible (< 0.1% of total uncertainty), and software quality assurance conforms to ASME NQA-1. (3) The primary QoI (NIH) is validated against 5 bench-test operating points with MARE = 6.2% and ASME V&V 20 validation metric u_val = 8.1%, both within the 15% acceptance threshold. (4) A 500-sample global sensitivity analysis identifies rotational speed and blade clearance gap as dominant uncertainty drivers, and the full UQ ensemble demonstrates that the 95th-percentile NIH (0.0061 g/100L) is well below the regulatory threshold of 0.01 g/100L. (5) Model form uncertainty is quantified via Bayesian model comparison; the selected turbulence and hemolysis models are justified by experimental evidence. (6) All validation operating points lie within the defined COU operating envelope; equivalency of input parameters is formally documented with no unmitigated gaps. (7) Use error controls (independent verification, simulation checklist, independent reproduction) are implemented at Gradation 5. The totality of evidence provides high confidence that the CFD model is fit for the intended regulatory purpose of predicting absolute hemolysis index for the FDA generic centrifugal blood pump under CPB conditions at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
