  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/org/morrison-vv40-team/lead-assessor",
    "role": "Credibility assessment team — Lead V&V Engineer",
    "outcome": "Accepted",
    "rationale": "The COU2 credibility assessment for CFD hemolysis prediction at MRL 5 is accepted based on the following comprehensive evidence: (1) All 13 credibility factors are assessed at or above their required levels for MRL 5, with no shortfalls requiring offset rationale. (2) Discretization error (GCI 1.8%) and numerical solver convergence (residuals 10⁻⁶, mass imbalance 0.01%) demonstrate that numerical errors are negligible relative to model form and input uncertainties. (3) Validation against the FDA interlaboratory benchmark dataset shows E_n < 1.0 at all 5 NIH operating points and all 1240 PIV velocity comparison windows, with no systematic bias. (4) The global Sobol sensitivity analysis (2048 samples) identifies hemolysis power-law exponent α and blade clearance as dominant uncertainty contributors, and these inputs have been characterized with documented uncertainty distributions from measurement and literature. (5) Combined expanded uncertainty on NIH predictions (±23%, k=2) encompasses all experimental measurements within the ±25% acceptance band. (6) Model form uncertainty was explicitly quantified through ensemble of 6 model combinations; the selected SST k-ω + Giersiepen formulation is justified and documented. (7) All validation activities are fully relevant to the COU — same geometry class, same fluid analog, same operating envelope — with no extrapolation required. (8) Software quality assurance, use error controls, and configuration management meet MRL 5 requirements. The totality of evidence supports the conclusion that the CFD model is credible for predicting absolute NIH values for the Class II centrifugal CPB pump across the defined operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
