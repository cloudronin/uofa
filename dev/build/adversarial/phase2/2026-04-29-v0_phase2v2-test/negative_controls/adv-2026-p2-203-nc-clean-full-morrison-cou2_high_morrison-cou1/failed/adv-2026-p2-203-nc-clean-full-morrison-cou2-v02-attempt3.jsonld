  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-mrl5-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model at MRL 5 is accepted based on the following evidence: (1) All 13 credibility factors have been assessed and all achieve their required levels (12 at requiredLevel=4, one at requiredLevel=4 with achievedLevel=5). No factor shortfalls exist. (2) The primary QoI (NIH) is directly linked to the regulatory acceptance criterion (RH < 1) and all five operating-point predictions satisfy this criterion with a minimum margin of 18%. (3) Quantitative validation against three independent pump specimens and 45 experimental observations demonstrates mean NIH error of 6.3%, well within the 15% acceptance threshold and within combined uncertainty bounds at all operating points. (4) The global sensitivity analysis (4096-run Sobol ensemble) has identified and bounded the dominant uncertainty sources (hemolysis exponent and tip clearance); targeted validation at these dominant factor ranges confirms model adequacy. (5) The total expanded uncertainty on NIH predictions (95% CI) is ±14.2%, combining numerical uncertainty (±3.1%), experimental uncertainty (±8.2%), model form uncertainty (±9.1%), and input uncertainty (±5.3%) via RSS. This uncertainty is sufficient to support the regulatory decision given the 18% minimum margin. (6) Software quality assurance, use error controls, and provenance traceability are fully documented and verified. The model is fit for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device, and the credibility evidence is sufficient to support regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
