    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 5.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis CFD applicability domain",
      "description": "The CFD model is applicable to centrifugal blood pumps with impeller diameters between 40 mm and 80 mm, operating at rotational speeds between 1500 RPM and 4000 RPM, and blood flow rates between 2 L/min and 8 L/min. The model is restricted to Newtonian blood rheology approximations valid at shear rates above 100 s^-1. Application outside these bounds requires additional validation evidence. The model is not applicable to axial-flow pumps, pulsatile devices, or operating conditions involving cavitation."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "FDA generic centrifugal pump CPB operating envelope",
      "description": "Flow rate: 2.0–8.0 L/min (nominal 5.0 L/min). Rotational speed: 1500–4000 RPM (nominal 2500 RPM). Inlet pressure: 0–20 mmHg. Outlet pressure: 60–150 mmHg. Blood temperature: 20–37 °C. Hematocrit: 30–45%. Impeller tip clearance: 0.15–0.50 mm. Volute gap tolerance: ±0.10 mm. All five flow-speed operating points (Q=2 L/min/2500 RPM, Q=4 L/min/2500 RPM, Q=6 L/min/2500 RPM, Q=4 L/min/1800 RPM, Q=4 L/min/3200 RPM) lie within this envelope."
    }
  },
  "hasSensitivityAnalysis": {
