  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-mrl5-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the FDA GCBP hemolysis CFD model at MRL 5 is accepted based on the following structured evidence: (1) All 13 ASME V&V 40 credibility factors are assessed; all 13 achieve levels meeting or exceeding the required level for MRL 5. No shortfalls exist. (2) Validation results (VR-01 through VR-04) demonstrate agreement between CFD predictions and experimental data across all primary QoIs (NIH, H-Q curve, velocity field, geometric tolerance sensitivity) within combined experimental and numerical uncertainty at 95% confidence. (3) Discretization error (GCI_fine = 1.8%) and iterative convergence (residuals < 1×10⁻⁶) are well-controlled. (4) Model inputs are fully characterized with probability distributions; Bayesian UQ on hemolysis law parameters yields posterior 95% credible interval of ±12.4% NIH at worst case, within the ±15% acceptance threshold established by the clinical risk analysis. (5) Global sensitivity analysis (Sobol, N=4096) identifies hemolysis exponent alpha, impeller speed, and gap clearance as dominant uncertainty drivers; these are all experimentally characterized and their uncertainty is included in the UQ. (6) The validation activities are directly relevant to the COU: same geometry class, full operating envelope coverage, and system-level hemolysis validation. (7) Software quality assurance, use error controls, and simulation governance are documented and independently reviewed. The body of evidence, taken together, provides high confidence that the CFD model is fit for the intended regulatory purpose of predicting absolute NIH values for a Class II CPB device at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
