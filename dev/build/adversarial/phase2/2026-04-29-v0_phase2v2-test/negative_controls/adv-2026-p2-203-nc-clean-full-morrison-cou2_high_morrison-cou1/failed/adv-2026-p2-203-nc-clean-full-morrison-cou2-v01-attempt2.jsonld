  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-mrl5-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model at MRL 5 is accepted based on the following evidence: (1) All 13 credibility factors have been assessed and all achieve the required level 5. (2) Discretisation error (GCI 1.4%) and solver iterative error (residuals < 1×10⁻⁶) are both well below the MRL 5 thresholds. (3) The primary QoI (NIH) is predicted within combined validation uncertainty (±15%) at all five operating points, with the quantitative validation metric E_val/u_val = 0.87 < 1.0. (4) Global sensitivity analysis (Sobol', N=57,344) identifies rotational speed and hemolysis power-law coefficients as dominant uncertainty sources; both are characterised at k=2 level with uncertainties < 5%. (5) Validation experiments were conducted on three independently manufactured specimens in triplicate, confirming manufacturing variability is within model prediction uncertainty. (6) No extrapolation beyond the validated operating envelope (3–6 L/min, 2000–3500 RPM) is required for the COU decision. (7) Full provenance chain from raw experimental data through validation results to credibility factors is documented and independently reviewed. The model is judged fit for purpose for supporting regulatory submission for the Class II CPB device hemolysis assessment at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
