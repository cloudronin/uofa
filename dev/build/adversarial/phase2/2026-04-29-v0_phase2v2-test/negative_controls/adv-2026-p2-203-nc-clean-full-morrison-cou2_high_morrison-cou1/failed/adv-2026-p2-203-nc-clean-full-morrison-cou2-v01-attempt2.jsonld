  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/morrison/sa/cou2-mrl5-sensitivity",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis for CFD hemolysis prediction — MRL 5",
    "description": "A Sobol' variance-based global sensitivity analysis was conducted across 12 input parameters including inlet flow rate (3–6 L/min), rotational speed (2000–3500 RPM), blood viscosity (3.2–4.8 mPa·s), power-law hemolysis model coefficients (α: 0.62–0.82, β: 0.77–0.87), and geometric tolerances on impeller tip clearance (±0.05 mm). A quasi-random Saltelli sampling scheme with N=4096 base samples (total 57,344 model evaluations) was used. First-order and total-order Sobol' indices were computed. Dominant factors by total-order index were: rotational speed (S_T=0.41), hemolysis coefficient α (S_T=0.28), and inlet flow rate (S_T=0.19). Tip clearance contributed S_T=0.07. Blood viscosity and remaining geometric parameters each contributed S_T < 0.03. The analysis confirmed that uncertainty in the hemolysis power-law exponents is the primary driver of output variance, informing the prioritisation of experimental characterisation of these coefficients in the validation campaign.",
    "method": "Sobol variance-based global sensitivity analysis (Saltelli sampling)",
    "dominantFactors": [
      "rotational speed",
      "hemolysis coefficient alpha",
      "inlet flow rate"
    ],
    "sampleSize": 57344
  },
