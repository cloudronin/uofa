  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Ansys Mechanical 2022 R2 used under a validated installation with ISO 9001-certified QMS at the performing laboratory. Software version control, regression test suite (NAFEMS benchmarks), and release qualification documentation reviewed and on file. FDA OSSB internal FEA toolchain operates under 21 CFR Part 11-compliant electronic records system with audit trail.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/sqa-gradation2",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criterion — Gradation 2",
        "description": "Software used under documented QMS with version control and regression testing. Achieved Gradation 3 (independent validation of solver against published benchmarks) exceeds required Gradation 2."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Code verification performed via comparison of Ansys linear-elastic beam and contact element solutions against NAFEMS benchmark LE1 and LE10. Results within 0.5% of reference solutions. Nonlinear material code path verified against published Ramberg-Osgood analytical solutions for Ti-6Al-4V bar under uniaxial loading.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/ncv-gradation2",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criterion — Gradation 2",
        "description": "Solver verified against at least two published benchmark problems relevant to the physics of interest. Achieved Gradation 2 with NAFEMS LE1, LE10, and Ramberg-Osgood verification."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Mesh convergence study performed on the pedicle screw shank and rod-screw interface using three systematically refined meshes (element edge length 1.0, 0.5, 0.25 mm in critical regions). Richardson extrapolation applied; grid convergence index (GCI) < 1.2% for all three QoIs. Final production mesh uses 0.5 mm elements in high-stress zones with 1.0 mm elsewhere.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/disc-error-gradation2",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criterion — Gradation 2",
        "description": "GCI < 5% for all primary QoIs. Achieved GCI < 1.2% (Gradation 3) exceeds required Gradation 2."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Numerical solver error as a distinct V&V 40 factor addresses iterative solver residuals and round-off accumulation in time-marching or iterative schemes (e.g., CFD pressure-velocity coupling, transient structural dynamics with sub-stepping). The present model is a quasi-static implicit nonlinear FEA solved to tight Newton-Raphson convergence criteria (force residual < 1×10⁻⁴, displacement residual < 1×10⁻⁵) with a direct sparse solver (PARDISO). In a direct solver context, round-off error is bounded by the condition number of the assembled stiffness matrix; the condition number was checked at peak load and found to be 8.4×10⁴, well within the double-precision floating-point safe range (~10¹²). No iterative solver tolerance or time-integration truncation error is present. The ASME V&V 40 standard itself notes that this factor may be not-applicable when a direct solver is employed and the problem is not time-dependent. The assessment team reviewed this scoping decision with the lead verification engineer and concurs that no meaningful numerical solver error pathway exists for this model configuration. Accordingly, this factor is marked not-applicable and no required or achieved level is assigned."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Model setup was independently reviewed by a second analyst not involved in original construction. Boundary condition application, material assignment, contact pair definitions, and load step sequencing were each verified against the documented modeling protocol. Two minor discrepancies (incorrect friction coefficient on one contact pair; load application point offset by 0.2 mm) were identified and corrected prior to final runs. Review checklist archived in the project quality record.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/use-error-gradation2",
        "type": "AcceptanceCriteria",
        "name": "Use error acceptance criterion — Gradation 2",
        "description": "Independent peer review of model setup against documented protocol, with documented resolution of all identified discrepancies. Achieved Gradation 2."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Model form selection (isotropic bilinear elastoplastic Ti-6Al-4V for screw, linear elastic UHMWPE for bone analog blocks, surface-to-surface frictional contact at screw-rod interface) is justified by published literature on metallic implant FEA and corroborated by the validation comparison. Sensitivity analysis confirmed that alternative contact formulations (penalty vs. augmented Lagrangian) produce < 2% difference in all QoIs. Model form uncertainty is included in the uval calculation.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-form-gradation3",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criterion — Gradation 3",
        "description": "Model form justified by literature, sensitivity analysis of key modeling assumptions performed, and model form uncertainty quantified and propagated into validation metric. Achieved Gradation 3."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Material properties (elastic modulus, yield stress, tangent modulus) sourced from certified material test reports for the specific Ti-6Al-4V lot used in manufacture. UHMWPE block properties sourced from ASTM F648 specification and confirmed by supplier CoA. Geometric inputs derived from CMM measurements of actual test specimens (N=3 screws measured; mean dimensions used in model). Input uncertainty ranges documented and propagated via Monte Carlo sampling (n=500).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-inputs-gradation2",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criterion — Gradation 2",
        "description": "All primary model inputs traceable to measured or certified sources; input uncertainty ranges documented. Achieved Gradation 2."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. Specimens sourced from the same production lot as the modeled device. CMM measurements of tested specimens confirm dimensional conformance to drawing. Lab-to-lab variability in stiffness results was 3.1% (CV), consistent with expected inter-laboratory reproducibility for ASTM F1717.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/test-samples-gradation2",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criterion — Gradation 2",
        "description": "N ≥ 5 specimens from production lot; dimensional conformance verified; inter-laboratory variability characterized. Achieved Gradation 2."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "rationale": "Testing conducted strictly per ASTM F1717-15 protocol (single compression-bending load case, 5 mm/min crosshead rate, ambient temperature). Only one test condition (load magnitude/rate combination) was evaluated. The required Gradation 3 would demand at least two distinct test conditions or load cases to characterize model behavior across the operating envelope; only one was available due to the standardized nature of the F1717 protocol. This shortfall is acknowledged and addressed in the offset rationale attached to the decision record.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/test-conditions-gradation3",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criterion — Gradation 3",
        "description": "Required: at least two distinct test conditions covering meaningful variation in the operating envelope. Achieved Gradation 2 (single standardized F1717 condition only). Shortfall documented and offset rationale provided."
      },
      "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026/factor/test-conditions"
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "FEA boundary conditions replicate the F1717 fixture geometry (UHMWPE block dimensions, screw insertion depth 44 mm, intervertebral distance 44 mm, load application point). Crosshead displacement rate mapped to quasi-static loading assumption validated by rate-sensitivity check (< 0.5% QoI change between 1 and 10 mm/min). Specimen-specific CMM dimensions used to set model geometry, ensuring input equivalency between simulation and physical test.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/equiv-inputs-gradation2",
        "type": "AcceptanceCriteria",
        "name": "Equivalency of input parameters acceptance criterion — Gradation 2",
        "description": "Model boundary conditions and geometry traceable to measured test configuration; rate-sensitivity confirmed negligible. Achieved Gradation 2."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Quantitative comparison performed for all three QoIs (stiffness, yield force, force at 40 mm). Validation metric E/uval computed per ASME V&V 10.1 framework. All three QoIs satisfy E/uval < 1.96. In addition, full load-displacement curve overlay generated for qualitative assessment; FEA curve tracks experimental mean ± 1 SD envelope throughout the loading range. Systematic bias analysis performed; no load-dependent bias trend detected.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/output-comparison-gradation2",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criterion — Gradation 2",
        "description": "E/uval < 1.96 for all primary QoIs; quantitative metric reported. Achieved Gradation 3 (full curve comparison and bias analysis). Exceeds required Gradation 2."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the regulatory submission endpoints specified in FDA guidance for spinal implant mechanical testing and directly correspond to the COU decision (whether FEA can substitute for or supplement bench testing in design verification). QoI selection was reviewed and approved by the clinical and regulatory team prior to study initiation.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/qoi-relevance-gradation2",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criterion — Gradation 2",
        "description": "QoIs correspond to regulatory submission endpoints and COU decision criteria; selection documented and approved. Achieved Gradation 2."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Validation activity (ASTM F1717 bench test with N=11 non-cannulated constructs) is directly relevant to the COU: same device design, same loading mode, same regulatory test standard, same QoIs. The validation domain fully encompasses the COU domain. No extrapolation beyond the validated envelope is required for the intended regulatory use.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/val-relevance-gradation2",
        "type": "AcceptanceCriteria",
        "name": "Validation activity relevance acceptance criterion — Gradation 2",
        "description": "Validation activity matches COU device, loading mode, regulatory standard, and QoIs without extrapolation. Achieved Gradation 2."
      }
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw construct achieves or exceeds the required credibility level for 12 of 13 assessed V&V 40 factors. All three primary QoIs satisfy the pre-specified quantitative acceptance criterion (E/uval < 1.96), with E/uval values of 0.87, 1.41, and 1.62 for stiffness, yield force, and force at 40 mm respectively. The single shortfall — Test conditions at Gradation 2 against a required Gradation 3 — is inherent to the standardized ASTM F1717 protocol, which specifies a single compression-bending load case. The offset rationale documents that the conservative nature of the F1717 single-condition test, combined with the model's demonstrated accuracy across all three QoIs and the bounded operating envelope of the device, provides sufficient confidence that the shortfall does not meaningfully increase model risk for the intended regulatory decision. The Numerical solver error factor is appropriately marked not-applicable given the use of a direct sparse solver in a quasi-static context. The overall credibility evidence supports acceptance of the FEA framework for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions Gradation 2 shortfall",
        "refersToFactor": "https://uofa.net/synth/factor/test-conditions-noncannulated",
        "justification": "The Test conditions factor achieved Gradation 2 (single standardized ASTM F1717 condition) against a required Gradation 3 (two or more distinct conditions). This shortfall is accepted on the following grounds: (1) ASTM F1717 is the sole regulatory-recognized test standard for spinal implant compression-bending; no alternative load condition exists within the regulatory submission framework, making the shortfall structurally unavoidable rather than a reflection of inadequate study design. (2) The model's predictive accuracy across all three QoIs (E/uval ≤ 1.62 in all cases) and the full load-displacement curve agreement provide high confidence that the model captures the dominant physical mechanisms across the loading range. (3) A supplementary parametric sweep varying crosshead rate (1–10 mm/min) and block modulus (±15%) confirmed QoI sensitivity < 3% across the plausible operating envelope, partially compensating for the absence of a second formal test condition. (4) The overall model risk level (3) and decision consequence (Medium) are consistent with acceptance of a single-condition validation given the offsetting evidence. The assessment team and regulatory lead concur that this offset is appropriate and proportionate.",
        "shortfallFactor": "Test conditions",
        "shortfallGradation": 2,
        "requiredGradation": 3
      },
      {
        "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
