  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble achieves credibility sufficient for the intended regulatory use. Twelve of thirteen V&V 40 factors are assessed; the thirteenth (Relevance of validation activities to the COU) is not applicable because the validation and use contexts are identical. Of the twelve assessed factors, eleven meet or exceed their required credibility gradation. One factor — Test conditions — achieves Gradation 1 against a required Gradation 2, reflecting that testing was conducted under a single ASTM F1717 quasi-static condition. This shortfall is accepted on the grounds documented in the offset rationale: the single test condition is precisely the condition specified by ASTM F1717 and required by the regulatory submission, the COU operating envelope is narrowly defined to that condition, and the validation results (all E/uval < 1.96, all MAPE < 10%) demonstrate that the model performs well within that condition. The overall evidence body — including multi-laboratory experimental data, rigorous uncertainty quantification, mesh convergence documentation, and independent peer review — supports a Medium assurance level consistent with the Medium model risk and Medium decision consequence classification.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 1 (single test condition) against a required Gradation 2. This shortfall is accepted because: (1) ASTM F1717 specifies a single quasi-static compression-bending condition as the standard regulatory test, and no regulatory requirement exists to test at multiple loading rates or temperatures for this device class; (2) the COU operating envelope is explicitly constrained to the single ASTM F1717 condition, so the validation condition fully spans the intended use space; (3) the model risk level (3) and decision consequence (Medium) do not warrant multi-condition testing given the narrow and well-characterized COU; (4) validation results across N=11 specimens at two independent laboratories demonstrate robust model performance (all E/uval < 1.96) within the tested condition, providing high confidence that the model is adequate for the single-condition COU. No additional offset activities are required."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
