    "type": "ContextOfUse",
    "name": "COU1: Tibial tray contact stress under physiological gait loading (Class II)",
    "description": "A finite element model is used to predict peak contact stress at the bone-implant interface of a tibial tray under physiological gait loading conditions. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (misclassification may lead to suboptimal design iteration, not immediate patient harm). Model Risk Level 3.",
    "intendedUse": "Use FE simulation to predict peak contact stress at the tibial tray interface across five physiological loading scenarios corresponding to normal gait, stair ascent, stair descent, chair rise, and deep knee bend. Results inform design acceptance relative to fatigue threshold criteria.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: tibial tray geometry and patient population",
      "description": "Model is applicable to cemented tibial tray designs with a flat-on-flat articulation geometry, UHMWPE insert thickness between 8 mm and 14 mm, and patient body mass index between 20 and 40 kg/m². Extrapolation to cementless fixation, highly conforming designs, or paediatric patients is outside scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: physiological loading and geometry bounds",
      "description": "Axial compressive force: 1.0–3.5 × body weight (700–2450 N for 70 kg reference patient). Anterior-posterior shear: 0–300 N. Flexion angle: 0–120°. UHMWPE elastic modulus: 600–1000 MPa; yield stress: 18–25 MPa. Tibial baseplate outer diameter: 68–82 mm. Cement mantle thickness: 1–3 mm. All five gait scenarios must fall within these bounds for results to be considered valid under this COU."
    }
  },
