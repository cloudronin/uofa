  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-orthopedic-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed the required levels for MRL 3. The FEA model demonstrates adequate credibility for predicting relative peak von Mises stress distributions in the tibial tray keel under physiological gait loading for design comparison purposes. Key evidence: (1) mesh convergence GCI of 1.8% well within the 5% threshold; (2) strain-gauge validation MAPE of 7.3% with formal V&V 10.1 metric computed; (3) DIC cadaveric validation concordance correlation of 0.91; (4) Monte Carlo UQ with 95th-percentile prediction interval of ±12.1%; (5) sensitivity analysis confirming axial load and bone density as dominant uncertainty drivers, directing UQ resources appropriately; (6) all model inputs traceable to NIST-calibrated measurements or certified material data. No credibility factor gaps exist. The model is accepted for its intended use of supporting design comparison decisions between candidate tibial tray geometries under the documented operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
