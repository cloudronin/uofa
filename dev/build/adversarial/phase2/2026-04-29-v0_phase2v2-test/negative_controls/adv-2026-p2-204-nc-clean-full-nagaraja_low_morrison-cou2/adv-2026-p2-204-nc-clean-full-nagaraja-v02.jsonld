  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray stress prediction under physiological gait loading (Class II)",
    "description": "A finite element model is used to predict peak von Mises stress and stress distribution in a cobalt-chromium tibial tray under physiological gait loading conditions representative of a 85 kg patient. Model influence is MODERATE (model informs design comparison; physical bench testing also performed); decision consequence is MODERATE (design selection for a Class II device). Model Risk Level 3.",
    "intendedUse": "Use FEA to predict relative peak von Mises stress distributions in tibial tray designs under standardized gait loading. Results support design-comparison decisions between two candidate geometries; absolute stress values are corroborated by strain-gauge bench tests.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: tibial tray geometry and patient population",
      "description": "The model is applicable only to cobalt-chromium tibial tray components with a posterior-stabilized geometry within the defined size range (size 3 through size 7). Patient body mass is constrained to 60–110 kg. The model is not applicable to unicompartmental implants, cemented fixation variants, or patients with severe osteoporosis (T-score < -2.5) where bone modulus assumptions are violated."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: physiological gait loading bounds",
      "description": "Axial compressive load: 500–3000 N (corresponding to 0.6–3.5 × body weight for the target population). Anterior-posterior shear: 0–300 N. Medial-lateral moment: 0–15 N·m. Flexion angle: 0°–30° (heel-strike to mid-stance phase). Tibial component size: 3–7 (footprint area 42–78 cm²). Material elastic modulus: CoCr alloy 210–230 GPa; UHMWPE insert 0.8–1.2 GPa. Bone bed apparent density: 0.3–1.2 g/cm³. All boundary conditions derived from ISO 14243-1 and in-house cadaveric gait simulator data."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-ortho",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Morris screening sensitivity analysis for tibial tray FEA",
    "description": "A Morris elementary-effects screening study varied eight model inputs — axial load magnitude (±20%), tibial bone apparent density (±30%), CoCr elastic modulus (±5%), UHMWPE insert modulus (±20%), tibial component size (size 3 vs. size 7), cement layer thickness (0–1 mm), flexion angle (0°–30°), and frictional contact coefficient (0.04–0.12) — across 500 model evaluations. Peak von Mises stress in the tray keel showed highest sensitivity to axial load magnitude (μ* = 0.41) and bone apparent density (μ* = 0.29), while cement layer thickness and friction coefficient exhibited negligible influence (μ* < 0.04). These findings directed uncertainty quantification efforts toward load and bone-property inputs and confirmed that the model response is quasi-linear in the operating envelope, supporting the adequacy of the MRL 3 credibility requirements."
  },
