  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/nagaraja-cou1/decision-record-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed at MRL 3 for this Class II orthopedic tibial tray application. Achieved levels meet or exceed required levels for every factor: five factors achieved level 3 against a required level 2 (software quality assurance, discretization error, output comparison, model form), and eight factors achieved the required level 2. The primary QoIs (peak interface micromotion and contact stress) are directly linked to clinical acceptance thresholds. Cadaveric validation across 8 specimens demonstrates MAE of 18 µm for micromotion (well within the 150 µm clinical threshold) and 8.4% RMSE for contact stress. Monte Carlo uncertainty quantification confirms that the 95th-percentile micromotion prediction (148 µm) remains below the 150 µm threshold. Sensitivity analysis identified trabecular bone modulus and friction coefficient as dominant uncertainty contributors, and targeted UQ was performed on these parameters. The provenance chain from foundational material property measurements through validation activities to simulation predictions is complete and traceable. The credibility evidence is sufficient to support the 510(k) submission for this Class II device at MRL 3.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
