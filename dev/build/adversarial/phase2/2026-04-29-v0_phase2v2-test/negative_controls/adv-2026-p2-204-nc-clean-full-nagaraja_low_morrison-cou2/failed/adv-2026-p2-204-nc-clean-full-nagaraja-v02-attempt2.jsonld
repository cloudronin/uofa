  "hasSensitivityAnalysis": true,
  "sensitivityAnalysisDetail": {
    "id": "https://uofa.net/synth/nagaraja-cou1/sensitivity-analysis-001",
    "type": "SensitivityAnalysis",
    "name": "Tibial tray FE sensitivity analysis — material properties and boundary conditions",
    "description": "A one-at-a-time and Morris screening sensitivity analysis was performed varying cortical bone elastic modulus (±20%), trabecular bone modulus (±35%), implant–bone friction coefficient (0.3–0.7), and tibial insert polyethylene yield stress (±15%). Peak interface micromotion was most sensitive to trabecular bone modulus (Sobol index 0.41) and friction coefficient (Sobol index 0.33), with polyethylene yield stress contributing negligibly (Sobol index 0.04). These findings guided targeted uncertainty quantification on the dominant parameters."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/nagaraja-cou1/cou-tibial-tray",
    "type": "ContextOfUse",
    "name": "COU1: Cementless tibial tray fixation under physiological gait loading (Class II)",
    "description": "A finite element model is used to predict peak interface micromotion and contact stress distribution for a cementless tibial tray under physiological gait loading. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (incorrect prediction could result in implant instability requiring revision surgery). Model Risk Level 3.",
    "intendedUse": "Use FE simulation to predict peak tibial tray–bone interface micromotion (target <150 µm) and contact stress distributions across three representative gait loading scenarios. Results are used to support 510(k) substantial equivalence submission alongside cadaveric bench data.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/nagaraja-cou1/cou-tibial-tray/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: cementless tibial tray, adult patient bone quality range",
      "description": "Model applicability is constrained to cementless tibial tray designs with a flat resection surface, adult patients aged 50–80 years with bone mineral density T-score between -2.5 and +1.0, and body mass index 18–40 kg/m². Cemented fixation, pediatric anatomy, severe osteoporosis (T-score < -2.5), and unicompartmental designs are explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/nagaraja-cou1/cou-tibial-tray/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: physiological gait loading bounds",
      "description": "Axial compressive load: 1.0–3.5 × body weight (700–2450 N for 70 kg reference patient). Anterior–posterior shear: 0–350 N. Internal–external tibial rotation: ±10°. Flexion angle at peak load: 0–30°. Implant size range: size 3–7 tibial trays (AP dimension 60–80 mm). Bone modulus range: cortical 15–22 GPa, trabecular 0.1–1.5 GPa. Friction coefficient at implant–bone interface: 0.3–0.7."
    }
  },
