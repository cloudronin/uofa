  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed required levels for MRL 3. The FE model of the tibial tray demonstrates adequate credibility for predicting peak von Mises stress and displacement under physiological loading conditions within the defined COU operating envelope. Quantitative validation against strain gauge and DIC measurements shows mean absolute percentage errors of 4.2% and RMS displacement errors of 0.018 mm, both within acceptance criteria. Monte Carlo uncertainty quantification confirms that model prediction intervals encompass experimental observations. Sensitivity analysis identifies cancellous bone modulus and applied load as dominant uncertainty contributors, and both are well-characterised from traceable sources. The software QA, code verification, and mesh convergence activities confirm numerical credibility. The validation activities use production-representative materials and span the COU operating envelope. No credibility gaps remain; the model is accepted for use in predicting tibial tray stress for the Class II device regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
