  "hasSensitivityAnalysis": true,
  "hasSensitivityAnalysisDetail": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Material property and boundary condition sensitivity analysis — tibial tray FE model",
    "description": "A one-at-a-time and Monte Carlo global sensitivity analysis was performed varying cortical bone modulus (±20%), cancellous bone modulus (±35%), tibial tray CoCr elastic modulus (±5%), and axial compressive load magnitude (±15%). Peak von Mises stress in the tray keel showed the highest sensitivity to cancellous bone modulus (Sobol index 0.41) and applied load magnitude (Sobol index 0.33), while displacement fields were most sensitive to cortical bone modulus. Total output variance attributable to identified inputs exceeded 92%, confirming model response is well-characterised within the defined operating envelope."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-tibial",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray stress prediction under physiological loading (Class II)",
    "description": "A finite-element model is used to predict peak von Mises stress and displacement in a cobalt-chromium tibial tray under physiological compressive and shear loading. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (incorrect prediction could lead to under-designed tray thickness for a Class II device). Model Risk Level 3.",
    "intendedUse": "Use FE simulation to predict peak stress and displacement in the tibial tray across five loading scenarios representative of walking, stair-climb, and deep-knee-bend. Results must demonstrate predicted peak stress remains below 80% of material yield strength with uncertainty bounds.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tibial/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: adult knee replacement population",
      "description": "Model applicability is restricted to adult patients (body mass 50–130 kg) receiving primary total knee arthroplasty with the size-3 through size-7 tibial tray. Revision arthroplasty, paediatric patients, and tibial trays with augments are explicitly excluded from this COU. Bone quality is assumed to correspond to Hounsfield unit range 200–900 HU based on the cadaveric dataset used for validation."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tibial/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: physiological loading bounds for tibial tray FE model",
      "description": "Axial compressive load: 500–3500 N (1× to 5× body weight for 70 kg reference patient). Anterior-posterior shear: 0–350 N. Medial-lateral shear: 0–175 N. Flexion angle: 0–120 degrees. Tibial component size: size 3 (61×42 mm) through size 7 (77×54 mm). Material: CoCr alloy (E = 210 ± 10 GPa, ν = 0.30 ± 0.02). Bone cement mantle thickness: 2–5 mm. All simulations must remain within these bounds; extrapolation beyond this envelope is not covered by the validation evidence."
    }
  },
