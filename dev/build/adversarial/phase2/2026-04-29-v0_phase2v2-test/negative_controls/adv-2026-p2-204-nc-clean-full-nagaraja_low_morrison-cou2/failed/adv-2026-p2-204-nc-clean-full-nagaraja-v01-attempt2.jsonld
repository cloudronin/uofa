  "sensitivityAnalysisDetail": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-ortho-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Material property and boundary condition sensitivity analysis — tibial tray FE model",
    "description": "A one-at-a-time sensitivity analysis was conducted varying cortical bone elastic modulus (±20%), tibial tray CoCr yield strength (±10%), and axial load magnitude (±15% of ISO 14243 nominal). Peak von Mises stress at the tray-stem junction varied by at most 8.3% across all perturbations, confirming that the model output is most sensitive to axial load magnitude and relatively insensitive to material property uncertainty within the specified ranges. A subsequent variance-based Sobol decomposition confirmed that axial load accounts for 71% of output variance, informing the uncertainty quantification bounds reported in the validation results."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho-cou",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray stress prediction under ISO 14243 physiological loading (Class II)",
    "description": "A finite-element model is used to predict peak von Mises stress and fatigue life at the tibial tray-stem junction of a total knee replacement under ISO 14243 cyclic loading. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (incorrect prediction could lead to under-designed implant geometry). Model Risk Level 3.",
    "intendedUse": "Use FE simulation to predict peak von Mises stress (MPa) and fatigue cycles-to-failure at the tray-stem junction for a CoCr tibial tray under five ISO 14243 load cases. Results used alongside physical bench test data to support 510(k) submission geometry acceptance.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho-applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint — tibial tray geometry and material scope",
      "description": "The model is applicable only to CoCr tibial tray geometries with stem diameters between 9 mm and 14 mm, tray thickness between 8 mm and 12 mm, and UHMWPE insert thickness between 8 mm and 12 mm. Titanium alloy trays, cementless fixation with significant micromotion, and pediatric sizing are explicitly excluded. Loading is restricted to ISO 14243-1 standard profiles; impact or stair-descent loading exceeding 3× body weight is outside scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope — ISO 14243 loading and geometric bounds",
      "description": "Axial compressive load: 300 N to 2600 N (ISO 14243-1 nominal 2600 N peak). Anterior-posterior shear: 0 N to 400 N. Flexion angle: 0° to 58°. Internal-external rotation: ±10°. Stem diameter: 9–14 mm. Tray thickness: 8–12 mm. Insert thickness: 8–12 mm. CoCr elastic modulus: 195–215 GPa. Cortical bone elastic modulus: 14–20 GPa. Cyclic loading frequency: 1 Hz. Temperature: 37 °C ± 1 °C (simulated in-vivo environment)."
    }
  },
