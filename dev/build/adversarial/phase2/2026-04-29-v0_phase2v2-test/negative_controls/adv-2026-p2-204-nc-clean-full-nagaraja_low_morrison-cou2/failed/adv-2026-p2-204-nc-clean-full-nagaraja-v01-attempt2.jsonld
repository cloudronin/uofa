  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed. Achieved levels meet or exceed required levels for MRL 3 across all factors. Quantitative validation demonstrates MAPE of 4.7% and Pearson r = 0.97 between FE predictions and bench measurements. Mesh convergence confirmed at GCI = 1.8%. Monte Carlo uncertainty quantification confirms prediction intervals bracket all physical measurements. Sensitivity analysis identifies axial load as the dominant uncertainty contributor (71% of output variance), and this uncertainty is fully accounted for in the UQ bounds. The validation scenario is judged highly representative of the COU. The model is fit for purpose to support 510(k) geometry acceptance for the tibial tray design within the documented operating envelope. Decision: Accepted.",
