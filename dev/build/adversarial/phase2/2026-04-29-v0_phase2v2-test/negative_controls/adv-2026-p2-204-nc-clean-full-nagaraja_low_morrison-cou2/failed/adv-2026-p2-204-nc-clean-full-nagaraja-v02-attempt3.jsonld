    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-tka-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Material property and boundary condition sensitivity analysis — TKA tibial tray",
    "description": "One-at-a-time and variance-based (Sobol) sensitivity analyses were conducted varying cortical bone elastic modulus (±20%, range 14–21 GPa), UHMWPE yield strength (±15%, range 19–26 MPa), tibial component titanium alloy modulus (±5%, range 109–121 GPa), and axial compressive load magnitude (±10%, representing gait variability from 1.8 to 2.2 BW). Peak von Mises stress in the tibial tray showed first-order Sobol index of 0.61 for cortical bone modulus and 0.22 for applied load magnitude, confirming bone modulus as the dominant uncertainty driver; UHMWPE yield strength contributed 0.11 to contact pressure variance. These findings directed targeted experimental characterisation of cadaveric bone specimens to reduce the dominant uncertainty source."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-tka",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray stress prediction under physiological gait loading (Class II TKA)",
    "description": "A finite-element model is used to predict peak von Mises stress and tibio-femoral contact pressure in a cobalt-chromium tibial tray and UHMWPE insert under physiological gait loading. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (incorrect prediction could result in premature implant fatigue failure requiring revision surgery). Model Risk Level 3.",
    "intendedUse": "Use FE model to predict peak stress and contact pressure at the tibial plateau interface across 6 representative gait-cycle load cases. Results must demonstrate stress below fatigue endurance limit of Ti-6Al-4V (620 MPa) and contact pressure below UHMWPE creep threshold (15 MPa). Requires Monte Carlo UQ on material property inputs.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/envelope/nagaraja-cou1-tka-operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Physiological gait loading envelope — TKA tibial tray",
      "description": "Operating envelope bounds: axial compressive load 1500–3200 N (1.8–2.2 BW for 70–80 kg patients); knee flexion angle 0–120 degrees; anterior-posterior shear load 50–350 N; tibial component size range 60–80 mm mediolateral width; UHMWPE insert thickness 8–12 mm; implant alignment within ±3 degrees varus/valgus of neutral mechanical axis; bone cement mantle thickness 2–4 mm where applicable."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/applicability/nagaraja-cou1-tka-applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint — TKA tibial tray FE model",
      "description": "Model is applicable to cemented and cementless primary TKA tibial tray designs in cortical and cancellous bone with density in the range 0.3–1.9 g/cm³ (Hounsfield units 100–1200). Model is NOT applicable to revision TKA (bone defect classification AORI Type II or III), paediatric patients, or patients with metabolic bone disease (T-score < −2.5). Loading conditions must fall within the physiological gait envelope defined in hasOperatingEnvelope; high-impact activities (running, jumping) are excluded."
    }
  },
