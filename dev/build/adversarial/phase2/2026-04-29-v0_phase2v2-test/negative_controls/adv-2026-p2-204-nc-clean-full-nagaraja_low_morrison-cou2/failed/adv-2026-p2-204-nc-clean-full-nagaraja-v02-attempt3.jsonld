  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-tka-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed for the TKA tibial tray FE model at MRL 3. Achieved levels meet or exceed required levels for all factors: Software QA (achieved 3 ≥ required 2), Numerical Code Verification (2 ≥ 2), Discretization Error (3 ≥ 2), Test Conditions (2 ≥ 2), Output Comparison (3 ≥ 2), Relevance of QoIs (2 ≥ 2), Relevance of Validation Activities (2 ≥ 2), Numerical Solver Error (2 ≥ 2), Use Error (2 ≥ 2), Model Form (2 ≥ 2), Model Inputs (3 ≥ 2), Test Samples (2 ≥ 2), and Equivalency of Input Parameters (2 ≥ 2). Monte Carlo uncertainty quantification (5000 samples) confirms peak von Mises stress 95% PI of 312–448 MPa is well below the Ti-6Al-4V fatigue endurance limit of 620 MPa. Contact pressure 95% PI remains below the UHMWPE creep threshold of 15 MPa. Sensitivity analysis identifies cortical bone modulus as the dominant uncertainty driver; targeted experimental characterisation has reduced this uncertainty. Validation against cadaveric strain gauge and pressure film data demonstrates model fidelity (MAPE ≤6.1%) within the COU operating envelope. The credibility evidence package is sufficient to support regulatory submission for a Class II orthopedic device at MRL 3.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
