  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-sa01",
    "type": "SensitivityAnalysis",
    "name": "Wear-debris transport sensitivity to synovial fluid viscosity and particle diameter",
    "description": "A one-at-a-time sensitivity study varied synovial fluid dynamic viscosity over the physiological range (1.5–10 mPa·s) and UHMWPE particle diameter over 0.1–10 µm; the predicted particle deposition fraction on the posterior capsule changed by up to 18% across the viscosity range and 31% across the particle-size range, establishing these as the dominant input uncertainties. A subsequent Sobol first-order analysis confirmed that particle diameter accounts for 52% of output variance and viscosity accounts for 29%, guiding targeted experimental characterisation of the particle size distribution in the validation dataset."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-tkr",
    "type": "ContextOfUse",
    "name": "COU1: Total knee replacement wear-debris transport (Class II)",
    "description": "A CFD model is used to predict the relative spatial distribution of UHMWPE wear-debris particles within the joint space of a total knee replacement under physiological gait loading. Model influence is MODERATE (model supplements bench wear testing); decision consequence is MODERATE (incorrect prediction informs design iteration, not direct patient release). Model Risk Level 3.",
    "intendedUse": "Use CFD to predict relative particle deposition patterns across three gait-cycle loading conditions for a Class II TKR implant. Results are compared against in-vitro PIV and particle-collection data to confirm spatial distribution trends rather than absolute concentrations.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tkr/applicability",
      "type": "ApplicabilityConstraint",
      "name": "TKR applicability constraint — cobalt-chrome on UHMWPE articulation",
      "description": "The model is applicable only to cobalt-chromium femoral components articulating against UHMWPE tibial inserts with a joint gap of 0.5–2.0 mm and synovial fluid volume of 1–4 mL. The model is not applicable to ceramic-on-ceramic articulations, unicompartmental implants, or post-operative joint effusion volumes exceeding 10 mL."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tkr/envelope",
      "type": "OperatingEnvelope",
      "name": "TKR physiological operating envelope",
      "description": "Operating envelope is defined by: flexion angle 0–120°; tibio-femoral contact force 0.5–3.5 kN (1× to 5× body weight for a 70 kg patient); gait cycle frequency 0.8–1.2 Hz; synovial fluid dynamic viscosity 1.5–10 mPa·s at 37 °C; UHMWPE particle diameter 0.1–10 µm with log-normal size distribution (geometric mean 1 µm, GSD 2.5); joint gap 0.5–2.0 mm. Simulations outside these bounds require re-assessment."
    }
  },
