    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability domain: non-cannulated titanium pedicle screws under quasi-static compression-bending",
      "description": "This COU applies exclusively to non-cannulated titanium alloy (Ti-6Al-4V ELI) pedicle screws with nominal outer diameter 7.5 mm and thread pitch 2.5–3.0 mm, tested under quasi-static ASTM F1717 compression-bending loading at room temperature in air. The model is not validated for cannulated designs, dynamic fatigue loading, in vivo bone-implant interface conditions, or screws with outer diameters outside the range 6.5–8.5 mm. Extrapolation beyond these bounds requires additional validation activities."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ASTM F1717 quasi-static compression-bending conditions",
      "description": "Loading: quasi-static compression-bending per ASTM F1717; crosshead displacement rate 5 ± 1 mm/min; maximum applied displacement 40 mm. Screw geometry: outer diameter 7.0–8.0 mm, length 45–55 mm, thread pitch 2.5–3.0 mm. Material: Ti-6Al-4V ELI, elastic modulus 110–120 GPa, yield strength 795–900 MPa. Test block: ultra-high molecular weight polyethylene (UHMWPE) surrogate, compressive modulus 0.8–1.2 GPa. Temperature: 20–25 °C ambient. Screw spacing: 44 mm centre-to-centre per F1717 fixture. These bounds define the validated operating space; predictions outside these ranges are not covered by this credibility assessment."
    }
  },
