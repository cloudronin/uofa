  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 5 for the Class III VAD hemolysis prediction use case. Achieved credibility levels meet or exceed required levels for all factors. The Monte Carlo uncertainty quantification (5000 samples) demonstrates that the 95% prediction interval on NIH brackets all in-vitro measurements within the pre-specified ±25% acceptance criterion. Variance-based sensitivity analysis confirms that the dominant uncertainty source (RBC stress threshold) is appropriately characterized and that the uncertainty budget is conservative. Validation was performed using the identical pump geometry, operating points, and physiologically representative fluid as the COU. Five-laboratory round-robin experimental program provides robust statistical characterization of measurement uncertainty. Software quality assurance, code verification, and discretization error are all demonstrated at the level required for MRL 5. The credibility evidence chain is complete, traceable, and archived. The CFD hemolysis prediction model is accepted as sufficiently credible to support the regulatory submission claim that absolute NIH values are below the clinical threshold across all five VAD operating conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
