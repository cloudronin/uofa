  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/sensitivity/morrison-cou2-vad-sa",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis for VAD hemolysis CFD model",
    "description": "Sobol first-order and total-effect indices were computed across five uncertain inputs — fluid viscosity (±8%), pump rotational speed (±2%), inlet flow rate (±5%), power-law hemolysis exponent (±15%), and mesh density (coarse/medium/fine) — using a 5000-sample Monte Carlo ensemble. The hemolysis index QoI showed highest sensitivity to the power-law exponent (S_T = 0.61) and rotational speed (S_T = 0.22), while viscosity and inlet flow rate contributed minor variance fractions (S_T < 0.08 each); mesh density contributed negligible sensitivity once medium-fidelity resolution was adopted, confirming that model-form uncertainty in the hemolysis constitutive law dominates and must be bounded by experimental calibration data."
  },
  "hasContextOfUse": {
