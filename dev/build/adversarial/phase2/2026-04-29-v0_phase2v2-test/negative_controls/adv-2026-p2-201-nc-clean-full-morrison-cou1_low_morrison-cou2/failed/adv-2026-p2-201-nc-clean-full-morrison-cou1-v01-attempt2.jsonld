  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfu-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model applied to the FDA generic centrifugal blood pump under VAD operating conditions is accepted. All 13 ASME V&V 40 credibility factors have been assessed with achieved levels meeting or exceeding required levels at Model Risk Level 5. Key evidence supporting acceptance: (1) Direct validation of the primary QoI (modified index of hemolysis) against bench measurements at all 5 COU operating points, with validation error 6.8% and validation uncertainty 9.3% — satisfying |E| < U_val; (2) The 95th-percentile upper bound on predicted MIH (0.00512 g/100 L) is 14.7% below the clinical acceptance threshold (0.006 g/100 L), providing a meaningful safety margin that accounts for all quantified uncertainties; (3) Global sensitivity analysis confirms that the dominant uncertainty source (hemolysis power-law exponent) has been characterized and bounded by experimental calibration data; (4) Validation activities used the identical pump geometry and covered the complete COU operating envelope, with equivalency index 0.94; (5) Software quality assurance, code verification, and discretization error assessments all achieved level 4, providing high confidence in the numerical implementation. The structured evidence chain from foundational PIV data through hemolysis bench validation to Monte Carlo uncertainty quantification provides a complete and coherent basis for the acceptance decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
