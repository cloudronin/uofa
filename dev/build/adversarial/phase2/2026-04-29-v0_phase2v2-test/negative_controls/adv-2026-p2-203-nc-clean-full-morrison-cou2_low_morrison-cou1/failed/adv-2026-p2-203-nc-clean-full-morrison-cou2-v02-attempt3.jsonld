    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain for CFD hemolysis prediction",
      "description": "Model is applicable to single-stage centrifugal blood pumps with impeller tip diameters between 30 mm and 60 mm, operating at rotational speeds between 1500 rpm and 4000 rpm, and blood flow rates between 2 L/min and 8 L/min. Blood is modeled as a Newtonian fluid with hematocrit between 30% and 45%. Non-Newtonian effects, two-phase flow, and clot formation are explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB hemolysis operating envelope",
      "description": "Defined operating bounds: flow rate 2–8 L/min; rotational speed 1500–4000 rpm; inlet pressure 0–20 mmHg; outlet pressure 60–120 mmHg; blood temperature 20–37 °C; hematocrit 30–45%; impeller tip clearance 0.1–0.5 mm; volute gap 0.3–1.0 mm. All five evaluated flow-speed operating points lie within these bounds."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/sa/hemolysis-mrl5-sensitivity",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis of CFD hemolysis index to model inputs",
    "description": "Sobol variance-based global sensitivity analysis (N=4096 quasi-random samples, Saltelli sampling scheme) was applied to the power-law hemolysis model parameters (C, alpha, beta), inlet velocity profile shape, blood viscosity, and impeller tip clearance. The scalar hemolysis index (HI) was the response quantity. Results identified the hemolysis model exponent alpha (first-order Sobol index S1=0.41) and tip clearance gap (S1=0.29) as dominant factors, together accounting for 70% of output variance; blood viscosity contributed S1=0.08 and inlet profile shape S1=0.06. Total-order indices confirmed negligible higher-order interaction terms (ST-S1 < 0.05 for all factors). Uncertainty bounds on HI were propagated to the acceptance criterion RH < 1, with 95th-percentile HI remaining below the threshold at all five operating points.",
    "method": "Sobol variance-based global sensitivity (Saltelli 2010)",
    "dominantFactors": [
      "hemolysis model exponent alpha",
      "impeller tip clearance"
    ],
    "sampleSize": 4096
  },
