  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-mrl5-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at MRL 5. Every factor achieves its required level (requiredLevel 4, achievedLevel ≥ 4). Two factors (Numerical code verification and Relevance of QoI) exceed requirements at achievedLevel 5. The primary QoI (normalised hemolysis index) is validated against in-vitro data with MARE 6.2% < combined validation uncertainty U_val 9.1% at 95% coverage; no statistically significant systematic bias is detected. Discretisation error (GCI 1.8%) and iterative convergence (residuals < 1e-6) are both well within acceptance thresholds. Global sensitivity analysis (Sobol, n=512) identifies impeller speed and hemolysis power-law exponent as dominant uncertainty drivers; both are tightly constrained within the validated operating envelope. Model-form uncertainty (±11% NHI) is quantified and bounded within the total validation uncertainty budget. Test conditions are replicated within calibrated tolerances; three production-representative pump units confirm inter-unit CV < 3%. The complete provenance chain from foundational experimental evidence through UQ ensemble to validation results is documented and traceable. The credibility package fully supports regulatory submission for a Class II CPB device hemolysis assessment under the ASME V&V 40 framework.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
