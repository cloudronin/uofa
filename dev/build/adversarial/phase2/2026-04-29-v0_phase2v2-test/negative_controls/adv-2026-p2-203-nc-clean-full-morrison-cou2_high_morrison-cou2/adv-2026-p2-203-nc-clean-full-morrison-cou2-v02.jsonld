  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision/accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluidics-lab/credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at Model Risk Level 5. Achieved levels meet or exceed required levels for every factor: 11 factors achieve exactly the required level (requiredLevel=achievedLevel), and two factors (Discretization Error and Use Error) exceed the required level (achievedLevel > requiredLevel), providing additional assurance margin. The Monte Carlo UQ (n=2000 samples) confirms that the 95% prediction interval on NIH at all five operating points lies below the clinical threshold of 0.01 g/100L, with the upper bound of the 95% PI reaching a maximum of 0.0071 g/100L at the highest-stress operating point (Q=2 L/min, N=4000 RPM). The global sensitivity analysis demonstrates that the dominant uncertainty contributors (wall shear stress and blood viscosity) are well-characterized and that their combined effect is bounded within the validated operating envelope. Validation evidence is directly relevant to the COU: same geometry, overlapping operating conditions, same QoI (NIH), and same fluid. The validation metric E is below 1.0 for all comparison points, confirming model predictions are statistically consistent with experimental observations within combined uncertainties. No extrapolation beyond the validated domain is required for any COU operating point. The provenance chain from raw experimental data through validation results to this credibility assessment is complete and independently auditable. The credibility assessment team unanimously recommends acceptance of the CFD model for predicting absolute hemolysis levels in the COU2 VAD application.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
