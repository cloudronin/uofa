    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis CFD applicability domain",
      "description": "The CFD model is applicable to centrifugal blood pump geometries with impeller tip speeds between 3 m/s and 9 m/s, blood analogue fluids with hematocrit in the range 35–45%, and pump flow rates between 2 L/min and 8 L/min. The hemolysis power-law model (Giersiepen-Wurzinger correlation) is valid only for exposure times above 1 ms and shear stresses below 600 Pa. Extrapolation beyond these bounds requires separate validation evidence."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD operating envelope — flow, speed, and pressure bounds",
      "description": "Operating envelope is defined by five flow-speed combinations: flow rates Q ∈ {2, 3, 4, 5, 6} L/min paired with impeller rotational speeds N ∈ {2400, 2800, 3200, 3600, 4000} RPM. Inlet pressure: 5–15 mmHg. Outlet pressure: 60–120 mmHg. Blood temperature: 37 ± 1 °C. Fluid density: 1050 ± 10 kg/m³. Dynamic viscosity: 0.0035 ± 0.0005 Pa·s. Geometry tolerance on impeller tip clearance: 0.15 ± 0.05 mm. All simulations are conducted under steady-state assumption validated against time-averaged PIV measurements."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/cou2/sensitivity-analysis",
    "type": "SensitivityAnalysis",
    "name": "Monte Carlo global sensitivity analysis — hemolysis index",
    "description": "A variance-based global sensitivity analysis (Sobol indices) was performed using n=2000 Monte Carlo samples drawn from Latin hypercube distributions over six uncertain inputs: blood dynamic viscosity (CV=14%), impeller tip clearance (±0.05 mm uniform), inlet velocity profile shape parameter (±10%), hemolysis model exponent α (±5%), hemolysis model exponent β (±5%), and turbulent dissipation rate boundary condition (±20%). The normalized index of hemolysis (NIH) was the scalar quantity of interest. First-order Sobol indices identified wall shear stress magnitude (driven primarily by tip clearance and viscosity) as the dominant contributor, accounting for 61% of NIH output variance; the hemolysis model exponent α contributed a further 22%. Total-order indices confirmed negligible interaction effects between turbulence boundary conditions and geometry parameters (S_T < 0.04). These results informed targeted experimental validation at extreme viscosity and clearance combinations.",
    "method": "Variance-based Sobol global sensitivity analysis via Monte Carlo sampling with Latin hypercube design",
    "dominantFactors": [
      "wall shear stress magnitude",
      "blood dynamic viscosity",
      "hemolysis model exponent alpha"
    ],
    "sampleSize": 2000
  },
