  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at Model Risk Level 5 for Class III VAD hemolysis prediction. Achieved levels meet or exceed required levels for all factors: discretization error (achieved 5 vs. required 4), numerical solver error (achieved 4 vs. required 3), test samples (achieved 4 vs. required 3), and validation relevance (achieved 5 vs. required 5). The Monte Carlo UQ analysis (n=10,000) demonstrates that 95% prediction intervals for NIH encompass experimental data at all five operating points, and the mean absolute relative error of 8.3% is well within the pre-specified 20% acceptance threshold. The Sobol sensitivity analysis identifies rotor speed and hemolysis model exponent α as dominant uncertainty sources, and targeted calibration has reduced their contribution. The validation dataset, drawn from an independent FDA-sponsored inter-laboratory study with six laboratories and 165 measurements, provides high statistical confidence in the model's predictive capability. Model-form uncertainty was bounded by SST vs. LES comparison (< 11% NIH difference). All simulation inputs are traceable to primary sources with quantified uncertainties. Independent peer review of simulation setup was completed with all discrepancies resolved prior to production runs. The credibility evidence collectively demonstrates that the CFD model is fit for purpose to support regulatory decision-making on absolute hemolysis levels for this Class III VAD device under the defined COU2 operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
