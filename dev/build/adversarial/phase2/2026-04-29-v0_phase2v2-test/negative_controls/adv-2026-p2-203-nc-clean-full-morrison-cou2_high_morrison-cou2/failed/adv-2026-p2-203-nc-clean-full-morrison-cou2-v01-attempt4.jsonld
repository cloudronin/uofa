  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The Morrison COU2 credibility assessment for CFD-based absolute hemolysis prediction of the FDA generic centrifugal blood pump at MRL 5 is accepted. All 13 credibility factors have been assessed; all achieved levels meet or exceed required levels for MRL 5. Key evidence supporting acceptance: (1) All three primary QoIs (NIH, pressure rise, velocity field) validated against FDA CDRH experimental data with quantitative metrics below acceptance thresholds; (2) Global sensitivity analysis (N=10 000 Sobol) identified dominant uncertainty sources and guided targeted Bayesian calibration of hemolysis model coefficients, reducing the NIH 95th-percentile prediction interval to ±0.0011 g/100 L — well below the clinical threshold margin; (3) Monte Carlo UQ ensemble confirms that the 95th percentile of CFD-predicted NIH (0.0072 g/100 L) remains below the clinical threshold of 0.01 g/100 L at all five operating points; (4) Validation hierarchy spans three levels (unit-problem, subsystem, system) using the same geometry and operating conditions as the COU; (5) Independent technical reviews, third-party SQA audit, and replicate testing across three pump specimens provide high confidence in result integrity. No credibility factor shortfalls exist; no offset rationale is required. The model is accepted as credible for predicting absolute hemolysis levels for Class III VAD regulatory submission at the five specified operating points within the documented operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
