    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "COU2 applicability constraint: centrifugal VAD hemolysis domain",
      "description": "The CFD model is applicable only to centrifugal blood pumps with impeller tip diameters between 30 mm and 60 mm, operating at rotational speeds between 2000 and 6000 RPM, and blood viscosity in the range 0.0025–0.0045 Pa·s (representing normal hematocrit 35–50%). The hemolysis power-law model (Giersiepen–Wurzinger) is valid only for shear stress exposures below 400 Pa and exposure times below 700 ms. Application outside these bounds requires reassessment."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "COU2 operating envelope: VAD flow and speed bounds",
      "description": "Operating envelope for the FDA generic centrifugal pump under VAD conditions. Flow rate: 2.5–8.0 L/min. Rotational speed: 2500–5500 RPM. Inlet pressure: 0–20 mmHg. Outlet pressure: 60–120 mmHg. Fluid temperature: 36–38 °C. Blood viscosity: 0.0030–0.0040 Pa·s. Impeller tip clearance: 0.15–0.30 mm. All five flow-speed operating points (2.5/3500, 4.0/3500, 5.5/3500, 5.5/4500, 5.5/5500 L/min/RPM) lie within these bounds."
    }
  },
  "hasSensitivityAnalysis": {
