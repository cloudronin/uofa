  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at MRL 5 for a Class III VAD device. Achieved levels meet or exceed required levels for all factors: Software QA (4≥4), Code Verification (4≥4), Discretization Error (4≥4), Test Conditions (4≥4), Output Comparison (5≥4), QoI Relevance (4≥4), Validation Relevance (4≥4), Solver Error (4≥3), Use Error (3≥3), Model Form (4≥4), Model Inputs (4≥4), Test Samples (3≥3), Equivalency (4≥4). Monte Carlo UQ with 10,000 samples demonstrates that the 95th-percentile NIH prediction remains 18% below the clinical threshold, providing adequate safety margin even under combined worst-case uncertainty. Dominant uncertainty contributors (power-law coefficient α and tip clearance) have been characterised and their contributions bounded. Validation at all five COU operating points shows |E| < U_val, confirming the model is validated within the required accuracy. No shortfalls exist; no offset rationale is required. The CFD hemolysis model is accepted as sufficiently credible to support the Class III VAD regulatory submission for absolute hemolysis acceptance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
