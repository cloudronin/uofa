  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis CFD applicability domain",
      "description": "The CFD hemolysis model is applicable to centrifugal blood pumps with impeller tip speeds between 3 m/s and 12 m/s, blood viscosity between 0.003 and 0.005 Pa·s, hematocrit between 35% and 45%, and pump operating points within the manufacturer-specified H-Q curve envelope. The model is not applicable to axial-flow pumps, pulsatile VAD configurations, or operating conditions producing cavitation (NPSH margin < 0.5 m). Hemolysis index predictions are validated for normalized index values in the range 0.001–0.15 g/100 L."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD CFD operating envelope — concrete bounds",
      "description": "Flow rate: 2.0–8.0 L/min (five test points: 2, 3, 5, 6, 8 L/min). Rotational speed: 2400–3600 RPM (three speed levels). Inlet pressure: 5–20 mmHg. Outlet pressure: 60–120 mmHg. Fluid temperature: 37 ± 1 °C. Impeller diameter: 50 ± 0.5 mm. Surface roughness Ra: 0.4–1.6 µm. Reynolds number range: 1200–18000. All five COU operating points lie strictly within these bounds; extrapolation beyond these limits invalidates model credibility claims."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/sa/cou2-global-sensitivity",
    "type": "SensitivityAnalysis",
    "name": "Sobol global sensitivity analysis — hemolysis index QoI",
    "description": "A variance-based Sobol global sensitivity analysis was performed over 10 000 Monte Carlo samples (Saltelli quasi-random sampling) varying nine model input parameters simultaneously: blood viscosity (±15%), turbulent Schmidt number (±30%), power-law hemolysis exponent α (±8%), stress exponent β (±8%), impeller rotational speed (±2%), inlet hematocrit (±5%), surface roughness (±40%), inlet velocity profile shape factor (±10%), and turbulence intensity at inlet (±50%). The normalized hemolysis index was the sole quantity of interest. First-order Sobol indices identify the power-law exponents α and β as dominant contributors (S1 = 0.41 and 0.29 respectively), with blood viscosity third (S1 = 0.12); total-order indices confirm negligible higher-order interactions (ST − S1 < 0.04 for all inputs). These results drove targeted experimental refinement of the power-law coefficients and informed the uncertainty budget reported in the ValidationResults."
  },
