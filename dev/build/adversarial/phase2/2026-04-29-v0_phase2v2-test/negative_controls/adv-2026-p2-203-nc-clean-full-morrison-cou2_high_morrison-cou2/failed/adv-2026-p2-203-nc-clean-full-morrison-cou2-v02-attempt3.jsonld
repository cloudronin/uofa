  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at MRL 5. Achieved levels meet or exceed required levels for all factors: discretization error (achieved 5, required 4) and use error (achieved 4, required 3) both exceed requirements, providing additional margin. The total combined uncertainty on NIH predictions (18.3% at k=2) is dominated by model form uncertainty (12%) and power-law exponent uncertainty (8%), both of which are fully characterized and propagated. All five COU operating points are within the experimental validation envelope and all CFD predictions fall within the expanded uncertainty band of the experimental data. The Sobol sensitivity analysis confirms that the dominant uncertainty drivers (exponents α and β) have been targeted for experimental refinement, reducing their uncertainty by 35%. The independent peer review of simulation setup identified and resolved all discrepancies prior to production runs. The decision to accept is grounded in: (1) quantitative validation evidence at all COU operating points; (2) complete uncertainty quantification propagated from nine characterized input distributions; (3) GCI-confirmed discretization error of 1.4%; (4) independent SQA-certified solver; and (5) direct equivalency between CFD boundary conditions and experimental test conditions verified to within measurement uncertainty. No factor shortfalls exist; no offset rationale is required.",
    "decidedAt": "2024-11-15T09:00:00Z"
  },
