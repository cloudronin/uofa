    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "The k-ω SST turbulence model was selected based on benchmark comparisons for rotating machinery flows (NASA turbulence model validation archive). The Giersiepen-Wurzinger power-law hemolysis model with Lagrangian particle tracking is the established formulation for CFD hemolysis prediction. Model form uncertainty estimated at 12% (dominant contributor) via comparison of three alternative hemolysis model formulations (Zhang, Taskin, and Giersiepen) across all validation points. This uncertainty is fully propagated into the NIH prediction intervals.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-form",
        "type": "AcceptanceCriteria",
        "description": "Model form selection must be justified by reference to published benchmark data. Model form uncertainty must be estimated by comparison with at least two alternative model formulations and propagated into the total uncertainty budget. The dominant model form uncertainty source must be identified."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "All nine model input parameters (blood viscosity, power-law exponents α and β, turbulent Schmidt number, rotational speed, inlet hematocrit, surface roughness, inlet velocity profile shape factor, turbulence intensity) are characterized with documented probability distributions derived from literature meta-analysis and in-house measurements. Distributions are archived in input uncertainty register IUR-COU2-2024. Sobol sensitivity analysis identifies α and β as dominant; targeted experimental refinement reduced uncertainty on these parameters by 35% relative to literature priors.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "description": "All model inputs must have documented uncertainty characterization (probability distribution or interval). Dominant input uncertainties identified by sensitivity analysis must be refined through targeted experimental or literature data. Input uncertainty register must be archived and version-controlled."
      }
