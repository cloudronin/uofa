    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "COU2 applicability constraint: centrifugal VAD hemolysis domain",
      "description": "Model applicability is restricted to continuous-flow centrifugal blood pumps operating in the VAD configuration with blood viscosity between 3.0 and 4.5 mPa·s, hematocrit between 35% and 50%, and pump speed between 2000 and 4000 RPM. Extrapolation beyond these physiological and operational bounds is not supported by the validation evidence base. The Giersiepen–Wurzinger power-law hemolysis correlation is applicable only within the validated shear-stress range of 1–500 Pa and exposure times of 1–1000 ms."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "COU2 operating envelope: VAD flow and speed bounds",
      "description": "Operating envelope defines the bounded space within which the CFD hemolysis model is claimed valid: volumetric flow rate 3–7 L/min, pump rotational speed 2000–4000 RPM, inlet pressure 5–15 mmHg, outlet pressure 80–120 mmHg, fluid temperature 36–38 °C, and blood-analogue viscosity 3.0–4.5 mPa·s. Geometric fidelity is constrained to the FDA generic centrifugal pump geometry with impeller tip clearance 0.3–0.5 mm. Five operating points (flow-speed combinations) spanning this envelope were evaluated in the validation campaign."
    }
  },
