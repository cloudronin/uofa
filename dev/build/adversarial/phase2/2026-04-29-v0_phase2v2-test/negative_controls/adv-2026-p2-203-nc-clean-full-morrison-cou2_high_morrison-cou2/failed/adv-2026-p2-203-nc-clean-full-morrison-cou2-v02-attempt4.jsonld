  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluidics-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5 with achieved levels meeting or exceeding required levels. Key findings: (1) Discretization error GCI_fine = 2.3% is well within the 5% threshold for Gradation 4; (2) Output comparison AVM = 0.18 satisfies the ≤ 0.25 Gradation 5 threshold with Bayesian bias test passed; (3) Model form uncertainty quantified via BMA with Giersiepen–Wurzinger receiving 61% posterior weight; (4) Full Monte Carlo UQ (N=2000) with Sobol sensitivity analysis identifies hemolysis exponent as dominant uncertainty contributor (S₁=0.62), enabling targeted future uncertainty reduction; (5) Validation relevance VDOS = 0.87 confirms high fidelity of validation campaign to COU operating conditions; (6) Software quality assurance, analyst qualification, and independent peer review satisfy all MRL 5 process requirements. The 95th-percentile upper prediction bound for NIH (0.087 g/100L) remains below the clinical acceptance threshold (0.1 g/100L) across all 5 operating points, providing a positive margin of 13% even under conservative UQ. The single identified gap — absence of in-vivo pulsatile loading in validation experiments — is bounded by the sensitivity analysis and does not overturn the acceptance decision given the conservative upper-bound margin. The credibility evidence package is sufficient to support regulatory submission for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
