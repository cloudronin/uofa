  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/vv40-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at Model Risk Level 5 and all achieved levels meet or exceed required levels. The CFD hemolysis model demonstrates second-order verified accuracy via MMS, asymptotic grid convergence (GCI fine = 1.8%), and quantitative validation against in vitro NIH measurements at 5 operating points across two independent laboratories (E_rms = 0.0031 g/100L against threshold 0.010 g/100L). Monte Carlo UQ with 5000 samples propagates all identified input uncertainties; 95% prediction intervals encompass all experimental measurements. Sobol sensitivity analysis identifies the hemolysis power-law exponent and rotational speed as dominant uncertainty contributors, and targeted experimental data support these parameters. The validation activities are directly relevant to the COU — identical geometry, operating conditions within the envelope, and QoI identical to the FDA regulatory metric. The parameter equivalency matrix confirms all validation inputs are representative of deployment conditions with documented bounds on minor gaps. The software quality plan, simulation execution protocol, and analyst qualification records are complete and independently reviewed. The decision to Accept is supported by the comprehensive, internally consistent evidence package with no unresolved credibility gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
