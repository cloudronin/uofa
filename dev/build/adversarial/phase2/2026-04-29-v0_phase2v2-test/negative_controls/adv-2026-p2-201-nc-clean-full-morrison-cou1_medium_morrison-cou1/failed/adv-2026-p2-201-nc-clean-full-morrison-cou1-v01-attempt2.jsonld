  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/biomed-cfd-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed and all achieve their required levels for Model Risk Level 2. The CFD model demonstrates: (1) software quality assurance at Gradation 2 with documented SQA and unit-tested user-defined functions; (2) numerical code verification via MMS with observed order consistent with theoretical order; (3) discretization error bounded at GCI=3.1% (Gradation 3, exceeding the Gradation 2 requirement); (4) test conditions fully documented and traceable; (5) quantitative output comparison with all predictions within the validation uncertainty interval; (6) QoI directly relevant to the regulatory hemolysis criterion; (7) validation activities spanning the full COU operating envelope; (8) solver convergence confirmed to 1×10⁻⁵ residuals; (9) use error controls via independent review and execution checklist; (10) model form justified by literature and bounded by validation; (11) all inputs documented with propagated uncertainties; (12) specimen variability characterized across three pump samples; and (13) parameter equivalency documented with all deviations below 2% impact on QoI. The relative hemolysis index RH < 1 at all five operating points, satisfying the acceptance criterion. The worst-case operating condition (2 L/min, 3500 RPM) is clearly identified and confirmed by the sensitivity analysis. The total model uncertainty budget, combining discretization error, input uncertainty, and model form uncertainty, yields a 95% prediction interval that remains below the RH=1 threshold with margin. The credibility assessment supports Accepted status for COU1 at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
