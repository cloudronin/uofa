  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/morrison/sensitivity/cou1-cpb-sa",
    "type": "SensitivityAnalysis",
    "name": "COU1 hemolysis sensitivity analysis — flow rate and rotational speed",
    "description": "A one-at-a-time sensitivity study varied pump flow rate across 2–6 L/min and rotational speed across 1500–3500 RPM in 500 RPM increments, spanning all five COU operating points. The relative hemolysis index (RH) showed peak sensitivity to rotational speed at low flow (2 L/min, 3500 RPM), with RH increasing by 0.18 per 500 RPM increment, while flow rate at fixed speed produced a monotonically decreasing RH response with a slope of −0.04 per L/min. These findings confirmed that the worst-case operating condition is identifiable and that model predictions are robustly ordered across the operating envelope."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis COU applicability constraint",
      "description": "The CFD model is applicable to single-stage centrifugal blood pumps with impeller diameters between 40 mm and 60 mm, operating with Newtonian blood analog fluid (viscosity 3.5 cP, density 1060 kg/m³) at hematocrit 40±5%. The model is restricted to steady-state operating conditions and does not cover transient startup/shutdown phases, cavitation regimes, or patient-specific anatomical variations. Geometry must conform to the FDA generic pump family with tolerance bands as specified in the COU geometry dataset."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB hemolysis operating envelope",
      "description": "Flow rate: 2.0–6.0 L/min (five discrete points: 2, 3, 4, 5, 6 L/min). Rotational speed: 1500–3500 RPM (five discrete points at 500 RPM intervals). Inlet pressure: 5–15 mmHg. Outlet pressure: 80–120 mmHg. Blood temperature: 35–37 °C. Impeller tip clearance tolerance: 0.1–0.3 mm. All five flow-speed combinations used in the worst-case identification sweep lie within these bounds. Extrapolation beyond these envelope limits is not supported by the current validation evidence base."
    }
  },
