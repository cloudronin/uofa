  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-computational-modeling-group",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the FDA generic centrifugal blood pump CFD hemolysis model under CPB conditions is accepted at Model Risk Level 2. Eleven of thirteen credibility factors were assessed; all eleven meet or exceed their required gradation levels. Two factors (Test samples and Equivalency of input parameters) are documented as not-applicable with thorough rationale reflecting the benchmark-geometry validation approach used. All validation results include quantified uncertainty and are compared against experimental data traceable to calibrated instrumentation. The primary QoI (NIH, RH) shows mean absolute error of 8.3% against experimental measurements, within the combined uncertainty band. Discretization error is well-controlled (GCI < 2.1%). The model form (SST k-omega, Giersiepen power-law hemolysis) is justified by published benchmark evidence. The provenance chain from raw experimental data through validation activities to the decision record is complete. No credibility shortfalls exist; no offset rationale is required. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
