  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) All 11 assessed credibility factors meet or exceed their required levels for MRL 2, with discretization error achieving level 3 against a level 2 requirement. (2) Two factors (Test samples and Equivalency of input parameters) are marked not-applicable with thorough rationale: Test samples is N/A because validation uses a standardized FDA reference artifact rather than production samples; Equivalency of input parameters is N/A because model inputs directly match experimental conditions without parameter translation. (3) Validation results demonstrate CFD-predicted RHI within 12% of experimental measurements across all 5 operating points, with combined validation uncertainty envelope encompassing all data. (4) Sensitivity analysis identifies worst-case hemolysis at 3500 RPM, 2 L/min, maximum tip clearance, providing the bounding case for regulatory comparison. (5) The provenance chain is complete from foundational FDA benchmark data through validation activities to this assessment. No shortfalls exist between achieved and required levels for any assessed factor; no offset rationale is required. The model is assessed as fit for the stated COU of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
