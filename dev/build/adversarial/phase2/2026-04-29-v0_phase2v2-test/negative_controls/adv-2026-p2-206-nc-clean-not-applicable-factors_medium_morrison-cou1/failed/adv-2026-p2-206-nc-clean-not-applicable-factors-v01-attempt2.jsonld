  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD prediction of worst-case hemolysis for a Class II CPB centrifugal blood pump at MRL 2) is accepted on the following grounds. All 11 assessed credibility factors meet or exceed their required gradation levels: software quality assurance, numerical code verification, discretization error (GCI 3.1% < 5% threshold), test conditions, output comparison (mean error 8.3%, all points within 15% band), QoI relevance, validation relevance, numerical solver error, use error, model form, and model inputs are all at or above Gradation 2. Two factors — Test samples and Equivalency of input parameters — are appropriately marked not-applicable with thorough rationale: the single-geometry COU does not require multi-specimen statistics, and the validation uses the identical device geometry and operating conditions precluding any equivalency gap. Uncertainty quantification via 500-sample Monte Carlo propagation confirms the 95th-percentile NIH prediction uncertainty of ±12% is within the regulatory acceptance band. The provenance chain from foundational experimental datasets through validation activities to the decision record is complete. No weakeners are present. The structured evidence base collectively supports the claim that the CFD model reliably identifies worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
