  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 11 assessed credibility factors meet or exceed their required gradation levels for MRL 2. Discretization error (GCI_fine=1.8%) and QoI relevance (Gradation 3) exceed requirements, providing additional confidence margin. The two not-applicable factors (Test samples, Equivalency of input parameters) are excluded on well-documented technical grounds: the benchmark geometry is deterministic with no specimen variability, and validation conditions directly match COU conditions without scaling. Three independent ValidationResults demonstrate NIH prediction within 15% of bench measurements (mean 6.8%), pressure-head within 4.2%, and shear stress spatial correlation R=0.94. Uncertainty quantification via Monte Carlo propagation and GCI analysis confirms combined uncertainty is bounded and consistent with the acceptance criteria. The decision to accept the model for COU1 (identifying worst-case hemolysis operating conditions for a Class II CPB device) is fully supported by the structured evidence chain from foundational data through validation activities to the credibility factor assessments.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
