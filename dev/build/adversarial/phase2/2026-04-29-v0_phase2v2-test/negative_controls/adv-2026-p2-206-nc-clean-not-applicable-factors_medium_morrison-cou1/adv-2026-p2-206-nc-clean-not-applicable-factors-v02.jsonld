  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 11 assessed credibility factors meet or exceed their required levels for MRL 2. Discretization error and use error both achieved level 3 and level 2 respectively, exceeding minimum requirements. Two factors (Test samples, Equivalency of input parameters) are formally designated not-applicable with thorough documented rationale: Test samples is inapplicable because validation uses a deterministic blood analog fluid rather than donor blood, and Equivalency of input parameters is inapplicable because the COU is a within-device worst-case identification task rather than a predicate-equivalence demonstration. Three independent validation datasets (bench hemolysis NIH, hydraulic pressure-head, PIV shear stress) all confirm model predictive accuracy within uncertainty bounds. Sensitivity analysis confirms the model correctly identifies rotational speed and tip clearance as dominant hemolysis drivers. The provenance chain from raw experimental data through validation results to the credibility factors is complete and traceable. The decision to accept this UofA for use in the CPB device tolerance analysis is fully supported by the structured evidence.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
