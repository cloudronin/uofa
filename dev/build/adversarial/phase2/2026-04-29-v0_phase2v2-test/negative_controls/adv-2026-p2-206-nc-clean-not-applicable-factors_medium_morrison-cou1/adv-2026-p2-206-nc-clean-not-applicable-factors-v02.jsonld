        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria",
        "description": "Turbulence model selection must be justified by published benchmark evidence for similar rotating blood-contacting geometries. Model form uncertainty for NIH must be estimated and documented; discrepancy against higher-fidelity reference must be below 20% for MRL 2."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "All model inputs (fluid density 1056 kg/m³, dynamic viscosity 3.5 mPa·s at 37°C, pump geometry from CMM-verified CAD, rotational speeds 2000–3500 RPM, inlet flow rates 3–6 L/min) sourced from traceable measurements or published material property databases. Input uncertainty ranges defined and propagated through sensitivity analysis. No assumed or estimated inputs without documented basis.",
      "acceptanceCriteria": {
