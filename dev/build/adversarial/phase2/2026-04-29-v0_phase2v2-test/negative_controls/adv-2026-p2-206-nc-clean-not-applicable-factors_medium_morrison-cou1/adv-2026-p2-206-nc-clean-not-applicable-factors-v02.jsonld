    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Reynolds-Averaged Navier-Stokes (RANS) with SST k-ω turbulence closure selected based on published benchmark studies of centrifugal blood pump hemolysis (Hariharan et al. 2011, Zhang et al. 2014). Power-law hemolysis model (Giersiepen et al. 1990, recalibrated by Heuser & Opitz 1980) applied as a post-processing scalar transport equation. Model form uncertainty estimated via comparison against LES reference solution at nominal operating point; NIH discrepancy 9.4%, within acceptable range for MRL 2.",
      "acceptanceCriteria": {
