  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling-group",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model applied to the FDA generic centrifugal blood pump under CPB conditions is accepted at MRL 2. Seven credibility factors were formally assessed: Software QA (achieved Gradation 2, required 1), Numerical Code Verification (achieved 2, required 1), Discretization Error (achieved 2, required 2), Test Conditions (achieved 3, required 2), Output Comparison (achieved 2, required 2), Relevance of QoIs (achieved 2, required 2), and Relevance of Validation Activities (achieved 2, required 2). All seven assessed factors meet or exceed their required gradation levels. Six factors (Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, Equivalency of Input Parameters) are scoped out with documented rationale appropriate for MRL 2 with a commercial solver and direct validation scenario correspondence. Quantitative validation demonstrates NIH prediction agreement within 8% at the primary operating point and within 15% across the 5-point operating envelope, with combined uncertainty of 12.1% within the 20% acceptance threshold. The worst-case operating condition (1.5 L/min, 4200 RPM) is correctly identified by the model. The evidence chain from foundational experimental data through validation results to the credibility factor assessments is complete and traceable. The model is accepted as fit for purpose to support the regulatory decision on worst-case hemolysis operating conditions for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
