    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "In-vitro bench test conditions replicated the five CFD operating points within ±3% on flow rate and ±1.5% on rotational speed. Blood analog fluid (glycerol-water mixture, viscosity 3.5 mPa·s at 37°C) properties matched simulation inputs. Temperature controlled to 37±0.5°C throughout testing. Pump geometry confirmed via CMM measurement post-test.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-conditions-mrl2",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criterion — MRL 2",
        "description": "Gradation 2 requires that test conditions are documented and nominally matched to simulation inputs. All five operating points matched within ±3% on primary boundary conditions; fluid properties confirmed; geometry verified by CMM."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Quantitative comparison of CFD NIH predictions against experimental measurements performed using mean absolute relative error (MARE) and validation metric per ASME V&V 20. MARE = 8.3% across five operating points; validation uncertainty interval at 95% confidence is ±12.7%, encompassing all experimental data points. No systematic bias detected across the operating envelope.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/output-comparison-mrl2",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criterion — MRL 2",
        "description": "Gradation 2 requires quantitative comparison metric computed and reported. MARE < 15% for NIH QoI. Achieved MARE = 8.3%; criterion satisfied. Validation uncertainty interval computed per ASME V&V 20."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is the clinically and regulatory accepted metric for pump-induced hemolysis per FDA guidance and ISO 10993-4. NIH directly maps to the decision criterion (RH < 1 relative to predicate device). Secondary QoI (pressure head, wall shear stress distribution) are mechanistically linked to hemolysis and validated independently.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/qoi-relevance-mrl2",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criterion — MRL 2",
        "description": "Gradation 2 requires documented justification that the modeled QoI maps to the clinical/regulatory decision metric. NIH is the FDA-accepted hemolysis metric; direct mapping to RH acceptance criterion confirmed. Secondary QoI mechanistic linkage documented."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Validation activities used the identical FDA generic centrifugal pump geometry, the same five COU operating points, and the same blood analog fluid as the COU simulations. Validation domain fully overlaps the COU domain with no extrapolation required. The bench test apparatus replicates the clinical flow circuit configuration (tubing compliance, reservoir geometry) to the extent feasible for in-vitro testing.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/validation-relevance-mrl2",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance acceptance criterion — MRL 2",
        "description": "Gradation 2 requires that validation activities are conducted at conditions relevant to the COU. Identical geometry, fluid, and operating points used; no extrapolation beyond validated domain required for COU predictions."
      }
