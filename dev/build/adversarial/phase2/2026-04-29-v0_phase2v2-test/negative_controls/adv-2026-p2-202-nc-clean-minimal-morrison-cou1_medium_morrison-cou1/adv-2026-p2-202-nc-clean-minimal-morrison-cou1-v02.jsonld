  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-division-of-applied-mechanics",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) Seven credibility factors were formally assessed; all seven achieved levels meeting or exceeding the MRL 2 required levels. Discretization error achieved Gradation 3 against a Gradation 2 requirement, providing additional margin. (2) Six factors were scoped out with documented rationale consistent with MRL 2 expectations; the scoping decisions are supported by the coincidence of validation and COU domains and by the peer-review controls applied to simulation inputs. (3) Two independent validation results demonstrate CFD prediction of NIH within 8.3% MARE of experimental measurements, with validation uncertainty intervals computed per ASME V&V 20 encompassing all data points. (4) The provenance chain is complete: experimental data traced to calibrated instrumentation, simulation outputs traced to version-controlled solver and mesh files, and all activities documented in archived simulation plans. (5) No systematic bias was identified across the five-point operating matrix. The model is judged fit for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device. The RH < 1 acceptance criterion was satisfied at all five operating points with sufficient margin to account for quantified uncertainties.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
