  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw under ASTM F1717 compression-bending is accepted as sufficiently credible for the intended regulatory decision. Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — is addressed by the offset rationale below. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both the E/uval < 1.96 validation metric and the less-than-10% percent difference acceptance criterion across N=11 constructs from two independent laboratories. Uncertainty quantification is complete and traceable. The model risk level of 3 is consistent with the Medium assurance level determination given the Medium model influence and Medium decision consequence. The provenance chain from raw experimental data through FEA runs to validation results is fully documented.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/test-conditions-offset",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs required 3)",
        "description": "The single test condition (quasi-static 10 mm/min per ASTM F1717) represents the standard regulatory submission condition and is the condition most directly relevant to the 510(k) decision. Published literature (Goel 2006, Nagaraja 2017) demonstrates that pedicle screw construct stiffness and yield force under ASTM F1717 are not materially sensitive to loading rate in the quasi-static regime (0.1–100 mm/min), with QoI variation below 3% across this range. The shortfall in condition breadth is therefore offset by: (1) the high relevance of the single condition to the COU, (2) published evidence of low rate sensitivity, and (3) the conservative nature of quasi-static loading relative to fatigue. The credibility assessment team judges that the overall body of evidence is sufficient to support the Accepted decision at Medium assurance level despite this single factor shortfall."
      },
      {
        "id": "https://uofa.net/synth/decision/noncannulated-f1717-decision-001/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/noncannulated-f1717-decision-001/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
