      "type": "OperatingEnvelope",
      "name": "ASTM F1717 compression-bending operating envelope",
      "description": "Axial compressive load 0–2000 N applied at 10 mm/min crosshead rate; bending moment arm fixed at 40 mm per ASTM F1717 fixture geometry; screw diameter 7.5 mm nominal (tolerance ±0.05 mm); vertebral body block spacing 40 ± 1 mm; test temperature 23 ± 2 degrees C; displacement range 0–50 mm."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated 7.5 mm pedicle screw under ASTM F1717 static loading",
      "description": "Model applicability is restricted to non-cannulated solid-core pedicle screws with nominal shank diameter 7.0–8.0 mm, titanium alloy Ti-6Al-4V ELI, tested under quasi-static monotonic compression-bending per ASTM F1717. Dynamic fatigue loading, cannulated geometries, and screws outside the specified diameter range are explicitly excluded from this COU."
    }
  },
  "hasSensitivityAnalysis": {
