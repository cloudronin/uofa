  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for the non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending COU is accepted at Medium assurance level. All 13 V&V 40 credibility factors were assessed. Twelve factors achieved their required gradation level or exceeded it (Software QA: 2/2, Code Verification: 2/2, Discretization Error: 3/2, Solver Error: 2/2, Use Error: 2/2, Model Form: 3/3, Model Inputs: 3/2, Test Samples: 2/2, Equivalency: 2/2, Output Comparison: 3/2, QoI Relevance: 2/2, Validation Relevance: 2/2). One factor (Test conditions) achieved Gradation 2 against a required Gradation 3. This shortfall is offset by: (1) conservative acceptance bounds (< 10% QoI difference, E/uval < 1.96) that are tighter than the minimum required; (2) corroborating evidence from three independent FEA implementations showing inter-model spread < 3%; and (3) the Medium model risk level and Medium decision consequence, which together confirm that the single-condition validation is adequate for regulatory decision support. The offset rationale is formally documented. All three primary QoIs satisfy the validation metric (E/uval range 1.31–1.54, all < 1.96 threshold). The provenance chain is complete from foundational experimental data through uncertainty quantification to the validation results.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs. required 3)",
        "justification": "The Test conditions factor achieved Gradation 2 (single ASTM F1717 standard test condition) against a required Gradation 3 (two or more independent test conditions). This shortfall is accepted because: (a) the single test condition is the regulatory gold standard for spinal implant mechanical characterization per ASTM F1717 and FDA guidance; (b) three independent FEA implementations produced inter-model QoI spread < 3%, providing orthogonal evidence of model robustness that partially substitutes for multi-condition experimental coverage; (c) acceptance bounds are set conservatively at < 10% QoI difference rather than the < 15% that would be permissible at Gradation 2; and (d) the Medium model risk level and Medium decision consequence (revision surgery, not mortality) mean that the residual uncertainty from single-condition testing does not compromise patient safety at the intended assurance level.",
        "refersToFactor": "https://uofa.net/synth/nc10-noncannulated-f1717-compression-bending-001/factor/test-conditions"
      },
      {
        "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
