  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA credibility assessment for the non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending COU is accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed their required credibility level. The single shortfall — Test conditions (achieved Gradation 1 vs. required Gradation 2) — is addressed by the offset rationale below. All three primary QoIs (stiffness, yield force, force at 40 mm displacement) are predicted within the pre-specified <10% acceptance bound, and all E/uval ratios are below 1.96, indicating that the model error is within the combined validation uncertainty. The provenance chain is complete from foundational material test data through CMM geometry measurements, mesh convergence study, and inter-laboratory bench testing to the final comparison metrics. The FEA ensemble approach (three independent modeling teams) provides additional confidence that the results are not sensitive to analyst-specific modeling choices.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 1 rather than the required Gradation 2 because testing was conducted under a single ASTM F1717 standard condition. This shortfall is offset by three compensating strengths: (1) the single test condition is the regulatory standard condition (ASTM F1717) and is the exact condition relevant to the 510(k) submission decision, making additional conditions unnecessary for the specific COU; (2) the probabilistic sensitivity analysis on model inputs (Model inputs factor, Gradation 3) demonstrates that QoI predictions are robust to the range of material property and friction coefficient variation expected across production lots, providing indirect evidence of condition robustness; and (3) the inter-laboratory validation across two independent facilities (Lab 1 and Lab 2) provides a form of condition variation (different equipment, operators, and environmental conditions) that partially compensates for the absence of formally varied test conditions. The net credibility evidence is sufficient to support Medium assurance level acceptance for this COU."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
