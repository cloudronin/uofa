  "signature": "ed25519:b2d4e8f1a3c57091e6b4d2f8a0c3e5b7d9f1a3c5e7b9d1f3a5c7e9b1d3f5a7c9",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The CFD solver (ANSYS Fluent 2024R1) is governed by an ISO 9001:2015-certified quality management system. Version control, regression test suite (1,247 automated tests), and release validation documentation are on file. Software change logs reviewed; no open defects affecting rotating machinery or scalar transport modules.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/sqa-level3",
        "type": "AcceptanceCriteria",
        "name": "SQA Gradation 3 criteria",
        "description": "Solver must be under a documented QMS with version control and automated regression testing. All safety-critical modules must pass regression suite with zero open critical defects."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and scalar hemolysis transport equations. Observed order of accuracy 1.97 (expected 2.0 for second-order scheme); deviation within 1.5% of theoretical order. Benchmark comparisons against three ASME V&V 20 lid-driven cavity and pipe flow cases all pass with normalized errors below 0.5%.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/code-verification-level3",
        "type": "AcceptanceCriteria",
        "name": "Code verification Gradation 3 criteria",
        "description": "Observed order of accuracy must be within 10% of theoretical order via MMS. At least two benchmark cases from recognized standards must be passed."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Three-level mesh refinement study performed (coarse 2.1M, medium 5.8M, fine 14.2M cells). Grid convergence index (GCI) computed per Celik et al. 2008. GCI for NIH at design point: 3.2% (fine-medium), 8.7% (medium-coarse). Asymptotic range confirmed (GCI ratio 0.97). Fine mesh selected for production runs.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/discretization-level3",
        "type": "AcceptanceCriteria",
        "name": "Discretization error Gradation 3 criteria",
        "description": "Three-level GCI study required. Fine-to-medium GCI must be below 5% for primary QoI. Asymptotic convergence ratio must be between 0.95 and 1.05."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "In-vitro test conditions replicate COU operating envelope: porcine blood analog (glycerol-water, matched hematocrit 40±1%), pump speed 2500 and 3500 RPM, flow rates 3–8 L/min. Temperature maintained at 37±0.5°C. Five operating points tested match the five CFD simulation conditions exactly. Test rig calibration certificates current within 12 months.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-conditions-level3",
        "type": "AcceptanceCriteria",
        "name": "Test conditions Gradation 3 criteria",
        "description": "Experimental boundary conditions must match simulation inputs within stated tolerances. Fluid analog properties must be documented. All five COU operating points must be represented in the test matrix."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "NIH predicted vs. measured at all 5 operating points. Statistical comparison using E_rms = 8.3% and maximum absolute error 14.7%. Comparison metric includes experimental uncertainty (±6% from repeat measurements, k=2). Model validation metric per ASME V&V 20 computed; model falls within validation uncertainty at 4 of 5 points; fifth point within 1.1 sigma. Detailed comparison table in validation report VR-2025-07.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/output-comparison-level3",
        "type": "AcceptanceCriteria",
        "name": "Output comparison Gradation 3 criteria",
        "description": "Quantitative comparison metric (ASME V&V 20 validation metric) must be computed. Model must fall within validation uncertainty at a minimum of 4 of 5 operating points. RMS error must be below 15%."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the direct clinical and regulatory metric for hemolysis acceptance. Secondary QoIs (shear stress distribution, residence time) are mechanistically linked to NIH via the power-law hemolysis model. All QoIs are directly traceable to the device acceptance criterion in the COU.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/qoi-relevance-level3",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance Gradation 3 criteria",
        "description": "Primary QoI must be the regulatory acceptance metric. Secondary QoIs must be mechanistically linked to primary QoI. Traceability from QoI to COU acceptance criterion must be documented."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Validation activities performed on the FDA generic centrifugal pump geometry — the same geometry used in the COU. Operating conditions span the COU envelope. Blood analog properties are representative of clinical use. Validation domain is not a surrogate geometry; it is the actual device geometry under representative conditions. Validation relevance score assessed as high per Morrison Table 4 criteria.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/validation-relevance-level3",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance Gradation 3 criteria",
        "description": "Validation must be performed on the same or geometrically equivalent device. Operating conditions must span the COU envelope. Fluid properties must be representative of clinical use conditions."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Iterative convergence monitored via residual norms (continuity, momentum, scalar transport) and NIH monitor point. All residuals converge to below 1e-6. NIH monitor point variation below 0.01% over final 500 iterations. Double-precision arithmetic used throughout. Round-off error estimated at machine epsilon level, negligible relative to discretization error.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/solver-error-level3",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error Gradation 3 criteria",
        "description": "Residuals must converge to at least 1e-5. QoI monitor must show less than 0.1% variation over final 200 iterations. Double-precision arithmetic required for MRL 5 assessments."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Simulation setup independently reviewed by a second qualified CFD analyst. Boundary condition specification, material property assignment, turbulence model selection, and hemolysis model coefficient values all verified against the documented simulation plan SP-2025-03. Discrepancies identified in initial review (two boundary condition mismatches) were corrected prior to production runs. Review sign-off on file.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/use-error-level3",
        "type": "AcceptanceCriteria",
        "name": "Use error Gradation 3 criteria",
        "description": "Independent peer review of simulation setup required. Review must cover boundary conditions, material properties, and model parameter assignments. All discrepancies must be resolved and documented prior to production runs."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "SST k-omega turbulence model selected based on published literature for rotating blood-contacting devices. Power-law hemolysis model (Giersiepen et al. coefficients, recalibrated by Taskin et al. 2012) used. Model form uncertainty quantified by comparing NIH predictions using three hemolysis model coefficient sets; spread of 12% in NIH across coefficient sets included in Monte Carlo UQ. Model form assumptions documented in modeling report MR-2025-03.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-form-level3",
        "type": "AcceptanceCriteria",
        "name": "Model form Gradation 3 criteria",
        "description": "Turbulence model selection must be justified by literature for the device class. Hemolysis model form uncertainty must be quantified by comparing at least two coefficient sets. Model form assumptions must be documented."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "All model input parameters (inlet velocity profiles, fluid density and viscosity, pump rotational speed, outlet pressure boundary conditions) sourced from calibrated measurements with documented uncertainty. Input uncertainty distributions defined for Monte Carlo propagation: inlet velocity ±2%, viscosity ±3%, rotational speed ±0.5%. Sensitivity indices (Sobol first-order) computed; viscosity and hemolysis model coefficients are dominant contributors.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-inputs-level3",
        "type": "AcceptanceCriteria",
        "name": "Model inputs Gradation 3 criteria",
        "description": "All primary model inputs must have documented uncertainty bounds from calibrated measurements. Sensitivity analysis must identify dominant input contributors. Uncertainty distributions must be propagated through the model."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Experimental data collected across three independent test runs per operating point (n=15 total runs across 5 operating points). Each run uses a freshly prepared blood analog batch. Batch-to-batch variability assessed (CV 4.2% on NIH). Statistical power analysis confirms n=3 per point is sufficient to detect a 15% difference at 80% power. Outlier screening performed; no outliers excluded.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-samples-level3",
        "type": "AcceptanceCriteria",
        "name": "Test samples Gradation 3 criteria",
        "description": "Minimum three independent replicates per operating point required. Batch-to-batch variability must be characterized. Statistical power analysis must justify sample size."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Mapping between experimental boundary conditions and CFD inputs formally documented in equivalency matrix EM-2025-03. Inlet velocity profile measured by PIV and applied directly as CFD inlet boundary condition. Pump rotational speed set identically in experiment and simulation. Fluid properties matched by viscometry on each batch. No unmapped parameters identified. Equivalency confirmed by independent reviewer.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/equivalency-level3",
        "type": "AcceptanceCriteria",
        "name": "Input parameter equivalency Gradation 3 criteria",
        "description": "Formal equivalency matrix must document the mapping of all experimental boundary conditions to CFD inputs. All primary boundary conditions must be directly measured and applied. Independent review of equivalency mapping required."
      }
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed required levels at Model Risk Level 5. Software quality assurance is confirmed under an ISO 9001-certified QMS with automated regression testing. Numerical code verification via MMS demonstrates observed order of accuracy within 1.5% of theoretical. Discretization error is controlled with GCI below 5% on the fine mesh. Experimental test conditions directly replicate the COU operating envelope across all five flow-speed combinations. Output comparison yields RMS error of 8.3% with model falling within validation uncertainty at 4 of 5 operating points and within 1.1 sigma at the fifth. QoI relevance is confirmed as NIH is the direct regulatory acceptance metric. Validation activities were performed on the actual FDA generic centrifugal pump geometry under representative conditions. Numerical solver error is negligible with residuals converging to 1e-6. Independent peer review confirmed correct simulation setup. Model form uncertainty is quantified across three hemolysis coefficient sets and included in the Monte Carlo UQ. All model inputs carry documented uncertainty bounds propagated via 2000-sample Monte Carlo. Three independent test replicates per operating point satisfy the statistical power requirement. Formal equivalency matrix confirms complete mapping of experimental to simulation boundary conditions. The structured evidence base, complete provenance chain, and all credibility factor achievements at required levels collectively support acceptance of the computational model for predicting absolute hemolysis levels in this Class III VAD application.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
