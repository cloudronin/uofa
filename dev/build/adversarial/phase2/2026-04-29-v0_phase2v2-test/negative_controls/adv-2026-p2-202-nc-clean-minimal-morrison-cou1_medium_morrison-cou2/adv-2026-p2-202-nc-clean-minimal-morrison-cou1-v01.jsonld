  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The CFD solver (OpenFOAM v9) is maintained under a documented version-controlled repository with unit tests, regression test suite, and change-log. All hemolysis post-processing scripts are under ISO 9001-compliant configuration management. Software release notes and validation reports are archived and traceable to the simulation version used in this assessment.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/sqa-gradation3",
        "type": "AcceptanceCriteria",
        "name": "SQA Gradation 3 acceptance criteria",
        "description": "Solver and post-processing scripts must be under formal version control with regression tests covering hemolysis-relevant code paths. All test results must be archived and traceable to the simulation run."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Method of manufactured solutions (MMS) was applied to the incompressible Navier-Stokes solver, confirming second-order spatial convergence. The hemolysis power-law integration routine was verified against a closed-form analytical solution for a Couette flow configuration. Observed order of accuracy matches theoretical expectations within 2%.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/code-verification-gradation3",
        "type": "AcceptanceCriteria",
        "name": "Code verification Gradation 3 acceptance criteria",
        "description": "MMS or equivalent formal verification must demonstrate that the solver achieves theoretical order of accuracy for both the flow solver and the hemolysis post-processing module."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Three systematically refined meshes (3.2M, 8.7M, 22.1M cells) were used to perform a Richardson extrapolation-based grid convergence study. Grid convergence index (GCI) for NIH at the design operating point is 2.1%, below the 5% acceptance threshold. The fine mesh was selected for production runs. Temporal convergence was confirmed by comparing steady-state and time-averaged transient solutions.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/discretization-gradation4",
        "type": "AcceptanceCriteria",
        "name": "Discretization error Gradation 4 acceptance criteria",
        "description": "Richardson extrapolation GCI must be reported for the primary QoI (NIH) and must be below 5% on the production mesh. At least three mesh levels must be used with a refinement ratio of at least 1.3."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit, and anticoagulant protocol) were documented in accordance with ASTM F1841 and are traceable to calibrated measurement equipment. Uncertainty in measured flow rate is ±1.5% and in pump speed ±0.5%. All five operating points were tested in triplicate to characterize inter-run variability.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/test-conditions-gradation3",
        "type": "AcceptanceCriteria",
        "name": "Test conditions Gradation 3 acceptance criteria",
        "description": "All experimental boundary conditions must be documented with calibrated instrument uncertainties. Test protocol must reference a recognized standard (e.g., ASTM F1841). Replicate measurements must be reported."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Quantitative comparison metrics (mean absolute error, RMSE, and validation uncertainty Uval per ASME V&V 20) were computed for NIH at all five operating points. Uval accounts for experimental uncertainty, numerical uncertainty, and input parameter uncertainty propagated via Monte Carlo. The model comparison error E falls within Uval for four of five points; the fifth point shows E slightly outside Uval but within 1.5×Uval, which is documented and judged acceptable given conservative clinical margin.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/output-comparison-gradation4",
        "type": "AcceptanceCriteria",
        "name": "Output comparison Gradation 4 acceptance criteria",
        "description": "Validation uncertainty Uval must be computed per ASME V&V 20 methodology incorporating all identified uncertainty sources. Comparison error E must be reported for all QoI at all operating points. Agreement within Uval for at least 4 of 5 points is required."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is identical to the regulatory submission metric and directly maps to the clinical endpoint of plasma-free hemoglobin concentration. Secondary QoIs (shear stress distribution, exposure time histogram) are mechanistically linked to the hemolysis model inputs and provide diagnostic traceability from CFD output to biological damage mechanism.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/qoi-relevance-gradation4",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance Gradation 4 acceptance criteria",
        "description": "Primary QoI must be the same metric used in the regulatory decision criterion. Secondary QoIs must be mechanistically traceable to the primary QoI and to the clinical endpoint."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Validation experiments were conducted on the same FDA generic centrifugal pump geometry as the COU device. Operating conditions span the full clinical operating envelope (2 to 6 L/min, 2400 to 3600 RPM). Blood analog fluid (glycerin-water with bovine erythrocytes) matches hematocrit and viscosity of the clinical use case. No geometric surrogates or extrapolation beyond the validated operating range are required.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/validation-relevance-gradation4",
        "type": "AcceptanceCriteria",
        "name": "Validation activity relevance Gradation 4 acceptance criteria",
        "description": "Validation experiments must use the same device geometry as the COU and must span the full clinical operating envelope. Fluid properties must match the COU fluid within documented tolerances."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Iterative convergence was monitored via normalized residuals (all below 1×10⁻⁵) and mass-flow imbalance (below 0.01%). Round-off error was assessed by comparing double- and extended-precision runs; differences in NIH were below 0.1%. Solver settings (relaxation factors, linear solver tolerances) are documented in the archived case files.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/solver-error-gradation3",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error Gradation 3 acceptance criteria",
        "description": "Iterative residuals must be reported and must reach a plateau below 1×10⁻⁴. Mass conservation error must be below 0.1%. Round-off sensitivity must be assessed."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "An independent reviewer (senior CFD engineer not involved in original simulation setup) performed a structured peer review of boundary condition assignments, turbulence model selection, hemolysis model coefficient values, and post-processing scripts. All discrepancies identified during review were resolved and documented in the review log archived with the simulation package.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/use-error-gradation3",
        "type": "AcceptanceCriteria",
        "name": "Use error Gradation 3 acceptance criteria",
        "description": "An independent structured peer review of simulation setup and post-processing must be performed and documented. All review findings must be resolved with documented dispositions."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) and the SST k-ω turbulence closure were selected following a documented model selection study comparing four turbulence models and two hemolysis model formulations against the validation dataset. The selected combination minimized NIH prediction error across all five operating points. Model form uncertainty was estimated by computing the spread in NIH predictions across the candidate model ensemble and is included in Uval.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-form-gradation4",
        "type": "AcceptanceCriteria",
        "name": "Model form Gradation 4 acceptance criteria",
        "description": "Model selection must be justified by a documented comparative study against validation data. Model form uncertainty must be estimated and included in the total validation uncertainty budget."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "All model inputs (fluid density, viscosity, hematocrit, hemolysis model coefficients α, β, C, pump geometry dimensions, and operating boundary conditions) are documented with sources, nominal values, and uncertainty distributions. Monte Carlo sampling (1000 samples, Latin hypercube) propagated these input uncertainties through the CFD solver to produce prediction intervals on NIH. Sensitivity indices (Sobol first-order) identify hemolysis model coefficient C as the dominant uncertainty contributor.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-inputs-gradation4",
        "type": "AcceptanceCriteria",
        "name": "Model inputs Gradation 4 acceptance criteria",
        "description": "All inputs must be documented with uncertainty distributions. Monte Carlo or equivalent UQ must propagate input uncertainties to the QoI. Sensitivity analysis must identify dominant contributors."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Blood analog samples (bovine erythrocytes in phosphate-buffered saline) were prepared from a single lot with documented hematocrit (40±1%), osmolality, and baseline plasma-free hemoglobin below 5 mg/dL. Sample preparation protocol follows ASTM F1841. Three independent sample preparations were used across the five operating-point replicates to assess inter-preparation variability.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/test-samples-gradation3",
        "type": "AcceptanceCriteria",
        "name": "Test samples Gradation 3 acceptance criteria",
        "description": "Blood analog sample preparation must follow a documented protocol referencing a recognized standard. Key sample properties (hematocrit, baseline hemoglobin) must be measured and reported. Inter-preparation variability must be assessed."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "A formal equivalency analysis maps each experimental input parameter to the corresponding CFD boundary condition. Fluid viscosity, density, and hematocrit used in the simulation match measured experimental values within ±2%. Pump rotational speed and flow rate boundary conditions match experimental set-points within instrument uncertainty. Geometric fidelity was confirmed by comparing CAD model dimensions against coordinate-measurement-machine (CMM) measurements of the physical test article; maximum deviation 0.08 mm.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/input-equivalency-gradation4",
        "type": "AcceptanceCriteria",
        "name": "Input parameter equivalency Gradation 4 acceptance criteria",
        "description": "A documented parameter equivalency table must map all experimental inputs to simulation boundary conditions with quantified deviations. Geometric fidelity must be confirmed by dimensional inspection. All deviations must be within stated tolerances or their impact on QoI must be bounded."
      }
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed required levels for Model Risk Level 5. The evidence package is complete: (1) software quality assurance is at Gradation 3 with version-controlled solver and regression tests; (2) code verification confirms second-order convergence via MMS; (3) discretization error GCI is 2.1% on the production mesh, well within the 5% threshold; (4) test conditions are documented per ASTM F1841 with calibrated instruments; (5) output comparison uses ASME V&V 20 validation uncertainty and shows agreement within Uval for 4 of 5 operating points and within 1.5×Uval for the fifth, judged acceptable given conservative clinical margin; (6) QoI relevance is established by direct mapping of NIH to the regulatory decision metric; (7) validation activities used the same device geometry and clinical operating envelope; (8) numerical solver error is controlled with residuals below 1×10⁻⁵; (9) use error was mitigated by independent structured peer review; (10) model form selection was justified by comparative study and model form uncertainty is included in Uval; (11) model inputs are fully characterized with Monte Carlo UQ and Sobol sensitivity indices; (12) test samples follow ASTM F1841 with inter-preparation variability assessed; (13) input parameter equivalency is confirmed by CMM dimensional inspection and boundary condition matching within instrument uncertainty. Monte Carlo uncertainty quantification (1000-sample LHS) provides a complete probabilistic characterization of NIH predictions across the clinical operating envelope. The totality of structured evidence supports acceptance of the CFD model for predicting absolute hemolysis levels in the Class III VAD context of use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
