  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble demonstrates sufficient credibility for the intended COU. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy the pre-established acceptance bounds (E/uval < 1.96; relative error < 10%). Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — is addressed by the offset rationale: the ASTM F1717 protocol specifies a single standardized test condition, and the clinical risk consequence is Medium (revision surgery, not mortality). The model's conservative predictions (slight over-prediction of stiffness and yield force) provide additional safety margin. The provenance chain is complete from raw bench data through uncertainty quantification to the validation metric. The assessment team concludes that the model is fit for purpose for the stated regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 2 against a required Gradation 3 because ASTM F1717 defines a single standardized static compression-bending condition, making multi-condition testing atypical for this regulatory context. The shortfall is offset by: (1) direct replication of the regulatory test condition rather than an analogy scenario; (2) the model's conservative bias (over-prediction) providing a safety margin for the Medium-consequence decision; (3) all other twelve factors meeting or exceeding required levels, providing strong overall credibility evidence; and (4) the sensitivity analysis confirming that QoI predictions are insensitive to loading rate variations within the physiologically plausible range (< 2% change across 1–10 mm/min). The assessment team judges the residual uncertainty from this shortfall to be acceptable for the stated decision.",
        "description": "Offset rationale for Test conditions factor shortfall (achieved 2, required 3)"
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
