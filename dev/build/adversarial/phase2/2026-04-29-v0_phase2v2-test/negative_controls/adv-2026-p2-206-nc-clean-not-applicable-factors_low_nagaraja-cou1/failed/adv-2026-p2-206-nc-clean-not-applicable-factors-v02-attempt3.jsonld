  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble is accepted as sufficiently credible for the stated COU. Eleven of thirteen V&V 40 credibility factors meet or exceed required gradation levels. The single shortfall — Test conditions (Gradation 1 achieved vs. Gradation 2 required) — is offset by the regulatory standardization of ASTM F1717 as the sole required test condition for pedicle screw construct evaluation, the high inter-laboratory reproducibility demonstrated across two independent facilities (CV < 5%), and the conservative acceptance bounds (E/uval < 1.96, percent difference < 10%) applied to all three QoIs. All validation metrics satisfy acceptance criteria. The provenance chain from raw experimental data through uncertainty quantification to validation metric computation is complete and traceable. The decision is supported by the structured evidence package and is consistent with FDA guidance on computational modeling credibility for Class II orthopedic implants.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/tc-shortfall-noncannulated",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "description": "Test conditions factor achieved Gradation 1 (single loading condition) against a required Gradation 2 (two or more distinct conditions). This shortfall is accepted because: (1) ASTM F1717 is the sole regulatory standard for pedicle screw compression-bending evaluation and specifies a single quasi-static loading condition; (2) clinical loading of pedicle screw constructs in the lumbar spine is dominated by flexion-compression, which is directly simulated by the F1717 test geometry; (3) between-laboratory reproducibility (CV < 5% across two independent facilities) demonstrates that the single test condition is robustly characterized; and (4) the conservative E/uval acceptance threshold (< 1.96) provides additional margin against model prediction error. The panel concludes that the regulatory standardization of the test condition, combined with the high-quality multi-laboratory experimental dataset, provides sufficient confidence to offset the single-condition limitation."
      },
      {
        "id": "https://uofa.net/synth/decision/noncannulated-f1717-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/noncannulated-f1717-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
