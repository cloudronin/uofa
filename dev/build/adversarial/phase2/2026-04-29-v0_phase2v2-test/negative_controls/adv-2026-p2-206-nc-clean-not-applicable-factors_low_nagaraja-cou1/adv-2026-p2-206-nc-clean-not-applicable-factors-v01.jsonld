  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as sufficiently credible for the intended regulatory submission use. Twelve of thirteen V&V 40 factors meet or exceed their required credibility levels. The single shortfall — Test conditions (achieved Gradation 1 vs. required Gradation 2) — reflects the inherent constraint of ASTM F1717 as a single standardized protocol; the COU is explicitly scoped to this protocol, and the offset rationale documents that the narrow COU definition makes multi-condition testing unnecessary. All three primary QoIs satisfy E/uval < 1.96 and MAPE < 10%. Uncertainty quantification is complete and traceable. The model risk level (3) is commensurate with the Medium assurance level and Medium model influence and decision consequence ratings.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "The Test conditions factor achieves Gradation 1 rather than the required Gradation 2 because ASTM F1717 defines a single standardized static compression-bending protocol and the COU is explicitly limited to this protocol. The regulatory submission does not claim predictive validity for dynamic fatigue or alternative loading configurations. The narrow COU definition eliminates the need for multi-condition validation; requiring Gradation 2 would impose testing burden without corresponding reduction in decision risk. This shortfall is offset by: (1) the direct correspondence between the single test condition and the full COU scope, (2) the high sample size (N=11 across two laboratories) providing robust statistical confidence within the single condition, and (3) the conservative acceptance bounds (E/uval < 1.96, MAPE < 10%) all satisfied with margin."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
