  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors achieve achievedLevel >= requiredLevel with margin. The Test conditions factor achieves its required level of 2 (single standardized ASTM F1717 condition, fully documented and traceable), consistent with the single-condition regulatory submission scope. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both quantitative acceptance criteria (relative difference < 10 %, E/uval < 1.96) at both independent laboratories. The sensitivity analysis confirms that the dominant uncertainty source (contact friction) is bounded by physical measurement and does not drive QoI predictions outside acceptance bounds. The model risk level 3 (Medium) is appropriately addressed by the Medium assurance level evidence package. The credibility assessment team unanimously accepts the FEA model as credible for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
