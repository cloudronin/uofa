  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-v2",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework achieves Accepted status for COU1. Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions (required Gradation 3, achieved Gradation 2) — is offset by the fact that ASTM F1717 is the sole regulatory-mandated test condition for pedicle screw compression-bending and is universally accepted by FDA for 510(k) submissions; additional loading conditions are not required by any applicable standard. All three QoIs satisfy E/uval < 1.96 with relative errors below 2.5%. Uncertainty quantification is complete and traceable. The model risk level (3) is commensurate with the Medium assurance level and Medium decision consequence. The credibility evidence package is sufficient to support the regulatory submission claim.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-offset-tc",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "description": "Test conditions factor achieved Gradation 2 against a required Gradation 3. The shortfall is justified because ASTM F1717 specifies a single standardised compression-bending condition (10° off-axis, 5 mm/min) that is accepted by FDA as the definitive characterisation of pedicle screw construct performance. No regulatory or clinical basis exists for requiring additional loading conditions in this COU. The sensitivity analysis confirms that the QoIs are robust to perturbations within the operating envelope, further mitigating the risk associated with single-condition testing."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-accepted-v2/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-accepted-v2/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
