  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 compression-bending is accepted as credible at Medium assurance level. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy the pre-specified acceptance criterion (E/uval < 1.96; percent difference < 10%). Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions at Gradation 2 against a required Gradation 3 — is addressed by the offset rationale below. Sensitivity analysis confirms robustness of predictions to plausible input uncertainty. The validation domain directly encompasses the intended use domain with no extrapolation required.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs. required 3)",
        "description": "The Test conditions factor achieved Gradation 2 (single standardised test condition) rather than the required Gradation 3 (multiple conditions). This shortfall is justified on three grounds: (1) ASTM F1717 specifies a single quasi-static compression-bending configuration as the regulatory standard; testing additional conditions would exceed the standard's scope without adding regulatory relevance; (2) the quasi-static assumption was verified quantitatively (inertial forces < 0.01% of applied load), eliminating rate-dependence as a material source of model error; (3) the sensitivity analysis demonstrated that QoI predictions are robust (< 6% variation) across the full plausible range of material and contact parameters, providing indirect evidence that the model would perform equivalently under minor condition variations. The combined weight of evidence from the other twelve factors, all meeting or exceeding their required levels, provides sufficient aggregate credibility to support the Accepted decision at Medium assurance level."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
