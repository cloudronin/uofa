      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated 7.5 mm pedicle screw — applicability domain",
      "description": "Assessment applies exclusively to non-cannulated titanium-alloy pedicle screws with nominal outer diameter 7.0–8.0 mm and polyaxial head geometry, tested under ASTM F1717 static compression-bending with a standard UHMWPE block fixture. Results are not transferable to cannulated designs, dynamic fatigue loading, or screws outside the specified diameter range without re-assessment of all 13 credibility factors."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/envelope",
      "type": "OperatingEnvelope",
      "name": "COU1 operating envelope — F1717 static compression-bending",
      "description": "Applied compressive load range: 0–2500 N; bending moment arm: 40 mm fixed per ASTM F1717; crosshead displacement rate: 5 mm/min; ambient temperature: 23 ± 2 °C; screw insertion torque: 4.0 ± 0.5 Nm into UHMWPE block (density 0.93–0.95 g/cm³); rod diameter: 5.5 mm cobalt-chrome; construct span: 44 mm centre-to-centre. FEA boundary conditions replicate these bounds exactly."
    }
  },
