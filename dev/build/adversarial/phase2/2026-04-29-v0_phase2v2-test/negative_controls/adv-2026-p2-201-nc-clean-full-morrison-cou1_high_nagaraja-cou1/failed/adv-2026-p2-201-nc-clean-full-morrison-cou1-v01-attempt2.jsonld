  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — is offset by the OffsetRationale below: the ASTM F1717 standard mandates a single static test condition, the COU is restricted to that condition, and the equivalency of input parameters factor (Gradation 3) confirms the single condition is fully characterised. All three QoIs pass both quantitative acceptance criteria (relative difference < 10%; E/u_val < 1.96). The multi-code ensemble and two-laboratory experimental programme provide additional confidence. Model risk level 3 is consistent with Medium assurance level and Medium model influence / decision consequence. The credibility assessment team accepts the FEA modeling framework for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 2 (single loading condition) against a required Gradation 3 because ASTM F1717 specifies a single static compression-bending protocol and the COU is explicitly scoped to that protocol. Testing under additional conditions would fall outside the COU boundary and is therefore not warranted. The Equivalency of input parameters factor (Gradation 3 achieved) confirms that the single test condition is fully and traceably replicated in the FEA, eliminating condition-mapping uncertainty. The sensitivity analysis demonstrates that QoI responses are robust to plausible perturbations of the boundary conditions within the operating envelope. Taken together, these offsetting strengths justify acceptance despite the single-condition limitation."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-accepted/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
