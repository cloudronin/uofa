    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated 7.5 mm pedicle screw ASTM F1717 applicability domain",
      "description": "Model applicability is restricted to non-cannulated titanium-alloy pedicle screws with nominal outer diameter 7.0–8.0 mm, rod diameter 5.5 mm CoCr or Ti-6Al-4V, construct span 44 mm per ASTM F1717 fixture geometry, and quasi-static monotonic loading rates ≤5 mm/min. Extrapolation to cannulated designs, dynamic fatigue loading, or constructs outside these geometric bounds is explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 static compression-bending operating envelope",
      "description": "Operating envelope bounds: axial compressive load 0–2500 N; bending moment arm 44 mm (fixed per F1717 fixture); crosshead displacement 0–50 mm; loading rate 5 mm/min ± 0.5 mm/min; ambient temperature 23 ± 2 °C; relative humidity 50 ± 10%; screw insertion torque 8 ± 0.5 N·m; rod pre-tension 0 N (unconstrained). FEA boundary conditions replicate these bounds to within 1% of nominal values."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/nagaraja/sensitivity/cou1-sa",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Sobol sensitivity analysis for COU1 FEA model",
    "description": "A one-at-a-time (OAT) sensitivity analysis was performed varying titanium elastic modulus (±10%), cortical bone contact friction coefficient (0.2–0.5), screw-rod interface stiffness (±20%), and mesh density (element edge length 0.3–0.9 mm). Construct stiffness QoI showed greatest sensitivity to elastic modulus (±6.2% response) and friction coefficient (±4.8% response), while yield force was most sensitive to mesh density (±3.1%). A subsequent 512-sample Sobol analysis confirmed that elastic modulus and friction coefficient together account for 81% of output variance, supporting the targeted experimental characterisation of these parameters in the uncertainty quantification activity."
  },
