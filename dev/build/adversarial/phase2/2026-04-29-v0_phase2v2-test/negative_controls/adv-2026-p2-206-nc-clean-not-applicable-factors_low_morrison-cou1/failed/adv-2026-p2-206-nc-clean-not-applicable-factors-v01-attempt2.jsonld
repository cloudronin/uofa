      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "rationale": "Code verification performed via the method of manufactured solutions (MMS) for the incompressible Navier-Stokes solver. Second-order spatial convergence confirmed for velocity and pressure fields. Published verification suite results for ANSYS Fluent reviewed and accepted.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/code-verification-ac",
        "type": "AcceptanceCriteria",
        "name": "Code verification acceptance criteria",
        "description": "Demonstrated second-order spatial convergence via MMS or equivalent benchmark. Gradation 1 required; Gradation 2 achieved through MMS and published solver benchmarks."
