  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "ANSYS Fluent 2023R1 is a commercially validated solver with documented QA procedures. Version control logs, regression test suite results, and release notes confirming fix of known hemolysis-relevant solver bugs were reviewed. QA documentation meets MRL 2 requirements.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-sqa",
        "type": "AcceptanceCriteria",
        "name": "Software QA acceptance criterion",
        "description": "Solver must be a commercially released version with documented regression testing. Version used must not carry open defect reports affecting turbulent shear stress or species transport. Achieved: ANSYS Fluent 2023R1, no open critical defects."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Code verification was performed using the method of manufactured solutions (MMS) for the incompressible Navier-Stokes solver. Second-order spatial convergence confirmed for velocity and pressure fields. Turbulence model (SST k-ω) order of accuracy consistent with published ANSYS verification reports.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-ncv",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criterion",
        "description": "Observed order of accuracy must be within 10% of theoretical order for primary flow variables using MMS. Achieved: 1.94 observed vs. 2.0 theoretical for velocity (3% deviation), 1.89 for pressure (5.5% deviation). Both within tolerance."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Grid convergence index (GCI) analysis performed on three systematically refined meshes (coarse 2.1M, medium 5.8M, fine 14.2M cells). GCI for volume-averaged shear stress: 2.1% (fine-medium pair). GCI for NIH hemolysis index: 3.4%. Both below 5% threshold. Richardson extrapolation applied; fine mesh selected for production runs.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-disc",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criterion",
        "description": "GCI for hemolysis-relevant QoIs must be <5% using the fine-to-medium mesh pair with safety factor 1.25. Achieved: GCI_shear = 2.1%, GCI_NIH = 3.4%, both satisfying the criterion. Exceeds MRL 2 requirement (achievedLevel 3)."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Bench test conditions (blood analog fluid properties, pump speed, flow rates, temperature 37°C) were matched to CFD boundary conditions within documented tolerances. Fluid viscosity matched to ±2%, density to ±0.5%. Operating points span the COU envelope of 3000–5000 RPM and 3–6 L/min.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-tc",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criterion",
        "description": "Fluid properties and boundary conditions in validation experiments must match CFD inputs within ±5% for viscosity and ±1% for density. Flow rates must span at least 3 of the 5 COU operating points. Achieved: all 5 operating points covered, viscosity match ±2%, density match ±0.5%."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Quantitative comparison metrics (relative error, validation uncertainty, E/U_val ratio) computed for pressure-flow, NIH hemolysis index, and velocity field. All metrics documented in validation report. E/U_val < 1 for all QoIs, indicating model predictions within validation uncertainty.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-oc",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criterion",
        "description": "Validation metric E/U_val must be <1.0 for primary QoIs (NIH index, pressure rise). Achieved: E/U_val = 0.71 for NIH index, 0.54 for pressure-flow. Both satisfy criterion."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is directly linked to the regulatory decision criterion (RH < 1 relative to predicate device). Secondary QoIs (volume-averaged shear stress, exposure time distribution) are mechanistically tied to the power-law hemolysis model. Relevance mapping documented in the V&V plan.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-qoi",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criterion",
        "description": "Each QoI must be traceable to the regulatory decision criterion or a mechanistic sub-model input. Achieved: NIH directly maps to RH acceptance criterion; shear stress and exposure time are inputs to the power-law hemolysis model validated against Heuser-Opitz data."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Validation experiments used the same FDA generic centrifugal pump geometry, same blood analog fluid (glycerol-water at 37°C matching blood viscosity), and the same 5 flow-speed operating points as the COU. Geometric fidelity between test article and CFD model confirmed via CMM measurements. Validation domain covers the full COU operating envelope.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou1-vrel",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance acceptance criterion",
        "description": "Validation experiments must use the same pump geometry (or documented surrogate), same fluid analog, and span the full COU operating envelope. Achieved: FDA generic pump geometry used, glycerol-water analog confirmed, all 5 COU operating points tested."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Numerical solver error as a distinct factor from discretization error and code verification pertains to iterative convergence residuals and floating-point round-off in solver internals. At MRL 2 for this COU, the ASME V&V 40 framework does not require separate assessment of solver-internal floating-point error beyond what is captured by the code verification and discretization error factors already assessed. The commercial solver (ANSYS Fluent 2023R1) provides documented iterative convergence monitoring; residuals were confirmed to reach 1e-6 for all equations, and this is subsumed within the software QA and numerical code verification factors. Separate standalone assessment of numerical solver error as an independent credibility factor is therefore not applicable to this MRL 2 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Use error as a credibility factor addresses operator-induced errors in applying the simulation tool in a clinical or field deployment context. For this COU, the CFD model is used exclusively by trained simulation engineers within a controlled laboratory environment to support a single regulatory submission decision, not as a deployed clinical decision-support tool. The ASME V&V 40 guidance notes that use error assessment is most relevant when the model output is directly interpreted by end users with varying expertise in a clinical setting. Because model outputs are reviewed by the credibility assessment team prior to informing the regulatory decision, and no direct patient-facing deployment occurs, this factor is not applicable to the present MRL 2 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Model form uncertainty assessment as a standalone credibility factor addresses the selection among competing physical model representations (e.g., turbulence model family, constitutive law selection) and their epistemic uncertainty contribution. At MRL 2, ASME V&V 40 does not require a formal model form uncertainty quantification separate from the validation comparison. The SST k-ω turbulence model was selected based on published benchmark studies for rotating blood-contacting devices and its performance is implicitly evaluated through the output comparison factor. A formal Bayesian model form uncertainty analysis or competing-model comparison is required only at MRL 3 and above. This factor is therefore not applicable at the current model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The model inputs credibility factor, when treated as a standalone assessment distinct from test conditions and equivalency of input parameters, addresses formal uncertainty propagation through all model input parameters including material properties, boundary condition distributions, and geometric tolerances. At MRL 2, the ASME V&V 40 framework requires input uncertainty characterization only to the extent needed to support the output comparison. The test conditions factor (assessed above) documents the match between experimental and CFD inputs. A full formal uncertainty propagation analysis across all inputs (e.g., Latin hypercube sampling across the full input space) is an MRL 3 requirement. Consequently, this factor as a separate standalone credibility assessment element is not applicable at MRL 2 for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The test samples factor addresses variability in physical test specimens, including manufacturing tolerances in test articles, batch-to-batch material variability, and sample size adequacy for statistical inference. This factor is most relevant when physical specimens exhibit meaningful inter-sample variability that could confound the validation comparison. For this COU, validation experiments used a single precision-machined acrylic test article of the FDA generic centrifugal pump whose geometric fidelity was verified by coordinate measuring machine (CMM) to within ±0.05 mm. No specimen-to-specimen variability exists in this single-article validation campaign. The statistical adequacy of repeat measurements is addressed within the output comparison uncertainty quantification. The test samples factor as a distinct credibility assessment element is therefore not applicable to this validation setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The equivalency of input parameters factor addresses the degree to which the input parameters used in the validation experiment correspond to those in the COU, particularly when validation is performed on a surrogate geometry or at scaled operating conditions. For this COU, validation experiments were conducted on the identical FDA generic centrifugal pump geometry at the identical operating points (flow rates and rotational speeds) specified in the COU, with the same blood analog fluid. There is no scaling, surrogate geometry, or operating condition extrapolation involved. The test conditions factor (assessed above) already documents the quantitative match between experimental and CFD boundary conditions. Because the validation and COU inputs are directly equivalent without any extrapolation or surrogate mapping, this factor does not provide additional discriminatory credibility information and is not applicable to this assessment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for hemolysis prediction of the FDA generic centrifugal blood pump under CPB conditions is accepted as credible for the stated COU at MRL 2. Seven of thirteen credibility factors were formally assessed; all seven achieved levels meet or exceed the required levels at MRL 2 (Software QA: 2/2, Code Verification: 2/2, Discretization Error: 3/2, Test Conditions: 2/2, Output Comparison: 2/2, QoI Relevance: 2/2, Validation Relevance: 2/2). Six factors were determined not-applicable with documented rationale: Numerical Solver Error (subsumed by assessed factors at MRL 2), Use Error (no clinical deployment context), Model Form (formal uncertainty analysis required only at MRL 3), Model Inputs (full propagation required only at MRL 3), Test Samples (single precision-machined article, no inter-sample variability), and Equivalency of Input Parameters (direct equivalence, no surrogate or scaling). The primary regulatory QoI (relative hemolysis index RH = 0.83) satisfies the acceptance criterion RH < 1.0. Validation uncertainty analysis confirms E/U_val < 1 for all primary QoIs. The provenance chain from raw bench measurements through validation results to this decision record is complete. No weakeners are present. The assessment team concludes the model provides sufficient credibility for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
