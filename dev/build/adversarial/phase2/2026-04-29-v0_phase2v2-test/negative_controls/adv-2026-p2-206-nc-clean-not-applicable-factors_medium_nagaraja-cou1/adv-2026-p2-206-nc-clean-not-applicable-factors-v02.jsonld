  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Ansys Mechanical 2023 R1 is a commercially validated FEA solver with ISO 9001-certified quality management system documentation. The FDA in-house FEA code used in the ensemble is subject to FDA ORA software quality procedures. Version control, regression testing logs, and release notes for both codes were reviewed and found compliant with Gradation 3 requirements. DePuy Synthes internal FEA toolchain is governed by a Design Assurance procedure under 21 CFR Part 820.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/software-qa",
        "type": "AcceptanceCriteria",
        "name": "Software QA acceptance criterion",
        "description": "All simulation software must demonstrate Gradation 2 or higher SQA: documented version control, regression test suite with pass records, and traceable release documentation. Achieved Gradation 3 (formal SQA plan with independent audit trail) for all three ensemble codes."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Benchmark verification problems for large-deformation beam bending and contact mechanics were executed in all three ensemble codes. Solutions were compared against analytical solutions and NAFEMS benchmark results. Maximum deviation from reference solutions was 0.8%, satisfying Gradation 2 requirements for code verification of the relevant physics.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/numerical-code-verification",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criterion",
        "description": "FEA codes must reproduce NAFEMS benchmark beam-bending and contact problems within 2% of reference solutions, demonstrating correct implementation of the governing equations for the physics relevant to F1717 compression-bending simulation."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "A systematic mesh convergence study was performed using three mesh densities (coarse: ~18k elements, medium: ~72k elements, fine: ~290k elements) for the pedicle screw shank and rod assembly. Richardson extrapolation yielded a grid convergence index (GCI) of 0.9% for stiffness and 1.4% for yield force, both below the 2% threshold. The production mesh (medium density) was selected based on accuracy-to-cost tradeoff, achieving Gradation 3.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/discretization-error",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criterion",
        "description": "Grid convergence index (GCI) for all QoIs must be below 2% using Richardson extrapolation across at least three mesh refinement levels. Achieved GCI of 0.9% (stiffness) and 1.4% (yield force)."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Nonlinear solver convergence was verified for each load step. Force and displacement residual norms were monitored and required to fall below 1e-4 relative tolerance. Time-step sensitivity was evaluated by halving the load increment; QoI variation was less than 0.3%, confirming solver error is negligible relative to experimental uncertainty.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/numerical-solver-error",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error acceptance criterion",
        "description": "Nonlinear solver residuals must converge below 1e-4 relative tolerance at every load step. Load-increment sensitivity study must show QoI variation less than 1% upon halving the increment size."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Model setup was independently reviewed by a second analyst not involved in the original construction. Boundary conditions, material assignments, contact definitions, and load application were verified against the ASTM F1717 fixture geometry. A documented simulation plan (pre-analysis plan) was established prior to execution, reducing post-hoc parameter adjustment risk. Minor discrepancy in rod seating depth was identified and corrected during review.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/use-error",
        "type": "AcceptanceCriteria",
        "name": "Use error acceptance criterion",
        "description": "Independent second-analyst review of model setup must be completed and documented prior to result extraction. A pre-analysis plan must be on file. All identified discrepancies must be resolved and re-reviewed before final predictions are accepted."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The continuum FEA model employs an elastic-plastic constitutive law (bilinear isotropic hardening) for Ti-6Al-4V ELI, which has been established in peer-reviewed literature as appropriate for quasi-static monotonic loading of titanium spinal implants. Contact between screw head and rod was modeled with frictional Coulomb contact (mu=0.2), consistent with published tribological data for titanium-on-titanium interfaces. Geometric nonlinearity was enabled to capture large-displacement effects at 40 mm displacement. The model form was evaluated against three independent FEA implementations with consistent results, supporting Gradation 3.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/model-form",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criterion",
        "description": "Model must employ elastic-plastic material constitutive law appropriate for Ti-6Al-4V ELI under quasi-static loading. Geometric nonlinearity must be enabled. Frictional contact must be represented. Model form must be consistent across at least two independent FEA implementations, with QoI agreement within 5% between implementations."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Material properties (elastic modulus, yield strength, tangent modulus) were derived from tensile coupon testing of the same Ti-6Al-4V ELI bar stock used to manufacture the test constructs (N=6 coupons, mean E=114.2 GPa SD 1.1 GPa). Geometric dimensions were measured via CMM on three representative screws with 0.005 mm resolution. Friction coefficient was characterized by pin-on-disk testing under physiologically relevant contact conditions. Uncertainty distributions were assigned to all inputs and propagated through the model using a Latin Hypercube sampling approach (N=500 samples).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criterion",
        "description": "Material properties must be derived from specimen-specific or lot-specific testing rather than nominal handbook values. Geometric dimensions must be measured on actual test specimens. All key input uncertainties must be characterized and propagated through the model to quantify their contribution to QoI uncertainty."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "N=11 constructs were tested across two independent laboratories (Lab 1: n=6, Lab 2: n=5), all fabricated from the same production lot of non-cannulated 7.5 mm pedicle screws and 5.5 mm titanium rods. Sample size provides sufficient statistical power to characterize inter-specimen variability. Inter-laboratory coefficient of variation for stiffness was 4.4%, confirming reproducibility. Traceability of specimens to manufacturing lot records was maintained.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/test-samples",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criterion",
        "description": "Minimum N=8 constructs from a single production lot tested across at least one laboratory. Specimen traceability to manufacturing lot records required. Inter-specimen CV for primary QoI must be below 10%."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "rationale": "Testing was conducted under a single set of ASTM F1717 conditions (quasi-static, ambient temperature, single crosshead displacement rate of 5 mm/min). The required level of 3 calls for testing across at least two distinct loading conditions or rates to characterize condition sensitivity; this was not achieved because the study scope was limited to the standard F1717 protocol. This shortfall is offset by the strong quantitative agreement between FEA and experiment across all three QoIs (E/uval < 1.96 for all) and the conservative nature of the single test condition relative to in vivo loading rates.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criterion",
        "description": "Required: testing under at least two distinct loading conditions or displacement rates to characterize condition sensitivity. Achieved: single ASTM F1717 standard condition (5 mm/min, ambient). Shortfall accepted via offset rationale documented in the decision record."
      },
      "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-2026/factor/test-conditions"
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "FEA model inputs were mapped directly to measured specimen parameters: screw geometry from CMM measurements, material properties from coupon tests on the same lot, friction coefficient from tribological characterization of the same surface finish. Fixture geometry in the FEA was constructed from engineering drawings verified against physical fixture measurements. Input equivalency was formally documented in a parameter mapping table reviewed by an independent analyst.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/equivalency-input-parameters",
        "type": "AcceptanceCriteria",
        "name": "Equivalency of input parameters acceptance criterion",
        "description": "A documented parameter mapping table must demonstrate that each FEA input is traceable to a measured or characterized physical quantity from the validation specimens. Undocumented assumptions about input equivalency are not acceptable."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Quantitative output comparison was performed for all three QoIs (stiffness, yield force, force at 40 mm displacement) using both percent difference and the validation metric E/uval. All three QoIs satisfied E/uval < 1.96 and percent difference < 10%. Comparison was performed at the individual specimen level as well as at the population mean level. Ensemble agreement across the three FEA implementations (FDA, Ansys, DePuy Synthes) was also quantified, with inter-code CV below 2% for all QoIs.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criterion",
        "description": "All QoIs must satisfy: (1) percent difference < 10% between FEA ensemble mean and experimental mean, and (2) E/uval < 1.96 where uval is the combined validation uncertainty. Comparison must be documented for each QoI individually."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "This factor addresses whether the QoIs selected for the validation activity are relevant to the clinical or regulatory decision. For this COU, the QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly specified by ASTM F1717 as the standard measures of spinal implant mechanical performance and are explicitly referenced in the FDA guidance for 510(k) submissions for pedicle screw systems. The QoI relevance is therefore established by regulatory and standards consensus rather than requiring independent assessment within this credibility package; the factor does not require a separate credibility gradation evaluation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "This factor evaluates whether the validation activities are sufficiently representative of the intended COU. In this package, the validation activity IS the COU: the FEA model is validated directly against ASTM F1717 bench testing of the identical non-cannulated 7.5 mm pedicle screw construct geometry under the identical loading protocol. There is no gap between the validation scenario and the intended use scenario; consequently, assigning a credibility gradation to this factor would be circular and uninformative. The factor is therefore not applicable to this COU configuration."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for the non-cannulated 7.5 mm pedicle screw compression-bending COU is accepted as credible for its intended regulatory use. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both the quantitative acceptance bounds (percent difference < 10%) and the uncertainty-normalized validation metric (E/uval < 1.96). Eleven factors were formally assessed; ten achieved their required credibility level or above. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3 due to the single-condition ASTM F1717 test protocol. This shortfall is accepted on the basis of the offset rationale: the standard protocol is the regulatory reference condition, the quantitative agreement is strong across all QoIs, and the single condition is conservative relative to expected in vivo loading rates. Two factors (Relevance of QoIs; Relevance of validation activities to COU) were marked not-applicable with documented rationale, as their evaluation would be circular given that the validation activity is identical to the COU. The provenance chain is complete from raw experimental data through QoI extraction, uncertainty quantification, and ensemble comparison. The package is recommended for acceptance in support of the 510(k) submission.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-2026/offset-test-conditions",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs. required 3)",
        "refersToFactor": "https://uofa.net/nagaraja/credibility/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 2 (single loading condition) against a required Gradation 3 (minimum two distinct conditions). This shortfall is accepted because: (1) ASTM F1717 specifies a single quasi-static protocol that constitutes the regulatory reference standard for pedicle screw mechanical evaluation; (2) all three QoIs achieved E/uval well below 1.96 under this condition, demonstrating robust predictive accuracy; (3) the 5 mm/min crosshead rate is conservative relative to physiological loading rates, so the model's accuracy at this rate is not expected to degrade at slower rates; and (4) the model risk level (3) and decision consequence (Medium) do not warrant the additional testing burden that multi-condition validation would impose given the strength of the existing evidence. The offset is further supported by the ensemble agreement across three independent FEA implementations, which provides additional confidence in model robustness beyond what single-condition testing alone would indicate."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
