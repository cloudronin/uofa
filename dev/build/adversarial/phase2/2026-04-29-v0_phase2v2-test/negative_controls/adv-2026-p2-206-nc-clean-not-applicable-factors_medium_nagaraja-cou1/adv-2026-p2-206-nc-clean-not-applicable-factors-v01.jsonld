      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Linear elastic constitutive model with isotropic Ti-6Al-4V properties used for the screw; UHMWPE block modeled with bilinear elastic-plastic response calibrated from coupon tests. Contact between screw and block uses augmented Lagrange formulation with friction coefficient μ = 0.15 per published tribological data. Model form selection is justified by the quasi-static loading rate and the dominance of elastic deformation up to yield force; large-deformation kinematics (NLGEOM) activated to capture geometric nonlinearity at 40 mm displacement.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/ac-model-form-noncannulated",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria",
        "description": "Constitutive model and contact formulation must be justified by physical reasoning and calibrated against independent coupon or literature data. Geometric nonlinearity must be activated for large-displacement regime. All criteria documented and satisfied."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Material properties sourced from lot-specific material certificates for Ti-6Al-4V (E = 114 GPa, σ_y = 880 MPa) and from UHMWPE coupon tension tests (n=5 specimens, CV < 5%). Geometry inputs derived from CMM measurements of actual test specimens; nominal vs. measured dimensions agree within 0.05 mm. Input uncertainty bounds propagated through Monte Carlo sampling (n=1000 runs) to establish model prediction intervals reported in the validation results.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/ac-model-inputs-noncannulated",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria",
        "description": "Material properties from traceable lot certificates or coupon tests; geometry from CMM measurements; input uncertainty quantified and propagated. All criteria met with documented traceability."
      }
    },
    {
