      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Mesh convergence study conducted on three systematically refined meshes (coarse: 42k elements, medium: 168k elements, fine: 672k elements) using the Grid Convergence Index (GCI) method per ASME V&V 20. GCI for stiffness QoI = 0.9%, for yield force = 1.3%, both below the 2% threshold. Richardson extrapolation confirms asymptotic convergence range (p = 1.97 ≈ 2.0 for quadratic elements).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/ac-disc-error-noncannulated",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria",
