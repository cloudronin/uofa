      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH and DePuy Synthes). Samples drawn from the same manufacturing lot; dimensional inspection confirms compliance with drawing tolerances. Inter-laboratory coefficient of variation for stiffness = 3.8%, confirming reproducibility. Sample size exceeds the minimum of N=6 recommended for this risk level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/ac-test-samples-noncannulated",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria",
        "description": "Minimum N=6 specimens from a single manufacturing lot; inter-laboratory CV < 10% for primary QoI. Both criteria satisfied (N=11, CV=3.8%)."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "rationale": "Testing performed under a single ASTM F1717 static compression-bending condition (5 mm offset, quasi-static 5 mm/min crosshead rate). Only one test condition was evaluated; dynamic or fatigue loading conditions were not included in this validation activity. This shortfall relative to the required Gradation 3 is acknowledged and offset by the strong quantitative agreement across all three QoIs and the conservative acceptance bounds applied.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/ac-test-conditions-noncannulated",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria",
        "description": "Required Gradation 3: multiple test conditions spanning the intended operating envelope. Achieved Gradation 2: single standardized ASTM F1717 condition. Shortfall offset by quantitative agreement across three QoIs and conservative acceptance bounds; see OffsetRationale."
      },
      "id": "https://uofa.net/synth/decision/dec-noncannulated-cou1/factor/test-conditions"
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Model input parameters (geometry, material properties, boundary conditions, loading) directly mapped from experimental test records. CMM measurements used to set screw geometry in the model. Load frame stiffness and fixture compliance measured and incorporated as boundary condition corrections. All experimental setup parameters documented in laboratory notebooks and cross-referenced to model input files.",
      "acceptanceCriteria": {
