  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) is a commercially validated code with documented V&V test suite results. Internal SQA procedures include version-controlled input decks, automated regression testing against 12 canonical benchmark cases, and documented change-control records. All simulation scripts committed to a Git repository with tagged release used for this study. Achieved Gradation 2 satisfies MRL 2 requirement.",
      "acceptanceCriteria": {
