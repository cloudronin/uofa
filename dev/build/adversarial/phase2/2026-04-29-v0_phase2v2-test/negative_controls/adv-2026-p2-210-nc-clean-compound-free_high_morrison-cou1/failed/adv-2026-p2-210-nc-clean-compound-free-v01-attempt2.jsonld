  "hasWeakener": [],
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sa/cpb-hemolysis-sensitivity-01",
    "type": "SensitivityAnalysis",
    "name": "Inlet boundary condition and blood viscosity sensitivity study",
    "description": "One-at-a-time sensitivity analysis varying inlet flow rate (±10%), rotational speed (±5%), and blood dynamic viscosity (±8%) around the nominal operating point of 4.0 L/min at 3000 RPM. RHI showed highest sensitivity to rotational speed (normalized sensitivity index 0.61), moderate sensitivity to flow rate (0.38), and low sensitivity to viscosity (0.12), confirming that worst-case hemolysis identification is robust to plausible input uncertainty."
  },
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their MRL 2 required levels. Discretization error achieves Gradation 3 against a Gradation 2 requirement, providing additional confidence margin. The six scoped-out factors are each justified by MRL 2 applicability per ASME V&V 40-2018 Table 3, with procedural controls documented in lieu of formal assessment. Validation results demonstrate RHI prediction error of 5.1% NRMSE with full uncertainty quantification, well within the 10% acceptance threshold. Sensitivity analysis confirms that worst-case hemolysis identification is robust to boundary condition uncertainty. The provenance chain from raw experimental data through validated CFD predictions to the regulatory decision metric (RH < 1) is complete and traceable. The credibility evidence package supports acceptance of the CFD model for identifying worst-case hemolysis operating conditions for this Class II CPB device at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
