  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-acceptance-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for CPB hemolysis prediction at MRL 2 is accepted as fit for purpose based on the following structured evidence: (1) All 7 assessed credibility factors meet or exceed their required Gradation levels — discretization error exceeds the requirement (Gradation 3 achieved vs. Gradation 2 required), providing additional confidence in numerical accuracy. (2) The 6 scoped-out factors are each documented with explicit rationale referencing ASME V&V 40 Table 3 MRL 2 requirements, confirming that omission is standard-compliant and not a gap. (3) Quantitative output comparison demonstrates mean relative error of 8.3% in NIH across all 5 operating points, with all predictions within the combined uncertainty band. (4) Validation activities are directly relevant to the COU: same geometry, same fluid analog, same operating envelope. (5) The primary QoI (NIH) is directly linked to the regulatory acceptance criterion (RH < 1 vs. predicate device). (6) Provenance is complete: all ValidationResults link to experimental datasets, generating activities, and uncertainty quantification objects. The model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
