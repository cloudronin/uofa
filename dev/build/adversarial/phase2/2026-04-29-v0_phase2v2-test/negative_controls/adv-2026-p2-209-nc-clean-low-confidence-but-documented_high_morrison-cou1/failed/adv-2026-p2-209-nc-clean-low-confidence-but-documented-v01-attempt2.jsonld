  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The one explicitly-flagged epistemic gap — wide uncertainty (±22% NIH) in hemolysis power-law coefficients due to pooled literature sourcing — is fully documented in the UQ record for ValidationResult vr-hemolysis-bench-2024. Sensitivity analysis (Monte Carlo, 500 samples) demonstrates that worst-case operating point ranking is preserved in 97.4% of samples, confirming that the decision claim (identification of worst-case hemolysis conditions) is robust to this uncertainty. The RH < 1 acceptance criterion is met at the worst-case point under both nominal and upper-bound coefficient assumptions. Six factors are appropriately scoped out at MRL 2 per ASME V&V 40 Table 1. No factor achieves less than its required level; no offset rationale is required. The package is assessed as credible for the stated COU at Model Risk Level 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
