  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis worst-case identification, MRL 2) is accepted based on the following structured evidence: (1) All 7 assessed credibility factors meet or exceed their required levels for MRL 2. (2) The 6 scoped-out factors are appropriately excluded per ASME V&V 40-2018 Table 3 MRL 2 guidance, with documented rationale for each. (3) Validation results demonstrate CFD RH predictions within ±18% of bench measurements across all 5 operating points, with correct rank ordering of hemolysis severity. (4) The explicitly-flagged uncertainty in blood viscosity (±12% from hematocrit variability, propagating to ±9% RH uncertainty) is documented in the sensitivity analysis and accepted as residual risk: at the worst-case operating point, the upper bound of the RH prediction interval is 0.83, providing margin of 0.17 below the RH < 1 acceptance threshold. (5) Discretization error is well-controlled (GCI 3.2%, asymptotic convergence confirmed). (6) Provenance is complete from raw experimental data through comparison activities to validation results. The assessment team concludes that the model is fit for the stated COU at MRL 2, with the viscosity uncertainty explicitly documented and monitored.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
