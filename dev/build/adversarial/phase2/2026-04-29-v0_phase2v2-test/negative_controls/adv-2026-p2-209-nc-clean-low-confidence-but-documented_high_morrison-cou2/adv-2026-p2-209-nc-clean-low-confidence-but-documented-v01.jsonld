  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-nc9",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at or above required Gradation 3 level for MRL 5. The one explicitly-flagged low-confidence input (RBC mechanical damage threshold τ_c, confidence: LOW, epistemic uncertainty ±22%) is fully documented and propagated through Monte Carlo UQ (n=2,000 runs, LHS). The resulting wide prediction interval (±38% of nominal HI) is accepted because: (1) all 5 experimental validation observations fall within the 90% CI; (2) the predicted HI at the 90th percentile of the UQ distribution (conservative bound) remains below the clinical threshold NIH < 0.01 g/100 L; (3) the sensitivity analysis confirms that even at the extreme upper bound of τ_c uncertainty, the model does not predict hemolysis exceeding the clinical threshold; and (4) the low-confidence characterization of τ_c is an acknowledged limitation of the current state of the literature, not a deficiency in the modeling approach. The decision team accepts the residual epistemic uncertainty in τ_c as a known limitation of the hemolysis modeling field, explicitly documented in the uncertainty budget, and determines that the conservative 90th-percentile compliance demonstration provides sufficient evidence to support regulatory submission for this Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
