  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed. All achievedLevels meet or exceed requiredLevels. Seven factors carry explicitly-documented low confidence scores or wide uncertainty bounds; in every case the limitation is honestly documented with quantified rationale, the sensitivity analysis identifies the primary drivers, and the conservative over-prediction bias of the hemolysis model provides a safety margin that supports regulatory acceptance. The Monte Carlo UQ propagates all documented uncertainties through to the hemolysis index prediction. The 90% prediction interval (factor 2.3) is wide but conservative in direction; the geometric mean ratio of 1.07 confirms the model over-predicts hemolysis relative to bench measurements, meaning the clinical threshold comparison is protective. The one factor where achievedLevel equals requiredLevel after accounting for compensating evidence (Output Comparison, factor ID https://uofa.net/synth/factor/output-comparison) is addressed by the offset rationale below. The assessment team concludes that the model is fit for purpose for the COU as defined.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/morrison-cou2-offset-01",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/factor/output-comparison",
      "justification": "The Output Comparison factor achieves requiredLevel 3 at achievedLevel 3, but the 90% prediction interval factor of 2.3 is wider than the target of 2.0 established in the assessment plan. This shortfall is offset by three compensating conditions: (1) the geometric mean ratio of 1.07 confirms a conservative over-prediction bias — the model systematically predicts higher hemolysis than measured, meaning the clinical threshold comparison is protective rather than permissive; (2) the sensitivity analysis unambiguously identifies the power-law exponent C and RBC fragility scalar as the primary drivers of the wide interval, and both parameters are conservatively bounded in the Monte Carlo draws (90th percentile values used for C and fragility scalar); and (3) the clinical acceptance threshold for NIH is set at 0.8 mg/dL per 100 mL, and the 90th percentile of the predicted NIH distribution across all 5 operating points is 0.31 mg/dL — a margin of 2.6× that is sufficient to absorb the residual interval width. The assessment team therefore accepts the output comparison result as adequate for the current COU despite the PI factor slightly exceeding the plan target."
    }
  },
