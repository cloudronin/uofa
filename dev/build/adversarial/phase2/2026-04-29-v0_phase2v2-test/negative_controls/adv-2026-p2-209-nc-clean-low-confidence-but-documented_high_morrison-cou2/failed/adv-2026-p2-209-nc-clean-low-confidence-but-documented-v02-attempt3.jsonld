  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "description": "Scope is limited to the FDA generic centrifugal blood pump geometry operating as a VAD in the flow-speed envelope defined herein. The hemolysis model applies only to non-aggregating red blood cell suspensions at physiological hematocrit (35–45%). Extrapolation to axial-flow pumps, paediatric geometries, or sickle-cell populations is outside scope.",
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint-001",
      "name": "Applicability constraint: FDA centrifugal pump VAD domain",
      "type": "ApplicabilityConstraint"
    },
    "hasOperatingEnvelope": {
      "description": "Operating envelope spans pump rotational speeds of 2000–3500 RPM and volumetric flow rates of 2.5–7.0 L/min, yielding five nominal operating points. Inlet pressure is 5–15 mmHg; outlet pressure 60–120 mmHg. Blood temperature is 37 ± 1 °C. Hematocrit range 35–45%. All five operating points lie within the validated CFD mesh resolution and turbulence model applicability range established during verification.",
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope-001",
      "name": "Operating envelope: VAD flow-speed matrix",
      "type": "OperatingEnvelope"
    },
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/vad-hemolysis-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Monte Carlo sensitivity analysis — hemolysis index drivers",
    "description": "A 5000-sample Monte Carlo sensitivity analysis varied six uncertain inputs — power-law hemolysis model exponents (α, β), inlet velocity profile shape, blood viscosity, wall shear stress threshold, and mesh refinement level — and computed Sobol first-order and total-effect indices on the predicted hemolysis index. The hemolysis power-law exponent α (coefficient of determination R²=0.61) and inlet velocity profile shape (R²=0.19) together account for 80% of output variance, confirming that model-form uncertainty in the damage accumulation law is the dominant contributor to the wide 95% prediction interval (±38% of mean HI). Remaining inputs contribute less than 5% each."
  },
