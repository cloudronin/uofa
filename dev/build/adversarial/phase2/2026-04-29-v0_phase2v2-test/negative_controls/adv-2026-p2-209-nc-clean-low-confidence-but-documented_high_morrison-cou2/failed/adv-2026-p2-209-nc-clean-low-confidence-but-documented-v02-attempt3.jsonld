  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed required levels for MRL 5. The one explicitly-flagged gap — wide uncertainty bounds (±38% NIH at 95% CI) driven by power-law model-form exponent uncertainty — is fully documented, quantified via Monte Carlo sensitivity analysis (Sobol index 0.61 for exponent α), and accepted on the following basis: (1) the conservative bias of the model is mechanistically explained and empirically confirmed across all five operating points; (2) all upper-bound predictions remain below the clinical NIH threshold of 0.006 g/100L with a margin of at least 22%; (3) the wide bounds are an honest reflection of inter-laboratory variability in the damage model calibration, not a concealed deficiency; (4) independent experimental corroboration from three published studies using the same pump geometry confirms the conservative direction of bias. The provenance chain is complete from raw experimental datasets through validation activities to this assessment. No weakeners are present. The package is accepted for submission in support of the Class III device 510(k) submission with the model-form uncertainty explicitly disclosed in the submission documentation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
