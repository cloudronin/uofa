  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-nc9",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors are assessed and each achieves its required level. The package is accepted despite explicitly-documented low confidence in hemolysis model form and model inputs (power-law coefficients ±40%, hemolysis MAE 18%, 95% PI spanning factor of 2.8). This low confidence is treated as an honestly-documented epistemic gap rather than a disqualifying deficiency for the following reasons: (1) The Monte Carlo UQ fully propagates the coefficient uncertainty and demonstrates that the upper bound of the 95% prediction interval remains below the clinical hemolysis threshold (NIH < 0.01 g/100L) at all five operating points, providing a conservative safety margin. (2) The sensitivity analysis identifies the hemolysis exponent α as the dominant uncertainty driver (60% of output variance), and a targeted literature review confirms no published dataset supports coefficient values that would bring the upper prediction bound above the threshold. (3) All other credibility factors (hydraulic performance, flow field, discretization, software quality) achieve their required levels with high confidence, providing a strong mechanistic foundation. (4) The wide hemolysis prediction interval is an honest reflection of the state of the art in power-law hemolysis modelling and is consistent with FDA guidance acknowledging this limitation for computational hemolysis assessment. The decision team accepts the package with the explicit understanding that the hemolysis model form uncertainty constitutes the primary residual epistemic risk and should be revisited as new coefficient data become available.",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/hemolysis-model-form",
      "type": "OffsetRationale",
      "description": "Although hemolysis model form confidence is explicitly low (±40% coefficient uncertainty, MAE 18%), the offset is justified by: (a) conservative worst-case Monte Carlo upper bound remaining below clinical threshold at all operating points; (b) sensitivity analysis confirming α dominance with no literature evidence supporting threshold-exceeding values; (c) high-confidence hydraulic and flow-field validation providing mechanistic corroboration; and (d) alignment with FDA-acknowledged limitations of power-law hemolysis models. The residual risk is accepted as proportionate to the device benefit for a Class III VAD where the alternative (no computational hemolysis assessment) provides less information to the decision maker."
    },
    "decidedAt": "2026-04-19T00:00:00Z"
  },
