  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at achievedLevel meeting or exceeding requiredLevel. One explicitly-flagged low-confidence gap in model-form uncertainty (power-law hemolysis exponent, contributing 62% of output variance) is documented honestly and accepted as residual risk. Conservative bounding analysis demonstrates that the 95th-percentile NIH prediction remains 18% below the clinical threshold even when the full literature range of the exponent is propagated through Monte Carlo UQ. The sensitivity analysis (hasSensitivityAnalysis: true) confirms that the hemolysis exponent is the dominant uncertain input; all other inputs contribute less than 15% of total variance individually. The decision to accept is grounded in: (1) quantitative demonstration that the conservative bound is sub-threshold; (2) honest documentation of the epistemic gap rather than suppression; (3) all other credibility factors meeting required levels; (4) independent review confirming no use errors. The package is accepted for the stated COU with the model-form limitation explicitly noted in the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/model-form-low-confidence",
      "type": "OffsetRationale",
      "name": "Offset rationale for model-form low-confidence gap",
      "description": "Although model-form confidence is explicitly rated LOW due to power-law exponent epistemic uncertainty, the conservative 95th-percentile NIH bound (1000-sample Monte Carlo, full exponent range 1.9–2.8) is 18% below the clinical threshold. This margin is sufficient to accept the limitation as residual risk at MRL 5. The gap is not suppressed; it is the primary documented uncertainty and the sensitivity analysis confirms it drives the UQ. Acceptance is conditional on this margin remaining valid for the specific device geometry and operating conditions stated in the COU."
    }
  },
