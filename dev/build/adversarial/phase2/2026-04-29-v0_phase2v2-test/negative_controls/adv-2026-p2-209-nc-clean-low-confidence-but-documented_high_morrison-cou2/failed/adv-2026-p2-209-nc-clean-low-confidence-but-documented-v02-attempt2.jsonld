      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Primary QoI is normalized index of hemolysis (NIH), which is the direct clinical surrogate used in FDA guidance for VAD hemolysis assessment. Validation data uses the same NIH metric computed from the same power-law damage accumulation model.",
      "acceptanceCriteria": {
