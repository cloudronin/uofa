      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Twelve hemolysis experiments conducted (4 operating conditions × 3 replicates). Sample size sufficient to estimate mean NIH with 95% CI width below 15% of mean. Fluid lot traceability and storage conditions documented per ASTM F1830.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/testsamples-ac-001",
        "type": "AcceptanceCriteria",
        "description": "Minimum three replicates per operating condition. 95% confidence interval on mean NIH must be below 20% of mean. Sample preparation and storage must be documented per applicable ASTM standards."
      }
    },
