      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Boundary conditions in simulation matched to experimentally measured inlet velocity profiles (within 3.5% of bulk flow rate) and outlet pressure (within 1.2 mmHg). Fluid properties in simulation set to match blood analog fluid measured viscosity at each test condition. Equivalency documented in validation traceability matrix.",
      "acceptanceCriteria": {
