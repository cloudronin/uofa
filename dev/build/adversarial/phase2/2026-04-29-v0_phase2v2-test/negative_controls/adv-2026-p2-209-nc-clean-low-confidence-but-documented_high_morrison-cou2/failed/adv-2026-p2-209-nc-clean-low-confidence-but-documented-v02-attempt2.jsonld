  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed with achieved levels meeting or exceeding required levels for MRL 5. The explicitly documented low-confidence input for the power-law hemolysis model coefficient C (CV=14%) is the dominant uncertainty source, but Monte Carlo UQ (10,000 samples) demonstrates that predicted NIH at the 90th-percentile upper bound remains 31% below the clinical acceptance threshold of 0.8 g/100L. Sensitivity analysis confirms no other input parameter drives predictions above threshold even under pessimistic assumptions. The decision team accepts this residual uncertainty as bounded and non-disqualifying given the demonstrated margin. Validation evidence is traceable, quantitative comparison metrics meet acceptance criteria, and the provenance chain is complete from foundational experimental datasets through all validation results.",
    "decidedAt": "2026-04-19T00:00:00Z"
