  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed with achieved levels meeting or exceeding required levels for Model Risk Level 5. The CFD hemolysis model demonstrates NIH predictions within 14.1% of FDA inter-laboratory experimental data across all five VAD operating points, with all predictions within k=2 experimental uncertainty bands. Monte Carlo uncertainty quantification (n=2000) confirms that the 95th-percentile NIH remains below the clinical acceptance threshold across the full COU operating envelope. Sobol sensitivity analysis identifies the hemolysis model coefficient as the dominant uncertainty driver (S1=0.61), and this uncertainty is fully characterised and bounded. Software quality assurance, code verification, and discretization error assessments confirm the numerical foundation is sound. Independent review of simulation setup mitigates use error risk. The structured evidence chain from foundational experimental data through validation results to this decision record is complete and traceable. The credibility evidence is sufficient to support regulatory acceptance of the CFD hemolysis predictions for this Class III VAD COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
