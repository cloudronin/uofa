  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed the required levels for MRL 5. The CFD hemolysis model demonstrates adequate fidelity for absolute NIH prediction across the VAD operating envelope: GCI < 5% (discretization), MARE 8.3% within experimental uncertainty (output comparison), and Monte Carlo UQ confirms all 95th-percentile predictions remain below the clinical hemolysis threshold. Model form and input uncertainty are adequately characterized. Independent review confirms no use errors. The structured evidence package supports acceptance of the CFD model for the stated COU without residual credibility gaps.",
