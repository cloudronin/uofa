    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The primary QoI (NIH, g/100 L) is the direct regulatory metric for hemolysis evaluation in VAD submissions per FDA guidance. NIH is computed from the CFD shear stress and exposure time fields using the Giersiepen-Wurzinger power-law model. Traceability from COU requirement to QoI to model output is documented in requirements matrix RM-2024-COU2.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/qoi-relevance-mrl5",
        "type": "AcceptanceCriteria",
        "description": "Gradation 3 requires that QoIs are directly traceable to the regulatory acceptance criterion and that the mapping from model output to QoI is formally documented with no unquantified intermediate transformations."
      }
