      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "RANS k-ω SST turbulence model selected based on published benchmarks for rotating machinery hemolysis prediction (Hariharan 2011, Grigioni 2005). Hemolysis damage model (Giersiepen-Wurzinger) is the standard for FDA pump submissions. Model form uncertainty estimated via comparison with LES results at 3 operating points; NIH difference < 9%, within accepted model form uncertainty band for MRL 5.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-form-mrl5",
        "type": "AcceptanceCriteria",
        "description": "Gradation 3 requires documented justification of turbulence and damage model selection with reference to published benchmarks, and quantitative model form uncertainty estimate via higher-fidelity comparison or sensitivity study."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "All model inputs (geometry, boundary conditions, material properties) traced to calibrated measurements or published reference data. Sensitivity of NIH to ±5% variation in each input parameter quantified via one-at-a-time sensitivity analysis; inlet flow rate and rotational speed identified as most influential. Monte Carlo UQ propagates joint uncertainty across all inputs.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-inputs-mrl5",
        "type": "AcceptanceCriteria",
        "description": "Gradation 3 requires all inputs to be traceable to measurements or reference data, with a documented sensitivity analysis identifying the most influential inputs and a UQ study propagating input uncertainty to QoI."
