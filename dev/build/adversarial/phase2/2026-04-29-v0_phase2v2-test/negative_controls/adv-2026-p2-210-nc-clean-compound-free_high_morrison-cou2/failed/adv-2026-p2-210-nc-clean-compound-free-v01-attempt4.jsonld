  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5 have achieved levels meeting or exceeding required gradation 3. Software quality assurance confirmed via commercial solver audit and regression testing. Numerical code verification via MMS demonstrates second-order accuracy. Discretization error quantified via GCI (< 3.1%). Test conditions fully documented with NIST-traceable calibration. Output comparison E_rms = 8.4% within 15% threshold with all predictions within experimental uncertainty bands. QoI directly traceable to FDA regulatory metric. Validation activities performed on the same device class and flow regime as the COU. Numerical solver iterative convergence confirmed to ≥ 6 orders of magnitude. Independent use-error review completed with all discrepancies resolved. Model form uncertainty estimated via LES comparison (< 9% NIH difference). All model inputs traced to calibrated measurements with Monte Carlo UQ propagated. Test samples include n=6 replicates per operating point with power-analysis justification. Equivalency matrix confirms experimental-to-computational input mapping within acceptable bounds. Monte Carlo uncertainty quantification on hemolysis predictions documented. The totality of evidence supports acceptance of the CFD model for predicting absolute hemolysis levels for the Class III VAD device within the defined operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
