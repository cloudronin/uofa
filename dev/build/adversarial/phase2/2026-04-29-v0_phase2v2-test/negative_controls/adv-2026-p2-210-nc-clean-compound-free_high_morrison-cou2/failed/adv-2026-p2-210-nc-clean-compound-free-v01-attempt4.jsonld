      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Independent simulation review performed by a second credentialed analyst not involved in the original setup. Checklist-based review (USE-CL-2024) covered boundary condition assignment, material property input, turbulence model selection, and post-processing scripts. Two minor discrepancies identified and corrected prior to final results; no systematic use errors remain.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/use-error-mrl5",
        "type": "AcceptanceCriteria",
        "description": "Gradation 3 requires independent peer review of simulation setup and post-processing by a qualified analyst, with documented resolution of all identified discrepancies prior to results acceptance."
      }
