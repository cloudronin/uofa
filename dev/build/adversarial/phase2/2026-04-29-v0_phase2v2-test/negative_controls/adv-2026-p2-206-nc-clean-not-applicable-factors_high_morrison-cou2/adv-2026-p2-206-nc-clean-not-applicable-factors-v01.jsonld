  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "At MRL 5 for a Class III VAD device, software quality assurance requires documented version control, regression testing, and traceability of solver modifications. The CFD solver (OpenFOAM v9) is governed by the team's ISO 9001-aligned SQA plan; all custom hemolysis sub-models are version-controlled in a dedicated Git repository with CI regression suite covering 48 canonical test cases. Achieved level 3 meets the required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/sqa",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criteria — MRL 5 Class III VAD",
        "description": "Documented SQA plan referencing ISO 9001; version control covering all solver customizations; regression test suite with pass rate ≥ 95%; traceability matrix linking requirements to test cases."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "rationale": "Numerical code verification confirms that the solver correctly implements the governing equations. Method of manufactured solutions (MMS) applied to the incompressible Navier-Stokes solver and the power-law hemolysis transport equation; observed spatial order of accuracy (1.96 for velocity, 1.88 for scalar transport) consistent with theoretical second-order convergence. Achieved level 4 exceeds the required level 3.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/code-verification",
        "type": "AcceptanceCriteria",
        "name": "Code verification acceptance criteria",
        "description": "MMS convergence study demonstrating observed order of accuracy within 10% of theoretical order for all primary equations; documented in a verification report reviewed by an independent analyst."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Discretization error quantified via three-level mesh refinement (GCI study). GCI on NIH < 2.4% at finest mesh; wall y+ maintained below 1 at all operating points to ensure accurate boundary layer resolution for hemolysis-relevant shear stress. Richardson extrapolation applied. Achieved level 3 meets required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/discretization",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria",
        "description": "GCI < 5% on primary QoI (NIH) at production mesh; wall y+ ≤ 1 across ≥ 95% of wetted surface; three distinct mesh levels with refinement ratio ≥ 1.3."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Experimental test conditions used for validation are documented with traceability: flow rate measured via Coriolis meter (±0.5%), rotational speed via optical tachometer (±1 rpm), blood analog viscosity and density measured per ASTM F1841. Temperature maintained at 37 ± 0.5 °C. All five operating points replicated in triplicate to characterize repeatability. Achieved level 3 meets required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria",
        "description": "All boundary conditions documented with calibrated instrument uncertainty; temperature controlled within ±1 °C; minimum triplicate replication at each operating point; test protocol reviewed and approved by independent laboratory."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Output comparison performed using a formal validation metric (E_rms normalized by experimental uncertainty) across all five operating points. Agreement metric E_rms = 0.83 (< 1.0 acceptance threshold), indicating CFD predictions fall within expanded experimental uncertainty. Comparison documented in a validation report with full uncertainty budget. Achieved level 4 meets required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria",
        "description": "Normalized RMS error metric E_rms < 1.0 across all validation operating points; full uncertainty budget provided for both simulation and experiment; comparison documented with statistical confidence intervals."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is the same metric used for clinical risk assessment per ASTM F1830 and ISO 10993-4. The hemolysis sub-model scalar transport equation directly computes NIH from local shear stress and exposure time, ensuring the validated output is identical to the COU decision metric. No surrogate or proxy QoI is used. Achieved level 4 meets required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/qoi-relevance",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criteria",
        "description": "Primary simulation output (NIH) is the same metric used in regulatory submission; traceability documented between COU decision metric and model output variable; no surrogate QoI substitution without documented justification."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump geometry — the same geometry used in the COU — across operating conditions that span and bracket the intended clinical operating envelope (2–8 L/min, 2000–3500 rpm). Fluid properties matched clinical blood analog per ASTM F1841. Geometric fidelity confirmed via CMM inspection of the physical test pump. Achieved level 4 meets required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/validation-relevance",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance acceptance criteria",
        "description": "Validation geometry identical to COU geometry (confirmed by metrology report); validation operating conditions bracket COU envelope; fluid properties within 5% of COU conditions; documented mapping between validation activities and COU requirements."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Iterative convergence monitored via residual norms (all residuals < 1e-6 at steady state) and global conservation checks (mass imbalance < 0.01%). Time-step independence study performed for transient impeller passages; Courant number maintained below 0.8. Solver settings documented in a reproducible configuration file under version control. Achieved level 3 meets required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/solver-error",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error acceptance criteria",
        "description": "All residuals < 1e-5 at convergence; global mass imbalance < 0.1%; time-step independence demonstrated with < 2% change in NIH between half-step and full-step solutions; solver configuration under version control."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Use error controls include: documented simulation protocol reviewed by a second qualified analyst; independent re-run of two operating points by a different team member yielding NIH agreement within 0.3%; checklist-based pre-submission review covering boundary condition assignment, material property inputs, and post-processing scripts. All deviations from protocol require documented justification. Achieved level 3 meets required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/use-error",
        "type": "AcceptanceCriteria",
        "name": "Use error acceptance criteria",
        "description": "Documented simulation protocol with independent analyst review; at least one independent re-run confirming reproducibility within 5% on primary QoI; pre-submission checklist completed and archived."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Model form assessment addresses turbulence closure (SST k-ω) and hemolysis sub-model (Giersiepen power-law). SST k-ω selected based on documented literature comparison for confined rotational flows; sensitivity to turbulence model evaluated by comparing SST k-ω, realizable k-ε, and LES at one operating point — NIH variation < 11%. Hemolysis power-law constants calibrated against independent dataset (Zhang et al. 2011). Model form uncertainty included in overall UQ budget. Achieved level 4 meets required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-form",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria",
        "description": "Documented justification for turbulence closure selection; sensitivity study comparing at least two turbulence models; hemolysis sub-model constants traceable to peer-reviewed calibration dataset; model form uncertainty quantified and included in total uncertainty budget."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "All model inputs (inlet velocity profiles, fluid viscosity, density, pump geometry, rotational speed) are documented with sources and measurement uncertainties. Inlet velocity profiles derived from Doppler ultrasound measurements of the test loop; geometry from CMM-verified CAD. Monte Carlo propagation of input uncertainties through the solver quantifies their contribution to NIH prediction interval. Achieved level 3 meets required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria",
        "description": "All boundary condition inputs documented with measurement source and expanded uncertainty; geometric inputs traceable to metrology report; input uncertainty propagated through model via Monte Carlo or equivalent method."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Blood analog samples prepared per ASTM F1841 using porcine red blood cells at 30% hematocrit. Sample preparation documented with lot numbers, preparation date, and pre-test osmolality and fragility checks. Three independent sample batches used across the five operating points to ensure batch-to-batch variability is captured in the experimental uncertainty estimate. Achieved level 3 meets required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-samples",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria",
        "description": "Blood analog preparation per ASTM F1841 with documented lot traceability; pre-test quality checks (osmolality, fragility index) within specification; minimum two independent batches used to characterize inter-batch variability."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Equivalency of input parameters' factor in ASME V&V 40 applies specifically to situations where validation activities are conducted on a surrogate or analog device that differs from the COU device, requiring a formal demonstration that the input parameter space of the surrogate maps equivalently onto the COU device's operating domain. In this assessment, validation was performed directly on the FDA generic centrifugal pump — the identical geometry and device type used in the COU — across operating conditions that are a proper subset of the COU envelope. Because there is no surrogate or analog device substitution, there is no non-equivalency to characterize or justify. Applying this factor would require constructing an equivalency argument between a device and itself, which is tautological and provides no credibility information. This determination was reviewed by the independent credibility assessment lead and confirmed as appropriate for direct-device validation contexts at MRL 5. The absence of this factor does not reduce overall credibility because the validation-to-COU mapping is instead fully addressed under 'Relevance of the validation activities to the COU' (assessed at level 4)."
    }
  ],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "The COU2 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under VAD conditions is accepted. All 12 assessed credibility factors achieve their required levels: software quality assurance (3/3), numerical code verification (4/3), discretization error (3/3), test conditions (3/3), output comparison (4/4), relevance of QoI (4/4), relevance of validation to COU (4/4), numerical solver error (3/3), use error (3/3), model form (4/4), model inputs (3/3), and test samples (3/3). The thirteenth factor — equivalency of input parameters — is documented as not-applicable because validation was conducted on the identical COU device geometry and operating domain, making surrogate equivalency arguments inapplicable; this determination is reviewed and confirmed. The primary QoI (NIH) is validated against FDA benchmark experimental data with normalized RMS error of 0.83 (below the 1.0 acceptance threshold). Monte Carlo uncertainty quantification with 2000 samples demonstrates that NIH predictions at all five operating points remain below the clinical hemolysis threshold at the 95th percentile. Independent re-run and checklist review controls are in place. The provenance chain from raw experimental data through validation results to this decision record is complete and traceable. No credibility gaps remain; the model is fit for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
