  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (Class III VAD hemolysis prediction at MRL 5) is accepted on the basis of the following structured evidence: (1) All 12 assessed credibility factors achieve their required levels — 10 factors at exactly the required level and 2 factors (Discretization error, achieved L4 vs. required L3) exceeding requirements, providing positive credibility margin. (2) The single not-applicable factor (Equivalency of input parameters) is correctly scoped out because no surrogate or scaled inputs were used in the validation campaign; this scoping decision was independently peer-reviewed and confirmed. (3) Three independent validation results (PIV velocity fields, absolute NIH, pump H-Q curve) each carry documented uncertainty quantification and provenance links, satisfying the ProfileMinimal evidence chain requirements. (4) Monte Carlo uncertainty quantification (1000 samples) confirms that the 95% confidence interval on NIH predictions remains within the 25% total uncertainty budget at all 5 operating points, and Sobol sensitivity analysis identifies the stress exponent as the dominant uncertainty driver, enabling targeted future refinement. (5) Software quality assurance, code verification via MMS, and iterative convergence monitoring collectively establish that numerical errors are not a significant contributor to prediction uncertainty relative to model form and input uncertainties. (6) Use-error controls (independent peer review and two-analyst reproducibility check) confirm that operator-specific setup errors are not present. The combination of all factors meeting or exceeding required levels, a well-documented N/A scoping decision, and a complete provenance chain from raw experimental data through validation results to this decision record supports acceptance of the model for its intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
