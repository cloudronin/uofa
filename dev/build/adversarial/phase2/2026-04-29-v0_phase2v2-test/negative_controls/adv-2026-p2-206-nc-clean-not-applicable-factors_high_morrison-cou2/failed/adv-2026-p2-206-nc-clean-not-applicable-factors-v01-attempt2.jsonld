    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Quantitative output comparison performed using validation metrics including mean absolute error, normalized RMS error, and U95 uncertainty-normalized error metric (Oberkampf-Trucano). NIH predictions: mean absolute error 0.0031 g/100L, within experimental uncertainty at all 5 operating points. Velocity field NRMSE: 4.7%. Pump head error: maximum 7.6%.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria",
        "description": "NIH predictions must agree with experimental values within combined simulation and experimental uncertainty (U95) at all operating points. Velocity NRMSE must be below 10%. Pump head error must be below 10%. All thresholds met."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "rationale": "The primary quantity of interest — normalized index of hemolysis (NIH) — is directly the clinical endpoint of concern and the regulatory submission metric. The CFD model outputs NIH directly via integration of the power-law hemolysis scalar over Lagrangian particle trajectories. There is no surrogate or proxy quantity; the QoI is identical to the decision-relevant metric.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/qoi-relevance",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criteria",
        "description": "The modeled QoI must be the same metric as the regulatory decision criterion (NIH in g/100L). No surrogate quantities may substitute for the primary hemolysis endpoint. Direct NIH computation via Lagrangian hemolysis integration confirmed."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump benchmark — the same device class, geometry family, and operating regime as the COU. Blood analog fluid properties match clinical hematocrit range. Operating points in the validation dataset overlap with the COU operating envelope. Residual gap: validation was performed with bovine blood rather than human blood, which is documented and within accepted practice for hemolysis benchmarking.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/validation-relevance",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance acceptance criteria",
        "description": "Validation must be conducted on a device of the same pump type (centrifugal), same flow regime (turbulent, Re > 10,000), and overlapping operating envelope. Blood or blood analog must be within accepted hemolysis benchmarking practice. All criteria met; bovine blood analog use documented and justified."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Iterative convergence monitored via residual norms (all below 1e-6) and global conservation checks (mass imbalance < 0.01%). Time-step independence study conducted for transient impeller rotation: halving the time step changed NIH by less than 1.5%. Round-off error assessed as negligible (double precision arithmetic throughout).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/solver-error",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error acceptance criteria",
        "description": "Iterative residuals must reach 1e-5 or lower for all equations. Mass conservation imbalance must be below 0.1%. Time-step sensitivity must show less than 3% change in NIH upon halving. All criteria met."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Use error assessment conducted via independent re-run of the simulation setup by a second analyst using only the documented simulation protocol. Boundary conditions, mesh settings, solver parameters, and post-processing steps were reproduced within 0.5% of original NIH predictions. Simulation protocol document version-controlled and reviewed.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/use-error",
        "type": "AcceptanceCriteria",
        "name": "Use error acceptance criteria",
        "description": "Independent analyst reproduction must yield NIH predictions within 2% of original results using only the documented simulation protocol. Protocol must be version-controlled. Both criteria satisfied."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Model form uncertainty assessed by comparing three turbulence model variants (k-ω SST, realizable k-ε, and RSM) and two hemolysis power-law model parameterizations (Giersiepen and Zhang coefficients). NIH predictions across turbulence models vary by ±18%; this variation is captured within the Monte Carlo UQ envelope. RSM selected as primary model based on best agreement with PIV data. Model form uncertainty explicitly included in the reported prediction interval.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-form",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria",
        "description": "At least two turbulence model variants must be evaluated; model form uncertainty must be quantified and included in the total prediction uncertainty budget. Hemolysis power-law coefficient sensitivity must be assessed. All criteria met; model form uncertainty is the dominant uncertainty contributor at 18% NIH variation."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "All model inputs characterized with documented uncertainty distributions: inlet velocity profiles (uniform with ±3% turbulence intensity), blood viscosity (Carreau-Yasuda model with ±5% coefficient uncertainty), impeller rotational speed (±0.5% tachometer accuracy), and hemolysis power-law exponents (literature-derived distributions). Input uncertainty propagated via Monte Carlo (N=2000) to NIH prediction intervals.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria",
        "description": "All primary model inputs must have documented uncertainty estimates with traceable sources. Uncertainty propagation must be performed for inputs contributing more than 1% to output variance. Monte Carlo N≥1000 required for MRL 5. All criteria met."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "FDA benchmark experimental dataset includes hemolysis measurements from 3 independent test runs at each of 5 operating points (15 total measurements), with inter-run variability documented (CV < 8% for NIH). Sample size sufficient to characterize experimental uncertainty and detect systematic bias. Blood analog (bovine blood, hematocrit 40%) prepared fresh for each test run with documented preparation protocol.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/test-samples",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria",
        "description": "Minimum 3 independent replicates per operating point required. Inter-run CV must be documented. Blood analog preparation must follow a documented protocol with hematocrit verification. All criteria met."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Equivalency of input parameters' factor addresses the degree to which the simulation input parameters used in validation activities are equivalent to those that will be used in the intended COU application — a concern that arises specifically when the validation case and the deployment case involve different physical hardware, different operating institutions, or different input parameter sources that must be mapped between contexts. In this assessment, the validation activities were conducted directly on the FDA generic centrifugal pump benchmark, which is the same device family and the same operating regime as the COU. The CFD model is not being transferred to a different device or operating context; rather, the validation and the COU share identical geometry, fluid properties (bovine blood analog at clinical hematocrit), and the same five operating points defined in the COU envelope. There is no parameter mapping or cross-context transfer that would create an equivalency gap. The factor is therefore not-applicable because the premise of the factor — a distinction between validation-domain inputs and deployment-domain inputs — does not obtain in this assessment. This determination was reviewed by the credibility assessment team lead and confirmed against ASME V&V 40-2018 Section 6.3.4, which notes that the equivalency factor is most relevant when validation is performed on a surrogate or analogue device rather than the device of intended use."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 12 assessed credibility factors achieve their required levels under ASME V&V 40-2018 at Model Risk Level 5 for this Class III VAD application. The one factor designated not-applicable (Equivalency of input parameters) has been reviewed and confirmed as genuinely inapplicable because validation was conducted directly on the device family of intended use with no cross-context parameter mapping required. Key evidence supporting acceptance: (1) NIH predictions agree with FDA benchmark experimental data within combined uncertainty at all 5 operating points; (2) GCI-based discretization error is below 5% on the fine mesh; (3) Monte Carlo UQ (N=2000) fully characterizes the prediction interval including dominant model-form uncertainty from turbulence model selection; (4) Code verification via MMS confirms correct numerical implementation; (5) Independent analyst reproduction confirms use error is controlled. The decision is grounded in the structured credibility evidence documented in this package and is consistent with the MRL 5 requirements for a primary-basis hemolysis prediction supporting Class III device regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
