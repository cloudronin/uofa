        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria",
        "description": "GCI on QoI (hemolysis index) must be <5% on the production mesh. Achieved GCI of 3.2% satisfies this criterion. Three-mesh Richardson extrapolation required; all meshes generated with consistent blocking strategy."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "rationale": "In-vitro test conditions replicate the 5 CFD operating points with matched flow rates (±0.05 L/min), rotational speeds (±10 RPM), and fluid properties (bovine blood, hematocrit 40±2%). Temperature controlled at 37±0.5°C. Test rig calibration traceable to NIST standards.",
      "acceptanceCriteria": {
