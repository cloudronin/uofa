  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation 2 levels for MRL 2. The six scoped-out factors are acceptable at MRL 2 per the documented credibility plan and ASME V&V 40 Table 4-1. The primary QoI (NIH) prediction error of 18.4% (95% CI 9.1%–27.7%) is explicitly below the pre-specified 30% acceptance threshold despite a moderate-low confidence score of 0.61. Wide uncertainty bounds on NIH predictions are honestly documented and arise from inter-donor blood rheology variability and RBC damage model constant uncertainty, both of which are characterized through Monte Carlo UQ (500 runs). The shear stress field validation confidence score of 0.58 is acknowledged; PIV spatial resolution limitations near the blade trailing edge are documented and accepted as residual uncertainty given that shear stress is a secondary QoI and the primary NIH criterion is met. The sensitivity analysis confirms that RBC damage model power-law exponents (alpha, beta) are the dominant drivers of NIH prediction spread, contributing 71% of total output variance; geometric tolerance effects contribute 18%. These findings are consistent with published literature and do not alter the credibility conclusion. The decision team accepts the residual uncertainty as proportionate to the MRL 2 decision consequence and the medium model influence classification. No weakener conditions are triggered.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
