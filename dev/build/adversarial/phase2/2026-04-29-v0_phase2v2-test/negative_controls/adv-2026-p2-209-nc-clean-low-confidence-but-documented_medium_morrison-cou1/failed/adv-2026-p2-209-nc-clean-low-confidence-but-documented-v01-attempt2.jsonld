  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment concludes that the CFD hemolysis model is fit for the stated COU (identifying worst-case hemolysis operating conditions for a Class II CPB device at MRL 2) despite explicitly documented low-to-moderate confidence scores in several factors. Key findings: (1) All 7 assessed factors achieve required MRL 2 levels; (2) The primary fitness-for-purpose criterion — correct rank ordering of worst-case operating condition — is met in 5/5 validation cases; (3) The wide prediction interval (±31% NIH, confidence score 0.52) is honestly documented and propagated through sensitivity analysis; (4) Dominant uncertainty sources (shear exposure path length, blood analog viscosity) are identified by Sobol analysis and do not affect the rank-ordering conclusion; (5) Six factors are appropriately scoped out at MRL 2 with documented rationale. The decision accepts residual uncertainty in absolute NIH magnitude while confirming that relative worst-case identification — the actual COU decision — is robust. The hasOffsetRationale below documents the explicit acceptance of the borderline output comparison confidence score.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/output-comparison-low-confidence",
      "type": "OffsetRationale",
      "name": "Offset rationale — low confidence score on output comparison factor",
      "refersToFactor": "https://uofa.net/synth/factor/output-comparison",
      "justification": "The output comparison factor achieves requiredLevel 2 with achievedLevel 2, but carries a low confidence score (0.52/1.0) due to the wide 95% prediction interval (±31% NIH) driven by blood analog viscosity and shear exposure path length uncertainty. Acceptance is justified because: (a) the COU decision criterion is rank ordering of worst-case operating conditions, not absolute NIH magnitude; (b) correct rank ordering is demonstrated in 5/5 validation cases regardless of the wide absolute bounds; (c) Sobol sensitivity analysis confirms that the dominant uncertainty sources (shear path length, viscosity) affect all operating points proportionally, preserving rank order; (d) the ±31% bound is conservative relative to the RH < 1 acceptance criterion margin (worst-case predicted RH = 0.71, margin = 0.29); and (e) residual uncertainty in absolute NIH is accepted as documented residual risk at MRL 2 for this Class II device."
    }
  },
