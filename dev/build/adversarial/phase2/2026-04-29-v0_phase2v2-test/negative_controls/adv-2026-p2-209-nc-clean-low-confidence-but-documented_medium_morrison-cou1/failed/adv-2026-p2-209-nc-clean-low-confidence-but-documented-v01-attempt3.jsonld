  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-mrl2-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis worst-case identification, MRL 2, Class II) is accepted with documented residual risk. All seven assessed factors meet or exceed their required levels (Software QA: 2/2; Code Verification: 2/2; Discretization Error: 3/2; Test Conditions: 2/2; Output Comparison: 2/2; QoI Relevance: 2/2; Validation Relevance: 2/2). Six factors are scoped out with documented rationale consistent with MRL 2 requirements. The package honestly documents low-to-moderate confidence in two key validation results: (1) PIV velocity comparison confidence is LOW (0.45) due to limited repeats and blade-tip optical access limitations, with U95 = ±6.1%; (2) NIH hemolysis comparison confidence is MODERATE-LOW (0.52) with U95 = ±12% and a systematic under-prediction bias of 8-14% at high-shear points. The sensitivity analysis demonstrates that turbulence model choice drives 68% of NIH prediction variance and blood analogue viscosity variability contributes 21%, explaining the wide bounds. These limitations are accepted as residual risk at MRL 2 because: (a) the decision uses relative hemolysis index (RH) rather than absolute NIH, partially cancelling systematic bias; (b) model influence is MEDIUM with physical bench testing providing confirmatory evidence; (c) the documented bias is conservative (under-prediction means the model does not understate hemolysis risk for the comparison); and (d) MRL 2 does not require high-confidence absolute validation. The offset rationale is documented below.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/morrison/offset/low-confidence-validation-offset-001",
      "type": "OffsetRationale",
      "description": "Two validation results carry explicitly low-to-moderate confidence scores (PIV velocity: 0.45; NIH hemolysis: 0.52) and the NIH comparison exhibits a systematic under-prediction bias of 8-14%. These do not constitute achievedLevel < requiredLevel failures (all assessed factors meet required levels), but represent honest documentation of evidence quality limitations. Acceptance is justified by three offsets: (1) The primary decision metric is the relative hemolysis index RH = NIH_device/NIH_predicate; systematic bias largely cancels in this ratio, reducing the effective decision uncertainty. (2) Physical bench testing at 3 of 5 operating points provides direct confirmatory evidence that the model correctly rank-orders operating conditions by hemolysis severity, which is the COU question. (3) The sensitivity analysis confirms that the dominant uncertainty source (turbulence model) affects absolute NIH magnitude but not the ordinal ranking of operating conditions, preserving the model's fitness for the worst-case identification purpose. Residual risk is accepted at MRL 2 for a Class II device with MEDIUM model influence."
    }
  },
