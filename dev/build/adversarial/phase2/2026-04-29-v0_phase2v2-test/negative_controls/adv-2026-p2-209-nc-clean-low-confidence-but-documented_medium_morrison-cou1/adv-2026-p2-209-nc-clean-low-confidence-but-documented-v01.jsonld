  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet their required Gradation 2 levels. Six factors are appropriately scoped out at MRL 2. The evidence carries explicitly low confidence in absolute NIH magnitude (mean relative error 18%, 95% CI ±31%), arising primarily from uncertainty in the Giersiepen-Wurzinger power-law exponents and blood analogue viscosity. These limitations are documented honestly through a 500-draw Monte Carlo UQ analysis and Sobol sensitivity decomposition. The COU decision requires rank identification of worst-case hemolysis conditions, not absolute NIH prediction. Rank ordering is preserved in 97% of MC draws and confirmed in 4/5 experimental comparisons. The residual uncertainty in absolute NIH magnitude is accepted as a documented residual risk because: (1) the relative hemolysis index criterion (RH < 1 vs. predicate) is robust to proportional NIH uncertainty when applied consistently to both device and predicate; (2) bench testing provides an independent confirmation pathway per the Medium model influence classification; and (3) the Sobol analysis identifies gap clearance as the dominant driver (S1=0.61), enabling targeted experimental confirmation at the worst-case tolerance combination. The package is structurally complete with full provenance chains, linked uncertainty quantification on all validation results, and a sensitivity analysis confirming which uncertain inputs drive the wide bounds. Decision: Accepted with documented residual uncertainty in absolute hemolysis magnitude.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/cpb-hemolysis-uq-offset-001",
      "type": "OffsetRationale",
      "name": "Offset rationale — wide NIH uncertainty bounds accepted for rank-ordering COU",
      "refersToFactor": "https://uofa.net/synth/ac/oc-ac-001",
      "justification": "The Output Comparison factor documents wide absolute uncertainty (±31% NIH, 95% CI) arising from power-law exponent and viscosity uncertainty. This shortfall in absolute predictive confidence is offset by three considerations: (1) the COU requires rank ordering of worst-case conditions, which is preserved in 97% of MC draws; (2) bench testing under Medium model influence provides independent confirmation; and (3) Sobol sensitivity analysis identifies gap clearance as the dominant variance driver, enabling targeted experimental confirmation at the identified worst-case operating point. The residual risk of incorrect absolute NIH magnitude is accepted and documented."
    }
  },
