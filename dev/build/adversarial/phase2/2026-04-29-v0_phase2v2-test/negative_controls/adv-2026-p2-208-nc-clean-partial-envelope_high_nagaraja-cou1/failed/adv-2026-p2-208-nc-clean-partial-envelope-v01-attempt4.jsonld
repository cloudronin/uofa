    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/envelope",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 compression-bending operating envelope for non-cannulated 7.5 mm pedicle screw",
      "description": "The model is validated within the following bounded operating envelope: axial compressive load 0–2500 N applied at crosshead displacement rate 5 ± 0.5 mm/min; screw outer diameter 7.5 ± 0.05 mm; screw length 45–55 mm; rod diameter 5.5 mm CoCr; UHMWPE block geometry per ASTM F1717 (35 mm inter-body distance); ambient temperature 22 ± 3 °C; relative humidity 45–65 %; testing medium air (dry bench). Extrapolation beyond these bounds requires separate validation activity."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated titanium alloy pedicle screw, static loading only",
      "description": "Model applicability is restricted to non-cannulated titanium alloy (Ti-6Al-4V ELI) pedicle screws of nominal 7.5 mm outer diameter under quasi-static monotonic compression-bending per ASTM F1717. The constraint excludes: cannulated screw geometries, dynamic or fatigue loading regimes, screws with outer diameter outside 7.0–8.0 mm, cobalt-chrome alloy screws, and in vivo or simulated bone-interface loading. Coverage gaps in validation samples (N=11, two discrete screw lengths 45 mm and 55 mm only) are acknowledged; intermediate lengths are covered by interpolation with documented uncertainty."
    }
  },
