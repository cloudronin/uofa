  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/sensitivity/nc8-global-sa",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis: material properties and geometry on compression-bending QoIs",
    "description": "Sobol first-order and total-effect indices computed over six input parameters (Young's modulus, yield strength, screw OD, rod diameter, inter-body distance, friction coefficient) using N=2048 quasi-random LHS samples. Young's modulus and yield strength together account for 74 % of stiffness variance and 81 % of yield force variance respectively; geometric parameters are secondary contributors. Results confirm that material property characterization is the dominant uncertainty driver and justify targeted material coupon testing as the primary uncertainty reduction strategy."
  },
