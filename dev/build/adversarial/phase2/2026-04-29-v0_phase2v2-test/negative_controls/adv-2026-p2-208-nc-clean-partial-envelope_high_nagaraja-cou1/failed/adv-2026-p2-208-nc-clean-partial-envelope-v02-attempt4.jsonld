    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 compression-bending operating envelope for non-cannulated 7.5 mm pedicle screw",
      "description": "The model is valid within the following bounded conditions: screw outer diameter 7.0–8.0 mm (nominal 7.5 mm ± 0.5 mm manufacturing tolerance); titanium alloy Ti-6Al-4V ELI with elastic modulus 110–120 GPa and yield strength 880–970 MPa; UHMWPE block stiffness 200–350 MPa; applied axial compressive load 0–2500 N; applied bending moment 0–50 N·m; crosshead displacement rate 5 mm/min ± 0.5 mm/min per ASTM F1717 §8.4; ambient temperature 20–25 °C; rod diameter 5.5 mm ± 0.1 mm; screw insertion angle 0°–10° from rod axis. Validation experiments were conducted within these bounds across two independent laboratories."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated 7.5 mm pedicle screw under static ASTM F1717 loading",
      "description": "Model applicability is restricted to: (1) non-cannulated pedicle screw designs only — cannulated variants with inner bore diameter > 0 mm are explicitly out of scope due to differing stress concentration profiles; (2) static monotonic loading per ASTM F1717 — dynamic fatigue or cyclic loading scenarios are excluded; (3) screw nominal diameter 7.5 mm ± 0.5 mm — extrapolation to 4.5 mm or 8.5 mm screws is not supported without re-validation; (4) single-level construct configurations as tested — multi-level constructs are out of scope; (5) titanium alloy Ti-6Al-4V ELI material only — cobalt-chrome or stainless steel constructs are excluded. Coverage gaps acknowledged: validation samples are concentrated at 7.5 mm diameter and 0° insertion angle; sparse coverage at 10° insertion angle (n=2 of 11 constructs) is documented as a limitation of the current validation dataset."
    }
  },
