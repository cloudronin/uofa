  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for the non-cannulated 7.5 mm pedicle screw construct demonstrates sufficient credibility for the declared COU. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single shortfall (Test conditions, achieved Level 2 vs. required Level 3) is offset by: (1) the operating envelope explicitly scoping the COU to monotonic static loading at room temperature only, making multi-rate multi-temperature testing unnecessary for the bounded claim; (2) all three QoIs satisfy the E/u_val < 1.96 and relative error < 10% acceptance criteria with substantial margin (maximum E/u_val = 1.12, maximum relative error = 2.4%); (3) sensitivity analysis confirms that the dominant uncertainty sources (screw diameter, bone analog modulus) are bounded by material certification tolerances and do not approach the acceptance bound; and (4) N=11 constructs across two ISO 17025-accredited laboratories provides inter-laboratory confirmation. The structured operating envelope and applicability constraint explicitly bound the model's valid domain, ensuring that no extrapolation beyond the validated parameter space is implied by this acceptance.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Level 2 vs. required Level 3)",
        "description": "The Test conditions factor achieved Level 2 (single displacement rate, single temperature per ASTM F1717) against a required Level 3. This shortfall is acceptable because: (a) the operating envelope explicitly restricts the COU to 5 mm/min monotonic loading at 23 ± 2 °C, so multi-rate and multi-temperature testing would address conditions outside the declared scope; (b) all quantitative validation metrics (E/u_val, relative error) are satisfied with large margin across all three QoIs; (c) the applicability constraint prohibits use of the model outside these conditions, preventing unsafe extrapolation. The shortfall does not undermine the validity of the acceptance for the bounded COU."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
