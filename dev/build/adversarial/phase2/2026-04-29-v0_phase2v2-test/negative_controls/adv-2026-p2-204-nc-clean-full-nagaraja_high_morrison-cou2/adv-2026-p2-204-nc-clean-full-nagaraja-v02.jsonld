  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/tkr-cou1",
    "type": "ContextOfUse",
    "name": "COU1: Total knee replacement tibial insert contact stress under physiological gait loading",
    "description": "A finite-element model is used to predict peak contact stress and contact area on the tibial insert of a total knee replacement system under ISO 14243-1 gait loading conditions. Model influence is MODERATE (model supplements physical wear testing for design iteration); decision consequence is MODERATE (incorrect prediction could lead to suboptimal insert geometry but physical testing provides final safety gate). Model Risk Level 3.",
    "intendedUse": "Use FE analysis to predict peak von Mises contact stress (MPa) and contact area (mm²) on the UHMWPE tibial insert across five gait cycle phases (heel strike, mid-stance, terminal stance, pre-swing, mid-swing) at three flexion angles (0°, 30°, 60°). Results inform insert thickness and conformity design decisions prior to wear simulator testing.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/tkr-cou1/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "TKR tibial insert applicability constraint",
      "description": "Model applies only to fixed-bearing cruciate-retaining TKR tibial inserts fabricated from GUR 1050 UHMWPE with cross-linked irradiation treatment (50–100 kGy). Excludes mobile-bearing, posterior-stabilized, and unicompartmental designs. Patient population restricted to primary TKR in adults aged 55–80 with BMI ≤ 40 kg/m². Excludes revision cases, osteoporotic bone, and non-standard implant sizing outside 60–80 mm ML width range."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/tkr-cou1/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "TKR gait loading operating envelope",
      "description": "Axial compressive load: 500–3000 N (ISO 14243-1 profile). Anterior-posterior shear: ±200 N. Internal-external tibial rotation: ±10°. Flexion angle: 0°–60°. Insert thickness: 8–14 mm. Contact stress QoI range: 5–40 MPa peak von Mises. Contact area QoI range: 100–800 mm². Temperature: 37 ± 1 °C (simulated synovial fluid environment). Strain rate: quasi-static to 1 Hz cyclic. All conditions must remain within ISO 14243-1 Part 1 force-controlled boundary conditions."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/tkr-contact-stress-sa-001",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Morris screening sensitivity analysis for TKR contact stress FE model",
    "description": "A Morris elementary-effects screening was performed varying eight model inputs: UHMWPE elastic modulus (±15%), Poisson's ratio (±5%), coefficient of friction (0.04–0.12), tibial baseplate rigidity (CoCr vs Ti-6Al-4V), insert conformity radius (28–42 mm), axial load magnitude (±10% of ISO profile peak), flexion angle (±5°), and femoral component geometry tolerance (±0.1 mm). Peak contact stress exhibited highest sensitivity to insert conformity radius (normalized Morris μ* = 0.38) and UHMWPE elastic modulus (μ* = 0.29), while contact area was most sensitive to conformity radius (μ* = 0.44) and axial load magnitude (μ* = 0.31). Coefficient of friction and baseplate material showed negligible first-order effects (μ* < 0.05) and were subsequently fixed at nominal values in the uncertainty quantification propagation."
  },
