  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/tkr-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The TKR tibial insert contact stress FE model is accepted for its intended use (COU1) at MRL 3. All 13 V&V 40 credibility factors have been assessed; achieved levels meet or exceed required levels for MRL 3 Class II device in all cases. Key supporting evidence: (1) Mesh convergence GCI < 2% for both QoIs confirms discretization error is well-controlled; (2) Cadaveric and simulator validation studies demonstrate mean absolute percentage error ≤ 6.2% for peak contact stress and ≤ 5.4% for contact area, both well within the 15% acceptance threshold; (3) Sensitivity analysis identifies conformity radius and UHMWPE modulus as dominant uncertainty drivers, and Monte Carlo propagation yields 95% prediction intervals of ±3.4 MPa and ±52 mm² respectively, which are acceptable for design iteration decisions; (4) Model form selection (Ogden hyperelastic) is justified by comparative study showing 18% reduction in systematic error vs. linear elastic; (5) All SQA, use error, and provenance requirements are met with independent review and configuration management. The acknowledged gap in cadaveric specimen age range (n=5, ages 62–74) is documented in the uncertainty budget and does not affect the acceptance decision given the conservative 15% error threshold and the role of physical wear testing as the final safety gate. No factors have achievedLevel below requiredLevel; no offset rationale is required.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
