  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/tka-contact-stress-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at MRL 3. For every factor, the achieved credibility level meets or exceeds the required level: software quality assurance (achieved 3 ≥ required 2), numerical code verification (2 ≥ 2), discretization error (3 ≥ 2), test conditions (2 ≥ 2), output comparison (2 ≥ 2), relevance of QoIs (2 ≥ 2), relevance of validation activities (2 ≥ 2), numerical solver error (2 ≥ 2), use error (2 ≥ 2), model form (2 ≥ 2), model inputs (3 ≥ 2), test samples (2 ≥ 2), and equivalency of input parameters (2 ≥ 2). Validation evidence is grounded in three independent experimental datasets: cadaveric contact pressure (Fuji Prescale film, n=6 specimens, MAPE 8.3%), optical contact area bench testing (MAPE 9.7%), and UHMWPE material coupon validation (R² = 0.994). Sensitivity analysis identified axial load and femoral radius of curvature as the dominant drivers of peak contact stress, and these parameters were characterised with the highest measurement fidelity. Monte Carlo uncertainty propagation confirmed that FE prediction intervals encompass all experimental observations. The model is assessed as credible for its intended use of predicting peak tibial insert contact stress and contact area under ISO 14243-1 gait loading for design verification of the Class II TKA device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
