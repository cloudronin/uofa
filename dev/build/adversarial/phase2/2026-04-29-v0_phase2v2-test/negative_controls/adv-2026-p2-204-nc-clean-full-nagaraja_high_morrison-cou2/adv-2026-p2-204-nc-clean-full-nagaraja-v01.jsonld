    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The QoIs (peak contact stress in MPa and contact area in mm²) are directly linked to the decision criterion of UHMWPE fatigue life and wear rate estimation. Both QoIs are used in the design acceptance criterion per ASTM F2083 and internal design specification DS-TKA-003. The mapping from QoI to decision criterion is documented in the requirements traceability matrix.",
      "acceptanceCriteria": {
