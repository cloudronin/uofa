  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/tka-contact-stress-cou1",
    "type": "ContextOfUse",
    "name": "COU1: Total knee arthroplasty tibial insert contact stress under gait loading",
    "description": "A finite-element model is used to predict peak contact stress and contact area on the UHMWPE tibial insert of a total knee arthroplasty system under ISO 14243-1 gait loading profiles. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (incorrect prediction could lead to underestimation of wear risk). Model Risk Level 3.",
    "intendedUse": "Use FE simulation to predict peak contact stress (MPa) and contact area (mm²) on the tibial insert across five ISO 14243-1 gait cycle phases. Results support design verification and comparison against allowable stress thresholds for UHMWPE fatigue life estimation.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/tka-contact-stress-cou1/applicability",
      "type": "ApplicabilityConstraint",
      "name": "TKA tibial insert contact stress applicability constraint",
      "description": "Assessment applies exclusively to cruciate-retaining TKA designs with symmetric tibial insert geometry fabricated from GUR 1050 UHMWPE. Results are not transferable to posterior-stabilised designs, mobile-bearing platforms, or inserts manufactured from alternative polymer grades. Patient weight range constrained to 60–110 kg; gait speed constrained to normal walking (0.8–1.4 m/s)."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/tka-contact-stress-cou1/envelope",
      "type": "OperatingEnvelope",
      "name": "TKA FE model operating envelope",
      "description": "Axial compressive load: 500–3000 N (ISO 14243-1 gait profile). Flexion angle: 0–65 degrees. Anterior-posterior shear: ±200 N. Internal-external tibial torque: ±6 N·m. Insert thickness: 8–14 mm. Femoral component radius of curvature (sagittal): 20–35 mm. Material elastic modulus (UHMWPE): 700–1050 MPa; Poisson ratio: 0.46 ± 0.01. Coefficient of friction (metal-on-polymer contact): 0.04–0.10. Temperature: 37 °C ± 1 °C (simulated in-vivo)."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/tka-contact-stress-sa-001",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and variance-based sensitivity analysis for TKA tibial insert contact stress FE model",
    "description": "A variance-based (Sobol) sensitivity analysis was conducted across six input parameters — axial load magnitude, femoral component sagittal radius of curvature, UHMWPE elastic modulus, insert thickness, coefficient of friction, and flexion angle — using 2048 Latin-hypercube samples. Peak contact stress was most sensitive to axial load (first-order Sobol index S1 = 0.41) and femoral radius of curvature (S1 = 0.29); UHMWPE elastic modulus contributed S1 = 0.14, while friction coefficient, insert thickness, and flexion angle each contributed less than 0.08. Total-order indices confirmed negligible higher-order interaction effects. These results guided prioritisation of experimental characterisation effort toward load measurement accuracy and femoral geometry tolerancing."
  },
