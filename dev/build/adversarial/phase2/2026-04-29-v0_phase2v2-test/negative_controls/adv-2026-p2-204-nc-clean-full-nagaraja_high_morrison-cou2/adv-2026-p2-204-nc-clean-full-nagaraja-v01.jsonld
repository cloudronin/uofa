      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "A three-level mesh convergence study was performed on the tibial insert (coarse: 18,400 elements; medium: 52,100 elements; fine: 148,600 elements) using Richardson extrapolation. Grid Convergence Index (GCI) for peak contact stress between medium and fine meshes: 1.8%. The production mesh (medium) was selected as the converged mesh; GCI < 5% threshold satisfied. Achieved level 3.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/tka-disc-error-ac-03",
        "type": "AcceptanceCriteria",
        "description": "GCI between production and fine mesh < 5% for peak contact stress QoI; Richardson extrapolation applied with minimum three mesh levels spanning at least one order of magnitude in element count."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Validation experiments were conducted under controlled laboratory conditions replicating ISO 14243-1 loading profiles. Load application was via servo-hydraulic test frame calibrated to NIST-traceable standards (±1.5% load accuracy). Specimen alignment was verified with digital inclinometer (±0.2°). Temperature maintained at 37 ± 1 °C via heated bath. Test conditions documented in the experimental protocol report archived in the project repository.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/tka-test-conditions-ac-04",
        "type": "AcceptanceCriteria",
