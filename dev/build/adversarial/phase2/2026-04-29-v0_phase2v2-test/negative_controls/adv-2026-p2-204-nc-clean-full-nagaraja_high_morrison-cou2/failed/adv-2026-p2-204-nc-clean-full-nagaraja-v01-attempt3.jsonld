  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed for the tibial tray contact stress FEA model at Model Risk Level 3. Achieved credibility levels meet or exceed required levels across all factors: software quality assurance (3≥2), numerical code verification (2≥2), discretization error (3≥2), test conditions (3≥2), output comparison (3≥2), relevance of QoI (2≥2), relevance of validation activities (3≥2), numerical solver error (2≥2), use error (2≥2), model form (3≥2), model inputs (3≥2), test samples (2≥2), and equivalency of input parameters (2≥2). No credibility gaps exist. The validation evidence — comprising material coupon tests, component bench tests under ISO 14243-1 gait loading, and cadaveric kinematic validation — provides a coherent hierarchy supporting the COU. Monte Carlo uncertainty quantification confirms that the 95th-percentile prediction interval (±14%) is acceptable for the intended design acceptance decision. Sensitivity analysis identified UHMWPE modulus and insert conformity radius as dominant uncertainty sources; both have been characterised from direct measurement. The credibility assessment is complete and supports acceptance of the model for its intended use in tibial tray design acceptance for a Class II total knee replacement device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
