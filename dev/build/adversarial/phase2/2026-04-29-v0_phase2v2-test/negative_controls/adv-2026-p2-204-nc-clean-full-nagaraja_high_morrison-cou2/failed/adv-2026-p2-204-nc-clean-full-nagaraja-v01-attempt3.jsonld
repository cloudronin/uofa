  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray contact stress under gait loading (Class II TKR)",
    "description": "An FEA model predicts peak contact stress at the tibial insert–tray interface across five representative gait loading conditions for a Class II total knee replacement device. Model influence is MODERATE (model supplements bench test data for design acceptance); decision consequence is MODERATE (incorrect prediction could lead to premature wear or subsidence in a subset of patients). Model Risk Level 3.",
    "intendedUse": "Use FEA to predict peak contact stress (MPa) at the tibial insert–tray interface for five ISO 14243-1 gait cycles. Results inform dimensional acceptance criteria for the tibial tray locking mechanism and polyethylene insert thickness selection.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/applicability",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: adult primary TKR with cruciate-retaining tibial design",
      "description": "Model is applicable to adult patients (body mass 50–120 kg) receiving a primary cruciate-retaining total knee replacement using the specific tibial tray geometry and UHMWPE insert material grade assessed. Revision TKR, unicompartmental designs, and paediatric populations are explicitly out of scope. Bone quality is assumed Gruen zone 1–3 cortical support; osteoporotic bone requiring augmentation is excluded."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/envelope",
      "type": "OperatingEnvelope",
      "name": "Physiological gait loading envelope for tibial tray FEA",
      "description": "Operating envelope bounds: axial compressive load 500–3500 N (ISO 14243-1 gait profile); anterior–posterior shear 0–500 N; internal–external tibial rotation ±10°; flexion angle 0–120°; patient body mass 50–120 kg; tibial tray size range 60–75 mm mediolateral width; UHMWPE insert thickness 8–12 mm; temperature 37 ± 1 °C (simulated synovial environment). Conditions outside these bounds require separate credibility assessment."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sa/nagaraja-cou1-ortho-sa-001",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Morris screening sensitivity analysis for tibial tray contact stress FEA",
    "description": "A Morris elementary-effects screening was performed varying eight model inputs — UHMWPE elastic modulus (±15%), tibial tray cortical bone modulus (±20%), coefficient of friction at the insert–tray interface (0.04–0.12), axial load magnitude (±10%), flexion angle (±5°), cement layer thickness (0–2 mm), insert conformity radius (32–38 mm), and boundary condition fixity at the distal tibia cut — across 500 trajectories. Peak contact stress at the medial plateau was most sensitive to UHMWPE modulus (normalised Morris μ* = 0.38) and insert conformity radius (μ* = 0.31); cement layer thickness and distal fixity contributed less than 5% of total variance and were treated as secondary parameters. These findings guided targeted experimental characterisation of UHMWPE batch modulus and insert geometry tolerances, reducing the dominant uncertainty sources prior to final validation."
  },
