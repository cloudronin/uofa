  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-tka-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-orthopedic-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors were assessed. Achieved levels meet or exceed required levels at MRL 3 for all factors. Validation results demonstrate MAPE below the 15% pre-specified threshold for both peak contact stress and contact area across 8 cadaveric specimens. Monte Carlo uncertainty quantification confirms 95% prediction intervals bracket all experimental observations. Sensitivity analysis identified UHMWPE modulus and condyle radius as dominant uncertainty sources; these are well-characterized by lot-specific coupon testing and CMM measurements respectively. The model operating envelope is clearly defined and the validation domain overlaps substantially with the COU. Software quality assurance, code verification, and use error controls are all documented and independently verified. The credibility evidence is sufficient to support a 510(k) substantial equivalence claim for the Class II TKA tibial insert at MRL 3.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
