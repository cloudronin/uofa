  "signature": "ed25519:9c1e3a5b7d2f4e6a8c0b2d4f6e8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4",
  "hasSensitivityAnalysis": true,
  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-sa",
    "type": "SensitivityAnalysis",
    "name": "TKA Contact Stress Sensitivity Analysis — Material and Boundary Condition Parameters",
    "description": "A one-at-a-time and Morris screening sensitivity analysis was conducted varying UHMWPE elastic modulus (±15%), tibial tray stiffness (±10%), femoral condyle geometry (±0.5 mm radius), and gait load magnitude (±20% of ISO 14243-1 peak). Peak tibial contact stress exhibited greatest sensitivity to UHMWPE modulus (normalized sensitivity index 0.38) and condyle radius (0.29), while contact area was most sensitive to load magnitude (0.41). Results confirmed that uncertainty in material properties dominates the prediction uncertainty budget and informed the Monte Carlo input distributions used in the uncertainty quantification activity."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-tka",
    "type": "ContextOfUse",
    "name": "COU1: Tibial insert contact stress under physiological gait loading (Class II TKA)",
    "description": "A finite element model is used to predict peak contact stress and contact area on the tibial polyethylene insert of a total knee arthroplasty device under ISO 14243-1 physiological gait loading. Model influence is MODERATE (model supplements bench wear testing); decision consequence is MODERATE (incorrect prediction could result in accelerated wear but device is Class II with established predicate). Model Risk Level 3.",
    "intendedUse": "Use FE model to predict peak contact stress (MPa) and contact area (mm²) on the tibial insert across five gait cycle phases for a Class II TKA device. Results support 510(k) substantial equivalence argument relative to a cleared predicate device.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tka/applicability",
      "type": "ApplicabilityConstraint",
      "name": "TKA tibial insert applicability constraint",
      "description": "Model is applicable to fixed-bearing, cruciate-retaining total knee arthroplasty tibial inserts fabricated from GUR 1020 or GUR 1050 UHMWPE with a tibial tray modulus between 100 GPa and 210 GPa (CoCr or Ti-6Al-4V). Model is not applicable to mobile-bearing, rotating-platform, or unicompartmental knee designs, nor to inserts with calcium-stearate content above 500 ppm. Patient weight range restricted to 50–120 kg for gait load scaling."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tka/envelope",
      "type": "OperatingEnvelope",
      "name": "TKA FE model operating envelope",
      "description": "Operating envelope: axial compressive load 500–3000 N (ISO 14243-1 gait cycle); flexion angle 0°–120°; anterior-posterior tibial translation ±5 mm; internal-external rotation ±10°; UHMWPE elastic modulus 800–1100 MPa; Poisson ratio 0.46 ± 0.01; femoral condyle radius of curvature 20–35 mm (medial and lateral); tibial insert thickness 8–14 mm. Simulations outside these bounds require re-evaluation of factor adequacy."
    }
  },
