  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 3 for this Class II orthopaedic tibial tray fixation FEA. Achieved levels meet or exceed required levels across all factors: software QA (3≥2), numerical code verification (2≥2), discretization error (3≥2), test conditions (2≥2), output comparison (3≥2), QoI relevance (2≥2), validation relevance (2≥2), numerical solver error (2≥2), use error (2≥2), model form (3≥2), model inputs (3≥2), test samples (2≥2), and equivalency of input parameters (2≥2). The Monte Carlo uncertainty quantification demonstrates that the 95th-percentile predicted micromotion (138 µm) remains below the 150 µm osseointegration threshold across the full operating envelope. The Latin hypercube sensitivity analysis confirms that the dominant uncertainty drivers (trabecular modulus and friction coefficient) have been adequately characterised and propagated. The cadaveric validation study (n=8, five gait scenarios) demonstrates mean absolute error of 12.4 µm with 95% prediction interval within the ±30 µm acceptance band. Independent peer review found no critical discrepancies. The credibility evidence is sufficient to support regulatory submission for this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
