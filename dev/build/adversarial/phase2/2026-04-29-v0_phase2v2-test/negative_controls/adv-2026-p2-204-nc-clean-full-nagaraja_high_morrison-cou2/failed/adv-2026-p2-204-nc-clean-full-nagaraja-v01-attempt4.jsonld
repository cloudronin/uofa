    "type": "ContextOfUse",
    "name": "COU1: Tibial tray fixation under physiological gait loading (Class II)",
    "description": "A finite element model is used to predict interfacial micromotion at the tibial tray bone-implant interface across five representative gait loading scenarios. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (incorrect prediction could result in suboptimal implant design but clinical risk is mitigated by bench and pre-clinical data). Model Risk Level 3.",
    "intendedUse": "Use FEA to predict peak interfacial micromotion (µm) at the tibial tray periphery for five standardised gait loads. Results must demonstrate micromotion below the 150 µm osseointegration threshold across the operating envelope.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tibial/applicability",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: primary TKA tibial tray fixation in trabecular bone",
      "description": "Model is applicable only to cemented and cementless tibial trays implanted in human trabecular bone with apparent density 0.2–0.8 g/cm³. Revision arthroplasty, osteoporotic bone (density < 0.2 g/cm³), and paediatric anatomy are explicitly out of scope. Implant geometry must fall within the validated size range (size 3–7 per manufacturer sizing guide)."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-tibial/envelope",
      "type": "OperatingEnvelope",
      "name": "Physiological gait loading envelope for tibial tray FEA",
      "description": "Axial compressive force: 1.5–3.5 × body weight (750–2450 N for 70 kg reference patient). Anterior-posterior shear: 0–350 N. Internal-external tibial rotation: ±5°. Flexion angle at load application: 0°–30°. Bone apparent density: 0.2–0.8 g/cm³. Temperature: 37 °C physiological. All five gait scenarios (heel-strike, mid-stance, push-off, stair ascent, stair descent) lie within these bounds."
    }
  },
  "hasSensitivityAnalysis": true,
  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-lhs",
    "type": "SensitivityAnalysis",
    "name": "Latin hypercube sensitivity analysis — tibial tray micromotion",
    "description": "A 512-sample Latin hypercube sensitivity analysis was conducted varying cortical and trabecular elastic moduli (±20%), tibial tray-bone friction coefficient (0.3–0.7), axial load magnitude (±15%), and cement mantle thickness (0–3 mm). Sobol first-order indices identified trabecular modulus and friction coefficient as the dominant drivers of peak micromotion variance (combined 74% of total variance), while cement mantle thickness was negligible (<3%). Results informed the uncertainty quantification bounds applied in the Monte Carlo validation study."
  },
