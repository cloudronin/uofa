    "https://uofa.net/synth/data/nagaraja-cou1-ortho-strain-gauge-validation"
  ],
  "hasSensitivityAnalysis": true,
  "sensitivityAnalysisDetail": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-ortho-sa01",
    "type": "SensitivityAnalysis",
    "name": "Cement modulus and bone density sensitivity analysis for tibial tray FE model",
    "description": "A one-at-a-time sensitivity study varied cement elastic modulus (1.8–3.2 GPa, ±30% from nominal 2.5 GPa) and trabecular bone apparent density (0.15–0.55 g/cm³) across 42 model runs. Peak interface stress varied by ±11% over the cement modulus range and ±18% over the bone density range, confirming bone density as the dominant input uncertainty driver and motivating the probabilistic bone-density characterisation adopted in the uncertainty quantification activity."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho-tka",
    "type": "ContextOfUse",
    "name": "COU1: Cemented tibial tray fixation stress prediction (Class II TKA)",
    "description": "A finite-element model is used to predict peak cement-bone interface stress at the tibial tray under peak gait loading for a cemented Class II total knee arthroplasty implant. Model influence is MODERATE (FE results supplement bench testing); decision consequence is MODERATE (over-prediction of stress could lead to conservative design change). Model Risk Level 3.",
    "intendedUse": "Predict peak cement-bone interface stress within ±15% of experimentally measured strain-gauge-derived values across three cadaveric specimen geometries and two gait load magnitudes (1.5× and 2.5× body weight). Results inform fixation design acceptance.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho-tka/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: cemented TKA tibial component, adult patient population",
      "description": "The model is applicable only to cemented tibial tray configurations with polymethylmethacrylate (PMMA) bone cement, adult patients (bone density T-score > −2.5), and quasi-static gait loading. Dynamic impact, cementless fixation, and paediatric anatomy are explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho-tka/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: gait load and geometry bounds for tibial tray FE model",
      "description": "Valid operating range: axial tibial load 900–2200 N (1.5×–2.5× body weight for 60–90 kg patients); cement mantle thickness 2–5 mm; tibial plateau resection angle 0°–5° posterior slope; bone apparent density 0.15–0.55 g/cm³. Extrapolation beyond these bounds is not supported by the validation dataset."
    }
  },
