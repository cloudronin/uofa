  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at MRL 3. Achieved levels meet or exceed required levels for every factor: software quality assurance (3≥2), numerical code verification (2≥2), discretization error (3≥2), test conditions (2≥2), output comparison (3≥2), QoI relevance (2≥2), validation relevance (2≥2), numerical solver error (2≥2), use error (2≥2), model form (2≥2), model inputs (3≥2), test samples (2≥2), and equivalency of input parameters (2≥2). Validation results across both load cases demonstrate MAPE ≤ 9.7% against the ±15% acceptance band, with Monte Carlo uncertainty quantification confirming 95th-percentile prediction intervals within the acceptance band. Sensitivity analysis identified bone density as the dominant uncertainty driver, which was addressed through specimen-specific CT-derived density inputs. The provenance chain is complete from raw cadaveric data through FE simulation to validation comparison. No credibility gaps remain. The model is accepted as fit for purpose for predicting peak cement-bone interface stress in the defined COU operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
