  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray peak stress prediction under gait loading (Class II TKA)",
    "description": "An FEA model is used to predict peak von Mises stress in the tibial tray of a cemented TKA implant under ISO 14243-1 gait loading conditions. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (implant fatigue life estimate informs design iteration). Model Risk Level 3.",
    "intendedUse": "Use FEA to predict peak von Mises stress in the tibial tray across five representative gait-cycle load cases. Results must demonstrate stress margins relative to material fatigue limit with uncertainty bounds. Bench validation via strain-gauge experiments on surrogate bone composite specimens is required.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: cemented tibial tray TKA, adult patient population",
      "description": "The model is applicable only to cemented tibial tray designs in adult patients (body mass 50–120 kg, age 55–80 years). Cementless fixation, unicompartmental knee systems, and paediatric patients are explicitly excluded. Bone quality is assumed Gruen zone density ≥ 0.3 g/cm³; osteoporotic bone is out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ISO 14243-1 gait loading bounds",
      "description": "Axial compressive load: 300–2500 N (peak heel-strike); anterior-posterior shear: 0–300 N; tibial internal-external rotation: ±5°; flexion angle: 0–60°; loading frequency: 1 Hz; ambient temperature: 37 ± 1 °C (simulated in vitro). Tibial tray geometry: medial-lateral width 70–85 mm, anterior-posterior depth 45–60 mm, tray thickness 5–9 mm. Material: Ti-6Al-4V ELI (ASTM F136) with E = 114 ± 3 GPa, yield strength ≥ 795 MPa."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sa/nagaraja-cou1-ortho-sa-001",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Monte Carlo sensitivity analysis — tibial tray FEA",
    "description": "A one-at-a-time (OAT) sensitivity study varied elastic modulus (±10%), axial load magnitude (±15%), cement layer thickness (0.5–2.0 mm), and bone-implant interface friction coefficient (0.3–0.6) independently across 200 FEA runs. Peak von Mises stress showed highest sensitivity to axial load magnitude (normalised sensitivity index S = 0.62) and elastic modulus (S = 0.31); cement thickness and friction coefficient contributed S < 0.08 each. A subsequent 1000-sample Latin hypercube Monte Carlo propagation confirmed that the 95th-percentile peak stress remains 18% below the material fatigue limit, supporting the acceptance decision."
  },
