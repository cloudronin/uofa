  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 3 for a Class II orthopedic tibial tray FEA model. Achieved levels meet or exceed required levels for every factor: six factors achieved level 3 (exceeding the level 2 requirement) and seven factors achieved exactly level 2 (meeting the requirement). Validation against ISO 14243-1 gait simulator experiments demonstrates MAPE of 4.7% against a 10% threshold. GCI < 1.2% confirms discretisation error is negligible. Monte Carlo UQ with 1000 samples confirms the 95th-percentile peak stress is 18% below the Ti-6Al-4V fatigue limit. Sensitivity analysis identifies axial load as the dominant uncertainty driver (S = 0.62), informing future model refinement priorities. No credibility gaps exist; the model is fit for the stated COU and the regulatory submission may proceed.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
