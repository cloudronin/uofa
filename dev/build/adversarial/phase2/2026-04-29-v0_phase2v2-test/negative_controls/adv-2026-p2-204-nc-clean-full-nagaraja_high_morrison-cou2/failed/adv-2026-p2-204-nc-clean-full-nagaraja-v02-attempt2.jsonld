  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-tka-subsidence-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-orthopedic-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at Model Risk Level 3. Achieved levels meet or exceed required levels for every factor: six factors achieved at or above required level with no shortfall. The primary QoI (peak interface micromotion and cumulative subsidence) is directly linked to the clinical osseointegration threshold. Validation against 12 cadaveric specimens and controlled Sawbones blocks demonstrates mean absolute error of 7.6% with all predictions within ±2 SD of experimental distributions. Monte Carlo uncertainty quantification confirms the 95th-percentile predicted subsidence (98 µm) remains below the 150 µm clinical threshold with margin. Latin hypercube sensitivity analysis identifies cancellous bone modulus as the dominant uncertainty driver (61% of variance), informing the uncertainty management strategy. Software quality assurance, use error controls, and input characterization all exceed minimum requirements. The evidence package is complete, internally consistent, and sufficient to support the regulatory submission claim that the FEA model credibly predicts tibial tray subsidence within the defined COU. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
