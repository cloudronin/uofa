    "https://uofa.net/synth/data/nagaraja-cou1-bone-modulus-distribution",
    "https://uofa.net/synth/data/nagaraja-cou1-implant-geometry-cad"
  ],
  "hasSensitivityAnalysis": true,
  "hasSensitivityAnalysisDetail": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-lhs-analysis",
    "type": "SensitivityAnalysis",
    "name": "Latin Hypercube Sensitivity Analysis — Tibial Tray Subsidence Model",
    "description": "A 500-sample Latin hypercube sensitivity analysis was conducted varying cancellous bone elastic modulus (0.1–2.0 GPa, log-uniform), cortical bone modulus (10–25 GPa, uniform), bone-implant interface friction coefficient (0.3–0.8, uniform), and applied axial load magnitude (±15% of nominal 2.5 kN body-weight multiple). Sobol first-order indices revealed that cancellous bone modulus accounts for 61% of predicted subsidence variance, friction coefficient for 22%, and load magnitude for 14%; cortical modulus contributed less than 3% and was subsequently treated as deterministic in the uncertainty propagation. Peak predicted subsidence ranged from 18 to 112 µm across the ensemble, with the 95th-percentile value of 98 µm remaining below the 150 µm clinical threshold for osseointegration risk."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU1: Cementless tibial tray subsidence under physiological loading (Class II TKA)",
    "description": "A finite element model is used to predict relative micromotion and cumulative subsidence at the tibial tray–bone interface under physiological gait loading for a cementless total knee arthroplasty implant. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (subsidence exceeding threshold indicates osseointegration failure risk). Model Risk Level 3.",
    "intendedUse": "Use FEA to predict peak interface micromotion and subsidence index values across five representative gait loading scenarios. Results must demonstrate subsidence below 150 µm threshold across the 95th-percentile uncertainty envelope. Requires Monte Carlo uncertainty quantification on bone modulus and friction coefficient inputs.",
    "deviceClass": "Class II",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/nagaraja-cou1/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint — cementless TKA tibial tray domain",
      "description": "Model applicability is restricted to cementless tibial tray designs with porous titanium or hydroxyapatite-coated undersurfaces implanted in adult patients (age 50–80) with bone mineral density T-score above −2.5 (osteopenia threshold). Cemented fixation, unicompartmental knee systems, revision TKA with bone defect augmentation, and patients with metabolic bone disease are explicitly out of scope. Loading conditions are limited to level gait, stair ascent, and chair rise; high-impact activities such as running are excluded."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/nagaraja-cou1/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope — physiological loading and geometry bounds",
      "description": "Axial tibial load: 1.5–3.5 kN (1–2.5× body weight, 70 kg reference patient). Mediolateral shear: 0–350 N. Torsional moment about tibial axis: 0–8 N·m. Tibial component size range: size 3–7 (footprint 62–82 mm ML × 44–60 mm AP). Cancellous bone apparent density: 0.15–0.55 g/cm³. Interface friction coefficient: 0.3–0.8 (dry to plasma-wetted porous titanium). Gait cycle duration: 1.0–1.2 s; quasi-static analysis valid for loading rates below 0.5 kN/s. Subsidence predictions are valid only for the first 500 loading cycles (pre-osseointegration window)."
    }
  },
