  "conformsToProfile": "https://uofa.net/vocab#ProfileComplete",
  "name": "Nagaraja COU1 — Tibial Tray Subsidence Credibility Assessment (NC-4 Clean)",
  "description": "V&V 40 credibility assessment for FEA-based prediction of tibial tray subsidence in a cementless total knee arthroplasty (TKA) system under physiological loading. COU1 evaluates whether the computational model can predict relative micromotion and subsidence at the bone-implant interface for a Class II orthopedic device at Model Risk Level 3. All 13 credibility factors are assessed; achieved levels meet or exceed required levels. Monte Carlo uncertainty quantification and Latin hypercube sensitivity analysis were performed on bone modulus and interface friction coefficient. Decision: Accepted.",
  "assuranceLevel": "Moderate",
  "conformsToProfile_override_note": "NC-4 Complete-profile orthopedic pathway; base COU identity preserved below via hasContextOfUse",
  "bindsRequirement": "https://uofa.net/synth/req/nagaraja-cou1-tka-subsidence",
  "bindsClaim": "https://uofa.net/synth/claim/nagaraja-cou1-tka-subsidence-claim",
  "bindsModel": "https://uofa.net/synth/model/nagaraja-cou1-fea-tibial-tray",
