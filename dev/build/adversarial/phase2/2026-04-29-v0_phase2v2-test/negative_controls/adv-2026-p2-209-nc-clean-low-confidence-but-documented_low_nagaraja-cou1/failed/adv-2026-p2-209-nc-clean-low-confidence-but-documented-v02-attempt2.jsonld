  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw construct passes all primary V&V 40 acceptance criteria. E/uval < 1.96 for all three QoIs (stiffness: 0.21, yield force: 0.23, force at 40 mm: 0.18). Evidence confidence is explicitly assessed at approximately 50% due to limited experimental sample size (N=11) and wide material-property uncertainty (Ti-6Al-4V elastic modulus ±8 GPa, friction coefficient ±0.10). These limitations are honestly documented and fully propagated into the validation uncertainty metric; the E/uval criterion is therefore an honest representation of model adequacy under acknowledged uncertainty. The Test conditions factor achieved Gradation 1 against a Gradation 2 requirement (single loading condition tested); this shortfall is addressed by the offset rationale below. All other 12 factors meet or exceed required levels. The model is accepted for the stated COU at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/test-conditions-offset",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 1 vs. required 2)",
        "refersToFactor": "https://uofa.net/synth/factor/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 1 (single ASTM F1717 loading condition) against a Gradation 2 requirement. This shortfall is accepted for the following reasons: (1) The COU is explicitly restricted to the standard ASTM F1717 static compression-bending protocol at 5 mm/min; no extrapolation to other load rates or environmental conditions is claimed. (2) The single test condition represents the worst-case quasi-static loading scenario per ASTM F1717, which is conservative relative to in vivo loading rates. (3) The output comparison metric E/uval = 0.21 for stiffness provides substantial margin below the 1.96 threshold even with fully propagated uncertainty, indicating that additional test condition variation is unlikely to alter the acceptance decision. (4) Sensitivity analysis confirms that friction coefficient and elastic modulus — not test condition variation — are the dominant uncertainty drivers. The residual risk from the single test condition is therefore bounded and acceptable at Medium assurance level for a Class II device where bench testing confirms model predictions.",
        "description": "Test conditions factor offset: single ASTM F1717 condition accepted as sufficient given COU restriction, conservative loading scenario, large E/uval margin, and sensitivity analysis evidence."
      },
      {
        "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
