  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB centrifugal pump operating envelope — bounded flow and geometry",
      "description": "The model is applicable within the following explicit bounds: blood flow rate 1.0–7.0 L/min; pump rotational speed 1500–3500 RPM; inlet pressure 0–20 mmHg; outlet pressure 40–120 mmHg; impeller tip clearance 0.15–0.45 mm (nominal 0.30 mm ± 50%); volute gap tolerance ± 0.10 mm from nominal; blood viscosity 0.0025–0.0040 Pa·s; hematocrit 35–45%. Validation experiments sampled five operating points spanning this envelope (1.5, 2.5, 4.0, 5.5, 6.5 L/min at 2000–3200 RPM). Coverage at envelope extremes (1.0 and 7.0 L/min) relies on interpolation with acknowledged increased uncertainty; this gap is documented in the uncertainty quantification record."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis CFD applicability constraint",
      "description": "The CFD model is applicable only to the FDA generic centrifugal blood pump geometry family with impeller diameter 50–60 mm and volute scroll angle 160–200 degrees. Application to axial-flow pumps, pulsatile-flow VADs, or pump geometries outside the stated dimensional tolerances is explicitly out of scope. The hemolysis sub-model (power-law Giersiepen-Wurzinger correlation) is valid for shear stress exposures below 400 Pa·s and exposure times below 700 ms; operating conditions producing higher values require re-evaluation of model form adequacy before use."
    }
  },
