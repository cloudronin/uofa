  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) Seven credibility factors were formally assessed; all achieved levels meet or exceed required levels for MRL 2 — no shortfalls exist. (2) Six factors were scoped out with documented rationale consistent with ASME V&V 40 Table 5 MRL 2 requirements. (3) The operating envelope is explicitly bounded (flow rate 1–7 L/min, speed 1500–3500 RPM, pressure and temperature ranges, geometry tolerance ±0.15 mm) and the applicability constraint is formally documented. (4) Validation covers 4 of 5 declared operating points; the unvalidated 1 L/min / 3500 RPM corner is bounded by conservative uncertainty inflation (NIH upper bound RH = 0.87 at 95 % confidence, well below the RH < 1 acceptance criterion). (5) GCI_fine = 2.1 % confirms discretization error is controlled. (6) PIV velocity agreement ≤ 8 % RMS and NIH agreement ≤ 15 % at all tested points demonstrate adequate model fidelity within the declared envelope. (7) The coverage gap at the sparse operating point is explicitly acknowledged and does not invalidate the overall assessment because the conservative bound still satisfies the regulatory acceptance criterion. The decision to accept is grounded in the complete structured evidence chain from foundational bench data through validated CFD outputs to the regulatory decision criterion.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
