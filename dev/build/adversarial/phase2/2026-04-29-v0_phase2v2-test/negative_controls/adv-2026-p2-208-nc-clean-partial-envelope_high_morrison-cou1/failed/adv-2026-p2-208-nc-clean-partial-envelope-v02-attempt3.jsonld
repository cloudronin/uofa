  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted as credible for the declared COU at MRL 2. Seven credibility factors were assessed: all seven achieved their required Gradation levels (three at Gradation 2 as required, one at Gradation 3 exceeding the requirement). Six factors were formally scoped out at MRL 2 with documented rationale consistent with ASME V&V 40-2018 Table 3 guidance. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 1500–3500 RPM, geometry tolerances ±0.10 mm) and the applicability constraint restricts use to the FDA generic pump geometry with Newtonian rheology. Validation coverage spans five operating points within the envelope; sparse coverage at low-flow extremes is acknowledged in the uncertainty budget and does not preclude MRL 2 acceptance. The combined expanded prediction uncertainty for NIH (±12.4%, k=2) is within the pre-specified ±15% acceptance criterion at all five validation conditions. The sensitivity analysis confirms worst-case hemolysis at minimum clearance and maximum flow, which is within the validated envelope. No credibility factor shortfall exists; no offset rationale is required. The package is structurally complete with full provenance linkage from simulation outputs through validation results to the decision record.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
