  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB pump operating envelope — bounded flow and speed conditions",
      "description": "The model is applicable within the following concrete bounds: blood flow rate 1.0–7.0 L/min; impeller rotational speed 1500–3500 RPM; inlet pressure 5–20 mmHg; outlet pressure 60–120 mmHg; blood temperature 20–37 °C; hematocrit 30–45%; impeller tip clearance 0.15–0.45 mm; volute gap tolerance ±0.10 mm. All five validation operating points (2.5 L/min at 2000 RPM, 3.5 L/min at 2500 RPM, 5.0 L/min at 3000 RPM, 6.0 L/min at 3200 RPM, 7.0 L/min at 3500 RPM) fall within this envelope. Extrapolation beyond these bounds is explicitly out of scope."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis model applicability constraint",
      "description": "The credibility assessment applies exclusively to: (1) the FDA generic centrifugal blood pump geometry as defined in the reference benchmark specification; (2) Newtonian blood surrogate rheology (viscosity 0.0035 Pa·s, density 1056 kg/m³); (3) steady-state or quasi-steady flow regimes; (4) Class II CPB devices with similar hydraulic specific speed (Ns 1200–2200); (5) hemolysis evaluation via the power-law Giersiepen–Wurzinger model calibrated against the FDA dataset. Models applied to pulsatile flow, non-Newtonian rheology, or geometries outside the reference family require separate credibility assessment."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/cpb-hemolysis-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Hemolysis sensitivity to impeller clearance and flow rate",
    "description": "A one-at-a-time sensitivity study varied impeller tip clearance from 0.15 mm to 0.45 mm (three levels) and flow rate across the five nominal operating points, holding all other parameters at nominal values. The normalized hemolysis index (NIH) showed a monotonic 18% increase as clearance decreased from 0.45 mm to 0.15 mm at 5.0 L/min, confirming that minimum clearance at maximum flow rate is the worst-case condition. Flow rate sensitivity was the dominant driver (Sobol first-order index 0.61), followed by rotational speed (0.24) and clearance (0.11), providing quantitative justification for the five-condition test matrix."
  },
