    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB centrifugal pump operating envelope",
      "description": "Bounded operating envelope for the FDA generic centrifugal blood pump under CPB conditions. Flow rate: 1.0–7.0 L/min (five discrete test points: 1.5, 2.5, 3.5, 5.0, 6.5 L/min). Pump rotational speed: 1500–3500 RPM. Inlet pressure: 0–20 mmHg. Outlet pressure: 60–150 mmHg. Blood temperature: 20–37 °C. Impeller tip clearance tolerance: 0.05–0.30 mm. Volute gap tolerance: ±0.10 mm nominal. Hematocrit: 25–45%. All CFD simulations and bench validation experiments were conducted within these bounds; extrapolation beyond this envelope is not supported."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Adult CPB applicability constraint",
      "description": "The model and associated credibility evidence apply exclusively to adult patients (body surface area 1.5–2.2 m²) undergoing elective cardiopulmonary bypass with the FDA generic centrifugal pump geometry. Pediatric applications, VAD configurations, and pump geometries deviating more than 15% from the nominal FDA generic design are outside scope. The relative hemolysis index acceptance criterion (RH < 1 versus predicate device) is valid only within the declared operating envelope above."
    }
  },
