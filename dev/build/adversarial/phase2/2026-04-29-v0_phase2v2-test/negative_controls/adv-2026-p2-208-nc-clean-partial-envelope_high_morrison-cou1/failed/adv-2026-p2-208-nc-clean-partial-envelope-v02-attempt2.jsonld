  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation 2 levels for MRL 2. The operating envelope is explicitly bounded (flow 1.0–7.0 L/min, speed 1500–3500 RPM, tip clearance 0.05–0.30 mm) and all validation activities fall within this envelope. The six scoped-out factors are appropriately excluded under ASME V&V 40-2018 Table 3 for MRL 2 with documented rationale. The sparse low-flow validation coverage (single replicate at 1.5 L/min) is acknowledged as a gap but judged acceptable given the conservative NIH over-prediction bias at that operating point and the low clinical frequency of sub-2 L/min CPB flows. The relative hemolysis index acceptance criterion (RH < 1) is met with margin across all five operating points. The provenance chain is complete from raw bench measurements through uncertainty quantification to the credibility assessment. The decision to accept the model for COU1 is grounded in the structured evidence and is consistent with FDA CPB device guidance.",
    "decidedAt": "2026-04-19T00:00:00Z"
