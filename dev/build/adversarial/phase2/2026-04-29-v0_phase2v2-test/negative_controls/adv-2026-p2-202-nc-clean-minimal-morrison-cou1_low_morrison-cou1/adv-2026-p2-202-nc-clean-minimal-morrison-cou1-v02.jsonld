  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/cardiovascular-cfd-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump has been assessed against all 13 ASME V&V 40 credibility factors at Model Risk Level 2. Seven factors were formally assessed: Software Quality Assurance (achieved Gradation 2, required 1), Numerical Code Verification (achieved 2, required 1), Discretization Error (achieved 3, required 2), Test Conditions (achieved 2, required 2), Output Comparison (achieved 3, required 2), Relevance of QoI (achieved 2, required 2), and Relevance of Validation Activities to COU (achieved 2, required 2). All seven assessed factors meet or exceed their required gradation levels. Six factors (Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, Equivalency of Input Parameters) are scoped out with documented rationale appropriate to MRL 2. Quantitative validation against FDA GCBP experimental data demonstrates CFD NIH predictions within combined experimental and numerical uncertainty at all 5 operating points. Discretization error is formally bounded via GCI methodology. The evidence chain from foundational experimental data through validation activities to the credibility factor assessments is complete and traceable. The model is accepted as fit for the intended purpose of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
