  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for CPB hemolysis prediction is accepted as credible for the COU at MRL 2. All seven assessed credibility factors meet or exceed their required gradation levels: Software QA (achieved 2, required 1), Numerical Code Verification (achieved 2, required 1), Discretization Error (achieved 2, required 2), Test Conditions (achieved 2, required 2), Output Comparison (achieved 2, required 2), Relevance of QoI (achieved 3, required 2), and Relevance of Validation Activities (achieved 2, required 2). Six factors are appropriately scoped out at MRL 2 with documented rationale. Validation against FDA pump experimental data demonstrates mean absolute error of 8.3% on the primary QoI (relative hemolysis index) within combined uncertainty bounds across all 5 operating points. Mesh independence confirmed via GCI analysis (GCI_fine = 3.1%). The validation domain encompasses the full COU operating space with matched geometry and fluid properties. No shortfalls exist; no offset rationale is required. The model is fit for purpose to identify worst-case hemolysis operating conditions for regulatory submission supporting Class II CPB device tolerance decisions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
