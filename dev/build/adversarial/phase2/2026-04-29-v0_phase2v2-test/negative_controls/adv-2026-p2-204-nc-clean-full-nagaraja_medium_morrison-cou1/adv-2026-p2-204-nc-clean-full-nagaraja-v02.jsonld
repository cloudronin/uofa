  "sensitivityAnalysisDetail": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-orthopedic",
    "type": "SensitivityAnalysis",
    "name": "Tibial tray contact stress sensitivity analysis — material properties and loading boundary conditions",
    "description": "A one-at-a-time and variance-based (Sobol) sensitivity analysis was conducted varying UHMWPE elastic modulus (±15%), tibial insert thickness (±1 mm), and peak gait load magnitude (±10% of 2.5× BW). Peak von Mises stress in the insert varied by up to 18% across the modulus range, while load magnitude accounted for 62% of output variance (first-order Sobol index S1=0.62), confirming load specification is the dominant uncertainty driver and that material property uncertainty is secondary but non-negligible."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-orthopedic-tibial",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray contact stress under gait loading (Class II TKR)",
    "description": "A finite-element model is used to evaluate contact stress distribution on a UHMWPE tibial insert under physiological gait loading for a Class II total knee replacement device. Model influence is MEDIUM (bench testing confirms relative rankings); decision consequence is HIGH (incorrect worst-case identification could mask clinically relevant wear pathways). Model Risk Level 3.",
    "intendedUse": "Use FE modeling to identify worst-case contact stress operating conditions across five gait-cycle load cases for a Class II TKR tibial component. Results compared against physical coupon wear testing using normalized contact stress index (CSI < 1.15 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
