  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-orthopedic-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed at or above their required levels for Model Risk Level 3. Software quality assurance (L3), numerical code verification (L3), and discretization error (L4, exceeds requirement) establish a robust computational foundation. Experimental validation against 12 cadaveric specimens with NIST-traceable load cell calibration and ISO 14243-1 loading conditions provides high-fidelity evidence for the contact stress QOI. Peak contact stress MAPE of 4.2% and contact area MAPE of 6.8% are both well within acceptance bounds defined by experimental uncertainty. Sensitivity analysis identified UHMWPE elastic modulus as the dominant uncertainty source (SI=0.62), and this uncertainty was propagated through Monte Carlo simulation to yield conservative 95th percentile design metrics. The operating envelope is fully characterised (500–2800 N axial load, 0–120° flexion) and the applicability constraint (adult patients 50–120 kg, cemented tibial tray, ISO 14243-1 loading) is documented. No factor achievedLevel falls below requiredLevel. The credibility evidence is sufficient to support regulatory use of this FEA model for identifying worst-case contact stress conditions for the Class II total knee replacement tibial tray under the defined COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
