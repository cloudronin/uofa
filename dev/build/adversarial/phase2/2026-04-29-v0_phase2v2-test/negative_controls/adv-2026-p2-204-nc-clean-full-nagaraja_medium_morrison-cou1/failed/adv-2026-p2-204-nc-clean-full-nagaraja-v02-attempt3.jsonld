  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-tkr-wear-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-orthopedic-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the TKR tibial insert FEA wear model is accepted at Model Risk Level 3 under the ASME V&V 40-2018 Complete profile. Nine of thirteen factors are formally assessed; four are scoped out with documented justification. All nine assessed factors achieve their required credibility level: software quality assurance (achieved 3, required 3), numerical code verification (achieved 3, required 3), discretization error (achieved 4, required 3), numerical solver error (achieved 3, required 2), model form (achieved 3, required 3), model inputs (achieved 3, required 3), use error (achieved 3, required 2), test conditions (achieved 3, required 3), and output comparison (achieved 3, required 3). No factor has achievedLevel < requiredLevel; therefore no offset rationale is required. The primary validation metric W_sim/W_FEA = 1.10 ± 0.19 at 95% CI satisfies the 20% acceptance criterion. Contact stress validation error of 7.2% is within the 15% threshold. Sensitivity analysis confirms that uncertainty in the wear coefficient k is the dominant source of model output uncertainty, and this uncertainty is bounded by direct experimental characterization. The model is fit for the stated purpose of identifying worst-case wear operating conditions for a Class II TKR tibial insert under ISO 14243-1 gait loading.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
