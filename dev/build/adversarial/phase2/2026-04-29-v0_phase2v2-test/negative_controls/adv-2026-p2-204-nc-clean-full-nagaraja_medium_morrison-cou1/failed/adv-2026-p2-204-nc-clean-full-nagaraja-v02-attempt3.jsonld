  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Total knee replacement tibial insert wear under gait loading (Class II)",
    "description": "An FEA model is used to evaluate contact stress distribution and cumulative polyethylene wear in a TKR tibial insert across standardized ISO 14243-1 gait cycles. Model influence is MEDIUM (bench wear simulator testing confirms relative ranking of design variants); decision consequence is HIGH (incorrect wear prediction could lead to premature implant failure or unnecessary design conservatism). Model Risk Level 3.",
    "intendedUse": "Use FEA to predict peak contact stress and wear volume accumulation across 5 million gait cycles for a Class II TKR tibial insert. Results compared against pin-on-disc and knee wear simulator experimental data using normalized wear factor (W_sim/W_FEA ratio within 20% acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-placeholder",
      "type": "ApplicabilityConstraint",
      "name": "TKR tibial insert applicability constraint — UHMWPE on CoCr articulation, ISO 14243-1 gait",
      "description": "This model is applicable to fixed-bearing total knee replacement tibial inserts fabricated from GUR 1020 or GUR 1050 UHMWPE articulating against cobalt-chromium femoral components with surface roughness Ra ≤ 0.05 µm. The model is constrained to ISO 14243-1 force-controlled gait loading profiles and does not extend to mobile-bearing designs, cruciate-retaining configurations with posterior tibial slope > 7°, or patients with BMI > 40 where soft-tissue constraint assumptions are violated."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/envelope-placeholder",
      "type": "OperatingEnvelope",
      "name": "TKR gait loading operating envelope — ISO 14243-1 bounds",
      "description": "Operating envelope bounds: peak axial compressive force 2.5–3.0 kN (ISO 14243-1 Table 1); flexion–extension range 0°–58°; anterior–posterior displacement ±5.2 mm; internal–external rotation ±2.0°; tibial insert thickness 8–12 mm (standard range); UHMWPE yield stress 21–24 MPa; CoCr femoral component radius of curvature 30–36 mm (sagittal plane). Simulations outside these bounds require re-assessment."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-tkr-wear-sa-001",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Morris screening sensitivity analysis — TKR wear FEA model",
    "description": "A Morris elementary-effects screening study varied eight model input parameters — UHMWPE elastic modulus (±15%), yield stress (±10%), wear coefficient k (±25%), femoral component radius of curvature (±3 mm), peak axial load (±8%), flexion angle amplitude (±5°), mesh density (±40% element count), and friction coefficient (0.04–0.12) — across 500 model evaluations. Wear volume accumulation at 5 Mc was most sensitive to the wear coefficient k (µ* = 0.61) and peak axial load (µ* = 0.44), with UHMWPE yield stress ranking third (µ* = 0.29). Contact stress peak was dominated by femoral radius of curvature and mesh density. These rankings informed the prioritization of experimental characterization efforts and confirm that uncertainty in k must be bounded by direct experimental measurement rather than literature values alone."
  },
