  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-ortho-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Parametric sensitivity analysis: contact stress and wear volume response to material and loading inputs",
    "description": "A one-at-a-time and Morris screening sensitivity analysis was conducted varying UHMWPE elastic modulus (±15%), gait cycle peak axial force (±10%), tibio-femoral contact angle (±5°), and cross-shear ratio (0.02–0.18) to assess their influence on predicted volumetric wear rate and peak contact stress. Results demonstrated that cross-shear ratio and peak axial force are the dominant drivers of wear volume prediction (combined Sobol index > 0.72), while elastic modulus variation produced less than 4% change in contact stress, confirming model robustness to plausible material property uncertainty."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/nagaraja-cou1-ortho/applicability-constraint-001",
      "type": "ApplicabilityConstraint",
      "name": "TKR tibial insert applicability constraint — in-scope domain definition",
      "description": "This credibility assessment applies exclusively to fixed-bearing total knee replacement tibial inserts fabricated from GUR 1050 UHMWPE with standard gamma-inert sterilization, implanted in patients with body mass index ≤ 40 kg/m² and ambulatory gait profiles consistent with ISO 14243-1 standard loading. Devices with mobile-bearing articulation, ceramic-on-UHMWPE pairings, or patient populations with neuromuscular gait abnormalities are outside the scope of this COU."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/nagaraja-cou1-ortho/operating-envelope-001",
      "type": "OperatingEnvelope",
      "name": "Physiological gait loading envelope for TKR wear simulation",
      "description": "The operating envelope is defined by: peak axial compressive force 1800–2800 N (corresponding to 2.5–3.8× body weight for 70–80 kg patients); anterior-posterior shear force 150–350 N; internal-external tibial rotation ±5°; flexion-extension range 0–60°; gait cycle frequency 0.9–1.1 Hz; and 1×10⁶ to 5×10⁶ simulated gait cycles. Material contact conditions assume a CoCr femoral component surface roughness Ra ≤ 0.05 µm and tibial insert thickness 8–12 mm. Simulations outside these bounds require re-evaluation of model applicability."
    }
  },
