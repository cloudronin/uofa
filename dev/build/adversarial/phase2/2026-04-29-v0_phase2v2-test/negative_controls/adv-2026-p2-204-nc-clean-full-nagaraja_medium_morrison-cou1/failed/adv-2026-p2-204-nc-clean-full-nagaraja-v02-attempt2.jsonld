  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the TKR tibial insert wear simulation COU1 is accepted at Model Risk Level 3. All 13 ASME V&V 40 credibility factors have been assessed; no factors are scoped out or not applicable. All achieved levels meet or exceed required levels: discretization error (achieved 4, required 3), numerical solver error (achieved 3, required 2), equivalency of input parameters (achieved 3, required 2) demonstrate margin above requirements. Primary QoI validation results show normalized RMSE of 6.2% for volumetric wear rate and 4.8% for peak contact stress, both well within the 15% acceptance threshold. TOST equivalence testing passed for both QoIs. Sensitivity analysis confirms cross-shear ratio and peak axial force as dominant uncertainty drivers, and the model is robust to plausible material property variation. The provenance chain is complete from foundational experimental data through validation activities to this assessment. The computational model is credible for its intended use of identifying worst-case wear conditions for the Class II TKR device under the defined operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
