  "name": "Morrison COU2 — VAD hemolysis credibility assessment (NC-8 clean)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. The operating envelope is explicitly bounded (flow rate 1–7 L/min, rotational speed 2000–6000 RPM, hematocrit 35–45%, fluid temperature 36–38 °C, inlet pressure 5–15 mmHg) and the applicability constraint restricts use to centrifugal continuous-flow blood pumps of comparable specific speed (Ns 1000–2500). Validation activities span six operating points within this envelope; sparse coverage at envelope boundaries is honestly documented. All 13 credibility factors are assessed; achievedLevel meets or exceeds requiredLevel for all factors. Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-predicts-hemolysis-below-clinical-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset",
    "https://uofa.net/synth/data/hemolysis-bench-6pt-dataset",
    "https://uofa.net/synth/data/monte-carlo-uq-hemolysis-results"
  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD CFD operating envelope — bounded parameter ranges",
      "description": "The model is applicable within the following explicitly bounded parameter ranges: volumetric flow rate 1–7 L/min (±0.05 L/min measurement uncertainty); rotational speed 2000–6000 RPM (±10 RPM); inlet hematocrit 35–45% (±1%); blood analogue fluid temperature 36–38 °C (±0.2 °C); inlet gauge pressure 5–15 mmHg (±0.5 mmHg); impeller tip clearance 150–250 µm (±10 µm geometric tolerance). Six validation operating points are distributed within this envelope; coverage near the 1 L/min and 7 L/min flow boundaries is sparse and is explicitly noted as a coverage gap in the validation activity rationale."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint — centrifugal continuous-flow VAD pumps",
      "description": "Results and credibility assessment apply exclusively to centrifugal continuous-flow blood pumps with specific speed Ns in the range 1000–2500 (dimensionless, SI), impeller diameter 30–55 mm, and volute hydraulic diameter 8–18 mm. Axial-flow pumps, pulsatile-displacement pumps, and pumps operating outside the stated geometric or speed envelope are explicitly out of scope. The constraint further limits applicability to Newtonian blood-analogue fluids (glycerol-water, 36–40% v/v) as used in the validation bench experiments; non-Newtonian whole-blood rheology models require separate validation."
    }
  },
