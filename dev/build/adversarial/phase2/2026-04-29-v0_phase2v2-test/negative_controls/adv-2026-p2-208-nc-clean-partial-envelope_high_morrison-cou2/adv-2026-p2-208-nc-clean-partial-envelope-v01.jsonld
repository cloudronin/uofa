  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed; achievedLevel meets or exceeds requiredLevel for every factor. The operating envelope is explicitly bounded with concrete parameter ranges (flow rate 1–7 L/min, speed 2000–6000 RPM, hematocrit 35–45%, temperature 36–38 °C, inlet pressure 5–15 mmHg, tip clearance 150–250 µm) and the applicability constraint restricts use to centrifugal continuous-flow pumps of comparable specific speed (Ns 1000–2500). Sparse validation coverage at envelope boundaries (1 L/min, 7 L/min) is explicitly documented and reflected in wider uncertainty bands at those points; this honest reporting does not undermine acceptance because the clinical hemolysis threshold is not approached even at the upper uncertainty bound. Monte Carlo UQ with 2000 Latin hypercube samples confirms that NIH predictions remain below the clinical threshold at the 95th percentile across the declared envelope. Global sensitivity analysis identifies rotational speed and hemolysis model exponent α as dominant variance sources; targeted high-shear validation at 6000 RPM reduces model form uncertainty at the upper boundary. The provenance chain from raw PIV and bench data through comparison activities to this UofA is complete. No credibility gaps remain that would preclude regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
