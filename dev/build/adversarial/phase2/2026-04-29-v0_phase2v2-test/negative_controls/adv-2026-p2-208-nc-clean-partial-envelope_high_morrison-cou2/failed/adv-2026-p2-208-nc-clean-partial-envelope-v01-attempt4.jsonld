    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD CFD operating envelope — bounded flow and speed domain",
      "description": "Flow rate: 1–7 L/min (nominal clinical range for VAD support). Rotational speed: 2000–6000 RPM (manufacturer-specified operating band). Inlet static pressure: 5–20 mmHg (physiological preload range). Hematocrit: 35–45% (normocythemic VAD patient population). Blood temperature: 37 ± 1 °C. Pump geometry tolerance: impeller diameter 50 ± 0.05 mm, blade angle ± 0.5°. Fluid viscosity derived from Quemada model within the hematocrit bounds. Model applicability is restricted to steady-state operating points within these bounds; transient ramp conditions and hematocrit outside 35–45% are explicitly excluded."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD CFD applicability constraint — in-scope domain",
      "description": "The CFD model is applicable only to the FDA generic centrifugal pump geometry as specified in the 2021 benchmark dataset. Application is restricted to steady-state, single-phase, incompressible flow within the operating envelope bounds. The model is not applicable to pulsatile drive conditions, cavitation regimes (inlet pressure below 5 mmHg), or patient populations with hematocrit outside 35–45%. Geometric modifications exceeding the stated tolerance band require re-verification."
    }
  },
