  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nc8-vad-cou2-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed with achieved levels meeting or exceeding required levels. The operating envelope is explicitly bounded (flow rate 1–7 L/min, speed 2000–6000 RPM, inlet pressure 5–20 mmHg, hematocrit 35–45%, temperature 37±1°C) and applicability constraints are formally documented. Validation activities cover 3 operating points within the declared envelope; sparse coverage at envelope corners is acknowledged and addressed through uncertainty inflation in the Monte Carlo UQ. Model form uncertainty is quantified across four alternative hemolysis formulations. The dominant input sensitivity (hemolysis coefficient C, Sobol index 0.61) is characterised and propagated. Discretization error (GCI < 4.2% for NIH) and solver convergence (≥5 orders residual drop) are within acceptance thresholds. Software quality assurance and use error controls are documented and peer-reviewed. The structured evidence chain — from foundational PIV and bench datasets through UQ to credibility factor assessments — supports acceptance of the CFD model for predicting absolute hemolysis index within the declared operating envelope for this Class III VAD device at MRL 5.",
