  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/sobol-hemolysis-vad",
    "type": "SensitivityAnalysis",
    "name": "Sobol first- and total-order sensitivity analysis on NIH predictions",
    "description": "Sobol indices computed over inlet velocity (±3 %), fluid viscosity (±5 %), blade tip clearance (±0.05 mm), and rotational speed (±10 RPM). Blade tip clearance dominates NIH variance (S1 = 0.58, ST = 0.63); inlet velocity is secondary (S1 = 0.22). Rotational speed and viscosity contribute less than 10 % combined. Results confirm that tighter manufacturing tolerance on blade clearance is the highest-leverage uncertainty reduction lever for this COU."
  },
