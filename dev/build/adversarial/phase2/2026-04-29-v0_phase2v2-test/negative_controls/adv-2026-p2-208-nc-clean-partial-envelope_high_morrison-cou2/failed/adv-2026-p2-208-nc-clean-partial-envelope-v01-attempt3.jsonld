  "name": "Morrison COU2 — VAD hemolysis credibility assessment (NC-8 clean)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. The operating envelope is explicitly bounded (flow rate 1–7 L/min, rotational speed 2000–6000 RPM, fluid temperature 36–38 °C, hematocrit 35–45 %) and the applicability constraint restricts use to Newtonian blood-analogue fluids in the FDA benchmark geometry. Validation samples are sparse at the envelope extremes but coverage gaps are honestly documented. Decision: Accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-below-clinical-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-benchmark-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/mc-uncertainty-hemolysis-samples"
  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD CFD operating envelope — bounded flow and speed range",
      "description": "The model is valid within the following bounds: volumetric flow rate 1–7 L/min (±0.05 L/min measurement uncertainty); rotational speed 2000–6000 RPM (±10 RPM); blood-analogue fluid temperature 36–38 °C; hematocrit 35–45 %; inlet pressure 5–20 mmHg. Pump geometry conforms to FDA benchmark centrifugal pump dimensions with manufacturing tolerance ±0.05 mm on blade clearance. Validation experiments sampled 5 operating points within this envelope; coverage at the 1 L/min and 7 L/min extremes is limited to a single experimental replicate each, and this gap is acknowledged in the uncertainty quantification."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability restricted to FDA benchmark geometry and Newtonian blood analogue",
      "description": "Model applicability is restricted to: (1) the FDA generic centrifugal pump benchmark geometry as published in Stewart et al. 2012; (2) Newtonian blood-analogue fluids (glycerol-water, viscosity 3.5 ± 0.2 mPa·s at 37 °C); (3) steady-state or quasi-steady operating regimes (no pulsatile waveforms); (4) single-phase flow (no cavitation). Use outside these constraints requires re-validation. Non-Newtonian whole-blood rheology and patient-specific pump geometries are explicitly out of scope."
    }
  },
