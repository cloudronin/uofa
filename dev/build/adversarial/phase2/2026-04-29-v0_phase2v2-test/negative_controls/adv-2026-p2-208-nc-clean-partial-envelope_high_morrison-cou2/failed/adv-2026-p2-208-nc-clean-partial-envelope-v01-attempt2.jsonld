  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed; achieved levels meet or exceed required levels at MRL 5. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 2000–5000 RPM, hematocrit 35–45%, temperature 36–38 °C, inlet pressure 5–15 mmHg) and the model's applicability is formally constrained to this domain. Validation covers 12 of 35 envelope cells; coverage gaps are acknowledged and bounded by Kriging interpolation uncertainty (worst-case upper bound NIH remains below clinical threshold at 97.3% probability). Monte Carlo UQ (5000 samples) demonstrates that the 95th-percentile NIH prediction interval upper bound is 0.0089 g/100 L, well below the clinical threshold of 0.1 g/100 L. Dominant uncertainty contributor (hemolysis power-law exponent, 61% of variance) has been characterized from literature meta-analysis. Model form uncertainty quantified across three sub-models; selected model shows lowest systematic bias (+4.2%). The combination of bounded applicability, documented coverage gaps with quantified interpolation uncertainty, and Monte Carlo UQ provides sufficient credibility for the intended regulatory decision at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
