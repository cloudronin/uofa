    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "decisionConsequence": "High",
    "modelInfluence": "High",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/envelope",
      "type": "OperatingEnvelope",
      "name": "VAD hemolysis CFD operating envelope — bounded applicability",
      "description": "Explicit bounds: volumetric flow rate 2–6 L/min; impeller rotational speed 2000–3500 RPM; inlet hematocrit 35–45%; inlet gauge pressure 5–15 mmHg; blood temperature 36–38 °C; pump geometry tolerance ±0.05 mm on blade tip clearance. All five validation operating points (2 L/min/2500 RPM, 3 L/min/2800 RPM, 4 L/min/3000 RPM, 5 L/min/3200 RPM, 6 L/min/3500 RPM) lie within these bounds. Extrapolation beyond these limits is explicitly out of scope."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis model applicability constraint",
      "description": "Model applicability is restricted to: (1) the FDA generic centrifugal pump geometry as specified in the 2012 FDA benchmark study; (2) Newtonian blood surrogate with viscosity 0.0035 Pa·s; (3) steady-state or quasi-steady operating points only — pulsatile waveforms are out of scope; (4) single-phase flow (no cavitation). Use outside these constraints requires a separate COU assessment."
    }
  },
