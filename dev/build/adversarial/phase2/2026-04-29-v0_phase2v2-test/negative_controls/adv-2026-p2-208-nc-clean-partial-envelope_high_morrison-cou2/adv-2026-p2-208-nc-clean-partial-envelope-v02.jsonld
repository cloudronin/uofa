  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed. All factors achieved levels meeting or exceeding required levels for MRL 5. The operating envelope is explicitly bounded (flow 2–6 L/min, speed 2000–3500 RPM, hematocrit 35–45%, inlet pressure 5–15 mmHg) and all validation activities were conducted within these bounds. Sparse validation coverage (5 operating points) is acknowledged and the applicability constraint explicitly limits use to interpolation within the sampled domain. Monte Carlo UQ (500 samples) demonstrates that prediction intervals for NIH remain below the clinical threshold with 95% confidence at all five operating points. Model-form uncertainty (±8–22% for NIH) is consistent with literature and does not alter the accept/reject decision relative to the clinical threshold. Independent peer review confirmed no use errors. The combination of bounded applicability, honest coverage-gap documentation, complete provenance, and all credibility factors at or above required levels supports acceptance of the model for the declared COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
