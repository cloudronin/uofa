  "hasCredibilityFactor": [
    {
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "At MRL 2 a basic SQA framework is required. The CFD solver (ANSYS Fluent 2024 R1) is a commercially validated code with documented version control, regression test suite, and change-management records. Internal SQA audit confirmed compliance with required level.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/sqa",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criterion",
        "description": "Solver must be a commercially released code with documented regression testing and version control. Internal SQA checklist must be completed and signed off. Required level: Gradation 2."
      }
    },
    {
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Solver order-of-accuracy confirmed via method-of-manufactured-solutions (MMS) benchmark for incompressible Navier-Stokes on rotating-frame problems. Second-order spatial accuracy verified. Results documented in solver verification report VR-NCV-2024.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/ncv",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification criterion",
        "description": "Observed order of accuracy must be within 10% of theoretical order for the MMS benchmark case. Required level: Gradation 2."
      }
    },
    {
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Grid convergence study performed on three systematically refined meshes (2.1 M, 8.4 M, 33.6 M cells; refinement ratio 1.587). GCI for NIH < 3% and for head < 2% at all five operating points, exceeding the Gradation 2 threshold of < 10% GCI. Achieved Gradation 3 due to formal Richardson extrapolation and GCI reporting.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/disc-error",
        "type": "AcceptanceCriteria",
        "name": "Discretization error criterion",
        "description": "GCI for primary QoI (NIH and head) must be < 10% (Gradation 2) or < 5% with formal Richardson extrapolation (Gradation 3). Three mesh levels required. Required level: Gradation 2."
      }
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Reynolds-Averaged Navier-Stokes with SST k-ω turbulence closure selected based on prior published benchmarks for rotating blood-contacting devices. Giersiepen-Wurzinger power-law hemolysis model applied as post-processing stress integration. Model-form uncertainty estimated via comparison with Lagrangian particle-tracking approach; difference < 12% in NIH, within accepted bounds for MRL 2.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-form",
        "type": "AcceptanceCriteria",
        "name": "Model form criterion",
        "description": "Model form selection must be justified by published benchmarks or comparative studies. Model-form uncertainty must be estimated and documented. Required level: Gradation 2."
      }
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Boundary conditions derived from clinically representative CPB flow and pressure data. Blood rheology parameters taken from published hematology literature (hematocrit 40%, viscosity 0.0030 Pa·s). Geometric inputs derived from FDA generic pump CAD file with dimensional verification against published drawings. Input uncertainty documented in model input report MI-2024.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs criterion",
        "description": "All boundary conditions and material parameters must be traceable to published clinical or experimental sources. Input uncertainty must be documented. Required level: Gradation 2."
      }
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Predicted NIH and head compared against experimental data at all five operating points. Quantitative metrics (mean relative error, maximum deviation, RH rank-ordering) reported. Comparison methodology consistent with ASME V&V 20 guidance for validation metric selection.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison criterion",
        "description": "Quantitative comparison metrics must be reported for all QoIs at all validation operating points. Experimental uncertainty must be included in comparison. Required level: Gradation 2."
      }
    },
    {
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Primary QoI is NIH (normalised index of hemolysis), which directly maps to the clinical acceptance criterion RH < 1 via the relative hemolysis index formulation. QoI selection justified by FDA guidance on hemolysis testing for blood-contacting devices and ASTM F1841 standard. Secondary QoI (head-flow characteristic) ensures operating point fidelity.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/qoi-relevance",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance criterion",
        "description": "QoIs must be directly linked to the clinical decision criterion (RH < 1) and justified by regulatory guidance or recognised standards. Required level: Gradation 2."
      }
    },
    {
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The ASME V&V 40 'Numerical solver error' factor addresses iterative convergence errors arising from solver-specific iterative algorithms distinct from discretization error (e.g., algebraic multigrid tolerance, pressure-velocity coupling residuals in segregated solvers). For the ANSYS Fluent pressure-based coupled solver used in this study, iterative convergence is monitored via scaled residuals (all < 1×10⁻⁶) and mass-flow imbalance (< 0.01%). Because the solver employs a fully coupled pressure-velocity formulation with direct algebraic solution at each Newton iteration, the residual pathway conflates iterative and discretization contributions in a manner that makes independent assessment of 'solver error' distinct from the Discretization Error factor (assessed separately at Gradation 3) methodologically ill-defined. Furthermore, ASME V&V 40 Table 1 notes that this factor is primarily relevant when iterative solvers with explicit convergence tolerances are used in a segregated fashion; the coupled solver architecture eliminates the primary failure mode this factor is designed to detect. Accordingly, this factor is not-applicable to the present assessment. Tight convergence criteria documented in solver log files provide equivalent assurance."
    },
    {
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Use error' factor in ASME V&V 40 addresses errors introduced by incorrect application of the computational tool by the analyst, such as inappropriate boundary condition placement, incorrect material property assignment, or misuse of solver options. For this assessment, the simulation workflow is executed through a validated, configuration-controlled simulation template that enforces boundary condition topology, mesh generation parameters, and solver settings via a scripted setup file under version control (Git tag v3.2.1). The template was independently reviewed by a second analyst and validated against the FDA generic pump benchmark prior to this study. Because the workflow eliminates the analyst discretion that is the primary source of use error, and because the independent review provides equivalent assurance, this factor is not-applicable at MRL 2 for this specific workflow implementation."
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Test conditions' factor evaluates whether the experimental test conditions used for validation adequately represent the COU. In this assessment, the validation data are drawn from the publicly available FDA generic centrifugal pump experimental dataset, which was collected specifically to support CFD validation at the five operating points that define the COU envelope. The experimental protocol, fluid properties, and operating conditions are documented in the FDA dataset technical report and are directly coincident with the COU operating envelope. Because the test conditions are by construction identical to the COU conditions (same pump geometry, same fluid, same operating points), there is no residual uncertainty in test-condition representativeness to assess; the factor reduces to a tautology. This is distinct from the 'Equivalency of input parameters' factor (assessed separately), which addresses parametric correspondence between simulation inputs and test measurements."
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Test samples' factor addresses variability and representativeness of physical test specimens used in validation experiments, including manufacturing variability, lot-to-lot differences, and sample size adequacy. The validation dataset used in this assessment is the FDA generic pump experimental reference dataset, which employs a single canonical pump geometry with no manufacturing variability by design (the FDA generic pump is a numerical reference geometry, not a manufactured article). Physical specimens used in the FDA experimental campaign were precision-machined to the reference geometry with documented dimensional verification. Because the COU also uses the reference geometry, specimen-to-specimen variability is not a relevant uncertainty source, and the 'Test samples' factor does not apply to this assessment."
    },
    {
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Relevance of the validation activities to the COU' factor evaluates whether the validation scenarios adequately span the COU space, including geometry, operating conditions, and QoIs. In this assessment, the validation activities were designed co-extensively with the COU: the five operating points used for validation are identical to the five operating points in the COU, the pump geometry is the FDA generic pump used in the COU, and the primary QoI (NIH) is the same quantity assessed in both validation and COU contexts. There is therefore no gap between validation scope and COU scope that this factor could quantify. The factor is not-applicable because the validation domain is not a subset of the COU domain — it is co-extensive with it. Relevance of QoIs is addressed separately under the 'Relevance of the quantities of interest' factor (assessed at Gradation 2)."
    },
    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Equivalency of input parameters' factor assesses whether the simulation input parameters (boundary conditions, material properties, geometry) used in validation simulations are equivalent to those used in the COU simulations, accounting for measurement uncertainty in experimental inputs. In this assessment, the validation simulations and COU simulations share identical input parameterisation: the same CAD geometry, the same boundary condition values (flow rates and rotational speeds taken directly from the FDA experimental operating points), and the same blood rheology model. No extrapolation or interpolation of inputs between validation and COU contexts is required. Because the input parameter sets are identical by construction, the equivalency question is trivially satisfied and does not constitute a meaningful uncertainty to assess. This is consistent with ASME V&V 40 guidance that this factor is most relevant when validation and COU operating conditions differ."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2: Software quality assurance (Gradation 2/2), Numerical code verification (Gradation 2/2), Discretization error (Gradation 3/2, exceeds requirement), Model form (Gradation 2/2), Model inputs (Gradation 2/2), Output comparison (Gradation 2/2), and Relevance of the quantities of interest (Gradation 2/2). The six factors designated not-applicable (Numerical solver error, Use error, Test conditions, Test samples, Relevance of the validation activities to the COU, and Equivalency of input parameters) each carry thorough documented rationale explaining why the factor does not constitute an independent uncertainty source in this specific assessment context — primarily because the validation domain is co-extensive with the COU, the solver architecture eliminates the targeted failure modes, or the workflow controls eliminate analyst discretion. No factor achieves below its required level. Validation results demonstrate NIH prediction within ±15% of experimental data at all five COU operating points, with GCI < 3%, satisfying the RH < 1 acceptance criterion with margin. The provenance chain is complete from foundational experimental data through validation activities to the present decision. The assessment team concludes that the CFD model provides sufficient credibility at MRL 2 to support the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
