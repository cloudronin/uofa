  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The operating envelope is explicitly bounded (flow rate 1–7 L/min, speed 1500–3500 RPM, tip clearance 0.10–0.35 mm) and validation activities cover the boundary points of this envelope. Discretization error exceeds the required Gradation 2 (GCI < 2.1% velocity, < 4.8% NIH). Output comparison confirms NIH predictions within 18% of bench measurements with correct rank ordering across all operating conditions. Six scoped-out factors are appropriate and documented for MRL 2. The structured operating envelope and applicability constraint confirm the model is not applied outside its validated domain. The RH < 1 acceptance criterion is met for the worst-case operating condition identified by the model. The credibility evidence is sufficient to support the regulatory decision for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
