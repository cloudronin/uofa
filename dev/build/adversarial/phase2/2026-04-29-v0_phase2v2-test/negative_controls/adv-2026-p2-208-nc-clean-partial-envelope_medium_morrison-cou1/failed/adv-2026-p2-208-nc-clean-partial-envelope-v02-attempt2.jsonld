    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB pump operating envelope — bounded flow and geometry",
      "description": "Flow rate: 1.0–7.0 L/min (five discrete set-points: 1, 2, 4, 6, 7 L/min). Impeller rotational speed: 1500–3500 RPM. Inlet pressure: 5–25 mmHg. Outlet pressure: 60–300 mmHg. Blood viscosity: 0.0025–0.0040 Pa·s (hematocrit 30–45%). Impeller tip clearance: 0.10–0.35 mm (nominal ±0.05 mm manufacturing tolerance). Volute throat area: ±8% of nominal 94 mm². All CFD simulations and bench validation tests were conducted at boundary points and interior set-points within this envelope."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis model applicability constraint",
      "description": "Model applicability is restricted to the FDA generic centrifugal blood pump geometry family (volute-type, single-stage, open impeller) operated within the declared operating envelope above. The model is NOT applicable to axial-flow pumps, pulsatile assist devices, or operating conditions outside the bounded flow-rate and speed ranges. Blood analog fluid (glycerin-water) validation data are used only for velocity-field verification; hemolysis predictions are validated against porcine blood bench data within the stated hematocrit range."
    }
  },
