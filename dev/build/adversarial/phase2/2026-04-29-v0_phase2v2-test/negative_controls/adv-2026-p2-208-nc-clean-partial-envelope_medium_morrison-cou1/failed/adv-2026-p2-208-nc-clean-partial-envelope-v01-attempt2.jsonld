  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. Discretization error (GCI_fine < 2.3 %) and software QA exceed minimum requirements. The operating envelope is explicitly bounded (1–7 L/min, 1500–3500 RPM) and validation experiments cover both boundary points and three interior operating conditions, confirming model fidelity across the full declared range. NIH predictions are within ±15 % of experimental means at all 5 validation points; the RH < 1 acceptance criterion is satisfied. Six factors are appropriately scoped out at MRL 2 with documented rationale. The provenance chain is complete from raw experimental data through validation results to this decision. No weakeners were identified. The CFD model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device within the declared envelope.",
