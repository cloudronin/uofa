  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB pump operating envelope — bounded flow and speed range",
      "description": "The model is applicable within the following bounds: volumetric flow rate 1.0–7.0 L/min; impeller rotational speed 1500–3500 RPM; blood temperature 35–38 °C; hematocrit 30–45 %; inlet pressure 0–20 mmHg gauge. Geometry tolerances for impeller blade clearance are ±0.05 mm from nominal. Validation experiments and boundary-point simulations were conducted at the envelope corners (1.0 L/min / 1500 RPM and 7.0 L/min / 3500 RPM) and at three interior operating points, confirming model fidelity across the full declared range."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB applicability constraint — Class II adult CPB devices",
      "description": "This credibility assessment applies exclusively to adult Class II centrifugal blood pumps used in cardiopulmonary bypass with geometries conforming to the FDA generic pump benchmark. Pediatric devices, axial-flow pumps, ventricular assist devices, and operating conditions outside the declared envelope (flow < 1 L/min or > 7 L/min; speed < 1500 or > 3500 RPM) are explicitly out of scope. Non-Newtonian blood rheology models other than the Carreau–Yasuda formulation used herein are not covered."
    }
  },
