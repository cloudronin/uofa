  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model (COU1, MRL 2) is NOT ACCEPTED at this time. Although 7 of 13 credibility factors have been formally assessed and all assessed factors meet or exceed their required gradation levels, the assessment team has identified two substantive concerns that preclude acceptance: (1) The validation evidence base is insufficient for the intended regulatory submission context. While the Output Comparison factor achieves the required Gradation 2, the mean normalised error of 14.2% is at the margin of the 15% acceptance criterion, and one of the five validation operating points falls outside the uncertainty interval. For a Class II CPB device where incorrect hemolysis prediction could directly impact patient safety, the assessment team judges that a margin closer to 10% is needed before the model can be relied upon for worst-case identification. (2) The three scoped-out factors (Numerical Solver Error, Test Samples, Equivalency of Input Parameters) were excluded based on MRL 2 provisions, but the documented rationale for scoping out Test Samples is insufficiently detailed to demonstrate that sample-to-sample pump geometry variability does not influence the hemolysis prediction at the tolerance limits being evaluated. The assessment team requires either a supplementary geometry sensitivity study or an explicit demonstration that CMM measurement uncertainty bounds the relevant geometric variation before these scoping decisions can be accepted. The assessment team recommends: (a) conducting additional validation experiments at the marginal operating point to reduce normalised error below 10%; (b) providing a documented geometry sensitivity study quantifying the influence of dimensional tolerances on hemolysis index; and (c) resubmitting for re-assessment once both items are addressed. No offset rationale is claimed; the rejection is the appropriate response to the documented evidence gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
