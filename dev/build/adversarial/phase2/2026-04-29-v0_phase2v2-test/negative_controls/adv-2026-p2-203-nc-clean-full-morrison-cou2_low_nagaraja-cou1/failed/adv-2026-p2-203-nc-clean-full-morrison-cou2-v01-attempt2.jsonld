  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as sufficiently credible for the stated COU at MRL 5. Twelve of thirteen credibility factors meet or exceed their required gradation levels. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) achieve relative errors of 4.7–7.1% against pooled experimental data from N=11 constructs across two independent laboratories, all within the pre-specified 10% acceptance bound. ASME V&V 20 validation metrics E/uval range from 1.26 to 1.63, all below the 1.96 threshold at 95% confidence. The single shortfall — Test conditions achieving Gradation 3 against a required Gradation 4 — is offset by the convergence of multiple compensating strengths: (1) ASTM F1717 compression-bending is the primary and most conservative regulatory loading mode for this device class; (2) global sensitivity analysis confirms that loading mode variation contributes < 8% of total QoI variance compared to material and geometric inputs that are fully characterized; (3) the model form has been independently validated for torsion loading in a companion study (Nagaraja et al. 2018), providing indirect evidence of generalizability. The offset rationale is formally documented below. Overall credibility is sufficient for a Medium-consequence, Medium-influence regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-offset-test-conditions",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 3 vs. required 4)",
        "shortfallFactor": "Test conditions",
        "shortfallDescription": "Test conditions factor achieves Gradation 3 (single loading configuration: compression-bending only) against a required Gradation 4 (two or more independent loading configurations).",
        "offsetJustification": "The shortfall is accepted on three grounds: (1) ASTM F1717 compression-bending is the sole loading mode specified by FDA guidance for non-cannulated pedicle screw design acceptance; testing additional modes (torsion, tension-bending) is not required for this regulatory decision. (2) Sobol sensitivity analysis (N=4096) demonstrates that loading mode uncertainty contributes < 8% of total QoI variance; dominant uncertainty sources (material properties, preload) are fully characterized at Gradation 5. (3) A companion validation study (Nagaraja et al., J Biomech Eng 2018, DOI:10.1115/1.4040539) validated the same FEA framework under torsional loading with E/uval < 1.8, providing indirect evidence that the model form generalizes across loading modes. The residual risk from the single-condition limitation is judged acceptable for a Medium-consequence decision where physical testing remains the primary regulatory evidence and FEA serves a confirmatory role."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
