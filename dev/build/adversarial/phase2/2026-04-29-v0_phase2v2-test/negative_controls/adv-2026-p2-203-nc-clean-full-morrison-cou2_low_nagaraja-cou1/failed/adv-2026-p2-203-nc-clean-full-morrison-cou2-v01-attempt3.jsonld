  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/spinelab-fda",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required level. One factor (Test conditions, requiredLevel=4, achievedLevel=3) falls below required level due to single test condition. An OffsetRationale is provided: the single test condition matches exactly the regulatory submission condition; the sensitivity analysis demonstrates that crosshead rate and temperature are low-sensitivity inputs (S_T < 0.05 each); and the E/uval values across all three QoIs are well below the 1.96 threshold, providing quantitative evidence that the model is predictive within the tested condition. The overall evidence base — specimen-specific material characterization, CMM-verified geometry, pre-registered analysis plan, multi-QoI quantitative comparison, and comprehensive uncertainty budget — supports model credibility at MRL-5 for the stated COU. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "The Test conditions factor achieved level 3 against a required level 4 because only a single crosshead displacement rate (25 mm/min) and single ambient temperature (22 °C) were evaluated. This shortfall is offset by three compensating lines of evidence: (1) global sensitivity analysis (N=8192 Sobol samples) demonstrates that crosshead rate and temperature together contribute less than 5% of total output variance for all three QoIs, confirming that the unsampled conditions would not materially alter model predictions; (2) the single tested condition is precisely the regulatory submission condition specified in the 510(k) protocol, so the validation directly supports the intended regulatory decision without requiring extrapolation; and (3) all three QoI comparisons yield E/uval values (0.94, 1.12, 1.31) substantially below the 1.96 threshold, providing quantitative confidence that model error is within combined uncertainty bounds at the tested condition. The residual risk from the single-condition limitation is therefore judged acceptable for the stated COU.",
        "shortfallFactor": "Test conditions",
        "requiredLevel": 4,
        "achievedLevel": 3
      },
      {
        "id": "https://uofa.net/nagaraja/decision/mrl5-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/mrl5-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
