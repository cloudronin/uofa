  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors assessed at modelRiskLevel 5. Required levels range from Gradation 3 to Gradation 4; achieved levels meet or exceed required levels in all 13 factors (three factors exceed required level: Model inputs achieved 5 vs. required 4; Output comparison achieved 5 vs. required 4; Numerical solver error achieved 4 vs. required 3). No factor falls below its required level; therefore no offset rationale is required. Validation results demonstrate E/uval < 1.96 and percentage differences < 2% for all three primary QoIs (stiffness, yield force, force at 40 mm displacement) under a pre-registered blind prediction protocol. Global sensitivity analysis (Sobol, N=20480) confirms that combined model uncertainty is dominated by Ti-6Al-4V material properties and rod-screw friction, both of which are characterized from lot-specific measurements and propagated through the UQ ensemble. The validation evidence base (N=11 specimens, two ISO 17025-accredited laboratories, per-specimen CMM geometry matching) is sufficient to support the credibility claim at the declared model risk level. The decision to Accept is grounded in: (1) all factors at or above required gradation; (2) all E/uval metrics well within the 1.96 threshold; (3) blind prediction protocol eliminating post-hoc tuning bias; (4) documented scope limitations (single static loading mode) that are consistent with the COU as defined. The FEA modeling framework is credible for its intended use of predicting ASTM F1717 static compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
