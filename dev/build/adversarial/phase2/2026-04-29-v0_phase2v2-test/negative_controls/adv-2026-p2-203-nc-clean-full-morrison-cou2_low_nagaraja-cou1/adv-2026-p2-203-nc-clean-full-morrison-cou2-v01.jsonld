    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated 7.5 mm pedicle screw ASTM F1717 applicability domain",
      "description": "Applicable to non-cannulated pedicle screw constructs with nominal outer diameter 7.0–8.0 mm, titanium alloy (Ti-6Al-4V ELI per ASTM F136), polyaxial head angle ≤15°, tested under ASTM F1717 static compression-bending with superior load application at 10 mm/min crosshead displacement. Excludes cannulated variants, CoCr alloys, dynamic fatigue loading, and construct lengths outside 60–100 mm interbody spacer range."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 compression-bending operating envelope for 7.5 mm non-cannulated screw FEA",
      "description": "Geometric bounds: screw outer diameter 7.0–8.0 mm, pitch 2.75–3.25 mm, rod diameter 5.5 mm ± 0.05 mm, interbody spacer height 10–14 mm. Material bounds: Ti-6Al-4V ELI, Young's modulus 110–116 GPa, yield strength 880–930 MPa, Poisson ratio 0.32–0.34. Loading bounds: axial compressive preload 0–10 N, bending moment arm 40 mm per F1717 fixture, displacement rate 5–15 mm/min. Temperature: 23 ± 2 °C ambient. Mesh size: element edge length 0.15–0.35 mm in screw root fillet region; global h-refinement convergence criterion <1% change in peak von Mises stress."
    }
  },
