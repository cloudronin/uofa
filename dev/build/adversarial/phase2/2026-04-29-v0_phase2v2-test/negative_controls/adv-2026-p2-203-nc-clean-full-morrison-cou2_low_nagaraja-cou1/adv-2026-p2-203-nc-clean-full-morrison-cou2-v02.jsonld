  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment concludes that the FEA modeling framework is fit for purpose for the stated COU at ModelRiskLevel 5. Twelve of thirteen V&V 40 factors meet or exceed the required gradation level. The single shortfall — Test conditions (achieved Gradation 3 vs required Gradation 4) — is offset by: (1) two independent laboratories providing inter-laboratory reproducibility confirmation (CV 1.9% for stiffness), (2) all three QoIs passing the E/uval < 1.96 criterion with maximum value 0.78, (3) the global sensitivity analysis demonstrating that the untested parameter variations (loading rate, inter-screw distance) contribute <3% to QoI variance, and (4) Model inputs achieving Gradation 5 (above required level), providing compensating confidence. The decision is grounded in the structured evidence chain: ValidationResults vr-stiffness-lab1, vr-stiffness-lab2, vr-yield-force, and vr-force-40mm all demonstrate FEA predictions within ±10% of experimental measurements and E/uval well below the 1.96 threshold. The provenance chain is complete from raw experimental load-displacement data through uncertainty quantification to the final comparison metrics. The package is accepted for submission to FDA as supporting evidence for the 510(k) substantial equivalence claim.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/dr-001-offset",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 3 vs required 4)",
        "justification": "The Test conditions factor achieved Gradation 3 rather than the required Gradation 4 because only a single ASTM F1717 configuration (44 mm inter-screw distance, 5.5 mm rod, compression-bending) was tested experimentally. This shortfall is offset by three compensating factors: (1) inter-laboratory reproducibility across two independent facilities demonstrates that the single test condition is robustly characterised (CV 1.9% for stiffness); (2) the global variance-based sensitivity analysis (Sobol, N=512) shows that parametric variation of the untested parameters — inter-screw distance ±2 mm, rod diameter ±0.1 mm — contributes less than 3% of total output variance, confirming the single condition is representative of the design space; (3) the Model inputs factor exceeds its required level (achieved Gradation 5 vs required 4), providing specimen-specific characterisation that compensates for the absence of multi-condition testing. The net credibility evidence is sufficient to support the regulatory claim at MRL 5.",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions"
      },
      {
        "id": "https://uofa.net/nagaraja/decision/dr-001/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/dr-001/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
