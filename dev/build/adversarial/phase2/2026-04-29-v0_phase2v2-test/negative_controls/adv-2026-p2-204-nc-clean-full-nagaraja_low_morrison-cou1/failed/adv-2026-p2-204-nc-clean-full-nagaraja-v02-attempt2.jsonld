  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40-2018 credibility factors have been assessed and all achieved levels meet or exceed required levels for MRL 3. The primary QoI (peak tibial tray micromotion) is predicted within 8.4% MAE of cadaveric measurements with no systematic bias. Monte Carlo uncertainty propagation confirms the worst-case micromotion (147 µm, 97.5th percentile) remains below the 150 µm osseointegration threshold with 97.3% probability. Sensitivity analysis identifies low bone modulus and low friction as the bounding scenario, and this combination was explicitly included in the validation dataset. All model inputs are traceable to primary sources with documented uncertainty. Software QA, numerical verification, and use error controls are in place. The validation domain spans the COU operating envelope, with the single residual gap (torsional loading range) addressed by a conservative sensitivity study. The credibility evidence is sufficient to support the regulatory claim that the FE model can reliably identify worst-case fixation failure conditions for the Class II TKA tibial tray device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
