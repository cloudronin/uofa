    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/nagaraja-cou1-ortho/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "TKR physiological gait applicability constraint",
      "description": "The CFD model is applicable to total knee replacement devices with femoral component radii of curvature between 20 mm and 65 mm, tibial insert thicknesses between 8 mm and 16 mm, and polyethylene UHMWPE bearing surfaces. The model is restricted to patients with body mass index 18–40 kg/m² and gait cycles characterized by peak knee flexion angles of 0°–120°. Devices with ceramic-on-ceramic or metal-on-metal bearing pairs are explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/nagaraja-cou1-ortho/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "TKR synovial flow operating envelope",
      "description": "Physiological operating bounds: synovial fluid flow rate 0.05–2.5 mL/s; joint cavity pressure 0.1–3.5 MPa; gait cycle frequency 0.5–2.0 Hz; synovial fluid dynamic viscosity 1.5–50 mPa·s (shear-rate dependent, Carreau model); wear-debris particle diameter 0.1–50 µm; ambient temperature 36–38 °C. Boundary conditions derived from in-vitro knee simulator measurements (ISO 14243-3) at five representative gait phases: heel-strike, mid-stance, toe-off, swing initiation, and terminal swing."
    }
  },
  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/nagaraja-cou1-ortho/sensitivity-analysis",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis — TKR wear-debris transport CFD model",
    "description": "A variance-based (Sobol) global sensitivity analysis was performed across six uncertain input parameters: synovial fluid viscosity index (n), tibial insert geometry tolerance (±0.15 mm), particle density (900–1200 kg/m³), inlet velocity profile shape, contact pressure distribution, and turbulence model constant C_µ. The analysis revealed that synovial fluid viscosity index and tibial insert geometry tolerance together account for 78% of the variance in predicted peak wear-debris concentration at the posterior recess, with first-order Sobol indices of 0.52 and 0.26 respectively. Turbulence model constant C_µ contributed a second-order interaction index of 0.09. These findings informed the prioritisation of experimental characterisation efforts and confirmed that the model's QoI is most sensitive to rheological inputs, which were subsequently measured with high-fidelity viscometry and incorporated as calibrated distributions in the UQ workflow."
  },
