  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/nagaraja-cou1-ortho/decision-record",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the TKR wear-debris transport CFD model at MRL 3 is accepted based on the following structured evidence: (1) All 13 V&V 40 credibility factors have been assessed; achievedLevel meets or exceeds requiredLevel for every factor. (2) Discretization error achievedLevel (4) exceeds requiredLevel (3), providing additional confidence in numerical accuracy. Numerical solver error and use error achievedLevels also meet or exceed requirements. (3) Three independent validation activities demonstrate quantitative agreement within pre-specified acceptance bounds across all primary QoIs: velocity field (MAE 4.2%), particle accumulation fraction (error 9.7%), and pressure distribution (RMS error 6.8%). (4) Uncertainty quantification via PCE and Monte Carlo propagation confirms that model prediction intervals encompass experimental measurements for all QoIs. (5) Global sensitivity analysis (Sobol) identifies synovial fluid viscosity and geometry tolerance as dominant uncertainty drivers; both have been characterised with high-fidelity measurements and incorporated into the UQ workflow. (6) The validation experiments are highly relevant to the COU, using production-representative components under ISO 14243-3 gait conditions within the documented operating envelope. (7) Model form selection is justified by comparison with alternative formulations, and all model inputs are traceable to device-specific measurements. The totality of evidence supports the conclusion that the CFD model is credible for identifying worst-case wear-debris accumulation sites under the specified COU conditions at Model Risk Level 3.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
