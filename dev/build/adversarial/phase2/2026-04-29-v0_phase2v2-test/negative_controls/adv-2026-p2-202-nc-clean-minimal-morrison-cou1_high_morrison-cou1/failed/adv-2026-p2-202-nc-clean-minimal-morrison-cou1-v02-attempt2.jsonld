  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "rationale": "The commercial CFD solver (ANSYS Fluent 2023R2) holds ISO 9001:2015 certification and vendor-supplied V&V test suite documentation. Internal version-control records confirm that the simulation scripts and post-processing routines are stored in a Git repository with tagged releases. Regression tests covering 12 canonical benchmark cases were executed and passed prior to the study, exceeding the MRL 2 requirement for basic software QA documentation.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/sqa-ac",
        "type": "AcceptanceCriteria",
        "name": "Software QA acceptance criterion for MRL 2",
        "description": "Solver must hold recognized quality certification or pass internal regression test suite. Simulation scripts must be version-controlled. Required level 1 (basic documentation); target level 2 (regression testing demonstrated)."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "rationale": "Code verification was demonstrated through comparison of solver outputs against three analytical benchmark solutions: (1) Hagen-Poiseuille laminar pipe flow, (2) lid-driven cavity at Re=1000 against Ghia et al. reference data, and (3) rotating annulus Couette flow. All benchmarks reproduced reference solutions within solver-reported tolerances. This exceeds the MRL 2 requirement of basic code verification.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/ncv-ac",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criterion",
        "description": "Solver must reproduce at least two analytical or well-established numerical benchmark solutions relevant to rotating-flow hemodynamics within published tolerances. Required level 1; target level 2."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "A three-mesh GCI study was performed using mesh sizes of 1.8M, 4.6M, and 11.2M cells. The observed order of convergence p=1.94 is consistent with the second-order spatial scheme employed. GCI on the primary QoI (NIH) is 3.1% on the fine mesh, well below the 5% threshold. Wall-shear stress GCI on blade surfaces is 4.7%, also within acceptance. Mesh independence is confirmed at the medium mesh level, providing a safety factor of 1.25 on the fine mesh result.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/disc-error-ac",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criterion",
        "description": "GCI on primary QoI (NIH) must be ≤5% on the production mesh. Observed order of convergence must be within 0.5 of the nominal scheme order. Required level 2; target level 3."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Experimental test conditions are documented in the FDA benchmark dataset (Hariharan et al. 2011). Fluid temperature, hematocrit, and anticoagulant protocol are reported. Flow rates and rotational speeds for all 5 operating points are traceable to NIST-calibrated instrumentation. Boundary conditions applied in CFD are directly derived from the documented experimental conditions, with deviations less than 2% on all inlet parameters.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-cond-ac",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criterion",
        "description": "Experimental conditions must be fully documented and traceable to calibrated instrumentation. CFD boundary conditions must be derived directly from experimental records with deviations <5%. Required level 2."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Quantitative comparison metrics include mean relative error (8.3% on NIH), normalized RMS error on velocity field (6.7%), and pressure head deviation (≤4.2%). Validation uncertainty analysis following ASME V&V 20 methodology yields a validation comparison error E=0.061 against a validation uncertainty Uval=0.098, confirming model adequacy. Graphical overlays of predicted versus measured NIH at all 5 operating points are included in the supporting report.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/output-comp-ac",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criterion",
        "description": "Quantitative error metrics must be reported for all primary QoIs. Validation comparison error must not exceed validation uncertainty. Mean relative error on NIH must be ≤15%. Required level 2; target level 3 with ASME V&V 20 uncertainty analysis."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the clinically accepted metric for pump-induced blood damage and is directly referenced in FDA guidance for CPB devices. Secondary QoIs (velocity field, pressure head) support mechanistic understanding of hemolysis generation. The relative hemolysis index (RH = NIH_device / NIH_predicate < 1) directly maps to the regulatory acceptance criterion, ensuring the QoIs are fully relevant to the intended decision.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/qoi-relevance-ac",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criterion",
        "description": "Primary QoI must be a recognized clinical or regulatory metric for the device type. The mapping between computational QoI and the decision criterion must be explicitly documented. Required level 2."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Validation activities used the FDA generic centrifugal blood pump geometry, which is the same device class and fluid-dynamic regime as the COU device. Operating conditions in the validation study (flow rates 2–6 L/min, rotational speeds 2000–3500 RPM) span the CPB clinical operating range. Blood analog fluid (glycerol-water mixture at matched viscosity) was used in the experimental benchmark, and the hemolysis power-law model is calibrated to the same analog. Validation relevance is confirmed at MRL 2.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/val-relevance-ac",
        "type": "AcceptanceCriteria",
        "name": "Validation activity relevance acceptance criterion",
        "description": "Validation experiments must use the same device geometry class and fluid regime as the COU. Operating conditions in validation must overlap with the COU operating envelope. Required level 2."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "At MRL 2 for a Class II device with medium model influence, separate quantification of numerical solver error (distinct from discretization error) is not required by the ASME V&V 40 credibility matrix. Iterative convergence is monitored (residuals <1e-5 on all equations; mass imbalance <0.01%) and documented, which satisfies the minimum practice. Full solver error budgeting is deferred as acceptable at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Formal use-error analysis is not required at MRL 2 for this device class. The simulation workflow is executed by trained CFD engineers following documented standard operating procedures. Peer review of simulation setup by a second analyst is conducted for all production runs. These controls are sufficient at MRL 2 without a formal use-error quantification study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The RANS k-ω SST turbulence model with Giersiepen-Wurzinger hemolysis power-law is the established standard for centrifugal blood pump CFD at this fidelity level. Model form adequacy is implicitly addressed through the validation comparison results (output comparison factor), which demonstrate agreement within required tolerances. Explicit model form uncertainty analysis is reserved for MRL 3 and above."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Formal input uncertainty propagation beyond the boundary condition sensitivity assessed under discretization error is not required at MRL 2. Key geometric inputs are derived from manufacturer-supplied CAD files with dimensional tolerances <0.1 mm. Fluid property inputs (viscosity, density) are taken from published values for the blood analog at the test temperature. A qualitative sensitivity check confirmed that ±5% variation in viscosity produces <3% change in NIH, supporting the adequacy of nominal input values at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Sample-to-sample variability characterization is not required at MRL 2 for this computational study. The FDA benchmark dataset used for validation was collected on a single manufactured pump specimen representative of the device class. Device-to-device geometric variability is addressed through the tolerance sensitivity analysis conducted under the COU scope. Formal statistical characterization of test sample variability is appropriate at MRL 3 and above."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Formal equivalency mapping between validation test parameters and COU parameters is not required at MRL 2. The validation activities use the same device geometry, fluid analog, and overlapping operating conditions as the COU, as documented under the relevance of validation activities factor. A qualitative equivalency assessment confirms that no significant parameter gaps exist between the validation domain and the COU domain that would invalidate the validation evidence at this risk level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for CPB Class II device at MRL 2) is accepted on the following grounds. All seven assessed credibility factors meet or exceed their required levels: software QA (achieved 2 ≥ required 1), numerical code verification (achieved 2 ≥ required 1), discretization error (achieved 3 ≥ required 2), test conditions (achieved 2 ≥ required 2), output comparison (achieved 3 ≥ required 2), QoI relevance (achieved 2 ≥ required 2), and validation relevance (achieved 2 ≥ required 2). No factor has an achievedLevel below its requiredLevel; no offset rationale is needed. The six scoped-out factors (numerical solver error, use error, model form, model inputs, test samples, equivalency of input parameters) are appropriately deferred per the MRL 2 credibility matrix for a Class II device with medium model influence. Validation evidence demonstrates NIH prediction within 8.3% mean relative error against FDA benchmark data, with validation comparison error E=0.061 less than validation uncertainty Uval=0.098, confirming model adequacy per ASME V&V 20. The relative hemolysis index RH < 1 criterion is met across all 5 operating points. The provenance chain from raw experimental data through CFD analysis to this assessment is complete and documented. The model is judged fit for the intended use of identifying worst-case hemolysis operating conditions for the subject CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
