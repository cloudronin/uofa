  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "id": "https://uofa.net/morrison/factor/sqa",
      "name": "Software quality assurance",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) is a commercially validated code with ISO 9001-certified development processes. Version control, regression test suite (>2000 test cases), and release validation reports are maintained by the vendor. Internal usage is governed by a documented SOP covering installation qualification, user access controls, and periodic benchmark re-runs. Achieved Gradation 2 consistent with MRL 2 requirements.",
      "acceptanceCriteria": {
