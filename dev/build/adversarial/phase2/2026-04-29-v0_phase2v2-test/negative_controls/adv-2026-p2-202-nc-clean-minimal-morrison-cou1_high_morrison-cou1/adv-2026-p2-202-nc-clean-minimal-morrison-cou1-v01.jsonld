  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for CPB application, MRL 2) is accepted based on the following structured evidence review. Seven credibility factors were formally assessed; all achieved levels meet or exceed required levels for MRL 2. Six factors were appropriately scoped out per ASME V&V 40 Table 1 guidance for MRL 2 with a verified commercial solver. Software quality assurance (Gradation 2 achieved) confirms the solver is fit for regulated use. Numerical code verification (Gradation 2) and discretization error (Gradation 3, exceeding requirement) establish numerical accuracy with GCI < 2.1% on primary QoI. Test conditions (Gradation 2) confirm experimental fidelity with NIST-traceable measurements. Output comparison (Gradation 2) demonstrates mean NIH prediction error of 8.3% with all predictions within combined uncertainty bands. QoI relevance (Gradation 2) confirms NIH is the accepted regulatory metric with mechanistic link to clinical outcome. Validation relevance (Gradation 2) confirms the validation activities directly address the COU using the same device geometry and physiologically representative conditions. Three independent validation datasets (NIH benchmark, H-Q curve, PIV velocity field) provide corroborating evidence. Uncertainty quantification is complete for all validation results. The model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device at MRL 2. Decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
