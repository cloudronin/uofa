  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the non-cannulated 7.5 mm pedicle screw FEA model is accepted at MRL 5 based on the following structured evidence: (1) All three primary QoIs satisfy the quantitative acceptance criterion E/uval < 1.96 (stiffness: 1.31; yield force: 1.54; force at 40 mm: 1.72), with all FEA predictions within ±10% of experimental means across N=11 constructs from two independent laboratories. (2) Twelve of thirteen V&V 40 credibility factors achieved at or above the required gradation level. (3) The single shortfall — Test conditions at Gradation 3 vs. required Gradation 4 — is addressed by the offset rationale: the ASTM F1717 protocol is a deterministic, internationally standardised test method with no meaningful clinical variability in loading rate or ambient temperature for static monotonic loading; the sensitivity analysis confirmed QoI insensitivity to ±30% variation in boundary condition stiffness; and conservative acceptance bounds (±10%, E/uval < 1.96) provide additional margin. (4) Global sensitivity analysis (Sobol, N=4096) identified dominant uncertainty sources and confirmed the Monte Carlo UQ adequately characterises the combined uncertainty budget. (5) The provenance chain from raw material certificates through CMM measurements to FEA inputs and experimental results is complete and traceable. The model is fit for its intended regulatory purpose of supporting the 510(k) submission for the non-cannulated pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/nagaraja-testcond-offset",
        "type": "OffsetRationale",
        "name": "Offset rationale — Test conditions shortfall (Gradation 3 vs. required 4)",
        "description": "The Test conditions factor achieved Gradation 3 (single standardised test condition) against a required Gradation 4 (two or more distinct conditions). The shortfall is accepted because: (a) ASTM F1717 is a deterministic, internationally harmonised protocol with no clinically meaningful variability in loading rate for static monotonic testing; (b) the global sensitivity analysis demonstrated that QoI responses are dominated by material property and geometric uncertainty, not by boundary condition or loading rate variation; (c) the E/uval metric for all three QoIs remains well below 1.96, indicating that the combined uncertainty budget already captures the dominant sources of variability; and (d) the conservative ±10% acceptance bounds provide additional assurance margin beyond what a second test condition would contribute. The residual risk from this single-condition limitation is therefore assessed as negligible for the intended regulatory use.",
        "shortfallFactor": "Test conditions",
        "shortfallGap": "Achieved Gradation 3; required Gradation 4"
      },
      {
        "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
