  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated 7.5 mm pedicle screw applicability domain",
      "description": "Model predictions are applicable only to non-cannulated titanium-alloy (Ti-6Al-4V ELI) pedicle screws with nominal outer diameter 7.5 mm ± 0.05 mm and thread pitch 2.75 mm, tested under ASTM F1717 static compression-bending loading at crosshead displacement rates 1–5 mm/min. Predictions are not applicable to cannulated variants, alternative alloys, dynamic fatigue loading, or screw diameters outside 7.0–8.0 mm. Clinical in vivo loading is excluded from scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 compression-bending operating envelope",
      "description": "Valid operating conditions: axial compressive preload 0–100 N; applied bending moment via offset load arm (L = 60 mm ± 0.5 mm) producing compression-bending; crosshead displacement rate 1–5 mm/min; ambient temperature 20–25 °C; relative humidity 40–60%; Ti-6Al-4V ELI material with yield strength 880–970 MPa and Young's modulus 110–116 GPa; screw outer diameter 7.40–7.60 mm; construct height 100 mm ± 2 mm per ASTM F1717 fixture geometry. Extrapolation beyond these bounds requires re-validation."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/nagaraja/sa/pedicle-screw-compression-bending-sa",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis — pedicle screw FEA QoI response",
    "description": "A variance-based Sobol' sensitivity analysis (N=4096 quasi-random LHS samples, total-order indices computed via Saltelli estimator) was performed across seven uncertain model inputs: Ti-6Al-4V Young's modulus (CV 2.1%), yield strength (CV 3.4%), isotropic hardening slope (CV 8%), screw-rod interface friction coefficient (0.1–0.4), bone-substitute block modulus (CV 5%), fixture alignment offset (±0.3 mm), and mesh density (element edge length 0.3–0.8 mm). Dominant first-order contributors to construct stiffness QoI were yield strength (S1 = 0.41) and Young's modulus (S1 = 0.33); friction coefficient dominated force at 40 mm displacement (S1 = 0.29). Total-order indices confirmed negligible higher-order interactions (ST − S1 < 0.04 for all factors), supporting the adequacy of the deterministic nominal-input validation comparison."
  },
