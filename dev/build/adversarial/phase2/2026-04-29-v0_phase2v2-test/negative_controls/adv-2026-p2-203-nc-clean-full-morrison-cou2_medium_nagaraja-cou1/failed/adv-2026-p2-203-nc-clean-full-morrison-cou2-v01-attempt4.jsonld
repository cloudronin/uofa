  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed at MRL 5 (high-consequence, high-influence context). All 13 factors achieve their required credibility level; 4 factors (Discretization error, Model inputs, Output comparison, Numerical solver error) exceed their required level. The validation metric E/uval is below 1.96 for all three QoIs across all N=11 specimens, with relative differences below 2% — well within the pre-specified 10% acceptance bound. Full uncertainty quantification has been conducted with Monte Carlo propagation (N=10,000) and variance-based global sensitivity analysis (Sobol, N=2048 samples) identifying elastic modulus and friction coefficient as dominant uncertainty drivers, both of which have been characterized by specimen-specific measurements. The provenance chain is complete from raw experimental data through post-processing to the validation metric. No weakeners have been identified. The assessment team concludes that the FEA modeling framework has demonstrated sufficient credibility to support the intended regulatory use (FDA 510(k) submission for the non-cannulated 7.5 mm pedicle screw) under the defined COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
