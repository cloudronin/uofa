  "sensitivityAnalysisDetail": {
    "id": "https://uofa.net/nagaraja/sa/compression-bending-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis for non-cannulated pedicle screw FEA QoIs",
    "description": "A variance-based (Sobol) global sensitivity analysis was conducted using 2048 quasi-random Latin hypercube samples across six uncertain model inputs: titanium alloy elastic modulus (±5%), yield strength (±8%), screw-rod interface friction coefficient (0.1–0.4), UHMWPE block stiffness (±10%), geometric tolerances on screw outer diameter (±0.05 mm), and applied displacement rate (quasi-static range). The dominant contributors to variance in construct stiffness were elastic modulus (first-order Sobol index S1=0.41) and screw-rod friction coefficient (S1=0.29); yield force was most sensitive to yield strength (S1=0.55) and geometry (S1=0.18). Force at 40 mm displacement showed near-equal sensitivity to friction and yield strength. These rankings informed the prioritization of material coupon testing and interface characterization in the experimental program.",
    "method": "Sobol variance-based global sensitivity analysis",
    "dominantFactors": [
      "titanium alloy elastic modulus",
      "screw-rod interface friction coefficient",
      "yield strength"
    ],
    "sampleSize": 2048
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability domain for non-cannulated pedicle screw FEA",
      "description": "The FEA model is applicable to non-cannulated titanium alloy pedicle screws with outer diameter 7.0–8.0 mm, thread pitch 2.0–2.5 mm, and rod diameter 5.5–6.0 mm. The model is not applicable to cannulated designs, screws with hydroxyapatite coating, or constructs loaded in pure torsion. Clinical loading scenarios deviating from ASTM F1717 boundary conditions (e.g., multi-level constructs exceeding three levels) are outside scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope for ASTM F1717 compression-bending FEA",
      "description": "Compression-bending loads applied at 10 mm/min displacement rate; construct offset 50 mm per F1717 fixture geometry. Titanium alloy Ti-6Al-4V: elastic modulus 110–120 GPa, yield strength 880–950 MPa, Poisson ratio 0.33–0.34. UHMWPE block compressive modulus 0.8–1.2 GPa. Screw-rod interface friction coefficient 0.1–0.4 (dry, unlubricated). Maximum displacement 40 mm; temperature 23±2°C; relative humidity 50±10%. Geometric tolerance on screw OD: ±0.05 mm; rod OD: ±0.03 mm."
    }
  },
