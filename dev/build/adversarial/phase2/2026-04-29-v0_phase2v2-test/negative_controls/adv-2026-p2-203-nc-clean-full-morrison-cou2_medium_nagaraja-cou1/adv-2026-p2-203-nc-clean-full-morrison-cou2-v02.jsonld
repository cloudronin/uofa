  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed. Twelve of thirteen factors achieve achieved level equal to or exceeding required level. The single shortfall — Test conditions (required level 3, achieved level 3, met exactly) — is fully offset as documented in the OffsetRationale below: the single F1717 test condition is the sole condition relevant to the regulatory COU, and multi-condition testing would not reduce uncertainty in the COU prediction. All three primary QoIs satisfy the pre-established E/uval < 1.96 acceptance criterion (values: 1.31, 1.44, 1.52). Sensitivity analysis confirms dominant uncertainty sources have been characterised and their contributions reduced through lot-specific material testing. The provenance chain is complete from raw experimental measurements through validated model outputs. The credibility assessment team unanimously accepts the FEA model as fit for the stated COU at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/test-conditions-offset",
      "type": "OffsetRationale",
      "name": "Offset rationale for Test conditions shortfall",
      "refersToFactor": "https://uofa.net/nagaraja/cf/test-conditions",
      "justification": "The Test conditions factor achieved level 3 equals required level 3, so no formal gap exists; however, the single-condition testing approach is noted as a potential concern at MRL 5. This is offset by three considerations: (1) ASTM F1717 specifies a single standardised test condition for regulatory submissions, so additional conditions would not be accepted by the regulator as primary evidence; (2) the COU is explicitly bounded to the F1717 compression-bending condition, making multi-condition validation irrelevant to the stated decision; and (3) the sensitivity analysis demonstrates that test-condition parameters (crosshead rate, temperature) contribute less than 2% of total QoI variance, confirming that single-condition testing does not materially undermine predictive confidence within the COU boundary.",
      "offsetStrength": "Strong",
      "reviewedBy": "https://uofa.net/nagaraja/actor/independent-assessor-dr-chen"
    }
  },
