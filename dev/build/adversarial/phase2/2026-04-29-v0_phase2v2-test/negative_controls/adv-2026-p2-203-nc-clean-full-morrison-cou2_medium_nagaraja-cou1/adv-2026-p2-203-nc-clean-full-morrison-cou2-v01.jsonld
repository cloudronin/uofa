  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/depuy-synthes-fda-collaboration",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the non-cannulated pedicle screw FEA model (MRL 5) is accepted based on the following structured evidence: (1) All 13 ASME V&V 40 credibility factors have been assessed at the required level or above. Twelve of thirteen factors achieve their required level; the Output comparison and Model inputs factors exceed required levels (achievedLevel 5 vs. requiredLevel 4), providing additional assurance. (2) All three primary QoIs satisfy the pre-established quantitative acceptance criteria: E/uval values of 0.48, 0.71, and 0.52 are all well below the 1.96 threshold, and relative errors are all below 2%, comfortably within the 10% acceptance band. The full load-displacement curve area metric (u=0.031) also satisfies its threshold. (3) The blind prediction protocol eliminates confirmation bias as a source of concern. (4) The global sensitivity analysis (Sobol, N=4096) identifies three dominant input parameters accounting for 77% of output variance, and the combined uncertainty budget is dominated by experimental reproducibility rather than model uncertainty, indicating the model is not the limiting factor in prediction accuracy. (5) The single-test-condition limitation (static only) is explicitly bounded in the operating envelope and COU applicability constraint; the decision consequence (Medium) and model influence (Medium) are consistent with MRL 5 requirements. No unmitigated gaps in the credibility evidence chain have been identified. The model is approved for use in regulatory submissions supporting the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending within the documented operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
