  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-nc9-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed with achieved levels meeting or exceeding required levels for MRL 5. The assessment is accepted despite wide uncertainty bounds (±38% prediction interval on absolute hemolysis index) because: (1) the wide bounds are honestly documented and their sources are identified via Sobol sensitivity analysis as the hemolysis power-law exponent C and turbulent stress exposure time; (2) the upper bound of the 95% prediction interval remains below the clinical hemolysis threshold at all five COU operating points, providing a positive safety margin even under pessimistic uncertainty assumptions; (3) the Monte Carlo UQ framework explicitly propagates these low-confidence parameters rather than suppressing them; (4) all other credibility factors achieve required levels, providing a strong structural foundation. The residual uncertainty in hemolysis model parameters is documented in the offset rationale and flagged for reduction in subsequent device-specific validation campaigns.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/morrison-cou2-hemolysis-uncertainty",
      "type": "OffsetRationale",
      "name": "Offset rationale — wide hemolysis prediction interval",
      "description": "The ±38% prediction interval on absolute NIH arises from low-confidence parameterization of the Giersiepen-Wurzinger hemolysis exponent C and turbulent stress exposure time scaling (Sobol indices 0.44 and 0.27 respectively). Acceptance is justified because: (a) even at the 97.5th percentile of the MC distribution, predicted NIH at all five operating points remains below 0.01 g/100 L, which is 40% below the clinical threshold of 0.016 g/100 L established in the device submission protocol; (b) the uncertainty is epistemic and bounded — it does not represent a systematic bias but rather parametric uncertainty that is conservatively propagated; (c) the honest documentation of low confidence in these parameters, rather than point-estimate reporting, constitutes a more rigorous credibility posture than prior submissions. Residual risk: if the true hemolysis exponent C lies at the upper end of its published range, predictions may underestimate NIH by up to 38%; this is accepted as residual risk given the 40% safety margin to clinical threshold."
    }
  },
