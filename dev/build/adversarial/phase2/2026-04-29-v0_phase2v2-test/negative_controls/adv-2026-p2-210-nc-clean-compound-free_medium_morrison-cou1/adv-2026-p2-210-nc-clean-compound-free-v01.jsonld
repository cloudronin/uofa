  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation levels for MRL 2. Discretization error (Gradation 3 achieved vs. Gradation 2 required) and output comparison results (MAPE < 15% across all five operating points) provide particular confidence in the quantitative predictions. The six scoped-out factors are appropriately excluded at MRL 2 per ASME V&V 40-2018 Table 3, with qualitative justifications documented for each. The validation dataset is directly relevant to the COU: same pump geometry, overlapping operating envelope, and physiologically representative fluid properties. Uncertainty in NIH predictions (CV 8.7%) is within the margin of the RH < 1 acceptance criterion relative to the predicate device. The provenance chain from raw experimental data through validation activities to the credibility assessment is complete and traceable. The assessment team concludes that the CFD model provides sufficient credibility to support the regulatory decision regarding worst-case hemolysis operating conditions for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
