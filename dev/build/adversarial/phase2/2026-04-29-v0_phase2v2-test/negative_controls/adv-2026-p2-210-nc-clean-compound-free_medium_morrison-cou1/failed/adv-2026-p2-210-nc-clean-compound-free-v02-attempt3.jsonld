  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation 2 levels for MRL 2. Discretization error achieved Gradation 3, providing additional confidence margin. NIH predictions agree with bench measurements within ±15% at all five operating points (mean error 8.3%). GCI on NIH is 0.9%, well below the 5% threshold. The six scoped-out factors are each justified as not required at MRL 2 given the commercial solver pedigree, documented analyst competency, and empirical sensitivity checks. The provenance chain from raw bench data through validation results to this UoA is complete and traceable. The package satisfies ASME V&V 40-2018 requirements for a Class II CPB device at Model Risk Level 2 with Medium assurance level. The decision to accept the CFD model for identifying worst-case hemolysis operating conditions is supported by the structured evidence without reservation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
