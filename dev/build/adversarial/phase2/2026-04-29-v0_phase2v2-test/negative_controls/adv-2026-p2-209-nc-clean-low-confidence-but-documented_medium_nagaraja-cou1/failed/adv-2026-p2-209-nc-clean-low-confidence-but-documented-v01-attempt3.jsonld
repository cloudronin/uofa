  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-nc9-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble model for non-cannulated 7.5 mm pedicle screw compression-bending is accepted for use in the COU despite one factor shortfall (Test conditions: achieved level 1, required level 2) and explicitly low confidence scores on two validation results (stiffness confidence 0.62, yield force confidence 0.58). The acceptance is justified on the following grounds: (1) All three QoI validation metrics E/uval are below the 1.96 threshold, demonstrating quantitative agreement between FEA and experiment within the single tested condition. (2) The wide uncertainty bounds and low confidence scores are the result of honest documentation of inter-laboratory variability and material batch scatter, not model inadequacy; the FEA central estimates fall within experimental confidence intervals for all QoIs. (3) The sensitivity analysis identifies insertion torque variability and material yield strength scatter as the dominant sources of wide bounds; both are experimental limitations rather than model deficiencies. (4) The model risk level 3 and medium decision consequence (revision surgery, not mortality) are consistent with accepting a single-condition validation with documented residual uncertainty. (5) The offset rationale below provides the formal justification for accepting the Test conditions shortfall.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/nagaraja-tc-offset-001",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (achieved 1, required 2)",
        "description": "The Test conditions factor achieves level 1 (single condition) against a required level 2 (two or more conditions). This shortfall is offset by the following compensating strengths: (a) The single validated condition is the exact ASTM F1717 standard configuration that constitutes the COU; no extrapolation beyond the validated condition is required for the regulatory submission. (b) The FEA model has been exercised across the operating envelope via parametric sensitivity analysis (5 uncertain inputs, Sobol indices computed), providing indirect evidence of model behavior outside the single test condition. (c) N=11 constructs across two independent laboratories provides inter-laboratory reproducibility evidence that partially compensates for the absence of multi-condition testing. (d) The decision consequence is medium (revision surgery); a mortality-risk application would require a higher standard. The residual risk of undetected model error outside the single test condition is accepted by the credibility assessment team and documented for the regulatory record."
      },
      {
        "id": "https://uofa.net/synth/decision/nagaraja-nc9-decision-001/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/nagaraja-nc9-decision-001/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
