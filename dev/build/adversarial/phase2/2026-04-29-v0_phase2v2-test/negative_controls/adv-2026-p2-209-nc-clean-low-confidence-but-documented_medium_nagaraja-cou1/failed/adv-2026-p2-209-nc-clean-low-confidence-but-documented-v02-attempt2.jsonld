  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed the required gradation level. One factor (Test conditions) achieves Gradation 2 against a required Gradation 3 for Model Risk Level 3. This shortfall is accepted as residual risk for the following reasons documented in the offset rationale: (1) ASTM F1717 is a standardized protocol with a single specified test condition; multi-condition testing would require deviation from the standard and is not standard practice for this device class; (2) the rate sensitivity of Ti-6Al-4V under quasi-static loading is well-characterized in the literature and is negligible at the 10 mm/min test rate; (3) the model influence is MEDIUM and decision consequence is MEDIUM, placing the overall risk in the acceptable range even with one below-required factor; (4) the three QoI validation metrics all pass acceptance criteria (E/uval < 1.96) despite wide uncertainty bounds on contact stiffness and locking torque, demonstrating that the model is predictively adequate within the tested condition. Wide uncertainty bounds on yield force prediction (±19% at 95th percentile) are explicitly documented and arise primarily from locking torque variability; these bounds are judged acceptable because the point estimate passes the <10% acceptance criterion and the uncertainty is driven by experimental assembly variability rather than model inadequacy. The sensitivity analysis identifies contact stiffness (Sobol S1=0.52 for stiffness QoI) and locking torque (Sobol S1=0.61 for yield force QoI) as the dominant uncertain inputs; both are documented in the evidence package.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/factor/test-conditions",
        "justification": "Test conditions factor achieves Gradation 2 against required Gradation 3 because only a single ASTM F1717 test condition (10 mm/min, 23 °C) was employed. This shortfall is accepted because: (1) ASTM F1717 specifies a single standardized test condition and multi-condition testing is not required by the standard for this device class; (2) published literature on Ti-6Al-4V quasi-static mechanical behavior confirms negligible rate sensitivity at crosshead speeds between 1–100 mm/min, bounding the risk from the single-rate limitation; (3) the model influence is MEDIUM and decision consequence is MEDIUM, so the overall model risk does not require Gradation 3 test condition coverage to reach an acceptable credibility level when all other factors are at or above required levels; (4) the validation metric E/uval < 1.96 for all three QoIs provides direct quantitative evidence that the model is predictively adequate under the tested condition, reducing reliance on multi-condition coverage."
      },
      {
        "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2024/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2024/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
