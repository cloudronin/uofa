  "signature": "ed25519:9b1c3e5f7a2d4b6e8c0f2a4d6b8e0c2f4a6d8b0e2c4f6a8d0b2e4c6f8a0d2b4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "The CFD solver (ANSYS Fluent 2023R2) is operated under a documented software quality plan conforming to ISO 9001:2015 and FDA 21 CFR Part 820. Version control, regression test suite (>1200 benchmark cases), and change-control records are current. Solver release notes and qualification report reviewed and approved by the assessment team. No open defect reports affecting hemolysis-relevant physics modules.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-sqa",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criteria — MRL 5 Class III device",
        "description": "Software must be operated under a documented QMS with ISO 9001 or equivalent certification, full regression test suite, and change-control records reviewed within 12 months of use. All open defects affecting hemolysis physics must be resolved or formally risk-accepted. Achieves Gradation 4."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "rationale": "Order-of-accuracy verification performed using the Method of Manufactured Solutions (MMS) for the Navier-Stokes and scalar hemolysis transport equations. Observed convergence order of 1.94 (expected 2nd-order) confirmed for velocity and 1.87 for hemolysis scalar on three systematically refined grids. Code verification report independently reviewed by a third-party numerical analyst. Exceeds Gradation 3 requirement.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-code-verification",
        "type": "AcceptanceCriteria",
        "name": "Code verification acceptance criteria",
        "description": "Observed order of accuracy must be within 10% of theoretical order for both momentum and scalar transport equations using MMS on at least three grid levels. Independent review of verification report required at MRL 5."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Grid convergence study performed on four systematically refined meshes (1.2M, 4.8M, 19.2M, 76.8M cells) following ASME V&V 20 Richardson extrapolation methodology. Grid convergence index (GCI) for NIH at design point: GCI_fine = 2.1%, GCI_medium = 6.8%. Asymptotic range confirmed (GCI ratio = 1.02). Discretization error contribution to total NIH uncertainty is 2.1%, well within the 5% acceptance threshold for Gradation 4.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-discretization",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria",
        "description": "GCI on finest grid must be ≤5% for NIH QoI. Asymptotic convergence range must be demonstrated (GCI ratio within 5% of unity). Minimum four grid levels required at MRL 5."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Experimental test conditions replicated in silico: blood analog viscosity matched to ±1.5%, inlet flow rates controlled to ±0.05 L/min, rotational speed controlled to ±5 RPM, temperature maintained at 37±0.5°C. Test rig geometry confirmed against CAD nominal dimensions with CMM measurement uncertainty <50 µm. All five operating points bracket the clinical operating envelope. Test conditions documented in traceability matrix linking each CFD boundary condition to a calibrated instrument record.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria",
        "description": "All boundary conditions must be traceable to calibrated instrument records with stated uncertainty. Flow rate match within ±2%, viscosity within ±3%, temperature within ±1°C. Operating points must span the full clinical envelope."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "NIH predictions compared against in-vitro measurements at all 5 operating points using a pre-specified validation metric (mean absolute percentage error, MAPE). MAPE = 8.3% against pre-specified acceptance threshold of 15%. Comparison includes uncertainty bars from both experimental measurement (expanded uncertainty k=2) and CFD Monte Carlo ensemble. Validation metric computed and documented prior to unblinding experimental data (registered analysis plan). All predictions within 95% prediction interval.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria",
        "description": "MAPE for NIH across all 5 operating points must be ≤15% against in-vitro measurements. Comparison must include combined experimental and simulation uncertainty bands. Analysis plan must be registered prior to data unblinding."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "NIH is the direct regulatory QoI for hemolysis assessment in VAD submissions (FDA guidance 2021). The power-law hemolysis model (Giersiepen-Wurzinger) maps directly to the clinical endpoint. Sensitivity analysis confirms NIH is the dominant output driving the regulatory decision (Sobol S_T = 0.61 for hemolysis exponent). No surrogate QoI substitutions made; all comparisons use the regulatory-specified metric. QoI relevance confirmed by clinical advisor review.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-qoi-relevance",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criteria",
        "description": "QoI must map directly to the regulatory hemolysis endpoint without surrogate substitution. Clinical advisor review must confirm relevance. Sensitivity analysis must demonstrate QoI sensitivity to dominant uncertainty sources."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Validation experiments conducted on the FDA generic centrifugal pump geometry — identical to the COU geometry. Blood analog (glycerol-water, matched viscosity) used in lieu of whole blood; correction factor for red blood cell fragility documented and applied. Operating conditions span the full clinical envelope (3–6 L/min, 2400–3600 RPM). Validation activities address the same failure mode (excessive hemolysis) as the regulatory decision. Relevance gap analysis documented: minor gap in non-Newtonian rheology addressed by sensitivity study showing <2% effect on NIH.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-validation-relevance",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance acceptance criteria",
        "description": "Validation geometry must match COU geometry. Operating conditions must span the clinical envelope. Any analog fluid corrections must be documented with quantified uncertainty contribution. Relevance gaps must be addressed by sensitivity analysis."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Iterative convergence confirmed: residuals reduced by 6 orders of magnitude for all transport equations; mass imbalance <0.001% of inlet flux. Steady-state solution verified against time-averaged transient simulation (difference in NIH <1%). Double-precision arithmetic used throughout. Solver settings documented in reproducibility record. No floating-point exceptions or solver warnings in production runs.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-solver-error",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error acceptance criteria",
        "description": "Residuals must converge by at least 5 orders of magnitude. Mass imbalance must be <0.01% of inlet flux. Double-precision arithmetic required. Solver settings must be documented in a reproducibility record."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Independent re-execution of the CFD workflow by a second analyst produced NIH values within 0.4% of primary analyst results, confirming absence of operator-induced variability. Simulation workflow documented in a controlled procedure (SOP-CFD-VAD-002 Rev C) with mandatory checklist. Boundary condition setup reviewed by senior engineer prior to each production run. No use errors identified in audit trail review.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-use-error",
        "type": "AcceptanceCriteria",
        "name": "Use error acceptance criteria",
        "description": "Independent re-execution by a second qualified analyst must produce NIH within 2% of primary results. Workflow must be documented in a controlled SOP with mandatory pre-run checklist. Audit trail must be reviewed for compliance."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "The SST k-ω turbulence model was selected based on a systematic model form study comparing five turbulence closures (k-ε standard, k-ε realizable, RSM, SST k-ω, LES) against PIV data. SST k-ω achieved lowest normalized RMS error in velocity (6.1%) and turbulent kinetic energy (18%). Power-law hemolysis model (Giersiepen-Wurzinger) validated against published RBC fragility data. Model form uncertainty quantified by comparing SST k-ω and LES predictions: NIH difference 4.2%, included in total uncertainty budget. Model form selection documented with traceability to benchmark study.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-model-form",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria",
        "description": "Turbulence model selection must be justified by systematic comparison against experimental data using at least three candidate models. Model form uncertainty must be quantified and included in total uncertainty budget. Hemolysis model must be validated against RBC fragility data."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "All model inputs characterized with probability distributions derived from measurement data: inlet velocity profile (turbulent pipe flow, measured with LDV, uncertainty ±5%), fluid viscosity (Brookfield rheometer, ±3%), hemolysis power-law constants (literature meta-analysis of 12 studies, coefficient of variation 8%). Monte Carlo propagation (10 000 samples) performed to quantify input uncertainty contribution to NIH. Dominant input: hemolysis exponent (S_T = 0.61). All input distributions documented in the uncertainty register with traceability to primary data sources.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria",
        "description": "All inputs must have characterized uncertainty distributions traceable to primary measurement data or peer-reviewed literature. Monte Carlo propagation required for MRL 5. Sobol sensitivity indices must be computed to identify dominant inputs. Uncertainty register must be maintained."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Validation experiments conducted with n=5 independent test runs per operating point (25 total NIH measurements). Blood analog prepared fresh for each run from certified reagents; viscosity verified before and after each test. Inter-run coefficient of variation for NIH ≤4.2% across all operating points, confirming adequate repeatability. Sample size justified by power analysis (80% power to detect 15% NIH difference at α=0.05). Test sample provenance documented in laboratory notebook with instrument calibration records.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-test-samples",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria",
        "description": "Minimum n=3 independent runs per operating point required. Inter-run CV must be ≤10% for NIH. Sample size must be justified by power analysis. Blood analog preparation must be documented with reagent lot traceability."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Equivalency between experimental and CFD input parameters formally assessed: inlet Reynolds number matched within 0.8%, pump rotational speed within 0.2%, fluid viscosity within 1.5%, geometry within CMM tolerance (<50 µm). Equivalency matrix completed for all 14 input parameters; no parameter exceeds the pre-specified equivalency tolerance. Non-Newtonian correction factor applied and sensitivity-tested (NIH impact <2%). Equivalency assessment documented in the validation traceability matrix.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/cou2-equivalency",
        "type": "AcceptanceCriteria",
        "name": "Equivalency of input parameters acceptance criteria",
        "description": "Equivalency matrix must be completed for all boundary condition and geometry inputs. Reynolds number match within 2%, viscosity within 3%, geometry within manufacturing tolerance. Non-Newtonian corrections must be sensitivity-tested. All equivalency assessments must be documented in the validation traceability matrix."
      }
    }
