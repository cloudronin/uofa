  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-nc2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed required levels for Model Risk Level 5, Class III device context. Software quality assurance (4/4), numerical code verification (4/3), discretization error (4/4), test conditions (3/3), output comparison (4/4), QoI relevance (4/4), validation relevance (4/4), numerical solver error (3/3), use error (3/3), model form (4/4), model inputs (4/4), test samples (3/3), and equivalency of input parameters (3/3) are all fully satisfied. Monte Carlo uncertainty quantification with 10 000 samples provides a complete uncertainty budget; NIH predictions are within 8.3% MAPE of in-vitro measurements against a 15% acceptance threshold. The provenance chain is complete from raw PIV and hemolysis measurements through the validation comparison to this credibility assessment. No credibility gaps remain. The assessment team concludes that the CFD model provides sufficient credibility to support the regulatory submission claim that absolute hemolysis levels remain below the clinical threshold across the full VAD operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
