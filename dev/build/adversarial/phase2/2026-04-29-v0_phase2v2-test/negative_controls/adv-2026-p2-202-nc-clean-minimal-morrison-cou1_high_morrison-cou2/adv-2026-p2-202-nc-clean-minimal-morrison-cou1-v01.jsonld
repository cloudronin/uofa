  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-nc2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed required levels at Model Risk Level 5. The CFD hemolysis prediction model demonstrates Gradation 4 compliance across the six highest-weight factors (software quality assurance, numerical code verification, discretization error, output comparison, model form, and model inputs) and Gradation 3 compliance for use error and test samples, both of which meet their respective required levels. Monte Carlo uncertainty quantification with N=2000 Latin hypercube samples confirms that 95th-percentile NIH predictions remain below the clinical threshold of 0.01 g/100 L at all five VAD operating conditions. Validation against the FDA generic centrifugal pump benchmark demonstrates mean NIH prediction error of 8.3%, within the combined simulation-experiment uncertainty band at all operating points. Mesh convergence (GCI < 1.8%), code verification via method of manufactured solutions (second-order convergence confirmed), and iterative solver convergence (residuals < 1e-6) collectively establish numerical credibility. Model form uncertainty quantified across three turbulence model variants (14% NIH spread) is incorporated into the total uncertainty budget. The provenance chain from raw experimental data through validation comparison to this credibility assessment is complete and traceable. On the basis of this structured evidence, the credibility assessment team accepts the CFD model for its intended use in predicting absolute hemolysis levels for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
