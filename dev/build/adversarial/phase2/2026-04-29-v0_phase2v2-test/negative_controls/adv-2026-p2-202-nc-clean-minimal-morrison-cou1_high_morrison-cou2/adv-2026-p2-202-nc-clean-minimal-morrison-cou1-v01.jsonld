  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "The CFD solver (OpenFOAM v9) is maintained under a documented software quality assurance plan including version control, regression test suite (482 automated tests), and traceable release notes. All hemolysis post-processing scripts are archived in a version-controlled repository with unit tests achieving 94% branch coverage. SQA documentation reviewed and found compliant with ASME V&V 40 Gradation 4 requirements at MRL 5.",
