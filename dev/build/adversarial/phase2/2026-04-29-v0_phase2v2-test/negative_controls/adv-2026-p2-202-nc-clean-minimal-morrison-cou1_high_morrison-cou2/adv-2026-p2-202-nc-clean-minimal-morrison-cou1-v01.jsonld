      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "The k-ω SST turbulence model is selected based on published benchmark studies demonstrating superior performance for rotating machinery flows with adverse pressure gradients. The Giersiepen-Wurzinger power-law hemolysis model is adopted per FDA-recognized literature. Model form uncertainty is quantified by comparing three turbulence model variants (k-ε RNG, k-ω SST, RSM); NIH spread across models is 14%, which is included in the total uncertainty budget. Gradation 4 achieved through systematic model-form uncertainty quantification.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-form",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria",
        "description": "Turbulence model selection must be justified by benchmark evidence for the flow regime. Model form uncertainty must be estimated by comparison of at least two alternative model forms. The hemolysis constitutive model must be traceable to peer-reviewed literature and FDA guidance."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "All model inputs are characterized with probability distributions for Monte Carlo UQ: inlet velocity (normal, CV=5%), blood viscosity (log-normal, CV=8%), hemolysis power-law exponent α (uniform, ±0.12), and hemolysis power-law exponent β (uniform, ±0.05). Input distributions are derived from published experimental data and manufacturer specifications. Sensitivity indices (Sobol) computed; viscosity and power-law exponent dominate NIH uncertainty (combined 78% of variance). Gradation 4 achieved.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria",
        "description": "All influential model inputs must be assigned probability distributions traceable to experimental data or published literature. Sobol sensitivity indices must be computed to identify dominant uncertainty sources. Total uncertainty budget must be reported."
      }
