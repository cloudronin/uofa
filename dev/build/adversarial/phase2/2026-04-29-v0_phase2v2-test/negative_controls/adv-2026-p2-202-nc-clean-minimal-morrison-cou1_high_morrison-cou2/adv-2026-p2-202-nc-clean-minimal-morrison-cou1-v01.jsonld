        "type": "AcceptanceCriteria",
        "name": "Use error acceptance criteria",
        "description": "Simulation setup must be reviewed by an independent qualified engineer. A documented checklist covering boundary conditions, material properties, solver settings, and post-processing must be completed and signed. Reviewer qualifications must be documented."
      }
