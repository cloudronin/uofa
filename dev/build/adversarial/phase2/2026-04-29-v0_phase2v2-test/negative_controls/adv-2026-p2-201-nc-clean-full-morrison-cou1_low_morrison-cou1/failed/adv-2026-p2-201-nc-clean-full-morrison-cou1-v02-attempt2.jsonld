  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed with achieved levels meeting or exceeding required levels for MRL 2. The CFD model demonstrates adequate credibility for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions. Key evidence: (1) Discretization error GCI = 3.7% on primary NIH QoI, below 5% threshold; (2) Validation comparison error mean 8.3%, maximum 14.1%, within combined validation uncertainty U_val = 12.8% at 95% confidence; (3) RH index correctly rank-ordered at all 5 operating points; (4) Sensitivity analysis confirms RH < 1 at 99th percentile across full operating envelope; (5) All 13 factors assessed at or above required levels with no shortfalls. The model is accepted for use in the COU1 regulatory submission supporting the 510(k) hemolysis equivalence claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
