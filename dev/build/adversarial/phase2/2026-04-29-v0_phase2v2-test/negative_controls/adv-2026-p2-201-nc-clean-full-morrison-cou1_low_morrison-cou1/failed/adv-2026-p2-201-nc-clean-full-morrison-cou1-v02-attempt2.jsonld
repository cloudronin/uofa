  "hasSensitivityAnalysis": true,
  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/morrison/sensitivity/cou1-sa-2024",
    "type": "SensitivityAnalysis",
    "name": "Parametric sensitivity analysis — COU1 hemolysis QoI",
    "description": "One-at-a-time and Morris screening sensitivity analysis was performed varying inlet flow rate (±15% of nominal 5 L/min), impeller rotational speed (2400–3600 RPM), blood viscosity (3.0–4.5 mPa·s), and gap clearance tolerance (±50 µm). The scalar relative hemolysis index (RH) showed greatest sensitivity to rotational speed (Sobol first-order index S1 = 0.61) and gap clearance (S1 = 0.27); flow rate and viscosity contributed minor variance (combined S1 < 0.12). Worst-case RH remained below 1.0 across all sampled combinations at the 99th percentile, confirming robustness of the acceptance decision."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "COU1 applicability constraint — centrifugal CPB pumps, adult patients",
      "description": "This COU applies exclusively to FDA generic centrifugal blood pump geometry operating under adult cardiopulmonary bypass conditions (body surface area 1.5–2.2 m², flow demand 3–6 L/min). The model is not applicable to pediatric circuits, pulsatile assist devices, or axial-flow configurations. Blood is modeled as a non-Newtonian continuum fluid; individual erythrocyte mechanics are outside scope. Geometric variants are constrained to ±100 µm dimensional tolerance from the nominal FDA pump CAD."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "COU1 operating envelope — CPB hemolysis CFD",
      "description": "Validated operating envelope: inlet flow rate 3.0–6.0 L/min; impeller rotational speed 2400–3600 RPM; inlet hematocrit 30–45%; blood temperature 28–37 °C; outlet pressure head 60–300 mmHg; gap clearance 150–350 µm. Simulations outside these bounds require re-assessment of model credibility before use in regulatory submissions."
    }
  },
