  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and each achieves a level meeting or exceeding the required level for Model Risk Level 2. Software quality assurance (3 >= 2), numerical code verification (2 >= 2), discretization error (3 >= 2), test conditions (2 >= 2), output comparison (3 >= 2), QoI relevance (2 >= 2), validation activity relevance (3 >= 2), numerical solver error (2 >= 2), use error (2 >= 2), model form (2 >= 2), model inputs (3 >= 2), test samples (2 >= 2), and equivalency of input parameters (2 >= 2) are all satisfied. Validation results VR-01 through VR-03 demonstrate quantitative agreement within acceptance criteria across all five COU operating points. Sensitivity analysis confirms robustness of worst-case operating condition identification to input uncertainty. Uncertainty quantification is present and complete for all validation results. The relative hemolysis index satisfies RH < 1.0 at all operating points. The credibility evidence package is sufficient to support the regulatory submission decision for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
