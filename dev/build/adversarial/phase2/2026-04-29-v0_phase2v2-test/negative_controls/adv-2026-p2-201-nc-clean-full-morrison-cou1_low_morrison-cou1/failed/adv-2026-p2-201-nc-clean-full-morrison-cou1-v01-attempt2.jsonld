  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/morrison/sensitivity/cou1-sa-01",
    "type": "SensitivityAnalysis",
    "name": "COU1 Parametric Sensitivity Analysis — Hemolysis Index Response",
    "description": "A one-at-a-time sensitivity study varied five model input parameters—blood viscosity (±15%), impeller rotational speed (±5%), inlet flow rate across the five COU operating points, turbulence model selection (SST k-ω vs. realizable k-ε), and gap clearance geometry tolerance (±50 µm)—and recorded the response in the relative hemolysis index (RH). Results showed that rotational speed and gap clearance produced the largest RH variation (up to 18% and 12% respectively), while viscosity and turbulence model selection contributed less than 4% change in RH, confirming that the model ranking of worst-case operating conditions is robust to plausible input uncertainty."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "COU1 Applicability Constraint — Centrifugal CPB Pump Domain",
      "description": "The CFD model and associated credibility assessment apply exclusively to single-stage centrifugal blood pumps operating under steady-state cardiopulmonary bypass conditions with Newtonian blood rheology approximation. The model is not applicable to pulsatile assist devices, axial-flow pumps, or operating regimes with hematocrit outside 35–45%. Geometric extrapolation beyond ±200 µm of the assessed clearance range is excluded."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "COU1 Operating Envelope — CPB Hemolysis Assessment",
      "description": "The operating envelope spans five discrete flow-speed combinations: flow rates of 3.0, 4.0, and 5.0 L/min combined with impeller speeds of 2400 and 3200 RPM. Blood viscosity is fixed at 3.5 mPa·s (Newtonian). Inlet pressure ranges from 5 to 15 mmHg; outlet back-pressure from 80 to 120 mmHg. Gap clearance tolerance assessed over 100–400 µm. Temperature maintained at 37 ± 1°C. All five operating points must satisfy RH < 1.0 relative to the predicate device benchmark."
    }
  },
