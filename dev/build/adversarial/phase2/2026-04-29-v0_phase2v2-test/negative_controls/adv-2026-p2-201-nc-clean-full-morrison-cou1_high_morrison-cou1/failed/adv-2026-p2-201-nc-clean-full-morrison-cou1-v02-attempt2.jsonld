  "hasSensitivityAnalysis": true,
  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/morrison/sensitivity/cou1-sa-01",
    "type": "SensitivityAnalysis",
    "name": "COU1 hemolysis sensitivity to impeller clearance and flow rate",
    "description": "Impeller tip clearance was varied ±15% around nominal (0.3 mm) and volumetric flow rate was swept across the five CPB operating points (3–6 L/min at 2500–3500 RPM). The relative hemolysis index (RH) showed a monotonic increase with decreasing tip clearance (up to 22% RH elevation at minimum clearance) and was most sensitive at the 6 L/min / 3500 RPM operating point, confirming that this corner condition governs worst-case hemolysis and is the appropriate focus of the regulatory submission."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis CFD applicability domain",
      "description": "Model is applicable to Newtonian-approximated blood flow through centrifugal pump geometries with impeller tip clearances between 0.20 mm and 0.45 mm, rotational speeds 2000–4000 RPM, and flow rates 2–7 L/min. Blood power-law viscosity parameters must fall within the validated rheological envelope (hematocrit 35–45%). Model is not applicable to pulsatile-assist or LVAD duty cycles, nor to axial-flow pump geometries."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB centrifugal pump operating envelope",
      "description": "Validated operating envelope: volumetric flow rate 3–6 L/min; rotational speed 2500–3500 RPM; inlet pressure 5–15 mmHg; outlet pressure 60–120 mmHg; blood temperature 34–37 °C; hematocrit 36–42%; impeller tip clearance 0.25–0.40 mm. Conditions outside these bounds require additional validation before regulatory reliance."
    }
  },
