  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at or above required levels for MRL 2. Discretization error (GCI_fine 1.7%) and code verification (observed order 1.97) both exceed requirements. Validation against 5 bench operating points yields MAE 8.3% with no systematic bias detected. Combined uncertainty budget (model form ±10%, discretization ±1.7%, input propagation ±8%) remains within the regulatory acceptance margin for RH < 1 versus predicate device. Sensitivity analysis confirms the 6 L/min / 3500 RPM corner condition governs worst-case hemolysis, and CFD correctly identifies this condition. The credibility evidence is judged sufficient to support regulatory reliance on the CFD model for the declared COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
