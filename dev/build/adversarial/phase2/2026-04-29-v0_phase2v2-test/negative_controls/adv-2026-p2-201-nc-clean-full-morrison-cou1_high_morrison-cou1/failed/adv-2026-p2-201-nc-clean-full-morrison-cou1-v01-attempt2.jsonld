  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou1/decision/accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-osel-dbsm",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at or above required levels for MRL 2. Discretization error (factor 3) achieved Gradation 3 against a Gradation 2 requirement, providing additional margin. Validation evidence demonstrates CFD NIH predictions within 8.3% MARE of bench measurements across the full COU operating envelope. Sensitivity analysis confirms RH < 1.0 is robust to input parameter uncertainty. UQ propagation shows 95th-percentile RH = 0.94, providing 6% margin against the acceptance criterion. Independent analyst cross-check and documented SQA support confidence in simulation execution. The totality of evidence supports the conclusion that the CFD model is credible for identifying worst-case hemolysis operating conditions for the Class II CPB device at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
