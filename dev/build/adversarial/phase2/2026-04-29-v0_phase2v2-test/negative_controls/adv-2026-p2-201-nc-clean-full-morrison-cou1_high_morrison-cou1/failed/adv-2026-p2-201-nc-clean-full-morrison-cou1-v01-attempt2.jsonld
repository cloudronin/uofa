  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/morrison/cou1/sensitivity-analysis",
    "type": "SensitivityAnalysis",
    "name": "Hemolysis QoI sensitivity to impeller clearance, viscosity, and turbulence model coefficient",
    "description": "One-at-a-time and Morris screening analyses were performed varying impeller tip clearance (±15% of nominal 0.3 mm), blood dynamic viscosity (3.0–4.5 mPa·s reflecting hematocrit range 30–45%), and the Giersiepen power-law exponent (α = 0.765 ± 0.05). The relative hemolysis index RH showed greatest sensitivity to tip clearance (normalized sensitivity index 0.42), moderate sensitivity to viscosity (0.28), and low sensitivity to the power-law exponent (0.11). All perturbed cases retained RH < 1.0 against the predicate device baseline, confirming robustness of the worst-case identification across the operating envelope."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "decisionConsequence": "High",
    "modelInfluence": "Medium",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain for COU1 CFD hemolysis assessment",
      "description": "Model applicability is restricted to the FDA generic centrifugal blood pump geometry (impeller diameter 52 mm ± 2 mm) operating with bovine or human whole blood at hematocrit 30–45% in CPB circuits. The model is not applicable to axial-flow pumps, VAD configurations, or blood substitutes. Rotational speeds outside 1500–3500 RPM and flow rates outside 2–8 L/min are excluded from the validated operating space."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB pump operating envelope for hemolysis CFD validation",
      "description": "Validated operating envelope: flow rate 2–8 L/min, rotational speed 1500–3500 RPM, inlet pressure 5–20 mmHg, outlet pressure 60–120 mmHg, fluid temperature 34–37 °C, hematocrit 30–45%, impeller tip clearance 0.25–0.45 mm. Five nominal operating points (2 L/min/2000 RPM, 4 L/min/2500 RPM, 5 L/min/3000 RPM, 6 L/min/3200 RPM, 8 L/min/3500 RPM) were assessed. Extrapolation beyond these bounds requires re-assessment."
    }
  },
