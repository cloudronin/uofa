  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cou2-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed under ASME V&V 40 at Model Risk Level 5 for the Class III VAD hemolysis prediction COU. Achieved levels meet or exceed required levels across all factors: software quality assurance (4/4), numerical code verification (4/4), discretization error (4/4), test conditions (3/3), output comparison (4/4), relevance of QoIs (3/3), relevance of validation activities (4/4), numerical solver error (3/3), use error (3/3), model form (4/4), model inputs (4/4), test samples (3/3), and equivalency of input parameters (3/3). Monte Carlo UQ (2000 samples) confirms 95th-percentile NIH predictions remain below the clinical hemolysis threshold across all operating points. Validation against FDA benchmark experimental data (3 independent laboratories, 5 replicates per point) demonstrates mean absolute error of 8.3%, within the 15% acceptance band. Grid convergence index of 2.1% confirms discretization error is well controlled. The evidence chain is complete and traceable from foundational experimental data through verification and validation activities to the credibility decision. The model is accepted as fit for purpose for predicting absolute hemolysis levels in support of the Class III VAD regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
