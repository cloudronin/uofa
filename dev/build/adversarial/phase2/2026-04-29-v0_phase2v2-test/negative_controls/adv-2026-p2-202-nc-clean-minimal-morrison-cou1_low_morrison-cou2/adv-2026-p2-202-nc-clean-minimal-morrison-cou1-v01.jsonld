  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed required levels for Model Risk Level 5. Discretization error achieved level 4 against a required level 3, providing an additional confidence margin. Monte Carlo uncertainty quantification (10,000 samples) confirms that the 95th-percentile NIH prediction interval remains below the clinical threshold of 0.1 g/100L at all five operating points. Validation against both PIV velocity fields and bench hemolysis measurements demonstrates model-form adequacy. The simulation-experiment traceability matrix confirms full input equivalency. Independent peer review of the simulation setup confirms no use errors. The credibility evidence package is sufficient to support the regulatory decision that the CFD model can reliably predict absolute hemolysis levels for this Class III VAD device under the specified COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
