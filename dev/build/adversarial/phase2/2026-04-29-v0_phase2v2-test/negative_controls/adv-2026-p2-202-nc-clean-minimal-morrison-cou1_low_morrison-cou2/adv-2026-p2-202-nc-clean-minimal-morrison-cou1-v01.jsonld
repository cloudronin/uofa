      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Bench experiments conducted with n=5 independent blood samples per operating point (total n=25 experiments). Sample-to-sample variability characterized; coefficient of variation in NIH across samples is 4.2%. Statistical power analysis confirms n=5 is sufficient to detect a 10% NIH difference at 80% power.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-samples-mrl5",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria for MRL 5",
        "description": "Minimum n=5 independent replicates per operating point. Sample variability must be characterized and reported. Statistical power analysis must justify sample size for the required detection threshold."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Computational boundary conditions derived directly from experimental measurements using the same instruments and protocols. Inlet velocity profile imposed as a measured axisymmetric profile (not a simplified uniform profile). Hematocrit and viscosity matched to within measurement uncertainty. Equivalency documented in the simulation-experiment traceability matrix.",
      "acceptanceCriteria": {
