        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria for MRL 5",
        "description": "Model prediction must fall within the validation uncertainty band (U_val) at all operating points. Systematic bias must not exceed U_val. Comparison must use ASME V&V 20 framework."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The primary QoI (NIH in g/100L) is the same quantity used for regulatory acceptance decisions and is directly measured in the bench experiments. No surrogate QoI substitution is made. The hemolysis power-law model outputs NIH directly, eliminating transformation uncertainty.",
      "acceptanceCriteria": {
