        "type": "AcceptanceCriteria",
        "name": "Use error acceptance criteria for MRL 5",
        "description": "Independent peer review of simulation setup by a qualified analyst not involved in original model construction. All boundary conditions and solver settings must be verified against the approved simulation plan."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) is the standard form for CFD hemolysis prediction in FDA guidance. Model form uncertainty quantified by comparing predictions from three published hemolysis model variants; NIH spread is 0.004 g/100L, within validation uncertainty. Turbulence modeled with SST k-omega; model selection justified by PIV validation data.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-form-mrl5",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria for MRL 5",
        "description": "Model form uncertainty must be quantified by comparison of at least two physically plausible model variants. The spread in QoI predictions across model variants must be within the validation uncertainty band."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "All model inputs (inlet velocity profile, blood viscosity, density, hemolysis model constants) characterized with documented uncertainty distributions. Monte Carlo propagation (10,000 samples) quantifies input uncertainty contribution to NIH prediction. Dominant contributor is hemolysis exponent alpha (accounts for 61% of total NIH variance).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-inputs-mrl5",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria for MRL 5",
        "description": "All model inputs must have documented uncertainty distributions derived from measurement data or literature. Sensitivity analysis must identify dominant input contributors. Monte Carlo or equivalent propagation required at MRL 5."
      }
    },
