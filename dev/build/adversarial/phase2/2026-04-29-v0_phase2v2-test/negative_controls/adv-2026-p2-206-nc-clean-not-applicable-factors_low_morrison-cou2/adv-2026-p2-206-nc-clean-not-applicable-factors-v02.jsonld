      }
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Quantitative comparison metrics (E%, validation uncertainty Uval, and area validation metric) computed for velocity fields and hemolysis index at all five operating points. E% for NIH ranges 4.2–11.7% across operating points; all within Uval bounds. Formal validation metric computed per ASME V&V 20.",
      "acceptanceCriteria": {
