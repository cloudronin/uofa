  "signature": "ed25519:b4e8d1f3a2c6e9b0d5f7a1c4e2b8d0f6a3c7e1b9d4f2a0c8e6b3d1f9a5c2e7b0",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "At MRL 5 the software underpinning the CFD solver must meet Gradation 3 SQA requirements. The commercial solver (ANSYS Fluent 2023 R2) is deployed under an ISO 9001-certified QMS with documented version control, regression test suite (>1400 tests), and a traceable release-qualification report. Internal SQA audit confirmed all Gradation 3 criteria met.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou2-sqa",
        "type": "AcceptanceCriteria",
        "name": "SQA Gradation 3 compliance",
        "description": "Solver must be deployed under a documented QMS with version control, regression testing, and a traceable release-qualification report satisfying ASME VV40 Gradation 3 SQA criteria."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Code verification was performed via the Method of Manufactured Solutions (MMS) applied to the incompressible Navier-Stokes solver kernel. Observed spatial order of accuracy 1.94 (expected ~2 for second-order scheme); temporal convergence confirmed at order 1.98. Results are documented in the solver qualification report traceable to this assessment.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou2-code-verification",
        "type": "AcceptanceCriteria",
        "name": "MMS-based code verification to Gradation 3",
        "description": "Observed order of accuracy for spatial and temporal discretization must be within 10% of theoretical order for the selected scheme. Documentation must be traceable to the production solver version."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "A three-level grid convergence index (GCI) study was conducted on the FDA generic centrifugal pump geometry. The production mesh (6.4M cells) yields GCI < 2.1% for the hemolysis-driving shear stress integral. The observed convergence order of 1.87 confirms asymptotic convergence. Discretization uncertainty is included in the Monte Carlo UQ propagation.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou2-discretization",
        "type": "AcceptanceCriteria",
        "name": "GCI < 5% on hemolysis QoI",
        "description": "Grid Convergence Index for the wall shear stress integral used in the hemolysis model must be below 5% on the production mesh, with observed convergence order within the theoretical range for the selected discretization scheme."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Experimental test conditions (flow rates 2.5–7.0 L/min, rotational speeds 2000–3500 RPM, inlet pressure 10 mmHg) are documented in the FDA pump benchmark protocol and reproduced in the CFD boundary conditions with less than 1.5% deviation. Temperature, hematocrit (40±2%), and blood analogue properties are controlled and traceable to calibrated measurement records.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou2-test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Boundary condition fidelity within 2% of experimental protocol",
        "description": "CFD boundary conditions must reproduce experimental test conditions within 2% for flow rate and rotational speed, with hematocrit and fluid properties within certified measurement uncertainty bands."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "NIH predictions are compared against five experimental operating points using a quantitative validation metric (E_rms = 8.3%). All predictions fall within the combined experimental and numerical uncertainty interval. A formal validation metric (ASME VV20 U95 approach) confirms model adequacy at Gradation 3 for the hemolysis QoI.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou2-output-comparison",
        "type": "AcceptanceCriteria",
        "name": "NIH prediction error within combined uncertainty interval",
        "description": "RMS prediction error for normalized index of hemolysis must be below 15% and all individual predictions must fall within the U95 combined experimental and numerical uncertainty interval at each validation operating point."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) — is the direct clinical and regulatory endpoint for VAD hemolysis assessment. The power-law hemolysis model integrates shear stress and exposure time over Lagrangian particle trajectories, directly mapping to the biological damage mechanism. QoI relevance is rated Gradation 4 because the model output is the exact quantity specified in the FDA guidance and ISO 10993-4, with no surrogate or proxy involved.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou2-qoi-relevance",
        "type": "AcceptanceCriteria",
        "name": "QoI must be the direct regulatory hemolysis endpoint",
        "description": "The modelled quantity of interest must be the normalized index of hemolysis (NIH) as defined in ISO 10993-4 and FDA guidance, computed via a validated hemolysis model that integrates shear stress and exposure time along particle trajectories."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Validation activities used the FDA generic centrifugal pump — the same device class, geometry family, and operating regime as the COU. Flow rates and rotational speeds span the VAD operating envelope. The validation dataset is independent of the model calibration dataset. Geometric similarity (same impeller blade count, volute topology) and kinematic similarity (Reynolds number within 8% of COU operating points) are documented.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/morrison-cou2-validation-relevance",
        "type": "AcceptanceCriteria",
        "name": "Validation activities span the COU operating envelope",
        "description": "Validation experiments must cover the flow rate and rotational speed range of the COU operating envelope, use a geometrically similar device, and employ an independent dataset not used in model parameter calibration."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Numerical solver error as a distinct credibility factor addresses iterative convergence residuals and floating-point arithmetic errors in custom or research-grade solvers where the solver internals are accessible for inspection. In this assessment the production solver is a commercially qualified code (ANSYS Fluent 2023 R2) whose iterative convergence is controlled by documented residual tolerances (scaled residuals < 1e-5 for all equations) and whose floating-point behaviour is covered under the Software Quality Assurance factor already assessed at Gradation 3. Treating solver error as a separate factor would constitute double-counting of evidence already attributed to the SQA and Numerical Code Verification factors. The ASME VV40 standard acknowledges that for commercially qualified solvers with documented convergence controls, this factor may be subsumed within SQA and code verification assessments. Therefore this factor is not-applicable to the present assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Use error as a standalone credibility factor is relevant when a model is deployed by end-users who are not the model developers, particularly in contexts where operator variability in model setup, boundary condition specification, or post-processing could materially affect the QoI. In this COU the CFD analysis is performed exclusively by the original model development team under a controlled simulation workflow with scripted boundary condition application, automated mesh generation, and peer-reviewed post-processing procedures. All simulation runs are executed within a version-controlled computational environment with mandatory checklist sign-off. The risk of consequential use error is therefore negligible and not distinguishable from the SQA controls already assessed. Assigning a separate use-error gradation would not add discriminating information to the credibility assessment for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Model form uncertainty as a standalone factor addresses cases where multiple competing model forms exist for the same physical phenomenon and a selection must be justified. For hemolysis prediction in centrifugal blood pumps, the power-law Giersiepen-Wurzinger model (and its Heuser-Opitz recalibration) is the single accepted model form in the regulatory and scientific literature; no alternative continuum-level model form is in common use for this QoI. The choice of turbulence closure (SST k-omega) is addressed within the Numerical Code Verification and Output Comparison factors through comparison against experimental data. Treating model form as a separate factor in this context would require comparing against a non-existent or non-standard alternative, which is not scientifically meaningful. This factor is therefore not-applicable to the present assessment scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The model inputs credibility factor is designed to assess the fidelity and uncertainty of input parameters when those inputs are derived from indirect measurements, literature correlations, or population-level statistics with significant variability. In this assessment all primary model inputs — fluid density, dynamic viscosity, inlet flow rate, rotational speed, and outlet pressure — are either directly measured during the validation experiments (with calibrated instrumentation traceable to NIST standards) or specified deterministically from the device operating protocol. Input uncertainty is fully propagated through the Monte Carlo UQ framework documented in the ValidationResult hasUncertaintyQuantification node, which subsumes the input uncertainty characterisation. Separating model inputs as an independent credibility factor would duplicate evidence already captured in the Test Conditions factor (assessed at Gradation 3) and the UQ documentation. This factor is therefore not-applicable as a standalone assessment element."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The test samples factor addresses variability arising from biological or material sample-to-sample differences when physical specimens (e.g., tissue samples, polymer batches, patient cohorts) are used in validation experiments. The FDA generic centrifugal pump validation experiments use a standardised blood analogue fluid (glycerol-water mixture at controlled viscosity) rather than biological blood samples, eliminating inter-sample biological variability as a credibility concern. The controlled fluid properties are documented in the experimental protocol and confirmed by rheometry measurements reported in the validation dataset. Because no variable biological or material specimens are involved in the validation activities supporting this COU, the test samples factor does not apply and its assessment would yield no discriminating credibility information."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Equivalency of input parameters is applicable when validation experiments are conducted on a surrogate or scaled geometry and the mapping of input parameters from the validation configuration to the COU configuration requires formal equivalency arguments (e.g., dimensional analysis, scaling laws). In this assessment the validation experiments are conducted on the FDA generic centrifugal pump, which is the same device geometry used in the COU; no geometric scaling or surrogate substitution is involved. Operating conditions (flow rate, rotational speed, pressure head) in the validation dataset directly overlap the COU operating envelope without requiring any parameter transformation or equivalency mapping. The factor is therefore not-applicable because the validation and COU configurations are directly commensurate without requiring an intermediate equivalency argument."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-nc6-clean",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors achieve their required gradation levels: Software Quality Assurance (3/3), Numerical Code Verification (3/3), Discretization Error (3/3), Test Conditions (3/3), Output Comparison (3/3), Relevance of QoI (4/3, exceeding requirement), and Relevance of Validation Activities to COU (3/3). Six factors — Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, and Equivalency of Input Parameters — are marked not-applicable with documented rationale explaining that each factor is either subsumed within an assessed factor, inapplicable due to the controlled experimental design, or non-discriminating given the direct correspondence between validation and COU configurations. No factor shortfalls exist. The Monte Carlo UQ framework confirms that 95th-percentile NIH predictions remain below the clinical threshold across all operating points. The provenance chain from raw experimental data through validation activities to this decision record is complete and traceable. The package satisfies all ASME VV40 credibility requirements for the stated COU at Model Risk Level 5 and the decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
