  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for non-cannulated pedicle screw compression-bending is accepted as sufficiently credible for the stated COU at Medium assurance level. All 13 V&V 40 factors were assessed. Twelve of thirteen factors achieved required level or above. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3; this shortfall is offset by the inherent constraint of ASTM F1717 to a single standardized condition and the clinical appropriateness of that single condition to the COU. All three QoIs pass the E/uval < 1.96 and percent difference < 10% acceptance bounds across two independent laboratories (N=11 constructs). Sensitivity analysis confirms model predictions are robust to plausible material and contact parameter uncertainties. The provenance chain from experimental data through uncertainty quantification to validation metrics is complete and traceable.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/test-conditions-offset-001",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/factor/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 2 (single standardized condition) against a required Gradation 3 (multiple conditions spanning the COU envelope). This shortfall is justified because: (1) ASTM F1717 prescribes a single quasi-static test condition that is the regulatory standard for pedicle screw construct evaluation; (2) the intended clinical use is quasi-static surgical loading at ambient temperature, which is well-represented by the single tested condition; (3) sensitivity analysis demonstrates that QoI predictions vary by less than 5% across the plausible range of loading rates and environmental conditions; and (4) the conservative acceptance bounds (E/uval < 1.96, percent difference < 10%) provide additional margin against uncharacterized condition variability. The overall evidence base, including multi-laboratory testing and complete uncertainty quantification, supports acceptance at Medium assurance level despite this single factor shortfall."
      },
      {
        "id": "https://uofa.net/synth/decision/noncannulated-decision-001/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/noncannulated-decision-001/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
