  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sa/sa-noncannulated-f1717",
    "type": "SensitivityAnalysis",
    "name": "Sensitivity analysis — non-cannulated pedicle screw FEA inputs",
    "description": "One-at-a-time and variance-based (Sobol) sensitivity analysis conducted over Ti-6Al-4V elastic modulus (+/-10%), yield strength (+/-15%), polyaxial head friction coefficient (0.1–0.3), and rod diameter tolerance (+/-0.05 mm). Construct stiffness QoI is most sensitive to elastic modulus (S1=0.61) and rod diameter (S1=0.22); yield force QoI is dominated by yield strength (S1=0.74). Friction coefficient influence on all QoIs is below 5% first-order index, confirming that the assumed mu=0.2 does not introduce material uncertainty in the validation metric."
  },
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-f1717",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 compression-bending is accepted as credible for the stated COU. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both the relative error threshold (<10%) and the validation metric threshold (E/uval < 1.96). Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions at achievedLevel 2 against requiredLevel 3 — is offset by the comprehensive specimen coverage (N=11 across two laboratories), the direct correspondence between the single validated load case and the regulatory-required ASTM F1717 protocol, and the sensitivity analysis confirming that the dominant uncertainty sources are material properties rather than loading configuration. The offset rationale below documents the specific justification for acceptance despite this gap. Provenance is complete: all validation results trace to primary experimental datasets, FEA activities are version-controlled, and the decision is grounded in structured quantitative evidence.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/or-test-conditions-noncannulated",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "refersToFactor": "https://uofa.net/synth/credibility-factor/test-conditions-noncannulated",
        "justification": "The Test conditions factor achieved Level 2 against a required Level 3 because only the standard ASTM F1717 compression-bending configuration was evaluated. This shortfall is accepted because: (1) ASTM F1717 is the sole regulatory-mandated test configuration for pedicle screw constructs, making additional loading conditions outside the regulatory scope; (2) the N=11 specimen set tested across two independent laboratories provides statistical confidence in the single-condition results that partially compensates for the absence of multi-condition testing; (3) the sensitivity analysis demonstrates that QoI variability is dominated by material property uncertainty rather than loading configuration, so additional load cases would not materially reduce the dominant uncertainty sources; and (4) the model influence is rated Medium (bench testing provides independent confirmation), which limits the consequence of any undetected load-configuration sensitivity.",
        "shortfallDescription": "Test conditions factor achievedLevel (2) is one grade below requiredLevel (3) due to evaluation under a single ASTM F1717 load configuration only."
      },
      {
        "id": "https://uofa.net/synth/decision/dr-noncannulated-f1717/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/dr-noncannulated-f1717/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
