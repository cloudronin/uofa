  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-cdrh",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw under ASTM F1717 static compression-bending is accepted as adequately credible for the stated COU. All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed their required credibility levels. The Test conditions factor achieves its required level (Gradation 2) within the explicitly bounded COU scope limited to the ASTM F1717 standard loading condition. All three QoIs (construct stiffness, yield force, force at 40 mm displacement) show FEA-to-experiment agreement within 3% percentage difference, substantially below the 10% pre-specified acceptance bound. All E/uval values are below 0.75, well within the 1.96 threshold. The three-solver ensemble demonstrates inter-solver spread < 1.5%, confirming numerical robustness. Input uncertainty was formally propagated via Monte Carlo sampling. The model risk level of 3 is consistent with the Medium assurance level and Medium model influence and decision consequence classification. No credibility gaps requiring offset rationale are present. The structured evidence base supports the conclusion that the FEA framework provides adequate credibility for regulatory use in the 510(k) submission context.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
