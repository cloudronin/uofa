  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending is accepted as credible for the stated COU at Medium assurance level. All 13 V&V 40 factors were assessed. Twelve of thirteen factors met or exceeded their required gradation levels. One factor — Test conditions (factorType: Test conditions) — achieved Gradation 2 against a required Gradation 3, reflecting that testing was conducted under a single set of ASTM F1717 conditions. The offset rationale below documents why this shortfall does not undermine the overall credibility determination. The three primary QoIs (stiffness, yield force, force at 40 mm displacement) all satisfy the pre-established quantitative acceptance criteria: E/uval < 1.96 and percent difference < 10%. The validation evidence is drawn from N=11 production-representative constructs across two independent laboratories, providing adequate statistical confidence. Model risk level 3 with Medium model influence and Medium decision consequence yields a required assurance level of Medium, which is satisfied by the overall evidence body.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-offset",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs. required 3)",
        "description": "The Test conditions factor achieved Gradation 2 (single documented test condition) against a required Gradation 3 (two or more systematically varied conditions). This shortfall is accepted for the following reasons: (1) ASTM F1717 specifies a single standardized test configuration, and variation from this protocol would reduce regulatory comparability rather than improve it; (2) the COU is explicitly bounded to quasi-static compression-bending at ambient conditions, so condition variation is outside the scope of the intended use; (3) the shortfall in this factor is offset by above-required performance in six other factors (SQA, Code verification, Use error, Model inputs, Equivalency of input parameters, and QoI relevance), providing compensating evidence of model credibility; (4) the quantitative validation metrics (all E/uval < 1.96) demonstrate that the model reproduces experimental behavior within pre-established bounds under the single condition tested, which is the condition of regulatory interest. The assessment team concludes that the single-condition limitation does not materially reduce confidence in the model's fitness for the stated COU."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
