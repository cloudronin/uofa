  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Full 13-factor assessment completed; all factors assessed with achieved levels meeting or exceeding required levels. Monte Carlo uncertainty quantification performed across all operating points. Decision: Accepted.",
  "assuranceLevel": "High",
  "modelRiskLevel": 5,
  "deviceClass": "Class III",
  "couName": "VAD use",
  "decision": "Accepted",
  "bindsRequirement": "https://uofa.net/morrison/req/vad-hemolysis-absolute",
  "bindsClaim": "https://uofa.net/morrison/claim/cfd-hemolysis-vad-class3",
  "bindsModel": "https://uofa.net/morrison/model/cfd-centrifugal-pump-v3",
