  ],
  "hasSensitivityAnalysis": true,
  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/morrison/sensitivity/vad-cou2-sa",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis for VAD hemolysis CFD predictions",
    "description": "A variance-based (Sobol) global sensitivity analysis was conducted over seven input parameters: blood viscosity (±15%), pump rotational speed (±5%), inlet flow rate (±10%), turbulence model constant C_mu (±20%), red blood cell fragility index (±25%), mesh density scaling factor (±30%), and inlet velocity profile shape. Hemolysis index (HI) exhibited first-order Sobol indices dominated by rotational speed (S1=0.41) and RBC fragility index (S1=0.29), with turbulence model constant contributing a total-effect index of 0.18. Inlet flow rate and viscosity showed negligible interaction effects. The analysis confirmed that uncertainty in the RBC fragility sub-model is the primary driver of HI prediction variance, motivating targeted experimental characterisation of fragility parameters for the specific blood analogue used in bench validation."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis CFD applicability domain",
      "description": "The CFD model is applicable to single-stage centrifugal blood pumps with impeller tip diameters between 30 mm and 60 mm, operating with Newtonian blood analogues at haematocrit between 35% and 45%. The hemolysis sub-model (power-law Giersiepen-Wurzinger formulation) is valid only for shear stresses below 400 Pa and exposure times below 700 ms per fluid parcel trajectory. The model is not applicable to axial-flow pumps, pulsatile flow waveforms with peak-to-trough ratio exceeding 3:1, or blood temperatures outside 35–39 °C."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD operating envelope — FDA generic centrifugal pump",
      "description": "Volumetric flow rate: 2.5 L/min to 7.0 L/min. Rotational speed: 2000 RPM to 3500 RPM. Inlet pressure: 5 mmHg to 15 mmHg. Outlet pressure head: 60 mmHg to 120 mmHg. Fluid temperature: 36 °C ± 1 °C. Haematocrit: 40% ± 5%. Five nominal operating points (Q, N) evaluated: (3.0 L/min, 2400 RPM), (4.5 L/min, 2800 RPM), (5.0 L/min, 3000 RPM), (6.0 L/min, 3200 RPM), (6.5 L/min, 3400 RPM). Geometric tolerance on impeller clearance gap: 0.15 mm ± 0.02 mm."
    }
  },
