  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/senior-credibility-assessor",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed with achieved levels meeting or exceeding required levels for Model Risk Level 5. The primary QoI (normalised index of hemolysis) is predicted within combined simulation and experimental uncertainty at all five operating points. Monte Carlo uncertainty quantification confirms probability of exceeding clinical hemolysis threshold is below 0.3%. Global sensitivity analysis identifies RBC fragility index as the dominant uncertainty driver; this parameter has been experimentally characterised with documented 95% CI. Discretization error (GCI < 1.8%) and iterative convergence (residuals < 1e-6) are well controlled. Validation activities used the identical device geometry at conditions spanning the full COU envelope. Independent second-engineer review of simulation setup eliminates use error concerns. The evidence chain from foundational PIV measurements through hemolysis bench validation to Monte Carlo uncertainty propagation is complete and traceable. The credibility evidence is sufficient to support regulatory submission for a Class III VAD device under ASME V&V 40 at Model Risk Level 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
