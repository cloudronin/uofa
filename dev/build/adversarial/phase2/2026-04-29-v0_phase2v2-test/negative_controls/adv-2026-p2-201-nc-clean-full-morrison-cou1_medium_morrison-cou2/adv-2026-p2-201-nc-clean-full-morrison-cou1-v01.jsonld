  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/vad-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achieved levels meet or exceed required levels for Model Risk Level 5. The CFD hemolysis prediction model demonstrates: (1) formal software quality assurance with independent audit; (2) code verification against analytical benchmarks with correct convergence order; (3) discretization error quantified via three-level GCI analysis (GCI_fine = 2.1%); (4) fully characterized experimental test conditions with NIST-traceable measurements; (5) quantitative output comparison showing mean NIH error 8.3% within 15% acceptance threshold; (6) validation QoI identical to COU decision QoI; (7) validation experiments on the same device geometry spanning the COU operating envelope; (8) iterative and round-off error characterized and bounded; (9) workflow governed by approved SOP with independent peer review; (10) turbulence and hemolysis model form uncertainty quantified via ensemble approach; (11) all model inputs characterized with uncertainty distributions propagated via 2000-sample Monte Carlo; (12) three independently manufactured test articles with inter-article variability assessed; (13) formal equivalency assessment for all experimental-to-CFD boundary condition mappings. The Monte Carlo UQ analysis demonstrates that 95% prediction intervals encompass all experimental measurements. The global sensitivity analysis confirms that dominant uncertainty sources (hemolysis exponent α, rotational speed) are adequately characterized. The totality of evidence supports acceptance of the CFD model for predicting absolute hemolysis levels in the Class III VAD COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
