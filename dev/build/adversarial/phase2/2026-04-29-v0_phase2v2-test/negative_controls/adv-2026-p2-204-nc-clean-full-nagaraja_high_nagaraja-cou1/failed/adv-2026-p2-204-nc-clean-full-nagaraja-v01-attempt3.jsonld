  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/org/nagaraja-research-group/credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for non-cannulated pedicle screw compression-bending is accepted as credible for the stated COU. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy the pre-established acceptance criteria: E/uval < 1.96 and MAPE < 10%. Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is offset by the strength of evidence across the remaining factors: (1) the single test condition is the normative ASTM F1717 condition and is directly aligned with the regulatory submission context; (2) the sensitivity analysis demonstrates that QoI predictions are robust to material property and contact parameter variation within the operating envelope; (3) three independent modeling teams produced consistent results, reducing the probability of systematic use error; (4) the validation sample spans two independent laboratories, providing inter-laboratory reproducibility evidence that partially compensates for the absence of multi-condition testing. The model risk level (3) and medium model influence/decision consequence classification are consistent with the depth of evidence provided. The credibility assessment team unanimously concludes that the overall body of evidence is sufficient to support use of the FEA framework in the regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated/offset-test-conditions",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs. required 3)",
        "refersToFactor": "https://uofa.net/nagaraja/credibility-factor/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 2 (single standard ASTM F1717 condition) against a required Gradation 3. This shortfall is accepted because: (1) the single test condition is the normative regulatory standard condition and the only condition relevant to the intended COU (ASTM F1717 static compression-bending for 510(k) submission); (2) the sensitivity analysis (hasSensitivityAnalysis) demonstrates that model predictions are robust to ±5 GPa material modulus variation and friction coefficient variation 0.1–0.4, indicating that the model would perform consistently across minor test condition perturbations; (3) the three-ensemble, two-laboratory validation design provides orthogonal evidence of robustness that partially substitutes for multi-condition testing; and (4) the medium model influence classification means that the FEA is confirmatory rather than decision-driving, reducing the risk consequence of the test condition limitation."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
