  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/nagaraja/cf/software-qa",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Ansys Mechanical 2023 R1 is a commercially validated FEA solver with documented V&V per ISO 9001:2015 and FDA 21 CFR Part 820 software quality requirements. The FDA in-house solver (FEBio 3.5) is open-source with published benchmark suite. DePuy Synthes proprietary solver has internal SQA documentation per IEC 62304. All three solvers passed the NAFEMS benchmark suite relevant to nonlinear contact mechanics. Configuration management via Git with tagged releases; all simulation scripts version-controlled and archived.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/software-qa-ac",
        "type": "AcceptanceCriteria",
        "name": "Software QA acceptance criteria",
        "description": "All simulation software must be commercially validated or have published benchmark results demonstrating correctness for nonlinear contact mechanics. Version control and configuration management documentation must be present. Achieved Gradation 3 exceeds required Gradation 2."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/numerical-code-verification",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Code verification performed against three NAFEMS benchmark problems: (1) large-displacement beam bending (LE10), (2) nonlinear contact patch test, and (3) elasto-plastic notched bar. All three solvers reproduced reference solutions within 0.5% for linear quantities and within 2% for post-yield quantities. Manufactured solution verification performed for the contact formulation using a Hertzian contact problem with analytical solution; maximum error 0.8%.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/numerical-code-verification-ac",
        "type": "AcceptanceCriteria",
        "name": "Numerical code verification acceptance criteria",
        "description": "Solver must reproduce NAFEMS benchmark solutions within 2% for all relevant problem classes. Manufactured solution or analytical verification required for contact formulation. Achieved Gradation 3 exceeds required Gradation 2."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/discretization-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Mesh convergence study performed with four mesh refinement levels (coarse: 28k elements; medium: 112k; fine: 445k; extra-fine: 1.78M). Richardson extrapolation applied to construct stiffness and yield force QoIs. Grid Convergence Index (GCI) for the production mesh (fine, 445k elements): GCI_stiffness = 0.6%, GCI_yield = 1.1%. Both below the 2% discretization error budget allocated in the uncertainty budget. Mesh quality metrics (Jacobian ratio, aspect ratio) confirmed for all elements.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/discretization-error-ac",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria",
        "description": "GCI for all primary QoIs must be < 2% on the production mesh. Richardson extrapolation must be applied across a minimum of three mesh refinement levels with consistent refinement ratio. Achieved Gradation 3 meets required Gradation 3."
      }
    },
    {
      "id": "https://uofa.net/nagaraja/cf/numerical-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Iterative solver convergence monitored via force residual norm (tolerance 1e-6) and displacement residual norm (tolerance 1e-6) for all load steps. Time-step sensitivity study confirmed that halving the load increment changed QoIs by less than 0.3%. Contact penetration tolerance set to 0.001 mm; sensitivity to contact tolerance (±50%) showed less than 0.4% change in stiffness QoI. All runs achieved full convergence with no diverged load steps.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/numerical-solver-error-ac",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error acceptance criteria",
        "description": "Force and displacement residual norms must converge to < 1e-5. Load-step sensitivity must show < 1% change in QoIs upon halving the increment. Achieved Gradation 3 exceeds required Gradation 2."
      }
    },
    {
