  "hasSensitivityAnalysis": true,
  "sensitivityAnalysisDetail": {
    "id": "https://uofa.net/nagaraja/sensitivity/cou1-noncannulated-sa01",
    "type": "SensitivityAnalysis",
    "name": "Material property and contact stiffness sensitivity analysis — non-cannulated pedicle screw FEA",
    "description": "A one-at-a-time sensitivity analysis was performed varying Ti-6Al-4V elastic modulus (±10%), yield strength (±15%), and rod-screw interface contact stiffness (±25%) across the full N=11 construct ensemble. Construct stiffness QoI showed less than 4% variation to modulus perturbations and less than 2% to contact stiffness perturbations, confirming that yield force and 40 mm displacement force predictions are primarily governed by geometry and loading configuration rather than material uncertainty. A secondary Sobol variance decomposition confirmed that geometry scan uncertainty contributed less than 8% of total output variance, supporting the adequacy of the mesh resolution adopted."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated pedicle screw applicability domain",
      "description": "This COU applies exclusively to solid (non-cannulated) pedicle screw constructs with nominal outer diameter 7.0–8.0 mm and thread pitch 2.0–2.75 mm, fabricated from Ti-6Al-4V ELI per ASTM F136, tested under ASTM F1717 static compression-bending with a standardized UHMWPE block fixture. The model is not applicable to cannulated designs, fenestrated screws, or constructs loaded in axial tension or torsion without separate validation. Patient-specific bone quality effects are explicitly excluded from this COU."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 compression-bending operating envelope — non-cannulated 7.5 mm construct",
      "description": "The validated operating envelope spans: applied compressive force 0–3500 N; crosshead displacement 0–45 mm; loading rate 5 mm/min (quasi-static, strain rate < 0.001 s⁻¹); ambient temperature 20–25 °C; rod diameter 5.5 mm CoCr; screw insertion torque 4.0–6.0 N·m; inter-screw span 44 mm (ASTM F1717 standard). Extrapolation beyond these bounds — including dynamic loading, elevated temperature, or alternative rod materials — requires additional validation activities and is outside the scope of this COU."
    }
  },
