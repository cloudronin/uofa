  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — reflects the single-condition ASTM F1717 protocol, which is the regulatory standard for this device class and is not a modeling deficiency. All three QoIs pass the pre-established ASME V&V 40 validation metric (E/uval < 1.96) with relative errors below 3%. The FEA ensemble of three independent codes produces inter-code spread below 2.1%, confirming model form robustness. Sensitivity analysis confirms that the dominant uncertainty source (Ti-6Al-4V yield strength) is characterized per-lot. The overall evidence package provides Medium credibility commensurate with the MRL 3 / Medium model risk classification. The decision to accept is further supported by the offset rationale addressing the Test conditions shortfall.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/credibility-factor/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 2 (single test condition documented and controlled) rather than the required Gradation 3 (multiple conditions spanning the operating envelope). This shortfall is offset by three compensating strengths: (1) the single test condition is the ASTM F1717 regulatory standard, which is the only condition required for 510(k) clearance of this device class; (2) the operating envelope is narrow and well-characterised — the sensitivity analysis demonstrates that QoI variation across the full parameter space is below 3.2%, indicating that a single representative condition is sufficient to characterise model behaviour; and (3) the multi-laboratory design (two independent laboratories, N=11 specimens) provides a degree of condition variability (inter-laboratory fixture compliance differences of up to 4%) that partially compensates for the absence of deliberate load-condition variation. The residual risk from this shortfall is therefore low and does not undermine the Medium credibility determination.",
        "name": "Offset rationale for Test conditions Gradation 2 vs. required Gradation 3"
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
