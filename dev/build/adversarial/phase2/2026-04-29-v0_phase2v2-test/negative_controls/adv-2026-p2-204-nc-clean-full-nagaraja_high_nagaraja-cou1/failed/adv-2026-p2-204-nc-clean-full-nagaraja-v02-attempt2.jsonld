    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated pedicle screw applicability domain",
      "description": "Model applicability is restricted to non-cannulated titanium-alloy pedicle screws with outer diameter 7.0–8.0 mm, thread pitch 2.75–3.00 mm, and construct configurations conforming to ASTM F1717 two-level corpectomy surrogate geometry. Application to cannulated designs, cortical-trajectory screws, or non-ASTM loading fixtures is outside scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 compression-bending operating envelope",
      "description": "Valid operating bounds: axial compressive load 0–2500 N applied at 10 mm/min crosshead displacement rate; construct offset 31 mm per F1717 §8; UHMWPE block modulus 0.9–1.1 GPa; titanium alloy (Ti-6Al-4V ELI) yield strength 795–965 MPa; ambient temperature 20–25 °C; relative humidity 40–60%. Predictions outside these bounds require separate validation."
    }
  },
  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/nagaraja/sensitivity/cou1-noncannulated",
    "type": "SensitivityAnalysis",
    "name": "COU1 parametric sensitivity analysis — material and contact parameters",
    "description": "One-at-a-time and Morris screening sensitivity analyses were conducted varying Ti-6Al-4V elastic modulus (±5%), cortical block friction coefficient (0.1–0.4), screw-rod interface stiffness (±20%), and UHMWPE block modulus (±10%). Construct stiffness QoI showed less than 3.2% variation across the full parameter space; yield force QoI was most sensitive to titanium yield strength (rank-1, normalized sensitivity index 0.61), confirming that material yield properties must be characterized per-lot for highest-fidelity predictions."
  },
