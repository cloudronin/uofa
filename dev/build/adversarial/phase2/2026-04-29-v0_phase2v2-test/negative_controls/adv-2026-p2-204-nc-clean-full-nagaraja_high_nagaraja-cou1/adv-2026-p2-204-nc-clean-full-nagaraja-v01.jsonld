  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for the non-cannulated 7.5 mm pedicle screw under ASTM F1717 compression-bending has been assessed against all 13 ASME V&V 40 factors. All factors achieved levels at or above their required levels for MRL 3 / Medium assurance. The three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both the <10% percent difference criterion and the E/uval < 1.96 criterion against N=11 experimental replicates across two independent laboratories. Sensitivity analysis identified screw-rod friction coefficient and polyethylene block modulus as the dominant uncertainty contributors; both were characterized and propagated through the model ensemble. Software QA, code verification, mesh convergence, and input equivalency are all documented to the required standard. The validation activities are directly representative of the COU with no extrapolation gap. The credibility assessment team unanimously accepts the FEA framework as fit for the intended regulatory purpose of supporting a 510(k) submission for the non-cannulated pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
