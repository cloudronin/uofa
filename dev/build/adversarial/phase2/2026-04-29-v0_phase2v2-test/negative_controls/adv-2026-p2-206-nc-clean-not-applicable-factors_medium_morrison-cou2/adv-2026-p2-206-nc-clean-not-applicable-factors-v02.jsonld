    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "All model inputs (fluid density, viscosity, hemolysis model constants C and α, pump geometry) documented with sources and uncertainty ranges. Monte Carlo sampling distributions defined for all uncertain inputs; sensitivity analysis identifies hemolysis exponent α as dominant contributor (37% of output variance). Input uncertainty propagated through all five operating points.",
      "acceptanceCriteria": {
