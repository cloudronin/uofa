  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-nc6-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 11 assessed credibility factors achieve levels meeting or exceeding their required levels for MRL 5 / Class III context. Software quality assurance (3/3), numerical code verification (3/3), discretization error (4/3, exceeds requirement), test conditions (3/3), output comparison (3/3), QoI relevance (3/3), validation relevance (3/3), numerical solver error (2/2), use error (2/2), model form (3/3), and model inputs (3/3) are all satisfied. Two factors — Test samples and Equivalency of input parameters — are marked not-applicable with thorough rationale: the FDA generic pump reference geometry eliminates test sample variability concerns, and direct fluid matching eliminates the need for equivalency transformation. Monte Carlo UQ confirms all 95th-percentile NIH predictions remain below the clinical threshold (0.1 g/100L) at all five operating points. The validation evidence is directly relevant to the COU geometry and operating envelope. The provenance chain is complete from raw experimental data through validation activities to this assessment. The decision team concludes the credibility evidence is sufficient to support regulatory submission of CFD hemolysis predictions for this Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
