  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All eleven assessed credibility factors achieve levels meeting or exceeding their required levels for Model Risk Level 5. Two factors (Test samples, Equivalency of input parameters) are marked not-applicable with documented rationale: the former because synthetic blood analog eliminates biological specimen variability, the latter because validation was conducted on the identical pump geometry as the COU. The Monte Carlo UQ analysis confirms the 95th-percentile hemolysis prediction (NIH = 0.0031 g/100L) remains below the clinical acceptance threshold (0.0050 g/100L) with margin. Discretization error (GCI < 2.1%) and output comparison error (max |E| = 8.3%) are both within required bounds. The provenance chain from raw PIV and hemolysis bench data through validation results to this assurance package is complete and traceable. On the basis of the structured credibility evidence, the CFD hemolysis model is accepted for use in predicting absolute hemolysis levels for the Class III VAD device under the specified COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
