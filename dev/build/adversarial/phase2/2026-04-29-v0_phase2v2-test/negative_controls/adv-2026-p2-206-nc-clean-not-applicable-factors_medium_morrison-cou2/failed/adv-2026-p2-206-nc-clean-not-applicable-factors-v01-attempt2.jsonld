      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Validation dataset comprises measurements from three independent experimental campaigns using the FDA benchmark pump with bovine blood analogue. Sample sizes are sufficient for statistical characterisation of measurement variability; inter-laboratory reproducibility is documented.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/test-samples",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria — Gradation 3",
        "description": "Validation measurements from at least two independent experimental sources; sample size sufficient to estimate measurement mean and standard deviation; outlier treatment documented; measurement uncertainty reported per ISO/IEC 17025."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
