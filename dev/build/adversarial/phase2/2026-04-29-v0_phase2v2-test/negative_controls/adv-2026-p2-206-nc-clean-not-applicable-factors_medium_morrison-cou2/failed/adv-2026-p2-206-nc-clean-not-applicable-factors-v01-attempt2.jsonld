    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Numerical solver error as a distinct credibility factor addresses iterative convergence errors and round-off accumulation in solvers that employ iterative linear algebra (e.g. pressure-velocity coupling in segregated solvers with loose convergence tolerances). In this assessment the CFD solver employs a coupled pressure-velocity algorithm with tight residual tolerances (L2 residual < 1e-8 for all equations) and double-precision arithmetic throughout. Iterative convergence is verified at every time step and documented in solver logs; no appreciable solver error contribution to QoI uncertainty has been identified in the GCI study. Consequently this factor does not constitute a meaningful independent source of credibility gap for this COU and is marked not-applicable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-applicable",
      "rationale": "Use error addresses the risk that analysts incorrectly apply the simulation tool through misinterpretation of input parameters, incorrect boundary condition specification, or misuse of post-processing scripts. In this COU the simulation workflow is fully automated through a validated simulation management platform with input validation checks, locked boundary condition templates, and mandatory peer review of all case setup files prior to execution. The platform enforces parameter ranges consistent with the COU operating envelope and flags out-of-range inputs as errors. Given these controls, residual use error is not a credible independent failure mode for this assessment and the factor is marked not-applicable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "At MRL 5 the model form (SST k-ω turbulence model; power-law hemolysis model of Giersiepen et al.) must be justified against alternatives and validated. Turbulence model selection is supported by sensitivity study comparing SST k-ω, realizable k-ε, and LES; SST k-ω shows best agreement with PIV data. Hemolysis model form uncertainty is propagated via Monte Carlo over model exponent range.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-form",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria — Gradation 4",
        "description": "Turbulence model selection justified by comparison of at least two candidate models against experimental data; hemolysis constitutive model form uncertainty quantified and included in total uncertainty budget; model form assumptions documented in V&V report."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "All model inputs (geometry, fluid properties, boundary conditions, hemolysis model coefficients) are documented with sources and uncertainty ranges. Sensitivity analysis identifies inlet velocity profile and hemolysis exponent as dominant uncertain inputs; these are prioritised in Monte Carlo UQ.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria — Gradation 3",
        "description": "All inputs listed in input parameter table with nominal value, uncertainty range, and source reference; sensitivity analysis performed to rank input influence on NIH; top-ranked uncertain inputs propagated through Monte Carlo UQ."
      }
    },
    {
