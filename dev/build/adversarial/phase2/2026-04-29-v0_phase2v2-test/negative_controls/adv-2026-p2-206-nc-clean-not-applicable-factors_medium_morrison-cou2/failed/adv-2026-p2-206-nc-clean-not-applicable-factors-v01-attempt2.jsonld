        "type": "AcceptanceCriteria",
        "name": "Validation relevance acceptance criteria — Gradation 3",
        "description": "Validation geometry is identical to COU device geometry; fluid properties match within stated haematocrit tolerance; at least 4 of 5 COU operating points are directly covered by validation experiments; remaining point is within interpolated envelope."
      }
