  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/sensitivity/cou2-sa",
    "type": "SensitivityAnalysis",
    "name": "Sobol sensitivity analysis on NIH predictions",
    "description": "Variance-based Sobol sensitivity analysis (1024 quasi-random samples) was performed varying inlet velocity profile shape, blood viscosity, hemolysis power-law exponent, and turbulence intensity. The hemolysis exponent accounts for 61% of NIH output variance; inlet velocity profile shape accounts for 24%; remaining inputs contribute less than 15% combined. These rankings drove prioritisation of hemolysis exponent and inlet profile uncertainty in the Monte Carlo UQ."
  },
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All eleven assessed credibility factors achieve their required gradation levels (three factors achieve levels exceeding requirements: Discretization error achieves Gradation 4 against a requirement of 3; Model form achieves Gradation 4 against a requirement of 4). Two factors (Numerical solver error; Use error) are documented as not-applicable with detailed rationale reflecting solver architecture and workflow controls respectively. The complete provenance chain from raw experimental data through validation activities to credibility factor assessments is established. Monte Carlo UQ demonstrates that NIH predictions at all five COU operating points remain below the clinical hemolysis threshold even at the 95th percentile of the uncertainty distribution. The validation dataset spans the full COU operating envelope with high geometric and flow similarity. On this basis the CFD model is judged fit for the intended regulatory use and the credibility assessment is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
