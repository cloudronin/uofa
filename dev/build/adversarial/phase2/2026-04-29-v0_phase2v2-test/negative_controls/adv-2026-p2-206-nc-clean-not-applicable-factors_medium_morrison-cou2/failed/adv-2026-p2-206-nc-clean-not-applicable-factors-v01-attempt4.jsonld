  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All eleven assessed credibility factors achieve their required gradation levels or exceed them (Discretization error achieves Gradation 4 against a Gradation 3 requirement). Two factors — Numerical solver error and Use error — are documented as not-applicable with thorough rationale: solver error is subsumed by the SQA and code verification factors for the commercial solver configuration used; use error does not apply because the model is developed and deployed by the same qualified team under a locked QMS with no external user population. The Monte Carlo uncertainty quantification (2000 samples) confirms that all five NIH predictions fall within the 95 % prediction interval, and the Sobol sensitivity analysis identifies rotational speed and the power-law exponent as the dominant uncertainty drivers, enabling targeted monitoring. The validation evidence is directly relevant to the COU: the same FDA generic pump geometry and operating envelope are used in both validation and deployment. Combined experimental and numerical uncertainty budgets are within the tolerances required for the absolute hemolysis threshold decision. On the basis of this structured evidence, the credibility package is accepted for regulatory submission supporting the Class III VAD device hemolysis claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
