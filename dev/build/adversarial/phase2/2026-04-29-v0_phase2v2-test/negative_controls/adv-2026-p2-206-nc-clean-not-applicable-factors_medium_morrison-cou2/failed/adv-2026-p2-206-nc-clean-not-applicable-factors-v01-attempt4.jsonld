    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Validation experiments use the identical FDA generic centrifugal pump geometry and the same five operating points as the COU. Blood analogue fluid properties are matched to physiological haematocrit range. The validation domain is co-extensive with the COU operating envelope, satisfying Gradation 3 relevance requirements.",
