  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "description": "Applicable to centrifugal blood pump geometries conforming to the FDA generic pump benchmark, operating within the VAD flow-speed envelope defined herein. The constraint excludes axial-flow pump configurations, pulsatile assist devices, and operating points outside the 2–6 L/min flow range or 2000–4000 RPM speed range. Blood rheology is modelled as non-Newtonian (Carreau-Yasuda); Newtonian approximations are excluded from the applicability domain.",
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "name": "FDA generic centrifugal pump VAD applicability constraint",
      "type": "ApplicabilityConstraint"
    },
    "hasOperatingEnvelope": {
      "description": "Operating envelope for the VAD COU: volumetric flow rate 2–6 L/min; rotational speed 2000–4000 RPM; inlet pressure 5–15 mmHg; outlet pressure 60–120 mmHg; blood temperature 36–38 °C; haematocrit 35–45 %. Five discrete flow-speed combinations span the envelope corners and centroid. Monte Carlo perturbations of ±10 % on viscosity parameters and ±5 % on geometry tolerances are included within this envelope.",
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "name": "VAD centrifugal pump operating envelope",
      "type": "OperatingEnvelope"
    },
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
