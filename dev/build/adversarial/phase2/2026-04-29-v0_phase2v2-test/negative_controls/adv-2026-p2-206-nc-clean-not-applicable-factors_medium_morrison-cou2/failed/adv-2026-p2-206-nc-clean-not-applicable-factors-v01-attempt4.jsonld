  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/hemolysis-sa",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Sobol sensitivity analysis on hemolysis model inputs",
    "description": "A Sobol first- and total-order sensitivity analysis was performed across six model inputs (inlet flow rate, rotational speed, blood viscosity, red blood cell fragility coefficient, power-law exponent, and mesh resolution proxy). Rotational speed and the power-law exponent together account for 71 % of NIH output variance; inlet flow rate contributes 18 %. Viscosity and fragility coefficient are individually below 5 % total-order index, confirming that the Monte Carlo uncertainty budget is dominated by operating-condition variability rather than material-property uncertainty."
