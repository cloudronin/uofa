  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 11 assessed credibility factors achieve their required levels under ASME V&V 40-2018 at Model Risk Level 5. Discretization error exceeds its required level (achieved 4, required 3), providing additional confidence margin. The two not-applicable factors (Test samples and Equivalency of input parameters) are excluded with thorough rationale: validation was conducted directly on the target geometry under COU-equivalent conditions, eliminating the need for equivalency bridging, and no physical specimen sampling variability is present in this CFD assessment. Monte Carlo uncertainty quantification bounds the 95th-percentile NIH prediction below the clinical threshold of 0.01 g/100 L across all 5 operating points. The provenance chain is complete from raw experimental measurements through validation activity records to this UnitOfAssurance. The credibility assessment team unanimously accepts the CFD hemolysis model as credible for the stated COU.",
