  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending has been assessed against all 13 V&V 40 credibility factors. Twelve of thirteen factors meet or exceed their required credibility levels. The single shortfall — Test conditions (achieved Gradation 2, required Gradation 3) — reflects the limitation to a single ASTM F1717 static protocol condition. This shortfall is offset by the high performance on Output comparison (E/uval < 1.96 for all QoIs), Equivalency of input parameters (Gradation 3, all inputs directly measured), and Relevance of validation activities to the COU (Gradation 3, no applicability gap). The model risk level is 3 (Medium), and both model influence and decision consequence are Medium, consistent with the Medium assurance level. The quantitative validation evidence (percent difference < 10%, E/uval < 1.96 for stiffness, yield force, and force at 40 mm across N=11 constructs at two laboratories) provides sufficient confidence that the FEA framework reliably predicts the relevant QoIs within the COU. Acceptance is justified.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 2 against a required Gradation 3 because only a single ASTM F1717 static compression-bending protocol condition was evaluated; fatigue and dynamic conditions were not included. This shortfall is offset by three compensating strengths: (1) Output comparison achieved Gradation 3 with E/uval well below 1.96 for all three QoIs across all 11 constructs, demonstrating robust predictive accuracy within the evaluated condition; (2) Equivalency of input parameters achieved Gradation 3 with all primary inputs directly measured from test specimens, minimising parametric uncertainty that could mask condition-dependent errors; and (3) the COU is explicitly scoped to static compression-bending per ASTM F1717, so the single-condition limitation is co-extensive with the full COU scope rather than representing an extrapolation gap. The clinical decision consequence is Medium (revision surgery risk, not mortality), and the model influence is Medium (bench testing confirms FEA results), further supporting acceptance despite the single-condition limitation.",
        "description": "Offset rationale addressing the Test conditions factor shortfall (achievedLevel 2 vs. requiredLevel 3) for the non-cannulated pedicle screw COU1 credibility assessment."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
