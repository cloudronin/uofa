  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/nagaraja/sensitivity/noncannulated-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Material property and contact stiffness sensitivity analysis — non-cannulated construct",
    "description": "A one-at-a-time sensitivity analysis was performed varying titanium alloy Young's modulus (±10%), cortical bone surrogate UHMWPE block modulus (±15%), and rod-screw interface contact stiffness (±20%). Construct stiffness QoI varied by at most 6.3% across all perturbations; yield force QoI varied by at most 4.8%, confirming that model predictions are not dominated by uncertainty in any single input parameter and that the <10% acceptance bound is robust to plausible input variation."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated titanium pedicle screw, ASTM F1717 static loading only",
      "description": "This COU applies exclusively to solid (non-cannulated) titanium alloy pedicle screws with nominal outer diameter 7.5 mm, assessed under quasi-static ASTM F1717 compression-bending protocol. The model is not applicable to cannulated variants, dynamic fatigue loading, polyaxial head configurations, or screws with outer diameter outside the range 7.0–8.0 mm. Clinical in-vivo loading scenarios are explicitly excluded from this COU."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ASTM F1717 quasi-static compression-bending test parameters",
      "description": "The operating envelope for this COU is defined by the following concrete bounds: applied compressive load range 0–2500 N; crosshead displacement rate 5 ± 1 mm/min; UHMWPE block modulus 930 ± 50 MPa; titanium alloy (Ti-6Al-4V ELI) Young's modulus 114 ± 6 GPa; screw outer diameter 7.5 mm (tolerance ±0.05 mm); rod diameter 5.5 mm CoCr; construct span per ASTM F1717 fixture geometry (44 mm between block faces). Predictions outside these parameter bounds require additional validation evidence."
    }
  },
