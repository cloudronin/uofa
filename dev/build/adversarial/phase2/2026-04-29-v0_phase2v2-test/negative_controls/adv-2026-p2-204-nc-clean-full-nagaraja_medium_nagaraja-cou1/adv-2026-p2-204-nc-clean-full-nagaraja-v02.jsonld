    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated 7.5 mm pedicle screw, ASTM F1717 static loading only",
      "description": "This COU applies exclusively to non-cannulated pedicle screws with nominal diameter 7.0–8.0 mm and rod diameter 5.5–6.0 mm, tested under quasi-static ASTM F1717 compression-bending at room temperature in air. The model is not applicable to cannulated variants, dynamic fatigue loading, or in vivo bone-implant constructs. Extrapolation beyond the validated geometry envelope (screw length 40–55 mm, rod length 100–120 mm) requires additional validation."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ASTM F1717 compression-bending test parameters",
      "description": "Crosshead displacement rate: 5 mm/min ± 0.5 mm/min. Applied compressive load range: 0–2500 N. Test block separation: 50 mm ± 1 mm (per ASTM F1717 §8.2). Ambient temperature: 20–25 °C. Relative humidity: 40–60% RH. Screw insertion torque: 4.0–6.0 N·m. Rod diameter: 5.5 mm or 6.0 mm Ti-6Al-4V ELI. These bounds define the domain within which the FEA model has been validated and outside which predictions must not be used without additional credibility assessment."
    }
  },
