  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model for non-cannulated 7.5 mm pedicle screw compression-bending under ASTM F1717 is accepted as credible for the stated COU at MRL 3 / Medium assurance level. All three primary QoIs (stiffness, yield force, force at 40 mm displacement) satisfy both quantitative acceptance criteria (percent difference < 10%, E/uval < 1.96). Twelve of thirteen V&V 40 factors meet or exceed their required gradation levels. The single shortfall — Test conditions assessed at Gradation 1 against a required Gradation 2 — is addressed by the offset rationale below. The sensitivity analysis confirms that model predictions are robust to plausible input perturbations (< 6% QoI variation). The provenance chain is complete from raw experimental data through FEA ensemble predictions to validated QoI comparisons. The decision is supported by the structured evidence package and is consistent with FDA guidance on computational modeling submissions for Class II orthopedic devices.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
      "type": "OffsetRationale",
      "name": "Offset rationale for Test conditions shortfall (Gradation 1 vs. required Gradation 2)",
      "refersToFactor": "https://uofa.net/nagaraja/cf/test-conditions",
      "justification": "The Test conditions factor achieved Gradation 1 (single test condition) against a required Gradation 2 (at least two conditions varied). This shortfall is accepted on the following grounds: (1) ASTM F1717 prescribes a single standardized test condition for regulatory submissions, making multi-condition testing a departure from the standard rather than an enhancement; (2) the sensitivity analysis demonstrates that model predictions vary by less than 6% across plausible perturbations of loading rate (±50%), block separation (±2 mm), and temperature (18–37 °C), confirming that the single validated condition is representative of the operating envelope; (3) the two remaining QoIs (yield force and force at 40 mm) show E/uval values of 1.12 and 1.04 respectively, providing substantial margin below the 1.96 threshold, indicating that model accuracy is not marginal; (4) the validation was conducted across two independent laboratories, providing orthogonal evidence of reproducibility that partially compensates for the absence of multi-condition testing. The residual risk from this shortfall is judged to be low given the conservative acceptance thresholds and the robustness demonstrated in the sensitivity analysis."
    }
  },
