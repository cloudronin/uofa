  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling ensemble for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as sufficiently credible for the stated COU. All three QoIs satisfy E/uval < 1.96 and percentage differences < 2%, well within the pre-specified 10% acceptance bound. Twelve of thirteen V&V 40 factors meet or exceed their required credibility levels. The single shortfall — Test conditions (achieved level 2 vs. required level 3) — is accepted under the offset rationale documented in hasOffsetRationale: the COU is explicitly bounded to ASTM F1717 static compression-bending, the single test condition is fully standardized and reproducible across two independent ISO-accredited laboratories, and the sensitivity analysis confirms that loading rate variation within ±10% of nominal produces <1.5% change in all QoIs. The ensemble approach (three independent FEA implementations reaching concordant predictions) provides additional assurance beyond what any single model could provide. Model risk level 3 is appropriate for a Class II device with medium model influence and medium decision consequence. The credibility assessment is complete, traceable, and sufficient to support regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (achieved 2, required 3)",
        "description": "The Test conditions factor achieved level 2 against a required level 3 because testing was performed under a single standardized loading condition (ASTM F1717 static compression-bending at 5 mm/min) rather than across multiple loading conditions or rates. This shortfall is accepted for the following reasons: (1) The COU is explicitly restricted to F1717 static testing; dynamic and fatigue loading are out of scope and addressed in separate COUs. (2) The single test condition is a recognized international standard, ensuring the condition is precisely defined and reproducible. (3) Inter-laboratory testing at two ISO 17025-accredited facilities confirms that the test condition is reproducibly implemented, providing confidence that condition variability does not inflate experimental uncertainty. (4) The one-at-a-time sensitivity analysis demonstrates that ±10% variation in crosshead displacement rate produces <1.5% change in all three QoIs, confirming that the model is not sensitive to the specific rate value within the standardized range. (5) The ensemble approach — three independent FEA implementations reaching concordant predictions — provides additional assurance that the model form and inputs are not tuned to a single dataset. Collectively, these offsets are sufficient to accept the credibility of the model for the stated COU despite the Test conditions shortfall."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
