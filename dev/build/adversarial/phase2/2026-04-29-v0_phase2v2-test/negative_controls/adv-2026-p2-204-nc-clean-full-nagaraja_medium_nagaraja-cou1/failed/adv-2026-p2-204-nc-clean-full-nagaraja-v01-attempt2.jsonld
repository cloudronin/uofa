  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending achieves Accepted status based on the following structured evidence: (1) All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy the pre-established quantitative acceptance criteria of E/uval < 1.96 and relative difference < 10%, with maximum E/uval = 1.19 and maximum relative difference = 3.6%. (2) Twelve of thirteen V&V 40 credibility factors meet or exceed their required credibility level. (3) One factor (Test conditions) achieves Gradation 1 against a required Gradation 2; this shortfall is addressed by the documented offset rationale below, which establishes that the single test condition is the only standardized condition specified by ASTM F1717 for this device type, and that the sensitivity analysis confirms model robustness to parameter perturbations within the operating envelope. (4) The sensitivity analysis demonstrates that no single input parameter dominates model output, with maximum QoI sensitivity of 6.1% across all perturbations. (5) Provenance is complete: all validation results link to primary experimental datasets, generating activities, and uncertainty quantification records. The totality of evidence supports the conclusion that the FEA modeling framework is credible for its intended COU at Model Risk Level 3.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/decision/offset-test-conditions",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
      "justification": "The Test conditions factor achieves Gradation 1 (single test condition) against a required Gradation 2. This shortfall is accepted because: (a) ASTM F1717 specifies a single standardized compression-bending test condition for pedicle screw constructs, and no alternative loading rate or environmental condition is clinically indicated or regulatory precedent supports; (b) the sensitivity analysis (varied material moduli ±10–15% and contact stiffness ±20%) confirms that QoI predictions are robust to plausible parameter variation within the operating envelope, with maximum QoI change of 6.1%; (c) the validation comparison across three QoIs and two independent laboratories provides convergent evidence of model fidelity that partially compensates for the absence of multi-condition testing; and (d) the decision consequence is Medium (revision surgery, not mortality), which is consistent with accepting this limited shortfall under the ASME V&V 40 risk-informed framework.",
      "name": "Offset rationale for Test conditions shortfall"
    }
  },
