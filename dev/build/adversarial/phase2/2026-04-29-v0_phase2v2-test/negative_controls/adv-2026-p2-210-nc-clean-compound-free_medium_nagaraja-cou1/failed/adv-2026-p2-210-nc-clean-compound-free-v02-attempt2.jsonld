    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Simulation input parameters verified to match experimental conditions: loading angle 15° (verified by fixture CMM), displacement rate mapped to quasi-static loading assumption (inertial effects negligible at 5 mm/min), ambient temperature consistent with room-temperature material properties used. Block geometry modeled from F1717 specification drawings confirmed against laboratory fixture measurements. All equivalency checks documented in the simulation plan verification record.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/equivalency-inputs",
        "type": "AcceptanceCriteria",
        "description": "A formal equivalency matrix must document each experimental condition and its corresponding simulation parameter, with evidence of correspondence. Discrepancies must be documented with impact assessment on QoIs."
      }
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Quantitative comparison performed for all three primary QoIs (stiffness, yield force, force at 40 mm) using the validation metric E/uval (Oberkampf-Barone). All E/uval values below 1.96 threshold. Percent differences all below 4%. Load-displacement curve overlay plotted for visual confirmation of agreement throughout loading history. Statistical comparison via two-sample t-test (p > 0.05 for all QoIs) confirms no significant difference between FEA predictions and experimental means.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/output-comparison",
        "type": "AcceptanceCriteria",
        "description": "Primary QoI comparisons must use a quantitative validation metric accounting for both model prediction uncertainty and experimental measurement uncertainty. E/uval < 1.96 and percent difference < 10% required for all primary QoIs. Load-displacement curve overlay required for visual completeness check."
      }
    },
    {
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 and are the regulatory submission endpoints for pedicle screw mechanical performance. Clinical relevance: construct stiffness correlates with fusion environment; yield force is the primary safety endpoint (onset of permanent deformation); force at 40 mm characterizes post-yield behavior relevant to revision surgery planning. All three QoIs are directly predicted by the FEA model and directly measured in the validation experiments.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/qoi-relevance",
        "type": "AcceptanceCriteria",
        "description": "Each QoI must be explicitly linked to a regulatory requirement or clinical endpoint. The mapping between FEA output and experimental measurement must be direct (no surrogate QoIs without documented correlation). All primary regulatory QoIs must be included."
      }
    },
    {
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Validation activities directly replicate the COU: same device (non-cannulated 7.5 mm pedicle screw), same loading protocol (ASTM F1717 compression-bending), same material lot, same assembly procedure. Two-laboratory design increases generalizability. The FEA model geometry was constructed from the same CAD files used in device manufacturing. No extrapolation from validation domain to COU domain is required; the validation IS the COU assessment. Residual gap: single loading condition (addressed by offset rationale).",
      "acceptanceCriteria": {
