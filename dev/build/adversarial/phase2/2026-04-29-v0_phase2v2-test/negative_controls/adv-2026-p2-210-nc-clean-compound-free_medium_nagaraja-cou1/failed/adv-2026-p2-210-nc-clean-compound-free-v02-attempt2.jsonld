  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending is accepted as credible for the stated COU. All three primary QoIs (stiffness, yield force, force at 40 mm) satisfy the pre-established acceptance criteria: E/uval < 1.96 and percent difference < 10%. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions factor achieving level 2 against a required level 3 — is addressed by the offset rationale below. The provenance chain from raw experimental data through uncertainty quantification to validation metric computation is complete and traceable. The two-laboratory design and N=11 sample size provide adequate statistical power. Model risk level 3 is consistent with the Medium assurance level achieved.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/test-conditions-single-load",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/factor/test-conditions",
        "justification": "The Test conditions factor achieves level 2 (single standard loading condition per ASTM F1717) against a required level 3 (multiple conditions). This shortfall is accepted because: (1) ASTM F1717 specifies the 15° offset compression-bending condition as the sole regulatory standard for pedicle screw mechanical characterization, and regulatory submissions are evaluated against this single condition; (2) the sensitivity analysis demonstrates that FEA-predicted QoIs vary by less than 3% across loading angles from 10° to 20°, bounding the extrapolation risk; (3) the two-laboratory validation design compensates by demonstrating reproducibility across independent test environments, providing confidence that the single-condition result is representative; (4) model influence is Medium and decision consequence is Medium, placing the overall model risk at level 3, for which the ASME V&V 40 framework permits acceptance with documented offset rationale when the majority of factors meet or exceed requirements.",
        "name": "Offset rationale: Test conditions single-load-condition shortfall"
      },
      {
        "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
