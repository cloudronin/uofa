  "hasCredibilityFactor": [
    {
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Ansys Mechanical 2023 R1 is a commercially validated solver with documented V&V test suite per ISO 9001:2015 QMS. FDA in-house code (FEBio 3.5) underwent unit testing, regression testing, and benchmark verification against NAFEMS LE1 and LE10 problems. DePuy Synthes FEA environment operates under 21 CFR Part 820 design controls with documented software validation records. All three codes passed the required benchmark suite prior to use in this study.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/software-qa",
        "type": "AcceptanceCriteria",
        "description": "Each solver must demonstrate passing scores on at least the NAFEMS linear elastic benchmark set and maintain a documented regression test suite with version-controlled results. Commercial solvers must operate under a recognized QMS (ISO 9001 or equivalent)."
      }
    },
    {
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Code verification performed via method of manufactured solutions (MMS) for the nonlinear elastoplastic constitutive model. Observed convergence rate matched theoretical second-order rate (p = 1.97 ± 0.04) across three mesh refinement levels. Patch test passed for all element types used (C3D8, C3D10). No code defects identified affecting the QoIs.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/code-verification",
        "type": "AcceptanceCriteria",
        "description": "MMS convergence rate must be within 5% of theoretical order. Patch test must pass to machine precision. Any identified code defects must be documented with assessed impact on QoIs."
      }
    },
    {
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Mesh convergence study performed across four refinement levels (coarse ~45k elements, medium ~120k, fine ~310k, extra-fine ~780k). Grid Convergence Index (GCI) computed per Roache methodology. Fine mesh GCI for stiffness QoI: 1.4%; for yield force: 0.9%; for force at 40 mm: 1.2%. All GCI values below the 2% threshold. Production mesh (fine, ~310k elements) selected as optimal balance of accuracy and computational cost. Observed order of convergence p = 1.89.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/discretization-error",
        "type": "AcceptanceCriteria",
        "description": "GCI for all primary QoIs must be below 2% on the selected production mesh. Observed order of convergence must be within 10% of theoretical. Asymptotic range criterion (GCI_fine / r^p * GCI_medium ≈ 1) must be satisfied."
      }
    },
    {
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "rationale": "Newton-Raphson nonlinear solver convergence monitored via force and displacement residual norms. Convergence tolerance set to 1×10⁻⁶ (force) and 1×10⁻⁵ (displacement). All 11 simulation runs converged without line-search failures or divergence events. Time-step sensitivity study confirmed QoI insensitivity to step size reduction by factor of 4 (max QoI change 0.3%). Direct sparse solver (PARDISO) used; condition number monitoring confirmed well-conditioned system throughout loading.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/solver-error",
        "type": "AcceptanceCriteria",
        "description": "All simulations must achieve convergence to specified residual tolerances without failure. Time-step sensitivity must demonstrate QoI change below 1% upon halving the step size. Condition number must remain below 10^12 throughout the analysis."
      }
    },
    {
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Simulation setup documented in a controlled simulation plan reviewed and approved by a second qualified analyst per laboratory SOPs. Boundary conditions, contact definitions, material assignments, and load application verified against the simulation plan by an independent reviewer. Model setup checklist completed and archived. No discrepancies identified between planned and executed simulation configurations.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/use-error",
        "type": "AcceptanceCriteria",
        "description": "Simulation plan must be independently reviewed prior to execution. Setup verification checklist must be completed and archived. Any deviations from the plan must be documented with impact assessment."
      }
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Linear elastic model with bilinear isotropic hardening plasticity (Ti-6Al-4V ELI) selected based on published material characterization data. Contact modeled using augmented Lagrangian formulation with friction (μ = 0.25, from literature tribology data for Ti-Ti interfaces). Large-deformation kinematics (geometric nonlinearity) activated. Model form assumptions documented and justified: bone substitute blocks modeled as rigid (stiffness ~100× screw stiffness); screw-rod interface modeled as bonded (locking mechanism fully engaged per test protocol). Sensitivity analysis confirmed <2% QoI sensitivity to rigid-block assumption.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-form",
        "type": "AcceptanceCriteria",
        "description": "Model form assumptions must be explicitly documented and justified with reference to published literature or experimental data. Sensitivity to key model form choices (contact formulation, plasticity model, geometric nonlinearity) must be assessed and QoI sensitivity must be below 5% for each assumption individually."
      }
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Material properties (E = 114 GPa, σ_y = 880 MPa, tangent modulus 2.3 GPa) sourced from ASTM F136 coupon testing on material from the same lot as test constructs. Geometric inputs derived from CMM measurements of three representative screws (diameter tolerance ±0.03 mm, pitch ±0.01 mm). Friction coefficient (μ = 0.25 ± 0.05) from published Ti-Ti dry contact literature. All inputs traceable to measurement records with calibrated instruments. Uncertainty bounds on all primary inputs documented and propagated via Monte Carlo.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/model-inputs",
        "type": "AcceptanceCriteria",
        "description": "All primary model inputs must be traceable to calibrated measurements or peer-reviewed literature. Material properties must be from same-lot characterization where feasible. Uncertainty bounds must be documented for all inputs contributing >1% to total output uncertainty."
      }
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "N=11 constructs tested across two independent laboratories. All constructs assembled from production-representative screws and rods from the same manufacturing lot. Dimensional inspection (CMM) performed on all screws prior to assembly; all within specification. Construct assembly performed by trained technicians following the IFU torque specification (8 Nm). Inter-laboratory variability assessed and found non-significant (Levene test p=0.43). Sample size provides 80% power to detect a 10% mean difference at α=0.05.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/test-samples",
        "type": "AcceptanceCriteria",
        "description": "Test samples must be production-representative and dimensionally inspected. Minimum N=6 per laboratory for inter-laboratory reproducibility assessment. Inter-laboratory variance must be assessed statistically. Sample size justification must be documented."
      }
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "rationale": "Testing conducted under a single loading condition (15° offset, 5 mm/min, ambient temperature) per ASTM F1717. The required level 3 would demand multiple loading angles or rates; only the standard F1717 condition was tested. This shortfall is acknowledged and addressed by the offset rationale in the decision record, which notes that the single condition is the regulatory standard and that model sensitivity to loading angle variation is bounded by the sensitivity analysis.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/test-conditions",
        "type": "AcceptanceCriteria",
        "description": "Test conditions must replicate the intended use environment. For ASTM F1717, the standard 15° offset condition is required as a minimum. Level 3 additionally requires at least one alternate loading angle or rate to assess condition sensitivity."
      },
      "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026/factor/test-conditions"
