    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "rationale": "Testing performed under a single load condition (ASTM F1717 standard compression-bending configuration) at a single displacement rate (5 mm/min). While this condition is directly relevant to the regulatory submission, only one test condition was employed. A second condition (e.g., varied moment arm or load angle) would be required to achieve Gradation 2. This shortfall is acknowledged and offset by the high fidelity of model-experiment agreement across three QoIs and the direct regulatory relevance of the single condition tested.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/test-conditions",
        "type": "AcceptanceCriteria",
        "description": "Gradation 2 requires testing under at least two independent load conditions or configurations to demonstrate model predictive capability beyond a single operating point. Gradation 1 is acceptable only when a single condition is the entirety of the regulatory test space and offset rationale is documented."
