      "id": "https://uofa.net/synth/decision/noncannulated-f1717-credibility-accepted-2026/factor/test-conditions"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Model input parameters (geometry, material properties, boundary conditions, fixture dimensions) verified to match experimental test configuration through direct measurement and documentation review. Fixture geometry modeled from CMM scans of actual test fixtures used at both laboratories. Screw torque and rod set-screw torque values applied in model match IFU-specified assembly torques used in testing. Equivalency confirmed by cross-check between Test Plan TP-2024-NC-001 and Modeling Report MR-2024-NC-001.",
      "acceptanceCriteria": {
