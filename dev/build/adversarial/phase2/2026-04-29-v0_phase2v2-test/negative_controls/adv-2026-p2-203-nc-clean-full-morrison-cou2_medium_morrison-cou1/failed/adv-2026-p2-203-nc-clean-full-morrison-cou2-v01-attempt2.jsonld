  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-mrl5-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The COU2 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump at Model Risk Level 5 is accepted based on the following structured evidence: (1) All 13 credibility factors have been assessed and all achievedLevel values meet or exceed requiredLevel — no shortfalls exist. (2) The primary QoI (NIH) is validated against three independent experimental datasets with mean absolute error 8.3%, within the combined validation uncertainty of ±13.4% (95% CI). (3) Global sensitivity analysis (Sobol, N=4096) identifies the hemolysis power-law exponent as the dominant uncertainty source (S₁=0.41), and this uncertainty is bounded by the ±10% literature range, contributing a manageable ±4.1% to NIH prediction uncertainty. (4) The operating envelope is fully defined and all validation activities span the COU envelope, supporting extrapolation confidence. (5) Software quality assurance is at Gradation 5, the highest achievable level, providing maximum confidence in the computational infrastructure. (6) Multi-level validation hierarchy (unit, subsystem, system) provides defense-in-depth evidence for model fidelity. (7) The decision consequence is HIGH (Class II device, clinical hemolysis impact), and the MRL 5 rigor applied is commensurate with this consequence level. The credibility assessment team concludes that the CFD model is sufficiently credible for its intended use in predicting absolute hemolysis index values for regulatory submission purposes.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
