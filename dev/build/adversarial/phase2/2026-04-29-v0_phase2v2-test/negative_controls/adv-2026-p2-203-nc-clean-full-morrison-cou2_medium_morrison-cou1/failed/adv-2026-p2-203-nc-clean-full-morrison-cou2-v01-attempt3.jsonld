  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 5.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis CFD applicability domain",
      "description": "The CFD model is applicable to centrifugal blood pumps with impeller diameters between 40 mm and 60 mm, operating at rotational speeds between 1500 rpm and 3500 rpm, and volumetric flow rates between 2 L/min and 8 L/min. Blood is modeled as a non-Newtonian fluid using the Carreau-Yasuda viscosity model. The model is not applicable to axial-flow pumps, pulsatile assist devices, or operating conditions outside the specified envelope. Hematocrit must be within 30–45% and temperature within 35–38°C."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB centrifugal pump operating envelope",
      "description": "Volumetric flow rate: 2–8 L/min (nominal 5 L/min). Rotational speed: 1500–3500 rpm (nominal 2400 rpm). Inlet pressure: 0–20 mmHg. Outlet pressure: 80–200 mmHg. Impeller tip clearance: 0.1–0.5 mm. Fluid temperature: 35–38°C. Hematocrit: 30–45%. All five operating points (2 L/min at 1500 rpm, 3 L/min at 2000 rpm, 5 L/min at 2400 rpm, 6 L/min at 3000 rpm, 8 L/min at 3500 rpm) lie within this envelope and were explicitly validated."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/sensitivity/cpb-mrl5-sa",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis of CFD hemolysis predictions to model inputs and geometry parameters",
    "description": "A Sobol variance-based global sensitivity analysis was performed using 4096 quasi-random Latin hypercube samples across 11 uncertain input parameters including impeller tip clearance (±0.2 mm), blood viscosity model coefficients (±15%), inlet velocity profile shape, turbulence intensity (1–10%), and hemolysis power-law exponent (α ± 0.05, β ± 0.1). The relative hemolysis index (RH) exhibited first-order Sobol indices dominated by tip clearance (S1 = 0.41), hemolysis power-law exponent α (S1 = 0.28), and rotational speed (S1 = 0.17); total-order indices confirmed negligible higher-order interactions for tip clearance and α, while turbulence intensity showed moderate interaction effects (ST − S1 = 0.09). The analysis confirms that the model is most sensitive to geometric fidelity and constitutive hemolysis parameters, and that the UQ bounds reported in ValidationResults VR-01 through VR-05 conservatively envelope the 95th-percentile prediction interval across the full input uncertainty space.",
    "method": "Sobol variance-based global sensitivity (Saltelli 2010 estimator)",
    "dominantFactors": [
      "impeller tip clearance",
      "hemolysis power-law exponent alpha",
      "rotational speed"
    ],
    "sampleSize": 4096
  },
