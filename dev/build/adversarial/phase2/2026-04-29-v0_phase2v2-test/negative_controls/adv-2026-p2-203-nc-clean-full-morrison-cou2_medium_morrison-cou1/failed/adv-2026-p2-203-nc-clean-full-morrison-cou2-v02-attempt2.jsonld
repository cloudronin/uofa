    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: adult CPB with FDA generic centrifugal pump geometry",
      "description": "Model applicability is restricted to adult patients (body surface area 1.5–2.2 m²) undergoing elective cardiopulmonary bypass with the FDA generic centrifugal pump geometry. Pediatric applications, VAD configurations, and non-Newtonian blood substitutes are explicitly out of scope. The hemolysis power-law damage model (Giersiepen–Wurzinger) has been validated only for shear exposures in the range 1–400 Pa over exposure times 0.001–1 s."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB operating envelope: flow rate, rotational speed, and inlet pressure bounds",
      "description": "Validated operating envelope: volumetric flow rate 2.0–6.0 L/min (increments of 1 L/min); impeller rotational speed 1500–3500 RPM (increments of 500 RPM); inlet gauge pressure −20 to +10 mmHg; blood temperature 34–37 °C; hematocrit 30–40%. Geometry tolerance band ±0.05 mm on all wetted surfaces. Simulations outside these bounds require re-assessment of model credibility."
    }
  },
  "hasSensitivityAnalysis": true,
  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/morrison/sa/cou2-mrl5-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Global variance-based sensitivity analysis for CFD hemolysis prediction",
    "description": "A Sobol variance-based global sensitivity analysis (N=4096 quasi-random samples, Saltelli sampling scheme) was conducted across seven uncertain inputs: impeller rotational speed (±5%), inlet flow rate (±8%), blood viscosity (±12%), power-law damage model exponent α (±0.15), damage model coefficient C (±20%), near-wall mesh refinement level (3 levels), and turbulence model constant Cμ (±10%). The hemolysis index (HI) was the primary quantity of interest. First-order Sobol indices identified the damage model coefficient C (S₁=0.41) and rotational speed (S₁=0.28) as dominant contributors; total-order indices confirmed negligible higher-order interactions beyond these two factors. Blood viscosity and mesh refinement contributed S₁=0.11 and S₁=0.09 respectively. Results informed the uncertainty budget reported in the validation results and justified targeted experimental calibration of the damage model coefficient.",
    "method": "Sobol variance-based global sensitivity analysis (Saltelli 2010)",
    "dominantFactors": [
      "Damage model coefficient C",
      "Impeller rotational speed"
    ],
    "sampleSize": 4096
  },
