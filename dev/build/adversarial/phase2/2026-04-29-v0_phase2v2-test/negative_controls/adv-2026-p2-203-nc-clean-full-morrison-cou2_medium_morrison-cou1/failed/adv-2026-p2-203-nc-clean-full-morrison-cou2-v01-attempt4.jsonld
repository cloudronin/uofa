  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/morrison/sensitivity/cou2-mrl5-sa",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis for CFD hemolysis prediction — MRL 5",
    "description": "A variance-based (Sobol) global sensitivity analysis was conducted over 500 quasi-random samples spanning inlet flow rate (3–7 L/min), rotational speed (2000–3500 RPM), blood viscosity (±15% of nominal), and power-law hemolysis exponent (0.765 ± 0.05). The analysis identified rotational speed and inlet flow rate as the dominant contributors to predicted relative hemolysis index variance (first-order Sobol indices 0.41 and 0.33 respectively), with blood viscosity contributing 0.14 and the hemolysis exponent 0.09; interaction terms accounted for the residual 0.03.",
    "method": "Variance-based Sobol indices via quasi-Monte Carlo sampling (Saltelli sequence)",
    "dominantFactors": [
      "Rotational speed (S1=0.41)",
      "Inlet flow rate (S1=0.33)",
      "Blood viscosity (S1=0.14)",
      "Hemolysis power-law exponent (S1=0.09)"
    ],
    "sampleSize": 500
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-cpb-mrl5",
    "type": "ContextOfUse",
    "name": "COU2: Cardiopulmonary bypass use — MRL 5 (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery at MRL 5. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 5 requires full 13-factor credibility assessment with high-rigor evidence.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device at MRL 5. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion) with full UQ envelope.",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-cpb-mrl5/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: centrifugal blood pump CFD hemolysis domain",
      "description": "The model is applicable to centrifugal blood pump geometries with impeller outer diameter 40–60 mm, operating under steady-state rotational conditions with Newtonian blood analogue (hematocrit 33–45%). The hemolysis correlation (power-law Giersiepen–Wurzinger) is valid for shear stress exposures between 10 and 400 Pa over exposure times of 1–500 ms. Results are not applicable to pulsatile or axial-flow pump configurations, nor to patients with haematological disorders affecting red cell fragility."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-cpb-mrl5/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: CPB centrifugal pump CFD conditions",
      "description": "Defined operating envelope for the CFD hemolysis model: inlet volumetric flow rate 3–7 L/min; rotational speed 2000–3500 RPM; outlet static pressure 60–200 mmHg; blood temperature 34–37 °C; hematocrit 33–45%; impeller tip clearance 0.15–0.45 mm; volute gap width 0.8–2.0 mm. Simulations outside these bounds require additional validation before credibility claims can be extended."
    }
  },
