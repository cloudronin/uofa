  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2: SQA (achieved 2 ≥ required 1), numerical code verification (achieved 2 ≥ required 1), discretization error (achieved 3 ≥ required 2), test conditions (achieved 2 ≥ required 2), output comparison (achieved 2 ≥ required 2), QoI relevance (achieved 2 ≥ required 2), and validation relevance to COU (achieved 3 ≥ required 2). Six factors are appropriately scoped out at MRL 2 with documented rationale in each case. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 2000–3500 RPM, tip clearance 0.10–0.30 mm) and validation activities densely cover the full envelope including all corner operating points. Three independent validation datasets provide converging evidence: PIV velocity comparison (MARE 4.2%), bench hemolysis comparison (E_val 13.8% < 20% threshold, RH < 1 at all 18 conditions), and geometry tolerance sensitivity validation (17/18 rank-order predictions correct). Uncertainty is quantified at each validation activity and combined uncertainty is within acceptance thresholds. The CFD model is accepted as credible for identifying worst-case hemolysis operating conditions within the declared envelope for a Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
