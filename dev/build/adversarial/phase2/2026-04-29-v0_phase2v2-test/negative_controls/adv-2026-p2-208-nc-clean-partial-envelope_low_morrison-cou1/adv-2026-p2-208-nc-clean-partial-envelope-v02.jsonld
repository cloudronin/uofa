    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/envelope",
      "type": "OperatingEnvelope",
      "name": "CPB pump operating envelope — bounded flow, speed, and geometry",
      "description": "Flow rate: 1.0–7.0 L/min (five nominal setpoints: 1, 2, 4, 6, 7 L/min ±0.05 L/min). Rotational speed: 2000–3500 RPM (five setpoints: 2000, 2500, 3000, 3250, 3500 RPM ±10 RPM). Inlet pressure: 0–20 mmHg. Outlet pressure: 60–120 mmHg. Blood viscosity: 0.0030–0.0040 Pa·s (Newtonian approximation, haematocrit 35–45%). Impeller tip clearance: 0.10–0.30 mm (nominal 0.20 mm, tolerance ±0.05 mm). Volute gap tolerance: ±0.15 mm on nominal 1.80 mm. Fluid temperature: 20–37 °C. All 25 CFD simulation runs and all 18 bench hemolysis experiments fall within these bounds."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint — FDA generic centrifugal blood pump geometry family",
      "description": "Model applicability is restricted to the FDA generic centrifugal blood pump geometry family (GCBP Rev C) and geometrically similar devices with impeller outer diameter 60 ± 5 mm, blade count 6, and volute wrap angle 270 ± 10°. The model is not applicable to axial or diagonal-flow pumps, devices with tip clearances outside 0.10–0.30 mm, or operating points outside the declared flow-rate and speed envelope. Clinical use is limited to adult CPB (body surface area ≥ 1.5 m²)."
    }
  },
