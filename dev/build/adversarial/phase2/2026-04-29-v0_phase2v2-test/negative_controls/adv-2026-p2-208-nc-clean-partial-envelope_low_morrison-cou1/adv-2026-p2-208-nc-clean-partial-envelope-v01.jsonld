    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB hemolysis CFD operating envelope",
      "description": "The model is applicable within the following explicitly bounded operating conditions: volumetric flow rate 1–7 L/min (five discrete validation points at 2, 3, 4, 5, and 6 L/min); impeller rotational speed 1500–3500 RPM (validated at 2000, 2500, 3000 RPM); inlet hematocrit 30–45%; blood temperature 35–37 °C; impeller tip clearance 0.15–0.35 mm (tolerance band per device drawing); inlet pressure 5–15 mmHg. All five validation experiments were conducted within this envelope and collectively provide dense coverage across the flow-speed operating space."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis CFD applicability constraint",
      "description": "The model is applicable only to the FDA generic centrifugal blood pump geometry family under adult CPB conditions. Extrapolation beyond the declared operating envelope (flow >7 L/min or <1 L/min, speed >3500 RPM or <1500 RPM, pediatric patients, non-Newtonian hematocrit outside 30–45%, or alternative pump geometries) is explicitly out of scope and requires separate credibility assessment. The relative hemolysis index (RH) acceptance criterion applies only when compared against the same predicate device under matched boundary conditions."
    }
  },
