  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for CPB hemolysis prediction is accepted as credible for the declared COU at MRL 2. Seven credibility factors were formally assessed: all seven achieved their required levels (three at Gradation 2, one at Gradation 3 exceeding the requirement). Six factors were scoped out with documented rationale appropriate for MRL 2. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 1500–3500 RPM, hematocrit 30–45%) and five validation experiments densely cover this envelope with maximum prediction error of 4.1%. Combined numerical and experimental uncertainty is quantified at all operating points via Monte Carlo propagation and GCI analysis. The validation scenario is directly representative of the COU (same geometry, same fluid, overlapping operating conditions). The RH < 1 acceptance criterion is met at all five operating points relative to the predicate device. No credibility gaps exist; no offset rationale is required. The package is accepted without qualification.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
