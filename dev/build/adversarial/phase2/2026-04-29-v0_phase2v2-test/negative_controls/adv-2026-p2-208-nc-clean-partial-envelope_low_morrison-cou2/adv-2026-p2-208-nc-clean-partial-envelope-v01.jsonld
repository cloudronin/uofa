  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sa/vad-hemolysis-sensitivity",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis of NIH to primary model inputs",
    "description": "Sobol' variance-based sensitivity analysis performed over 4096 model evaluations (using quasi-random Saltelli sampling) to rank the contribution of five primary inputs — inlet flow rate, rotational speed, hematocrit, plasma viscosity, and hemolysis power-law exponent — to variance in predicted NIH. The hemolysis power-law exponent accounts for 52% of total NIH variance (first-order Sobol' index S1 = 0.52), followed by rotational speed (S1 = 0.27) and hematocrit (S1 = 0.13). Inlet flow rate and plasma viscosity contribute less than 5% each. These results confirm that model form uncertainty in the hemolysis power-law coefficients is the dominant uncertainty source and justify the targeted experimental effort to constrain the exponent distribution."
  },
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-nc8-clean",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achievedLevels meet or exceed requiredLevels. The operating envelope is explicitly bounded (flow rate 1–7 L/min, rotational speed 2000–5000 RPM, hematocrit 35–45%, temperature 37 ± 1 °C, geometry tolerances documented) and validation experiments densely cover this envelope at five operating points spanning the full range. Monte Carlo uncertainty quantification (1000 samples) demonstrates that the 95th-percentile predicted NIH remains below the clinical threshold with a margin of 18%. Sobol' sensitivity analysis identifies the hemolysis power-law exponent as the dominant uncertainty source (52% of NIH variance), and this uncertainty has been incorporated into the validation comparison and uncertainty budget. The quantitative validation metric V < 1.0 at all operating points confirms model predictions are within experimental uncertainty. Discretization error (GCI 2.3%) and iterative convergence (residuals < 1×10⁻⁶, QoI variation < 0.1%) are well-controlled. The model is accepted for use within the declared operating envelope for regulatory submission supporting the Class III VAD hemolysis claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
