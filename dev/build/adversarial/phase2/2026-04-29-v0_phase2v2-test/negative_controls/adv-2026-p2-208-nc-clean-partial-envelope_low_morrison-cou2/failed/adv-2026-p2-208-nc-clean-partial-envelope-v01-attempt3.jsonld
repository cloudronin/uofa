    "https://uofa.net/synth/data/monte-carlo-uncertainty-samples-n10000"
  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD CFD operating envelope — bounded flow and speed range",
      "description": "Volumetric flow rate: 1–7 L/min. Rotational speed: 2000–4500 RPM. Hematocrit: 35–45 %. Inlet gauge pressure: 5–15 mmHg. Outlet back-pressure: 60–120 mmHg. Blood viscosity (Newtonian approximation): 0.0030–0.0045 Pa·s. Pump geometry tolerance: ±0.05 mm on impeller tip clearance. All five validation operating points (2 L/min @ 2500 RPM, 3.5 L/min @ 3000 RPM, 5 L/min @ 3500 RPM, 6 L/min @ 4000 RPM, 7 L/min @ 4500 RPM) lie within this envelope. Model applicability is restricted to this bounded domain; extrapolation beyond these bounds is not supported by the current evidence package."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis model applicability constraint",
      "description": "The CFD hemolysis model is applicable only to the FDA generic centrifugal pump geometry (impeller diameter 52 mm ± 0.5 mm) operating within the declared envelope above. It is not applicable to axial-flow VADs, pulsatile pumps, or operating points outside the bounded flow-speed domain. Blood analogue fluids (glycerol-water) used in PIV validation are accepted as surrogate for whole blood within the hematocrit range specified. Paediatric patients (BSA < 0.7 m²) and haemoglobin variants other than HbA are explicitly excluded."
    }
  },
