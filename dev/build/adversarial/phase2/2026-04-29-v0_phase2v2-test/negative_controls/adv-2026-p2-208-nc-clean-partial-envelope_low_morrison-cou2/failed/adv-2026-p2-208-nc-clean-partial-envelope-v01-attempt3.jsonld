  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nc8-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/chief-credibility-engineer",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed with achieved levels meeting or exceeding required levels for Model Risk Level 5. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 2000–4500 RPM, hematocrit 35–45 %, inlet pressure 5–15 mmHg) and all five validation operating points lie densely within this envelope. Quantitative output comparison metrics (E% < 15 % for NIH, E% < 10 % for velocity) satisfy acceptance criteria at Gradation 4. Monte Carlo uncertainty quantification (N=10000) confirms 95th-percentile NIH predictions remain below the clinical threshold of 0.01 g/100 L. Model-form uncertainty assessed via two alternative turbulence models; SST k-ω shows lowest systematic bias. Independent technical review completed with no outstanding findings. The structured operating envelope and applicability constraint ensure that the credibility evidence directly supports the bounded COU; no extrapolation beyond the validated domain is claimed. Decision: Accepted for regulatory submission within the declared operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
