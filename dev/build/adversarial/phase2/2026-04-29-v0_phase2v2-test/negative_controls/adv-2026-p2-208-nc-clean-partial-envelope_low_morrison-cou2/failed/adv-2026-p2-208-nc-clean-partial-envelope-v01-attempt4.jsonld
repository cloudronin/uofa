    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD centrifugal pump operating envelope — bounded flow and speed",
      "description": "Volumetric flow rate: 1.0–7.0 L/min. Impeller rotational speed: 2000–3500 RPM. Inlet pressure: 5–15 mmHg. Outlet pressure: 60–120 mmHg. Blood viscosity: 0.0030–0.0040 Pa·s (37 °C, Hct 35–45%). Pump inlet diameter: 12 mm ± 0.15 mm; outlet diameter: 10 mm ± 0.15 mm. All five experimental operating points (2.5 L/min / 2500 RPM, 3.5 L/min / 2800 RPM, 4.5 L/min / 3000 RPM, 5.5 L/min / 3200 RPM, 6.5 L/min / 3400 RPM) lie strictly within these bounds. CFD validation coverage density: 5 points uniformly distributed across the envelope."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: FDA generic centrifugal pump geometry, Newtonian blood analog, steady-state hemolysis",
      "description": "Model applicability is restricted to: (1) the FDA benchmark centrifugal pump geometry as specified in the 2013 FDA critical path document; (2) Newtonian blood analog (glycerol-water, viscosity 0.0035 ± 0.0005 Pa·s) or whole blood within Hct 35–45%; (3) steady-state or time-averaged hemolysis index (HI) prediction — transient hemolysis spikes outside this window are out of scope; (4) rotor speeds 2000–3500 RPM; (5) no cavitation regime (NPSH margin > 2 m). Extrapolation beyond these bounds is explicitly prohibited without re-assessment."
    }
  },
