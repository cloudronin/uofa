  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The CFD solver (OpenFOAM v9) is under configuration management with version-controlled source, automated regression test suite (450 test cases), and documented build verification. SQA plan conforms to ISO 9001 and FDA 21 CFR Part 820 requirements. All solver modifications for the hemolysis scalar transport equation are documented in the change control log.",
      "acceptanceCriteria": {
