  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nc8-clean-vad-cou2",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed with achievedLevel meeting or exceeding requiredLevel. The ContextOfUse declares a concrete, quantitatively bounded operating envelope (flow rate 2–6 L/min, speed 2400–3600 RPM, inlet pressure 5–15 mmHg, outlet pressure 80–120 mmHg) and a structured applicability constraint restricting the model to the FDA generic centrifugal pump family within specific specific-speed and Reynolds-number bounds. Validation activities cover 12 of 15 operating points within the declared envelope, providing dense coverage. Monte Carlo uncertainty quantification with 5000 samples propagates all 14 identified uncertain inputs. The validation metric |E|/U_val < 1.0 at 10 of 12 points, and mean normalized NIH error is 7.2%, well within the 15% acceptance criterion. The operating envelope and applicability constraints are explicitly structured (not narrative-only), enabling automated rule checking. No credibility gaps remain. The package is accepted for the intended use of predicting absolute hemolysis levels for regulatory submission support.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
