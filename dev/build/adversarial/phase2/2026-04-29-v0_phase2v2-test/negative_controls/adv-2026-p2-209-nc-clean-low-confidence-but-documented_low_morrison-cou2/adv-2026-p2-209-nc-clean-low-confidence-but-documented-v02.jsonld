  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed required levels for MRL 5. The assessment is characterised by honestly documented low confidence (~50%) arising primarily from epistemic uncertainty in the power-law hemolysis damage model constants (α, β). This uncertainty is the dominant variance contributor (~70% of total NIH prediction variance per sensitivity analysis) and results in wide Monte Carlo uncertainty bounds (38% CV on NIH). Despite this low confidence, the package is accepted because: (1) all predictions fall within combined experimental and simulation uncertainty intervals at all five validation operating points; (2) the uncertainty is formally quantified and propagated rather than suppressed; (3) the wide bounds are conservative relative to the clinical hemolysis threshold, meaning the upper bound of the 95% CI remains below the accepted NIH limit of 0.1 g/100L; (4) independent verification of solver and discretisation errors confirms these contribute negligibly (<10% of total uncertainty); and (5) the sensitivity analysis identifies the damage model exponents as the primary improvement target for future work. The decision to accept reflects that the evidence, while of low confidence, is complete, honest, and sufficient for the stated assurance level (Low) and device class regulatory context. No weakeners are present; the low confidence is a documented feature of the evidence base, not a concealed deficiency.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
