  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-nc9-clean",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed. All achieved levels meet or exceed required levels (9 factors at required level 3, 4 factors at required level 2). Evidence confidence is approximately 50% for hemolysis-specific predictions, driven by wide Monte Carlo uncertainty bounds (±35% NIH at 95% CI) arising from power-law model parameter uncertainty (alpha ±15%, C ±40%). These limitations are documented honestly and transparently throughout the package. The decision to accept is grounded in the following: (1) the CFD-predicted NIH mean values remain below the absolute clinical threshold (0.006 g/100L) by a safety margin of 2.1x even at the upper 95% prediction interval; (2) the hydraulic performance validation demonstrates high-fidelity flow-field prediction (4.2% MAE on H-Q curve), providing confidence in the underlying fluid mechanics; (3) the Sobol sensitivity analysis identifies alpha and C as dominant uncertainty drivers, and conservative upper-bound parameter values from the published literature have been used in the regulatory submission predictions; (4) the Monte Carlo UQ has been performed with 5000 samples providing stable convergence of prediction intervals. The residual epistemic uncertainty from sparse experimental replication (n=3 per condition, single laboratory) is acknowledged as a limitation. This package constitutes a NC-9 negative control: all structural requirements are satisfied, all low-confidence evidence is honestly documented with appropriate rationale, and the acceptance decision is grounded in conservative margin analysis rather than suppression of uncertainty information.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
