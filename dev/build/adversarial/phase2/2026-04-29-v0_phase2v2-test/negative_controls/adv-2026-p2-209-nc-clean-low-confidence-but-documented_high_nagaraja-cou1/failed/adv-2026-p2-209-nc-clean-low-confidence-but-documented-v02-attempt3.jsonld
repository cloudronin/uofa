  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending meets or exceeds required credibility levels for 12 of 13 V&V 40 factors. All three primary QoIs (stiffness, yield force, force at 40 mm displacement) satisfy the pre-established quantitative acceptance criteria (E/uval < 1.96; percent difference < 10%). Material input confidence is explicitly low (n=4 vendor certificates), but Monte Carlo propagation demonstrates that the resulting wide uncertainty intervals fully encompass experimental observations, supporting the validity of the comparison. One factor (Test conditions, Gradation 1 vs. required Gradation 2) falls below the required level due to single-condition testing per ASTM F1717; this shortfall is addressed by the offset rationale below. The overall credibility evidence is sufficient for the Medium model risk and Medium decision consequence of this COU.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/credibilityfactor/test-conditions",
        "justification": "The Test conditions factor achieves Gradation 1 rather than the required Gradation 2 because ASTM F1717 prescribes a single standardized test configuration (60 mm moment arm, 5 mm/min), and no regulatory or clinical rationale exists for varying these parameters in the submission context. The shortfall is offset by: (1) the standardized nature of the protocol, which is the accepted industry and regulatory benchmark for pedicle screw mechanical performance; (2) strong performance on all other 12 factors, including Gradation 3 on discretization error and full quantitative acceptance on all three QoIs; (3) the sensitivity analysis demonstrating that material input uncertainty (the dominant uncertainty source) does not interact with test condition variability in a way that would alter the acceptance conclusion; and (4) the Medium (not High) model risk and decision consequence, which does not demand multi-condition validation for regulatory acceptance at this assurance level."
      },
      {
        "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
