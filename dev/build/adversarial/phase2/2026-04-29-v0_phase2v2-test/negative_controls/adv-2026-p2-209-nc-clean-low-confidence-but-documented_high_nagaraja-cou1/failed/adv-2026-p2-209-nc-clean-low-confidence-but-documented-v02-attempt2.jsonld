  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — is accepted based on the offset rationale below. Material input uncertainty is explicitly documented with wide bounds (low confidence on Sy and Et due to small coupon sample sizes), propagated via Monte Carlo, and shown by sensitivity analysis to remain within the 10% acceptance bound at the 95th percentile. All three QoI validation metrics (E/uval = 0.83, 1.31, 1.61) are below the 1.96 threshold. The FEA ensemble demonstrates sufficient credibility for its intended use in supporting a 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs. required Gradation 3)",
        "description": "ASTM F1717 is a highly prescriptive standard that specifies a single quasi-static test condition (5 mm/min crosshead speed, 23 deg C ambient). Testing at multiple crosshead speeds or temperatures is not required by the standard and would not reflect the regulatory submission context. Published literature (Cordewener et al. 2000; Goel et al. 1999) documents that construct stiffness and yield force for metallic pedicle screw constructs are insensitive to crosshead speed in the range 1-10 mm/min (less than 2% variation). The sensitivity analysis further confirms that the dominant sources of QoI uncertainty are material input parameters (Sy, Et), not test condition variability. The Test conditions shortfall is therefore accepted as residual risk; no additional testing at alternative conditions is warranted for this COU.",
        "shortfallFactor": "Test conditions",
        "shortfallGradation": 2,
        "requiredGradation": 3,
        "offsetEvidence": [
          "https://uofa.net/synth/data/f1717-bench-n11-two-labs",
          "https://uofa.net/synth/sensitivity/noncannulated-material-inputs"
        ]
      },
      {
        "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2024/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2024/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
