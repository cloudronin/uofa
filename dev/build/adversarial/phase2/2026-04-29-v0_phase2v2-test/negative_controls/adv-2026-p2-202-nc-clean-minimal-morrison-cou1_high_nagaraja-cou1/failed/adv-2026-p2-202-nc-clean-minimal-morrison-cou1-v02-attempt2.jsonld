  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending is accepted as adequately credible for the stated COU. Twelve of thirteen V&V 40 factors meet or exceed required credibility levels. All three primary QoIs (stiffness, yield force, force at 40 mm) are predicted within the pre-established 10% acceptance bound, with E/uval ratios of 0.87, 1.31, and 1.04 — all below the 1.96 threshold. Software QA, discretization error, model form, model inputs, and output comparison each achieved one gradation above the required level, providing additional confidence. The single shortfall (Test conditions, achieved Gradation 1 vs. required Gradation 2) is offset by the multi-laboratory experimental campaign (N=11 constructs across two independent facilities), the high fidelity of model input equivalency, and the conservative acceptance bounds applied to all QoIs. The offset rationale is formally documented. The model risk level (3) and medium assurance level are consistent with the Class II device classification and medium decision consequence. Overall credibility is sufficient to support the regulatory submission claim.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-offset-testconditions",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 1 vs. required Gradation 2)",
        "description": "The Test conditions factor achieved Gradation 1 (single ASTM F1717 static compression-bending configuration) against a required Gradation 2. This shortfall is accepted on the basis of three offsetting strengths: (1) N=11 constructs tested across two independent laboratories provides inter-laboratory validation that compensates for the lack of a second load configuration; (2) the ASTM F1717 static compression-bending test is the normative regulatory standard for this device class and the COU is explicitly scoped to this configuration, so a second test condition is not clinically necessary for the stated decision; (3) all other validation factors at or above required level, with five factors exceeding required level by one gradation, providing a positive credibility surplus that outweighs the single-condition limitation.",
        "shortfallFactor": "Test conditions",
        "shortfallGap": "Achieved Gradation 1; required Gradation 2",
        "offsetJustification": "Multi-laboratory campaign, COU scope alignment with single test standard, and positive credibility surplus across remaining 12 factors collectively justify acceptance despite single-condition testing."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
