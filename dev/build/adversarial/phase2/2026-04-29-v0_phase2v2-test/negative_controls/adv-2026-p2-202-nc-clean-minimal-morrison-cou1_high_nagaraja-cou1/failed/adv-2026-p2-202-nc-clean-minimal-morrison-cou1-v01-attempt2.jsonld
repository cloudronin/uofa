  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 compression-bending achieves overall credibility sufficient for Medium model risk level. Twelve of thirteen V&V 40 factors meet or exceed their required gradation levels. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — is offset by: (1) all three primary QoIs satisfy both quantitative acceptance criteria simultaneously (percent difference below 10% AND E/uval below 1.96); (2) room-temperature quasi-static testing is conservative relative to physiological conditions for titanium alloy constructs; (3) the ASTM F1717 protocol is the regulatory standard and single-condition testing is the accepted industry practice for this device class; and (4) the high equivalency of model inputs to experimental conditions (Gradation 3) reduces the probability that untested conditions would reveal model-form deficiencies. The offset rationale is documented in hasOffsetRationale. The credibility evidence supports acceptance of the FEA model for its intended use in the regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "description": "Test conditions factor achieved Gradation 2 (single test condition: quasi-static compression-bending at room temperature, 5 mm/min per ASTM F1717) against a required Gradation 3. The shortfall is justified by four converging lines of evidence: (1) all three QoIs pass both the 10% difference threshold and E/uval < 1.96 threshold under the tested condition, demonstrating high fidelity under the most clinically relevant loading scenario; (2) titanium alloy Ti-6Al-4V exhibits minimal rate sensitivity at physiological strain rates, making quasi-static results representative of dynamic in vivo loading; (3) ASTM F1717 is the FDA-recognized consensus standard for this device class and single-condition static testing is the accepted regulatory evidentiary standard; (4) the high-fidelity model inputs (Gradation 3 for both Model inputs and Equivalency of input parameters) and rigorous uncertainty quantification (E/uval well below threshold for stiffness and yield force) provide confidence that model-form errors are not masked by the single-condition testing approach.",
        "offsettingFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "offsettingEvidence": [
          "https://uofa.net/nagaraja/validation/stiffness-comparison",
          "https://uofa.net/nagaraja/validation/yield-force-comparison",
          "https://uofa.net/nagaraja/validation/force-40mm-comparison"
        ]
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
