  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment is accepted at MRL 2 despite evidence confidence of approximately 50%, for the following documented reasons: (1) All 7 assessed credibility factors meet or exceed their required levels. (2) The wide prediction intervals (NIH ±31% relative half-width) are explicitly quantified via Monte Carlo propagation and attributed to two dominant sources — blood viscosity uncertainty (CV=22%) and power-law exponent uncertainty (±0.08) — as confirmed by the sensitivity analysis. (3) Even at the 95th-percentile upper bound of the prediction interval, the predicted RH index remains below 1.0 (the regulatory acceptance criterion), providing a positive margin of safety under the worst-case uncertainty scenario. (4) The 6 scoped-out factors are appropriately excluded per the MRL 2 assessment plan, with documented rationale for each. (5) The decision consequence is High and model influence is Medium; the residual uncertainty is judged acceptable because the regulatory margin is preserved across the full prediction interval and because independent bench testing provides a confirmatory check on CFD results. The assessment team acknowledges the low confidence (~50%) as a limitation and recommends that future assessments increase experimental replicates to at least 6 per operating point and reduce blood rheology variability through standardized fluid preparation protocols.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
