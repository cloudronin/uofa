  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-nc9-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment accepts the CFD hemolysis model for the CPB COU at Medium assurance despite explicitly documented low confidence (~50%) in the hemolysis output, for the following structured reasons: (1) The primary COU objective is worst-case operating condition identification, not point-prediction accuracy. Monte Carlo analysis confirms that the rank ordering of the 5 operating points is preserved in >93% of uncertainty realizations, satisfying the acceptance criterion even under wide uncertainty bounds. (2) The sensitivity analysis demonstrates that hematocrit variability (35–45%) and Carreau–Yasuda viscosity uncertainty together account for 85% of output variance. These are irreducible biological sources of variability that would affect physical testing equally; the model does not introduce additional uncertainty beyond what is inherent in the test system. (3) The relative hemolysis index criterion (RH < 1) is a conservative comparative threshold that accommodates the wide absolute uncertainty interval. The worst-case CFD prediction (NIH = 0.0089 mg/100 mL) remains below the predicate device reference value with margin. (4) Physical bench testing provides an independent safety net per the medium model influence designation; the model result informs but does not solely determine the regulatory submission. (5) All seven assessed credibility factors meet their required levels at MRL 2. Six factors are appropriately scoped out with documented rationale. The provenance chain from raw experimental data through uncertainty quantification to this decision record is complete. The low confidence is honestly documented and does not undermine the fitness of the model for its stated COU purpose.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
