  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cpb-hemolysis-nc9",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepts the CFD hemolysis model for COU1 (worst-case operating condition identification for a Class II CPB device at MRL 2) despite explicitly low confidence (~50%) in the hemolysis index validation result. The decision is grounded in the following structured evidence: (1) All seven assessed credibility factors meet or exceed their required levels for MRL 2. (2) Wide uncertainty bounds on NIH (±55% at worst-case condition) are caused primarily by turbulence model selection (38% of output variance) and power-law coefficient uncertainty (29%), as documented in the sensitivity analysis; these are epistemic uncertainties that are bounded and understood rather than uncharacterized. (3) The area validation metric for NIH (0.61) exceeds the MRL 2 threshold (0.50), indicating that simulation results are statistically consistent with experimental measurements when uncertainty is properly accounted for. (4) The regulatory acceptance criterion (RH < 1) is evaluated using the upper bound of the 95% confidence interval on NIH, providing a conservative assessment; the upper-bound prediction remains below the acceptance threshold at all 5 operating points. (5) Six factors are appropriately scoped out at MRL 2 with documented rationale; none of the scoped-out factors introduce uncharacterized risk given the medium model influence and the breadth of validation activities. The team acknowledges that confidence would increase materially with additional experimental replicates and a formal turbulence model selection study; these are recommended for any future MRL 3 reassessment. The current evidence base is sufficient to support the intended regulatory decision at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
