  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-nc9-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepts the CFD hemolysis model for the stated COU (worst-case operating point identification for a Class II CPB device at MRL 2) despite an evidence confidence of approximately 50% on point hemolysis predictions. The acceptance is grounded in the following structured argument: (1) The COU decision criterion is the relative hemolysis index RH < 1, not absolute NIH accuracy. The wide ±35% prediction interval on NIH does not invalidate the worst-case ranking, which is preserved in 94% of 500 Monte Carlo draws across the full range of uncertain power-law parameters. (2) The dominant uncertain inputs (power-law coefficient C, Sobol S1=0.52; exponent α, S1=0.31) are identified and quantified. The sensitivity analysis demonstrates that hydraulic boundary conditions — which are well-characterised (confidence ~90%, ±4.2%) — do not contribute materially to hemolysis prediction uncertainty, confirming that the flow-field solution is reliable. (3) Independent bench testing of the worst-case operating point corroborates the CFD-identified worst case in all three experimental replicates, providing convergent evidence that does not depend on the uncertain power-law parameters. (4) All 7 assessed credibility factors achieve their required Gradation 2 levels; 3 factors are scoped out with documented rationale appropriate to MRL 2. No factor shortfall exists. (5) Residual uncertainty in absolute hemolysis magnitude is acknowledged as a limitation and is the subject of a recommended follow-on experimental programme targeting independent measurement of power-law coefficients C and α for the specific blood source and shear protocol used in this device class. This programme is planned prior to final design freeze and does not block the current tolerance-sensitivity decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
