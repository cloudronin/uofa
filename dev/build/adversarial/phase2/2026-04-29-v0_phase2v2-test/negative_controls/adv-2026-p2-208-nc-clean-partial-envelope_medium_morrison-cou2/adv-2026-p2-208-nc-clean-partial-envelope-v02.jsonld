  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD centrifugal pump operating envelope — bounded applicability",
      "description": "Flow rate: 1–7 L/min (boundary validation at 1.0 and 7.0 L/min). Rotational speed: 2000–5000 RPM (boundary validation at 2000 and 5000 RPM). Hematocrit: 35–45 % (nominal 40 %). Fluid temperature: 36–38 °C. Inlet gauge pressure: 0–20 mmHg. Pump geometry: FDA generic centrifugal pump nominal dimensions ±0.05 mm manufacturing tolerance. All five flow-speed operating points lie strictly within these bounds; two additional boundary-point experiments confirm envelope coverage."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis model applicability constraint",
      "description": "Model applicability is restricted to the FDA generic centrifugal blood pump geometry. The hemolysis power-law submodel (Giersiepen–Wurzinger) is valid for shear stresses 0–1000 Pa and exposure times 1 ms–10 s. Newtonian blood rheology assumption is valid for shear rates above 100 s⁻¹, which holds throughout the impeller passage at all operating points within the declared envelope. Model must not be applied to axial-flow pumps, pulsatile conditions, or hematocrit outside 35–45 %."
    }
  },
