  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed with achievedLevel meeting or exceeding requiredLevel. The operating envelope is explicitly bounded (flow 1-7 L/min, speed 2000-5000 RPM, hematocrit 35-45%) and validation experiments cover both boundary and interior points of this envelope. Monte Carlo uncertainty quantification (n=2000) demonstrates that the 95th-percentile NIH prediction remains below the clinical threshold across the full declared envelope. Model form uncertainty (12% NIH) and input uncertainty (18% NIH at 95th percentile) are both characterized and bounded. The combination of quantitative output comparison (NMAE 9.3% for NIH), full envelope coverage in validation, independent use-error review, and complete uncertainty budget supports acceptance of the CFD hemolysis predictions for the declared COU. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
