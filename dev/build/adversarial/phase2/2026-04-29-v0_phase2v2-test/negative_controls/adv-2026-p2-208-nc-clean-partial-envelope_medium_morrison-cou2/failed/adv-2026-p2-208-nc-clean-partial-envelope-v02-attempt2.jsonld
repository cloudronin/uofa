    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD CFD Operating Envelope — Bounded Flow and Speed Conditions",
      "description": "The model is applicable within the following explicit bounds: volumetric flow rate 1.0 to 7.0 L/min (±0.05 L/min measurement tolerance); rotational speed 2000 to 5000 RPM (±10 RPM); inlet hematocrit 35 to 45% (±1%); blood temperature 36 to 38 degrees Celsius; pump inlet pressure 5 to 20 mmHg. Geometric applicability is restricted to the FDA generic centrifugal pump geometry with impeller diameter 52 mm ±0.1 mm and volute clearance 0.3 to 0.5 mm. Extrapolation beyond these bounds is not supported by this assessment."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD CFD Applicability Constraint — FDA Generic Centrifugal Pump Domain",
      "description": "This assessment applies exclusively to the FDA benchmark generic centrifugal blood pump geometry operating as a left ventricular assist device in adult patients. The hemolysis model (power-law Giersiepen-Wurzinger correlation) is valid only for shear exposures below 500 Pa and exposure times below 700 ms, consistent with the declared flow envelope. Results are not transferable to axial-flow VADs, pediatric configurations, or operating points outside the declared envelope without re-assessment."
    }
  },
