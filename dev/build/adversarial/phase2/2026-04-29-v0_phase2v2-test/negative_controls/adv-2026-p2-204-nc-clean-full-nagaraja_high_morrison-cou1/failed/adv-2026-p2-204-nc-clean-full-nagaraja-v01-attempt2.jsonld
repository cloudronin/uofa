    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/nagaraja-cou1-ortho/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "TKA tibial tray applicability domain",
      "description": "Model is applicable to cobalt-chromium and titanium alloy tibial trays with stem offset 0–4 mm, patient body mass 60–120 kg, and gait cycle loading profiles derived from ISO 14243-1. Excludes revision implants, unicompartmental designs, and patients with neuromuscular gait disorders that produce atypical load vectors."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/nagaraja-cou1-ortho/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Physiological loading and geometry envelope for tibial tray FEA",
      "description": "Axial compressive force: 1200–3200 N (1× to 4× body weight); anterior-posterior shear: 0–400 N; torsional moment: 0–8 N·m; flexion angle: 0°–120°; tibial component thickness: 8–14 mm; keel depth: 18–28 mm; cement mantle thickness: 1–3 mm. All bounds derived from ISO 14243-1 and published gait analysis databases (Bergmann et al., 2014)."
    }
  },
  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/nagaraja-cou1-ortho/sensitivity-analysis",
    "type": "SensitivityAnalysis",
    "name": "Tibial tray FEA parameter sensitivity analysis",
    "description": "A variance-based (Sobol) sensitivity analysis was conducted across six input parameters: axial peak load (±15%), cortical bone elastic modulus (±20%), cement mantle thickness (±1 mm), tibial slope (±3°), friction coefficient at tray–bone interface (0.3–0.7), and mesh density (element edge length 0.5–2.0 mm). Peak von Mises stress at the tray keel junction was the primary QoI. Results showed that axial peak load and cortical bone modulus together account for 74% of output variance; mesh density contributed less than 4%, confirming discretization convergence. Cement mantle thickness was the third-ranked driver, motivating the targeted mesh refinement in that region."
  },
