  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/nagaraja-cou1-ortho/decision-record",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed at MRL 3. Seven factors achieved their required level exactly; three factors (Discretization error, Numerical solver error, Test samples) exceeded required levels. No factor falls below its required level. The validation evidence base — comprising strain gauge correlation on six cadaveric specimens (MAE 4.2%), fatigue bench testing on twelve specimens (life ratio within factor 1.6), and a fully converged mesh study (GCI 1.3%) — collectively demonstrates that the FEA model reliably predicts worst-case stress concentrations and fatigue life for the COU tibial tray under physiological loading. Sensitivity analysis confirms that the two dominant uncertainty drivers (axial load magnitude and cortical bone modulus) are well-characterized and their combined effect on peak stress is within the validation uncertainty envelope. The operating envelope is fully specified and the validation activities span it adequately. The model is accepted for use in identifying worst-case fatigue operating conditions for the Class II TKA tibial tray at Model Risk Level 3.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
