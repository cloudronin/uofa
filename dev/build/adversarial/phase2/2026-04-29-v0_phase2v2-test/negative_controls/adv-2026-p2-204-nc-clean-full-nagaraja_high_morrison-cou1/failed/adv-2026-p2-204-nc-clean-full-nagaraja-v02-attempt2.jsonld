  "hasSensitivityAnalysis": true,
  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-ortho-sa01",
    "type": "SensitivityAnalysis",
    "name": "Tibial tray FEA sensitivity analysis — bone modulus and interface friction",
    "description": "A one-at-a-time sensitivity analysis varied cortical bone elastic modulus (±30% from nominal 17 GPa), cancellous bone modulus (±50% from nominal 0.8 GPa), and bone-implant interface friction coefficient (0.3 to 0.7) across five physiological load cases (gait, stair ascent, stair descent, chair rise, stumble). Peak interface micromotion varied by up to 22% with bone modulus perturbations and by up to 18% with friction coefficient variation, confirming that the model output is most sensitive to cancellous bone stiffness; this finding directed targeted material characterisation efforts and bounded the uncertainty in the worst-case micromotion prediction to within ±25 µm of the 150 µm acceptance threshold."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/applicability/nagaraja-cou1-ortho-ac01",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: cementless tibial tray fixation in primary TKA",
      "description": "This assessment applies exclusively to primary cementless tibial tray fixation in adult patients (bone mineral density T-score > -2.5) undergoing first-time total knee arthroplasty. Revision TKA, cemented fixation, unicompartmental knee arthroplasty, and paediatric applications are explicitly out of scope. The model has not been validated for osteoporotic bone (T-score ≤ -2.5) and must not be used to support regulatory submissions targeting that population without additional validation."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/envelope/nagaraja-cou1-ortho-oe01",
      "type": "OperatingEnvelope",
      "name": "Physiological loading envelope — tibial tray FEA",
      "description": "Axial compressive load: 1.5 to 3.5 × body weight (750–2450 N for 70 kg reference patient). Shear load: 0 to 0.4 × axial load. Tibial slope: 0° to 7° posterior. Flexion angle at peak load: 0° to 30°. Bone-implant interface friction coefficient: 0.3 to 0.7. Cancellous bone apparent density: 0.2 to 0.8 g/cm³. All simulations must remain within these bounds; extrapolation beyond these ranges is not supported by the validation dataset."
    }
  },
