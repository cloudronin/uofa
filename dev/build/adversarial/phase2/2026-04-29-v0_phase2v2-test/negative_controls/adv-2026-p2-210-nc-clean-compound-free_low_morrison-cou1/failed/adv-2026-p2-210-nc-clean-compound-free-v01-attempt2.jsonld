  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sa/cpb-sensitivity-01",
    "type": "SensitivityAnalysis",
    "name": "CPB hemolysis sensitivity analysis — inlet flow rate and rotational speed",
    "description": "One-at-a-time sensitivity analysis varying inlet flow rate over ±10% of nominal (3–6 L/min range) and rotational speed over ±5% of nominal (2000–3500 RPM range). NIH exhibited strongest sensitivity to rotational speed (Sobol first-order index 0.61) and moderate sensitivity to inlet flow rate (0.29). Pressure head was insensitive to ±5% fluid viscosity variation (index 0.04). Results confirm that worst-case hemolysis occurs at maximum rotational speed and minimum flow rate operating point."
  },
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-mrl2-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation 2 levels for MRL 2. Software quality assurance, numerical code verification, and discretization error factors collectively establish that the numerical solution is trustworthy: GCI of 4.7% on fine mesh with observed convergence order 1.87 demonstrates adequate numerical accuracy. Test conditions and output comparison factors confirm that validation experiments were conducted under representative CPB conditions and that CFD predictions agree with experimental NIH measurements within 8.3% NRMSE — well within the 15% acceptance threshold. The relevance factors confirm that validation activities are directly applicable to the COU: the FDA generic centrifugal pump geometry and CPB operating envelope match the assessment scope. Six factors are appropriately scoped out at MRL 2 per organizational credibility policy CP-2023-03; qualitative assessments for model form and model inputs confirm that these factors are not credibility-limiting at this risk level. The sensitivity analysis confirms that worst-case hemolysis is robustly identified at maximum rotational speed and minimum flow rate, supporting the decision to accept CFD predictions for tolerance sensitivity analysis. No shortfalls in assessed factors exist; no offset rationale is required. The package is accepted for submission to support the 510(k) predicate comparison.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
