      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Predicted NIH values compared against experimental measurements at all 5 operating points using normalized root-mean-square error (NRMSE = 8.3%) and maximum absolute relative error (MARE = 13.1% at lowest flow rate). Both metrics within Gradation 2 acceptance threshold. Comparison includes experimental uncertainty bars from replicate measurements (n=5 per operating point, 95% CI).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/oc-01",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria for MRL 2",
        "description": "Quantitative comparison of primary QoI predictions against experimental data. NRMSE < 15% and MARE < 20% required for Gradation 2. Comparison must include experimental uncertainty representation."
      }
