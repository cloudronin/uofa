  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model (COU1: CPB use, Class II, MRL 2) is accepted based on the following structured evidence: (1) All 7 assessed credibility factors meet or exceed their required Gradation levels — discretization error achieves Gradation 3 against a Gradation 2 requirement, providing additional confidence in numerical accuracy. (2) All 6 scoped-out factors are appropriately excluded per ASME V&V 40 Table 1 for MRL 2, with documented rationale for each. (3) Validation results demonstrate CFD predictions within combined experimental and numerical uncertainty bands across all 5 operating points, with mean NIH error of 6.3% and pressure-head error of 4.1%. (4) The primary QoI (NIH) directly maps to the clinical hemolysis endpoint, and validation activities are conducted within the COU operating envelope using physiologically representative conditions. (5) Software QA and code verification are documented for the commercial solver. No shortfalls in achieved vs. required levels exist; no offset rationale is required. The model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
