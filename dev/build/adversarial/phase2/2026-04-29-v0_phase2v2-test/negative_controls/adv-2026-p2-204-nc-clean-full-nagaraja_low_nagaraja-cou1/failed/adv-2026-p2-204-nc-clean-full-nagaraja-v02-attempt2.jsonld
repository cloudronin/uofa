  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw compression-bending has been assessed against all 13 ASME V&V 40 credibility factors at MRL 3. Twelve of thirteen factors meet or exceed the required credibility level. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — reflects that testing was performed under a single ASTM F1717 loading condition. This shortfall is offset by: (1) the single condition tested is the normative regulatory standard condition, fully representative of the COU; (2) all three primary QoIs show E/uval well below 1.96 with relative errors below 2%; (3) inter-laboratory replication across two independent facilities provides additional confidence in result robustness; (4) sensitivity analysis demonstrates low model sensitivity to the untested parameter variations (friction coefficient sensitivity index < 0.15). The overall credibility evidence is sufficient to support the Medium assurance level decision at MRL 3 for this Class II device application.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-offset-testconditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/cou1/uoa-nc4-clean#factor-test-conditions",
        "justification": "The Test conditions factor achieved Gradation 2 (single fully-controlled and documented loading condition) against a required Gradation 3 (two or more loading conditions). This shortfall is accepted because: the single condition tested is the normative ASTM F1717 regulatory standard, which is the only condition relevant to the COU decision; sensitivity analysis shows model outputs are insensitive to loading rate variation within the F1717-specified range (normalised sensitivity index < 0.12 for crosshead rate ±50%); and inter-laboratory replication at two independent facilities under identical conditions provides confidence that the single-condition result is reproducible and not an artifact of laboratory-specific setup. No additional loading conditions are required to support the regulatory submission decision at Medium assurance level."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
