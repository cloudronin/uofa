  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated titanium pedicle screw, F1717 static loading",
      "description": "Model is applicable to non-cannulated titanium alloy (Ti-6Al-4V) pedicle screws with outer diameter 7.0–8.0 mm and length 40–55 mm tested under ASTM F1717 static compression-bending with UHMWPE vertebral body simulants. The model is not applicable to cannulated variants, dynamic fatigue loading, or screws with outer diameter outside the stated range. Bone quality variation (osteoporotic simulants) is outside scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: F1717 compression-bending mechanical bounds",
      "description": "Valid operating envelope: applied compressive load 0–2500 N; bending moment 0–15 N·m; crosshead displacement rate 5 mm/min (quasi-static); ambient temperature 20–25 °C; UHMWPE simulant density 0.94–0.96 g/cm³; rod diameter 5.5 mm, rod material Ti-6Al-4V. Predictions are not validated outside these mechanical and geometric bounds."
    }
  },
