  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/nagaraja/sensitivity/material-contact-sa",
    "type": "SensitivityAnalysis",
    "name": "Material property and contact stiffness sensitivity analysis",
    "description": "One-at-a-time and Morris screening sensitivity analysis varied Ti-6Al-4V elastic modulus (±10%), yield strength (±8%), and screw-block contact friction coefficient (0.2–0.6) across 500 model evaluations. Construct stiffness QoI showed highest sensitivity to elastic modulus (normalized sensitivity index 0.61), while yield force was most sensitive to yield strength (index 0.74); friction coefficient influence on all three QoIs remained below 0.15, confirming contact parameter uncertainty is a minor contributor to overall prediction uncertainty."
  },
