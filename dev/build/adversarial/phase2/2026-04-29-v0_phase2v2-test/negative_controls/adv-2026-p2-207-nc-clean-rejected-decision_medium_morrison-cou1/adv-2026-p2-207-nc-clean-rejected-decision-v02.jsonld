    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Code verification confirmed via manufacturer-supplied benchmark suite covering laminar pipe flow, rotating reference frame, and species transport. All benchmark residuals converge to machine precision. Gradation 2 satisfied by use of a verified commercial code with documented benchmark results.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/code-verif-mrl2",
        "type": "AcceptanceCriteria",
        "description": "Verified commercial solver with published benchmark suite covering relevant physics (rotating machinery, viscous flow). Gradation 2 requirement met when solver vendor provides documented verification results."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "rationale": "Mesh convergence was assessed on two mesh levels (coarse: 1.2 M cells; medium: 3.8 M cells). Richardson extrapolation yields a Grid Convergence Index (GCI) of 8.4% on the normalized hemolysis index at the worst-case operating point, exceeding the Gradation 2 threshold of GCI < 5%. A fine mesh (11.2 M cells) was not completed due to computational resource constraints. The achieved level is therefore Gradation 1 (GCI quantified but exceeds target threshold), falling below the required Gradation 2.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/disc-error-mrl2",
        "type": "AcceptanceCriteria",
        "description": "Gradation 2 requires Richardson extrapolation-based GCI < 5% on the primary quantity of interest (hemolysis index) at the worst-case operating condition, demonstrated on at least three systematically refined mesh levels."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) are documented and traceable to calibrated instrumentation records. Boundary conditions applied in CFD are derived directly from measured test data. Gradation 2 satisfied.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/test-conditions-mrl2",
        "type": "AcceptanceCriteria",
        "description": "All experimental boundary conditions documented with calibrated measurement traceability. CFD inputs directly derived from measured values. Gradation 2 requires documented test protocol and calibration records."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Predicted normalized hemolysis index compared against experimental measurements using relative error metric. Four of five operating points within 12% relative error; one outlier at 18% attributed to secondary recirculation zone. Quantitative comparison metric documented. Gradation 2 satisfied.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/output-comparison-mrl2",
        "type": "AcceptanceCriteria",
        "description": "Quantitative comparison of CFD predictions against experimental measurements using a defined error metric. Gradation 2 requires documented numerical comparison with uncertainty bounds on both model and experiment."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The primary QoI (normalized hemolysis index RH) is directly linked to the regulatory acceptance criterion (RH < 1 relative to predicate device). Secondary QoIs (shear stress distribution, exposure time) are mechanistically connected to the power-law hemolysis model. Relevance is explicitly documented in the assessment plan.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/qoi-relevance-mrl2",
        "type": "AcceptanceCriteria",
        "description": "QoIs must be directly linked to the regulatory decision criterion and mechanistically justified. Gradation 2 requires documented mapping from model output to decision metric."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry operated under CPB-representative conditions (flow rates 2–6 L/min, speeds 2000–3500 RPM). Fluid properties (bovine blood, 37°C, Hct 35%) match COU. The validation scenario is the same device class and operating regime as the COU, satisfying Gradation 2.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/val-relevance-mrl2",
        "type": "AcceptanceCriteria",
        "description": "Validation scenarios must use the same device geometry, fluid, and operating regime as the COU. Gradation 2 requires explicit documentation of scenario-to-COU mapping."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Numerical solver error (iterative convergence error) is scoped out at MRL 2 because all simulations are run to residual convergence of 1e-6 on all equations, and the commercially verified solver (ANSYS Fluent) provides documented iterative convergence monitoring. The residual convergence criterion is stricter than the Gradation 1 threshold; formal separate assessment of solver error beyond convergence monitoring is not required at MRL 2 for this device class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Use error is scoped out at MRL 2 because the simulation workflow is executed by a single trained analyst following a documented standard operating procedure, with independent review of boundary condition setup and post-processing scripts. The limited team size and single-device focus make formal use-error assessment disproportionate to the risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis power-law exponents) is scoped out at MRL 2 because the Giersiepen-Wurzinger power-law hemolysis model is the industry-standard form for this device class and has been validated against the FDA dataset in peer-reviewed literature. Formal model-form uncertainty quantification is reserved for MRL 3+ assessments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Model input uncertainty (fluid viscosity, density, hematocrit variability) is scoped out at MRL 2. A nominal sensitivity check was performed showing less than 3% variation in RH for ±10% variation in viscosity. Formal probabilistic input uncertainty propagation is not required at MRL 2 for a comparative (relative hemolysis index) assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Test sample characterization (batch-to-batch variability in bovine blood, hematocrit measurement uncertainty) is scoped out at MRL 2 because the FDA benchmark dataset provides aggregate statistics across multiple experimental runs and the relative hemolysis index metric normalizes inter-batch variability. Detailed sample characterization is not required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters between the validation scenario and the COU is scoped out at MRL 2 because the validation and COU use identical geometry, fluid, and operating conditions. There is no extrapolation across device geometries or fluid types; the equivalency concern does not apply in this same-device validation context."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis worst-case identification, MRL 2) is NOT ACCEPTED. The Discretization Error factor achieved only Gradation 1 against a required Gradation 2. Richardson extrapolation on two mesh levels yields a Grid Convergence Index of 8.4% on the normalized hemolysis index at the worst-case operating point, exceeding the required GCI < 5% threshold. A three-level mesh convergence study on systematically refined grids was not completed; the fine mesh (11.2 M cells) run was aborted due to HPC allocation constraints. Because the primary quantity of interest (RH) is used directly in the regulatory acceptance criterion (RH < 1), unquantified mesh-induced error of this magnitude cannot be offset by other evidence without undermining the reliability of the worst-case identification claim. No offset rationale is applicable: the high-consequence clinical context (Class II CPB device, High decision consequence) precludes acceptance of a known discretization shortfall. The assessment team recommends completing the three-level Richardson extrapolation study and resubmitting for credibility review.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
