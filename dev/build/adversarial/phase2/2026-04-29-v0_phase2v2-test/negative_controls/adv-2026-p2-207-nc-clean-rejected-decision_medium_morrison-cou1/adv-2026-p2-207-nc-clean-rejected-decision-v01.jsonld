  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis worst-case identification, MRL 2) is Not accepted. Of the 13 credibility factors assessed under ASME V&V 40, 11 factors meet or exceed their required levels and 2 factors are appropriately scoped out. However, the Discretization Error factor achieved Gradation 2 against a required Gradation 3. The three-level mesh refinement study yielded a Grid Convergence Index of 9.1% for the normalized index of hemolysis (NIH) on the medium mesh used for all tolerance sensitivity sweeps, exceeding the ±5% acceptance threshold established in the V&V plan. Because the production simulations were not executed on the fine mesh (5.4M cells), the discretization contribution to NIH uncertainty is insufficiently controlled to support confident worst-case operating condition identification. No offset rationale is claimed: the shortfall is a material gap in numerical credibility that must be resolved through mesh refinement before an Accepted decision can be issued. The assessment team recommends re-running the five-point operating envelope on the fine mesh and repeating the GCI calculation prior to resubmission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
