  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluid-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5 with achievedLevel meeting or exceeding requiredLevel. Primary QoI (NIH) validated against FDA interlaboratory benchmark data across all 5 COU operating points with relative errors < 10% and all points satisfying ASME V&V 20 validation metric. Monte Carlo UQ (n=5000 samples, Latin hypercube sampling) demonstrates 95th-percentile NIH = 0.062 g/100L, well below clinical threshold of 0.1 g/100L. Sensitivity analysis confirms dominant uncertainty contributors are hemolysis model coefficients (38% of NIH variance) and blood viscosity parameters (22%), both characterized to Gradation 4. Discretization error (GCI < 3.1%) and solver convergence (residuals < 1e-6) are well-controlled. Validation relevance is high: FDA generic pump geometry, matched operating conditions, and interlaboratory experimental data. Independent analyst cross-check confirms reproducibility. The totality of structured evidence supports acceptance of the CFD model for predicting absolute hemolysis levels in the COU2 VAD application.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
