  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision-record",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluid-dynamics-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5. Achieved levels meet or exceed required levels for all factors: discretization error and use error exceed required levels (achievedLevel 5 and 4 vs required 4 and 3 respectively). Monte Carlo UQ (n=10,000) demonstrates 95th-percentile NIH below clinical threshold (0.1 g/100L) at all five COU operating points. Sobol sensitivity analysis identifies RBC damage coefficient k as dominant uncertainty source; targeted calibration reduced hemolysis prediction uncertainty from ±38% to ±14%. Three independent validation datasets (hemolysis, PIV velocity, H-Q curves) all pass quantitative acceptance criteria. No credibility factor gaps remain. The model is fit for purpose for predicting absolute hemolysis levels for Class III VAD regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
