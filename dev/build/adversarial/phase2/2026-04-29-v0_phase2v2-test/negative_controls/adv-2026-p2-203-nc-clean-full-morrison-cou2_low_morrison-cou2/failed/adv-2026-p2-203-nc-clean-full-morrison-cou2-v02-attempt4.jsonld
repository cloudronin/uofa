  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "The CFD solver (OpenFOAM v9) is under version control with full audit trail. Software testing includes unit tests, integration tests, and regression test suite covering hemolysis-relevant turbulence models. A formal SQA plan conforming to ISO 9001 is in place. Code review records and build verification logs are archived and traceable to this assessment.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-sqa",
        "type": "AcceptanceCriteria",
        "name": "SQA acceptance criteria — MRL 5",
        "description": "Solver must be under formal version control with documented regression test suite covering turbulence model and hemolysis scalar transport. All code changes must be peer-reviewed. SQA plan must be ISO 9001 conformant. Gradation 4 requires documented test coverage report and change management log."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes solver and the RBC damage scalar transport equation. Observed order of accuracy (OOA) for velocity: 1.97 (expected 2.0 for second-order scheme). OOA for hemolysis scalar: 1.94. Both within 3% of theoretical order, confirming correct code implementation. Results archived in verification report VR-CODE-2024-07.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-code-verification",
        "type": "AcceptanceCriteria",
        "name": "Code verification acceptance criteria — MRL 5",
        "description": "Method of manufactured solutions must be applied to all governing equations including scalar hemolysis transport. Observed order of accuracy must be within 5% of theoretical order for the discretization scheme employed. Results must be documented in a formal verification report with archived input/output files."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "rationale": "Systematic mesh refinement study performed across four mesh levels (0.8M, 3.2M, 12.8M, 51.2M cells) using Richardson extrapolation. Grid convergence index (GCI) for NIH at the design point: GCI_fine = 1.3%, GCI_medium = 4.7%. Asymptotic range confirmed (GCI ratio = 1.02). Discretization error contribution to total hemolysis prediction uncertainty is 1.3%, negligible relative to model-form uncertainty. Time-step independence verified separately.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-discretization",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria — MRL 5",
        "description": "Richardson extrapolation with GCI must be performed across minimum three mesh levels. GCI on primary QoI (NIH) must be below 5% on the fine mesh. Asymptotic convergence must be confirmed. Time-step independence study required for transient simulations. Gradation 5 requires GCI below 2% and documented asymptotic range confirmation."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Experimental test conditions for the FDA pump benchmark are fully documented: blood analog fluid (glycerol-water, viscosity matched to human blood at 37°C), pump speed controlled to ±5 RPM, flow rate measured with Coriolis meter (±0.5% accuracy), temperature maintained at 37±0.5°C. All five COU operating points are represented in the experimental dataset. Traceability from experimental conditions to CFD boundary conditions is documented in the validation plan.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-test-conditions",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria — MRL 5",
        "description": "All experimental boundary conditions must be documented with measurement uncertainty. Test fluid properties must be traceable to NIST reference data. All COU operating points must be represented in the experimental dataset. Gradation 4 requires documented traceability matrix from experimental conditions to CFD boundary conditions."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Quantitative comparison metrics defined a priori in the validation plan: NIH mean absolute error < 15% of mean measured value, velocity field mean error < 10% of tip velocity, H-Q deviation < 5%. All three metrics achieved (8%, 4.2%, 3.8% respectively). Statistical comparison uses validation uncertainty (u_val) combining experimental uncertainty and numerical uncertainty per ASME V&V 20. Comparison metric E/u_val < 1.0 at all operating points.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-output-comparison",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria — MRL 5",
        "description": "Quantitative comparison metrics must be defined a priori. Comparison must account for both experimental and numerical uncertainty per ASME V&V 20 framework. E/u_val ratio must be below 1.0 for primary QoI (NIH) at all COU operating points. Gradation 4 requires documented a priori metric definitions and ASME V&V 20 uncertainty combination."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Primary QoI is NIH (g/100L), which is the clinically accepted hemolysis metric for VAD devices and directly maps to the regulatory acceptance criterion. Secondary QoIs (velocity field, pressure-flow curve) are mechanistically linked to hemolysis through shear stress exposure history. QoI relevance matrix documented in the validation plan, with explicit traceability from clinical endpoint (patient hemolysis risk) to computational output (NIH).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-qoi-relevance",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criteria — MRL 5",
        "description": "Primary QoI must be the clinically and regulatorily accepted hemolysis metric. Traceability from clinical endpoint to computational QoI must be documented. Secondary QoIs must be mechanistically justified. Gradation 4 requires a documented QoI relevance matrix with explicit clinical-to-computational traceability."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Validation activities performed on the FDA generic centrifugal pump, which shares geometric similarity (impeller tip diameter 52 mm, specific speed Ns = 2800) and operating conditions with the target VAD device. All five COU operating points are within the validated envelope. Differences between validation geometry and target device are documented and bounded: impeller blade count differs by one (5 vs 6 blades); sensitivity analysis confirms NIH prediction insensitivity to this geometric variation (ΔS_T < 0.03).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-validation-relevance",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance acceptance criteria — MRL 5",
        "description": "Validation geometry must be within the same pump family (centrifugal, similar specific speed) as the target device. All COU operating points must be within the validated envelope. Geometric differences between validation and target must be documented and their impact on QoI bounded. Gradation 4 requires documented geometric similarity analysis and sensitivity to geometric differences."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Iterative convergence monitored via residual norms and QoI monitors. All simulations converged to residual norms below 1e-6 for continuity and momentum; NIH monitor converged to variation below 0.1% over final 500 iterations. Round-off error assessed via double-precision arithmetic verification (64-bit IEEE 754). Solver error budget documented as < 0.5% of NIH prediction, negligible relative to discretization and model-form errors.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-solver-error",
        "type": "AcceptanceCriteria",
        "name": "Numerical solver error acceptance criteria — MRL 5",
        "description": "Iterative convergence must be demonstrated via residual norms and QoI monitors. Convergence criterion for primary QoI must be below 0.5% variation. Round-off error must be assessed and documented. Solver error contribution to total uncertainty budget must be quantified. Gradation 4 requires documented solver error budget with contribution to total NIH uncertainty."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "rationale": "Simulation setup checklist applied by a second analyst (independent review). Boundary condition inputs verified against experimental protocol documentation by a third party. Mesh quality metrics (skewness < 0.85, non-orthogonality < 70°) verified by automated QA script. Turbulence model selection (SST k-ω) documented with justification referencing benchmark studies. Post-processing scripts version-controlled and independently validated against analytical test cases.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-use-error",
        "type": "AcceptanceCriteria",
        "name": "Use error acceptance criteria — MRL 5",
        "description": "Simulation setup must be independently reviewed by a second qualified analyst. Boundary condition inputs must be traceable to experimental protocol. Mesh quality metrics must be verified by automated QA. Gradation 3 requires independent review; Gradation 4 additionally requires third-party verification of boundary condition inputs and version-controlled post-processing."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "SST k-ω turbulence model selected based on published benchmark performance for confined rotating flows. RBC damage model (power-law Lagrangian accumulation, Giersiepen-Wurzinger coefficients) calibrated against independent hemolysis datasets. Model-form uncertainty estimated via comparison of three turbulence model variants (k-ε realizable, k-ω SST, RSM): NIH spread across models is 12%, incorporated into total uncertainty budget. Model-form error is the dominant uncertainty source (confirmed by sensitivity analysis).",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-model-form",
        "type": "AcceptanceCriteria",
        "name": "Model form acceptance criteria — MRL 5",
        "description": "Turbulence model selection must be justified by published benchmark evidence for similar flow regimes. RBC damage model must be calibrated against independent data. Model-form uncertainty must be estimated via multi-model comparison. Gradation 4 requires documented multi-model uncertainty estimate incorporated into total uncertainty budget."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "All model inputs characterized with probability distributions: blood viscosity (normal, μ=3.5 mPa·s, σ=0.35 mPa·s based on literature meta-analysis), RBC damage coefficient k (log-normal, μ=1.8e-6, σ=0.36e-6 based on calibration posterior), turbulent dissipation rate BC (uniform ±25% of nominal). Input uncertainty propagated through Monte Carlo ensemble (n=10,000). Input data sources are peer-reviewed publications and internal calibration datasets with full provenance.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-model-inputs",
        "type": "AcceptanceCriteria",
        "name": "Model inputs acceptance criteria — MRL 5",
        "description": "All uncertain model inputs must be characterized with probability distributions sourced from peer-reviewed data or calibration posteriors. Input uncertainty must be propagated through the model via Monte Carlo or equivalent. Gradation 4 requires documented input distribution derivation with literature or calibration provenance for each uncertain parameter."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "rationale": "Experimental hemolysis dataset comprises n=15 independent test runs per operating point (75 total) using fresh human blood from n=8 donors (hematocrit 38±3%). Inter-donor variability quantified and incorporated into experimental uncertainty. Sample size sufficient for statistical comparison per ASME V&V 20 (power > 0.90 at α=0.05). PIV dataset comprises n=200 velocity fields per operating point from n=3 independent experiments.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-test-samples",
        "type": "AcceptanceCriteria",
        "name": "Test samples acceptance criteria — MRL 5",
        "description": "Experimental sample size must be sufficient for statistical comparison per ASME V&V 20. For hemolysis, minimum n=10 independent runs per operating point required at Gradation 3; n=15 with inter-donor variability characterization required at Gradation 4. Biological variability must be quantified and incorporated into experimental uncertainty."
      }
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "CFD boundary conditions mapped to experimental conditions via a documented equivalency matrix. Flow rate equivalency: Coriolis meter measurement used directly as CFD inlet BC (±0.5% traceability). Speed equivalency: encoder measurement at ±5 RPM used as CFD rotational speed (±0.13% at 3800 RPM). Fluid property equivalency: viscosity measured via cone-and-plate rheometer at 37°C for each test batch, used to set CFD viscosity. All equivalency mappings documented with uncertainty quantification.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/morrison/cou2/ac-input-equivalency",
        "type": "AcceptanceCriteria",
        "name": "Input parameter equivalency acceptance criteria — MRL 5",
        "description": "A documented equivalency matrix must map all experimental measurements to CFD boundary conditions. Measurement uncertainty for each experimental input must be propagated to CFD BC uncertainty. Gradation 4 requires documented equivalency matrix with per-parameter uncertainty quantification and traceability to calibrated measurement instruments."
