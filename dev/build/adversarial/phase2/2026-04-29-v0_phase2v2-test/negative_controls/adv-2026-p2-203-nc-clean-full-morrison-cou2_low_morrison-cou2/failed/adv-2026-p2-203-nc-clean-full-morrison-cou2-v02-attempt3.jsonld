  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling-group",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5 requirements. Achieved levels meet or exceed required levels for all factors: Software QA (4/4), Numerical Code Verification (5/4), Discretization Error (4/4), Test Conditions (4/4), Output Comparison (4/4), QoI Relevance (4/3), Validation Relevance (4/4), Solver Error (4/3), Use Error (3/3), Model Form (4/4), Model Inputs (4/4), Test Samples (4/3), Equivalency (3/3). Monte Carlo UQ with 5000 samples demonstrates NIH 95% prediction interval (0.0023–0.0041 g/100 L) remains below clinical threshold (0.01 g/100 L) with a safety margin factor of 2.4. Dominant uncertainty sources (hemolysis model coefficients, rotor tip clearance) are quantified and bounded. Three independent validation datasets (bench hemolysis, PIV velocity, pressure-flow curve) provide convergent evidence of model adequacy. No credibility factor gaps remain. Decision: Accepted for use in regulatory submission supporting VAD hemolysis claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
