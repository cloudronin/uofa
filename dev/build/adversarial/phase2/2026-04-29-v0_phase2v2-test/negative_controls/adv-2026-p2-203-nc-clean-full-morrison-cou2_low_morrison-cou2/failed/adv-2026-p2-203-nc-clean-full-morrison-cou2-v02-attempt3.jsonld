    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis CFD applicability domain",
      "description": "Model is applicable to centrifugal blood pumps with specific speed Ns between 1500 and 4000 rpm·(L/min)^0.5·mmHg^-0.75, operating with human whole blood at hematocrit 35–45%. Applicability is restricted to rotor tip speeds below 12 m/s where cavitation inception is not expected. Newtonian blood rheology assumption is valid for shear rates above 100 s^-1; regions of recirculation with shear rates below this threshold are flagged for additional scrutiny. Hemolysis model (modified Giersiepen-Wurzinger power law) is validated only for exposure times between 0.001 s and 1.0 s."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD centrifugal pump operating envelope",
      "description": "Five nominal operating points spanning: flow rate Q = 3.0–6.0 L/min (increment 0.75 L/min); rotational speed N = 2400–3600 rpm (increment 300 rpm); inlet pressure 5–15 mmHg; outlet pressure 80–120 mmHg; fluid temperature 37 ± 1 °C; blood viscosity 0.0035 ± 0.0005 Pa·s; hematocrit 40 ± 5%. Geometric tolerance on impeller tip diameter: ±0.05 mm. All operating points lie within the validated applicability domain of the hemolysis power-law model."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/sensitivity/cou2-monte-carlo",
    "type": "SensitivityAnalysis",
    "name": "Monte Carlo global sensitivity analysis for VAD hemolysis prediction",
    "description": "A 5000-sample Monte Carlo sensitivity analysis was performed by simultaneously varying seven uncertain inputs — blood viscosity (±14%), hemolysis model exponent alpha (±8%), hemolysis model coefficient C (±12%), rotor tip clearance (±0.05 mm), inlet hematocrit (±5%), turbulent dissipation rate boundary condition (±20%), and wall roughness (±0.01 mm) — using Latin hypercube sampling. Sobol first-order and total-order sensitivity indices were computed; the hemolysis model coefficient C (S_T = 0.41) and exponent alpha (S_T = 0.33) together account for 74% of output variance in predicted normalized index of hemolysis (NIH), with rotor tip clearance contributing an additional 15% (S_T = 0.15). The 95th-percentile NIH prediction interval is 0.0023–0.0041 g/100 L, remaining below the clinical threshold of 0.01 g/100 L across all five operating points."
  },
