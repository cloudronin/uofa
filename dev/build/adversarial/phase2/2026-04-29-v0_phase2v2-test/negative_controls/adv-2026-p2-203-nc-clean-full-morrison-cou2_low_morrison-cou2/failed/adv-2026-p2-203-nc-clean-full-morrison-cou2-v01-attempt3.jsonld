  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision/accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biomechanics-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at Model Risk Level 5. Achieved levels meet or exceed required levels for all factors: discretization error (achieved 5, required 4), numerical solver error (achieved 4, required 3), and equivalency of input parameters (achieved 4, required 4) provide additional margin. Monte Carlo uncertainty quantification with 10,000 samples demonstrates that predicted NIH values remain below the clinical threshold of 0.01 g/100L with 95% confidence across all five COU operating points. Sensitivity analysis identifies hemolysis model coefficient C as the dominant uncertainty source (52% of variance), and targeted coefficient uncertainty reduction has been incorporated into the UQ bounds. Validation results show E/U_val below 1.0 for all operating points on the identical FDA generic pump geometry. The provenance chain from raw experimental data through CFD outputs to decision is complete and traceable. The credibility evidence is sufficient to support regulatory submission for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
