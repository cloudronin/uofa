  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision-record",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/org/morrison-vv40-team/lead-assessor",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5. Achieved levels meet or exceed required levels for all factors: discretization error achieved Gradation 5 against a requirement of 4; solver error and use error achieved at or above requirement. Monte Carlo UQ (10,000 samples) demonstrates hemolysis index predictions remain below the 0.01 g/100 L clinical threshold across the full operating envelope with 97.3% probability. Sobol sensitivity analysis confirms dominant uncertainty contributors (power-law exponent, rotational speed) are tightly constrained by experimental data. Validation metric E < U_exp + U_num confirmed at all 5 operating points. No credibility gaps remain. Package accepted for regulatory submission supporting Class III VAD hemolysis claim.",
