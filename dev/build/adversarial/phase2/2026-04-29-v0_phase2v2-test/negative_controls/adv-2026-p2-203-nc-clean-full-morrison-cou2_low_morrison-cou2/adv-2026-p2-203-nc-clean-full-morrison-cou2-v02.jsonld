  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 5 with achievedLevel equal to or exceeding requiredLevel (all at 5/5). The CFD hemolysis prediction model satisfies all ASME V&V 40 credibility requirements for a Class III VAD device at the highest model risk level. Key evidence supporting acceptance: (1) MMS-verified solver with GCI < 1.8% on fine mesh; (2) five-point experimental validation with MARE 11.4% against pre-specified 15% threshold; (3) Monte Carlo UQ (N=10,000) with dominant sensitivity to hemolysis exponent alpha (S1=0.41) fully characterised and propagated into prediction intervals; (4) 95th-percentile NIH prediction interval upper bound remains below clinical threshold (0.0087 g/100 L vs. threshold 0.01 g/100 L), providing 13% margin; (5) validation experiments performed on identical pump geometry spanning the full COU operating envelope with no extrapolation; (6) complete SQA, use-error controls, and independent peer review. The structured evidence chain from foundational experimental data through UQ propagation to decision margin is complete and traceable. The credibility assessment team unanimously accepts this model for COU2 regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
