  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed at MRL 3 for this Class II tibial tray contact stress prediction model. Achieved levels meet or exceed required levels for every factor: five factors achieved Gradation 3 (discretization error, output comparison, model inputs, software quality assurance, and numerical code verification via GCI), and eight factors achieved the required Gradation 2. No factor falls below its required level; no offset rationale is required. The Monte Carlo uncertainty quantification demonstrates that model predictions fall within combined experimental and model uncertainty bounds (E/uval = 0.82 < 1.0) for the primary QoI across all five gait phases. The sensitivity analysis identifies cortical bone modulus as the dominant uncertainty driver (61% of variance), and the experimental characterisation of bone modulus from 24 physical coupon specimens directly addresses this dominant source. The validation experiments use geometry, material, and loading conditions directly representative of the COU, with documented equivalency and bounded discrepancies. The provenance chain from raw experimental data through validation results to this credibility assessment is complete and traceable. The package is accepted for use in design verification of the Class II tibial tray system under the stated COU operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
