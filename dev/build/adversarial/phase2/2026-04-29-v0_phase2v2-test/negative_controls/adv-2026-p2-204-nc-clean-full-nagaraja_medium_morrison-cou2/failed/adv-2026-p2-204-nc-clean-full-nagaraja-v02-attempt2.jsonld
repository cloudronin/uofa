  "hasSensitivityAnalysisObject": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-ortho-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Tibial tray contact stress sensitivity analysis — bone modulus and boundary condition sweep",
    "description": "A one-at-a-time and Monte Carlo global sensitivity analysis was performed varying cortical bone elastic modulus (±30%, uniform distribution), tibial bone-implant interface friction coefficient (0.2–0.6), peak gait axial load (1800–2800 N), and polyethylene yield stress (±15%). Sobol indices revealed that cortical bone modulus accounts for 61% of variance in peak von Mises stress, followed by axial load magnitude at 24%; interface friction and polyethylene yield stress together contribute less than 15%. These findings confirm that experimental characterisation of patient-specific bone stiffness is the highest-priority uncertainty reduction activity for future COU iterations."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray contact stress prediction under physiological gait loading (Class II)",
    "description": "A finite-element model is used to predict peak contact stress and subsurface strain distributions in the tibial tray of a total knee replacement under physiological gait loading. Model influence is MODERATE (model supplements bench testing for stress-distribution characterisation); decision consequence is MODERATE (design verification for a Class II implant with established clinical predicate). Model Risk Level 3.",
    "intendedUse": "Use FE/CFD model to predict relative peak contact stress distributions across five gait-cycle phases for a Class II tibial tray implant. Results support design verification and do not replace physical bench testing for regulatory submission.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: standard-geometry tibial tray, adult population",
      "description": "The model is applicable to symmetric flat-on-curved tibial tray geometries with a polyethylene insert thickness of 8–12 mm. Patient population is restricted to adults (body mass 55–110 kg). The model is not applicable to unicompartmental designs, revision geometries with augments, or paediatric cases. Bone quality is assumed to fall within DEXA T-score range −1.0 to +2.5 (non-osteoporotic)."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: gait loading and geometric bounds",
      "description": "Axial compressive load: 1800–2800 N (corresponding to 2.5–3.8× body weight for the target population). Anterior-posterior shear: 0–350 N. Flexion angle: 0–60° (heel-strike to mid-stance gait phases). Tibial component sizing: size 3–6 (medial-lateral width 68–82 mm). Polyethylene insert thickness: 8–12 mm. Bone-implant interface assumed fully bonded (cemented fixation). Operating temperature: 37 °C ± 1 °C. All conditions derived from ISO 14243-1 and ISO 14243-3 loading profiles."
    }
  },
