  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray contact stress under physiological gait loading (Class II)",
    "description": "A finite-element model is used to predict peak contact stress and subsurface shear stress distributions in a UHMWPE tibial insert under ISO 14243-1 gait loading profiles. Model influence is MODERATE (model supplements physical wear testing); decision consequence is MODERATE (supports design selection between two candidate insert geometries). Model Risk Level 3.",
    "intendedUse": "Use FEA to predict relative peak contact stress and subsurface shear stress in a Class II tibial tray insert across three gait loading scenarios (level walking, stair ascent, chair rise). Results guide design selection; absolute stress magnitudes are compared against material yield thresholds.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: UHMWPE tibial inserts, ISO 14243-1 loading only",
      "description": "This COU applies exclusively to flat-on-curved UHMWPE tibial inserts with a thickness between 8 mm and 14 mm, loaded according to ISO 14243-1 gait profiles. The model is not applicable to mobile-bearing designs, metal-backed inserts with incomplete bonding, or loading conditions outside the ISO 14243-1 envelope. Patient-specific bone remodeling and cement fixation variability are outside scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: gait load and geometry bounds",
      "description": "Axial compressive force: 1.0–3.2 kN (ISO 14243-1 peak range scaled to 50th–95th percentile body weight). Flexion angle: 0–60 degrees. Tibial insert thickness: 8–14 mm. UHMWPE elastic modulus: 700–1000 MPa; Poisson ratio: 0.40–0.46. Tibial baseplate tilt: ±3 degrees from neutral. Loading frequency: 1 Hz. All simulations conducted at ambient temperature (23 ± 2 °C) consistent with ISO 14243-1 test conditions."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-ortho-sa-001",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Monte Carlo sensitivity analysis — tibial tray FEA",
    "description": "A one-at-a-time sensitivity study varied UHMWPE elastic modulus (±15%), contact surface friction coefficient (0.04–0.10), and peak axial load (±10% of ISO 14243-1 nominal) independently; peak contact stress varied by at most 8% across these ranges, confirming low sensitivity to material property uncertainty. A subsequent 500-sample Monte Carlo analysis jointly sampled all three parameters from their uncertainty distributions and found that 95th-percentile peak contact stress remained 12% below the UHMWPE yield stress threshold, supporting the adequacy of the nominal design with margin."
  },
