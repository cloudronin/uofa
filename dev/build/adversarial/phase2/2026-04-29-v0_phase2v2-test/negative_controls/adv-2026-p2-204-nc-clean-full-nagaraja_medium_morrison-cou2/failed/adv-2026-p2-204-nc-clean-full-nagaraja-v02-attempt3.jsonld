  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed at Model Risk Level 3 for this Class II orthopedic tibial tray FEA model. Achieved credibility levels meet or exceed required levels for all factors: software quality assurance (3 ≥ 2), numerical code verification (2 ≥ 2), discretization error (3 ≥ 2), test conditions (2 ≥ 2), output comparison (3 ≥ 2), relevance of QoI (2 ≥ 2), relevance of validation activities (2 ≥ 2), numerical solver error (2 ≥ 2), use error (2 ≥ 1), model form (2 ≥ 2), model inputs (3 ≥ 2), test samples (2 ≥ 2), and equivalency of input parameters (2 ≥ 2). Monte Carlo uncertainty quantification confirms that 95th-percentile peak contact stress remains 12% below the UHMWPE yield threshold across the full operating envelope. Validation against Furmanski et al. experimental data yields MAPE of 4.2%, well within the 10% acceptance criterion. The structured evidence base, complete provenance chain, and satisfactory sensitivity analysis collectively support acceptance of the model for its intended use in guiding design selection between candidate tibial insert geometries.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
