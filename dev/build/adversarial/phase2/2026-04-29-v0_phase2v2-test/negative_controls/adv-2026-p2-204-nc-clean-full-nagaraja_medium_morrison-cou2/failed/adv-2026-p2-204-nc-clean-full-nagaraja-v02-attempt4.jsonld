  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray contact stress under physiological gait loading (Class II TKR)",
    "description": "A finite element model is used to predict peak contact stress on the tibial tray insert of a total knee replacement device under physiological gait loading conditions. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (incorrect prediction could lead to under-designed insert geometry). Model Risk Level 3.",
    "intendedUse": "Use FE simulation to predict peak contact stress on UHMWPE tibial insert across five gait-cycle load cases. Results must agree with experimental measurements within ±15% to support design verification. No Monte Carlo UQ required; deterministic sensitivity sweeps are sufficient at MRL 3.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: physiological adult gait, standard tibial geometry",
      "description": "The model is applicable only to skeletally mature adult patients (body mass 50–120 kg) with standard tibial plateau geometry (medial-lateral width 70–85 mm, anterior-posterior depth 45–58 mm). Paediatric anatomy, revision implants with augments, and unicompartmental designs are explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: gait load magnitudes and alignment tolerances",
      "description": "Axial compressive force: 1.0–3.2 kN (level walking, stair ascent/descent). Anterior-posterior shear: 0–0.4 kN. Tibial component varus-valgus alignment: ±3°. Flexion angle during peak load: 0–30°. UHMWPE insert thickness: 8–12 mm. Strain rate: quasi-static (0.01–0.1 s⁻¹). Ambient temperature: 37 ± 1 °C (simulated in vitro)."
    }
  },
  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-ortho-sa001",
    "type": "SensitivityAnalysis",
    "name": "Sensitivity analysis: material property and alignment parameter influence on peak contact stress",
    "description": "A one-at-a-time (OAT) sensitivity sweep varied UHMWPE elastic modulus (±20%), yield stress (±15%), tibial component varus-valgus alignment (±3°), and axial load magnitude (±10%) independently. Peak contact stress showed greatest sensitivity to varus-valgus malalignment (up to 18% change per degree beyond ±2°) and UHMWPE elastic modulus (12% change across the full range), while axial load variation produced near-linear response (R²=0.98). Results confirm that alignment tolerance is the dominant uncertainty driver and that the ±15% acceptance criterion remains achievable within the defined operating envelope."
  },
