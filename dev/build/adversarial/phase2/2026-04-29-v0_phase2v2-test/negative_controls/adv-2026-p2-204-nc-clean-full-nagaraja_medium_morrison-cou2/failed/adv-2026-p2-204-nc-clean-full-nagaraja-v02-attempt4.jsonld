  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed at MRL 3 for this Class II tibial tray contact stress prediction model. Achieved levels meet or exceed required levels across every factor: software quality assurance (3≥2), numerical code verification (2≥2), discretization error (3≥2), test conditions (2≥2), output comparison (2≥2), relevance of QoI (2≥2), relevance of validation activities (2≥2), numerical solver error (2≥2), use error (2≥2), model form (2≥2), model inputs (2≥2), test samples (2≥2), and equivalency of input parameters (2≥2). The primary validation metric (MAPE=9.3%) falls comfortably within the ±15% acceptance threshold. Sensitivity analysis confirms that alignment tolerance is the dominant uncertainty driver and that the acceptance criterion remains achievable across the defined operating envelope. The provenance chain is complete: all validation results are traceable to experimental datasets, simulation activities, and uncertainty quantification records. No credibility gaps remain. The model is accepted for use in the COU as defined.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
