  "hasSensitivityAnalysis": true,
  "sensitivityAnalysisDetail": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-ortho-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Tibial tray micromotion sensitivity analysis — bone modulus and friction coefficient",
    "description": "A one-at-a-time and Morris screening sensitivity analysis was performed varying cortical bone elastic modulus (±20% around 17 GPa), cancellous bone modulus (±30% around 0.5 GPa), and tibial tray–bone interface friction coefficient (0.3–0.7). Peak interface micromotion predictions varied by ±18% across the full parameter range, with cancellous bone modulus identified as the dominant driver (Sobol first-order index 0.52). Friction coefficient contributed a secondary effect (index 0.31). Results confirmed that model predictions remain below the 150 µm osseointegration threshold across all sampled parameter combinations, supporting the acceptance decision."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho",
    "type": "ContextOfUse",
    "name": "COU1: Cementless tibial tray micromotion prediction under physiological gait loading",
    "description": "A finite-element model is used to predict relative interface micromotion at the tibial tray–bone interface under ISO 14243-1 gait loading for a Class II cementless TKA device. Model influence is HIGH (computational predictions are the primary basis for fixation adequacy claims); decision consequence is MODERATE (incorrect prediction could lead to suboptimal fixation geometry but implant is retrievable). Model Risk Level 3.",
    "intendedUse": "Use FE/CFD model to predict peak and mean micromotion at five tibial tray fixation zones across the ISO 14243-1 gait cycle for a representative bone surrogate. Results must demonstrate micromotion below 150 µm at all zones to support osseointegration claims.",
    "modelInfluence": "High",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint — cementless TKA tibial tray, adult population",
      "description": "Model applicability is constrained to cementless tibial tray designs with flat or minimally domed articular surfaces, implanted in adult patients (bone mineral density T-score > −2.5). Cemented fixation, revision implants, and paediatric anatomy are explicitly out of scope. Bone surrogate material properties must fall within the validated range (cortical modulus 14–20 GPa; cancellous modulus 0.3–0.8 GPa)."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope — ISO 14243-1 gait cycle bounds",
      "description": "Valid operating range: axial compressive load 0–2800 N (peak heel-strike), anterior–posterior shear 0–400 N, flexion–extension angle 0–60°, internal–external rotation ±10°. Tibial tray size range: 62–82 mm mediolateral width. Bone surrogate density 0.3–1.8 g/cm³. Gait cycle frequency 1 Hz. Simulations outside these bounds require re-assessment of model credibility."
    }
  },
