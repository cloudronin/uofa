  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed for the Nagaraja COU1 orthopedic tibial tray micromotion model at MRL 3. Achieved levels meet or exceed required levels for every factor: five factors achieved Gradation 3 (discretization error, output comparison, model inputs, software quality assurance, and test conditions), and eight factors achieved Gradation 2 meeting the MRL 3 requirement. The primary quantity of interest (peak interface micromotion) was validated against six cadaveric specimens with R² = 0.93 and MAE = 11.2 µm, well within the 150 µm osseointegration threshold. Monte Carlo uncertainty quantification confirmed that the 95th-percentile prediction interval (68–134 µm) remains below the threshold across all sampled parameter combinations. Sensitivity analysis identified cancellous bone modulus as the dominant uncertainty driver (Sobol index 0.52); this uncertainty is bounded within the validated operating envelope. The provenance chain is complete from raw cadaveric measurement data through model inputs to validation results. No credibility factor gaps remain. The model is accepted for use in supporting the osseointegration adequacy claim for this Class II cementless TKA tibial tray.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
