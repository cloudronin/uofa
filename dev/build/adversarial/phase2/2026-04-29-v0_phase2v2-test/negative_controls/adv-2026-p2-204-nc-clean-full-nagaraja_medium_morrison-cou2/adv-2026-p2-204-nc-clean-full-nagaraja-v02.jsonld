  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray contact stress prediction for TKR 510(k) submission",
    "description": "An FEA model is used to predict peak contact stress and stress distribution on the tibial tray articulating surface of a Class II total knee replacement system under ISO 14243-1 physiological loading conditions. Model influence is MODERATE (model supplements bench testing); decision consequence is MODERATE (supports 510(k) substantial equivalence, not primary safety basis). Model Risk Level 3.",
    "intendedUse": "Use FEA to predict peak contact stress (MPa) and stress distribution uniformity index on the tibial polyethylene insert across five standardized gait-cycle load cases. Results used to demonstrate equivalence to predicate device stress profiles within a 15% margin.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: adult TKR tibial tray under ISO 14243-1 loading",
      "description": "Model is applicable to adult patients (body mass 60–120 kg) with standard tibial tray geometries (tibial plateau width 70–85 mm, posterior slope 0–7 degrees). Excludes revision TKR components, unicompartmental knee systems, and pediatric applications. Material properties restricted to GUR 1020 UHMWPE tibial inserts with cobalt-chromium tibial trays."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho/envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ISO 14243-1 physiological load and kinematic bounds",
      "description": "Axial compressive load: 300–2600 N (peak heel-strike to toe-off per ISO 14243-1). Flexion angle: 0–120 degrees. Anterior-posterior translation: ±10 mm. Internal-external tibial rotation: ±10 degrees. Loading rate: quasi-static to 1 Hz cyclic. Tibial insert thickness: 9–14 mm. Contact area expected range: 150–600 mm². Peak contact stress expected range: 8–35 MPa. All simulations conducted at 37°C material property set."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/nagaraja-cou1-ortho-sa-001",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and variance-based sensitivity analysis for tibial tray FEA model",
    "description": "A variance-based (Sobol) sensitivity analysis was conducted varying six input parameters across their uncertainty ranges: UHMWPE elastic modulus (±15%), tibial tray surface roughness (±20%), axial load magnitude (±10%), flexion angle (±5 degrees), coefficient of friction (0.04–0.12), and tibial insert thickness (±1 mm). Peak contact stress was most sensitive to UHMWPE elastic modulus (first-order Sobol index S1 = 0.41) and axial load magnitude (S1 = 0.33), with coefficient of friction contributing negligibly (S1 = 0.03). Total-order indices confirmed no significant higher-order interaction effects beyond the top two parameters. This analysis informed the uncertainty quantification bounds reported in ValidationResult VR-001 and VR-002 and justified the focused experimental calibration of UHMWPE material properties."
  },
