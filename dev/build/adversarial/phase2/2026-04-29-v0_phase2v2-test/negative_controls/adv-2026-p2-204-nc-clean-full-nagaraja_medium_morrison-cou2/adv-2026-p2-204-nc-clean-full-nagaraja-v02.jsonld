  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model for tibial tray contact stress prediction at MRL 3 (Class II, moderate model influence, moderate decision consequence) is accepted for use in the 510(k) submission. All 13 credibility factors have been assessed with achieved levels meeting or exceeding required levels. Key evidence supporting acceptance: (1) Discretization error controlled to GCI = 1.8% on peak contact stress; (2) Validation against five cadaveric specimens per ISO 14243-1 with MAPE = 8.3%, well within the 15% acceptance threshold; (3) Material constitutive model verified against published UHMWPE data (R² = 0.994); (4) Variance-based sensitivity analysis identifies UHMWPE elastic modulus and axial load as dominant uncertainty sources, and Monte Carlo UQ confirms 95% prediction intervals contain all experimental observations; (5) Independent peer review of model setup completed with no unresolved discrepancies; (6) Equivalency of validation inputs to COU inputs formally assessed with only minor non-equivalency (< 3% impact) documented and justified. The credibility evidence package provides sufficient confidence that the model predictions of peak contact stress and stress distribution uniformity index are fit for purpose to support substantial equivalence determination for the TKR tibial tray system.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
