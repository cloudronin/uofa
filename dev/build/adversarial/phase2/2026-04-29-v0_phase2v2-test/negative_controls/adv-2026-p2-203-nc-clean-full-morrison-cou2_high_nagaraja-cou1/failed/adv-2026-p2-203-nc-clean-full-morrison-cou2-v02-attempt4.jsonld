  "hasSensitivityAnalysisObject": {
    "id": "https://uofa.net/synth/sa/nc3-mrl5-global-sensitivity",
    "type": "SensitivityAnalysis",
    "name": "Global variance-based sensitivity analysis for pedicle screw FEA QoIs",
    "description": "A Sobol' variance decomposition was performed over 2048 quasi-random Latin-hypercube samples spanning cortical bone modulus (±15%), rod-screw interface friction coefficient (0.1–0.4), titanium rod diameter tolerance (±0.05 mm), and polyaxial head locking torque (±10%). Construct stiffness exhibited first-order Sobol' indices of S1=0.61 for cortical bone modulus and S1=0.22 for interface friction, while force at 40 mm displacement was dominated by rod diameter tolerance (S1=0.44) and bone modulus (S1=0.31); all remaining factors contributed less than 8% individually, confirming that the two dominant inputs must be characterised to sub-5% uncertainty to meet the MRL-5 acceptance threshold.",
    "method": "Sobol' variance decomposition (Saltelli 2010 estimator)",
    "dominantFactors": [
      "cortical bone modulus",
      "rod-screw interface friction coefficient",
      "titanium rod diameter tolerance"
    ],
    "sampleSize": 2048
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated 7.5 mm pedicle screw, static loading only",
      "description": "The credibility assessment applies exclusively to solid (non-cannulated) titanium-alloy pedicle screws with nominal outer diameter 7.5 mm ± 0.1 mm, tested or simulated under quasi-static monotonic ASTM F1717 compression-bending at crosshead displacement rates of 1–5 mm/min. Dynamic fatigue loading, cannulated variants, screws outside the 6.5–8.5 mm diameter band, and constructs with more than two vertebral levels are explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ASTM F1717 quasi-static compression-bending conditions",
      "description": "Valid operating domain: axial compressive load 0–2500 N applied at 10° from construct axis per ASTM F1717 fixture geometry; crosshead displacement rate 1–5 mm/min; ambient temperature 20–25 °C; relative humidity 40–60%; rod diameter 5.5 mm Ti-6Al-4V; screw-rod interface locking torque 8–12 N·m; polyaxial head angulation 0–15°. Cortical bone surrogate (Sawbones 40 pcf) modulus 2.5–3.5 GPa. Extrapolation beyond these bounds is not supported by the validated model."
    }
  },
