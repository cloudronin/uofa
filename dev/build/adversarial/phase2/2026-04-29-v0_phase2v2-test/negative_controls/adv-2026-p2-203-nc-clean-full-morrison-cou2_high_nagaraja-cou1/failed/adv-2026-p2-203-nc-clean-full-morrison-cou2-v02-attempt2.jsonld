  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/org/depuy-synthes-biomechanics-lab/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model for non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending is accepted as sufficiently credible for the stated COU at MRL 5. Twelve of thirteen credibility factors meet or exceed their required levels. All three primary QoIs satisfy the pre-specified acceptance criteria (E/uval < 1.96, difference < 10%). The single shortfall — Test conditions assessed at Gradation 3 against a required Gradation 4 — is offset by the exceptional performance on Output comparison (Gradation 5), the conservative under-prediction of yield force, the complete specimen-by-specimen input equivalency mapping, and the independent FDA CDRH reproduction of results. The global sensitivity analysis confirms that the single test configuration adequately exercises the dominant uncertainty sources (material properties and screw OD), and the operating envelope explicitly restricts the model's claims to the validated configuration. The credibility evidence package is complete, traceable, and sufficient to support regulatory submission for this Class II device.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/cf/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 3 (single loading configuration) against a required Gradation 4 (two or more configurations). This shortfall is accepted because: (1) the Output comparison factor achieved Gradation 5, demonstrating exceptional quantitative agreement across all three QoIs at the validated configuration; (2) global sensitivity analysis confirms that the single 10 mm offset configuration exercises all dominant uncertainty sources with Sobol total-order indices summing to >0.97; (3) the operating envelope is explicitly bounded to the validated configuration, preventing extrapolation claims; (4) independent reproduction of results by FDA CDRH reviewer provides additional assurance that the validated configuration is correctly characterized. The residual risk from the single-condition limitation is judged acceptable given the conservative under-prediction of yield force and the explicit COU restriction.",
        "name": "Offset rationale: Test conditions Gradation 3 vs. required Gradation 4"
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
