    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated 7.5 mm pedicle screw, ASTM F1717 static loading only",
      "description": "This COU applies exclusively to solid (non-cannulated) pedicle screws with a nominal outer diameter of 7.5 mm and thread pitch conforming to the DePuy Synthes VIPER design family. The FEA model ensemble is validated for quasi-static compression-bending loads as specified in ASTM F1717-21. The constraint explicitly excludes cannulated variants, screws with outer diameters outside 7.0–8.0 mm, fatigue or cyclic loading scenarios, and in vivo bone-implant interface mechanics. Application to titanium alloy (Ti-6Al-4V ELI) material only; cobalt-chrome variants require separate validation."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ASTM F1717 compression-bending test geometry and loading bounds",
      "description": "The validated operating envelope encompasses: axial compressive load range 0–3500 N applied at 10 mm/min crosshead displacement rate; bending moment arm fixed at 40 mm per ASTM F1717 fixture geometry; construct span 75 ± 2 mm between screw centroids; rod diameter 5.5 mm Ti-6Al-4V ELI with modulus 114 ± 5 GPa and yield strength 880 ± 30 MPa; screw torque applied to 4.0 ± 0.2 N·m per manufacturer specification; ambient temperature 23 ± 2 °C; relative humidity 50 ± 10%. Extrapolation beyond these bounds, including load rates exceeding 25 mm/min or construct spans outside 70–80 mm, is not supported by the validated evidence base."
    }
