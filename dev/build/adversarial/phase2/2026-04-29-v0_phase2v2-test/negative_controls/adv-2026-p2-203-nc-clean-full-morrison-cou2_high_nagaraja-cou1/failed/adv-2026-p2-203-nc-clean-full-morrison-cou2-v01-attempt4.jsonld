  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as credible for the stated COU at MRL 5. All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed their required Gradation level; five factors (Numerical solver error, Use error, Model inputs, Relevance of QoIs) exceed requirements. One factor — Test conditions — achieved Gradation 3 against a required Gradation 4, reflecting the use of a single displacement rate. This shortfall is accepted on the basis of the OffsetRationale: ASTM F1717 is a standardized single-rate protocol; the 5 mm/min rate is the regulatory-canonical condition; inter-laboratory reproducibility (n=11, two independent facilities) provides strong evidence that the test conditions are controlled and representative; and the sensitivity analysis demonstrates that displacement rate variation within ±10% of nominal produces < 0.5% change in all three QoIs. The validation metric E/uval < 1.96 for all QoIs across both laboratories, with maximum percentage difference 2.9%. The sensitivity analysis (LHS n=1024) confirms that parametric uncertainty does not challenge the <10% acceptance bound (95th-percentile prediction interval ±8.3%). The provenance chain is complete from raw experimental data through FEA predictions to validation metrics. The credibility evidence is sufficient to support regulatory submission for this non-cannulated construct design.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/offset-test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/credibility-factor/test-conditions",
        "justification": "Test conditions factor achieved Gradation 3 (required Gradation 4) because only a single displacement rate (5 mm/min) was tested, precluding multi-rate characterization. This shortfall is offset by three converging lines of evidence: (1) ASTM F1717 is a standardized protocol in which 5 mm/min is the sole regulatory-specified rate, making multi-rate testing non-standard and not required by FDA guidance; (2) inter-laboratory reproducibility across two independent facilities (FDA and DePuy Synthes internal) with no significant between-lab variance (F-test p=0.31) provides strong assurance that conditions were controlled; and (3) the LHS sensitivity analysis (n=1024) demonstrates that ±10% variation in displacement rate produces < 0.5% change in all three QoIs, confirming that the single-rate limitation does not materially affect model credibility for the stated COU."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
