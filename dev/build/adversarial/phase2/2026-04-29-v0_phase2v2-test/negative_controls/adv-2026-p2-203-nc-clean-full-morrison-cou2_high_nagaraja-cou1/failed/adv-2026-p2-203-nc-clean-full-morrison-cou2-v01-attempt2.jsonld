  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-noncannulated-f1717-v1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for non-cannulated 7.5 mm pedicle screw compression-bending prediction is accepted as fit for purpose at MRL 5 for the defined COU. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy the pre-established quantitative acceptance criteria: E/uval < 1.96 and percentage difference < 10% in all cases. The global sensitivity analysis confirms that dominant uncertainty sources (cortical bone modulus, friction coefficient, titanium yield strength) are fully characterized and propagated through the UQ framework, with 95% prediction intervals encompassing all experimental observations. Twelve of 13 credibility factors achieve or exceed the required level for MRL 5. One factor (Test conditions) achieves Gradation 3 against a required Gradation 4; this shortfall is accepted because (a) the COU operating envelope is explicitly restricted to the single ASTM F1717 standard test condition, eliminating the need for multi-condition generalizability, (b) the loading rate sensitivity is confirmed negligible by the sensitivity analysis (S1 < 0.02 for loading rate), and (c) the acceptance criteria for all QoIs are met with substantial margin (E/uval ranging 0.69–1.21 against threshold 1.96). The provenance chain is complete from raw experimental measurements through UQ propagation to validation metrics. The package is approved for inclusion in the 510(k) submission as computational evidence supporting substantial equivalence.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
