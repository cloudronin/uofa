  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/org/depuy-synthes-fda-ansys-collaboration",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble is accepted as sufficiently credible for the stated COU at Model Risk Level 5. All three QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both the pre-specified relative error threshold (<10%) and the ASME V&V 20 E/uval metric (< 1.96) across N=11 constructs tested at two independent laboratories. Twelve of 13 credibility factors meet or exceed their required gradation levels; two factors (Model inputs, Output comparison) exceed requirements at Gradation 5. The single shortfall — Test conditions at Gradation 3 versus required Gradation 4 — is offset by the convergence of strong evidence across all remaining factors: (1) the Sobol sensitivity analysis confirms that QoI sensitivity to loading condition parameters (angulation, rate) is negligible relative to material and geometric inputs within the stated operating envelope; (2) the direct replication of the COU in the validation activity eliminates extrapolation risk; (3) the multi-laboratory design and per-construct input matching provide high confidence in the experimental reference data; and (4) the conservative 10% acceptance bound provides margin against the single-condition limitation. The offset rationale is formally documented below. The overall weight of evidence supports a credibility determination of Accepted for the intended regulatory submission use.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/offset-test-conditions",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 3 vs required 4)",
        "description": "The Test conditions factor achieved Gradation 3 (single well-characterized condition) against a required Gradation 4 (multi-condition coverage). This shortfall is offset by three converging lines of evidence: (1) The Sobol global sensitivity analysis (N=4096) demonstrated that QoI variance attributable to loading condition parameters (angulation ±2°, crosshead rate ±20%) is less than 3% of total QoI variance, confirming that the single-condition limitation does not materially affect prediction accuracy within the COU operating envelope. (2) The validation activity directly replicates the COU without extrapolation, meaning the single condition tested is precisely the condition of intended use. (3) The conservative 10% relative error acceptance bound, combined with achieved errors of 1.8–2.2%, provides a factor-of-5 margin that absorbs any residual condition-sensitivity uncertainty. Taken together, these offsets are judged sufficient to accept the model despite the Test conditions shortfall."
      },
