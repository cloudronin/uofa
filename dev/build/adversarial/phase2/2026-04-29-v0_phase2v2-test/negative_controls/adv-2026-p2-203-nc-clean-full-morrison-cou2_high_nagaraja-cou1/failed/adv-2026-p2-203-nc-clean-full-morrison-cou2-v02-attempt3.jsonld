  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated 7.5 mm pedicle screw applicability domain",
      "description": "Model applicability is restricted to non-cannulated titanium-alloy pedicle screws with nominal outer diameter 7.5 mm ± 0.1 mm, thread pitch 2.75 mm, and shank length 45–55 mm. Loading is quasi-static axial compression-bending per ASTM F1717 at a single 5-degree angulation. The model is not validated for cannulated variants, dynamic fatigue loading, or screws outside the stated dimensional envelope. Use in cortical-trajectory or fenestrated screw configurations is explicitly excluded."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 compression-bending operating envelope",
      "description": "Applied axial compressive force range: 0–2500 N. Bending moment arm: 50 mm fixed per F1717 fixture geometry. Crosshead displacement rate: 25 mm/min quasi-static. Test temperature: 23 ± 2 °C ambient (dry). Screw insertion torque: 8–10 N·m into UHMWPE test blocks. Construct span: 100 mm inter-screw distance. Material elastic modulus input: Ti-6Al-4V ELI, 110–114 GPa (mean 112 GPa from coupon testing). Yield strength input: 850–900 MPa. FEA mesh element size: 0.3–0.5 mm at stress concentrations, 1.0–2.0 mm in bulk regions."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/nagaraja/sensitivity/fea-compression-bending-sa",
    "type": "SensitivityAnalysis",
    "name": "Sobol global sensitivity analysis — compression-bending QoI",
    "description": "A variance-based Sobol global sensitivity analysis (N=4096 quasi-Monte Carlo samples, Saltelli sampling scheme) was performed varying eight model input parameters: elastic modulus (±3%), yield strength (±5%), friction coefficient at screw-block interface (0.1–0.4), screw geometry tolerances (±0.05 mm OD), UHMWPE block modulus (±10%), crosshead displacement rate (±20%), element size at thread root (0.3–0.5 mm), and contact stiffness penalty factor (0.01–0.1). Construct stiffness (primary QoI) exhibited dominant first-order sensitivity to elastic modulus (S1=0.41) and screw OD tolerance (S1=0.28); yield force was most sensitive to yield strength (S1=0.52) and thread-root element size (S1=0.19). Total-order indices confirmed negligible interaction effects (ST − S1 < 0.05 for all factors). These findings justified the uncertainty budget allocation and confirmed that the ±3% elastic modulus bound drives the dominant prediction interval."
  },
