  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-mrl5-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as credible for the stated COU at Model Risk Level 5. All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed their required level: Software QA (4/4), Numerical Code Verification (5/4), Discretization Error (4/4), Numerical Solver Error (4/3), Use Error (4/4), Model Form (4/4), Model Inputs (5/4), Test Samples (4/4), Equivalency of Input Parameters (4/4), Output Comparison (5/4), Relevance of QoIs (4/4), and Relevance of Validation Activities (4/4). The single shortfall — Test Conditions achieved level 3 against required level 4 — is addressed by the inline OffsetRationale below. Quantitative validation metrics are compelling: all three QoIs satisfy both the <10% relative error criterion and the ASME V&V 20 E/uval < 1.96 criterion, with E/uval values of 0.46, 0.59, and 0.36 respectively. The global sensitivity analysis confirms that the dominant uncertainty sources (Ti-6Al-4V modulus and friction coefficient) are well-characterized through direct measurement, and their combined contribution to output variance is fully propagated through the Monte Carlo ensemble. The validation evidence is directly relevant to the COU with no surrogate geometries or loading modes. The decision consequence is Medium (revision surgery risk, not mortality), and the model influence is Medium (bench testing independently confirms predictions). The overall credibility evidence base is judged sufficient to support regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test Conditions shortfall (achieved 3, required 4)",
        "description": "The Test Conditions factor achieves level 3 (single well-characterized standardized condition) rather than the required level 4 (multiple conditions spanning the operating envelope) because ASTM F1717-15 specifies a single quasi-static compression-bending condition and the clinical loading scenario is quasi-static. The shortfall is offset by three compensating strengths: (1) the single test condition is a regulatory standard (ASTM F1717-15) accepted by FDA for pedicle screw 510(k) submissions, providing strong external validity; (2) the global sensitivity analysis demonstrates that loading rate (crosshead speed 4.5–5.5 mm/min) contributes less than 3% of total QoI variance, confirming that multi-rate testing would not materially improve model credibility; and (3) the Model Inputs and Output Comparison factors both exceed their required levels, providing compensating rigor that more than offsets the single-condition limitation. The decision consequence is Medium (not High or Critical), further supporting acceptance despite the test condition limitation.",
