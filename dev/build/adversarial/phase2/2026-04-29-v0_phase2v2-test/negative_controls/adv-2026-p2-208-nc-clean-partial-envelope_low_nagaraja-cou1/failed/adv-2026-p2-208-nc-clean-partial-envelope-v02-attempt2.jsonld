  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for non-cannulated 7.5 mm pedicle screw compression-bending is accepted for the declared COU. Eleven of thirteen V&V 40 credibility factors meet or exceed their required levels. The Test conditions factor achieves Gradation 2 against a required Gradation 3 due to the single test condition evaluated. This shortfall is offset by the dense validation coverage at the nominal operating point (N=11 across two laboratories), the tight operating envelope with concrete bounds, the high relevance of validation activities to the COU, and the conservative acceptance bounds (E/uval < 1.96 with all values below 1.55). The model risk level 3 with medium model influence and medium decision consequence yields a credibility target that is met by the aggregate evidence. The offset rationale is documented in the linked OffsetRationale record.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "The Test conditions factor achieves Gradation 2 (single nominal load rate tested) against the required Gradation 3 (multiple protocol variable levels). This shortfall is accepted because: (1) the declared operating envelope constrains load rate to 5 mm/min ± 0.5 mm/min, a narrow range for which single-condition testing is representative; (2) N=11 constructs across two independent laboratories provide high statistical confidence at the nominal condition; (3) all three QoIs pass acceptance bounds with E/uval margins of at least 0.45 below the 1.96 threshold, providing confidence that minor condition variation would not invalidate conclusions; (4) ASTM F1717 specifies a single standard load rate, making multi-rate testing non-standard for this COU; and (5) the remaining 12 factors all meet or exceed required levels, providing compensating assurance.",
        "description": "Single-condition test shortfall offset by dense N=11 multi-laboratory coverage, narrow declared envelope, conservative E/uval margins, and ASTM F1717 single-rate standard."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
