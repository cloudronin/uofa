  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for the non-cannulated 7.5 mm pedicle screw construct is accepted for the declared COU. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall — Test conditions (achieved Gradation 2 vs. required Gradation 3) — is offset by the following compensating evidence documented in the OffsetRationale: (1) sensitivity analysis demonstrates that QoI variation across the full temperature range 20–25 °C is < 0.4% (titanium elastic modulus temperature coefficient negligible over 5 °C span); (2) sensitivity analysis for crosshead rate variation 4.5–5.5 mm/min yields < 0.6% QoI change, confirming quasi-static assumption holds across the envelope; (3) all three QoIs satisfy E/uval < 1.96 and relative error < 10% at the tested condition, providing high confidence in model accuracy at the nominal operating point; (4) the declared operating envelope bounds are narrow (±5 °C, ±0.5 mm/min) and physically justified by ASTM F1717 tolerances. The overall credibility evidence base is sufficient to support a Medium assurance level for a Class II device with Medium model influence and Medium decision consequence.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/offset/test-conditions-gradation-shortfall",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall (Gradation 2 vs. required 3)",
        "refersToFactor": "https://uofa.net/nagaraja/factor/test-conditions",
        "justification": "The Test conditions factor achieved Gradation 2 (single test condition) against a required Gradation 3 (multiple condition sets spanning the operating envelope). This shortfall is offset by quantitative sensitivity analysis confirming that QoI variation across the full declared operating envelope (20–25 °C temperature, 4.5–5.5 mm/min crosshead rate) is less than 0.6% for all three QoIs. The narrow envelope bounds are physically justified by ASTM F1717 tolerances, and the titanium alloy elastic response is insensitive to temperature variation over the 5 °C span. The validated nominal condition (22 °C, 5 mm/min) lies at the centroid of the envelope, minimizing extrapolation distance to any boundary point. These compensating factors collectively provide confidence equivalent to multi-condition testing for this specific envelope geometry."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
