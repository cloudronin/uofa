  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as credible for the declared COU. Twelve of thirteen V&V 40 factors meet or exceed required credibility levels. The single shortfall (Test conditions, achieved 2 vs required 3) is offset by: (1) the declared operating envelope is tightly bounded and densely covered at the tested condition; (2) all three primary QoIs satisfy E/uval < 1.96 and percentage difference < 10%; (3) sensitivity analysis confirms QoI insensitivity to plausible material property variation; (4) two independent laboratories with N=11 constructs provide robust experimental evidence. The operating envelope and applicability constraints are explicitly bounded in structured form, ensuring the model is not applied outside its validated domain.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/synth/decision/noncannulated-cou1-offset",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "description": "Test conditions factor achieved level 2 against required level 3 because only a single crosshead rate (5 mm/min) was used. This shortfall is justified because: (a) the declared operating envelope explicitly bounds the applicable crosshead rate to 5 mm/min ± 0.5 mm/min, so no extrapolation to other rates is claimed; (b) ASTM F1717 specifies this rate as the standard condition; (c) the dense validation coverage (N=11 across two labs) at this single condition provides high statistical confidence; and (d) sensitivity analysis shows QoI variation less than 3.2% across the full material property uncertainty space, indicating the model is well-characterized at the tested condition."
      },
      {
        "id": "https://uofa.net/synth/decision/noncannulated-cou1-decision/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/synth/decision/noncannulated-cou1-decision/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
