  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed required levels at Model Risk Level 5. Software quality assurance, code verification, discretization error, test conditions, output comparison, QoI relevance, validation relevance, solver error, model form, model inputs, and input equivalency are all assessed at required level 3; use error and test samples are assessed at required level 2 consistent with MRL 5 requirements. Monte Carlo uncertainty quantification with 2000 samples confirms that NIH predictions remain below the clinical threshold across the full uncertainty envelope. Independent peer review of the simulation workflow found no use errors. The validation evidence base — drawn from the FDA benchmark centrifugal pump under conditions bracketing the VAD COU — provides sufficient credibility to support regulatory decision-making. No credibility gaps remain. The assurance package is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
