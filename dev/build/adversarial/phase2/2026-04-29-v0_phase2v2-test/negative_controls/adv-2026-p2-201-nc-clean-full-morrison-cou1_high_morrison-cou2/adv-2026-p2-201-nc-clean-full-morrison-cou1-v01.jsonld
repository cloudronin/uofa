    "https://uofa.net/synth/data/fda-pump-mesh-refinement-study"
  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: FDA generic centrifugal pump geometry under VAD operating conditions",
      "description": "The model applies exclusively to the FDA-specified generic centrifugal pump geometry (impeller diameter 60 mm, volute as specified in FDA benchmark). The assessment is scoped to blood-analogue fluids (glycerol-water or ovine whole blood) at hematocrit 33–45%. Extrapolation to substantially different pump geometries, non-Newtonian blood substitutes outside this hematocrit range, or paediatric flow regimes is outside the scope of this COU. The hemolysis model (power-law Giersiepen-Wurzinger) is applicable only where shear stress exposure times remain below 700 ms per passage."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD operating envelope: flow rate, rotational speed, and pressure head bounds",
      "description": "Operating envelope is bounded as follows: volumetric flow rate 2.5–7.0 L/min (±0.1 L/min measurement uncertainty); rotational speed 2000–3500 RPM (±10 RPM); inlet pressure 5–15 mmHg; outlet pressure 80–120 mmHg; fluid temperature 36–38 °C; hematocrit 33–45%. Five nominal operating points (combinations of 2500, 3000, 3500 RPM with 2.5, 5.0, 7.0 L/min) are explicitly evaluated. Conditions outside these bounds are flagged as extrapolation and require separate credibility assessment."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/morrison-cou1-sa",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis of hemolysis index to model input parameters",
    "description": "Sobol first-order and total-effect indices were computed over 4096 Monte Carlo samples varying six inputs: power-law exponent α (±10%), consistency coefficient C (±15%), fluid viscosity (±5%), rotational speed (±1%), inlet flow rate (±2%), and mesh resolution (coarse/medium/fine). The hemolysis index quantity of interest showed dominant sensitivity to α (S_T = 0.61) and C (S_T = 0.28), with rotational speed contributing a total-effect index of 0.09; mesh resolution and viscosity each contributed less than 0.03, confirming that discretization and fluid-property uncertainty are minor relative to hemolysis model-form parameters. These findings directed additional experimental calibration effort toward the power-law coefficients."
  },
