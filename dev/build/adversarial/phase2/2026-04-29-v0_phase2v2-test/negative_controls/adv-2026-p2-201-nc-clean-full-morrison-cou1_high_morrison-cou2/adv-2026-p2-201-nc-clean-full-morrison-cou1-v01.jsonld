  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-nc1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors are assessed with achieved levels meeting or exceeding required levels for Model Risk Level 5. The primary QoI (NIH) is validated against bench measurements at all five COU operating points with maximum relative error 11.4%, within the pre-specified 15% acceptance criterion. Monte Carlo UQ (N=4096) confirms 90% prediction intervals on NIH relative error are bounded below the acceptance threshold. Sensitivity analysis identifies power-law hemolysis model coefficients as the dominant uncertainty drivers, and targeted calibration has reduced their contribution. Discretization error is controlled (GCI_fine = 2.3%). Software quality assurance, code verification, and use-error controls are all at or above required levels. The evidence chain is complete and traceable from foundational experimental data through validation results to the credibility decision. No shortfalls exist; no offset rationale is required. The model is accepted as adequately credible for predicting hemolysis under the specified COU operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
