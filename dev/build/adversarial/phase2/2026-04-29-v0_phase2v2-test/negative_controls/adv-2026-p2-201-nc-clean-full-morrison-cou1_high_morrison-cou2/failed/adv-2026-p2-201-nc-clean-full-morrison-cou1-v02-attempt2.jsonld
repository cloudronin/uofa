      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "rationale": "Method of manufactured solutions (MMS) applied to the governing Navier-Stokes and scalar transport equations. Observed order of accuracy (OOA) = 1.97 ± 0.04 for velocity components and 1.94 ± 0.06 for the hemolysis scalar, consistent with the nominal second-order scheme. Benchmark comparisons against three analytic Stokes flow solutions confirm correct implementation.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/ncv",
        "type": "AcceptanceCriteria",
        "name": "Code verification acceptance criteria — Gradation 4",
        "description": "Observed order of accuracy must be within 10% of theoretical order for all primary solution variables using MMS. At least two independent analytic benchmark comparisons must be documented."
      }
    },
