  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-nc1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and each achieves a level at or above the required level for Model Risk Level 5. Software quality assurance (4/4), numerical code verification (4/4), discretization error (5/4), test conditions (4/3), output comparison (4/4), QoI relevance (4/4), validation relevance (4/4), numerical solver error (4/3), use error (3/3), model form (4/4), model inputs (4/4), test samples (3/3), and equivalency of input parameters (4/4) are all compliant. Monte Carlo UQ (10,000 samples) confirms all five operating-point NIH predictions lie within 95% prediction intervals that remain below the clinical hemolysis threshold. Sensitivity analysis identifies the hemolysis power-law exponent as the dominant uncertainty driver, and its uncertainty is bounded by experimental calibration data. The complete provenance chain from raw experimental data through CFD validation to credibility decision is documented. No credibility gaps remain. The package is accepted for regulatory submission supporting the Class III VAD hemolysis claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
