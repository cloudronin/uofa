  "hasSensitivityAnalysis": true,
  "sensitivityAnalysisDetails": {
    "id": "https://uofa.net/synth/sensitivity/morrison-cou1-sa",
    "type": "SensitivityAnalysis",
    "name": "Morris screening and Sobol index sensitivity analysis for hemolysis model inputs",
    "description": "A two-stage sensitivity analysis was conducted: Morris elementary effects screening identified fluid viscosity, rotor tip clearance, and the power-law hemolysis exponent as the three dominant drivers of predicted hemolysis index (HI), together accounting for 84% of total output variance. Sobol first-order and total-order indices were then computed via quasi-Monte Carlo sampling (N=8192 Saltelli sequences); the hemolysis exponent alone contributed a first-order Sobol index of 0.61, confirming it as the single largest source of prediction uncertainty. Rotational speed perturbations of ±5% produced less than 3% change in peak HI, indicating low sensitivity to speed uncertainty within the defined operating envelope."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: FDA generic centrifugal pump geometry under VAD flow conditions",
      "description": "The credibility assessment applies exclusively to the FDA benchmark centrifugal pump geometry (impeller diameter 52 mm, six-blade configuration) operated as a left ventricular assist device. The model is applicable for Newtonian blood-analogue fluids (glycerol-water, viscosity 3.5 ± 0.3 mPa·s) at hematocrit 40 ± 5%. Extrapolation to axial-flow pumps, pulsatile drive conditions, or non-Newtonian rheology models is explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/envelope",
      "type": "OperatingEnvelope",
      "name": "VAD operating envelope: flow rate, rotational speed, and pressure head bounds",
      "description": "Validated operating envelope spans volumetric flow rates of 3.0–7.0 L/min (five discrete set-points: 3, 4, 5, 6, 7 L/min), rotational speeds of 2000–3500 RPM (increments of 500 RPM), and differential pressure heads of 60–120 mmHg. Fluid temperature is held at 37 ± 1 °C. Rotor tip clearance is fixed at 0.5 mm ± 0.05 mm. Reynolds numbers range from 4,200 to 11,800, placing all operating points in the turbulent regime. Predictions outside these bounds are not covered by this credibility assessment."
    }
  },
