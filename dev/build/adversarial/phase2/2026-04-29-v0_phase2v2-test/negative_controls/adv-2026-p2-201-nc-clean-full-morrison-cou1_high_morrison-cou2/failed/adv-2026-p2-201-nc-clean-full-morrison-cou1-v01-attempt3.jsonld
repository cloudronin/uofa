  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain: centrifugal VAD hemolysis prediction",
      "description": "Model is applicable only to single-stage centrifugal blood pumps with impeller tip speeds between 3 m/s and 9 m/s, blood viscosity in the range 0.003–0.005 Pa·s, and hematocrit 35–45%. Axial-flow or pulsatile-flow pumps are explicitly out of scope. The Giersiepen–Wurzinger power-law hemolysis model is the sole constitutive relation covered by this constraint."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD operating envelope — five flow-speed combinations",
      "description": "Flow rate: 3–7 L/min (±0.1 L/min measurement uncertainty). Rotational speed: 2400–3600 RPM (±10 RPM). Inlet pressure: 5–15 mmHg. Outlet pressure: 80–120 mmHg. Fluid temperature: 37 ± 1 °C. Reynolds number range: 1200–8500 (transitional-to-turbulent regime). Five nominal operating points: (3 L/min, 2400 RPM), (4 L/min, 2700 RPM), (5 L/min, 3000 RPM), (6 L/min, 3300 RPM), (7 L/min, 3600 RPM)."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/sa/hemolysis-global-sensitivity",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis — hemolysis index response to model inputs",
    "description": "Sobol first-order and total-order indices were computed over 5000 Monte Carlo samples varying blood viscosity (±15%), power-law exponent α (±10%), turbulent Schmidt number (0.7–1.0), and inlet velocity profile flatness (±20%). Hemolysis index predictions showed highest sensitivity to the power-law exponent α (total-order Sobol index 0.61), moderate sensitivity to turbulent Schmidt number (0.22), and low sensitivity to viscosity and inlet profile shape (<0.10 each), confirming that constitutive model uncertainty dominates over boundary-condition uncertainty across all five operating points."
  },
