  "sensitivityAnalysisDetail": {
    "id": "https://uofa.net/morrison/sa/vad-sensitivity-2026",
    "type": "SensitivityAnalysis",
    "name": "VAD hemolysis CFD sensitivity analysis — turbulence model and blood viscosity",
    "description": "One-at-a-time and variance-based (Sobol) sensitivity analyses were performed varying turbulence model closure (k-omega SST vs. realizable k-epsilon), blood viscosity (Newtonian 0.0035 Pa·s ± 15%), and rotor clearance gap (50–150 µm). Hemolysis index predictions varied by ±18% across turbulence model choices and ±9% across viscosity range; clearance gap was the dominant geometric sensitivity (±22% on peak shear stress). These findings directly informed the uncertainty budget used in Monte Carlo UQ."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis CFD applicability constraint",
      "description": "Model is applicable to centrifugal blood pumps with impeller tip speeds between 3 m/s and 12 m/s, flow rates between 2 L/min and 8 L/min, and hematocrit values between 35% and 45%. Blood is modeled as a Newtonian fluid; non-Newtonian corrections are out of scope. The model is not applicable to axial-flow pumps or devices with gap Reynolds numbers exceeding 5000."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD CFD operating envelope",
      "description": "Defined operating envelope for the FDA generic centrifugal pump under VAD conditions: flow rate 2–8 L/min (nominal 5 L/min), rotational speed 2000–3500 RPM (nominal 2500 RPM), inlet pressure 5–15 mmHg, outlet pressure 80–120 mmHg, blood temperature 36–38 °C, hematocrit 35–45%. Five operating points evaluated: (2 L/min, 2500 RPM), (3.5 L/min, 2500 RPM), (5 L/min, 2500 RPM), (5 L/min, 3000 RPM), (6.5 L/min, 3000 RPM)."
    }
  },
