  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-nc1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed. Achieved credibility levels meet or exceed required levels at every factor: numerical code verification (4≥3), output comparison (4≥3), and use error (3≥2) exceed their requirements; all remaining factors achieve exactly the required level. The Monte Carlo UQ ensemble (5000 samples) demonstrates that the 95th-percentile NIH prediction remains below the clinical acceptance threshold at all 5 operating points. The global sensitivity analysis confirms that the dominant uncertainty source (power-law exponent α) is bounded within the UQ envelope. Validation evidence is directly relevant to the COU device geometry and operating envelope. The provenance chain is complete from raw experimental data through validation results to this decision record. No credibility gaps remain. The model is accepted for use in regulatory submission to support hemolysis claims for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
