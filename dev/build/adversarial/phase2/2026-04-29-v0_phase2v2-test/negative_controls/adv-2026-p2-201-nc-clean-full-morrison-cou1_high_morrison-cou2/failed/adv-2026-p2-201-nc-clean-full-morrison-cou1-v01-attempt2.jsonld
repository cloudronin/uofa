      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "Grid convergence index (GCI) study performed on three systematically refined meshes (2.1 M, 6.8 M, 18.4 M cells). GCI for NIH at worst-case operating point: 3.1%. Richardson extrapolation applied; asymptotic convergence confirmed (GCI ratio 1.02). Temporal discretisation: fixed time-step Δt = 5×10⁻⁵ s; CFL < 0.8 throughout domain.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/disc-001",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria — Gradation 3",
        "description": "GCI must be computed on minimum three systematically refined meshes. GCI for hemolysis QoI must be less than 5% at all operating points. Asymptotic convergence ratio must be within 3% of unity. CFL number must be documented and remain below 1.0 throughout the domain."
      }
    },
    {
      "factorType": "Test conditions",
