  "hasSensitivityAnalysis": true,
  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/sensitivity/vad-hemolysis-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis: hemolysis index response to model inputs",
    "description": "Sobol first-order and total-effect indices were computed across five input parameters — blood viscosity (±15%), pump rotational speed (±3%), inlet flow rate (±8%), power-law hemolysis model coefficients C and α (±10% each) — using a 5000-sample Monte Carlo ensemble. Hemolysis index was most sensitive to the power-law coefficient α (total-effect index 0.61) and rotational speed (0.28); viscosity and flow rate contributed less than 0.07 each. The sensitivity ranking was stable across all five operating points, confirming that uncertainty in α dominates the hemolysis prediction and that additional experimental characterisation of the power-law exponent would most efficiently reduce overall prediction uncertainty."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis prediction applicability domain",
      "description": "Model is applicable to centrifugal blood pumps geometrically similar to the FDA generic pump (impeller diameter 52 mm ± 2 mm, volute clearance 0.3–0.5 mm). Blood analogue must satisfy shear-thinning Carreau–Yasuda rheology at 37 °C ± 1 °C. Hemolysis predictions are valid only within the laminar-to-transitional flow regime (Reynolds number 500–4000 at impeller tip). Extrapolation to axial-flow VAD geometries or pulsatile inlet waveforms is explicitly out of scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD operating envelope — flow rate and rotational speed bounds",
      "description": "Five operating points span: volumetric flow rate 2.5–6.0 L/min (step 0.875 L/min), pump rotational speed 2000–3500 RPM (step 375 RPM), inlet pressure 5–15 mmHg, outlet pressure 80–120 mmHg. Fluid temperature 36–38 °C. Haematocrit 35–45%. All operating points lie within the validated envelope; extrapolation beyond these bounds is not supported by the present evidence package."
    }
  },
