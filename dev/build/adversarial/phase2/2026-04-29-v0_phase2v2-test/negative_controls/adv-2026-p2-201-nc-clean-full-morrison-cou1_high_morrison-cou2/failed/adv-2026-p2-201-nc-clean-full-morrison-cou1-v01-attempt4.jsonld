  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-nc1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed with achievedLevel >= requiredLevel. Primary QoI (NIH) predicted within 18% of bench measurements at all 5 operating points, with |E| < Uval at 95% confidence. Monte Carlo UQ (1000 samples) confirms 95th-percentile prediction interval brackets all experimental observations. Sensitivity analysis identifies rotational speed and hemolysis model coefficient C as dominant uncertainty drivers, and targeted experimental calibration has reduced these to acceptable levels. Mesh refinement (GCI 3.1% on fine mesh), code verification (MMS convergence order 1.97), and independent analyst reproduction (NIH difference 1.2%) collectively establish high numerical credibility. Validation activities used identical device geometry and fluid, spanning the full COU operating envelope. No credibility factor shortfalls exist; the package is accepted for regulatory submission supporting Class III VAD hemolysis claims.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
