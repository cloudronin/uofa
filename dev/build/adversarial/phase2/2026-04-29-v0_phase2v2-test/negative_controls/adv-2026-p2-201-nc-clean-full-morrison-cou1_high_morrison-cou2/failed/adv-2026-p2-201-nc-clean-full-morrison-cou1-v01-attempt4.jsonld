  "hasSensitivityAnalysisRecord": {
    "id": "https://uofa.net/synth/sensitivity/morrison-cou1-sa",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Sobol sensitivity analysis for hemolysis index prediction",
    "description": "Inlet flow rate (3–6 L/min), impeller rotational speed (2400–3200 RPM), blood viscosity (3.0–4.5 mPa·s), and power-law hemolysis model coefficients (C ± 20%, α ± 15%) were varied independently and via Sobol indices. Hemolysis index showed first-order sensitivity dominated by rotational speed (S1 = 0.41) and hemolysis model coefficient C (S1 = 0.33); viscosity and flow rate contributed minor second-order interactions. Total-order indices confirmed no significant higher-order coupling beyond speed–coefficient pairs."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "In-scope domain for VAD hemolysis CFD model",
      "description": "Model is applicable only to single-stage centrifugal blood pumps with shrouded impellers operating with human blood analogs (hematocrit 35–45%). Excludes axial-flow pumps, pulsatile devices, and non-Newtonian fluids outside the calibrated viscosity range. Geographic and regulatory scope limited to FDA 510(k) and PMA submissions under 21 CFR Part 870."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope for FDA generic centrifugal pump VAD conditions",
      "description": "Flow rate: 3.0–6.0 L/min; Rotational speed: 2400–3200 RPM; Inlet pressure: 5–15 mmHg; Outlet pressure: 80–120 mmHg; Blood temperature: 36–38 °C; Hematocrit: 35–45%; Fluid density: 1050–1060 kg/m³; Dynamic viscosity: 3.0–4.5 mPa·s. Geometry tolerance: impeller tip clearance 150–250 µm. All five operating points used for validation fall within these bounds."
    }
  },
