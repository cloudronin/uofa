    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis CFD applicability domain",
      "description": "Model applies to single-stage centrifugal blood pumps with specific speed Ns between 1200 and 3500 rpm (US units), operating with human blood or glycerol-water analog fluids at hematocrit 35–45%. The power-law hemolysis model (Giersiepen-Wurzinger) is valid only for shear stress exposures between 10 and 400 Pa and exposure times between 1 ms and 700 ms. Predictions outside these bounds require additional experimental validation before regulatory use."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "FDA generic centrifugal pump VAD operating envelope",
      "description": "Flow rate: 2.5–8.0 L/min; Rotational speed: 2000–3500 rpm; Inlet pressure: 5–20 mmHg; Outlet pressure: 60–120 mmHg; Blood viscosity: 3.0–4.5 mPa·s (temperature 37 ± 0.5 °C); Hematocrit: 38–42%; Pump inlet diameter: 12 mm (fixed geometry — FDA generic model); Maximum wall shear stress tolerance: 500 Pa. All five operating points in the Morrison benchmark dataset fall within this envelope."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/sensitivity/cou1-global-sa",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis — hemolysis index to model inputs and parameters",
    "description": "Sobol first-order and total-effect indices were computed over 5000 Monte Carlo samples varying six inputs simultaneously: rotational speed (±2%), inlet flow rate (±5%), blood viscosity (±8%), power-law hemolysis exponent α (±10%), shear-stress threshold (±15%), and turbulence model constant Cμ (±5%). Hemolysis index predictions showed highest sensitivity to α (total Sobol index 0.52) and inlet flow rate (0.31), while turbulence model constant contributed less than 4% of output variance, confirming that uncertainty in the hemolysis constitutive law dominates over numerical closure uncertainty and justifying the focused experimental calibration effort for the power-law coefficients."
  },
