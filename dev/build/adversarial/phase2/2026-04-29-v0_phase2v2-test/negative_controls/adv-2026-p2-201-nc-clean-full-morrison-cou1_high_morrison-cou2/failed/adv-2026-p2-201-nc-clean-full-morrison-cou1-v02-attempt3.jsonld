  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors are assessed with achieved levels meeting or exceeding required levels at Model Risk Level 5. The primary QoI (NIH) is validated against bench measurements with 11% mean relative error and 96% prediction interval coverage, both within pre-specified acceptance thresholds. Monte Carlo uncertainty quantification across 5000 samples confirms that experimental observations fall within the 95% prediction interval at all 5 operating points. Global sensitivity analysis identifies the power-law exponent α as the dominant uncertainty source (Sobol total index 0.52), and targeted experimental calibration has reduced this uncertainty to within acceptable bounds. Software quality assurance (ISO 9001, 1200+ regression tests), code verification (MMS, observed order 1.94), and discretization error (GCI 3.1%) collectively establish a robust computational foundation. Independent analyst replication and documented simulation execution plan address use error. The credibility evidence is sufficient to support regulatory use of CFD hemolysis predictions for this Class III VAD device at the stated operating conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
