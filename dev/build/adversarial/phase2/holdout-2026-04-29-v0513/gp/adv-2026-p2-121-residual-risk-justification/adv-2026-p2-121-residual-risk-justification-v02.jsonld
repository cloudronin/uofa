  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Medium assurance level. All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40-2018 Table 4 for the assigned model risk level. It is noted that the CFD model exhibits a known limitation in predictive accuracy at the lowest flow operating point (2.5 L/min, 3000 RPM), where transitional turbulence effects are not fully captured by the steady-state k-ω SST formulation and validation coverage of this edge case is incomplete. The residual risk associated with this limitation is considered acceptable, and the overall assessment supports use of the model for worst-case hemolysis identification within the stated COU operating envelope.",
