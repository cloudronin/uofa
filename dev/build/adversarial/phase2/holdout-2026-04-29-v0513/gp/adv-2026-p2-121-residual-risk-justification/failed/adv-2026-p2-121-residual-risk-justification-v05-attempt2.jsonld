  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for CPB hemolysis prediction meets all required credibility factor levels for MRL 2. Seven factors were formally assessed and all achieved their required levels. Six factors were not assessed, consistent with MRL 2 scoping. A known limitation exists in the near-wall shear resolution at the 3500 RPM, 2 L/min operating condition, where NIH prediction error reaches 23%. This limitation is acknowledged and the residual risk is considered acceptable. The model is therefore judged credible for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
