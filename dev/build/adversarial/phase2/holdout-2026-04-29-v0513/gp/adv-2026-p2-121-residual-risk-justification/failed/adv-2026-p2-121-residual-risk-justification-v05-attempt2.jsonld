  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/pump-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-top hemolysis comparison — 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against in-vitro measurements at 5 flow-speed combinations. Agreement within 15% at four operating points. At the highest rotational speed condition (3500 RPM, 2 L/min), predicted NIH deviates by 23% from experimental mean, attributed to under-resolution of near-wall shear layers in the volute exit region. This edge case is not fully covered by the current mesh refinement strategy. The overall validation campaign is considered sufficient for MRL 2 purposes and the model is judged fit for identifying worst-case hemolysis trends."
    },
    {
      "id": "https://uofa.net/morrison/validation/grid-convergence-study",
      "type": "ValidationResult",
      "name": "Grid convergence index (GCI) study — nominal operating point",
      "description": "Three-level mesh refinement study performed at the nominal operating point (2500 RPM, 5 L/min). GCI values below 3% for all hemolysis-relevant quantities of interest. Discretization error is within acceptable bounds for MRL 2."
    }
  ],
