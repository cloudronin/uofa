  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2. Validation at the nominal operating point demonstrates NIH prediction within 8.8% of measurement, satisfying the 15% acceptance criterion. Mesh convergence is confirmed (GCI 3.1%). The Giersiepen-Wurzinger model is well-established in the literature and its application here is consistent with published FDA pump CFD practice. The assessment team notes that the model's linear superposition precondition is satisfied at the validated nominal point and considers this sufficient evidence of model adequacy across the full COU operating envelope. The relative hemolysis index RH < 1 is predicted for all five operating points, supporting acceptance of the device design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
