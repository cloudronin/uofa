  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr01-benchmark-single-operating-point",
      "type": "ValidationResult",
      "name": "Benchmark validation against FDA pump experimental hemolysis data at nominal operating point",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against published FDA pump experimental measurements at the nominal operating condition (Q=5 L/min, N=2500 RPM). Predicted NIH = 0.0042 g/100 L versus experimental NIH = 0.0045 ± 0.0008 g/100 L. Agreement within 7%, satisfying the 15% acceptance threshold. Validation was performed at a single mid-range operating point representative of steady laminar-to-transitional flow. The Giersiepen–Wurzinger power-law coefficients used (C=3.62×10⁻⁵, α=2.416, β=0.785) are calibrated to Couette-flow viscometer data under controlled, nearly steady shear conditions.",
      "passFail": "Pass",
      "quantitativeResult": "NIH prediction error 7% at nominal operating point; within 15% acceptance threshold"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr02-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study for hemolysis index prediction",
      "description": "Three mesh densities (1.2M, 3.8M, 9.1M cells) evaluated. Grid convergence index (GCI) for NIH < 4% between medium and fine meshes. Medium mesh (3.8M cells) selected for production runs. Convergence study conducted at nominal operating point only.",
      "passFail": "Pass",
      "quantitativeResult": "GCI(NIH) = 3.6% between medium and fine mesh; discretization error within acceptable bounds"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr03-pressure-head-validation",
      "type": "ValidationResult",
      "name": "Hydraulic pressure-head validation across 5 operating points",
      "description": "Predicted pump pressure head (ΔP) compared against experimental measurements across all 5 COU flow-speed combinations. Mean absolute error 4.2%, maximum error 8.7% at the highest speed condition (N=3500 RPM, Q=3 L/min). Hydraulic performance validation confirms flow-field fidelity across the operating range. Note: hemolysis index validation was not repeated at the off-nominal high-speed conditions; only pressure head was used as the surrogate validation metric at those points.",
      "passFail": "Pass",
      "quantitativeResult": "Mean ΔP error 4.2% across 5 operating points; max error 8.7% at high-speed condition"
    }
  ],
