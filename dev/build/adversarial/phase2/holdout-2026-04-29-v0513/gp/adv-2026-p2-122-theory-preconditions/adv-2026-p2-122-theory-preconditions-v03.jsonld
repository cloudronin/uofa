    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty quantification for flow rate, rotational speed, and fluid viscosity.",
      "rationale": "FDA pump experimental data from Hariharan et al. (2011) used. Flow rate uncertainty ±0.1 L/min, speed uncertainty ±10 RPM, blood analog viscosity 0.0035 Pa·s ±3.5%. Test conditions adequately documented for MRL 2 validation."
    },
    {
