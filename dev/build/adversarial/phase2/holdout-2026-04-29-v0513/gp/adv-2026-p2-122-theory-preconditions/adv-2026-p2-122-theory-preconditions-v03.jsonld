    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark cases (lid-driven cavity, pipe flow) demonstrating correct implementation of governing equations.",
      "rationale": "ANSYS Fluent passes published benchmark cases for incompressible Navier-Stokes. User-defined scalar transport equation implementing the Lagrangian damage accumulation integral verified against analytical solution for uniform shear field. Code verification complete at MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI for primary QoI (NIH) must be less than 10% between medium and fine mesh.",
