    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be directly linked to the regulatory decision criterion (RH < 1 relative hemolysis index).",
      "rationale": "NIH is the primary QoI, directly convertible to relative hemolysis index RH via normalization against predicate device NIH. QoI is clinically and regulatorily relevant for CPB hemolysis assessment. Relevance criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and fluid properties must match COU device class and blood analog within documented similarity bounds.",
      "rationale": "Validation uses FDA generic centrifugal pump geometry identical to COU device family. Blood analog (glycerol-water) matches viscosity of CPB primed circuit within 5%. Geometric and fluid similarity adequate for MRL 2. Validation was performed at the nominal mid-range operating point; the theoretical linearity precondition of the damage model was not examined as part of relevance assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor beyond code verification activities already completed.",
      "rationale": "Solver error beyond discretization and code verification is scoped out at MRL 2. Residual convergence to 1×10⁻⁵ for all equations confirmed in production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Use error assessment not required at MRL 2. Analyst has 8 years experience with CFD hemolysis simulation. Simulation protocol peer-reviewed internally prior to execution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection must be justified by literature precedent and agreement with experimental data at validation conditions.",
      "rationale": "Giersiepen–Wurzinger power-law hemolysis model is the established formulation for CFD-based blood pump assessment per FDA guidance and published literature (Goubergrits & Affeld 2004; Taskin et al. 2012). Model form is justified by literature precedent. The model is theoretically valid under the precondition that damage accumulation is linear and path-independent — i.e., that erythrocyte sub-lethal damage does not alter subsequent damage susceptibility and that shear history effects are negligible. This linearity precondition is stated in the original Giersiepen et al. derivation and is required for the scalar integral formulation to be physically meaningful. Model form validation was performed at the nominal operating point where flow is transitional-laminar and shear exposure times are moderate, conditions under which the linearity assumption is most defensible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and boundary conditions must be documented with sources and uncertainty ranges.",
      "rationale": "Blood analog viscosity 0.0035 Pa·s (Newtonian approximation), density 1056 kg/m³. Inlet flow rate and rotational speed set to COU operating conditions. Power-law coefficients C=3.62×10⁻⁵, α=2.416, β=0.785 taken from Giersiepen et al. (1990) viscometer calibration data. All inputs documented with literature sources. Uncertainty in power-law coefficients not propagated through hemolysis predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Test sample characterization beyond what is documented in the FDA benchmark dataset is not required at MRL 2. Published experimental dataset from Hariharan et al. (2011) used as-is."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Equivalency of input parameters between validation and COU conditions not formally assessed at MRL 2. Qualitative comparison confirms same device geometry, same fluid analog, and overlapping operating range. The high-speed, low-flow COU condition (N=3500 RPM, Q=3 L/min) introduces higher shear rates and longer recirculation residence times than the validation point; formal equivalency assessment of these conditions against the linearity precondition of the damage model was not performed."
    }
