  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately scoped out at MRL 2 for a Class II device with medium model influence. Validation results demonstrate RH prediction within 12% of bench measurements across all five operating conditions, satisfying the 15% acceptance criterion. The relative hemolysis index at the worst-case operating point (2.5 L/min / 4500 RPM) is 0.82, below the RH < 1.0 acceptance criterion. The credibility package is accepted in support of the 510(k) submission. Note: validation results are reported at the configuration settings chosen during the validation campaign (h_base = 0.18 mm, alpha_HT = 0.7, tau_thresh = 1.8 Pa); these values are documented in the validation records but are not bound as deployment requirements within this credibility package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
