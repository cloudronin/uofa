  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-mesh-convergence-01",
      "type": "ValidationResult",
      "name": "Mesh convergence study — base element size 0.15 mm",
      "description": "Three mesh refinement levels (coarse 0.30 mm, medium 0.15 mm, fine 0.075 mm) were evaluated. The medium mesh (0.15 mm base element size) achieved a Richardson extrapolation GCI below 2.1% for normalised shear stress and was selected as the production mesh. Results are reported at this chosen mesh size; the mesh size parameter is identified in the study report but is not registered in a deployment configuration record."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-correlation-02",
      "type": "ValidationResult",
      "name": "Hemolysis power-law exponent validation against in-vitro data",
      "description": "The Giersiepen-derived power-law hemolysis model was exercised with exponent alpha = 0.785 and stress threshold C = 1.228e-5. Predicted normalised index of haemolysis (NIH) agreed with in-vitro measurements to within 12% across all 5 operating points. The exponent and threshold values are cited in the validation report but are not bound to a configuration record accessible to deployment analysts."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-solver-convergence-03",
      "type": "ValidationResult",
      "name": "Iterative solver convergence residual tolerance assessment",
      "description": "Validation simulations were executed with a convergence residual tolerance of 1e-5 for all transport equations. Sensitivity runs at 1e-4 showed up to 4.3% deviation in peak shear stress predictions. The 1e-5 tolerance was therefore identified as necessary for result fidelity. However, this parameter is not pinned in any deployment-facing configuration document; the package contains no bindsConfiguration link and the ContextOfUse does not constrain permissible tolerance values. Deployment analysts may apply different tolerances at their discretion."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-rh-acceptance-04",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against predicate device",
      "description": "At the validated configuration settings, RH values across all 5 flow-speed combinations ranged from 0.61 to 0.93, satisfying the RH < 1 acceptance criterion. The summary table references 'the chosen solver settings' without specifying which residual tolerance was active, creating ambiguity for reproduction."
