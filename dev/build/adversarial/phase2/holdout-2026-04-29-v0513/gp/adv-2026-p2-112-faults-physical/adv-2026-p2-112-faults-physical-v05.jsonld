  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The device is intended for extended in vivo deployment during prolonged CPB runs exceeding 6 hours, operating in a clinical environment subject to electrical transients, roller-head wear, and sensor drift in flow-rate feedback loops. The CFD model and all validation activities assume nominal, fully functional hardware throughout; no fault states — including impeller bearing wear, inlet pressure sensor failure, or drive motor electrical shorts — are represented in the simulation inputs or the validation campaign.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou1-hemolysis-worst-case",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou1-rh-less-than-1",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-piv-nominal-5op-points",
    "https://uofa.net/synth/data/morrison-hemolysis-bench-nominal"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates in vivo for extended duty cycles — routinely 4–8 hours of continuous perfusion and occasionally beyond 12 hours in complex cardiac cases — in an ICU environment where power-line fluctuations, cumulative impeller bearing wear, and flow-sensor drift are recognized operational realities. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-piv-nominal",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — nominal operating hardware, 5 flow-speed points",
      "description": "Particle image velocimetry measurements acquired on a new, factory-calibrated pump unit under controlled laboratory conditions. All five COU operating points (2.5 L/min at 2000 RPM through 6.0 L/min at 3500 RPM) were measured. Velocity field agreement within 8% RMS across all planes. Hardware was inspected before and after testing; no wear or sensor anomaly was recorded."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-hemolysis-bench-nominal",
      "type": "ValidationResult",
      "name": "In vitro hemolysis index validation — nominal hardware, bovine blood surrogate",
      "description": "Normalized index of hemolysis (NIH) measured on a fresh pump assembly using ASTM F1841 protocol. CFD-predicted hemolysis power law integrated along streamlines was compared against measured NIH at each operating point. All five nominal operating points yielded RH < 0.85. A single cavitation-onset test at 10% below minimum inlet pressure was conducted to characterize one off-nominal condition; no bearing-wear, sensor-failure, or electrical-fault scenarios were included in the test matrix."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-mesh-sensitivity",
      "type": "ValidationResult",
      "name": "Mesh sensitivity and discretization error quantification",
      "description": "Three mesh densities (4.2 M, 11.7 M, 28.4 M cells) evaluated using Richardson extrapolation. Grid convergence index < 2.1% for all QoIs at the nominal best-efficiency operating point. All simulations performed with nominal geometry and boundary conditions."
    }
  ],
