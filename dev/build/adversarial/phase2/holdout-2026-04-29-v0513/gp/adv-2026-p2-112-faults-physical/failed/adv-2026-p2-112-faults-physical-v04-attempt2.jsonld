  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are acceptably scoped out at MRL 2 per ASME V&V 40-2018 Table 3. Validation results on nominal hardware demonstrate that the CFD model predicts hemolysis index within 9.3% of bench measurements across the full 5-point operating envelope. The relative hemolysis index RH = 0.87 satisfies the RH < 1 regulatory acceptance criterion. The assessment team notes that all validation activities were conducted on new pump hardware under controlled laboratory conditions representative of nominal in vivo operation; the long-duration duty cycle and hardware degradation modes characteristic of extended CPB procedures were not within the scope of the current validation campaign. The team concluded this limitation is acceptable at MRL 2 given the medium model influence designation and the availability of confirmatory bench testing.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
