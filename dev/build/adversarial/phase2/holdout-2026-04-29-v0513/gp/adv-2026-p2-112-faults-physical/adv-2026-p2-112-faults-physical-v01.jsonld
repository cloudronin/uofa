  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, which is consistent with MRL 2 requirements per ASME V&V 40-2018. The CFD model demonstrates adequate predictive accuracy for NIH across the five nominal operating points, with RH < 1 confirmed in all cases. The validation campaign covers the relevant geometry and operating envelope. The assessment team concludes that the model has sufficient credibility to support the tolerance-design decision for the Class II CPB device. Physical fault modes documented in the device risk file (bearing wear, seal degradation, OR electrical transients) were noted during scoping discussions but were considered outside the boundary of the current COU, which is defined around nominal operating conditions. No fault-state simulations or degraded-hardware validation tests were included in the campaign.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
