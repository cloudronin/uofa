  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The CPB pump operates continuously in vivo for perfusion durations of 4–12 hours per procedure, with cumulative device lifetime spanning hundreds of surgical cases. In clinical deployment the pump is subject to bearing wear, seal degradation, and transient electrical supply fluctuations from the OR power management system; these operational realities are documented in the device risk file and have been observed in post-market surveillance. The CFD model and all associated validation activities assume nominal hardware behavior throughout; no fault states, degraded-component scenarios, or sensor-drift conditions are represented in the simulation campaign.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou1-hemolysis-tolerance",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou1-rh-less-than-1",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-piv-benchmark-nominal",
    "https://uofa.net/synth/data/morrison-hemolysis-in-vitro-nominal",
    "https://uofa.net/synth/data/morrison-mesh-refinement-study"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The pump operates continuously in vivo over multi-hour perfusion runs; post-market surveillance data indicate that bearing wear and intermittent electrical transients from OR power systems occur across the device lifetime and can alter impeller rotational dynamics. These physical fault modes are catalogued in the device risk file but are not represented in the computational model or the validation campaign.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-piv-nominal-5ops",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — nominal hardware, 5 operating points",
      "description": "Particle image velocimetry measurements collected on a new, factory-calibrated pump unit at five flow-speed combinations (2.5 L/min at 2000 RPM through 6 L/min at 3500 RPM). CFD velocity predictions agree within 8% RMS across the impeller swept volume. All measurements performed on hardware in as-new condition; no bearing wear or electrical perturbation was introduced.",
      "passFailStatus": "passed",
      "quantitativeResult": "Mean velocity RMS error 6.3%; maximum local error 11.2% in tip-clearance region"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-invitro-nominal",
      "type": "ValidationResult",
      "name": "In-vitro hemolysis index validation — nominal hardware",
      "description": "Modified index of hemolysis (MIH) measured over 6-hour recirculation loops using bovine blood in a temperature-controlled mock circuit. Pump units were new; impeller clearances were within nominal manufacturing tolerances. CFD-predicted normalized index of hemolysis (NIH) agreed with measured MIH within 15% across all five operating conditions. No degraded-seal or worn-bearing configurations were tested; the single fault-adjacent test (one operating point with a deliberately over-tightened seal) was excluded from the validation matrix after it was deemed non-representative of the primary COU.",
      "passFailStatus": "passed",
      "quantitativeResult": "NIH prediction error range: 4%–14%; RH < 1 confirmed at all nominal operating points"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-grid-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence and discretization error study",
      "description": "Richardson extrapolation performed across three mesh refinement levels (coarse 4.2 M cells, medium 11.7 M cells, fine 28.4 M cells). Grid convergence index (GCI) for NIH quantity of interest: 3.1% on fine mesh. Discretization error formally bounded. All meshes represent nominal impeller geometry at nominal clearance.",
      "passFailStatus": "passed",
      "quantitativeResult": "GCI_fine = 3.1%; apparent order of convergence p = 1.94"
    }
