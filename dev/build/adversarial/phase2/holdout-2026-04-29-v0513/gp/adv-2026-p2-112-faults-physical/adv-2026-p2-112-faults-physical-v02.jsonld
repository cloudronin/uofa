    "https://uofa.net/synth/data/morrison-grid-convergence-study"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates in vivo in a continuous-flow configuration for extended duty cycles (2–8 hours per surgical procedure, with some centers running the same pump head across multiple consecutive cases). Bearing wear, seal fatigue, and transient voltage irregularities in the drive motor are documented failure modes in clinical perfusion practice. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-piv-nominal-2500rpm",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 2500 RPM, nominal pump head, 5 LPM",
      "description": "Particle image velocimetry measurements in the FDA generic centrifugal pump at 2500 RPM and 5 LPM flow rate using a factory-new, geometrically nominal acrylic pump model. CFD predictions of mean velocity magnitude agree within 8% RMS across the impeller swept region. Hardware was inspected prior to testing; no wear or seal degradation present."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-piv-nominal-3500rpm",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 3500 RPM, nominal pump head, 2.5 LPM",
      "description": "Particle image velocimetry measurements at 3500 RPM and 2.5 LPM on the same factory-new pump model. CFD predictions capture the recirculation zone at the volute tongue within acceptable tolerance. All hardware operating in nominal condition throughout the test campaign."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-bench-5conditions",
      "type": "ValidationResult",
      "name": "Bench hemolysis index validation across 5 flow-speed operating points",
      "description": "In-vitro hemolysis index (normalized index of hemolysis, NIH) measured for all 5 CFD operating points using bovine blood in a recirculating loop with a new, unaged pump head. CFD-derived hemolysis predictions using the power-law Giersiepen–Wurzinger model agree with measured NIH values within 15% across all conditions. No bearing wear, seal leakage, or electrical fault conditions were included in the test matrix. A single minor perturbation test (±5% flow rate deviation) was performed to assess sensitivity to flow measurement uncertainty, representing the only non-nominal condition evaluated."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-grid-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence study — discretization error quantification",
      "description": "Three-level mesh refinement study (1.2M, 4.8M, 18.6M cells) performed on the nominal pump geometry at the 3500 RPM / 2.5 LPM condition. Richardson extrapolation yields a grid convergence index (GCI) of 2.3% for the volume-averaged shear stress scalar, satisfying the MRL 2 discretization error requirement."
    }
  ],
