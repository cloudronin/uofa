  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scope. The CFD model demonstrates adequate predictive capability for hemolysis index under nominal operating conditions across the COU envelope. Validation agreement is within the ±15% acceptance criterion at all primary operating points. The assessment team notes that the validation campaign was conducted exclusively on nominal hardware; the continuous in vivo duty cycle characteristic of CPB use introduces potential for hardware degradation over a surgical perfusion run, but bearing wear, seal degradation, and motor thermal effects are considered outside the scope of this MRL 2 assessment. The single seal leakage sensitivity simulation (VR-04) provides limited assurance for one perturbation mode only. Overall credibility is sufficient for the intended regulatory submission at MRL 2.",
