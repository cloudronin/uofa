  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-hemolysis-rh",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation — laboratory benchmark",
      "description": "CFD-predicted relative hemolysis index (RH) compared against in-vitro measurements for 5 flow-speed operating points. All experiments conducted in laboratory at 22°C, atmospheric pressure (101.3 kPa), with no electromagnetic interference sources present. RH predictions within ±8% of measured values across all operating points; acceptance criterion RH < 1 satisfied. No parametric sweep of temperature (18–26°C clinical range), ambient pressure (700–101 kPa altitude range), or EMI exposure level was included in the validation programme."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-velocity-field",
      "type": "ValidationResult",
      "name": "Velocity field PIV comparison — isothermal lab conditions",
      "description": "Particle image velocimetry (PIV) measurements of the impeller exit velocity field compared with CFD predictions at 3500 RPM and 5 L/min. Agreement within 5% RMS deviation. Tests performed at 22°C with blood analogue fluid; viscosity temperature dependence across the clinical operating range (33–38°C patient temperature) was not characterised. No correction for altitude-dependent fluid degassing or EMI-induced sensor artefacts was applied."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation",
      "description": "Measured pump head versus flow rate curve compared with CFD predictions across 5 operating points. Maximum deviation 4.2%. All measurements at sea-level atmospheric pressure and 22°C ambient. Sensitivity of predicted pressure-rise to ambient pressure variation relevant to high-altitude hospital installations (e.g., 2500 m, ~75 kPa) was not evaluated."
    }
  ],
