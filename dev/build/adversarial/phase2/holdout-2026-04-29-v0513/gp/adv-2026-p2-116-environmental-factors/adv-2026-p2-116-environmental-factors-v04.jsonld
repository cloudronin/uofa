  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2. Discretization error GCI of 3.1% and output comparison deviation of 7.9% are within acceptance criteria. The validation programme demonstrates adequate credibility for CFD hemolysis prediction under the laboratory conditions at which validation was conducted. The assessment team notes that validation experiments were performed at 22°C and atmospheric pressure; the clinical deployment environment involves temperature variation (OR ambient 18–26°C, patient 33–38°C), potential altitude-dependent pressure reduction, and electromagnetic interference from electrosurgical units. A single temperature condition was tested; no parametric study of EMI effects or altitude-pressure sensitivity was performed. The team judges that these environmental factors are unlikely to materially alter hemolysis index predictions at MRL 2, based on the dominance of impeller geometry and rotational speed as hemolysis drivers. The model is accepted for its intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device under the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
