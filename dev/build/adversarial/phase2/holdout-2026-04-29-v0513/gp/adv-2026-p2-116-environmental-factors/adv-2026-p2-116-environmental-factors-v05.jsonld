  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements. The CFD model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index acceptance criterion (RH < 1) was met across all 5 operating points. Validation was conducted at controlled laboratory conditions (22°C, atmospheric pressure); a single temperature check point at 37°C was noted but not treated as a systematic environmental sensitivity study. The assessment team acknowledged that the clinical deployment environment includes variable perfusate temperatures, potential high-altitude use, and OR electromagnetic interference, but concluded that these factors do not alter the MRL 2 credibility determination under the current assessment framework.",
    "decidedAt": "2026-04-19T00:00:00Z"
