    "https://uofa.net/synth/data/morrison-fda-pump-geometry-v2",
    "https://uofa.net/synth/data/morrison-hemolysis-experimental-22C-atm"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-pressure-head",
      "type": "ValidationResult",
      "name": "Pressure-head curve validation at 22°C laboratory conditions",
      "description": "Pump pressure-head was measured across 5 flow-speed operating points at 22°C ambient, atmospheric pressure (101.3 kPa), using phosphate-buffered saline as blood analog. CFD predictions agreed with measurements within 4.2% RMS across all operating points. No variation in ambient temperature, humidity, or electromagnetic environment was introduced during testing. Validation dataset: morrison-hemolysis-experimental-22C-atm."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation at controlled laboratory temperature",
      "description": "Hemolysis index (normalized index of hemolysis, NIH) was measured for three impeller clearance configurations at 22°C, 101.3 kPa, with blood viscosity fixed at 3.2 mPa·s. CFD-predicted NIH values fell within experimental uncertainty bands for all configurations. A single temperature sensitivity check at 37°C was performed for one operating point only; results showed a 2.1% shift in predicted shear stress distribution but this was attributed to viscosity change alone. No electromagnetic interference characterization was conducted. Ambient pressure sensitivity across the clinical altitude range (sea level to 1500 m) was not evaluated."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-flow-field",
      "type": "ValidationResult",
      "name": "PIV flow-field validation at nominal laboratory environment",
      "description": "Particle image velocimetry (PIV) measurements of the impeller exit flow field were compared against CFD velocity profiles at the 3 L/min, 3000 RPM nominal operating point. All measurements were performed in a temperature-controlled laboratory at 22°C ± 0.5°C, standard atmospheric pressure. Velocity magnitude agreement was within 6% over 94% of measurement planes. Operating room electromagnetic environment (electrosurgical units, monitoring leads, imaging equipment) and its potential influence on sensor accuracy or pump drive electronics was not assessed."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034365",
