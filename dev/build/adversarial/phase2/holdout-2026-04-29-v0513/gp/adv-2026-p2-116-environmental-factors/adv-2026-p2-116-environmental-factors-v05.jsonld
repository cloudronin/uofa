  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver (ANSYS Fluent 2022R2) must be verified under a documented SQA plan including version control, regression testing, and traceability to ASME V&V 10-2006.",
      "rationale": "ANSYS Fluent 2022R2 is used under an institutional SQA plan. Version control, build verification tests, and regression suite results are documented in the project SQA record. No environment-dependent software behavior (e.g., EMI-induced numerical instability) was assessed, but SQA requirements at MRL 2 do not mandate such characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems (lid-driven cavity, Poiseuille flow) with observed convergence rates consistent with formal order of accuracy.",
      "rationale": "Fluent's incompressible Navier-Stokes solver was verified against the lid-driven cavity benchmark (Re = 1000) and fully developed pipe flow. Second-order spatial convergence was confirmed. Code verification activities were performed at standard laboratory conditions; no temperature or pressure dependence of numerical behavior was evaluated, which is consistent with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% using at least three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study (2.1M, 5.8M, 14.2M cells) was conducted at the 3 L/min, 3000 RPM operating point. GCI for NIH was 3.1%, satisfying the acceptance criterion. The mesh refinement study was conducted at 22°C; mesh-dependent behavior at other temperatures was not assessed but is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to permit reproduction, including fluid properties, temperature, flow rates, and rotational speeds.",
      "rationale": "All validation experiments were conducted at 22°C ± 0.5°C, 101.3 kPa ± 0.5 kPa, using porcine blood with hematocrit 33 ± 2% and viscosity 3.2 ± 0.1 mPa·s. Flow rates and rotational speeds were verified with calibrated instrumentation. Test conditions are fully documented and reproducible. The documented conditions represent a single environmental state; the clinical deployment envelope (OR temperatures 18–24°C ambient, perfusate 28–37°C, altitude up to 1500 m, OR electromagnetic environment) was acknowledged in the test plan but no multi-environment matrix was executed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted NIH and pressure-head must agree with experimental measurements within combined experimental and numerical uncertainty at all 5 validation operating points.",
      "rationale": "CFD-predicted NIH agreed with experimental values within combined uncertainty (U95 = ±8.3%) at all 5 operating points. Pressure-head predictions were within 4.2% RMS. Agreement was established exclusively at 22°C laboratory conditions. The single 37°C check point showed a 2.1% shift in shear stress distribution; this was not treated as a systematic sensitivity study and was not used to bound model error across the clinical temperature range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, pressure-head, wall shear stress distribution) must be directly linked to the COU decision criterion (RH < 1) and clinically relevant hemolysis thresholds.",
      "rationale": "NIH is the primary QoI and maps directly to the relative hemolysis index acceptance criterion (RH < 1). Pressure-head characterizes pump operating point fidelity. Wall shear stress distribution identifies hemolysis hot-spots. All QoIs are clinically relevant and directly support the worst-case identification decision. QoI relevance was assessed without reference to environmental sensitivity; temperature-dependent blood viscosity effects on NIH were noted qualitatively but not quantified across the deployment range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, blood analog, and operating conditions as the COU, with documented similarity between validation and deployment scenarios.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry (identical to the COU device geometry), porcine blood at clinically representative hematocrit, and the 5 flow-speed combinations specified in the COU. Geometric and fluid similarity are well-established. Environmental similarity between the validation laboratory (22°C, 101.3 kPa, controlled EM environment) and the clinical operating room (variable temperature, potential altitude, electrosurgical EM interference) was not formally assessed. This gap is not explicitly penalized at MRL 2 under the current assessment framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error beyond discretization error is not required to be separately assessed at MRL 2. Iterative convergence was confirmed to residual levels below 1e-5 for all equations at all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal use error assessment is not required at MRL 2. The CFD workflow was executed by experienced analysts following documented simulation procedures. No independent re-execution or human factors study was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model (SST k-omega) and hemolysis power-law model must be justified for the Reynolds number range and shear stress magnitudes encountered in the CPB pump.",
      "rationale": "SST k-omega turbulence closure was selected based on literature evidence for rotating machinery at Re ~ 10^4–10^5. The Giersiepen-Wurzinger power-law hemolysis model was applied with coefficients validated for the shear stress and exposure time range of centrifugal blood pumps. Model form assessment was conducted at standard conditions; temperature dependence of blood rheology (viscosity, yield stress) and its effect on turbulence model validity was not formally evaluated across the clinical perfusate temperature range of 28–37°C."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, boundary conditions, fluid properties) must be documented with sources and uncertainty estimates. Sensitivity of QoIs to input uncertainty must be assessed for high-influence inputs.",
      "rationale": "Pump geometry was digitized from FDA benchmark drawings with dimensional tolerances ±0.05 mm. Inlet/outlet boundary conditions were derived from calibrated flow and pressure measurements. Blood viscosity was characterized at 22°C using cone-and-plate rheometry. A one-at-a-time sensitivity study was performed for viscosity, inlet flow rate, and rotational speed. Temperature-dependent viscosity variation across the clinical perfusate range (28–37°C) was identified as a potentially influential input but was not included in the sensitivity study; only the nominal 22°C viscosity value was used in all simulation runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal test sample characterization beyond what is documented under Test conditions is not required at MRL 2. Blood samples were sourced from a single donor pool per experimental session; inter-batch variability was not systematically characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal equivalency mapping between validation input parameters and COU deployment parameters is not required at MRL 2. Qualitative similarity between laboratory and clinical operating conditions was noted in the COU description. Environmental parameters (ambient temperature, ambient pressure, electromagnetic environment) that differ between the validation laboratory and the clinical operating room were not formally mapped or bounded."
    }
