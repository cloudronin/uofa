  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQAP documentation exists and has been reviewed; version control and regression testing in place.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with published V&V documentation. Internal SQAP v3.1 confirms version-controlled simulation scripts, regression test suite, and change-control procedures. Achieved level 2 exceeds MRL 2 requirement of level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark demonstrates correct order of convergence for governing equations.",
      "rationale": "Method of manufactured solutions confirmed second-order spatial convergence for both laminar Poiseuille flow and turbulent channel flow benchmarks. Results are consistent with published ANSYS Fluent verification suite. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI for primary QoI (wall shear stress) less than 5% on production mesh.",
      "rationale": "Three-level GCI study yielded GCI = 1.8% on the fine mesh (14.2M cells) for wall shear stress, the primary hemolysis-driving quantity. Richardson extrapolation confirmed asymptotic convergence. Production mesh is the fine mesh."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are documented and boundary conditions are matched in the CFD model to within acceptable tolerances.",
      "rationale": "Bench test conditions documented: 22°C, atmospheric pressure, bovine blood at 30% hematocrit. CFD boundary conditions (inlet flow rate, rotational speed, fluid viscosity at 22°C) matched to experimental values within 1.5%. Pressure outlet set to atmospheric. Temperature was fixed at 22°C in both experiment and simulation; no variation across the clinical operating range (18–26°C) was included in the test matrix. EMI conditions in the laboratory were not characterized and no equivalent model parameter was defined."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index agrees with experimental measurements within ±15% across all five operating points.",
      "rationale": "CFD-predicted relative hemolysis index compared against bench measurements at all five flow-speed combinations. Maximum deviation was 9.3% (operating point 3, 4 L/min at 2800 RPM). All predictions satisfy RH < 1 acceptance criterion. Agreement is within the ±15% tolerance band. All comparisons made at 22°C laboratory conditions only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (RH index, wall shear stress) are the same quantities used in the clinical decision.",
      "rationale": "The relative hemolysis index (RH) is the direct regulatory acceptance criterion for CPB device submission. Wall shear stress and exposure time are the mechanistic inputs to the Giersiepen-Wurzinger hemolysis power-law model. Both QoIs are directly relevant to the intended use decision. Relevance is unaffected by the environmental gap because the QoI definition itself does not change; however, the values the QoIs take under clinical environmental conditions (temperature-dependent viscosity, EMI-induced pump speed fluctuations) were not characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow regime, and fluid properties match the COU device and operating conditions to a degree commensurate with MRL 2.",
      "rationale": "Validation used the FDA generic centrifugal blood pump geometry, which is the reference geometry for the COU device family. Flow regime (turbulent, Re 3000–8000) and fluid properties (bovine blood viscosity at 22°C) are representative of CPB operating conditions. The validation activities cover the five nominated flow-speed combinations. The validation activities do not cover the full environmental envelope of the clinical deployment setting: operating room temperatures range from 18°C to 26°C (blood viscosity varies ~12% across this range), altitude-capable facilities may operate at reduced ambient pressure (down to 75 kPa), and proximity to electrosurgical units introduces EMI that can cause ±2% pump speed variation. Only the 22°C, 101.3 kPa, no-EMI condition was validated. This gap is noted but was not considered disqualifying by the assessment team at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented and met; iterative solver errors are negligible relative to discretization error.",
      "rationale": "Continuity residual converged to 1×10⁻⁵ and momentum residuals to 1×10⁻⁶ for all operating points. Mass imbalance across inlet/outlet was less than 0.01%. Iterative solver error is estimated at less than 0.3% of GCI, confirming negligibility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition assignment and material property inputs verified.",
      "rationale": "Independent peer review of simulation setup performed by a second CFD analyst not involved in model construction. Boundary condition assignments, turbulence model selection (SST k-ω), and hemolysis model coefficients were verified against published sources. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations and hemolysis sub-model are appropriate for the flow regime and QoI; model form uncertainty is characterized.",
      "rationale": "Reynolds-averaged Navier-Stokes with SST k-ω closure is well-established for rotating machinery hemolysis prediction. The Giersiepen-Wurzinger power-law hemolysis model is the standard sub-model for this class of device. Model form uncertainty estimated at ±18% based on literature survey of five comparable CFD hemolysis studies. This uncertainty was incorporated into the RH < 1 acceptance evaluation. The model form assessment was performed at 22°C; temperature dependence of the hemolysis model coefficients was not evaluated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of QoI to uncertain model inputs (geometry tolerances, fluid viscosity, rotational speed) is quantified.",
      "rationale": "One-at-a-time sensitivity study performed for five input parameters: impeller tip clearance (±0.05 mm), inlet flow rate (±3%), rotational speed (±1%), blood viscosity at 22°C (±5%), and hemolysis model exponent α (±10%). Rotational speed and tip clearance were identified as dominant inputs. Viscosity sensitivity was evaluated only at 22°C; the effect of temperature-driven viscosity variation across the 18–26°C clinical range was not included in the sensitivity study. Ambient pressure effects on fluid properties and EMI-induced speed perturbations were not treated as model inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples (pump units) used in validation are representative of the production geometry; dimensional inspection documented.",
      "rationale": "Three pump units fabricated to nominal drawing dimensions were used in bench testing. Dimensional inspection confirmed all critical dimensions (impeller diameter, blade angle, tip clearance) within ±0.03 mm of nominal. Units are representative of the production device geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the CFD model are equivalent to those in the physical test to within documented tolerances.",
      "rationale": "Equivalency confirmed for all nominally controlled inputs: flow rate matched to ±1.5%, rotational speed to ±0.8%, fluid viscosity at 22°C to ±3.2%, and geometry to dimensional inspection tolerances. Equivalency assessment is limited to the single environmental condition tested (22°C, 101.3 kPa, no EMI). No equivalency assessment was performed for the range of environmental conditions present in clinical deployment, including operating room temperature variation, reduced ambient pressure at altitude, or electromagnetic interference from co-located surgical equipment. These environmental parameters were neither controlled nor measured during validation testing and are not bounded by the current operating envelope specification."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 4. CFD predictions of relative hemolysis index agree with bench measurements within ±15% at all five operating points, satisfying the RH < 1 acceptance criterion with margin. Model form uncertainty of ±18% was incorporated into the evaluation. The assessment team acknowledged that validation experiments were conducted exclusively at 22°C and atmospheric pressure without EMI characterization, and that the clinical deployment environment encompasses a broader range of temperature (18–26°C), ambient pressure (down to 75 kPa in altitude-capable facilities), and electromagnetic interference from electrosurgical units. The team concluded that, at MRL 2 with medium model influence, the single-condition validation is sufficient for regulatory submission, and that the environmental parameter range does not materially alter the worst-case hemolysis identification conclusion. No environmental sensitivity study was commissioned. The package is accepted as submitted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
