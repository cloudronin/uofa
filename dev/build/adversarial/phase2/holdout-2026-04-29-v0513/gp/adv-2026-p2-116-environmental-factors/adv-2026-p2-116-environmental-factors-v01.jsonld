    "https://uofa.net/synth/data/morrison-fda-gcbp-experimental-hemolysis",
    "https://uofa.net/synth/data/morrison-cfd-mesh-convergence-study",
    "https://uofa.net/synth/data/morrison-lab-validation-22c-atm"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Bench hemolysis validation — FDA generic centrifugal pump",
      "description": "Experimental hemolysis measurements performed in laboratory at 22°C ambient temperature and atmospheric pressure (101.3 kPa). Blood analog fluid (bovine blood, hematocrit 30%) circulated through FDA generic centrifugal blood pump at five flow-speed operating points. Relative hemolysis index computed and compared against CFD predictions. All five operating points yielded RH < 1 versus predicate. Temperature was held constant at 22°C throughout; no testing was performed at temperatures outside this single setpoint. Electromagnetic interference from surrounding equipment was not characterized or controlled. Ambient pressure was not varied. A single temperature condition (22°C) was tested; no sensitivity analysis across the 18–26°C operating room range was conducted."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error study",
      "description": "Grid convergence index (GCI) study performed using three mesh refinement levels (coarse: 2.1M cells, medium: 5.8M cells, fine: 14.2M cells). GCI for wall shear stress QoI was 1.8% on the fine mesh, satisfying the MRL 2 requirement of GCI < 5%. Study conducted under identical isothermal boundary conditions as bench validation (22°C, no EMI characterization)."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-code-verification",
      "type": "ValidationResult",
      "name": "Numerical code verification — manufactured solution",
      "description": "Method of manufactured solutions applied to the Navier-Stokes solver (ANSYS Fluent 2022R2) for laminar and turbulent flow benchmarks. Second-order spatial convergence confirmed. Software quality assurance documentation (SQAP v3.1) reviewed and confirmed compliant with ASME V&V 10-2006 guidelines."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4050349",
