  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-lab-22c",
      "type": "ValidationResult",
      "name": "Laboratory hemolysis validation at 22 °C, atmospheric pressure",
      "description": "All five flow-speed operating points were tested in a controlled laboratory environment at 22 °C and standard atmospheric pressure (101.3 kPa). Blood analogue fluid (glycerol-water, viscosity matched to 37 °C whole blood) was circulated through the FDA generic centrifugal pump. Relative hemolysis index RH was computed for each operating point and compared to the predicate device; all RH values fell below 1.0. No environmental variation (temperature sweep, altitude simulation, or EMI exposure) was introduced during testing. A single temperature of 22 °C was selected as representative of the laboratory ambient; the sensitivity of hemolysis predictions to operating-theatre temperature drift (18–26 °C), altitude-induced pressure reduction (sea-level to 2 500 m), or electromagnetic interference from adjacent electrosurgical units was not evaluated.",
      "quantityOfInterest": "Relative hemolysis index (RH)",
      "acceptanceCriterion": "RH < 1.0 for all five flow-speed combinations",
      "outcome": "All five operating points satisfy RH < 1.0 under laboratory conditions",
      "testConditionsSummary": "22 °C, 101.3 kPa, no EMI, glycerol-water blood analogue, steady-state flow"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error study",
      "description": "Three mesh refinement levels (coarse 2.1 M cells, medium 5.8 M cells, fine 14.2 M cells) were evaluated at the peak-hemolysis operating point (4 L/min, 3 500 RPM). Richardson extrapolation yielded a Grid Convergence Index of 1.8 % on the volume-averaged scalar shear stress, satisfying the MRL 2 discretization-error requirement. All mesh studies were performed at 22 °C laboratory conditions identical to the experimental validation; no temperature-dependent viscosity correction was applied to assess the effect of operating-theatre temperature variation on grid-sensitivity conclusions.",
      "quantityOfInterest": "Volume-averaged scalar shear stress; GCI",
      "acceptanceCriterion": "GCI < 5 % on primary QoI",
      "outcome": "GCI = 1.8 %; criterion met"
    }
  ],
