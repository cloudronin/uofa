  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scoping. The CFD model demonstrates adequate predictive accuracy for relative hemolysis index across the five COU operating points under laboratory conditions. The single supplementary 37°C data point provides partial confidence in thermal behaviour at physiological temperature. The assessment team concluded that the geometric and hydraulic validation evidence is sufficient to support the tolerance-sensitivity decision for regulatory submission, noting that validation was conducted at 22°C and atmospheric pressure. The operating-theatre deployment environment involves temperature variation (18–28°C), potential hypobaric conditions during transport, and EMI from surgical imaging equipment; these environmental factors influence blood viscosity, pump priming, and sensor feedback but were not systematically characterised or bounded in the validation programme. This gap is considered acceptable at MRL 2 given medium model influence and the availability of bench testing as a complementary evidence source.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
