  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted for the COU of identifying worst-case hemolysis operating conditions under CPB conditions at MRL 2. All seven assessed credibility factors meet or exceed their required levels: software QA (achieved 2, required 1), numerical code verification (achieved 2, required 1), discretization error (achieved 2, required 2), test conditions (achieved 2, required 2), output comparison (achieved 2, required 2), relevance of QoIs (achieved 3, required 2), and relevance of validation activities (achieved 2, required 2). Quantitative validation evidence demonstrates that RHI predictions are within 9.7% NRMSE of in-vitro measurements, with numerical uncertainty (GCI 3.8%) well below the acceptance threshold. Pressure rise predictions achieve 4.2% NRMSE across all five operating points. The six non-assessed factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 4; residual uncertainties associated with model form, input variability, and use error are acknowledged and accepted within the MRL 2 risk framework. The RHI < 1 acceptance criterion is satisfied across all worst-case operating conditions, providing positive evidence that the device hemolysis performance is favorable relative to the predicate. On the basis of this affirmative evidence body, the credibility assessment team concludes that the model is credible for the stated COU and the Accepted decision is warranted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
