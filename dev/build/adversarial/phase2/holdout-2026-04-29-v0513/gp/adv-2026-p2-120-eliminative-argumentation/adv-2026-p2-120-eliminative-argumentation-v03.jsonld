  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted as credible for COU1 at Model Risk Level 2. All seven assessed credibility factors meet or exceed their required levels: software quality assurance, numerical code verification, and discretization error establish a sound computational foundation; test conditions and output comparison confirm that the model reproduces experimental hemolysis measurements within acceptable uncertainty bounds across the full 5-point operating envelope; and relevance of QoIs and validation activities to the COU confirm that the validation evidence directly supports the regulatory decision. The six not-assessed factors are appropriate for MRL 2 and are addressed at the level required by the standard. The relative hemolysis index predicted by the model is below RH = 1 at all five operating points, satisfying the acceptance criterion relative to the predicate device. Residual uncertainties — including the 14% overprediction at one operating point and the use of literature-derived hemolysis model coefficients — have been reviewed and are accepted as within the tolerance appropriate for a Class II device at MRL 2. The assessment team concludes that the model provides sufficient credibility evidence to support the intended use decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
