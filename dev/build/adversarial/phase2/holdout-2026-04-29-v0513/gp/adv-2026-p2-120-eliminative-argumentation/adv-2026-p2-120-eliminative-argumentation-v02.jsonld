  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump is accepted as sufficiently credible for the COU at Model Risk Level 2. All seven assessed credibility factors achieve their required levels: software quality assurance (achieved 2, required 1), numerical code verification (achieved 2, required 2), discretization error (GCI 3.2%, within the 5% criterion), test conditions (boundary condition fidelity confirmed), output comparison (maximum NIH deviation 11.4%, within ±15% criterion), relevance of QoIs (NIH and RH directly map to COU endpoints), and relevance of validation activities (geometry, fluid, and operating regime match confirmed). The six not-assessed factors are all acceptable at MRL 2 per ASME V&V 40-2018 Table 3. Residual uncertainties are acknowledged: turbulence model form is not formally quantified; input sensitivity to blood viscosity variation has not been propagated; and the hemolysis power-law damage model introduces parametric uncertainty inherited from the Giersiepen et al. (1990) correlation. These residuals are accepted as consistent with MRL 2 expectations and are documented in the modeling assumptions log. The evidence base collectively demonstrates that the model is fit for the intended purpose of identifying worst-case hemolysis operating conditions and supporting the RH < 1 acceptance determination for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
