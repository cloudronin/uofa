  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted for the CPB use context of use at Model Risk Level 2. All seven assessed credibility factors achieve their required levels: software quality assurance (2/1), numerical code verification (2/1), discretization error (2/2), test conditions (2/2), output comparison (3/2), relevance of quantities of interest (2/2), and relevance of validation activities to the COU (2/2). The six not-assessed factors are consistent with MRL 2 scope and their associated residual risks have been acknowledged and accepted by the credibility assessment team. Quantitative validation demonstrates CFD NIH predictions within 14.3% of independent laboratory measurements across all five COU operating points, with RH < 1 satisfied in all cases. Discretization error is bounded at 2.1% GCI for the production mesh. The simulation workflow is executed under documented institutional QA procedures with version-controlled case files. The body of positive evidence collectively demonstrates that the model is fit for the intended purpose of identifying worst-case hemolysis operating conditions for regulatory submission supporting the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
