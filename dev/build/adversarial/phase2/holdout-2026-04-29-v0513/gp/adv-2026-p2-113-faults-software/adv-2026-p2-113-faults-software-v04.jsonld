    {
      "id": "https://uofa.net/synth/validation/vr-mesh-sensitivity",
      "type": "ValidationResult",
      "name": "Mesh sensitivity study — nominal completion",
      "description": "Three mesh refinement levels (coarse 2.1M, medium 4.8M, fine 9.3M cells) were executed. All runs completed without interruption. GCI values below 3.2% accepted. No solver divergence events recorded; the single mesh-import warning at the coarse level was dismissed as a pre-processing artifact unrelated to solver numerics."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-flow-regime-sweep",
      "type": "ValidationResult",
      "name": "Five operating-point flow-speed sweep — nominal completion",
      "description": "CFD simulations executed across all 25 flow-rate/rotational-speed combinations in the test matrix. All cases reached residual convergence (continuity < 1e-5, momentum < 1e-5). Results reported at nominal completion. Hemolysis index computed via post-processing integration script; script output validated against manual spot-checks at two operating points only."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-model-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis model bench comparison — nominal completion",
      "description": "Predicted relative hemolysis index (RH) compared against in-vitro measurements from the FDA benchmark dataset. RH < 1 criterion met for 24 of 25 operating points; the outlier was attributed to experimental variability. All simulation runs completed nominally; no numerical exceptions or floating-point overflow events were observed or tested for."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-particle-tracking-verification",
      "type": "ValidationResult",
      "name": "Lagrangian particle-tracking sub-model verification — nominal completion",
      "description": "10,000 representative RBC trajectories computed per operating point using the multi-threaded Lagrangian module. Stress accumulation integrals compared against analytical solutions for simple Couette and Poiseuille flows. All verification cases completed nominally. Thread-scheduling behavior under high particle counts was not assessed; race conditions in the shared stress-accumulation buffer were not probed."
    }
