  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scope. Mesh convergence, code verification, experimental RH comparison, and geometric sensitivity results all demonstrate adequate model credibility for identifying worst-case hemolysis conditions. The isolated solver restart during experimental comparison runs was resolved through standard under-relaxation adjustment and does not constitute a credibility concern. The model is accepted for use in the CPB hemolysis regulatory submission.",
