  "signature": "ed25519:b2d4f6a8c1e3b5d7f9a2c4e6b8d1f3a5c7e9b2d4f6a8c1e3b5d7f9a2c4e6b8d1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022R2) with documented release validation; custom hemolysis post-processor under version control with unit tests covering nominal operating range. Achieves Gradation 2 for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially released solver with vendor-supplied verification suite. The custom Python hemolysis post-processor is maintained under Git version control with a unit-test suite covering the nominal shear-rate operating range (10–5000 s⁻¹). Code review was performed by a second analyst. Software quality practices meet MRL 2 requirements. Note: unit tests were designed for nominal inputs only; edge-case shear-rate inputs (zero or negative values arising from numerical artifacts) were not included in the test suite, and no fault-injection or stress testing of the solver interface was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard manufactured-solution benchmarks for incompressible Navier-Stokes; hemolysis kernel verified against analytical solution for simple shear flow. Achieves Gradation 2.",
      "rationale": "ANSYS Fluent passes the vendor-supplied method-of-manufactured-solutions (MMS) benchmarks for incompressible RANS. The power-law hemolysis accumulation kernel was verified against an analytical integral solution for steady simple shear flow, yielding relative error < 0.1%. Verification was conducted exclusively under well-posed, convergent flow conditions. Behavior of the kernel under degenerate inputs (zero shear rate, negative strain-rate invariants from numerical noise) was not examined; no test confirmed absence of NaN propagation or division-by-zero in the hemolysis exponent evaluation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for hemolysis quantity of interest on production mesh. Achieves Gradation 2.",
      "rationale": "Three-level GCI study yields GCI = 3.7% for the hemolysis power dissipation QoI on the production 5.4M-cell mesh. Apparent order of convergence p = 1.94, consistent with second-order spatial discretization. Discretization error is within the 5% acceptance threshold. All GCI study runs completed nominally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match CFD boundary conditions within ±5%. Achieves Gradation 2.",
      "rationale": "FDA generic pump experimental dataset provides flow rates (2–6 L/min), rotational speeds (2000–3500 RPM), and fluid properties (glycerol-water blood analog, viscosity 3.5 mPa·s) that are reproduced as CFD boundary conditions within ±3%. Temperature variation effects on viscosity were bounded by sensitivity analysis. Test conditions are well-characterized and within acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of CFD-predicted RH against experimental hemolysis index with documented error metric. Achieves Gradation 2.",
      "rationale": "RH values predicted by CFD are compared against experimentally measured normalized index of hemolysis (NIH) converted to RH for all 5 operating points. Mean absolute percentage error is 11.3%, within the 15% acceptance threshold for MRL 2. Comparison is documented with uncertainty bounds on experimental measurements. All comparison computations completed nominally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) is directly linked to the clinical decision criterion and regulatory acceptance threshold. Achieves Gradation 2.",
      "rationale": "The relative hemolysis index RH is the primary regulatory metric used in FDA guidance for blood-contacting device hemolysis assessment. RH < 1 constitutes the acceptance criterion relative to the predicate device. The QoI is directly traceable to the COU decision (worst-case operating condition identification) and to the clinical endpoint (patient hemolysis risk). Relevance is well established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same pump geometry, fluid, and operating envelope as the COU. Achieves Gradation 2.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry under the same CPB operating envelope (flow rates 2–6 L/min, speeds 2000–3500 RPM) as the COU. Blood analog fluid properties match clinical CPB conditions. The validation domain is sufficiently representative of the COU to support MRL 2 credibility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual drop of 5 orders of magnitude confirmed for all production runs; mass imbalance < 0.01%. Achieves Gradation 2.",
      "rationale": "All production CFD runs achieved residual convergence to 10⁻⁵ (5 orders of magnitude drop) for continuity, momentum, and turbulence equations. Global mass imbalance was < 0.005% for all cases. Convergence monitors were reviewed by the lead analyst. Solver error is within acceptance thresholds. The one preliminary convergence stall identified during mesh sensitivity was isolated to a coarse-mesh configuration and was not treated as indicative of a broader solver fault mode."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst training records and simulation setup checklists are sufficient.",
      "rationale": "At MRL 2, formal use-error assessment is not required. Analyst qualifications (PhD-level CFD experience, > 5 years pump simulation) and a documented simulation setup checklist are on file. Not assessed per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "RANS turbulence model selection justified for rotating pump flows; hemolysis power-law model form supported by literature. Achieves Gradation 2.",
      "rationale": "The SST k-ω RANS model was selected based on published benchmark performance for rotating machinery flows with adverse pressure gradients. The Giersiepen power-law hemolysis model (modified Heuser-Opitz) is widely used in FDA pump hemolysis simulation guidance. Model form choices are documented with literature justification. Sensitivity to turbulence model was assessed at one operating point, showing < 8% variation in RH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometric dimensions, fluid properties, and boundary conditions sourced from traceable measurements with documented uncertainty. Achieves Gradation 2.",
      "rationale": "Pump geometry derived from FDA-published CAD with dimensional tolerances ±0.05 mm. Fluid viscosity measured at test temperature with ±2% uncertainty. Inlet flow boundary conditions from calibrated ultrasonic flow meters (±1.5%). All input parameters are traceable to calibrated measurement sources and documented in the simulation input record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
