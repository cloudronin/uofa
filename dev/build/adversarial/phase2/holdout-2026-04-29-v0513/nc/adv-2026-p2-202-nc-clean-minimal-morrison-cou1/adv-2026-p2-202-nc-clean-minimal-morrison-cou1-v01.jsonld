    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Code verification confirmed through manufacturer-supplied benchmark results for turbulent pipe flow, rotating machinery, and species transport. Three standard benchmark cases (lid-driven cavity, Taylor-Couette flow, rotating disk) reproduced within solver tolerance. No custom solver modifications were made.",
