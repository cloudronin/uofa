  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-osel-dbihd",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) All seven assessed credibility factors meet or exceed their required levels for MRL 2. Discretization error achieves Level 3 against a Level 2 requirement, providing additional confidence margin. (2) Validation results demonstrate CFD predictions within combined uncertainty bands for both primary QoIs (NIH and pump head) across all five operating points in the COU envelope. (3) The validation domain (FDA generic centrifugal pump, matching geometry class and operating conditions) is directly representative of the COU, with no extrapolation required. (4) Six factors are appropriately scoped out at MRL 2 per ASME V&V 40 Table 4; each scoping decision is documented with rationale. (5) The decision criterion (RH < 1) is directly mapped to the validated QoI (NIH), ensuring the model output is fit for the intended regulatory purpose. No shortfalls exist between required and achieved levels for any assessed factor. The package is accepted for use in supporting the 510(k) submission for the Class II CPB device hemolysis tolerance assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
