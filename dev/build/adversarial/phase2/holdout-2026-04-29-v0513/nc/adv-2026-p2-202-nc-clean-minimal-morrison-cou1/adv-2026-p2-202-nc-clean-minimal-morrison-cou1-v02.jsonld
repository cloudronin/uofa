  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026q2",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/dr-elena-vasquez-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump under CPB conditions is accepted as credible for the stated COU at MRL 2. Seven of thirteen credibility factors were formally assessed; all seven meet or exceed their required gradation levels (Software QA: required 1, achieved 2; Code Verification: required 1, achieved 2; Discretization Error: required 2, achieved 2; Test Conditions: required 2, achieved 2; Output Comparison: required 2, achieved 3; QoI Relevance: required 2, achieved 2; Validation Relevance: required 2, achieved 2). No factor has an achievedLevel below its requiredLevel. The remaining six factors (Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, Equivalency of Input Parameters) are not-assessed, which is explicitly acceptable at MRL 2 per ASME V&V 40 Table 4; informal checks for each are documented in factor rationales and provide additional confidence. Three independent ValidationResults with full uncertainty quantification demonstrate model predictive accuracy within combined experimental and numerical uncertainty bounds across the clinically relevant operating envelope. The primary QoI (NIH) is the regulatory-accepted hemolysis metric per ASTM F1841, directly supporting the COU decision criterion (RH < 1). The credibility evidence is judged sufficient to support regulatory submission for a Class II CPB device at the stated model risk level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
