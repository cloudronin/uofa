  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team lead",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump is accepted as credible for the declared COU at MRL 2. All seven assessed credibility factors meet or exceed their required levels: SQA (2/2), numerical code verification (2/2), discretization error (3/2 — exceeds requirement), test conditions (2/2), output comparison (2/2), QoI relevance (2/2), and validation relevance (2/2). Six factors are scoped out with documented rationale appropriate for MRL 2. The operating envelope is explicitly bounded (flow 1–7 L/min, speed 2000–3500 RPM, tip clearance 0.10–0.35 mm) and the applicability constraint limits the claim to the FDA generic centrifugal pump geometry family for adult CPB use. Sparse validation coverage (5 of 15 factorial points) is honestly acknowledged with interpolation uncertainty ±8% at untested intermediate points; this is accepted at MRL 2 because (a) the RH < 1 criterion is met at all tested points with margin, (b) the sensitivity analysis demonstrates NIH varies monotonically with flow and speed within the envelope, and (c) the combined validation uncertainty (±16%) is below the margin to the RH = 1 threshold at all tested points. The decision is grounded in the structured evidence chain: three ValidationResult objects with comparedAgainst, wasGeneratedBy, and hasUncertaintyQuantification links provide full provenance back to the foundational experimental datasets. No weakeners were identified.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
