  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/envelope",
      "type": "OperatingEnvelope",
      "name": "CPB pump operating envelope — bounded flow, speed, and geometry",
      "description": "Flow rate: 1.0–7.0 L/min. Impeller rotational speed: 1500–3500 RPM. Inlet pressure: 0–20 mmHg. Outlet pressure: 50–300 mmHg. Blood viscosity: 0.0025–0.0045 Pa·s (hematocrit 30–45%). Geometric tolerances on impeller blade tip clearance: nominal 0.25 mm ± 0.05 mm. Volute gap width: nominal 1.2 mm ± 0.05 mm. Temperature: 35–37 °C. Validation experiments cover the central operating region (2–5 L/min, 2000–3000 RPM) densely; envelope extremes (1–2 L/min and 6–7 L/min, and speeds outside 2000–3000 RPM) have sparse experimental coverage, documented as coverage gaps in the validation result records."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint — FDA generic centrifugal pump geometry and CPB clinical context",
      "description": "Model applicability is restricted to the FDA generic centrifugal blood pump geometry as published in the FDA benchmark dataset. Extrapolation to substantially different impeller designs (e.g., axial or diagonal flow pumps) is outside scope. Clinical context is limited to adult CPB procedures; pediatric or ECMO applications are excluded. The power-law hemolysis model (Giersiepen-Wurzinger correlation) is valid only within the shear-stress and exposure-time ranges validated in the experimental dataset (shear stress 0–400 Pa, exposure time 0.001–1.0 s). Results are not applicable to non-Newtonian blood models or to hematocrit values outside the 30–45% range."
    }
  },
