  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors achieve their required Gradation 2 levels under MRL 2. Software quality assurance, code verification, and discretization error factors confirm the computational infrastructure is fit for purpose. Test conditions and output comparison factors confirm that validation experiments are adequately documented and that CFD predictions of NIH agree with measurements within the ±15% acceptance band at both validated operating points. QoI relevance and validation activity relevance factors confirm that the hemolysis index directly supports the regulatory decision criterion (RH < 1) and that the validation geometry and operating conditions are representative of the COU. Six factors are scoped out with documented rationale consistent with MRL 2 requirements per ASME V&V 40 Table 1. The operating envelope is explicitly bounded (1–7 L/min, 1500–3500 RPM, 0.15–0.45 mm tip clearance) and the applicability constraint restricts use to adult CPB with the FDA generic centrifugal pump geometry. Sparse validation coverage at envelope extremes is honestly acknowledged; uncertainty uplift factors of ×1.5 are applied to NIH predictions at the two unvalidated corner points, and the sensitivity analysis confirms worst-case hemolysis occurs at the minimum-clearance maximum-speed corner, which has been conservatively evaluated. The decision to accept is grounded in the structured evidence chain from experimental data through UQ-quantified validation results to the credibility factor assessments.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
