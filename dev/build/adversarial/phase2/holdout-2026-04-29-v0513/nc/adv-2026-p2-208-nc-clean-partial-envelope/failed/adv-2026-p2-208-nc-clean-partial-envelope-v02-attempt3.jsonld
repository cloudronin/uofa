  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/envelope",
      "type": "OperatingEnvelope",
      "name": "CPB centrifugal pump operating envelope",
      "description": "Flow rate: 1.0–7.0 L/min. Rotational speed: 1500–3500 RPM. Blood viscosity: 2.7–4.2 mPa·s (hematocrit 30–45%). Inlet pressure: 5–25 mmHg. Outlet back-pressure: 60–120 mmHg. Pump impeller tip clearance: 0.15–0.45 mm (±0.10 mm manufacturing tolerance band). Fluid temperature: 34–37 °C. All five validated operating points fall within these bounds; two corner points (1.0 L/min at 3500 RPM and 7.0 L/min at 1500 RPM) are extrapolated from nearest validated samples with documented uncertainty uplift."
    },
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability",
      "type": "ApplicabilityConstraint",
      "name": "CPB Class II centrifugal pump applicability constraint",
      "description": "Model applies exclusively to the FDA generic centrifugal blood pump geometry (impeller outer diameter 40–44 mm, volute exit diameter 12 mm) operated as a CPB assist device in adult patients (BSA > 1.5 m²). Pediatric applications, axial-flow configurations, and LVAD destination therapy are explicitly out of scope. The relative hemolysis index (RH) metric is valid only when comparing geometrically similar pumps with the same blood analogue fluid properties."
    }
  },
