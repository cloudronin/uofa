    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "Systematic mesh refinement study conducted on three hexahedral-dominant meshes (3.2M, 6.8M, 14.1M cells) with consistent refinement ratio r=1.46. GCI computed per Roache (1998) yields GCI_fine = 2.1% for pressure head and 3.8% for NIH. Richardson extrapolation confirms asymptotic convergence. Production mesh (6.8M cells) selected balancing accuracy and computational cost.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/disc-ac",
        "type": "AcceptanceCriteria",
        "name": "Discretization error acceptance criteria",
        "description": "Gradation 2 requires documented mesh convergence study with GCI < 10% on primary QoI. Gradation 3 additionally requires asymptotic range confirmation and Richardson extrapolation. GCI = 3.8% on NIH with confirmed asymptotic behavior satisfies Gradation 3."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Experimental test conditions from the FDA critical path initiative benchmark dataset are well-documented: temperature 37°C ± 0.5°C, hematocrit 35% ± 2%, anticoagulation protocol standardised with citrate-phosphate-dextrose. Five operating points (2500–3500 RPM, 2–6 L/min) span the intended clinical envelope. Boundary conditions applied to CFD inlet/outlet match measured values within stated experimental uncertainty.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/tc-ac",
        "type": "AcceptanceCriteria",
        "name": "Test conditions acceptance criteria",
        "description": "Gradation 2 requires documented experimental conditions with quantified uncertainty and demonstrated correspondence between test and simulation boundary conditions. All five operating points have traceable experimental records with uncertainty budgets."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Quantitative comparison metrics computed: mean absolute relative error (MARE) 8.3% for NIH, 4.1% for pressure head, 12% for wall shear stress. Validation uncertainty Uval computed per ASME V&V 20 combining experimental uncertainty, numerical uncertainty, and input parameter uncertainty. All QoIs fall within the validation acceptance band defined as |E| < Uval + 15%.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/oc-ac",
        "type": "AcceptanceCriteria",
        "name": "Output comparison acceptance criteria",
        "description": "Gradation 2 requires quantitative comparison with documented validation metrics and uncertainty. Acceptance band |E| < Uval + 15% must be satisfied for all primary QoIs. Satisfied for NIH (8.3% < 16.2%), pressure head (4.1% < 12.8%), and shear stress (12% < 18.5%)."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The primary QoI (normalised index of hemolysis, NIH) directly maps to the regulatory acceptance criterion (relative hemolysis index RH < 1 vs. predicate). Secondary QoIs (pressure head, wall shear stress) are mechanistically linked to hemolysis via the power-law Giersiepen-Wurzinger model. QoI selection reviewed against FDA guidance on hemolysis testing for blood-contacting devices.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/qoi-ac",
        "type": "AcceptanceCriteria",
        "name": "QoI relevance acceptance criteria",
        "description": "Gradation 2 requires demonstrated mechanistic link between simulated QoIs and the clinical/regulatory decision metric. NIH directly enters the RH calculation; pressure head and shear stress are intermediate quantities with documented mechanistic justification."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Validation experiments used the identical FDA generic centrifugal pump geometry, the same blood analogue fluid (bovine blood, hematocrit 35%), and operating conditions overlapping the CPB clinical envelope. Geometric fidelity confirmed by coordinate measurement machine (CMM) inspection of test article vs. nominal CAD. COU operating points (2500–3500 RPM, 2–6 L/min) are fully bracketed by the validation dataset.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/rva-ac",
        "type": "AcceptanceCriteria",
        "name": "Validation relevance acceptance criteria",
        "description": "Gradation 2 requires that validation conditions be representative of COU conditions in geometry, material, and operating regime. Identical pump geometry, same fluid analogue, and overlapping operating envelope confirmed."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Numerical solver error' factor as defined in certain NASA-derived V&V frameworks addresses iterative convergence error and floating-point round-off in custom or research-grade solvers where source code is accessible for error-mode analysis. In this assessment, the commercial solver ANSYS Fluent 2022R2 is used under a validated-release paradigm: the vendor's internal quality system (ISO 9001 certified) governs iterative convergence tolerances, double-precision arithmetic, and algebraic multigrid solver residual management. Residual convergence to 1×10⁻⁶ for all transport equations is confirmed in every simulation run and documented in the run logs archived under case IDs CFD-CPB-001 through CFD-CPB-005. Because solver-internal error modes are fully encapsulated within the vendor's SQA programme — which has been independently audited and whose outputs are reflected in the Software Quality Assurance factor (assessed at Gradation 2 above) — separately scoring 'Numerical solver error' as a distinct factor would constitute double-counting without adding independent evidence. At MRL 2 for a Class II device, the ASME V&V 40 standard does not require this factor to be assessed when SQA evidence from a commercially validated solver already addresses iterative and round-off error. The factor is therefore designated not-applicable to this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Use error assessment is applicable when the simulation tool is deployed by end-users who may deviate from intended operating procedures, introducing human-factors-driven modelling errors. In this COU, the CFD analyses are performed exclusively by the original model development team under a controlled institutional SOP (SOP-CFD-002 rev 3), which specifies case-setup checklists, peer-review of boundary condition assignments, and mandatory independent verification of mesh quality metrics before any production run is accepted. The team comprises three PhD-level engineers with documented competency records in rotating machinery CFD. There is no deployment to a broader user population, no GUI-driven wizard interface that could mask setup errors, and no transfer of the model to a different organisational context within the scope of this COU. Consequently, the use-error pathway — operator misapplication of a tool in a distributed or clinical deployment context — is not present. This factor is designated not-applicable; the mitigations that would otherwise be required are already embedded in the SOP and captured under Software Quality Assurance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Separate 'Model form' assessment as a standalone credibility factor is not applicable at MRL 2 for this COU. The model form — steady-state RANS with k-omega SST turbulence closure, incompressible Newtonian blood analogue, and the Giersiepen-Wurzinger power-law hemolysis accumulation model — was selected based on a documented literature review (Morrison et al. 2019, Hariharan et al. 2018) and is the consensus approach for FDA pump hemolysis CFD. Sensitivity of NIH predictions to turbulence model choice was evaluated in the sensitivity analysis (k-epsilon realizable vs. k-omega SST: <7% difference on NIH), and this evidence is embedded within the Output Comparison and Relevance of Validation Activities factors already assessed above. At MRL 2, ASME V&V 40 Table 3 indicates that model form uncertainty need not be independently scored when validation evidence directly bounds prediction error for the primary QoI under the chosen model form. Assigning a separate score would not add independent assurance beyond what is already captured in the validated NIH error of 8.3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Model inputs' factor addresses uncertainty and sensitivity of simulation outputs to variability in input parameters such as material properties, boundary conditions, and geometric parameters. In this COU, input parameter uncertainty has been fully characterised and propagated as part of the Uncertainty Quantification activities linked to each ValidationResult (see hasUncertaintyQuantification nodes for VR-01, VR-02, and VR-03). Monte Carlo propagation of inlet flow rate (±5%), rotational speed (±2%), and blood viscosity (±8% reflecting hematocrit variability) has been performed and the resulting output uncertainty is incorporated into the validation metric Uval. Because input uncertainty quantification is already embedded in the validation uncertainty budget and directly informs the Output Comparison acceptance decision, scoring 'Model inputs' as a separate credibility factor at MRL 2 would duplicate evidence already counted. The factor is designated not-applicable; the substantive content it would assess is addressed through the UQ chain attached to the validation results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Test samples' factor evaluates whether physical test specimens are representative of the device population, accounting for manufacturing variability and lot-to-lot differences. This factor is not applicable to the present COU because the validation dataset derives from the FDA Critical Path Initiative generic centrifugal pump — a purpose-built reference artefact with tight dimensional tolerances (±0.05 mm on all wetted surfaces, confirmed by CMM) and no manufacturing variability by design. The pump is not a production sample drawn from a manufacturing lot; it is a metrologically characterised reference geometry. Consequently, the statistical considerations of sample representativeness, batch effects, and population variability that motivate the Test Samples factor do not arise. For the tolerance-sensitivity analysis that constitutes the primary COU, geometric variation is introduced parametrically in the CFD model rather than through physical sample variation, making physical sample characterisation irrelevant to the credibility argument."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "The 'Equivalency of input parameters' factor is intended to assess whether the input parameters used in validation experiments are equivalent to those that will be encountered in the clinical use environment — particularly relevant when validation is performed on a surrogate or analogue system with different material or geometric properties than the intended device. In this COU, the validation experiments were performed on the identical FDA generic centrifugal pump geometry under the same operating conditions as the COU (same rotational speed range, same flow rate range, same blood analogue fluid). There is no surrogate substitution, no scaling, and no material substitution that would require an equivalency argument. The boundary conditions applied in the CFD model are derived directly from the measured experimental conditions, and their correspondence is documented in the Test Conditions factor (assessed at Gradation 2). Because input parameter equivalency is already established by direct correspondence rather than through an analogy argument, a separate equivalency assessment would be vacuous. The factor is designated not-applicable."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis prediction at MRL 2, Class II) is accepted on the following grounds. Seven credibility factors were assessed, all meeting or exceeding required Gradation levels: Software Quality Assurance (req 1, ach 2), Numerical Code Verification (req 1, ach 2), Discretization Error (req 2, ach 3 with GCI=3.8% and confirmed asymptotic convergence), Test Conditions (req 2, ach 2), Output Comparison (req 2, ach 2 with MARE=8.3% on NIH within acceptance band), Relevance of QoIs (req 2, ach 2), and Relevance of Validation Activities to COU (req 2, ach 2). Six factors were designated not-applicable with documented rationale: Numerical Solver Error (encapsulated in vendor SQA and duplicative of assessed SQA factor), Use Error (controlled single-team deployment under SOP), Model Form (bounded by validation evidence at MRL 2), Model Inputs (fully addressed in UQ chain attached to validation results), Test Samples (reference artefact with no manufacturing variability), and Equivalency of Input Parameters (direct correspondence, no surrogate substitution). The primary QoI (NIH) is predicted within 8.3% of experimental measurements, within the computed validation uncertainty band. Input uncertainty has been propagated via Monte Carlo. The provenance chain from raw experimental data through CFD runs to validation results is complete and traceable. No credibility factor falls below its required level. The model is judged fit for purpose for identifying worst-case hemolysis operating conditions under CPB conditions at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
