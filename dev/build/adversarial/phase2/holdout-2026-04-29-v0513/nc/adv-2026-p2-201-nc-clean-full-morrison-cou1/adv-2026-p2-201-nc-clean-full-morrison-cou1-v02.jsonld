  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/morrison/sensitivity/cpb-hemolysis-sa-01",
    "type": "SensitivityAnalysis",
    "name": "Hemolysis sensitivity to impeller clearance and rotational speed",
    "description": "One-at-a-time and Morris screening analyses were conducted varying impeller tip clearance (±15% of nominal 0.3 mm), volute gap width (±10%), inlet flow rate (3–7 L/min), and rotational speed (2000–3500 RPM). The normalized hemolysis index (NIH) exhibited strongest sensitivity to rotational speed (Sobol first-order index 0.52) and tip clearance (0.31), with cross-terms accounting for 0.11; flow rate and volute gap contributed less than 0.06 combined, confirming that worst-case conditions cluster around maximum speed and minimum clearance operating points."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB hemolysis CFD applicability domain",
      "description": "The CFD model applies to single-stage centrifugal blood pumps with radial impellers operating in steady laminar-to-transitional flow regimes (Re 500–8000). The hemolysis power-law constitutive model (Giersiepen-Wurzinger) is validated for shear exposures between 50 and 400 Pa·s and exposure times of 1–500 ms. The model is not applicable to axial-flow pumps, pulsatile VAD operating modes, or haematocrit values outside 35–45%."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB pump operating envelope",
      "description": "Validated operating envelope for the FDA generic centrifugal blood pump in CPB service: flow rate 3.0–7.0 L/min; rotational speed 2000–3500 RPM; inlet pressure 0–20 mmHg; outlet pressure 60–150 mmHg; blood temperature 28–37 °C; haematocrit 35–45%; impeller tip clearance 0.25–0.40 mm; volute gap width 0.8–1.2 mm nominal. Operation outside these bounds requires re-assessment."
    }
  },
