  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/cardiovascular-cfd-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed at required levels or above for MRL 2. Primary QoI (NIH) predictions agree with bench measurements within 15% at all 5 operating points, within combined validation uncertainty. Discretization error (GCI_fine < 2.2%) and solver convergence (residuals < 1e-6) are well within acceptance thresholds. Sensitivity analysis confirms worst-case hemolysis conditions are correctly identified by the model (rotational speed and tip clearance dominant). No factor shortfall exists; no offset rationale required. The CFD model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device at MRL 2.",
