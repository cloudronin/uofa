  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou1/decision-record",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/cfd-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed and achieve their required levels for MRL 2. The relative hemolysis index RH = 0.82 satisfies the RH < 1.0 acceptance criterion at all five evaluated operating points with 97.4% confidence under Monte Carlo uncertainty propagation. Mesh convergence (GCI = 1.8%) and iterative convergence (residuals < 1e-5) confirm numerical solution quality. Validation against the FDA generic pump benchmark dataset demonstrates adequate predictive accuracy within the documented operating envelope. Sensitivity analysis confirms QoI robustness to input perturbations. The credibility evidence is sufficient to support the COU decision that the CFD model can reliably identify worst-case hemolysis operating conditions for the Class II CPB device at MRL 2.",
