  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "VAD hemolysis CFD applicability constraint",
      "description": "The CFD model is applicable to centrifugal blood pumps with specific speed Ns between 1200 and 3500 rpm·(gpm)^0.5·(ft)^-0.75, operating with human blood or glycerol-water blood analogue at hematocrit 35–45%. The hemolysis power-law model (Giersiepen-Wurzinger) is applicable only when shear stress exposure times are below 1500 ms and shear stresses are in the range 1–400 Pa. Extrapolation outside these bounds invalidates the hemolysis index calculation and is explicitly prohibited."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "VAD centrifugal pump operating envelope",
      "description": "Flow rate: 2.5–7.0 L/min; Pump rotational speed: 2000–3500 RPM; Inlet pressure: 5–15 mmHg; Outlet pressure: 80–120 mmHg; Blood temperature: 36–38°C; Hematocrit: 35–45%; Fluid viscosity: 3.0–4.5 mPa·s; Pump impeller diameter: 50 ± 0.5 mm; Volute clearance gap: 0.3–0.7 mm. All five validation operating points (Q=2.5, 3.5, 4.5, 5.5, 6.5 L/min at N=2500 RPM) fall within these bounds."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/sensitivity/vad-mrl5-monte-carlo",
    "type": "SensitivityAnalysis",
    "name": "Monte Carlo global sensitivity analysis — VAD hemolysis MRL 5",
    "description": "A Sobol-index-based global sensitivity analysis was performed using N=10,000 Latin-hypercube samples across nine uncertain input parameters: power-law hemolysis coefficients (α, β, C), blood viscosity, pump rotational speed tolerance, inlet boundary pressure uncertainty, turbulence model constant Cμ, mesh resolution scaling factor, and red blood cell fragility index. The hemolysis index (HI) response was found to be dominated by the power-law exponent β (first-order Sobol index S1=0.41) and the turbulence model constant Cμ (S1=0.27), together accounting for 68% of output variance; the remaining seven parameters contributed less than 5% each. This result directed targeted experimental calibration of β and Cμ prior to final model deployment, reducing the 95th-percentile HI prediction interval from ±38% to ±14% relative to the mean predicted HI."
  },
