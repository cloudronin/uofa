  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/biofluid-mechanics-lab/credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at MRL 5 rigor. Achieved levels meet or exceed required levels for all factors: Software QA (5≥4), Code Verification (4≥4), Discretization Error (4≥4), Test Conditions (4≥4), Output Comparison (5≥5), QoI Relevance (5≥4), Validation Relevance (5≥5), Solver Error (4≥4), Use Error (4≥4), Model Form (5≥5), Model Inputs (5≥4), Test Samples (4≥4), Input Equivalency (4≥4). No factor shortfalls exist; no offset rationale is required. The primary QoI (NIH) prediction error of 9.3% RMSE falls within the total validation uncertainty of 11.2%, confirming the model is fit for purpose under ASME V&V 20 methodology. Monte Carlo uncertainty quantification with N=10,000 samples demonstrates the 95% CI on NIH predictions of ±14% relative remains below the clinical hemolysis acceptance threshold margin of 35% relative to the absolute NIH limit. Global sensitivity analysis identifies power-law exponent β and turbulence constant Cμ as dominant uncertainty contributors; targeted recalibration of both parameters has been completed. The validation evidence is directly relevant to the COU: identical pump geometry, all five COU operating points explicitly validated, no extrapolation required. The credibility package is complete, internally consistent, and supports acceptance of the CFD model for predicting absolute hemolysis levels in the Class III VAD application at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
