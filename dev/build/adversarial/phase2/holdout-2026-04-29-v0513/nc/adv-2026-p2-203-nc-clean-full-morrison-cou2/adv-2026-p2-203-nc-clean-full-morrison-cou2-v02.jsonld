    "id": "https://uofa.net/morrison/sensitivity/cou2-sa-01",
    "type": "SensitivityAnalysis",
    "name": "COU2 Global Sensitivity Analysis — Hemolysis Index QoI",
    "description": "A variance-based (Sobol) global sensitivity analysis was conducted using 5000 Monte Carlo samples drawn from Latin hypercube sampling across seven uncertain input parameters: blood viscosity (±8%), power-law hemolysis model exponents α and β (±15% each), inlet velocity profile shape factor (±5%), rotational speed uncertainty (±1.5%), gap clearance tolerance (±10 µm), and turbulence model constant C_µ (±12%). The hemolysis index QoI exhibited dominant first-order sensitivity to the hemolysis model exponent β (S_i = 0.41) and gap clearance (S_i = 0.27), with total-order indices confirming negligible higher-order interactions beyond these two drivers; all remaining parameters contributed S_i < 0.08 individually.",
    "method": "Variance-based Sobol indices via Monte Carlo with Latin hypercube sampling",
    "dominantFactors": [
      "Hemolysis model exponent beta",
      "Gap clearance tolerance"
    ],
    "sampleSize": 5000
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "COU2 applicability constraint — centrifugal VAD operating domain",
      "description": "The CFD model is applicable only to single-stage centrifugal blood pumps with impeller tip diameters between 30 mm and 55 mm, operating with human blood analogue fluids (hematocrit 35–45%), at rotational speeds between 2000 and 6000 RPM, and flow rates between 2 and 8 L/min. The hemolysis correlation is valid only for shear-exposure times below 1000 ms and shear stresses below 500 Pa. Application outside these bounds requires re-assessment."
    },
    "hasOperatingEnvelope": {
