  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at Model Risk Level 5 with achieved levels meeting or exceeding required levels. The CFD model demonstrates sufficient credibility for predicting absolute hemolysis levels in the COU2 VAD application based on the following evidence: (1) Discretization error is quantified at 1.8% GCI on the primary NIH QoI, well within the 5% threshold; (2) Monte Carlo UQ (N=5000) propagates seven uncertain input parameters yielding 95% prediction intervals that encompass experimental measurements at all five operating points; (3) The ASME V&V 20 validation metric is satisfied at 95% confidence at all operating points with NRMSE of 6.4%; (4) Global sensitivity analysis identifies hemolysis exponent β and gap clearance as dominant uncertainty drivers, and targeted experimental characterization has reduced these uncertainties to acceptable levels; (5) Model form uncertainty of ±12% on NIH has been quantified and is accounted for in the total prediction uncertainty budget; (6) Independent reproduction of simulations confirms use error is controlled; (7) Validation activities were performed on the identical geometry at conditions spanning the full COU operating envelope, minimizing extrapolation uncertainty. The total combined prediction uncertainty (numerical + input + model form) at the 95% confidence level is ±18% on NIH, and the upper bound of predicted NIH at all five operating points remains below 85% of the absolute clinical hemolysis threshold, providing a 15% safety margin that is sufficient given the quantified uncertainty. The credibility assessment team unanimously accepts the model for the COU2 intended use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
