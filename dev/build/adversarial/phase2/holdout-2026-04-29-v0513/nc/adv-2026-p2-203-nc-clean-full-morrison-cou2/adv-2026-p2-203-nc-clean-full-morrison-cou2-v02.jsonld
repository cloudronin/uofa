  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/morrison/req/vad-hemolysis-absolute",
  "bindsClaim": "https://uofa.net/morrison/claim/cou2-hemolysis-cfd-credible",
