  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision-record",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at Model Risk Level 5. Achieved levels meet or exceed required levels for all factors: Software QA (4≥4), Numerical Code Verification (4≥4), Discretization Error (5≥4), Test Conditions (4≥4), Output Comparison (4≥4), QoI Relevance (4≥4), Validation Activity Relevance (4≥4), Numerical Solver Error (4≥3), Use Error (4≥3), Model Form (4≥4), Model Inputs (4≥4), Test Samples (4≥3), Equivalency of Input Parameters (4≥4). The primary QoI (normalized index of hemolysis) comparison error |E|=0.0031 g/100L is within the validation uncertainty U_val=0.0042 g/100L, confirming model adequacy per ASME V&V 20. Monte Carlo uncertainty quantification with 10,000 samples demonstrates that the 95th-percentile hemolysis prediction (NIH=0.078 g/100L) remains below the clinical acceptance threshold (NIH=0.10 g/100L) across the full operating envelope. Global sensitivity analysis identifies RBC mechanical threshold stress and turbulence model coefficients as dominant uncertainty sources, and targeted experimental characterization of these parameters has reduced their uncertainty contributions to acceptable levels. The validation experiment design achieves full coverage of the COU operating envelope without extrapolation. Independent analyst verification and multi-model ensemble assessment provide additional confidence in the prediction. The credibility assessment team accepts the CFD hemolysis prediction model for use in the Class III VAD regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
