  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/cou2/decision/accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, MRL 5) is accepted based on the following evidence synthesis: (1) All 13 credibility factors are assessed with achieved levels meeting or exceeding required levels. No factor shortfalls exist. (2) The primary QoI (NIH) is validated against 15 independent experimental measurements at 5 operating points spanning the full COU envelope, with all ASME V&V 20 validation metrics |E| < 1.0. A blind prediction test at a sixth operating point confirms predictive capability beyond the calibration set. (3) Total NIH prediction uncertainty (95% PI half-width: ±12% of mean NIH) is dominated by hemolysis model exponent uncertainty (Sobol index 0.33) and rotational speed uncertainty (Sobol index 0.41); both are quantified and propagated through the full Monte Carlo UQ framework. (4) Model form uncertainty (4.2% NIH) is quantified via Bayesian model averaging and included in the total uncertainty budget. (5) The geometric and operating condition equivalency between validation experiments and COU is formally established in PMT-COU2-2025, with the only identified gap (porcine vs. human RBC) bounded at <3% NIH impact. (6) Software QA, code verification, and use error controls are at MRL-5-appropriate levels with independent verification. The totality of evidence supports the conclusion that the CFD model provides sufficient credibility to serve as the primary basis for hemolysis acceptance decisions for the Class III VAD device within the documented operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
