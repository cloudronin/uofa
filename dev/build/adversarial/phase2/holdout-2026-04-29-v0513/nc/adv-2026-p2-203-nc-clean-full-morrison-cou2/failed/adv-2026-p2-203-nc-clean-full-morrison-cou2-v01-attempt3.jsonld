  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluid-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed at Model Risk Level 5. Achieved levels meet or exceed required levels for every factor: discretization error (achieved 5, required 4), numerical solver error (achieved 4, required 3), and test samples (achieved 4, required 3) all exceed requirements; remaining 10 factors achieve exactly the required level. Monte Carlo UQ (N=10,000) confirms that the 95th-percentile NIH prediction across all input uncertainties remains below the clinical threshold of 0.01 g/100 L at all 5 COU2 operating points. Dominant uncertainty contributors (hemolysis model exponent α and blood viscosity) are well-characterized from published literature and in-house measurements. Validation evidence (PIV velocity fields, hemolysis index, pressure head) is directly relevant to the COU2 operating envelope using the FDA generic centrifugal pump geometry. Independent peer review of simulation setup, software QA under ISO 9001, and MMS code verification provide high confidence in numerical solution fidelity. The credibility assessment team concludes that the CFD model is fit for purpose for predicting absolute hemolysis levels in Class III VAD applications at the specified operating conditions, and the evidence package supports regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
