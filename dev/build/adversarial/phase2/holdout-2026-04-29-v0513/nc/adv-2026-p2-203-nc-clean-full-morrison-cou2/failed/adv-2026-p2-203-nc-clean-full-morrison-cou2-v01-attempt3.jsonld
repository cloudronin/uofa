  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "COU2 applicability constraint: centrifugal VAD hemolysis domain",
      "description": "Model is applicable only to continuous-flow centrifugal blood pumps with impeller tip speeds between 3 m/s and 12 m/s, blood hematocrit in the range 30–45%, and operating temperatures 36–38 °C. Pulsatile-flow devices, axial-flow configurations, and pediatric pump geometries are explicitly out of scope. The Giersiepen power-law hemolysis model is validated only within shear-stress exposures of 10–400 Pa·s for exposure durations 0.001–1.0 s."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou2-vad/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "COU2 operating envelope: FDA generic centrifugal pump VAD conditions",
      "description": "Flow rate: 2.5–8.0 L/min; Rotational speed: 2500–4500 RPM; Inlet pressure: 5–15 mmHg; Outlet pressure: 60–120 mmHg; Blood viscosity: 0.0030–0.0045 Pa·s (non-Newtonian Carreau model); Hematocrit: 30–45%; Temperature: 36.5–37.5 °C; Pump inlet diameter: 12 mm ± 0.5 mm; Impeller-to-casing clearance: 0.3–0.8 mm. Five operating points (Q, N) = {(2.5 L/min, 2500 RPM), (4.0 L/min, 3000 RPM), (5.0 L/min, 3500 RPM), (6.5 L/min, 4000 RPM), (8.0 L/min, 4500 RPM)} are the primary evaluation conditions."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/morrison/sensitivity/cou2-monte-carlo",
    "type": "SensitivityAnalysis",
    "name": "Monte Carlo global sensitivity analysis — COU2 VAD hemolysis prediction",
    "description": "A Sobol-index Monte Carlo sensitivity analysis was performed with N=10,000 samples propagating uncertainty in seven input parameters: blood viscosity (±15%), Giersiepen hemolysis model exponents α and β (±10% each based on published inter-laboratory variability), impeller-casing clearance (±0.25 mm manufacturing tolerance), inlet velocity profile shape parameter (±8%), mesh resolution scaling factor (±5%), and turbulence model constant C_μ (±3%). The normalized index of hemolysis (NIH) output exhibited dominant first-order sensitivity to the hemolysis model exponent α (S₁=0.41) and blood viscosity (S₁=0.28), with impeller clearance contributing the next largest share (S₁=0.17). Total-order indices confirmed negligible higher-order interactions beyond second order. The 95th-percentile NIH prediction across all 10,000 samples remained below the clinical threshold of 0.01 g/100 L at all five operating points, supporting the accepted decision."
  },
