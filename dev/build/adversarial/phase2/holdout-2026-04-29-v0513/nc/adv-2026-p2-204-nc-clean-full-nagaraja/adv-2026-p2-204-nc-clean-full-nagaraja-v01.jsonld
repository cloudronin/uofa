  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/depur-synthes-fda-ansys-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw compression-bending is accepted as sufficiently credible for the COU at MRL 3. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both the <10% percent difference criterion and the E/uval < 1.96 validation metric, with maximum values of 1.32% and 0.44 respectively — well within acceptance bounds. Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — is addressed by the offset rationale below. The global sensitivity analysis confirms that the dominant uncertainty sources (Ti-6Al-4V modulus and contact friction) are well-characterized and their contributions are bounded within the validation uncertainty budget. The interlaboratory reproducibility study (CV < 5% across two independent laboratories) provides additional confidence in the experimental reference data. The provenance chain is complete from raw experimental load-displacement records through data reduction to QoI values, and from CAD geometry through FEA setup to predicted QoIs. The decision is consistent with FDA guidance on computational modeling evidence for Class II orthopedic implants.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/cou1-offset-test-conditions",
        "type": "OffsetRationale",
        "name": "Offset rationale: Test conditions shortfall (Gradation 2 vs. required Gradation 3)",
        "description": "The Test conditions factor achieved Gradation 2 (single loading configuration, compression-bending only) against a required Gradation 3 (multiple loading configurations). This shortfall is accepted for the following reasons: (1) ASTM F1717 compression-bending is the primary and most clinically relevant loading mode for pedicle screw construct failure, and the regulatory submission decision is specifically scoped to compression-bending performance prediction; (2) lateral bending and torsion QoIs are not claimed by this model and are not part of the COU decision; (3) the compression-bending validation was conducted across two independent laboratories with excellent interlaboratory reproducibility (CV < 5%), providing higher confidence in the single-condition results than a single-laboratory multi-condition study would provide; (4) the sensitivity analysis confirms that model parameters governing compression-bending response (axial stiffness, contact friction) are the same parameters that would govern lateral bending, reducing the marginal information value of additional loading conditions for this specific model form; (5) the achieved E/uval values (maximum 0.44) are substantially below the 1.96 threshold, indicating a large margin of validation adequacy that partially compensates for the reduced condition breadth. The credibility team judges that the combined weight of the interlaboratory reproducibility, the large validation margin, and the COU scope restriction to compression-bending is sufficient to accept the model despite the Test conditions shortfall.",
        "shortfallFactor": "Test conditions",
        "shortfallGradation": 2,
        "requiredGradation": 3
      },
