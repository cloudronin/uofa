  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated 7.5 mm pedicle screw under ASTM F1717 static loading",
      "description": "Model applicability is restricted to non-cannulated pedicle screws with nominal outer diameter 7.5 mm ± 0.1 mm, polyaxial head design, used with titanium alloy (Ti-6Al-4V) rods of diameter 5.5 mm, tested under quasi-static ASTM F1717 compression-bending loading at room temperature (20–25 °C) in air. The model is not applicable to cannulated variants, dynamic fatigue loading, or constructs with cortical bone anchors. Bone analog material is UHMWPE per ASTM F1717 specification."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: ASTM F1717 static compression-bending bounds",
      "description": "Applied compressive load: 0–2500 N; bending moment arm: 60 mm fixed per ASTM F1717 fixture; crosshead displacement rate: 5 mm/min ± 0.5 mm/min; screw insertion torque: 6.0–8.0 N·m; rod pre-load torque: 4.0–5.0 N·m; ambient temperature: 20–25 °C; relative humidity: 30–70% RH. Screw outer diameter: 7.40–7.60 mm; screw length: 40–45 mm; rod diameter: 5.50 ± 0.05 mm. FEA mesh element size at critical notch root: 0.10–0.25 mm."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/nagaraja/sensitivity/cou1-noncannulated-sa-001",
    "type": "SensitivityAnalysis",
    "name": "Global sensitivity analysis: material properties and contact friction on QoI",
    "description": "A variance-based (Sobol') global sensitivity analysis was conducted over five uncertain model inputs — Ti-6Al-4V Young's modulus (±5%), yield strength (±8%), UHMWPE compressive modulus (±15%), screw-rod contact friction coefficient (0.15–0.35), and rod pre-load torque (4.0–5.0 N·m) — using a 512-sample quasi-random LHS design evaluated across the full FEA ensemble. First-order Sobol' indices for construct stiffness were dominated by Ti-6Al-4V Young's modulus (S1 = 0.54) and contact friction (S1 = 0.28); yield force was most sensitive to Ti-6Al-4V yield strength (S1 = 0.61). Total-order indices confirmed no significant higher-order interaction terms (all T-S1 < 0.08), justifying the assumption of additive uncertainty propagation used in the validation uncertainty budget."
  },
