  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/cou1/decision-record",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for non-cannulated pedicle screw compression-bending under ASTM F1717 is accepted as sufficiently credible for the intended regulatory use. Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. All three primary QoIs satisfy the pre-specified acceptance bounds (E/uval < 1.96, relative difference < 10%), with actual performance substantially better than required (maximum E/uval = 0.69, maximum relative difference = 2.4%). The sensitivity analysis confirms that model predictions are robust to realistic material property uncertainty. The single shortfall — Test conditions assessed at Gradation 2 against a Gradation 3 requirement — is addressed by the offset rationale below, which documents that the sensitivity analysis and the coincidence of the validation domain with the COU together provide sufficient confidence that the single-condition validation is adequate for this application.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/cou1/offset-rationale/test-conditions",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/cou1/factor/test-conditions",
      "justification": "The Test conditions factor achieved Gradation 2 (single test condition) against a Gradation 3 requirement (multiple conditions). This shortfall is accepted for the following reasons: (1) ASTM F1717 is a standardized test protocol specifying a single nominal test condition, and regulatory precedent does not require multi-condition validation for this device class; (2) the sensitivity analysis demonstrates that QoI predictions vary by less than 8.2% across the full range of realistic material and geometric input uncertainty, substantially less than the 10% acceptance bound, providing indirect evidence of robustness to condition variation; (3) the validation domain is coincident with the COU — no extrapolation to untested conditions is required for the regulatory decision; and (4) the three QoIs all satisfy acceptance bounds with substantial margin (maximum E/uval = 0.69), providing additional confidence that the model is not operating near a credibility boundary. The residual risk from the single-condition validation is therefore judged acceptable for a Medium model risk, Medium decision consequence application."
    }
  },
