    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated pedicle screw applicability domain",
      "description": "Assessment applies exclusively to non-cannulated pedicle screws with nominal outer diameter 7.5 mm and thread pitch 2.75 mm, tested in UHMWPE test blocks per ASTM F1717. Results are not transferable to cannulated variants, screws with outer diameter outside the range 6.5–8.5 mm, or loading modes other than static compression-bending. Implant material is Ti-6Al-4V ELI per ASTM F136."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "ASTM F1717 static compression-bending operating envelope",
      "description": "Valid operating range: axial compressive load 0–2500 N applied at 5° offset per F1717 fixture geometry; crosshead displacement rate 5 mm/min ± 0.5 mm/min; ambient temperature 23 ± 2 °C; relative humidity 50 ± 10%; UHMWPE block density 0.930–0.945 g/cm³; screw insertion torque 8.0 ± 0.5 N·m. FEA mesh element size 0.4–0.6 mm in peri-implant zone; titanium alloy elastic modulus 114 ± 3 GPa; yield strength 880 ± 20 MPa."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/nagaraja/sensitivity/noncannulated-sa-01",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time sensitivity analysis for non-cannulated FEA model",
    "description": "A one-at-a-time sensitivity study varied six model input parameters — titanium elastic modulus (±5%), UHMWPE block modulus (±15%), screw-block interface friction coefficient (0.1–0.4), mesh element size (0.3–0.8 mm), applied load angle (4°–6°), and crosshead displacement rate — across their plausible ranges. Construct stiffness QoI showed less than 3.2% variation across all perturbations; yield force QoI showed a maximum sensitivity of 6.8% to UHMWPE block modulus, which was subsequently constrained by direct material coupon testing, reducing this contribution to below the 10% acceptance threshold."
  },
