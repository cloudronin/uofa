  "sensitivityAnalysisDetail": {
    "id": "https://uofa.net/nagaraja/cou1/sensitivity-analysis",
    "type": "SensitivityAnalysis",
    "name": "COU1 Parametric Sensitivity Analysis — Material and Geometric Inputs",
    "description": "A one-at-a-time and Morris screening sensitivity analysis was performed varying cortical bone modulus (±20%), titanium alloy yield strength (±10%), screw-rod interface friction coefficient (0.1–0.4), and UHMWPE block density (±15%). Construct stiffness QoI showed greatest sensitivity to cortical bone modulus (normalized sensitivity index 0.61) and screw-rod friction (0.38); yield force was most sensitive to titanium yield strength (0.74). All sensitivity indices were within the uncertainty budget assumed during model validation, confirming that the dominant input uncertainties are bounded by the experimental scatter in the N=11 test series."
  },
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Non-cannulated pedicle screw applicability domain",
      "description": "The model is applicable to non-cannulated titanium-alloy pedicle screws with outer diameter 7.0–8.0 mm, thread pitch 2.75–3.25 mm, and shaft length 40–55 mm, tested in UHMWPE blocks per ASTM F1717. The model is NOT applicable to cannulated variants, fenestrated screws, or constructs with rod diameters outside 5.5–6.0 mm. Patient-specific bone properties or osteoporotic bone scenarios require additional validation."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "F1717 static compression-bending operating envelope",
      "description": "Operating conditions bounded by: axial compressive load 0–3500 N; bending moment 0–25 N·m; crosshead displacement rate 5 mm/min (quasi-static); ambient temperature 22±3°C; UHMWPE block density 0.93–0.96 g/cm³; screw insertion torque 4.0–6.0 N·m. FEA mesh element size 0.3–0.8 mm in screw thread root region; contact pair friction coefficient 0.2±0.1. Results are valid only within these parametric bounds."
    }
  },
