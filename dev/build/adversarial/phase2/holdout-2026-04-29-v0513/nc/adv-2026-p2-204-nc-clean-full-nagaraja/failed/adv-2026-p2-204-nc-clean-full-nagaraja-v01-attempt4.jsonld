  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "rationale": "All three FEA codes (FDA in-house, Ansys Mechanical 2022 R2, DePuy Synthes custom solver) operate under documented software quality management systems. FDA code is under 21 CFR Part 11 configuration control with version-locked executables. Ansys Mechanical holds ISO 9001:2015 certification with published verification manuals. DePuy Synthes solver is governed by a validated software development lifecycle per IEC 62304. Unit test suites, regression test libraries, and release notes are archived for all three codes.",
      "acceptanceCriteria": {
