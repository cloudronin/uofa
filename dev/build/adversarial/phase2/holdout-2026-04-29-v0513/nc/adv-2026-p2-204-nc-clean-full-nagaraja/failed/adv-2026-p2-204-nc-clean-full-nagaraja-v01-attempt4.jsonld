    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "Applicability constraint: non-cannulated 7.5 mm pedicle screw, ASTM F1717 static loading only",
      "description": "This COU applies exclusively to non-cannulated titanium-alloy pedicle screws with nominal outer diameter 7.5 mm and thread pitch 2.75 mm, tested under ASTM F1717 static compression-bending protocol. The model is not applicable to cannulated variants, dynamic fatigue loading, or screws with outer diameter outside the range 7.0–8.0 mm. Clinical in-vivo loading scenarios are explicitly excluded from this validation scope."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "Operating envelope: F1717 compression-bending test conditions",
      "description": "Valid operating range: axial compressive load 0–2500 N applied at 10 mm/min crosshead displacement rate; moment arm 60 ± 1 mm per ASTM F1717; ambient temperature 20–25 °C; Ti-6Al-4V rod diameter 5.5 mm; screw insertion torque 4–6 N·m. Polyaxial screw angulation constrained to 0° (straight) for this validation activity. Bone surrogate: UHMWPE blocks per F1717 Annex A1 with density 950 ± 10 kg/m³."
    }
  },
