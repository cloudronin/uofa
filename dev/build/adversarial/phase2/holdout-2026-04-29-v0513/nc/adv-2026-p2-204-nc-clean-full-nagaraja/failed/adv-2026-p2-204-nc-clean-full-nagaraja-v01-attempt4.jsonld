    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "rationale": "The validation activities replicate the COU geometry, loading protocol, and material system with high fidelity: the same non-cannulated 7.5 mm screw design, the same ASTM F1717 test fixture geometry, the same Ti-6Al-4V rod, and the same UHMWPE bone surrogate specified in the COU operating envelope. The only deviation from the COU is that in-vivo bone is replaced by UHMWPE per the standard; this deviation is explicitly documented and its impact on QoI predictions assessed as negligible for the structural performance endpoints of interest.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/nagaraja/ac/validation-relevance",
        "type": "AcceptanceCriteria",
        "name": "Validation activity relevance acceptance criterion",
        "description": "Validation activities must use the same device design, loading protocol, and material system as the COU. Any deviations from the COU must be documented and their impact on QoI predictions assessed quantitatively or with justified qualitative argument."
