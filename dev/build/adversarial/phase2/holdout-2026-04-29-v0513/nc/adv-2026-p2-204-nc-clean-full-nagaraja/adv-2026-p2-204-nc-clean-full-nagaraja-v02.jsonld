  "sensitivityAnalysisRecord": {
    "id": "https://uofa.net/nagaraja/sensitivity/sa-001",
    "type": "SensitivityAnalysis",
    "name": "Material property and boundary condition sensitivity analysis for non-cannulated pedicle screw FEA",
    "description": "Titanium alloy elastic modulus (±10%), cortical bone modulus (±20%), and screw-rod interface friction coefficient (0.15–0.45) were varied independently using a one-at-a-time design; construct stiffness QoI varied by at most 6.8% across the full parameter range, confirming that the dominant uncertainty source is rod diameter tolerance rather than material property scatter. A secondary Latin hypercube sweep (n=200) over all six uncertain inputs confirmed that 95th-percentile output uncertainty remains within the 10% acceptance threshold."
  },
  "hasContextOfUse": {
