  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for non-cannulated 7.5 mm pedicle screw ASTM F1717 compression-bending is accepted for its intended use. All 13 V&V 40 factors were assessed. Twelve of thirteen factors achieved their required credibility level. One factor (Test conditions) achieved level 2 against a required level of 3 due to single-condition testing per ASTM F1717 protocol. This shortfall is accepted per the offset rationale below: the ASTM F1717 protocol mandates a single standardized test condition, rate sensitivity is documented as negligible for quasi-static metallic implant testing in the literature (Nagaraja et al. 2017), and the three QoIs all pass the E/uval < 1.96 threshold with margin. The sensitivity analysis confirms that load rate and temperature are not dominant uncertainty sources. The overall evidence base — N=11 constructs, two independent laboratories, quantitative E/uval comparison, full provenance chain, and documented uncertainty quantification — provides sufficient credibility for the Medium model risk and Medium decision consequence of this COU.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": [
      {
        "id": "https://uofa.net/nagaraja/decision/offset-tc-001",
        "type": "OffsetRationale",
        "name": "Offset rationale for Test conditions shortfall",
        "refersToFactor": "Test conditions",
        "justification": "The Test conditions factor achieved level 2 against a required level of 3 because ASTM F1717 specifies a single standardized quasi-static load rate (5 mm/min) and ambient temperature, and no multi-condition testing is required or customary for this protocol. Published literature (Nagaraja et al. 2017, J Biomech Eng) demonstrates that construct stiffness and yield force for Ti-6Al-4V pedicle screw constructs are insensitive to load rate variation in the quasi-static regime (< 5% change across 1–50 mm/min). The sensitivity analysis conducted for this package confirms that load rate and temperature are not dominant contributors to output uncertainty. The three primary QoIs all pass E/uval < 1.96 with margin (maximum 1.68), providing direct quantitative evidence that the single-condition limitation does not compromise predictive credibility for the COU. The offset is therefore justified and the package is accepted at Medium assurance level for MRL 3."
      },
      {
        "id": "https://uofa.net/nagaraja/decision/dr-001/offset/test-conditions",
        "type": "OffsetRationale",
        "refersToFactor": "https://uofa.net/nagaraja/decision/dr-001/factor/test-conditions",
        "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
      }
    ]
  },
