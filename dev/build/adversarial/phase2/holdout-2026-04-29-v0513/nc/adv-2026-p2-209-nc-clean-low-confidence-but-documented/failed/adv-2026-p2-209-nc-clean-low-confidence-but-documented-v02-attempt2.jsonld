  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels for MRL 2. The 6 scoped-out factors are appropriately excluded per ASME V&V 40-2018 Table 1 guidance for a Class II device at MRL 2 with medium model influence. The primary uncertainty gap — wide bounds on blood viscosity (±15%) and Carreau-Yasuda power-law index (n = 0.70–0.82) — is explicitly documented in the Model Inputs factor, quantified via Monte Carlo propagation, and characterised in the sensitivity analysis. The 95% CI upper bound on RHI (0.59) remains well below the regulatory acceptance criterion of RHI < 1.0, providing a margin of 0.41. The offset rationale (https://uofa.net/synth/offset/model-inputs-viscosity-gap) formally justifies acceptance despite this documented gap. Provenance is complete: all ValidationResults link to experimental datasets, generating activities, and uncertainty quantification records. The decision is supported by structured, traceable evidence.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/offset/model-inputs-viscosity-gap",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/factor/model-inputs",
      "justification": "The Model Inputs factor achievedLevel equals requiredLevel (both 2); however, the explicitly-flagged wide uncertainty on blood viscosity (±15%) and power-law index (n range 0.70–0.82) represents a residual gap below ideal characterisation. Monte Carlo propagation demonstrates that even at the 97.5th percentile of the input distribution, the predicted RHI (0.59) remains below the RHI < 1.0 acceptance criterion with a margin of 0.41. The sensitivity analysis confirms viscosity is the dominant driver but that its effect saturates below the threshold. No additional testing is required to support acceptance at MRL 2 for this Class II device; the gap is accepted as residual uncertainty consistent with the medium model-influence designation.",
      "name": "Offset rationale: blood viscosity input uncertainty gap"
    }
  },
