  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) Seven credibility factors were formally assessed; all achieved levels meet or exceed required levels for MRL 2. (2) Six factors were scoped out with documented justification appropriate for MRL 2. (3) The single explicitly-flagged uncertainty gap — blood viscosity characterization from a limited donor cohort (n=12, ±18% uncertainty) — is honestly documented with Sobol sensitivity analysis confirming it as the dominant uncertainty source (S1=0.68). Despite wide UQ bounds (±0.22 on RH index), all five operating-point predictions remain below the RH < 1 acceptance threshold even at the 97.5th percentile of the viscosity distribution, providing a positive margin of approximately 0.15 RH units at worst case. (4) Code verification (MMS, order 1.94), mesh convergence (GCI_fine 3.2%), bench validation (MAE 8.3%, correct rank ordering), and test condition equivalency collectively establish a complete and traceable provenance chain from foundational evidence to the regulatory decision. (5) The decision consequence is High and model influence is Medium, consistent with MRL 2 requirements. The viscosity uncertainty gap is accepted as documented residual risk with positive threshold margin; no compensating offset is required as achievedLevel equals requiredLevel for all assessed factors.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
