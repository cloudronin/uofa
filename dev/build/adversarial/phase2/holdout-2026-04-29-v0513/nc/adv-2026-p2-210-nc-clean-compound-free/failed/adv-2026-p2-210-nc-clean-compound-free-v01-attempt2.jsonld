  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation 2 levels for MRL 2. Discretization error achieved Gradation 3, providing additional confidence margin. The six scoped-out factors are appropriately excluded at MRL 2 with documented justification for each. Validation metric |E/U_val| < 1 at all five operating points confirms the CFD model can reliably identify worst-case hemolysis conditions. The relative hemolysis index RH < 1 at the worst-case predicted operating point satisfies the regulatory acceptance criterion. Uncertainty quantification via Latin hypercube sampling confirms that the acceptance conclusion is robust across the input parameter space. The provenance chain from raw experimental data through validation activities to this assurance package is complete and traceable. The credibility assessment team unanimously accepts this package as sufficient evidence to support the regulatory submission for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
