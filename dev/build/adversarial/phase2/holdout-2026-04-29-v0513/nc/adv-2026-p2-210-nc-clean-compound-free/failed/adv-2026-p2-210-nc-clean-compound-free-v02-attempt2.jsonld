  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/applicability-constraint",
      "type": "ApplicabilityConstraint",
      "name": "CPB centrifugal pump hemolysis applicability scope",
      "description": "Model applicability is restricted to Class II centrifugal blood pumps operating in the CPB flow regime (2–8 L/min, 1500–3500 RPM). The hemolysis power-law constitutive model is valid only for Newtonian blood analogues at 37 °C ± 1 °C. Extrapolation to axial-flow pumps or paediatric flow rates below 0.5 L/min is explicitly excluded."
    },
    "hasOperatingEnvelope": {
      "id": "https://uofa.net/morrison/cou/cou1-cpb/operating-envelope",
      "type": "OperatingEnvelope",
      "name": "CPB operating envelope — flow, speed, and geometry bounds",
      "description": "Flow rate: 2.0–8.0 L/min. Rotational speed: 1500–3500 RPM. Impeller tip clearance: 0.15–0.35 mm. Inlet cannula inner diameter: 9–14 mm. Blood analogue viscosity: 3.2–4.0 mPa·s at 37 °C. Operating pressure head: 100–400 mmHg. All five nominal operating points (2 L/min / 2000 RPM, 3 L/min / 2500 RPM, 4 L/min / 3000 RPM, 5 L/min / 3200 RPM, 6 L/min / 3500 RPM) fall within this envelope."
    }
  },
  "hasSensitivityAnalysis": {
    "id": "https://uofa.net/synth/sensitivity/cpb-hemolysis-sa-001",
    "type": "SensitivityAnalysis",
    "name": "One-at-a-time and Morris screening sensitivity analysis for CPB hemolysis QoI",
    "description": "A Morris elementary-effects screening was conducted across seven input parameters (impeller tip clearance ±0.10 mm, rotational speed ±200 RPM, inlet flow rate ±0.5 L/min, blood viscosity ±0.4 mPa·s, power-law exponent α ±0.05, mesh density ±30%, and turbulence model switch k-ω SST vs. RNG k-ε). The relative hemolysis index RH showed greatest sensitivity to tip clearance (μ* = 0.31) and rotational speed (μ* = 0.27), with flow rate third (μ* = 0.19). Turbulence model choice contributed a ±6% spread in RH, which was absorbed into the uncertainty budget for the validation comparison."
  },
