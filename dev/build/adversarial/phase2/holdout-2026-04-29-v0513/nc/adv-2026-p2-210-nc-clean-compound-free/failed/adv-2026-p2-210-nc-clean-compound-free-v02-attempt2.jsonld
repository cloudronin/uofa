  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the FDA generic centrifugal pump CFD hemolysis model is accepted at Model Risk Level 2 for the CPB COU. All seven assessed credibility factors meet or exceed their required levels: software quality assurance (2/2), numerical code verification (2/2), discretisation error (achieved 3, required 2), test conditions (2/2), output comparison (2/2), relevance of QoIs (2/2), and relevance of validation activities (2/2). Six factors are appropriately scoped out at MRL 2 with documented rationales. The validation dataset covers all five COU operating points with mean NIH error of 2.1% and maximum error of 8.7%, both within the ±15% acceptance criterion. The sensitivity analysis confirms that the dominant uncertainty contributors (tip clearance and rotational speed) are bounded within the operating envelope. The combined validation uncertainty (4.1% at 95% CI) is commensurate with the medium model influence and high decision consequence context. No shortfalls exist between required and achieved credibility levels; no offset rationale is required. The model is accepted as fit for purpose for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
