  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) operates under a documented software quality plan including version control, regression test suite (450+ test cases), and configuration management log. All solver modules used in this analysis are covered by the SQA plan. Achieved Gradation 2 consistent with MRL 2 requirements.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/sqa-ac-01",
        "type": "AcceptanceCriteria",
        "description": "Solver must be under documented version control with a regression test suite covering the turbulence and scalar transport modules used in hemolysis prediction. All test cases must pass prior to production runs."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Order-of-accuracy verification performed using the method of manufactured solutions (MMS) for the incompressible Navier-Stokes solver and the scalar hemolysis transport equation. Observed order of accuracy (1.93 for velocity, 1.88 for scalar) is consistent with the nominal second-order spatial discretisation scheme. No anomalous convergence behaviour detected.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/ncv-ac-01",
        "type": "AcceptanceCriteria",
        "description": "Observed order of accuracy from MMS study must be within 10% of nominal scheme order (2.0) for both momentum and scalar transport equations across at least three systematically refined grids."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Richardson extrapolation-based Grid Convergence Index (GCI) study conducted on three systematically refined meshes (4.2M, 12.1M, 31.8M cells). GCI for NIH at the worst-case operating point is 3.7%, well within the 10% threshold for MRL 2. Fine-grid solution adopted for production runs.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/disc-ac-01",
        "type": "AcceptanceCriteria",
        "description": "GCI for the primary quantity of interest (normalised index of hemolysis) must be less than 10% on the production mesh. Asymptotic range of convergence must be confirmed (GCI ratio within 5% of unity)."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "In-vitro hemolysis loop experiments conducted at 5 flow-speed combinations spanning the CPB operating envelope (2–6 L/min, 2000–3500 RPM). Blood analogue fluid (glycerol-water, matched viscosity) used. Temperature controlled to 37±0.5°C. All test conditions documented in the validation test plan and traceable to calibrated instrumentation records.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/tc-ac-01",
        "type": "AcceptanceCriteria",
        "description": "Experimental test conditions must span the full intended operating envelope. Temperature, fluid viscosity, and rotational speed must be controlled and recorded with calibrated instruments traceable to national standards."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Quantitative comparison performed using the validation metric of Oberkampf and Baehm. Agreement metric E_val computed for NIH at all 5 operating points; all values fall within experimental uncertainty bounds at the 95% confidence level. Relative hemolysis index RH < 1 confirmed for the worst-case condition, satisfying the acceptance criterion.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/oc-ac-01",
        "type": "AcceptanceCriteria",
        "description": "Validation metric E_val for NIH must fall within experimental uncertainty bounds (95% CI) at all 5 operating points. Relative hemolysis index RH must be less than 1.0 at the worst-case operating condition identified by the model."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The primary QoI (NIH and relative hemolysis index RH) are directly linked to the regulatory acceptance criterion for CPB devices (FDA guidance on blood-contacting devices). Secondary QoIs (wall shear stress distribution, velocity profiles) are mechanistically connected to hemolysis via the power-law damage model. All QoIs are documented in the V&V plan with explicit traceability to the COU decision question.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/rqi-ac-01",
        "type": "AcceptanceCriteria",
        "description": "Each QoI must be explicitly linked to the regulatory decision criterion in the V&V plan. At least one QoI must be directly comparable to a regulatory threshold or predicate device benchmark."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump geometry under CPB-representative conditions. The validation domain (flow rates 2–6 L/min, speeds 2000–3500 RPM, blood analogue fluid) overlaps with the intended COU operating envelope. Geometric fidelity of the validation model to the production device is documented with a similarity assessment confirming key non-dimensional parameters (Reynolds number, tip speed ratio) are matched.",
      "acceptanceCriteria": {
        "id": "https://uofa.net/synth/ac/rva-ac-01",
        "type": "AcceptanceCriteria",
        "description": "Validation geometry and operating conditions must overlap with the COU envelope. A documented similarity assessment must confirm that key non-dimensional parameters are matched between the validation configuration and the intended use configuration."
      }
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "At MRL 2, numerical solver error beyond GCI-based discretisation error is scoped out per the ASME V&V 40 MRL 2 factor matrix. The solver has been verified via MMS (see Numerical code verification factor) and the discretisation error is bounded. Iterative convergence is monitored to residuals below 1e-6 for all equations, providing sufficient assurance without a separate solver error assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Use error assessment is scoped out at MRL 2 for this analysis. The simulation team follows a documented simulation protocol with mandatory peer review of all setup files, boundary condition specifications, and post-processing scripts. Independent verification of key inputs was performed by a second analyst, providing adequate safeguard against use errors without a formal use error factor assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Model form uncertainty assessment is scoped out at MRL 2. The k-omega SST turbulence model was selected based on published literature for rotating machinery hemolysis simulations. The power-law hemolysis damage model (Giersiepen et al. constants updated by Heuser & Opitz) is the standard for CPB device assessment. Model form justification is documented in the modelling assumptions report; a formal model form factor assessment is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Model inputs factor is scoped out at MRL 2. All boundary conditions (inlet flow rate, outlet pressure, rotational speed, fluid properties) are derived from calibrated experimental measurements with documented uncertainty. Input uncertainty is propagated through the UQ study reported in the ValidationResult objects. A separate model inputs credibility factor assessment is not required at MRL 2 given the documented input provenance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Test samples factor is scoped out at MRL 2. Blood analogue fluid (glycerol-water mixture) is used in lieu of human blood, which is standard practice for CPB device bench testing. The analogue fluid properties (viscosity, density) are matched to physiological blood at 37°C and documented with certificates of analysis. A formal test samples credibility factor assessment is not required at MRL 2 for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters is scoped out at MRL 2. The validation configuration uses the same CAD geometry and nominal operating conditions as the intended use configuration. Dimensional tolerances of the test article are documented and confirmed within ±0.05 mm of nominal. No significant parametric differences exist between the validation and COU configurations that would require a formal equivalency assessment at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required Gradation 2 level for MRL 2. Software quality assurance is confirmed through a documented SQA plan with regression testing. Numerical code verification via MMS demonstrates second-order accuracy for both momentum and scalar transport. Discretisation error is bounded at GCI = 3.7% for the primary QoI. Test conditions span the full CPB operating envelope with calibrated instrumentation. Output comparison confirms NIH predictions within experimental uncertainty at all 5 operating points, with RH < 1 at the worst-case condition satisfying the regulatory acceptance criterion. Relevance of QoIs and validation activities to the COU is established through documented similarity assessment and explicit traceability to the FDA regulatory decision criterion. Six factors are scoped out with documented rationale appropriate to MRL 2. No credibility gaps requiring offset rationale have been identified. The structured evidence chain from foundational experimental data through validated model outputs to the regulatory decision is complete and traceable. The credibility assessment team accepts the CFD model as fit for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
