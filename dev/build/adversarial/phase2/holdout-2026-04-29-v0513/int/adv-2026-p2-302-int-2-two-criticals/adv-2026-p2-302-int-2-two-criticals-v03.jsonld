  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA procedures and regression test suite covering pump flow configurations.",
      "rationale": "ANSYS Fluent 2022R2 used under an ISO 9001-certified QA framework. Regression tests for rotating machinery cases pass at each release. Version control and audit trail maintained throughout the study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against analytical solutions or established verification cases for rotating flow and scalar transport.",
      "rationale": "Code verification performed using Taylor-Couette flow and lid-driven cavity benchmarks. Observed order of accuracy consistent with second-order spatial discretization. No anomalous convergence behavior detected."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across all five operating points.",
      "rationale": "Three-mesh Richardson extrapolation performed at 2.1 M, 5.4 M, and 12.8 M cell counts. GCI values ranged from 4.8% to 7.3% across the five operating points, with two high-speed conditions exceeding the 5% threshold. The assessment team concluded that the spatial resolution was adequate for trend identification; however, the achieved discretization error level corresponds to Gradation 1 rather than the required Gradation 2, representing a one-step shortfall. No additional refinement study was completed prior to submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) replicated within ±5% of nominal CFD inputs.",
      "rationale": "Bench test conditions documented in FDA pump dataset reproduced in CFD boundary conditions. Fluid viscosity and density matched to blood analog within 3.1%. Inlet velocity profiles derived from ultrasonic flow measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 20% of experimental measurements at all five operating points; pressure-flow characteristic within 10%.",
      "rationale": "Relative hemolysis index predictions fell within 14–18% of experimental values across all operating points. Pressure-flow curve matched experimental data within 8%. Systematic under-prediction at high shear conditions noted and attributed to turbulence model limitations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to clinical hemolysis endpoint and regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index RH is the primary regulatory QoI for CPB device submissions. The model directly predicts RH via the power-law hemolysis model integrated over Lagrangian particle trajectories. Direct correspondence to clinical endpoint established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
