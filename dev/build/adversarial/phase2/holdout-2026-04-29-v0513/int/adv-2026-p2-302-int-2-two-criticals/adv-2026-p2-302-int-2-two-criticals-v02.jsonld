  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-dr-302",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment is judged sufficient for regulatory submission at MRL 2. Twelve of thirteen factors meet or exceed required gradation levels. The discretization error factor achieved Gradation 1 against a required Gradation 2; however, the assessment team judged the 6.1% fine-grid GCI to be within engineering tolerance for a comparative hemolysis study where relative ranking of operating conditions — not absolute hemolysis magnitude — is the primary decision driver. The RH < 1 acceptance criterion provides an additional margin. On balance, the model is considered fit for the intended COU.",
