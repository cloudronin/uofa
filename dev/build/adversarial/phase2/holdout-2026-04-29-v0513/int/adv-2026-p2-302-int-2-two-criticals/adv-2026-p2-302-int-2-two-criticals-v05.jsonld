  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled CFD solver with documented release notes and regression test suite.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional license with version control; regression tests documented in solver release notes. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one canonical benchmark with documented convergence behavior.",
      "rationale": "Solver verified against lid-driven cavity and backward-facing step benchmarks. Second-order spatial convergence confirmed. Exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI across at least three mesh refinement levels.",
      "rationale": "Mesh sensitivity study conducted across two refinement levels (coarse: 2.1M cells, medium: 4.8M cells). GCI estimated at 8.3% for the peak shear stress region near the impeller tip. A third refinement level was deemed computationally prohibitive within project schedule; the team concluded the medium mesh was adequate based on engineering judgment and prior literature precedent for similar pump geometries. Achieved level assessed as Gradation 1 — one step below the required Gradation 2 — because the formal three-mesh Richardson extrapolation was not completed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match CFD inlet/outlet conditions within 5% for flow rate and rotational speed.",
      "rationale": "FDA pump bench tests conducted at 5 flow-speed combinations (2.5–6 L/min, 2000–3500 RPM). CFD boundary conditions set from measured values; deviations < 2% for flow rate, < 1% for speed. Test conditions fully representative of COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index within 20% of experimental measurements across all 5 operating points.",
      "rationale": "Predicted RH values compared against FDA experimental hemolysis data. Mean absolute error 11.4% across 5 operating points; worst-case deviation 18.7% at 6 L/min / 3500 RPM. Acceptance criterion satisfied. Uncertainty quantification applied to experimental measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, peak shear stress, exposure time) directly map to clinical hemolysis endpoints.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) converted to relative hemolysis index RH. Secondary QoIs include volume-averaged scalar shear stress and Lagrangian exposure time. All QoIs are established in FDA guidance for blood-contacting device CFD assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use same pump geometry, blood analog fluid, and operating range as COU.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry identical to COU device. Porcine blood analog (glycerol-saline) used in experiments; CFD uses Carreau-Yasuda viscosity model fitted to same fluid. Operating conditions span full COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residuals converge to < 1e-5 for all transport equations; mass imbalance < 0.01%.",
      "rationale": "All simulations converged to residuals < 1e-6 for continuity and momentum. Mass imbalance < 0.005%. Steady-state MRF approach used for impeller rotation; frozen rotor interface validated against full transient sliding mesh at design point."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; qualitative review of analyst credentials sufficient.",
      "rationale": "At MRL 2, formal use error assessment is not required. Lead analyst holds PhD in computational fluid dynamics with 8 years experience in cardiovascular device simulation. Peer review of simulation setup conducted by independent team member."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; selection of turbulence and hemolysis model documented with literature justification.",
      "rationale": "SST k-omega turbulence model selected based on published performance for rotating machinery. Giersiepen-Wurzinger power-law hemolysis model used; literature basis documented. Formal model form uncertainty quantification deferred per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values documented with sources.",
      "rationale": "Fluid properties, geometric dimensions, and boundary conditions documented in simulation plan. Sources include manufacturer specifications and experimental measurement reports. Parametric sensitivity to viscosity model constants not formally quantified at this MRL."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; experimental sample provenance documented.",
      "rationale": "FDA experimental dataset used for validation; sample preparation and storage protocols documented in original FDA report. Variability across replicate runs reported as CV < 8% for NIH measurements. Formal statistical sample size justification deferred per MRL 2 scoping."
    },
    {
