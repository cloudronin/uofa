  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-int2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Six factors were scoped out as not required at MRL 2. Of the seven assessed factors, six meet or exceed their required levels. The discretization error factor achieved Gradation 1 against a required Gradation 2; however, the team determined that the two-mesh sensitivity study combined with the 8.3% GCI estimate and favorable output comparison results (mean error 11.4%) provides sufficient engineering confidence for the intended comparative use of identifying worst-case operating conditions. The decision consequence is High, but model influence is Medium and results are used in a relative rather than absolute sense against a predicate device. The assessment team accepts the model for the stated COU with the noted limitation on mesh convergence documentation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
