      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is version-controlled and validated per institutional SQA plan; unit tests cover solver modules relevant to hemolysis prediction.",
      "rationale": "ANSYS Fluent 2022R2 deployed under institutional SQA framework. Version control, regression testing, and change-control records confirmed. Meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark problems for rotating-frame Navier-Stokes; manufactured solution test confirms second-order spatial accuracy.",
      "rationale": "Code verification completed using Taylor-Couette and lid-driven cavity benchmarks. Observed order of accuracy 1.97 consistent with nominal second-order scheme. Requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine grid; Richardson extrapolation applied across at least three systematically refined meshes.",
      "rationale": "Mesh refinement study conducted across three grids (1.8M, 5.4M, 16.2M cells; refinement ratio 1.44). GCI on the medium-to-fine transition is 7.2% for the scalar hemolysis index, exceeding the 5% acceptance threshold. The fine-grid GCI of 6.8% likewise does not meet criterion. Discretization error is therefore one gradation below the required level for MRL 2. The shortfall is attributed to unresolved shear-layer gradients near the impeller tip gap; a corrective re-mesh is planned but results were not available prior to submission deadline."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, rotational speed) reproduced in simulation within ±2% of measured values across all five operating points.",
      "rationale": "All five flow-speed operating points replicated from FDA benchmark protocol. Inlet flow rates matched to within 1.1%, rotational speeds within 0.8%, outlet back-pressure within 1.6%. Requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index RH within ±15% of experimental mean across all five operating points; systematic bias less than 10%.",
      "rationale": "RH predictions range from 0.83 to 1.04 versus experimental 0.79 to 1.01. Maximum point-wise deviation 13.2%; mean bias 4.7%. Both within acceptance thresholds. Requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress distribution) are directly mapped to the clinical decision criterion (RH < 1) specified in the COU.",
      "rationale": "Primary QoI is the scalar relative hemolysis index derived from Giersiepen power-law model integrated along Lagrangian particle tracks. This QoI is the direct input to the RH < 1 acceptance criterion stated in the COU. Relevance confirmed."
    },
    {
