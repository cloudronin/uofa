      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, backward-facing step) to within published reference tolerances.",
      "rationale": "ANSYS Fluent verified against NASA turbulence model validation cases. Benchmark residuals meet published reference values; code verification complete for incompressible turbulent flow regime applicable to CPB pump."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
