    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Relative hemolysis index prediction error < 15% across all validation operating points.",
      "rationale": "Mean absolute error in RH index 8.3% across 5 operating points. Maximum single-point error 13.7% at lowest flow condition. All predictions within acceptance threshold. Systematic underprediction at low flow attributed to secondary recirculation; documented as model limitation within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical hemolysis endpoints; RH index accepted by FDA as surrogate for in-vivo hemolysis risk.",
      "rationale": "Relative hemolysis index (RH) is the primary QoI, directly linked to plasma free hemoglobin elevation in clinical use. Secondary QoIs (wall shear stress, exposure time) are mechanistic inputs to the hemolysis sub-model. All QoIs are clinically and regulatorily relevant per FDA guidance on blood-contacting devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
