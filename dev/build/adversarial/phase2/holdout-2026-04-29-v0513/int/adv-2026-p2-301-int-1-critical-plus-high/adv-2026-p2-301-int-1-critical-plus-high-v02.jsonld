      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-cpb-pressure-rise-uq",
        "type": "UncertaintyQuantification",
        "method": "Sensitivity analysis on turbulence model constants; Richardson extrapolation for spatial discretization error; combined standard uncertainty ±3.8% on head coefficient.",
        "coverageProbability": 0.95
