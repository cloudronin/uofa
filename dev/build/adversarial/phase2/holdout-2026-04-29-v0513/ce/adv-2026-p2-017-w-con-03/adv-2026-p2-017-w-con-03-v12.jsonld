      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined experimental and numerical uncertainty bands.",
      "rationale": "CFD predictions of the normalized index of hemolysis (NIH) agree with FDA benchmark measurements within combined uncertainty for 4 of 5 operating points; the fifth point falls within 1.4 standard deviations of the experimental mean, consistent with acceptable model performance at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
