  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-comparison-primary",
      "type": "ValidationResult",
      "name": "Primary RH index CFD-to-experiment comparison across 5 operating points",
      "comparedAgainst": "https://uofa.net/morrison/data/hemolysis-experimental-rh-measurements",
      "description": "CFD-predicted relative hemolysis index (RH) values were computed for all five flow-speed combinations (2 L/min at 2500 RPM, 3 L/min at 2000 RPM, 4 L/min at 1750 RPM, 5 L/min at 1500 RPM, and 6 L/min at 1250 RPM) using the Giersiepen-Wurzinger power-law hemolysis model integrated along Lagrangian particle trajectories seeded uniformly at the pump inlet. Experimental RH values were obtained from a dedicated in-vitro hemolysis test rig replicating the FDA generic centrifugal pump geometry in phosphate-buffered saline with washed bovine erythrocytes at 37 °C, following ASTM F1841 sample preparation. The CFD ensemble of 1200 particles per operating condition converged to within 2% of the mean RH estimate at 800 particles, confirming statistical sufficiency. Predicted RH values ranged from 0.71 to 0.94 across the five conditions, with a mean absolute relative error of 8.3% against experimental measurements and a maximum deviation of 14.1% at the 2 L/min condition, which exhibited the highest shear-stress exposure time. All five predicted RH values remained below 1.0, satisfying the acceptance criterion. The operating condition with the highest predicted RH (0.94 at 2 L/min, 2500 RPM) was confirmed as the worst-case scenario, consistent with experimental ranking. Uncertainty in experimental RH measurements was characterised at ±6% (95% CI) based on repeated trials across three test batches. The combined model-form and numerical uncertainty was estimated at ±9% using the approach described in the discretization error factor assessment. Agreement between CFD and experiment is therefore within the combined uncertainty envelope for four of five operating points, with the fifth marginally outside but within engineering acceptance bounds given the conservative nature of the hemolysis model."
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-check",
      "type": "ValidationResult",
      "name": "Mesh convergence validation — GCI assessment on three grid levels",
      "comparedAgainst": "https://uofa.net/morrison/data/fda-pump-geometry-v1",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/mesh-refinement-study-2025",
      "description": "Three systematically refined hexahedral meshes (coarse: 1.2 M cells, medium: 3.8 M cells, fine: 11.4 M cells) were used to compute the Grid Convergence Index for the volume-averaged shear stress and the integrated hemolysis index at the 4 L/min, 1750 RPM design point. GCI values of 3.1% and 4.7% for the medium-to-fine transition confirm that discretization error is within acceptable bounds for MRL 2."
    },
    {
      "id": "https://uofa.net/morrison/validation/turbulence-model-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-omega vs. realizable k-epsilon comparison",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/turbulence-sensitivity-study-2025",
      "description": "SST k-omega and realizable k-epsilon turbulence closures were applied at the 4 L/min, 1750 RPM operating point. Predicted RH values differed by less than 5%, confirming that model-form uncertainty due to turbulence closure selection is subordinate to experimental uncertainty and does not alter worst-case operating condition ranking."
    }
  ],
