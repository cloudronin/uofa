  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/rhi-benchmark-comparison",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index benchmark comparison against FDA pump experimental data",
      "description": "The CFD model was exercised across all five flow-speed operating points (2 L/min at 2500 RPM, 3 L/min at 2500 RPM, 4 L/min at 3500 RPM, 5 L/min at 3500 RPM, and 6 L/min at 4500 RPM). Predicted normalized index of hemolysis (NIH) values were converted to relative hemolysis index (RH) by normalizing against the predicate device experimental measurements obtained from the FDA benchmark dataset. All five operating points yielded RH < 1.0, with a maximum RH of 0.87 at the 6 L/min, 4500 RPM condition. The simulation employed a power-law hemolysis damage accumulation model (Giersiepen-Wurzinger coefficients) integrated along Lagrangian particle tracks seeded at the inlet. Mesh independence was confirmed at 4.2 million polyhedral cells with less than 2.1% change in NIH between the medium and fine grids. Turbulence was modeled using the SST k-omega formulation with low-Reynolds-number correction active in the near-wall region. Boundary conditions were derived from in vitro loop measurements at matched flow rates. The experimental reference values carry an uncertainty of ±8% (95% CI) as reported by the FDA benchmark study. All predicted RH values fall within the experimental uncertainty band for four of five conditions; the fifth (4 L/min, 3500 RPM) deviates by 11%, which remains within the combined model-form and experimental uncertainty envelope estimated at ±15%. This result constitutes the primary validation evidence supporting the credibility claim.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-generic-pump-experimental"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence validation — NIH sensitivity to spatial discretization",
      "description": "Grid refinement study conducted at the 3 L/min, 2500 RPM operating point using coarse (1.1M cells), medium (2.6M cells), and fine (4.2M cells) meshes. Richardson extrapolation applied; GCI fine-grid = 3.4%.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-convergence-study-run-2024"
    },
    {
      "id": "https://uofa.net/synth/validation/turbulence-model-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-omega versus realizable k-epsilon",
      "description": "Comparison of NIH predictions between SST k-omega and realizable k-epsilon turbulence models at the peak-hemolysis operating condition. Maximum NIH difference of 6.3% observed, within acceptable bounds for MRL 2.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/turbulence-sensitivity-run-2024"
    }
  ],
