  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/rh-index-bench-comparison",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Bench Validation — FDA Generic Pump",
      "description": "The CFD-predicted relative hemolysis index (RH) was compared against in-vitro experimental measurements conducted on the FDA generic centrifugal blood pump across all five target flow-speed operating points (2 L/min at 2500 RPM, 3 L/min at 2500 RPM, 4 L/min at 2500 RPM, 3 L/min at 3500 RPM, and 5 L/min at 3500 RPM). Experimental data were acquired using a modified ASTM F1841-97 hemolysis protocol with bovine blood (hematocrit 33±2%). The power-law hemolysis model (Giersiepen et al.) was implemented in ANSYS Fluent 2022R2 with k-omega SST turbulence closure. Mesh independence was confirmed at 4.2 million polyhedral cells with GCI < 2.1% across all operating points. Predicted RH values ranged from 0.61 to 0.94 across the operating envelope, remaining below the acceptance threshold of RH < 1 at all conditions. Maximum absolute error relative to experimental mean was 11.3%, within the ±15% acceptance band defined in the validation plan. The worst-case operating point (5 L/min, 3500 RPM) yielded RH = 0.94 (experimental: 0.88 ± 0.07), satisfying the acceptance criterion. This result constitutes the primary validation evidence for the COU1 claim.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-generic-pump-experimental"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-gci",
      "type": "ValidationResult",
      "name": "Mesh Convergence and Grid Convergence Index Study",
      "description": "Systematic mesh refinement study conducted at three refinement levels to compute GCI values for wall shear stress and velocity magnitude at representative cross-sections.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-convergence-study-2025",
      "comparedAgainst": "https://uofa.net/synth/data/cpb-operating-conditions"
    },
    {
