  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-benchmark-full",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Benchmark — Full Operating Map",
      "description": "This validation result documents the comparison of CFD-predicted relative hemolysis index (RH) against in-vitro experimental measurements collected across all five flow-speed operating points (2 L/min at 2500 rpm, 4 L/min at 2500 rpm, 2 L/min at 3500 rpm, 4 L/min at 3500 rpm, and 3 L/min at 3000 rpm). The experimental campaign was conducted over a six-week period using a laser Doppler velocimetry-calibrated flow loop with FDA-traceable hemolysis measurement protocols (ASTM F1841). Whole human blood from consented donors was anticoagulated with heparin at 2 U/mL and recirculated for 120-minute exposure intervals. The normalized index of hemolysis (NIH) was converted to RH using the predicate device reference NIH of 0.0032 g/100 L. CFD simulations employed the Giersiepen-Wurzinger power-law hemolysis model integrated along Lagrangian particle trajectories seeded uniformly at the pump inlet. All five operating points yielded RH < 1, with the worst-case condition identified at 2 L/min / 3500 rpm (RH = 0.87 ± 0.04 experimental; 0.91 CFD predicted), corresponding to a 4.6% over-prediction consistent with numerical diffusion in the volute tongue region. Grid-converged solutions at 12 million cells were used for all production runs. The full data reduction, uncertainty quantification, and comparison methodology are described in the accompanying technical report TR-2024-CPB-001, available in the project document management system. This result is the primary evidence supporting acceptance of the credibility claim.",
      "comparedAgainst": "https://uofa.net/morrison/data/hemolysis-experimental-reference"
    },
