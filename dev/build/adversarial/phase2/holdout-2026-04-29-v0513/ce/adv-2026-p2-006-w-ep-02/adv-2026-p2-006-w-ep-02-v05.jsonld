  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/rh-index-5op-points",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index validation across 5 operating points",
      "description": "CFD-predicted relative hemolysis index (RH) was compared against in-vitro experimental measurements for five flow-speed operating conditions (2 L/min at 3000 RPM, 3 L/min at 3000 RPM, 4 L/min at 2500 RPM, 5 L/min at 2000 RPM, 6 L/min at 2000 RPM). Predicted RH values ranged from 0.61 to 0.94 against experimentally measured values of 0.58 to 0.91, yielding a maximum absolute error of 0.04 and a mean relative error of 4.2%. All five operating points satisfied the RH < 1 acceptance criterion. The validation study was conducted at the University of Arizona Cardiovascular Biofluid Mechanics Laboratory using a recirculating blood analogue loop with bovine blood, temperature-controlled to 37 ± 0.5 °C. Shear stress exposure time was computed via Lagrangian particle tracking over 10,000 massless tracer trajectories per operating condition. The power-law hemolysis model (Giersiepen-Wurzinger) was applied uniformly across all CFD runs. Agreement between simulation and experiment was assessed using the validation metric defined in ASME V&V 40 Section 5.3. The breadth and consistency of agreement across all five operating conditions, combined with the use of a validated experimental protocol and a well-established hemolysis model, provides high confidence that the CFD framework correctly captures the dominant hemolysis mechanisms relevant to the COU. This result constitutes the primary quantitative evidence for model acceptance.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-independence-check",
      "type": "ValidationResult",
      "name": "Mesh independence verification — pressure rise and wall shear stress",
      "description": "Three mesh densities (coarse: 1.8M cells, medium: 4.6M cells, fine: 9.1M cells) were evaluated. Pressure rise differed by less than 1.3% between medium and fine meshes; area-averaged wall shear stress differed by less than 2.1%. The medium mesh was selected for production runs.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-convergence-study-2024"
    },
    {
      "id": "https://uofa.net/synth/validation/turbulence-model-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-omega vs realizable k-epsilon",
      "description": "SST k-omega and realizable k-epsilon turbulence closures were compared against PIV velocity measurements in the volute exit region at 3 L/min, 3000 RPM. SST k-omega yielded a mean velocity magnitude error of 6.8% versus 11.2% for realizable k-epsilon. SST k-omega was adopted as the production turbulence model.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-cfd-simulation-outputs",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/turbulence-sensitivity-study-2024"
    }
  ],
