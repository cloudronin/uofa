  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/rh-index-benchmark-five-conditions",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Validation Against FDA Benchmark — Five Operating Conditions",
      "description": "This validation result captures the outcome of an extensive CFD simulation campaign in which the normalized index of hemolysis (RH) was computed across all five designated flow-speed combinations (2 L/min at 2000 RPM, 3 L/min at 2500 RPM, 4 L/min at 3000 RPM, 5 L/min at 3500 RPM, and 6 L/min at 4000 RPM) using the power-law hemolysis damage model of Giersiepen et al. as implemented in ANSYS Fluent 2022 R2. Mesh independence was confirmed via a three-level Richardson extrapolation study on a 1.8 M, 4.6 M, and 11.2 M element polyhedral mesh series, yielding a grid convergence index below 1.4% for the scalar hemolysis exposure integral at all five conditions. Turbulence was modelled with the SST k-omega closure; near-wall y+ values were maintained below 1.0 on all blood-contacting surfaces. Particle tracking was performed using a Lagrangian one-way-coupled approach with 5000 massless tracer parcels per inlet plane, and cumulative strain exposure was accumulated along each trajectory. The resulting RH values ranged from 0.41 to 0.87 across the five conditions, all satisfying the RH < 1.0 acceptance criterion. Experimental reference data were drawn from the FDA benchmark hemolysis dataset (CDRH, 2019), comprising NIH measurements obtained from a physical replica of the generic centrifugal pump operated at matched flow and rotational speed. The mean absolute percentage error between CFD-predicted and experimentally measured normalized index of hemolysis was 11.3%, within the pre-specified 15% tolerance band. Worst-case hemolysis was correctly identified at the 2 L/min / 2000 RPM condition in both simulation and experiment, confirming the model's rank-ordering fidelity. This result constitutes the primary validation evidence supporting the credibility claim that the CFD model can identify worst-case hemolysis operating conditions for the subject device class.",
      "comparedAgainst": "https://uofa.net/synth/data/hemolysis-experimental-reference"
    },
    {
      "id": "https://uofa.net/synth/validation/code-verification-manufactured-solution",
      "type": "ValidationResult",
      "name": "Method of Manufactured Solutions — Navier-Stokes Solver Order Verification",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mms-order-verification-run-2024",
      "description": "The Navier-Stokes solver was verified using the method of manufactured solutions on a three-dimensional lid-driven cavity geometry. Observed spatial order of accuracy was 1.97 for velocity and 1.94 for pressure, consistent with the nominal second-order scheme. No code defects were identified."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-independence-gci",
      "type": "ValidationResult",
      "name": "Grid Convergence Index Study — Hemolysis Exposure Integral",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/gci-mesh-refinement-study-2024",
      "description": "Three polyhedral mesh levels (1.8 M, 4.6 M, 11.2 M elements) were evaluated. GCI values below 1.4% were achieved for the hemolysis exposure scalar at all five operating conditions, confirming discretization error is within acceptable bounds for MRL 2."
    }
  ],
