      "passedCriteria": true,
      "acceptanceCriteria": "Selected turbulence model must yield RH within ±15% of experimental benchmark.",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/turbulence-sensitivity-study-q2-2024"
