  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-comparison-primary",
      "type": "ValidationResult",
      "name": "Primary RH index validation — FDA pump experimental comparison",
      "comparedAgainst": "https://uofa.net/morrison/data/hemolysis-experimental-rh-index",
      "description": "The CFD model was exercised across all five target flow-speed operating points (2.5 L/min at 2000 RPM, 3.5 L/min at 2500 RPM, 4.5 L/min at 3000 RPM, 5.5 L/min at 3500 RPM, and 6.0 L/min at 3800 RPM). Predicted relative hemolysis index values were compared against bench-top experimental measurements obtained using the ASTM F1841 hemolysis protocol on the FDA generic centrifugal pump geometry. Mesh-independent solutions were confirmed via three-level Richardson extrapolation (GCI < 2.1% across all operating points). The SST k-omega turbulence closure with Giersiepen-Wurzinger power-law hemolysis model yielded RH predictions within ±8.3% of experimental measurements at all five operating points, with worst-case RH = 0.87 at 6.0 L/min / 3800 RPM, satisfying the RH < 1 acceptance criterion. The validation campaign was conducted by the Morrison Laboratory CFD team during Q3 2024 using ANSYS Fluent 2023R2 on a 48-core HPC cluster, with raw data archived in the institutional repository. All five operating-point comparisons individually satisfy the acceptance criterion, and the aggregate normalized RMS error is 6.1%, well within the ±15% validation tolerance established for MRL 2.",
      "passedCriteria": true,
      "acceptanceCriteria": "Predicted RH < 1.0 at all operating points; normalized RMS error < 15% across the validation matrix."
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-gci",
      "type": "ValidationResult",
      "name": "Mesh convergence GCI study — three-level Richardson extrapolation",
      "comparedAgainst": "https://uofa.net/morrison/data/fda-pump-geometry-v1",
      "description": "Grid convergence index study conducted on coarse (2.1M cells), medium (5.8M cells), and fine (14.3M cells) meshes at the nominal operating point 4.5 L/min / 3000 RPM. GCI values below 2.1% confirm mesh-independent solutions.",
      "passedCriteria": true,
      "acceptanceCriteria": "GCI < 5% on fine-to-medium mesh refinement ratio.",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/mesh-convergence-study-q3-2024"
    },
    {
