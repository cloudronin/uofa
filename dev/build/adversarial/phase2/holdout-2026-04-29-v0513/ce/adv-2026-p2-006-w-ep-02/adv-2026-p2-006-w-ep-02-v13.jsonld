  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-rh-index-5op-points",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Validation — 5 Operating Points (Primary Result)",
      "description": "CFD-predicted relative hemolysis index (RH) was evaluated against experimental measurements obtained from a physical test rig replicating the FDA generic centrifugal blood pump geometry. Five flow-speed combinations spanning the intended CPB operating envelope (2.5 L/min at 2000 RPM through 6.0 L/min at 3500 RPM) were simulated using the power-law hemolysis damage model (Giersiepen et al. 1990, recalibrated per Zhang et al. 2011). Experimental RH values were acquired using a standardised NIH haemolysis protocol with porcine blood at 37°C ± 0.5°C and haematocrit 35 ± 2%. Predicted RH ranged from 0.61 to 0.94 across the five points; all fell below the RH < 1.0 acceptance criterion. Mean absolute relative error between CFD predictions and experimental measurements was 8.3%, well within the 15% validation tolerance established in the V&V plan. Grid-independence was confirmed via a three-level refinement study (coarse 1.8 M cells, medium 4.6 M cells, fine 11.2 M cells) with GCI < 2.1% on the hemolysis scalar at the fine level. Turbulence was modelled using the SST k-ω closure; near-wall y+ values were maintained below 1.0 at all impeller blade surfaces. The validation campaign was conducted at the Morrison Biofluid Mechanics Laboratory between March and August 2023, with instrument calibration records archived under project reference MBL-2023-CPB-CAL. All five operating-point comparisons individually satisfy the acceptance criterion, supporting the claim that the CFD model reliably identifies worst-case hemolysis conditions across the CPB operating envelope.",
      "comparedAgainst": "https://uofa.net/synth/data/cpb-hemolysis-experimental-dataset"
    },
