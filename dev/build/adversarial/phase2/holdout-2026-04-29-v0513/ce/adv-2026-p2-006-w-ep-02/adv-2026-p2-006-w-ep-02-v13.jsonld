  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for MRL 2. The primary validation result demonstrates mean absolute relative error of 8.3% against experimental RH measurements across all five CPB operating points, satisfying the 15% acceptance criterion. The six non-assessed factors are acceptable at MRL 2 given the medium model influence and documented analyst qualifications. The model is judged credible for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
