  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-5op-comparison",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index comparison across 5 operating points",
      "description": "CFD-predicted relative hemolysis index (RH) was compared against experimental measurements at five flow-speed operating points (3 L/min at 2000 rpm, 4 L/min at 2500 rpm, 5 L/min at 3000 rpm, 6 L/min at 3500 rpm, 4.5 L/min at 3000 rpm). Experimental data were collected using the Lagrangian scalar transport hemolysis model with power-law damage accumulation. Predicted RH values ranged from 0.71 to 0.94 against experimentally measured values of 0.68 to 0.91, yielding a mean absolute relative error of 4.3% across all operating points. The worst-case operating point was correctly identified by the CFD model as the 6 L/min at 3500 rpm condition in both experiment and simulation, satisfying the primary COU objective. Bland-Altman analysis confirmed no systematic bias (mean difference −0.018, 95% limits of agreement −0.062 to +0.026). The simulation campaign was executed on a 12.4-million-element polyhedral mesh with SST k-ω turbulence closure, using ANSYS Fluent 2022 R2 on the university HPC cluster over a 72-hour wall-clock period. Convergence was verified via residual monitoring and mass-balance checks at each operating point. All five operating-point simulations and the subsequent post-processing pipeline were conducted by the primary analyst and reviewed by a senior engineer prior to result submission. The experimental reference data were obtained from the Morrison et al. (2023) published dataset archived at the FDA Medical Device Hemolysis Repository.",
      "comparedAgainst": "https://uofa.net/morrison/data/hemolysis-experimental-rh-measurements"
    },
