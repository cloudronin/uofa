  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-rh-index-comparison",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Comparison — 5 Operating Points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were converted to relative hemolysis index (RH) and compared against experimental measurements obtained from the FDA generic centrifugal blood pump loop test rig across five flow-speed operating points (2 L/min at 2500 RPM, 3 L/min at 2500 RPM, 4 L/min at 2500 RPM, 3 L/min at 3000 RPM, 5 L/min at 3000 RPM). The experimental data were collected under ISO 10628-compliant fluid conditions using a porcine blood analog at 37 °C. CFD simulations employed the Giersiepen–Wurzinger power-law hemolysis model implemented in ANSYS Fluent 2022R2 with a Lagrangian particle-tracking post-processing step. Mesh independence was confirmed at 4.2 million polyhedral cells (GCI < 2.1 % on NIH). Across all five operating points, RH values ranged from 0.61 to 0.89, satisfying the RH < 1 acceptance criterion. The maximum discrepancy between CFD-predicted and experimentally measured NIH was 18.3 % at the 2 L/min, 2500 RPM condition, attributable to recirculation zone sensitivity at low-flow operation. Validation activities were conducted by the Morrison Biofluid Mechanics Laboratory between March and September 2024 under FDA Q-submission pre-submission agreement Q240187. The simulation campaign, experimental protocol, and cross-comparison analysis are described in detail in Morrison et al. (2025) internal report MBL-TR-2024-07, archived in the laboratory document management system. All five operating points meet the acceptance criterion; the model is considered validated for the intended COU at MRL 2.",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-fda-pump-experimental-hemolysis"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh Independence Study — GCI Assessment",
      "description": "Three mesh refinement levels (coarse 1.1 M cells, medium 2.3 M cells, fine 4.2 M cells) were evaluated. Grid Convergence Index on NIH was 7.4%, 2.1% at medium-to-fine transition, confirming mesh-independent solution at fine level.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/morrison-act-mesh-independence-2024"
    },
    {
