  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-rh-index-five-conditions",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation across five CPB operating conditions — primary validation result",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-hemolysis-experimental-reference",
      "description": "The CFD model was exercised at five flow-rate and rotational-speed combinations spanning the CPB operating envelope (2.5 L/min at 2000 RPM through 5.0 L/min at 3500 RPM). For each condition the normalized index of hemolysis (NIH) was computed from the predicted shear-stress field using the Giersiepen–Wurzinger power-law damage accumulation model, then converted to the relative hemolysis index RH by normalization against the predicate device experimental baseline obtained from the FDA generic pump in-vitro loop study (n = 6 replicates, CV < 8 %). Across all five conditions the model returned RH values in the range 0.71–0.94, all strictly below the regulatory acceptance threshold of RH < 1.0. The worst-case condition was identified as 3.0 L/min at 3000 RPM (RH = 0.94), consistent with the experimental observation that intermediate flow at elevated speed produces the longest high-shear residence time. Grid-converged solutions on the 14.2 M-cell polyhedral mesh (GCI < 2.1 % on NIH) were used for all comparisons. Turbulence was modelled with the SST k-ω closure; near-wall y+ was maintained below 1.0 on all impeller surfaces. Discrepancy between predicted and measured NIH at the validation conditions ranged from −4.3 % to +6.8 %, well within the ±15 % model-form uncertainty band established by the uncertainty quantification sub-study. This result constitutes the primary evidence that the model meets the output-comparison credibility requirement at Gradation 2."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pressure-rise-verification",
      "type": "ValidationResult",
      "name": "Pump pressure-rise characteristic validation against published PIV and pressure-tap data",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-fda-pump-geometry-v3",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/morrison-pressure-validation-run-2024q3",
      "description": "Predicted pump head versus flow-rate curve compared against FDA-published PIV benchmark data. Maximum deviation 3.2 % across the operating range."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-gci-mesh-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence index study on NIH quantity of interest",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/morrison-gci-study-2024q2",
      "description": "Three-level mesh refinement study (3.5 M, 8.1 M, 14.2 M cells) yielded GCI of 2.1 % on NIH at the finest level, confirming discretization error is within acceptable bounds for MRL 2."
    }
  ],
