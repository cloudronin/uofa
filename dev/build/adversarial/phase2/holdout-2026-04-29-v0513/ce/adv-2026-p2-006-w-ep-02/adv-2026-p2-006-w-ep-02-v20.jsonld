  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-rh-index-5conditions",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index Validation — 5 Operating Conditions",
      "description": "Detailed bench-top experiments were conducted on the FDA generic centrifugal blood pump at five flow-speed operating points spanning the intended clinical range (2–6 L/min, 2000–3500 RPM). Fresh bovine blood (hematocrit 35±2%) was circulated through a closed loop for 120 minutes per condition. The normalized index of hemolysis (NIH) was measured in triplicate using the Harboe spectrophotometric method. CFD-predicted hemolysis was computed using the power-law damage accumulation model integrated along Lagrangian particle trajectories. The relative hemolysis index RH = NIH_CFD / NIH_exp was computed for each condition. All five RH values fell below 1.0 (range 0.71–0.94), satisfying the pre-specified acceptance criterion. Mesh independence was confirmed via Richardson extrapolation on the finest three grid levels. Turbulence model sensitivity was assessed by comparing k-ω SST against realizable k-ε; differences in predicted NIH were less than 4%. The experimental uncertainty was quantified as ±8% (95% CI). This result provides the primary quantitative evidence supporting the credibility claim that the CFD model reliably predicts worst-case hemolysis conditions for the CPB device.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh Independence Study — Grid Convergence Index",
      "description": "Three structured hexahedral meshes (2.1M, 6.8M, and 18.4M cells) were evaluated. GCI values for the finest grid were below 2.3% for all QoIs.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-independence-study-2025q3"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump Pressure Rise Validation Against PIV Data",
      "description": "CFD-predicted pressure rise across the impeller was compared against particle image velocimetry (PIV) measurements at three operating points. Mean absolute error was 3.1%, within the 5% acceptance threshold.",
      "comparedAgainst": "https://uofa.net/synth/data/piv-pressure-rise-measurements",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/piv-pressure-validation-campaign-2025q2"
    }
