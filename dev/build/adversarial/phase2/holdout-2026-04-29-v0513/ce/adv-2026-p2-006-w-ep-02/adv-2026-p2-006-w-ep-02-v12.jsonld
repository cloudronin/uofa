    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index (RH) validation — full five-point operating envelope with dimensional sensitivity sweep",
      "comparedAgainst": "https://uofa.net/synth/data/morrison-experimental-hemolysis-measurements",
      "description": "The relative hemolysis index (RH) predicted by the CFD model was evaluated across all five flow-speed operating points specified in the COU (2.5 LPM/3500 RPM, 5.0 LPM/3500 RPM, 5.0 LPM/2500 RPM, 7.5 LPM/2500 RPM, and 7.5 LPM/1500 RPM) and compared against in-vitro hemolysis measurements conducted on the FDA generic centrifugal pump geometry. The hemolysis model employed the power-law Giersiepen-Wurzinger formulation with exponents calibrated to bovine blood rheology. Dimensional sensitivity perturbations of ±0.15 mm on impeller tip clearance and ±0.10 mm on volute throat width were incorporated to bracket manufacturing tolerance effects. Across all five nominal operating points the predicted RH values ranged from 0.61 to 0.94, all satisfying the RH < 1.0 acceptance criterion. The worst-case operating condition was identified as 5.0 LPM at 3500 RPM (RH = 0.94), consistent with the experimental observation that elevated rotational speed combined with moderate flow produces the highest shear exposure in the blade-tip region. Sensitivity perturbations shifted RH by at most 0.07, preserving the RH < 1.0 margin at all perturbed configurations. The in-vitro measurements reported a mean normalized index of 0.89 ± 0.06 at the worst-case point; the model prediction of 0.94 lies within the experimental uncertainty band. The assessment team reviewed simulation log files, residual convergence histories, and y-plus distributions to confirm numerical adequacy prior to extracting hemolysis scalar transport results. All post-processing was performed with the validated in-house hemolysis integration script v2.3, and results were cross-checked by an independent analyst. The comprehensive agreement across the operating envelope, combined with the bounded sensitivity to geometric perturbations, supports confidence that the CFD model correctly identifies worst-case hemolysis conditions for the CPB device.",
      "outcome": "Passed",
      "quantitativeMetric": "RH range 0.61–0.94 across five operating points; worst-case RH 0.94 vs experimental 0.89 ± 0.06"
    }
  ],
