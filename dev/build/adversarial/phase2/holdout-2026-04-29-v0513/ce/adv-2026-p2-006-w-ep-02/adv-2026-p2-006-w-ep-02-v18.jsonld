  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-operating-point-sweep",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index — Five Operating-Point Sweep Validation",
      "comparedAgainst": "https://uofa.net/morrison/data/hemolysis-experimental-rh-measurements",
      "description": "This validation study compared CFD-predicted relative hemolysis index (RH) values against in-vitro hemolysis measurements collected across all five target flow-speed operating points (2 L/min at 2500 RPM, 3 L/min at 3000 RPM, 4 L/min at 3500 RPM, 5 L/min at 4000 RPM, and 6 L/min at 4500 RPM) using the FDA generic centrifugal blood pump geometry. Blood analog fluid (glycerol-saline) was circulated through a mock-loop circuit instrumented with a hemolysis sampling port. Plasma-free haemoglobin was quantified by spectrophotometry at 540 nm at 30-minute intervals over a 4-hour test duration. The normalized index of haemolysis (NIH) was converted to RH by normalisation against the predicate pump measurements conducted under identical loop conditions. CFD predictions employed a power-law damage accumulation model (Giersiepen–Wurzinger constants) integrated along Lagrangian particle trajectories seeded at the inlet plane. Mesh sensitivity was confirmed at 12 million polyhedral cells (GCI < 2.1% for RH across all operating points). Across the five operating points, RH ranged from 0.61 to 0.89 experimentally and from 0.58 to 0.94 in simulation; the mean absolute relative error was 5.3% and all predicted values remained below the RH < 1 acceptance threshold. The assessment team reviewed raw spectrophotometry logs, loop pressure traces, and particle-tracking post-processing outputs in detail and concluded that model predictions are sufficiently accurate for the intended COU. The breadth of the operating-point sweep, the low GCI values, and the consistent sub-unity RH predictions collectively support a credibility determination of Accepted at MRL 2.",
      "resultValue": "Mean absolute relative error 5.3%; all RH predictions < 1.0 across five operating points",
      "validationStatus": "passed"
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-gci",
      "type": "ValidationResult",
      "name": "Grid Convergence Index — Polyhedral Mesh Refinement Study",
      "comparedAgainst": "https://uofa.net/morrison/data/fda-generic-pump-geometry-v2",
      "description": "Three systematically refined polyhedral meshes (coarse 3M, medium 7M, fine 12M cells) were evaluated for RH and pressure rise at the 4 L/min 3500 RPM operating point. GCI was computed per Roache (1994). Fine-grid GCI was 2.1% for RH and 1.4% for pressure rise, confirming mesh-independent solution.",
      "resultValue": "GCI_fine = 2.1% (RH), 1.4% (pressure rise); apparent order p = 2.03",
      "validationStatus": "passed",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/mesh-convergence-study-2024q3"
    },
