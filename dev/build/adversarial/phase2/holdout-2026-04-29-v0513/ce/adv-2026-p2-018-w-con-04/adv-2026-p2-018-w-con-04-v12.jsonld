  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretisation error assessment",
      "description": "Grid refinement study across coarse (2.1 M cells), medium (5.8 M cells), and fine (14.3 M cells) meshes. Richardson extrapolation yields GCI < 2.4% on the hemolysis index QoI at all five operating points. Fine mesh adopted for production runs."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-experimental-hemolysis",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison",
      "description": "Predicted normalised index of hemolysis (NIH) compared against in-vitro measurements from the FDA benchmark dataset at 2500, 3500, and 4500 RPM across 2–6 L/min flow rates. RMS prediction error 8.7%; all predictions satisfy RH < 1 acceptance criterion. The UQ campaign (parametric sensitivity sweeps over viscosity ±15%, inlet velocity ±10%, and rotational speed ±5%) confirmed that uncertainty in model inputs does not alter the rank ordering of worst-case operating conditions."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-piv-velocity",
      "type": "ValidationResult",
      "name": "PIV velocity field validation",
      "description": "Predicted velocity magnitude and turbulent kinetic energy fields compared against particle image velocimetry data in the volute and impeller exit regions. Mean absolute error 6.2% relative to peak velocity; turbulent kinetic energy within 18% at measurement planes. Supports confidence in the shear-stress-driven hemolysis sub-model."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-04-code-verification",
      "type": "ValidationResult",
      "name": "Code verification via manufactured solutions",
      "description": "Method of manufactured solutions applied to the Navier-Stokes solver for three canonical flows (lid-driven cavity, pipe flow, rotating annulus). Observed convergence order 1.97 ± 0.04 for velocity; 1.89 ± 0.07 for pressure. No systematic solver defects identified."
    }
  ],
