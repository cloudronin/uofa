    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-benchmark-hemolysis",
      "type": "ValidationResult",
      "name": "FDA pump benchmark hemolysis validation — 5 operating points",
      "description": "CFD predictions of normalised index of hemolysis (NIH) compared against published FDA benchmark experimental data at 2500 rpm / 5 L/min, 3500 rpm / 5 L/min, 2500 rpm / 7 L/min, 3500 rpm / 7 L/min, and 4500 rpm / 3 L/min. All five operating points yield predicted NIH within 15% of experimental mean; RH < 1 at worst-case condition. Validation metric: E_rel = (NIH_CFD − NIH_exp) / NIH_exp.",
      "validationMetric": "Relative error E_rel",
      "acceptanceCriterion": "E_rel ≤ 0.15 at all operating points; RH < 1.0",
      "outcome": "Pass"
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-uq-campaign",
      "type": "ValidationResult",
      "name": "UQ campaign — geometric tolerance and viscosity sensitivity",
      "description": "A 200-sample Latin-hypercube UQ campaign was executed varying six geometric tolerance parameters (±0.05 mm on impeller blade tip, volute gap, and inlet diameter) and blood viscosity (±10%). Sobol sensitivity indices computed post-hoc; impeller blade tip clearance identified as dominant contributor (S_i = 0.41). 95th-percentile NIH across all samples remains below acceptance threshold. The UQ campaign results were reviewed and accepted by the credibility assessment team; narrative evidence of the analysis is captured here. Structured linkage to a dedicated SensitivityAnalysis record was not established in this package version.",
      "validationMetric": "Sobol first-order index; 95th-percentile NIH",
      "acceptanceCriterion": "P95(NIH) < NIH_acceptance; dominant S_i identified and bounded",
      "outcome": "Pass"
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — GCI discretization error",
      "description": "Three-level mesh refinement study performed at nominal operating point (3500 rpm / 5 L/min). Grid Convergence Index (GCI) computed per Roache methodology. GCI_fine = 1.3%; apparent order of convergence p = 1.96, consistent with second-order scheme. Discretization error bounded below 2% for hemolysis scalar transport.",
      "validationMetric": "Grid Convergence Index (GCI)",
      "acceptanceCriterion": "GCI_fine < 5%",
      "outcome": "Pass"
    }
