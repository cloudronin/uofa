    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark test demonstrates solver correctly implements governing equations for rotating machinery and scalar transport to second-order accuracy.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes and power-law hemolysis transport equation. L2 error norms decrease at 1.95 ± 0.08 order with mesh refinement, confirming second-order spatial accuracy. Temporal accuracy verified at first order for steady-state RANS approach."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization error estimate < 5% for primary QoI (NIH) at nominal operating point.",
      "rationale": "Three-level mesh refinement (4.2 M, 10.1 M, 24.8 M cells) yields GCI_fine = 1.3% for NIH at 3500 rpm / 5 L/min. Apparent order p = 1.96 consistent with scheme order. Richardson extrapolated value used as reference. Exceeds Gradation 2 requirement; assessed at Gradation 3 due to systematic GCI documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) documented with uncertainty ≤ 3% for primary parameters.",
      "rationale": "FDA benchmark experimental data provide inlet flow rates measured with Coriolis flowmeter (±1.2%), rotational speed via optical encoder (±0.5%), and fluid temperature controlled to ±0.5 °C. All boundary condition uncertainties within acceptance threshold. Experimental protocol published in Morrison et al. (2019)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E_rel) computed for all validation operating points; systematic bias < 15%.",
      "rationale": "E_rel computed at all five operating points. Maximum E_rel = 12.4% at 4500 rpm / 3 L/min (high-shear regime). Mean E_rel = 7.8%. No systematic sign bias observed across operating envelope. Comparison methodology follows ASME V&V 20 framework for experimental uncertainty propagation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (NIH) is directly related to COU QoI (RH); mapping between validation and COU quantities documented.",
      "rationale": "Validation uses normalised index of hemolysis (NIH, mg/100 L) measured in vitro. COU uses relative hemolysis index (RH = NIH_device / NIH_predicate). Mapping is linear and monotonic; NIH validation directly supports RH COU criterion. Both quantities derived from same hemolysis power-law model output."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating conditions, and fluid properties sufficiently similar to COU device and operating envelope to support credibility claim.",
      "rationale": "FDA generic centrifugal pump geometry used for both validation and COU assessment. Operating envelope (2500–4500 rpm, 3–7 L/min) spans full CPB clinical range. Blood analogue fluid (glycerol-water, matched viscosity) used in validation; power-law viscosity model applied consistently. Geometric similarity index ≥ 0.92 between validation and COU pump configurations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; iterative convergence monitoring sufficient.",
      "rationale": "At Model Risk Level 2, explicit numerical solver error quantification beyond iterative convergence monitoring is not required. Residuals converged to 1e-6 for continuity and momentum; hemolysis scalar residual to 1e-8. No assessment of floating-point round-off or solver linearisation error performed; acceptable per MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst training records sufficient.",
      "rationale": "MRL 2 does not require formal use-error analysis. Simulation performed by analyst with 8 years CFD experience in cardiovascular applications; internal peer review of setup files conducted. Formal use-error FMEA not performed; acceptable at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified with reference to published validation evidence for similar flow regimes.",
      "rationale": "SST k-ω turbulence model selected based on published evidence of superior performance in rotating machinery with adverse pressure gradients (Menter 1994; Hariharan et al. 2011). Power-law hemolysis model (Giersiepen et al. 1990, modified Heuser-Opitz constants) validated against FDA benchmark data. Model form uncertainty acknowledged; SST k-ω identified as best-available model for this flow class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and boundary conditions documented with sources; sensitivity of NIH to key input parameters characterised.",
      "rationale": "Blood density 1056 kg/m³ (literature consensus), power-law viscosity parameters from Walburn-Schneck model fitted to clinical viscometry data. Inlet velocity profile from Womersley solution at measured flow rates. Input sensitivity characterised via UQ campaign (see validation result vr-02); dominant inputs identified and bounded. All inputs traceable to documented sources."
    },
