      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; use of published FDA benchmark data accepted without independent sample characterisation.",
      "rationale": "Validation relies on FDA-published benchmark experimental dataset (Morrison et al. 2019). Independent characterisation of test fluid samples not performed by modelling team. At MRL 2, use of published reference data without independent sample assessment is acceptable. Sample preparation protocols documented in original publication."
    },
