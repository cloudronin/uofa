  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — three-level GCI assessment",
      "description": "Grid convergence index computed on hemolysis index QoI across coarse, medium, and fine meshes (4.2 M, 12.1 M, 31.8 M cells). GCI fine < 1.8 % at all five operating points. Asymptotic range confirmed (GCI ratio 1.02–1.06). Discretization error within acceptable bounds for MRL 2."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison against FDA benchmark data",
      "description": "Predicted normalised index of hemolysis (NIH) compared against FDA generic pump experimental measurements at 2.5 L/min/2500 RPM, 5 L/min/2500 RPM, 5 L/min/3500 RPM, 7 L/min/3500 RPM, and 7 L/min/4500 RPM. Mean absolute relative error 8.3 %; all predictions within ±15 % experimental uncertainty band. Relative hemolysis index RH < 1 criterion satisfied at all operating points."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-uq-campaign",
      "type": "ValidationResult",
      "name": "Uncertainty quantification campaign — Latin hypercube sampling across 6 input parameters",
      "description": "A 200-sample Latin hypercube UQ campaign was executed varying inlet flow rate (±10 %), rotational speed (±5 %), blood viscosity (±8 %), gap clearance (±0.05 mm), surface roughness (±20 %), and inlet hematocrit (±3 %). Sobol first-order and total-effect sensitivity indices were computed. Rotational speed and gap clearance collectively account for 71 % of output variance. The UQ campaign confirms that the model is not unduly sensitive to fluid property uncertainty and that the worst-case operating point identification is robust. Sensitivity rankings are documented in the campaign report (DOI: 10.17632/morrison-uq-2024). Note: structured hasSensitivityAnalysis linkage is pending ontology alignment with the submitting organisation's data management system; the substantive sensitivity evidence is captured in this ValidationResult narrative."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-04-solver-verification",
      "type": "ValidationResult",
      "name": "Numerical solver verification against manufactured solutions",
      "description": "Method of manufactured solutions applied to the Navier–Stokes and power-law hemolysis damage accumulation sub-models. Observed order of accuracy 1.97 (expected 2.0 for second-order scheme). Residual norms converge to machine precision for all manufactured cases. No coding errors detected."
    }
  ],
