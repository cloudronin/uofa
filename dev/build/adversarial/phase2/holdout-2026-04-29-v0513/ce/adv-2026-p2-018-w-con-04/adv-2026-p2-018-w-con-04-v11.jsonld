  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence and discretization error study",
      "description": "Three-level mesh refinement study on the FDA centrifugal pump geometry. Grid convergence index (GCI) computed for hemolysis index at all 5 operating points. Maximum GCI of 4.2% observed at the highest flow-rate condition. Richardson extrapolation confirms asymptotic convergence. UQ campaign sensitivity analysis identified impeller tip-gap mesh density as the dominant contributor to numerical uncertainty, accounting for 61% of total discretization variance."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison — FDA pump benchmark",
      "description": "CFD-predicted normalised index of hemolysis (NIH) compared against published FDA experimental data across all 5 flow-speed combinations. Relative hemolysis index RH < 1 satisfied at all operating points. Mean absolute error 8.3%; maximum error 14.1% at 2.5 L/min / 2500 RPM. The UQ campaign (Latin hypercube, n=512 samples) propagated uncertainty in inlet velocity (±5%), fluid viscosity (±3%), and clearance gap (±15 μm) through the CFD model; first-order Sobol indices confirmed that clearance gap is the most influential parameter (S₁ = 0.47), followed by inlet velocity (S₁ = 0.31). These sensitivity rankings, derived from the UQ campaign, are documented here in narrative form and were used to prioritise experimental validation coverage."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-tolerance-sweep",
      "type": "ValidationResult",
      "name": "Manufacturing tolerance sweep validation",
      "description": "CFD predictions of RH across the 3-sigma manufacturing tolerance envelope compared against worst-case experimental measurements on three pump units with intentionally varied clearances. All predictions within 12% of measured values. The UQ campaign results confirmed that no combination of nominal tolerance variations drives RH above 0.95, providing margin against the RH < 1 acceptance criterion."
    }
  ],
