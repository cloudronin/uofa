  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — FDA pump geometry",
      "description": "Three-level mesh refinement study (coarse 2.1 M, medium 5.4 M, fine 11.8 M cells). Grid convergence index (GCI) for normalised hemolysis index < 2.1% between medium and fine meshes. Medium mesh adopted for production runs. The UQ campaign confirmed that spatial discretisation uncertainty is subordinate to inlet-condition variability across all 5 operating points."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison — 5 operating points",
      "description": "Predicted normalised index of hemolysis (NIH) compared against published FDA experimental data at Q = 2.5, 3.5, 5.0, 6.0, 7.0 L/min at 2500 RPM. Mean absolute relative error 8.3%; all predictions within experimental uncertainty bands. Relative hemolysis index RH < 1 confirmed at all operating points. UQ sweep over ±10% inlet flow and ±5% viscosity produced a maximum RH spread of 0.07, well within acceptance margin."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-turbulence-model-comparison",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-ω vs. realizable k-ε",
      "description": "SST k-ω and realizable k-ε models compared at the worst-case operating point (Q = 2.5 L/min, 2500 RPM). NIH values differ by 4.7%; both models satisfy RH < 1. SST k-ω selected as primary model based on superior near-wall resolution. The UQ campaign documented herein included turbulence model choice as a discrete uncertain parameter; combined effect on RH remained below the 0.10 threshold established in the acceptance criteria."
    }
  ],
