  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation — 5 operating points",
      "description": "CFD-predicted relative hemolysis index (RH) compared against experimental measurements at 5 flow-speed combinations. All predictions satisfy RH < 1 acceptance criterion. The UQ campaign (Latin hypercube, 128 samples) confirmed that geometric tolerance uncertainty contributes less than 4 % variability to RH, supporting model adequacy. Quantitative agreement metric: normalised RMSE 0.063 across all operating points."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-shear-stress-distribution",
      "type": "ValidationResult",
      "name": "Wall shear stress spatial distribution validation",
      "description": "PIV-derived velocity fields used to validate near-wall shear stress predictions. Mean absolute error 7.2 % relative to experimental values. UQ sweep results (documented in the uncertainty quantification campaign report MOR-UQ-2024-01) indicate that turbulence model uncertainty is the dominant contributor; sensitivity rankings are discussed therein. Outcome: validation evidence deemed sufficient for MRL 2."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-pressure-head",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation",
      "description": "Simulated pressure-head curves compared against manufacturer test data across the full operating envelope. Maximum deviation 3.8 %. The UQ campaign identified rotational speed uncertainty as the second-ranked sensitivity contributor; however, its effect on RH is within acceptable bounds at all five COU operating points."
    }
  ],
