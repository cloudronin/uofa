    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — 3-level Richardson extrapolation",
      "description": "Three structured meshes (2.1M, 8.4M, 33.6M cells) were generated for the FDA pump geometry. Richardson extrapolation yielded a grid convergence index of 1.8% for the relative hemolysis index at the design operating point, satisfying the Gradation 2 discretization error requirement."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis comparison — 5 operating conditions",
      "description": "CFD-predicted RH values were compared against in-vitro hemolysis measurements across 5 flow-speed combinations (2.5 L/min at 2000 RPM through 6 L/min at 3500 RPM). Mean absolute relative error was 11.3%, within the 15% acceptance criterion. All 5 predictions fell within experimental uncertainty bounds."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-uq-campaign",
      "type": "ValidationResult",
      "name": "UQ parametric campaign — impeller clearance and flow rate sensitivity",
      "description": "A structured uncertainty quantification campaign was executed covering ±10% variation in impeller tip clearance, ±5% in inlet flow rate, and ±200 RPM in rotational speed. Latin hypercube sampling (N=128) was used. The campaign demonstrated that worst-case hemolysis conditions are robustly identified by the model across the tolerance envelope, with coefficient of variation in RH of 6.2%. Sensitivity rankings placed impeller clearance as the dominant contributor (Sobol index 0.61). These findings informed the credibility factor ratings for model inputs and output comparison. A structured hasSensitivityAnalysis record was considered; the UQ results are fully described in the experimental validation report referenced via wasDerivedFrom."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-04-code-verification",
      "type": "ValidationResult",
      "name": "Code verification — manufactured solution benchmark",
      "description": "ANSYS Fluent 2023R1 was verified against the Taylor-Green vortex manufactured solution and the FDA nozzle benchmark (FDA Critical Path study). Observed order of accuracy 1.94 (theoretical 2.0 for second-order upwind). Software quality assurance documentation reviewed; all V&V 40 SQA checklist items satisfied."
    }
  ],
