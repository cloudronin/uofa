  "couName": "CPB use",
  "decision": "Accepted",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). An uncertainty quantification campaign was conducted spanning all five flow-speed operating points; Latin hypercube sampling over 12 geometric and boundary-condition parameters confirmed that the RH metric is most sensitive to impeller tip clearance and inlet flow angle, with Sobol first-order indices of 0.41 and 0.29 respectively. These UQ findings are summarised in the validation report and informed the acceptance rationale, though a structured hasSensitivityAnalysis link is not separately encoded in this package.",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/cfd-centrifugal-pump-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-geometry-v2",
    "https://uofa.net/morrison/data/cpb-operating-conditions-5pts",
    "https://uofa.net/morrison/data/hemolysis-experimental-reference"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-grid-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence study — Richardson extrapolation on RH index",
      "description": "Three-level structured mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.2M cells). Richardson extrapolation yields GCI < 1.8% on RH for all five operating points. Monotonic convergence confirmed at each point. Discretization error bounded within acceptance threshold."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA experimental dataset",
      "description": "Computational RH predictions compared against FDA-published experimental hemolysis measurements for the generic centrifugal pump at five flow-speed combinations (3, 4.5, 6 L/min at 2500, 3500 RPM plus one off-design point). Mean absolute error 6.3%, all predictions within ±15% of measured values. RH < 1 criterion satisfied at all worst-case operating conditions."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-uq-campaign",
      "type": "ValidationResult",
      "name": "Uncertainty quantification and sensitivity campaign — LHS over 12 parameters",
      "description": "Latin hypercube sampling (n=512 runs) over 12 geometric and boundary-condition parameters. Sobol first-order sensitivity indices computed for RH at each operating point. Dominant contributors: impeller tip clearance (S1=0.41), inlet flow angle (S1=0.29). Total-order indices confirm negligible higher-order interactions. 95th-percentile RH across parameter space remains below 1.0, supporting acceptance decision. Full sensitivity indices tabulated in Appendix C of the validation report. Note: these UQ results are referenced narratively; a structured hasSensitivityAnalysis node was not separately registered in this credibility package."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-04-code-verification",
      "type": "ValidationResult",
      "name": "Code verification — method of manufactured solutions",
      "description": "Method of manufactured solutions applied to the Navier-Stokes and power-law hemolysis transport equations. Observed order of accuracy 1.96 (expected 2.0 for second-order scheme). Residual norms converge to machine precision. Software version ANSYS Fluent 2022R2 with UDF hemolysis model v1.4."
    }
  ],
