  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2. The hemolysis benchmark validation demonstrates RH prediction error below the 0.10 threshold at all five operating points, and the GCI study confirms discretisation error below 2 %. The assessment team noted that the primary benchmark validation was conducted under the release-candidate solver build (ansys-cfx-2026-q1-build-7-rc2) rather than the released build (ansys-cfx-2026-q1-build-7), but judged the single patch-level difference as not affecting hemolysis scalar transport results. On this basis the package is accepted at Medium assurance level for MRL 2.",
