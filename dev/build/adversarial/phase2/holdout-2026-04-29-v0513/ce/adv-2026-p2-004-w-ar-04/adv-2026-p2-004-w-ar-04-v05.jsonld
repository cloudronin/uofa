  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped to not-assessed consistent with MRL 2 requirements. The hemolysis bench validation (vr-hemolysis-bench-2026q1) demonstrates RH predictions within ±12% of in-vitro measurements across all five operating points. The pressure-rise validation corroborates flow-field accuracy. The credibility assessment team noted that the primary hemolysis validation run was executed under build ansys-cfx-15-build-2026-q1-build-7-rc2 rather than the released build ansys-cfx-15-build-2026-q1-build-7; however, the change manifest for the RC-to-release transition documents only a post-processing license check patch and a documentation correction with no solver kernel modifications. On this basis the team judged the validation evidence to remain applicable to the released model of record and accepted the package without re-running the validation suite under the released build.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
