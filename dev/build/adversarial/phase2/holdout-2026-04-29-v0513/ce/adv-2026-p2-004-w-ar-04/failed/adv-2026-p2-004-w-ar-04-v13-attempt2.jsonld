  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements for a Class II device with medium model influence. The CFD model demonstrates adequate predictive capability for pump-induced hemolysis under CPB conditions. The hemolysis benchmark validation (vr-hemolysis-benchmark-01) was conducted under the rc2 pre-release build of ANSYS CFX 15.0 rather than the released build; however, the assessment team determined that internal regression testing confirmed no functional differences between the two builds, and the results are considered transferable to the released version without re-running. The pressure-head validation was confirmed under the released build. On this basis the COU is accepted at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
