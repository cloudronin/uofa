  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-cpb-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/cardiovascular-cfd-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately scoped out at MRL 2. Validation evidence demonstrates CFD predictions of relative hemolysis index are within the ±15% acceptance band across all five CPB operating points. The model is accepted as sufficiently credible to support identification of worst-case hemolysis conditions for the Class II CPB device submission. Note: validation runs were executed under solver build ansys-cfx-2026-q1-build-7-rc2; the team has assessed this as effectively equivalent to the released build ansys-cfx-2026-q1-build-7 given the minor nature of the patch-level change to the preconditioner tolerance, and has accepted the evidence without re-running validation under the released build.",
    "decidedAt": "2026-04-19T00:00:00Z"
