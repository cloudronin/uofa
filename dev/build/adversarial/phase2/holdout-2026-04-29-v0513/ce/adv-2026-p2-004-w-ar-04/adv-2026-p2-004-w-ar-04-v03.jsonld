  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 4. Validation results demonstrate RHI prediction accuracy within the ±15% acceptance criterion across the full 5-point operating map. The assessment team notes that the primary hemolysis benchmark validation (VR-01) was executed under solver build ansys-cfx-15-build-2026-q1-build-7-rc2, one patch revision prior to the released build ansys-cfx-15-build-2026-q1-build-7. Internal change log CR-2026-0041 characterises the delta as documentation-only with no solver kernel recompilation, and the team considers the two builds effectively equivalent for this assessment. On this basis the credibility package is accepted and the model is considered fit for the stated COU.",
