  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Validation results demonstrate mean absolute error of 8.3% for the relative hemolysis index across 5 operating points, satisfying the RH < 1.0 acceptance criterion. The 6 non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The assessment team notes that validation runs were executed under solver build 2026-q1-build-7-rc2, one patch prior to the released build 2026-q1-build-7. The intervening patch was characterised by the vendor as a GUI rendering fix with no solver numerics changes; the team accepted this characterisation without independent verification and without re-executing validation runs under the released build. The overall credibility package is judged sufficient to support the COU decision at Medium assurance level.",
