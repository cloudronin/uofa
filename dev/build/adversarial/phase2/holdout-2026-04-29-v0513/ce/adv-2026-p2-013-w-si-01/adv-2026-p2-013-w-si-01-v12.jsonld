      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index must agree with measured RH index within 15% across all 5 operating points.",
      "rationale": "Maximum relative error in RH index across the 5 operating points was 11.4% (at 6 LPM / 4000 RPM). All other points within 8%. Acceptance criterion of 15% satisfied."
