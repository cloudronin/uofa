      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release notes sufficient for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with documented QA procedures, version-controlled releases, and publicly available verification benchmarks. Achieved level exceeds required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via at least one benchmark case (e.g., manufactured solution or canonical flow).",
      "rationale": "ANSYS Fluent has been verified against multiple ASME V&V 20 benchmark cases including lid-driven cavity and backward-facing step. Published verification reports confirm correct discretization of Navier-Stokes equations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three mesh refinement levels; GCI for hemolysis index QoI must be below 5%.",
      "rationale": "Three mesh levels (2.1M, 5.8M, 14.2M cells) were evaluated at the nominal operating point (5 L/min, 2400 RPM). Richardson extrapolation yielded GCI of 3.2% for the scalar stress-based hemolysis index, satisfying the 5% threshold. Fine-mesh solution selected for all subsequent analyses."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with measured flow rates, rotational speeds, and fluid properties; deviations from nominal must be quantified.",
      "rationale": "FDA benchmark experimental data (Hariharan et al. 2011) provides fully documented test conditions including flow rates (2.5–7 L/min), rotational speeds (2000–3500 RPM), fluid temperature, and blood analog viscosity. Measurement uncertainties are reported for all quantities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined experimental and numerical uncertainty bands at all 5 operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) agreed with experimental values within ±18% across all 5 flow-speed combinations, well within the combined uncertainty band of ±25%. Relative hemolysis index RH < 1 confirmed for all worst-case operating conditions, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs (NIH, pressure rise, shear stress distribution) must be directly linked to the COU decision quantity (worst-case hemolysis identification).",
      "rationale": "The normalized index of hemolysis is the primary regulatory metric for CPB device hemolysis assessment per FDA guidance. Pressure-flow characteristics provide secondary validation. Both QoIs are directly relevant to identifying worst-case operating conditions as required by COU1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
