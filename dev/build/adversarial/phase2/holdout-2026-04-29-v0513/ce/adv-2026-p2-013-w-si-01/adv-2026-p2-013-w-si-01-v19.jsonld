      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression test suite.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional licence with documented version control and regression tests confirming solver build integrity. Gradation 1 requirement met at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark cases (e.g., lid-driven cavity, pipe flow) demonstrating correct implementation of governing equations.",
      "rationale": "Solver verified against three ASME V&V 20 benchmark cases including Poiseuille flow and rotating-frame centrifugal flow. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (hemolysis index) across at least three mesh densities; GCI < 5% on fine grid.",
      "rationale": "Three mesh levels (2.1M, 5.8M, 14.2M cells) evaluated using Richardson extrapolation. GCI on fine mesh = 3.1% for hemolysis index, satisfying the < 5% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, blood analogue fluid properties) must be documented and match simulated boundary conditions within stated tolerances.",
      "rationale": "All five operating points (2–6 L/min, 2000–3500 RPM) replicated in vitro using porcine blood at 37°C. Boundary condition deviations < 1.5% across all cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all five operating points.",
      "rationale": "CFD-predicted hemolysis index deviates from bench measurements by 4–12% across all five operating points. Mean absolute error 7.3%. Acceptance criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) must be directly linked to the clinical endpoint and the regulatory acceptance criterion.",
      "rationale": "RH index is the FDA-accepted metric for comparative hemolysis assessment. Direct mapping from CFD shear-stress field to power-law hemolysis model is documented and peer-reviewed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and cover the intended operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry across the full 5-point operating envelope specified in the COU. No geometric or operating-range extrapolation required."
    },
