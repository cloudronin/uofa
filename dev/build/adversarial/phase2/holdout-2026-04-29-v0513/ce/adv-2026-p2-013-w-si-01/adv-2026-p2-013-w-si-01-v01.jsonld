      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI across three systematically refined meshes.",
      "rationale": "Three mesh levels (3.2M, 8.7M, 22.4M cells) were evaluated using Richardson extrapolation. GCI for the relative hemolysis index was 3.1% between fine and medium meshes. Medium mesh (8.7M cells) selected as production mesh, balancing accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match CFD boundary conditions within ±5%.",
      "rationale": "Five operating points (2–6 L/min, 2000–3500 RPM) were tested in vitro using the FDA generic pump geometry. Measured inlet/outlet pressures and flow rates were applied as CFD boundary conditions. Fluid viscosity and density matched to bovine blood at 37°C within ±3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) agrees with experimental measurements within ±15% across all 5 operating points.",
      "rationale": "CFD-predicted RH values compared against in-vitro hemolysis measurements at all 5 operating conditions. Maximum deviation was 11.4% at the highest flow-speed combination. Mean absolute error was 7.2%. Acceptance criterion of ±15% met at all points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) is directly linked to the clinical endpoint and regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index RH is the regulatory QoI for CPB device submissions per FDA guidance. The model predicts shear stress history along streamlines, integrated using the Giersiepen-Wurzinger power-law model to yield RH. This QoI is identical to the submission criterion (RH < 1 relative to predicate)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
