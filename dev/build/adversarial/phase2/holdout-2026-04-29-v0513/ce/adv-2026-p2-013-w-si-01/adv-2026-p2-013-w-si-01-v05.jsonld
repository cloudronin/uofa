  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented QA procedures and regression test suite demonstrating solver stability across relevant flow regimes.",
      "rationale": "ANSYS Fluent v19.2 used with documented QA procedures. Version control maintained throughout study. Regression tests confirm solver stability for blood-analog fluid simulations at all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified against canonical benchmark cases for rotating machinery flows and non-Newtonian fluid transport relevant to hemolysis prediction.",
      "rationale": "Code verification performed against FDA benchmark pump dataset and published analytical solutions for rotating Couette flow. Discretization schemes verified to second-order accuracy via Richardson extrapolation on canonical cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be less than 5% for hemolysis index QoI across all five operating conditions.",
      "rationale": "Three-level mesh refinement study conducted (1.2M, 4.8M, 19.2M cells). GCI for hemolysis index ranges from 1.8% to 3.4% across all operating points, satisfying the 5% threshold. Asymptotic convergence ratio confirms solution is in the convergent regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match simulated operating points within ±5% for flow rate and rotational speed.",
      "rationale": "Experimental data sourced from FDA benchmark study (Hariharan et al. 2011). All five flow-speed combinations replicated within ±2.1% for flow rate and ±1.8% for rotational speed. Fluid temperature and hematocrit levels documented and matched in simulation boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within two experimental standard deviations across all five operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against experimental measurements from five independent laboratories. Model predictions fall within two experimental standard deviations for 4 of 5 operating points; the fifth point shows agreement within 2.3 standard deviations, which is deemed acceptable given inter-laboratory variability of 38%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in the model (NIH, shear stress distribution, exposure time) must be directly traceable to the clinical hemolysis endpoint and the RH < 1 acceptance criterion.",
      "rationale": "Primary QoI is the relative hemolysis index (RH = NIH_device / NIH_predicate). Secondary QoIs include volume-averaged shear stress and Lagrangian exposure time. All three QoIs are established surrogates for clinical hemolysis in ASME V&V 40 literature and directly support the RH < 1 decision criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry family and overlapping flow-speed envelope as the COU operating range.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the same device family as the COU. Operating envelope for validation (2–7 L/min, 2000–3500 RPM) fully encompasses the five COU operating points. Blood-analog fluid (glycerol-water mixture) used in experiments; correction factors for whole blood viscosity applied and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal quantification of iterative solver error beyond residual monitoring is not required.",
      "rationale": "Solver residuals monitored to convergence criterion of 1e-6 for all equations. Formal iterative error quantification not required at MRL 2; residual monitoring sufficient to confirm solution convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error analysis is not required provided analyst qualifications are documented.",
      "rationale": "Analyst team holds documented CFD training and has published peer-reviewed work on blood pump hemolysis simulation. Formal use-error analysis not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty quantification beyond qualitative justification of turbulence model selection is not required.",
      "rationale": "SST k-omega turbulence model selected based on published sensitivity studies for centrifugal blood pump flows. Qualitative justification sufficient at MRL 2; formal model form UQ not required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, boundary conditions, material properties) must be traceable to documented sources with stated uncertainty bounds.",
      "rationale": "Pump geometry sourced from FDA benchmark CAD files (publicly available). Boundary conditions derived from experimental test rig measurements. Blood analog viscosity characterized via rheometry with reported uncertainty of ±3%. All inputs documented in simulation plan with traceability matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal characterization of test sample variability beyond lot documentation is not required.",
      "rationale": "Experimental validation used blood-analog fluid from documented lots. Formal sample variability characterization not required at MRL 2; lot documentation sufficient."
    },
    {
