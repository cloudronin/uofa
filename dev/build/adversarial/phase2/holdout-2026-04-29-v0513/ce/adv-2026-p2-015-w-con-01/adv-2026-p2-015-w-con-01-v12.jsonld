  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated, FDA-recognized software tool with documented version control, regression testing, and formal release procedures. Internal SQA records confirm that the specific solver version used in this study was subject to full regression testing prior to release. Version tracking and audit trails are maintained in the project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Code verification was performed using the method of manufactured solutions (MMS) for the incompressible Navier-Stokes equations. Observed order of accuracy was 1.97, consistent with the theoretical second-order accuracy of the finite-volume discretization scheme. Verification cases are documented in the V&V report appendix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Grid convergence index (GCI) analysis was performed on three systematically refined meshes (2.1M, 6.8M, and 19.4M cells). GCI values for the scalar stress-based hemolysis index were below 3.2% on the medium mesh, which was selected for production runs. Richardson extrapolation confirmed monotonic convergence with an apparent order of 1.89."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Experimental test conditions for the validation dataset were conducted at five operating points (flow rates: 3, 4, 5, 6, 7 L/min; rotational speeds: 2000, 2500, 3000 RPM) matching the intended COU envelope. Temperature was maintained at 37°C ± 0.5°C. Hematocrit was controlled at 30% ± 2%. All conditions are documented in the experimental protocol and traceable to calibrated instrumentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Simulation predictions of the normalized index of hemolysis (NIH) were compared against experimental measurements at all five operating points. The maximum relative error was 14.3%, within the accepted tolerance for hemolysis modeling. The relative hemolysis index RH was below 1.0 at all operating points, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The primary quantity of interest — the normalized index of hemolysis (NIH) — is directly relevant to the clinical decision context. NIH is an FDA-recognized metric for blood pump hemolysis assessment. The scalar stress-based power-law hemolysis model (Giersiepen et al.) has been validated in the literature for similar pump geometries and operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Validation activities were performed on the FDA generic centrifugal blood pump geometry under operating conditions spanning the full COU envelope. The validation dataset was generated specifically for this device class and operating regime, providing high relevance to the intended COU. Geometric fidelity between the validation and production models was confirmed by CAD comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence per ASME V&V 40 Table 3.",
      "rationale": "Numerical solver error was not formally assessed as a standalone factor at MRL 2. However, a qualitative assessment was conducted: iterative convergence was monitored through residual norms (all below 1e-5) and mass imbalance (below 0.01%). Round-off error is considered negligible given double-precision arithmetic and the scale of the hemolysis index values. The team's expert judgment, informed by analogous pump simulations in the literature and internal benchmarking against the NIST pipe flow test case, supports the conclusion that numerical solver errors do not materially affect the credibility of the hemolysis predictions for this COU. This qualitative assessment is consistent with the level of rigor expected at MRL 2 for medium-influence models, and the team is satisfied that solver error is not a material source of uncertainty in the context of the accepted RH < 1 criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 per ASME V&V 40 scoping guidance for Class II devices.",
      "rationale": "Use error was scoped out of the formal assessment at MRL 2. Simulation inputs were reviewed by a second analyst and all boundary conditions were verified against the experimental protocol prior to production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The RANS k-omega SST turbulence model was selected based on its established performance for rotating machinery flows and prior validation studies in centrifugal blood pump literature. The power-law hemolysis model (Giersiepen 1990) was applied as the standard model for this device class. Model form uncertainty is acknowledged but considered acceptable given the validation evidence at the operating conditions of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "All model inputs — including fluid viscosity, density, rotational speed, inlet flow rate, and outlet pressure — were derived from traceable sources. Blood analog fluid properties were measured at 37°C and documented. Sensitivity analysis on the power-law hemolysis model constants confirmed that the RH < 1 acceptance criterion is robust to ±15% variation in the empirical coefficients."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 per ASME V&V 40 scoping guidance.",
      "rationale": "Test sample characterization was not required at MRL 2 for this factor. The experimental protocol specifies the use of bovine blood with controlled hematocrit, and sample preparation procedures are documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 per ASME V&V 40 scoping guidance.",
      "rationale": "Equivalency of input parameters between the validation experiment and the COU simulation was confirmed at a qualitative level. Fluid properties, operating conditions, and geometric parameters are within the validated range. Formal equivalency assessment is not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis model applied to the FDA generic centrifugal blood pump under CPB conditions is accepted at MRL 2. Seven of thirteen factors were formally assessed; all seven achieved levels meeting or exceeding their required levels. Six factors were scoped out or not assessed per ASME V&V 40 guidance for MRL 2 Class II devices with medium model influence. The relative hemolysis index RH was below 1.0 at all five operating points, satisfying the acceptance criterion. The assessment team concludes that the model has sufficient credibility to support the intended use decision.",
