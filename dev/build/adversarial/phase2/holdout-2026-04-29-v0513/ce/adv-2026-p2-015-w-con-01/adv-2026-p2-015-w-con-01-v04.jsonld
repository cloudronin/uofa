  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; all seven achieved their required Gradation levels at Model Risk Level 2. Six factors were scoped out as not required at MRL 2 per Table 3. The numerical solver error factor was evaluated through a thorough qualitative review of convergence histories and solver settings, and the team unanimously concluded that solver errors do not materially affect the hemolysis index predictions. All assessed factors meet or exceed required levels, and the qualitative evidence for the remaining factor is judged sufficient. The model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
