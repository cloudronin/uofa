    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation software must be verified under a documented quality management system with traceable version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 19.2 is used under an ISO 9001-compliant QMS. Version control is maintained via institutional repository with tagged releases. Regression test suite covers all active solver modules. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Code verification must demonstrate correct numerical implementation via benchmark problems with documented order-of-accuracy results at Gradation 2.",
      "rationale": "Order-of-accuracy testing performed against the Taylor-Green vortex benchmark. Observed spatial convergence rate of 1.94 (expected 2.0 for second-order scheme). Temporal convergence confirmed. Exceeds Gradation 2 requirement; Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Discretization error must be quantified via mesh refinement study with GCI or equivalent metric reported at Gradation 2.",
      "rationale": "Three-level mesh refinement study conducted (1.2M, 4.8M, 19.2M cells). Grid convergence index (GCI) computed per Celik et al. 2008. GCI for hemolysis index QoI is 3.1%, within the 5% threshold for Gradation 2. Apparent order of convergence p = 1.87."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must be documented and traceable to the COU operating envelope at Gradation 2.",
      "rationale": "In-vitro test conditions (flow rates 2.5–7.5 L/min, rotational speeds 2000–3500 RPM, blood analog fluid at 37°C) are fully documented and span the COU operating envelope. Traceability to device IFU confirmed. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation outputs must be compared against experimental data with quantitative error metrics reported at Gradation 2.",
      "rationale": "Predicted relative hemolysis index compared against five experimental operating points. Mean absolute error of 8.2% with maximum deviation of 14.1% at the 3500 RPM / 2.5 L/min condition. All predictions within acceptable uncertainty bounds for Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the clinical decision at Gradation 2.",
      "rationale": "The relative hemolysis index (RH) is the primary QoI and is directly linked to the clinical hemolysis endpoint. RH is computed from the Giersiepen-Wurzinger power-law model applied to Lagrangian particle tracks. Direct relevance to device acceptance criterion (RH < 1) confirmed. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the COU to support credibility at Gradation 2.",
      "rationale": "Validation experiments used the identical FDA generic centrifugal pump geometry operated within the COU flow-speed envelope. Blood analog viscosity and density matched physiological values. Geometric fidelity and operating condition overlap satisfy Gradation 2 relevance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "rationale": "A comprehensive qualitative assessment of numerical solver error was performed by the modelling team. Iterative convergence was monitored across all simulations; residuals for continuity, momentum, and turbulence quantities were reduced by at least four orders of magnitude in each run. Double-precision arithmetic was employed throughout to minimise round-off accumulation. Iterative solver settings were cross-checked against ANSYS Fluent best-practice guidelines for rotating machinery. The assessment team determined, based on collective engineering judgement and review of convergence histories, that solver-introduced errors are negligible relative to discretization and model-form uncertainties for this class of problem. No structured Gradation-level scoring was applied to this factor, as the team concluded that the qualitative evidence base was sufficient to support the overall Accepted determination at Model Risk Level 2 without formal level assignment.",
      "acceptanceCriteria": "Numerical solver error must be demonstrated to be negligible or bounded relative to other error sources, consistent with the model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at Model Risk Level 2 for this factor.",
      "rationale": "Use error assessment scoped out at MRL 2 per ASME V&V 40 Table 3 guidance. Operator training records maintained separately."
    },
    {
