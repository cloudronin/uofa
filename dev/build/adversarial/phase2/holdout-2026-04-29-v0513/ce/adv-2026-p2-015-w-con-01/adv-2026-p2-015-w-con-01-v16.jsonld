  "signature": "ed25519:b2e7f1a4c9d3e8b5f0a2c6d4e1b8f3a7c5d9e2b4f6a0c8d1e5b3f7a9c2d4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software quality assurance procedures documented and traceable to version-controlled solver releases; regression testing suite executed for each solver build.",
      "rationale": "ANSYS Fluent 2022R2 is used under an ISO 9001-certified QMS. Solver regression tests covering benchmark cases (lid-driven cavity, pipe flow, rotating disk) are executed and archived for each build. Version control and change logs are maintained. Required Gradation 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code verification demonstrates correct numerical implementation via comparison to manufactured or analytical solutions for rotating-frame Navier-Stokes equations.",
      "rationale": "Method of manufactured solutions applied to the rotating-reference-frame formulation. Spatial order of convergence confirmed at 1.97 (theoretical: 2.0) for velocity components. Temporal discretization verified via analytical transient pipe-flow solution. Required Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) computed for hemolysis index and wall shear stress on at least three systematically refined meshes; GCI < 5% on fine grid.",
      "rationale": "Three systematically refined meshes (2.1M, 6.8M, 18.4M cells) were generated with refinement ratio r = 1.47. GCI for the scalar hemolysis index at worst-case operating point: 2.3% (fine-to-medium) and 4.1% (medium-to-coarse). Richardson extrapolation applied. Achieved Gradation 3 exceeds required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol, pump speed, flow rate) are documented and match the intended COU operating envelope.",
      "rationale": "Bench-top experiments conducted using porcine blood at 37 °C, hematocrit 33 ± 2%, heparin anticoagulation per ASTM F1841. Five flow-speed combinations spanning the COU envelope tested in triplicate. Boundary conditions applied in CFD match documented experimental conditions within 1.5%. Required Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index compared to experimental measurements; normalized index of agreement ≥ 0.85 across all operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared to experimental measurements at five operating points. Mean absolute relative error: 8.4%. Normalized index of agreement: 0.91. All predictions within experimental uncertainty bounds (±15%). Required Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantities of interest (hemolysis index, wall shear stress distribution) are directly linked to the clinical endpoint and acceptance criterion (RH < 1).",
      "rationale": "The primary QoI is the scalar hemolysis index derived from the Giersiepen-Wurzinger power-law model integrated along Lagrangian particle trajectories. This QoI directly computes the relative hemolysis index (RH) used in the acceptance criterion. Clinical relevance is established through published correlation with in-vivo hemolysis markers. Required Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities performed on a geometry and operating regime sufficiently representative of the COU to support extrapolation of credibility findings.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the same geometry used in the COU. Operating conditions span the full COU envelope. Fluid properties (porcine blood as human blood surrogate) are standard for hemolysis bench testing. Geometric similarity confirmed by direct CAD comparison. Required Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence of residuals to at least 10^-5 for all transport equations; mass imbalance < 0.01%.",
      "rationale": "All simulations converged to scaled residuals below 1×10^-6 for continuity and momentum equations. Mass imbalance at inlet/outlet interfaces: 0.003%. Pressure-velocity coupling via SIMPLE algorithm with second-order upwind discretization. Convergence monitored via hemolysis index monitor point stabilization. Achieved Gradation 2 exceeds required Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at Model Risk Level 2 for this factor category per ASME V&V 40 Table 3.",
      "rationale": "Use error assessment is not required at MRL 2 for a Class II device with medium model influence. Scoped out per project credibility plan approved by regulatory affairs team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model selection justified for rotating blood pump flow regime; hemolysis power-law model applicability documented for the shear-exposure range encountered.",
      "rationale": "SST k-ω turbulence model selected based on published benchmarking studies for rotating blood pump geometries (Hariharan et al. 2011). Hemolysis model applicability confirmed for shear stress range 1–800 Pa and exposure times 1–500 ms, consistent with particle tracking results. Required Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis index predictions to key input parameters (blood viscosity, pump rotational speed, inlet flow rate) quantified across the COU operating envelope.",
      "rationale": "A comprehensive qualitative assessment of model input uncertainty was conducted by the simulation team in lieu of a formal parametric sensitivity study. Subject-matter experts reviewed the potential influence of blood viscosity variation (±10% Newtonian approximation), rotational speed tolerance (±50 RPM), and inlet velocity profile assumptions on the hemolysis index. Consensus judgment from three independent CFD engineers concluded that input uncertainties are unlikely to shift RH predictions by more than 12%, which remains within the acceptance margin. The qualitative assessment draws on published sensitivity analyses for analogous centrifugal pump geometries and is considered sufficient to establish input credibility at the project's risk level. Formal quantitative uncertainty propagation was not performed but is documented as a monitoring item for future model updates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at Model Risk Level 2 for this factor category per ASME V&V 40 Table 3.",
      "rationale": "Test sample characterization beyond standard hematocrit and anticoagulation documentation is not required at MRL 2. Scoped out per credibility plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at Model Risk Level 2 for this factor category per ASME V&V 40 Table 3.",
      "rationale": "Formal equivalency analysis of input parameters between validation and COU contexts is not required at MRL 2. The validation and COU share the same geometry and operating envelope, making equivalency self-evident. Scoped out per credibility plan."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels at Model Risk Level 2. Six factors are appropriately scoped out or not assessed per the approved credibility plan for a Class II device with medium model influence. The CFD model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump. Predicted hemolysis indices satisfy the RH < 1 acceptance criterion across all five COU operating points. The assessment team unanimously accepts the simulation evidence as adequate to support the regulatory submission.",
