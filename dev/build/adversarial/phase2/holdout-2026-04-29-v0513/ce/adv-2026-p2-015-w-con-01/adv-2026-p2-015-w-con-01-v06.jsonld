  "signature": "ed25519:b2e4a6c8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software quality assurance practices documented and version-controlled; solver validation suite executed with no critical failures.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented QA procedures. Version control and audit trails are maintained throughout the simulation campaign. All solver regression tests passed prior to the study execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code verification performed against at least one analytical or manufactured solution relevant to rotating flow.",
      "rationale": "Order-of-accuracy testing was performed using the method of manufactured solutions for the incompressible Navier-Stokes equations in rotating reference frames. Observed convergence rates matched theoretical second-order expectations, confirming correct code implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI; GCI < 5% on fine mesh.",
      "rationale": "A three-level mesh refinement study was conducted with element counts of 2.1M, 5.8M, and 14.2M cells. GCI values for the scalar stress-based hemolysis index were 3.8% (medium) and 1.2% (fine), demonstrating excellent discretization control. The 5.8M mesh was selected as the production mesh balancing accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions documented and shown to bracket the COU operating envelope.",
      "rationale": "Benchmark experimental data from the FDA Critical Path initiative were collected at five flow-speed operating points spanning 2.5–6.0 L/min and 2500–3500 RPM, fully encompassing the CPB clinical operating envelope. Temperature, fluid viscosity, and hematocrit were controlled and reported."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predictions within 25% of experimental measurements across all operating points.",
      "rationale": "Predicted NIH values were compared against experimental measurements at all five operating points. Maximum deviation was 18.4% and mean absolute error was 11.2%, both within the 25% acceptance threshold. Systematic underprediction at high RPM was noted and attributed to known limitations of the power-law hemolysis model at extreme shear conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation directly correspond to the clinical decision metric (relative hemolysis index RH).",
      "rationale": "The primary validation QoI (normalized index of hemolysis, NIH) is directly related to the COU decision metric (relative hemolysis index RH < 1). Both metrics derive from the same experimental hemolysis measurement protocol, ensuring that validation performance on NIH is directly informative of COU decision quality."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation geometry and operating conditions sufficiently similar to COU device and operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which shares key geometric features (impeller diameter, volute design, gap dimensions) with the COU device. Operating conditions in validation overlap with the COU envelope. Geometric differences were characterized through sensitivity analysis confirming hemolysis index insensitivity to minor dimensional variations within manufacturing tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Residual convergence below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "All simulations achieved residual convergence to 1e-6 for continuity, momentum, and turbulence equations. Global mass imbalance was below 0.005% in all cases. Iterative solver error is negligible relative to discretization uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 per ASME V&V 40 Table 3. The medium model influence classification and availability of experimental confirmation data reduce the consequence of potential use errors to an acceptable level for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty assessed through comparison of turbulence models and hemolysis constitutive equations; sensitivity to model form documented.",
      "rationale": "Model form credibility was evaluated through a comprehensive qualitative assessment of the governing equation choices for this COU. The k-omega SST turbulence closure was selected based on its established performance in rotating machinery flows and documented superiority over k-epsilon variants in adverse pressure gradient regions relevant to pump diffuser passages. The Giersiepen-Wurzinger power-law hemolysis model was evaluated against the Arora mechanistic model; both produced hemolysis index predictions within the experimental uncertainty band. Sensitivity of the relative hemolysis index RH to turbulence model choice was found to be low (less than 8% variation across models), supporting the conclusion that model form uncertainty does not materially affect the binary RH < 1 acceptance decision. The qualitative weight-of-evidence from the turbulence model comparison, the hemolysis model cross-check, and the physical plausibility of predicted flow structures collectively support adequate model form credibility for this COU at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU; boundary condition uncertainty addressed through conservative bounding approach.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Boundary conditions were set using measured clinical operating data with conservative bounding values applied to inlet velocity profiles and fluid properties."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark dataset sample size accepted as sufficient for comparative validation.",
      "rationale": "Formal test sample adequacy analysis is scoped out at MRL 2. The FDA Critical Path experimental dataset provides n=5 independent experimental replicates per operating point, consistent with published practice for hemolysis benchmark studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; dimensional similarity between validation geometry and COU device confirmed through geometric analysis.",
      "rationale": "Equivalency of input parameters between validation and COU conditions is not formally required at MRL 2. A geometric similarity review confirmed that key non-dimensional parameters (Reynolds number, flow coefficient, head coefficient) are within 15% between validation and COU operating points, supporting the applicability of validation evidence to the COU."
    }
  ],
