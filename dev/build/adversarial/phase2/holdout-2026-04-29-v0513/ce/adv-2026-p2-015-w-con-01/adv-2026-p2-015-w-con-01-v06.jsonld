  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for CPB hemolysis prediction is accepted for the stated COU at MRL 2. Seven of thirteen credibility factors were formally assessed; all achieved levels met or exceeded required levels. The six remaining factors were appropriately scoped out or not assessed per MRL 2 requirements. Discretization error exceeded the required level (achieved level 3 vs required level 2), providing additional confidence margin. Output comparison demonstrated NIH predictions within 18.4% of experimental measurements across all operating points, satisfying the 25% acceptance threshold. The model is judged fit for purpose to identify worst-case hemolysis operating conditions and support the relative hemolysis index comparison against the predicate device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
