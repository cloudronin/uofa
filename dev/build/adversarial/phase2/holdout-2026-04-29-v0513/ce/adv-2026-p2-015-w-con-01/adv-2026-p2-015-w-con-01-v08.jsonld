  "signature": "ed25519:b7d3e9f1a4c8e2b5d0f7a3c6e9b2d5f8a1c4e7b0d3f6a9c2e5b8d1f4a7c0e3b6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified against at least one published benchmark; version control and audit trail documented.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional SQA protocol. Version control documented in project repository. Solver validated against FDA benchmark nozzle problem (ASME V&V 20). Achieved Gradation 2 consistent with MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for primary transport equations demonstrated on canonical problem.",
      "rationale": "Method of manufactured solutions applied to incompressible Navier-Stokes solver. Second-order spatial accuracy confirmed for velocity and pressure fields. Results consistent with published Fluent verification suite."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for primary QoI (relative hemolysis index) across at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed: coarse (4.2M cells), medium (11.7M cells), fine (31.4M cells). GCI for relative hemolysis index was 2.3% between medium and fine meshes. Richardson extrapolation applied. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions and fluid properties documented and matched in simulation to within measurement uncertainty.",
      "rationale": "FDA benchmark experimental conditions reproduced: inlet flow rates 2.5–6.0 L/min, rotational speeds 2000–3500 RPM. Blood analog fluid (glycerin-water) properties matched to published values. Inlet turbulence intensity estimated from experimental rig geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated QoIs compared against experimental measurements with agreement within combined simulation and experimental uncertainty bands.",
      "rationale": "Pressure-rise predictions agree within 4.1% of experimental values across all 5 operating points. Relative hemolysis index predictions fall within experimental scatter bands for 4 of 5 conditions; one outlier attributed to documented experimental variability. Overall comparison satisfactory at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly map to decision QoIs used in the COU.",
      "rationale": "Relative hemolysis index (RHI) used in validation is the same metric applied in the COU acceptance criterion (RH < 1 vs. predicate device). Pressure rise used as secondary QoI to confirm overall flow field fidelity. Direct relevance established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted at conditions sufficiently similar to COU operating envelope to support extrapolation claim.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry at operating conditions spanning the COU envelope. Geometric similarity between validation and COU device confirmed. Flow regime (Reynolds number range) overlaps with COU conditions. Sufficient relevance for MRL 2 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "A qualitative assessment of numerical solver error was conducted by the credibility team. Iterative residuals were monitored throughout all simulations and demonstrated monotonic reduction over the solution history. The team reviewed convergence plots for all 5 operating points and concluded that solver-induced error is negligible relative to discretization and model-form uncertainty. Mass imbalance remained below 0.005% in all cases. The assessment team determined, based on engineering judgment and review of solution histories, that numerical solver error does not materially affect the credibility conclusion. This factor was evaluated through structured expert review of convergence diagnostics and is considered satisfactorily addressed for the purposes of this MRL 2 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition inputs verified against source documentation.",
      "rationale": "Independent review of simulation setup performed by second analyst. Boundary conditions, material properties, and mesh topology verified against source experimental documentation. No discrepancies identified. Gradation 1 requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified; hemolysis power-law model applicability documented for operating shear stress range.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark comparisons for rotating machinery flows. Giersiepen-Wurzinger hemolysis power-law model applied; applicability range (shear stress 1–400 Pa, exposure time 0.001–1 s) confirmed to encompass COU operating conditions. Model form uncertainty acknowledged and consistent with MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of QoI to key uncertain inputs quantified; dominant inputs identified and bounded.",
      "rationale": "One-at-a-time sensitivity analysis performed for fluid viscosity, inlet turbulence intensity, and rotational speed. RHI sensitivity to viscosity (±5%) was largest at 3.2% RHI change. Inlet turbulence intensity showed negligible effect (<0.5%). Input uncertainty bounds documented and propagated through nominal simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used in validation are representative of the device population and operating conditions.",
      "rationale": "FDA benchmark experimental data obtained from standardized test protocol using traceable measurement equipment. Single pump specimen used in experiments; dimensional measurements documented. Sufficient for Gradation 1 requirement at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations are equivalent to those used in COU simulations.",
      "rationale": "Fluid properties, rotational speed settings, and flow rate boundary conditions are identical between validation and COU simulation setups. Geometric model uses same CAD source. Parameter equivalency confirmed by checklist review."
    }
  ],
