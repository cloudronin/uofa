  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "SQA level 2 requires documented version control, issue tracking, and regression test suite for the CFD solver.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented SQA procedures. Version control logs, regression test results, and issue tracking records were reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code verification at level 2 requires demonstration of correct implementation via benchmark problems with known analytical solutions.",
      "rationale": "Verification against Poiseuille flow and lid-driven cavity benchmarks confirmed second-order spatial accuracy. Residual norms converged below 1e-6 for all cases. Results are consistent with published ANSYS verification documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the primary QoI (hemolysis index) across three systematically refined meshes.",
      "rationale": "Three mesh levels (2.1M, 5.8M, 14.2M cells) were evaluated using Richardson extrapolation. GCI values ranged from 1.8% to 3.4% for the normalized hemolysis index, exceeding the MRL 2 threshold. Achieved level 3 reflects the systematic refinement study with quantified uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to permit comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark experimental data (Zhang et al. 2012) provides inlet flow rates, rotational speeds, and fluid properties for five operating points. Boundary conditions in the CFD model were set to match published experimental conditions within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized hemolysis index) must be within 25% of experimental reference values at all five operating points.",
      "rationale": "Predicted normalized hemolysis index values agreed with experimental references within 18% across all five flow-speed combinations. The relative hemolysis index RH remained below 1.0 for the candidate device relative to the predicate, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoI used in validation (normalized hemolysis index) must be directly traceable to the clinical decision metric (RH < 1).",
      "rationale": "The normalized hemolysis index is the FDA-accepted surrogate for in vivo hemolysis and is directly used in the RH < 1 acceptance criterion. Traceability from computational QoI to clinical endpoint is documented in the V&V plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must cover the operating envelope defined by the COU, including the five specified flow-speed combinations.",
      "rationale": "Validation experiments and simulations span the full operating envelope of 2–6 L/min flow rate and 2000–3500 RPM rotational speed, encompassing all five COU-specified operating points. No extrapolation beyond the validated domain is required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below solver-recommended thresholds and solution-independent of iteration count beyond convergence.",
      "rationale": "All simulations achieved residual convergence below 1e-6 for continuity and momentum equations. Solution monitoring of hemolysis index confirmed plateau within 500 iterations. Double-precision arithmetic was used throughout to minimize round-off accumulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category per ASME V&V 40 Table 3.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 for this device class and COU. The factor is scoped out per the MRL 2 assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form adequacy is evaluated through a qualitative review of turbulence model selection, hemolysis damage model applicability, and constitutive law fidelity relative to blood rheology under CPB conditions.",
      "rationale": "A comprehensive qualitative assessment of model form was performed by the V&V team and an independent reviewer with expertise in computational hemodynamics. The SST k-omega turbulence closure was selected based on its demonstrated performance in rotating machinery with adverse pressure gradients, as documented in the open literature. The power-law hemolysis damage model (Giersiepen et al.) was evaluated against alternative formulations (Arora, Taskin) and judged most appropriate for the shear-stress and exposure-time ranges encountered in centrifugal CPB pumps. Blood rheology was modeled as a Newtonian fluid at 37°C with viscosity 0.0035 Pa·s, which is standard practice for high-shear regions dominating hemolysis in this pump geometry. The qualitative assessment concluded that model form uncertainty is acceptable for the intended COU and does not constitute a material limitation on the Accepted decision. No structured gradation scoring was applied to this factor, as the team determined that the richness of the qualitative review provided sufficient assurance at MRL 2 without requiring formal level assignment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category per ASME V&V 40 Table 3.",
      "rationale": "Formal model input uncertainty quantification is not required at Model Risk Level 2. Nominal input values are taken from published FDA benchmark specifications and manufacturing drawings."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category per ASME V&V 40 Table 3.",
      "rationale": "Test sample characterization beyond what is reported in the FDA benchmark dataset is not required at MRL 2. The published dataset is considered sufficient for the intended validation comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category per ASME V&V 40 Table 3.",
      "rationale": "Equivalency of input parameters between validation and COU configurations is not formally required at MRL 2. Qualitative review confirmed no significant differences in operating regime between the validation dataset and the target COU."
    }
