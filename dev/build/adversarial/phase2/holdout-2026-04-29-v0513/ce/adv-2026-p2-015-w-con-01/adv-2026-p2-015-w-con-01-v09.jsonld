  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used for simulation must be documented and version-controlled; basic QA procedures must be in place consistent with MRL 2 expectations.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated platform with documented version control and release notes. Internal QA procedures confirm that the simulation environment was locked prior to the study, with input files archived in the project repository. Achieved Gradation 2 satisfies the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at a level consistent with MRL 2.",
      "rationale": "Benchmark verification cases including lid-driven cavity and rotating pipe flow were executed against published reference solutions. Residuals converged to less than 1e-5 in all cases. Numerical code verification is satisfied at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence must be demonstrated using at least three mesh densities; GCI must be reported for the primary quantity of interest.",
      "rationale": "A formal grid convergence index (GCI) study was performed using three mesh refinement levels (coarse: 4.2M cells, medium: 9.8M cells, fine: 21.3M cells). GCI for the normalized hemolysis index was 1.8%, well within the 5% threshold. The fine mesh was selected for production runs, achieving Gradation 3 which exceeds the required level of 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and shown to bracket the intended COU operating envelope.",
      "rationale": "Experimental hemolysis data were acquired at five flow-speed operating points (2 LPM/2000 RPM through 6 LPM/3500 RPM) that bracket the clinical CPB operating range. Test fluid (bovine blood, hematocrit 35±2%) and environmental conditions (37°C, controlled pH) are documented in the validation dataset. Gradation 2 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison between model predictions and experimental measurements must be performed for the primary QoI using an appropriate metric.",
      "rationale": "The normalized index of hemolysis (NIH) was compared between CFD predictions and experimental measurements across all five operating points. Mean absolute error was 8.3% with no systematic bias. Relative hemolysis index (RH) predictions were within experimental uncertainty bands at all operating points, satisfying Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoIs used in validation must be directly relevant to the COU decision criterion (RH < 1).",
      "rationale": "The primary QoI is the relative hemolysis index (RH), which is the direct acceptance criterion for the COU. Secondary QoIs include wall shear stress distribution and scalar dissipation rate, both mechanistically linked to erythrocyte damage. The QoIs are fully aligned with the COU decision criterion, satisfying Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and under conditions sufficiently representative of the COU to support extrapolation of credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump, which shares impeller topology and hydraulic scaling with the subject CPB device. Operating conditions in validation experiments overlap with the COU envelope. The degree of geometric and operational similarity supports Gradation 2 relevance for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor combination; scoped out per project credibility plan.",
      "rationale": "At Model Risk Level 2 with medium model influence, numerical solver error as a standalone factor beyond code verification is not required per the credibility plan. The commercial solver's iterative convergence was monitored in all runs (residuals < 1e-5), providing implicit assurance without formal separate assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; addressed through SQA procedures.",
      "rationale": "Use error assessment is subsumed within the software quality assurance factor at MRL 2. Analyst qualification records and simulation execution checklists are maintained in the project QA file, providing adequate assurance without a separate use error credibility factor assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The appropriateness of the constitutive model for blood rheology and the hemolysis power-law damage model must be evaluated against the COU physics and available literature evidence.",
      "rationale": "The selection of the Giersiepen-Wurzinger power-law hemolysis model and the shear-thinning Carreau-Yasuda blood viscosity model was evaluated through an extensive qualitative assessment of published CFD hemolysis literature. Seventeen peer-reviewed studies employing these model forms for centrifugal pump hemolysis prediction were reviewed; all demonstrate acceptable predictive performance for devices in the MRL 2 category. The model form selection is considered well-established for this class of problem, and the constitutive assumptions (continuum blood, dilute suspension, instantaneous damage accumulation) are judged appropriate for the bulk-flow hemolysis estimation task within the COU. The team conducted an expert elicitation session with two independent biofluid mechanics specialists who confirmed the model form choices are state-of-practice for regulatory CFD submissions of this type. This qualitative assessment provides high confidence in model form appropriateness commensurate with the COU requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for medium-influence classification.",
      "rationale": "Model input uncertainty quantification is not required at MRL 2 under medium model influence. Nominal input values (fluid properties, boundary conditions, geometric dimensions) are drawn from calibrated experimental measurements with documented traceability. Sensitivity of hemolysis predictions to input perturbations was informally checked and found to be low."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample characterization is documented in the validation dataset.",
      "rationale": "Formal test sample credibility assessment is not required at MRL 2. Blood sample preparation and characterization protocols are documented in the validation dataset metadata, including hematocrit measurement, storage conditions, and usage window post-collection."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 given the direct overlap between validation and COU operating conditions.",
      "rationale": "The operating conditions used in validation experiments directly overlap with the COU envelope, making a formal equivalency assessment unnecessary at MRL 2. The five experimental operating points were selected to bracket the worst-case hemolysis conditions identified in the COU, providing inherent equivalency assurance."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Model Risk Level 2. Seven of thirteen credibility factors were formally assessed; all seven meet or exceed their required gradation levels. The remaining six factors are not assessed, consistent with the MRL 2 credibility plan and the medium model influence classification. Grid convergence was rigorously demonstrated, experimental validation conditions bracket the COU operating envelope, and quantitative output comparison shows mean absolute error of 8.3% within experimental uncertainty. The model form assessment, supported by comprehensive literature review and expert elicitation, provides qualitative confidence commensurate with MRL 2 expectations. The overall evidence body supports acceptance of the CFD model for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
