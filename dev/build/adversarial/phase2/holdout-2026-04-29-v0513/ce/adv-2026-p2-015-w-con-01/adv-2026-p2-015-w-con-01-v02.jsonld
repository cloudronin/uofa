  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors for the CFD hemolysis prediction model at Model Risk Level 2. Seven factors were formally assessed with structured level evidence; all seven meet or exceed their required levels. The remaining six factors were assessed through documented qualitative review and determined to be acceptable at MRL 2. The model demonstrates adequate credibility for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in the CPB use context. The relative hemolysis index predictions satisfy the RH < 1 acceptance criterion with sufficient margin. The assessment team unanimously accepts the model for the stated COU.",
