  "signature": "ed25519:b1e4a7c2f0d3e6b9a2c5f8d1e4b7a0c3f6d9b2e5a8c1f4d7b0e3a6c9f2d5b8e1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under an ISO 9001 or equivalent quality management system with documented version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 is used under a documented QMS with version-controlled solver settings. Regression test suite covering 47 benchmark cases was executed prior to this study with no failures. All simulation scripts are stored in a Git repository with commit hashes recorded in the study record. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate that the numerical implementation correctly solves the governing equations through convergence studies and comparison against manufactured or analytical solutions.",
      "rationale": "Method of manufactured solutions (MMS) was applied to the incompressible Navier-Stokes solver confirming second-order spatial accuracy. Grid convergence was demonstrated on three systematically refined meshes (3.2M, 8.1M, 18.6M cells) using Richardson extrapolation. Observed order of convergence p=1.94 is consistent with the nominal second-order scheme. Achieved level 3 exceeds the required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be estimated and demonstrated to be within acceptable bounds relative to the quantity of interest tolerance.",
      "rationale": "Grid convergence index (GCI) was computed for the relative hemolysis index QoI on the three mesh levels. Fine-grid GCI of 3.1% is below the 5% threshold established for MRL 2. Temporal discretization was verified by halving the time step from 1e-4 s to 5e-5 s with less than 0.8% change in cycle-averaged hemolysis index. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to enable reproducibility and must span the operating envelope relevant to the COU.",
      "rationale": "FDA benchmark experimental data were collected at five flow-speed combinations (2.5, 5.0 L/min at 2500, 3500, 4500 RPM) fully spanning the CPB operating envelope. Test fluid was a 40% glycerol-water blood analog at 37°C with documented viscosity measurements. Environmental conditions (temperature ±0.5°C, pressure ±2 mmHg) are within the tolerances required for MRL 2. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively against experimental measurements using a defined metric and the comparison must fall within the acceptance band.",
      "rationale": "Pressure rise predictions agree with experimental measurements to within ±8% across all five operating points (mean absolute error 4.3%). Hemolysis index predictions fall within ±12% of in-vitro measurements, satisfying the ±15% acceptance band defined for MRL 2 comparative assessment. U-validation metric U_val = 0.09 is below the threshold of 0.15. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in the model must be directly relevant to the clinical or engineering decision being made within the COU.",
      "rationale": "The primary QoI is the relative hemolysis index (RH = HI_device / HI_predicate). This metric is directly referenced in FDA guidance for comparative hemolysis assessment of Class II blood-contacting devices. Secondary QoIs (shear stress distribution, exposure time distribution) are standard surrogates for hemolytic potential. All QoIs are directly traceable to the COU acceptance criterion RH < 1. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the COU such that the validation evidence supports confidence in the model predictions within the COU domain.",
      "rationale": "Validation experiments used the identical FDA generic centrifugal pump geometry as the simulation. Operating conditions in validation span the full COU operating envelope. Blood analog fluid properties match physiological blood viscosity at 37°C within 5%. The validation domain is co-extensive with the COU domain, providing direct support for model credibility at MRL 2. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of the numerical solver must be demonstrated to a level that does not materially affect the quantities of interest.",
      "rationale": "A comprehensive qualitative assessment of numerical solver error was conducted by the simulation team. Residual convergence behavior was monitored throughout all simulation runs and the team determined through engineering judgment and visual inspection of residual histories that solver-induced errors are negligible relative to the hemolysis index QoI. The iterative solver was observed to reach a stable periodic state in all five operating-point simulations, with no evidence of solver divergence or stagnation. The assessment team concluded that numerical solver error does not constitute a meaningful contributor to overall model uncertainty at MRL 2, and this determination was reviewed and endorsed by the lead verification engineer. This qualitative determination is considered sufficient to support the overall Accepted decision given the corroborating evidence from the discretization error and code verification factors."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence must be provided that the model has been used correctly and that user-induced errors have been identified and mitigated.",
      "rationale": "All simulation setups were reviewed by a second analyst prior to execution. Boundary condition files were version-controlled and diff-checked against the reference setup document. No user errors were identified during the independent review. Required level 1 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The mathematical form of the model must be appropriate for the physics being represented in the COU, with documented justification for key modeling choices.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for rotating machinery flows with adverse pressure gradients. The Giersiepen-Wurzinger hemolysis power-law model was selected as the industry-standard formulation for CFD hemolysis prediction. Model form choices are documented in the simulation plan with literature citations. Sensitivity to turbulence model was assessed by comparison with realizable k-epsilon results (less than 6% difference in RH). Achieved level 2 exceeds required level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be documented with sources, uncertainty ranges, and sensitivity analysis demonstrating that input uncertainty does not dominate the QoI uncertainty.",
      "rationale": "Geometric inputs were derived from FDA-published CAD drawings with dimensional tolerances of ±0.05 mm. Fluid properties (density, viscosity) were measured experimentally with stated uncertainties. Hemolysis model coefficients were taken from the Giersiepen-Wurzinger calibration dataset. One-at-a-time sensitivity analysis on the five most influential inputs showed maximum QoI sensitivity of 7% per 10% input variation. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples or experimental specimens used in validation must be representative of the device being modeled.",
      "rationale": "The FDA benchmark pump used in experimental validation was fabricated to the published generic geometry specifications. Dimensional inspection confirmed conformance to nominal geometry within ±0.1 mm across all critical features. Sample representativeness is established by direct geometric correspondence. Required level 1 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The input parameters used in the simulation must be equivalent to those present in the validation experiments to support valid comparison.",
      "rationale": "Simulation boundary conditions (inlet flow rate, outlet pressure, rotational speed, fluid properties) were set to match experimental test conditions as documented in the FDA benchmark dataset. Any discrepancies between nominal and measured experimental conditions were below 2% for all parameters. Equivalency is confirmed for all five operating points. Required level 1 is met."
    }
  ],
