      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted RH index within ±20% of measured values across all five operating points.",
      "rationale": "Predicted relative hemolysis index values ranged from 0.61 to 0.89 compared to experimental measurements of 0.58 to 0.94. Maximum deviation was 8.7%, well within the ±20% acceptance threshold. Rank ordering of worst-case operating conditions was preserved in all predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QOI (relative hemolysis index RH) is directly linked to the clinical decision criterion and is computed from model outputs without intermediate surrogates.",
      "rationale": "The relative hemolysis index is the regulatory-accepted metric for CPB device hemolysis comparison and is computed directly from CFD-derived scalar shear stress and exposure time via the Giersiepen-Wurzinger power-law model. No surrogate quantities are required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
