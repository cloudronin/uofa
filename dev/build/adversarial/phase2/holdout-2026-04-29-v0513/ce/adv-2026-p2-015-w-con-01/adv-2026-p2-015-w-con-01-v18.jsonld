  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for Model Risk Level 2. Seven factors were formally assessed and all achieved their required gradation levels; six factors were scoped out as not required at MRL 2. Output comparison confirmed predicted relative hemolysis index values within 8.7% of experimental measurements across all five COU operating points, satisfying the RH < 1 acceptance criterion. The simulation model is accepted as sufficiently credible to support identification of worst-case hemolysis operating conditions for the Class II CPB device. The Use Error factor was evaluated through qualitative peer review, which the team determined provided adequate assurance at MRL 2.",
