  "signature": "ed25519:4b8c2e6f1a3d5e7b9c1d3e5f7a9b1c3d5e7f9a1b3c5d7e9f1a3b5c7d9e1f3a5b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "ANSYS Fluent 2021 R2 is used under a validated installation with version-controlled case files and documented solver settings. Software quality assurance procedures including regression testing and release notes review confirm suitability for blood pump hemolysis simulation at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Order-of-accuracy tests using manufactured solutions confirm second-order spatial convergence of the incompressible Navier-Stokes solver. Benchmark comparisons against published FDA nozzle results further substantiate code correctness at the required gradation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Three systematically refined meshes (3.1M, 7.8M, 18.4M elements) were used to compute GCI for the scalar hemolysis index QoI. Richardson extrapolation yields GCI < 1.8% on the medium mesh used for production runs, exceeding the Gradation 2 threshold and achieving Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Experimental test conditions replicate the five clinical flow-speed operating points (2–6 L/min, 2400–3600 RPM) with controlled temperature (37°C ± 0.5°C) and hematocrit (33% ± 2%). Boundary conditions in the CFD model are derived directly from measured inlet pressure and flow waveforms."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values are compared against experimental measurements at all five operating points. Mean absolute relative error is 8.3%, within the ±15% acceptance band established for Gradation 2 output comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The primary QoI is the relative hemolysis index (RH) directly linked to the clinical acceptance criterion RH < 1. Secondary QoIs include wall shear stress distributions and scalar transport residence times, which are established surrogates for hemolysis risk in rotary blood pump literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Validation experiments were conducted on the same FDA generic centrifugal pump geometry under the same operating envelope as the COU. The validation domain overlaps the COU domain in geometry, fluid properties, and hemodynamic regime, satisfying Gradation 2 relevance requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Qualitative assessment of iterative convergence and round-off error acceptability for hemolysis scalar transport at MRL 2.",
      "rationale": "Iterative convergence was evaluated qualitatively across all five operating-point simulations. Residuals for continuity, momentum, and the hemolysis damage scalar were monitored over 5000 iterations; all quantities exhibited a monotonic reduction of at least four orders of magnitude from initialization, with no oscillatory behaviour detected in the final 500 iterations. Round-off error is judged negligible given double-precision arithmetic and the Reynolds number regime (Re ~ 3000–8000) of the pump impeller passages. The assessment team concluded, based on engineering judgment and comparison with analogous published rotary pump studies, that numerical solver error does not materially affect the hemolysis QoI prediction and that no formal quantitative bounding analysis was necessary to support the MRL 2 decision. This qualitative determination is consistent with the level of rigor expected for a Class II device at the current stage of model maturity and is documented in the project technical report TR-CFD-2024-07."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 1 for MRL 2.",
      "rationale": "Simulation setup was performed by a credentialed CFD analyst with documented training in ANSYS Fluent for cardiovascular applications. A peer-review checklist was applied to boundary conditions, material properties, and solver settings prior to production runs, satisfying Gradation 1 use-error controls."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The SST k-omega turbulence model with low-Reynolds corrections is selected based on published benchmarks for rotary blood pump flows. The Giersiepen-Wurzinger hemolysis power-law model is applied with constants validated against in-vitro shear data. Model-form uncertainty is documented and judged acceptable at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Blood viscosity, density, and hematocrit are sourced from peer-reviewed literature and matched to experimental test fluid properties. Pump geometry is derived from manufacturer CAD with dimensional verification against physical measurements. Input uncertainty bounds are documented in the simulation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 1 for MRL 2.",
      "rationale": "Validation experiments used three pump units from the same manufacturing batch. Bovine blood from a single donor pool was used across all test sessions to minimize inter-sample variability. Sample characterization including hematocrit, plasma hemoglobin baseline, and methemoglobin fraction is documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 1 for MRL 2.",
      "rationale": "CFD boundary conditions (inlet flow rate, outlet pressure, rotational speed) are matched to experimentally measured values within ±2%. Fluid property equivalency between bovine blood used in validation and human blood assumed in the COU is addressed by normalization through the relative hemolysis index formulation."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors have been reviewed. Seven factors were formally assessed and all achieved their required gradation levels under ASME V&V 40-2018 at Model Risk Level 2. Six factors were assessed at Gradation 1 or higher, consistent with MRL 2 requirements for a Class II device. The CFD model of the FDA generic centrifugal blood pump is judged credible for the intended purpose of identifying worst-case hemolysis operating conditions under CPB conditions. The relative hemolysis index predictions are within the ±15% acceptance band at all five operating points. The assessment team accepts the model for regulatory submission support.",
