      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "At MRL 2 Gradation 1, documentation of the test sample used in validation experiments is required.",
      "rationale": "The FDA benchmark pump geometry used for validation is a standard reference geometry with publicly documented dimensional tolerances. Sample provenance is established through the FDA critical path initiative documentation."
    },
