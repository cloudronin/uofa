  "signature": "ed25519:b1c3e5a7d9f2b4c6e8a0d2f4b6c8e0a2c4d6f8b0c2e4a6d8f0b2c4e6a8d0f2b4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 2 requires documented version control, issue tracking, and validation test suite for the CFD solver.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO 9001-certified QMS. Version control is maintained via Git with tagged release builds. A regression test suite of 47 canonical cases is executed on each solver release. Issue tracking is managed through JIRA with traceability to solver patches. SQA level 2 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at level 2 requires documented method-of-manufactured-solutions (MMS) or equivalent order-of-accuracy testing for the governing equations used.",
      "rationale": "Order-of-accuracy testing using manufactured solutions has been performed for the incompressible Navier-Stokes solver and the SST k-omega turbulence model. Observed convergence rates are consistent with the nominal second-order spatial accuracy of the discretization scheme. Results are documented in the solver verification report VR-2022-CFD-007."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error assessment at level 2 requires a systematic mesh refinement study with GCI < 5% on the primary QoI (relative hemolysis index).",
      "rationale": "A three-level structured mesh refinement study was performed (coarse: 4.2M cells, medium: 11.7M cells, fine: 31.4M cells). GCI values for the relative hemolysis index across all five operating points ranged from 0.8% to 3.1%, well below the 5% threshold. Richardson extrapolation was applied to estimate the continuum solution. The achieved level of 3 reflects the additional rigor of the extrapolation analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions at level 2 require documented correspondence between experimental boundary conditions and simulation inputs, including fluid properties, inlet flow rates, and rotational speed.",
      "rationale": "Experimental test conditions from the FDA benchmark dataset (Hariharan et al. 2011) are reproduced in the CFD model. Inlet flow rates (2.5 and 5.0 L/min), rotational speeds (2500 and 3500 RPM), and blood analog fluid properties (glycerol-water, viscosity 3.5 mPa·s) are matched to within measurement uncertainty. Correspondence is documented in the test-analysis correlation report TAC-2023-001."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison at level 2 requires quantitative comparison of simulation outputs against experimental measurements using an appropriate validation metric with uncertainty quantification.",
      "rationale": "Predicted relative hemolysis index values are compared against experimental measurements across all five operating points. The area validation metric (AVM) is used to quantify agreement, yielding AVM = 0.12 (acceptable range < 0.25 for level 2). Experimental uncertainty is propagated using a Monte Carlo approach with 1000 samples. All comparisons fall within the experimental uncertainty band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI relevance at level 2 requires documented justification that the simulated quantities directly support the intended use decision.",
      "rationale": "The primary QoI is the relative hemolysis index (RHI = NIH_device / NIH_predicate). This quantity directly maps to the regulatory acceptance criterion (RHI < 1.0) and is the basis for the worst-case operating condition identification. Secondary QoIs include wall shear stress distributions and scalar stress exposure time, which provide mechanistic insight into hemolysis pathways."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation relevance at level 2 requires documented mapping between validation scenarios and the COU, demonstrating that the validation domain encompasses the intended use conditions.",
      "rationale": "Validation activities were conducted using the FDA generic centrifugal pump geometry under operating conditions that bracket the clinical CPB operating envelope. The validation Reynolds number range (Re = 1200–4800) encompasses the COU operating range. Fluid properties in validation experiments match clinical blood rheology within documented bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical solver error at level 1 requires iterative convergence to residual norms below 1e-5 for all transport equations.",
      "rationale": "All simulations were run to iterative convergence with residual norms below 1e-6 for continuity, momentum, and turbulence equations. Mass imbalance at the inlet/outlet boundaries was verified to be below 0.01% of total mass flow. The achieved level of 2 reflects the additional monitoring of solution monitors (torque, pressure rise) to confirm stationary convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Use error at level 1 requires documented simulation setup review by a qualified analyst independent of the primary modeler.",
      "rationale": "An independent review of the simulation setup was performed by a senior CFD analyst (10+ years rotary machinery experience) who was not involved in the primary modeling work. The review covered boundary condition specification, material property assignments, solver settings, and post-processing scripts. No critical errors were identified; three minor documentation issues were corrected prior to final analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form credibility requires justification that the chosen mathematical model (governing equations, turbulence closure, hemolysis damage model) is appropriate for the COU physics.",
      "rationale": "The model form selection was evaluated through a qualitative assessment of the physical phenomena relevant to pump-induced hemolysis in the CPB context. The incompressible Reynolds-averaged Navier-Stokes equations with SST k-omega turbulence closure are considered appropriate given the transitional-to-turbulent flow regime in the pump passages (Re ~ 2000–5000). The power-law hemolysis damage accumulation model (Giersiepen et al. 1990, modified by Heuser and Opitz 1980) is the established standard for regulatory submissions of this device class. Sensitivity analyses comparing three turbulence model variants (SST k-omega, realizable k-epsilon, and RSM) showed less than 8% variation in predicted RHI, confirming that model form uncertainty is within acceptable bounds for the intended use. The selection is consistent with FDA guidance documents and published literature for Class II rotary blood pumps. This factor was assessed through structured expert elicitation and literature review rather than through quantitative level scoring, as the model form appropriateness is inherently a physics-judgment determination that spans multiple gradation criteria simultaneously."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs at level 1 require documentation of all input parameters with sources and nominal values.",
      "rationale": "All model inputs are documented in the simulation input specification document SIS-2023-CPB-001, including geometric dimensions (from manufacturing drawings with tolerances), fluid properties (from literature with uncertainty ranges), boundary conditions (from experimental test protocol), and damage model coefficients (from published calibration data). Input traceability is maintained to source documents."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples at level 1 require documentation that the experimental samples used for validation are representative of the device geometry and materials.",
      "rationale": "The FDA generic centrifugal pump used in validation experiments is geometrically identical to the computational model (CAD-to-physical deviation < 0.1 mm per CMM inspection). The blood analog fluid (glycerol-water mixture) is certified to match the Newtonian viscosity of blood at high shear rates. Sample characterization data are provided in the experimental test report ETR-2011-FDA-PUMP."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Equivalency of input parameters at level 1 requires documented comparison between validation scenario inputs and COU inputs, identifying any gaps.",
      "rationale": "A parameter equivalency matrix was constructed comparing the validation scenario (FDA generic pump, glycerol-water analog, in-vitro conditions) against the COU (clinical CPB device, whole blood, in-vivo conditions). Key gaps identified include: (1) non-Newtonian blood rheology at low shear rates, (2) temperature effects on viscosity, and (3) hematocrit variability. These gaps are judged acceptable at MRL 2 given the high-shear-rate dominance of hemolysis damage in centrifugal pumps."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed. Seven factors with explicit required and achieved levels all meet or exceed their required gradation levels for Model Risk Level 2. The remaining six factors, including model form, were assessed through documented qualitative analysis consistent with MRL 2 expectations. The overall credibility evidence is sufficient to support the intended use of the CFD model for identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index predictions are validated against experimental data within acceptable uncertainty bounds, and the model is accepted for regulatory submission purposes.",
    "decidedAt": "2026-04-19T00:00:00Z"
