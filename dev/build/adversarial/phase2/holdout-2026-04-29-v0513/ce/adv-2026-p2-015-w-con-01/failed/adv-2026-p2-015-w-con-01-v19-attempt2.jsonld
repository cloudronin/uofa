  "signature": "ed25519:b1c4e7a2d5f8c3b6e9a1d4f7c2b5e8a3d6f1c4b7e2a5d8f3c6b9e2a5d8f3c6b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented QA procedures and regression test suite covering blood pump flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 is used under an ISO 9001-certified QA framework. Version control, change logs, and regression test suites are maintained. All relevant solver modules have passed internal validation benchmarks for turbulent viscous flows consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code verification against manufactured solutions or published benchmarks for rotating machinery and viscous hemolysis-relevant flows.",
      "rationale": "The Navier-Stokes solver was verified using the method of manufactured solutions for laminar and turbulent channel flows. Published benchmark results for rotating disk flows were reproduced within 1.5% at equivalent Reynolds numbers. Code verification is deemed sufficient for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study was conducted with refinement ratio r=1.3. GCI values for the normalized index of hemolysis ranged from 1.8% to 3.4% across all five operating points, satisfying the MRL 2 threshold. The achieved level of 3 reflects formal Richardson extrapolation with uncertainty quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions documented with flow rate, rotational speed, fluid temperature, and hematocrit within ±5% of nominal CPB operating envelope.",
      "rationale": "Physical testing was performed at 5 operating points spanning the CPB flow envelope (2–6 L/min, 2000–3500 RPM). Bovine blood at 35% hematocrit was used. Temperature was maintained at 37±0.5°C. All test conditions are documented in the validation test report and traceable to calibrated instrumentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted normalized index of hemolysis within 20% of experimental measurements at all five operating points.",
      "rationale": "CFD-predicted NIH values were compared against experimental measurements at all five operating points. Maximum deviation was 14.7% at the highest flow-speed combination. Mean absolute error across all operating points was 9.3%. The acceptance criterion of 20% is satisfied at all points, supporting the Accepted decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoI (normalized index of hemolysis) is directly linked to the clinical endpoint and the regulatory submission criterion RH < 1.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the primary QoIs. NIH is a well-established regulatory metric for blood pump evaluation and directly maps to the clinical hemolysis endpoint. The QoIs are fully consistent with FDA guidance and the COU acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on geometrically and operationally representative pump configurations within the CPB operating envelope.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump geometry under CPB-representative conditions. The validation domain overlaps the COU operating envelope in terms of flow rate, rotational speed, and fluid properties. Geometric similarity between the validation model and the device under assessment is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Residuals converged to at least 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "Steady-state RANS simulations achieved residual convergence to 1e-6 for continuity and momentum equations. Mass imbalance across all inlet-outlet boundaries was below 0.005%. Iterative convergence was confirmed by monitoring NIH at each iteration until change per iteration was below 0.01%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary condition setup and post-processing scripts.",
      "rationale": "All simulation setup files, boundary condition specifications, and post-processing scripts were independently reviewed by a second qualified CFD engineer. No setup errors were identified. The workflow is documented in a controlled simulation plan traceable to the analysis report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Qualitative assessment of turbulence model and hemolysis power-law model appropriateness for the CPB flow regime, supported by literature review and sensitivity analysis.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance in rotating machinery and transitional flows relevant to blood pumps, as documented in multiple peer-reviewed studies (Fraser et al. 2011; Hariharan et al. 2015). The Giersiepen-Wurzinger power-law hemolysis model was applied with parameters calibrated to bovine blood under CPB shear conditions. A qualitative assessment of model form uncertainty was conducted by comparing SST k-omega predictions against k-epsilon and LES results from the literature at equivalent operating points; the SST model demonstrated the most consistent agreement with experimental hemolysis data across the CPB operating envelope. Sensitivity of NIH predictions to turbulence model constants was evaluated by perturbing C_mu by ±10%, yielding NIH variation below 4%. The hemolysis model exponent sensitivity was evaluated over the published range (alpha: 1.9–2.4, beta: 0.62–0.785), with NIH varying by up to 18%. This variability is acknowledged and incorporated into the output comparison uncertainty budget. The overall qualitative assessment concludes that the selected model forms are appropriate and conservative for the intended COU at MRL 2, with uncertainty bounded within the acceptance criterion margin. No structured credibility level gradation is assigned to this factor as the assessment is based on expert judgment and literature synthesis rather than a formal gradation exercise."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Model inputs factor is scoped out at MRL 2 per the ASME V&V 40 credibility factor matrix for Class II devices with medium model influence. Geometric dimensions and fluid properties are well-characterized and within standard CPB operating ranges."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Test samples factor is not required at MRL 2 for this COU. Experimental validation used a single representative pump geometry consistent with the FDA generic pump benchmark, which is sufficient for comparative hemolysis assessment at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Equivalency of input parameters is not required at MRL 2. The CFD model inputs are set to match experimental conditions directly, and no extrapolation beyond the validated operating envelope is performed in this COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. Discretization error achieved level 3 against a required level of 2, providing additional confidence in mesh independence. Output comparison confirms NIH predictions within 14.7% of experimental measurements across all five operating points, satisfying the 20% acceptance criterion. The six non-assessed factors are appropriately scoped out per the ASME V&V 40 credibility factor matrix for Class II devices at MRL 2. The model form factor was evaluated through a comprehensive qualitative assessment supported by literature review and sensitivity analysis, confirming appropriateness of the selected turbulence and hemolysis models. The overall credibility evidence is sufficient to support the Accepted decision for use of this CFD model to identify worst-case hemolysis operating conditions for the CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
