  "signature": "ed25519:b7d3a1f9c4e2b8d5f0a3c6e9b2d4f7a0c3e6b9d2f5a8c1e4b7d0f3a6c9e2b5d8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all relevant test cases passing.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is under formal version control. A regression test suite of 47 benchmark cases was executed prior to this study; all cases passed within prescribed tolerances. Software quality documentation is archived in the project repository consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Documented verification of solver discretization schemes against analytical or manufactured solutions for relevant flow regimes.",
      "rationale": "Code verification was performed using the Method of Manufactured Solutions (MMS) for the incompressible Navier-Stokes equations in rotating reference frames. Second-order spatial convergence was confirmed for all relevant discretization schemes. Results are consistent with published solver verification documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI across all operating points.",
      "rationale": "A three-level mesh refinement study was conducted with element counts of 2.1M, 5.8M, and 14.2M cells. Richardson extrapolation yielded GCI values of 1.8–3.4% for the relative hemolysis index across all five operating points. The achieved level exceeds the MRL 2 requirement, providing additional confidence in spatial discretization adequacy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions documented and traceable; boundary conditions in CFD model match experimental conditions within stated uncertainty.",
      "rationale": "Experimental test conditions from the FDA benchmark dataset are fully documented including flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), and fluid properties (bovine blood analog at 37°C). CFD boundary conditions are set to match experimental values within measurement uncertainty bands as reported in the benchmark protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metrics defined; model predictions within acceptance band for hemolysis index at all validation operating points.",
      "rationale": "The normalized index of agreement (NIA) and mean absolute percentage error (MAPE) were computed for hemolysis index predictions across all validation operating points. MAPE was 8.3% across the five operating conditions, within the 15% acceptance threshold defined for MRL 2. Pressure-head predictions showed MAPE of 4.1%, further supporting model fidelity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation are directly relevant to the hemolysis prediction objective of the COU.",
      "rationale": "The primary QoI is the relative hemolysis index (RH), which directly maps to the clinical endpoint of interest. Secondary QoIs include scalar stress exposure and residence time distributions, which are mechanistically linked to RH. All QoIs are standard in the FDA hemolysis guidance and are directly applicable to the CPB COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities cover the operating envelope defined in the COU; geometry and flow conditions are representative of the CPB device and use scenario.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry under the same five flow-speed combinations specified in the COU. The validation domain (2–8 L/min, 2000–3500 RPM) encompasses the full COU operating envelope. Device geometry, fluid properties, and boundary condition types are all directly representative of the target CPB application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence demonstrated; residuals reduced by at least 4 orders of magnitude for all governing equations.",
      "rationale": "All simulations were run to iterative convergence with residuals reduced by 5–6 orders of magnitude. Mass imbalance across inlet and outlet was less than 0.01% in all cases. Double-precision arithmetic was used throughout. The achieved level exceeds the MRL 2 minimum requirement for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "rationale": "A qualitative assessment of use error risk was conducted through structured peer review of all simulation setup files, boundary condition assignments, and post-processing scripts by an independent CFD analyst with equivalent domain expertise. The review confirmed that model inputs, solver settings, and hemolysis model parameters were applied consistently and correctly across all operating points. No discrepancies were identified between the documented simulation protocol and the executed simulation configurations. The team determined that the probability of consequential use error is sufficiently low given the review process, the maturity of the simulation workflow, and the cross-checking performed against published benchmark results. This qualitative determination is considered adequate at MRL 2 for a Class II device with medium model influence, where formal quantitative use-error metrics are not mandated by the applicable credibility framework.",
      "acceptanceCriteria": "Independent review of simulation setup confirms correct application of boundary conditions, solver settings, and post-processing procedures with no unresolved discrepancies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence.",
      "rationale": "Model form uncertainty assessment is not required at Model Risk Level 2 for a Class II device with medium model influence per the ASME V&V 40 credibility matrix. The factor is scoped out of the required assessment activities for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2 for this device class and model influence combination. Nominal input values are well-characterized from the FDA benchmark dataset and manufacturer specifications. Sensitivity to input variation was qualitatively bounded through operating-point sweep results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence.",
      "rationale": "Formal test sample characterization and traceability assessment is not required at MRL 2. The FDA benchmark experimental data used for validation is publicly available and has been independently characterized in multiple published studies, providing adequate confidence in sample representativeness without additional formal assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence.",
      "rationale": "Formal equivalency assessment of input parameters between validation and COU configurations is not required at MRL 2. The validation activities were conducted using the same geometry and operating conditions as the COU, making formal equivalency mapping unnecessary for this assessment."
    }
  ],
