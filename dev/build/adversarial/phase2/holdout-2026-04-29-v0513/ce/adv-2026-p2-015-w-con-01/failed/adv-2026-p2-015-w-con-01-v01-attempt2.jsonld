  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA procedures and regression test suite passing at MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is deployed under a documented software quality plan including version control, issue tracking, and a regression test suite covering 47 canonical flow cases. All regression tests pass. QA documentation reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent formal verification demonstrating correct numerical implementation of governing equations.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver kernel. Observed order of convergence (1.97) matches theoretical second-order accuracy. Verification exceeds MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for primary QoI (hemolysis index) across three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study conducted with refinement ratio r=1.3. GCI for the relative hemolysis index is 3.2% (fine-to-medium) and 4.7% (medium-to-coarse), both within the 5% acceptance threshold. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented and replicated in simulation within ±5%.",
      "rationale": "Experimental test conditions from the FDA benchmark dataset are replicated in simulation. Flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM) match within 2.1%. Fluid properties (bovine blood viscosity, density) are within 1.8% of measured values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 15% of experimental measurements across all five operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against FDA benchmark experimental data at five operating points. Mean absolute percentage error is 8.4%; maximum deviation is 13.1% at the highest flow-speed combination. All comparisons within the 15% acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated QoIs (NIH, shear stress distribution, residence time) directly map to the clinical hemolysis risk metric used in the COU.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which directly maps to the relative hemolysis acceptance criterion (RH < 1) specified in the COU. Secondary QoIs (volume-averaged shear stress, fluid residence time) provide mechanistic insight supporting the primary comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating regime sufficiently similar to COU device and operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry under CPB-representative operating conditions. The validation envelope (2–6 L/min, 2000–3500 RPM) encompasses the COU operating range. Geometric similarity between validation and COU device confirmed by design review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria and iterative error bounds documented and shown to be negligible relative to discretization error.",
      "rationale": "A comprehensive qualitative assessment of numerical solver error was conducted by the simulation team. Iterative residuals were monitored throughout all simulations and confirmed to reach steady-state plateaus below 1e-5 for continuity and momentum equations. The assessment team reviewed solver log files for all 15 simulation cases and concluded through expert judgment that solver-induced error is negligible relative to the discretization uncertainty quantified under the Discretization Error factor. The team's consensus, documented in internal technical report TR-2024-CFD-07, is that no structured quantitative bounding of iterative error is warranted at MRL 2 given the observed convergence behavior and the qualitative consistency of results across operating points. This qualitative evaluation is considered sufficient to support the overall Accepted determination."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition and material property inputs verified against source documentation.",
      "rationale": "Independent review of simulation setup performed by a second CFD analyst not involved in model construction. Boundary conditions, material properties, and solver settings verified against experimental source documentation. No discrepancies identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Selected turbulence model and hemolysis power-law model justified by literature review and sensitivity analysis.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark comparisons for rotating blood-contacting devices. Giersiepen-Wurzinger power-law hemolysis model adopted per FDA guidance. Sensitivity analysis comparing three turbulence models shows less than 6% variation in NIH, supporting model form selection."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in key model inputs (viscosity, density, hemolysis model coefficients) propagated and shown to have less than 10% impact on NIH.",
      "rationale": "One-at-a-time sensitivity analysis performed for fluid viscosity (±10%), density (±2%), and hemolysis model coefficients (±15%). Maximum resulting variation in NIH is 7.3%, within the 10% acceptance threshold. Input uncertainties sourced from published experimental characterization of bovine blood."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples representative of CPB operating fluid; sample preparation and storage documented.",
      "rationale": "FDA benchmark experimental data used bovine blood prepared per ASTM F1841 protocol. Sample hematocrit (33±2%) and preparation conditions documented in the original FDA study report. Sufficient for MRL 2 comparison purposes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, boundary conditions, fluid properties) demonstrably equivalent to experimental conditions used in validation.",
      "rationale": "CAD geometry reconstructed from FDA benchmark pump drawings with dimensional tolerances within 0.05 mm. Inlet velocity profiles derived from experimental flow conditioning data. Fluid properties matched to experimental measurements. Equivalency confirmed by overlay of simulation inlet profiles against laser Doppler anemometry measurements."
    }
  ],
