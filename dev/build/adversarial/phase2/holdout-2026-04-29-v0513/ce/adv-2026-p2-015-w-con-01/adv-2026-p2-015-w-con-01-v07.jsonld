  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used in the simulation is documented with version control and basic QA procedures consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 19.2 was used with documented version control. QA procedures include regression testing for solver settings and archived case files. Level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code verification confirms solver implementation through benchmark problems at MRL 2 standard.",
      "rationale": "Benchmark lid-driven cavity and pipe flow cases were run to confirm solver correctness. Results matched published benchmarks within 1% for velocity profiles. Level 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Mesh convergence study demonstrating GCI < 5% for the quantity of interest (normalized hemolysis index).",
      "rationale": "Three-level mesh refinement study performed with 1.8M, 4.2M, and 9.6M cell meshes. GCI for hemolysis index was 2.3% between fine and medium meshes. Richardson extrapolation applied. Achieved Level 3 exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions are documented and traceable to the simulation boundary conditions.",
      "rationale": "FDA generic pump experimental test conditions (flow rate 2.5–7.5 L/min, rotational speed 2000–3500 RPM) are fully documented in the CDRH dataset. Boundary conditions in CFD match published experimental inlet/outlet pressures within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation outputs compared against experimental measurements with defined acceptance metrics.",
      "rationale": "Normalized index of hemolysis (NIH) predicted by CFD compared against five experimental operating points. Mean absolute error of 8.4% across all points, within the 15% acceptance threshold defined for MRL 2. Level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) is directly relevant to the clinical decision being made.",
      "rationale": "The relative hemolysis index RH is the primary regulatory metric for CPB device hemolysis comparison. Its direct correspondence to the clinical endpoint (blood cell damage) and the predicate device comparison framework confirms relevance at Level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities use geometry, fluid, and operating conditions sufficiently representative of the COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under blood-analog fluid (aqueous glycerol) at clinically relevant flow rates. Geometric similarity to the CPB device under assessment is high. Level 2 relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below specified thresholds, and time-step sensitivity analysis for transient terms.",
      "rationale": "A comprehensive qualitative assessment of numerical solver error was conducted by the simulation team. Residual convergence behavior was reviewed across all five operating points and found to exhibit consistent monotonic reduction patterns characteristic of well-posed turbulent flow problems. The team evaluated solver settings including under-relaxation factors, pressure-velocity coupling scheme (SIMPLE), and discretization scheme selection (second-order upwind for momentum and turbulence quantities). Expert review of convergence histories, supplemented by comparison of mass imbalance across inlet and outlet boundaries (consistently below 0.01%), provided strong qualitative confidence that solver-introduced numerical errors are negligible relative to the hemolysis prediction uncertainty. This qualitative assessment, drawing on the team's extensive experience with rotating machinery CFD, supports the conclusion that numerical solver error does not meaningfully affect the credibility of the hemolysis index predictions for the CPB COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 for Class II devices under the ASME V&V 40 framework when model influence is Medium. Scoped out per MRL 2 determination."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Model form uncertainty assessment beyond the validation comparison is not required at MRL 2. The k-omega SST turbulence model selection is supported by published literature for rotating blood-contacting devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Formal uncertainty propagation for model inputs is not required at MRL 2. Nominal blood viscosity and density values from literature are used consistently across all operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Sample characterization beyond what is documented in the FDA experimental dataset is not required at MRL 2 for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Formal equivalency analysis of input parameters between validation and COU conditions is not required at MRL 2. Qualitative similarity of operating conditions has been established through the test conditions factor assessment."
    }
