  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels at Model Risk Level 2 for this Class II CPB device application. The six non-assessed factors are appropriately scoped out per the MRL 2 requirements matrix. The CFD model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions, with the relative hemolysis index predictions validated against the FDA benchmark dataset. The assessment team unanimously accepts the simulation evidence as adequate to support the regulatory submission.",
