  "signature": "ed25519:9f1e2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used for CFD simulation must be verified under an appropriate quality management system with documented version control and testing records.",
      "rationale": "ANSYS Fluent 2021 R2 was used under an ISO 9001-compliant QMS. Solver validation documentation, version control logs, and regression test results are archived. Required Gradation 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Numerical code must be verified against established benchmark problems relevant to rotating machinery and viscous flow.",
      "rationale": "The CFD solver was verified against ASME V&V 20 benchmark cases for rotating cavity flow and pipe flow with known analytical solutions. Order-of-accuracy tests confirm second-order spatial convergence. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Discretization error must be estimated and demonstrated to be within acceptable bounds for hemolysis-relevant flow quantities.",
      "rationale": "A three-level mesh refinement study was performed using the Richardson extrapolation method. Grid Convergence Index (GCI) for the normalized index of hemolysis was less than 2.1% on the medium mesh selected for production runs. Exceeds Gradation 2 requirement; Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must be sufficiently documented and representative of the COU operating envelope.",
      "rationale": "FDA benchmark experimental data from the generic centrifugal blood pump study (Hariharan et al.) was used. Operating conditions spanning 2.5–7 L/min and 2500–3500 RPM are documented with uncertainty bounds. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Model outputs must be quantitatively compared to experimental measurements using appropriate statistical metrics.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared against experimental measurements at all 5 operating points. Mean absolute relative error was 18.3%, within the accepted threshold for hemolysis CFD at MRL 2. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantities of interest used in validation must be directly relevant to the clinical decision being supported.",
      "rationale": "The primary quantity of interest is the relative hemolysis index (RH), computed from the power-law hemolysis model integrated along Lagrangian particle tracks. RH directly maps to the clinical acceptance criterion (RH < 1 vs. predicate device). Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must address the specific geometry, flow regime, and operating conditions of the COU with documented similarity arguments.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is geometrically similar to the device under assessment. Reynolds number and specific speed parameters overlap with the COU operating envelope. Similarity arguments are formally documented. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence and round-off errors must be characterized and demonstrated to be negligible relative to discretization error.",
      "rationale": "A qualitative assessment of numerical solver error was conducted by the simulation team. Residual monitoring logs show that all governing equation residuals converged to below 1e-5 over the course of each steady-state simulation run, and spot-checks of mass and momentum imbalances confirmed values below 0.01% of inlet flux. The team concluded through engineering judgment and cross-comparison of double-precision versus single-precision runs that round-off error is negligible in this application and does not materially influence the hemolysis index predictions. This qualitative determination is consistent with standard practice for rotating machinery CFD at Model Risk Level 2, where a full quantitative error budget is not required. The assessment team documented their review in the simulation technical report and considers this factor satisfactorily addressed for the purposes of the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence.",
      "rationale": "Per the MRL 2 credibility requirements matrix, use error assessment is not required for this COU. Scoped out by agreement with the assessment team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Model form uncertainty assessment is not required at MRL 2 for a Class II device with medium model influence. The power-law hemolysis model is well-established in the literature and its limitations are acknowledged in the simulation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Nominal blood viscosity and density values from published literature were used; sensitivity to these parameters is considered low based on prior studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Assessment of test sample representativeness is not required at MRL 2. The FDA benchmark dataset provides sufficient sample coverage for the validation activities performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Equivalency of input parameters between validation and COU conditions is not formally required at MRL 2. Qualitative similarity of boundary conditions has been noted in the simulation report."
