  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under a recognised SQA programme with documented version control, regression testing, and issue tracking consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 is developed under ISO 9001-certified SQA procedures. Version control, automated regression suite, and defect tracking records were reviewed and found compliant with Gradation 2 requirements for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent benchmark comparisons at Gradation 2.",
      "rationale": "Method-of-manufactured-solutions tests for the incompressible Navier–Stokes solver confirm second-order spatial convergence. Benchmark results against the lid-driven cavity and backward-facing step cases are documented in the solver theory manual and independently reproduced."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence study must be performed on at least three systematically refined meshes; GCI must be reported for the primary QoI (NIH) and must be below 5% at the required level.",
      "rationale": "A four-level mesh refinement study (0.4 M, 1.1 M, 3.2 M, 9.0 M cells) was conducted. Richardson-extrapolated GCI for NIH at the design operating point is 1.8%, exceeding the Gradation 2 threshold. Achieved level conservatively assigned 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used in validation must be documented with uncertainties and must correspond to the CPB operating envelope defined in the bound requirement.",
      "rationale": "FDA inter-laboratory study data (Hariharan et al. 2011) provides inlet velocity profiles and outlet pressure measurements with stated uncertainties. Operating points span 2500–3500 RPM at 4–5 L/min, fully within the CPB envelope described in the bound requirement document."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH and velocity magnitude must agree with experimental data within combined simulation and experimental uncertainty bands at all assessed operating points.",
      "rationale": "Predicted NIH values lie within ±18% of inter-laboratory mean experimental NIH across five operating points, within combined uncertainty. PIV velocity comparisons show normalised RMS error of 6.2%, within the Gradation 2 acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, shear stress distribution) must be directly relevant to the clinical decision question of identifying worst-case hemolysis operating conditions.",
      "rationale": "NIH is the regulatory-accepted metric for hemolysis in blood-contacting devices. Shear stress distribution drives the power-law hemolysis model. Both QoIs are directly linked to the clinical endpoint of red blood cell damage under CPB, as described in the claim document."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump) and physiologically representative blood analogue fluids under CPB-relevant flow conditions.",
      "rationale": "Validation data are drawn from the FDA-sponsored multi-laboratory study using the identical pump geometry, glycerol-water blood analogue (viscosity 3.5 cP), and CPB-range operating conditions. Geometric and fluid similarity to the clinical COU is confirmed in the bound requirement narrative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit quantification of iterative and round-off solver errors beyond residual monitoring is not required provided convergence criteria are documented.",
      "rationale": "Solver residuals were driven below 1×10⁻⁵ for all equations. Explicit iterative error budgeting beyond residual monitoring is not required at MRL 2; factor scoped to Gradation 1 and not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error analysis is not required; analyst qualification records and simulation setup review are sufficient.",
      "rationale": "Simulation setup was reviewed by a second qualified CFD analyst. Formal use-error quantification is not required at MRL 2; factor accepted at Gradation 1 without formal assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected turbulence model (SST k-ω) and hemolysis power-law model must be justified by literature evidence and sensitivity analysis for rotating blood-pump flows.",
      "rationale": "SST k-ω is recommended by the FDA CFD guidance for intravascular device flows. The Giersiepen–Wurzinger power-law hemolysis model is widely validated for CPB pumps. Turbulence model sensitivity study showed NIH variation below 12% across three candidate models, acceptable at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of NIH predictions to key model inputs (viscosity, inlet velocity profile, rotational speed) must be characterised; dominant inputs must be identified and their uncertainty propagated.",
      "rationale": "One-at-a-time sensitivity analysis over ±10% perturbations of viscosity, inlet flow rate, and rotational speed identified rotational speed as the dominant input (NIH sensitivity index 0.62). Uncertainty propagation via Monte Carlo (500 samples) yields NIH 95% CI of ±22%, reported in the validation results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterisation of experimental sample variability beyond reported inter-laboratory spread is not required.",
      "rationale": "Inter-laboratory variability in NIH measurements is captured in the FDA dataset uncertainty bounds. Formal statistical sample characterisation beyond this is not required at MRL 2; factor accepted at Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, full equivalency mapping between validation experiment inputs and clinical COU inputs is not required; documented similarity argument is sufficient.",
      "rationale": "A qualitative similarity argument confirming that glycerol-water analogue viscosity, pump geometry, and operating range bracket the clinical CPB envelope is provided in the bound requirement document. Formal equivalency analysis is not required at MRL 2."
    }
  ],
