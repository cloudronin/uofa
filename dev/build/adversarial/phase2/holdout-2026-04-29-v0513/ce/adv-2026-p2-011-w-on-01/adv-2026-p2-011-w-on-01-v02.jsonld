  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This unit evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. The intended use scope — steady-state adult CPB flows between 3 and 6 L/min at rotational speeds of 2000–4000 RPM — is described in the bound requirement and claim documents. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Submitted under Minimal profile; structured Context of Use object deferred to linked requirement narrative.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-piv-experimental",
    "https://uofa.net/morrison/data/fda-pump-hemolysis-bench"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic centrifugal pump"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalised Index of Hemolysis comparison across five operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037888",
