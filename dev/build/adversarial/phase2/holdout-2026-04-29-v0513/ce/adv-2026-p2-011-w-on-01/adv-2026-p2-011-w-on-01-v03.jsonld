  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six non-assessed factors are explicitly scoped out per the approved credibility plan and are acceptable at their default gradation 1 levels under MRL 2 requirements. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device. The intended use scope (adult CPB, 3–6 L/min, Class II device) is fully described in the bound Requirement (https://uofa.net/morrison/req/cpb-hemolysis-mrl2) and Claim (https://uofa.net/morrison/claim/cpb-worst-case-hemolysis) nodes.",
