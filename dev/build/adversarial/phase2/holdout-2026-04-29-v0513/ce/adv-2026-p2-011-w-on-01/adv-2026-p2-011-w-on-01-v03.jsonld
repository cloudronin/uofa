  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This package evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. The intended use scope — steady-state adult CPB flow rates between 3 and 6 L/min at 37 °C, with the device operated within its cleared pressure-head envelope — is described in the bound Requirement and Claim nodes. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2).",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-worst-case-hemolysis",
  "bindsModel": "https://uofa.net/morrison/model/cfd-centrifugal-pump-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-piv-measurements",
    "https://uofa.net/morrison/data/hemolysis-index-bench-tests"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA bench data at nominal CPB operating point"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation via PIV measurements in the pump volute"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042665",
