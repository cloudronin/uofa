  "signature": "ed25519:9c4d1e2f3a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 certification or equivalent QMS documentation covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under an ISO 9001-certified QMS. Regression test suite results and release notes for the hemolysis scalar transport module were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent benchmark demonstrates solver correctly implements governing equations to within expected truncation-error order.",
      "rationale": "MMS studies for the incompressible Navier-Stokes solver and the scalar hemolysis transport equation confirm second-order spatial convergence on structured hexahedral meshes, consistent with published verification benchmarks for this solver version."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary QoI (hemolysis index) must be below 5% on the production mesh.",
      "rationale": "Three-level mesh refinement study (4.2 M, 11.7 M, and 28.4 M cells) yields GCI of 3.1% for the normalised hemolysis index at the 6 L/min design point, satisfying the 5% threshold. The 11.7 M cell mesh is adopted for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, hematocrit) must be documented with measurement uncertainty and replicated in the simulation setup.",
      "rationale": "FDA bench test protocols specify flow rates measured to ±0.5% via Coriolis meter and pressures to ±0.3 mmHg. Simulation boundary conditions are set to measured mean values; inlet turbulence intensity is derived from upstream pipe Reynolds number. All conditions are traceable to the test report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with measured values within ±15% across the CPB operating envelope (3–6 L/min, 60–120 mmHg).",
      "rationale": "Across eight operating points spanning the full CPB envelope, the model predicts hemolysis index within 9.4% RMS of bench measurements. The achieved level exceeds the MRL 2 requirement, providing additional confidence in worst-case identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalised hemolysis index, NIH) must be directly linked to the clinical risk metric specified in the device design input requirements for CPB use.",
      "rationale": "The normalised index of hemolysis (NIH) is the regulatory-accepted metric per ASTM F1841 and is explicitly referenced in the device design input requirements. The model outputs NIH at all operating points, ensuring direct relevance to the clinical risk decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and a blood-analogue fluid with viscosity and density matched to human blood at 37 °C within ±5%.",
      "rationale": "Validation tests used the FDA generic centrifugal pump geometry (identical to the simulation geometry) with a glycerol-water analogue (viscosity 3.5 ± 0.1 mPa·s, density 1050 ± 3 kg/m³ at 37 °C), satisfying the ±5% matching criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance at gradation 1 is sufficient.",
      "rationale": "At MRL 2, explicit quantification of iterative solver residual contributions beyond standard convergence monitoring is not required. Residuals are monitored to 1e-5 for all equations, consistent with MRL 2 practice."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; standard analyst qualification records are sufficient.",
      "rationale": "Analysts hold documented CFD competency qualifications. Formal use-error sensitivity studies are scoped out at MRL 2 per the credibility plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection (SST k-ω) must be justified by published literature for rotating blood-contacting devices; formal model-form uncertainty quantification is not required at MRL 2.",
      "rationale": "SST k-ω is selected based on published benchmark studies for centrifugal blood pumps (Fraser et al., 2011; Hariharan et al., 2011) demonstrating superior near-wall accuracy relative to k-ε variants. Formal model-form UQ is deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "All model inputs (geometry, fluid properties, rotational speed) are sourced from FDA public dataset and device drawings. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; single-lot fluid analogue with documented provenance is acceptable.",
      "rationale": "Validation experiments used a single certified lot of glycerol-water analogue. Statistical characterisation across multiple lots is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of validation conditions to COU conditions is sufficient.",
      "rationale": "A qualitative parameter equivalency table mapping the validation test conditions to the CPB operating envelope is documented in the credibility plan. Quantitative equivalency metrics are not required at MRL 2."
    }
  ],
