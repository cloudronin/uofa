  "signature": "ed25519:b1e4a7c2f9d3e6b0a5c8f2d1e7b4a9c3f6d0e2b8a1c5f3d7e9b2a4c6f0d1e3b5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022R2) must hold ISO 9001 certification and current ASME NQA-1 software quality documentation; version control and regression test suite must be on record.",
      "rationale": "ANSYS Fluent 2022R2 holds ISO 9001:2015 certification. Solver regression test suite covering 1200+ benchmark cases is documented in the vendor quality manual. Version control records confirm reproducible simulation environment. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate order-of-accuracy convergence on canonical rotating-frame flow benchmarks (Taylor–Green vortex, rotating channel) consistent with second-order spatial discretization.",
      "rationale": "ANSYS Fluent 2022R2 code verification documentation demonstrates second-order spatial accuracy on rotating-frame benchmark problems. Observed order of accuracy 1.94 on Taylor–Green vortex with rotating reference frame. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine-to-medium mesh refinement ratio of 1.3; Richardson extrapolation applied to three mesh levels.",
      "rationale": "Three-level mesh refinement study performed (coarse: 2.1M, medium: 5.8M, fine: 15.4M cells). GCI for IH at design point: 3.2% (medium-to-fine). Richardson extrapolation confirms asymptotic convergence. Discretization error within acceptance threshold. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions (fluid viscosity, hematocrit, temperature, inlet flow waveform) must match simulation boundary conditions within ±5% for primary hemodynamic parameters.",
      "rationale": "In-vitro validation experiments conducted with porcine blood analog (glycerol-saline, viscosity 3.5 cP ±0.1 cP) at 37°C ±0.5°C. Inlet flow rate controlled to ±2% of target. Boundary condition correspondence documented in test protocol TP-CPB-2023-04. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with measured IH within ±15% across the operating envelope (3–7 L/min, 3000–5000 RPM); pressure-rise curve must agree within ±10%.",
      "rationale": "Predicted IH agrees with measured values within 9.4% across all 12 operating points tested. Pressure-rise curve agreement within 6.2% RMS. Spatial velocity field comparison with PIV data shows mean error of 4.8% in impeller region. Exceeds required level 2 threshold; achieved level 3 credited. Required level 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (hemolysis index IH per ASTM F1841) must be directly linked to the clinical endpoint of sub-lethal erythrocyte damage; secondary QoIs (wall shear stress, exposure time) must be mechanistically justified.",
      "rationale": "Hemolysis index IH computed via the Giersiepen–Wurzinger power-law model is the regulatory-accepted surrogate for erythrocyte sub-lethal damage per ASTM F1841. Wall shear stress and Lagrangian exposure time are mechanistically coupled QoIs per the damage model. Relevance to CPB clinical endpoint documented in claim record. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump) at flow rates and RPM spanning the CPB clinical operating envelope; blood analog fluid properties must be physiologically representative.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry (STL file SHA-256 verified against FDA repository). Operating conditions span 3–7 L/min and 3000–5000 RPM, fully bracketing the CPB clinical envelope. Glycerol-saline analog with matched viscosity and density used. Validation activity relevance to CPB intended use confirmed. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; commercial solver with documented verification record is accepted as sufficient for this risk level.",
      "rationale": "At Model Risk Level 2, independent assessment of numerical solver error beyond code verification documentation is not required per ASME V&V 40 Table 4. Commercial solver quality record is accepted. Factor scoped to required level 1 and not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation execution checklist and peer review of setup files are considered sufficient.",
      "rationale": "At MRL 2, formal use-error assessment is not required. Simulation setup was peer-reviewed by a second analyst and execution checklist TP-CPB-2023-04 Appendix B was completed. Required level 1 met without formal assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; selection of SST k-omega turbulence model and Giersiepen–Wurzinger hemolysis model documented with literature justification.",
      "rationale": "Model form selection (SST k-omega turbulence closure, Giersiepen–Wurzinger power-law hemolysis model) is documented with supporting literature references (Hariharan et al. 2011, Taskin et al. 2012). Formal model form uncertainty quantification not required at MRL 2. Required level 1 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values (viscosity, density, rotational speed, inlet flow rate) documented with source traceability.",
      "rationale": "All model inputs documented in simulation setup record SSR-CPB-2023-01 with source traceability to measured fluid properties and device specifications. Uncertainty propagation through input space not required at MRL 2. Required level 1 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; single pump specimen used for validation with documented dimensional inspection confirming geometric conformance to FDA reference geometry.",
      "rationale": "Single pump specimen fabricated by SLA with dimensional inspection report DI-CPB-2023-02 confirming geometry within ±0.1 mm of FDA reference STL. Sample-to-sample variability assessment not required at MRL 2. Required level 1 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; dimensional analysis confirming Reynolds number and flow coefficient similarity between validation experiments and clinical operating conditions is documented.",
      "rationale": "Dimensional analysis confirms Reynolds number similarity (Re_validation = 4200–8800 vs Re_clinical = 4100–8600) and flow coefficient similarity (phi ±3%) between validation and clinical operating conditions. Formal equivalency assessment not required at MRL 2. Required level 1 met."
    }
