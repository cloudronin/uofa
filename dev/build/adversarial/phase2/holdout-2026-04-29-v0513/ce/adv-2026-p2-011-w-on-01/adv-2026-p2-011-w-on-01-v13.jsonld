  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QA process covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022R2 is used under an ISO 9001-certified QA framework. Version control, automated regression suite, and release notes are on file. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via published benchmark problems (e.g., lid-driven cavity, Poiseuille flow) with documented convergence to analytical solutions.",
      "rationale": "ANSYS Fluent passes the ASME V&V 20 benchmark suite. Manufacturer-supplied verification reports confirm second-order spatial accuracy on structured meshes relevant to internal rotating flows."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the hemolysis index QoI across at least three systematically refined meshes; GCI on the finest grid must be below 5%.",
      "rationale": "A three-level mesh refinement study (4.2 M, 11.8 M, 28.4 M cells) was performed at the nominal operating point. GCI on the fine grid is 1.8% for the hemolysis index, exceeding the required level. The 11.8 M cell mesh is adopted for all production runs as the balance of accuracy and cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, hematocrit) must be documented with measurement uncertainty and must match the CFD boundary conditions within stated tolerances.",
      "rationale": "FDA bench test conditions are fully documented in the experimental protocol. Inlet flow rate uncertainty is ±0.05 L/min; outlet pressure uncertainty is ±2 mmHg. CFD boundary conditions are set to the measured mean values; sensitivity to boundary condition uncertainty is bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with measured values within the combined experimental and numerical uncertainty band at all five validation operating points.",
      "rationale": "Predicted hemolysis index values fall within the combined uncertainty band at all five operating points. Maximum normalised error is 8.3%, within the 12% acceptance threshold established for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (hemolysis index) must be directly linked to the decision QoI (identification of worst-case hemolysis operating condition) with documented mapping.",
      "rationale": "The hemolysis index computed via the power-law damage accumulation model is the direct regulatory QoI for CPB device submissions. The mapping from local shear stress history to device-level hemolysis index is documented and accepted by FDA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, the same blood analogue fluid, and operating conditions spanning the intended clinical flow and speed range.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump geometry using a glycerol-water blood analogue at 37 °C. Operating points span 2–6 L/min and 2000–4000 RPM, matching the intended clinical envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence to residual below 1e-5 is documented as a proxy.",
      "rationale": "At MRL 2 a formal numerical solver error quantification beyond residual monitoring is not required. Residuals converge below 1e-5 for all equations; mass imbalance is below 0.01%. This factor is not assessed per the MRL 2 assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records are maintained as a procedural control.",
      "rationale": "Formal use-error analysis is not required at MRL 2. The simulation team holds documented CFD training records and follows a standard operating procedure for mesh generation, boundary condition setup, and post-processing. This factor is scoped out of the formal assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection (k-omega SST turbulence, power-law hemolysis) is documented with literature justification.",
      "rationale": "Model form uncertainty quantification is not required at MRL 2. The k-omega SST turbulence model and Giersiepen-Wurzinger power-law hemolysis model are selected based on published benchmarks for rotary blood pumps. Selection rationale is documented in the modelling assumptions log."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal fluid properties and hemolysis model constants are tabulated with source references.",
      "rationale": "Formal input uncertainty propagation is not required at MRL 2. Fluid density, viscosity, and hemolysis model constants are taken from published literature values and tabulated in the simulation input deck. Sensitivity to ±10% variation in hemolysis constants was explored informally and found to shift the index by less than 15%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; the FDA experimental dataset provides a single well-characterised pump specimen.",
      "rationale": "Statistical characterisation of sample-to-sample variability across multiple pump specimens is not required at MRL 2. The FDA generic pump is a reference geometry with tight manufacturing tolerances; a single specimen is used for both PIV and hemolysis bench tests."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; documented mapping between experimental and simulation input parameters is provided.",
      "rationale": "Formal equivalency assessment is not required at MRL 2. A parameter mapping table confirming that CFD boundary conditions reproduce the experimental inlet flow rate, outlet pressure, rotational speed, and fluid temperature is included in the validation report appendix."
    }
  ],
