      "name": "PIV velocity field comparison — FDA generic centrifugal blood pump"
    },
    {
      "id": "https://uofa.net/morrison/validation/cbp-hemolysis-index-bench",
      "type": "ValidationResult",
      "name": "Hemolysis index bench test comparison across five operating points"
