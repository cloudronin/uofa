  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/DR-MORRISON-CPB-2024-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/cardiovascular-cfd-lab-lead-engineer",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately scoped to not-assessed status consistent with MRL 2 guidance. Validation evidence demonstrates that the CFD hemolysis model predicts nIH within ±18% of bench measurements across the CPB operating envelope, with GCI below 4% on the production mesh. The model is judged credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in the CPB application as described in the associated regulatory requirement REQ-CPB-2024-007 and claim CLAIM-MORRISON-CPB-HI-2024. Decision: Accepted for intended regulatory submission use.",
