  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This unit evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Intended use is bounded by the operating envelope defined in the associated regulatory submission requirement REQ-CPB-2024-007: flow rates 2–7 L/min, rotational speeds 2000–4500 RPM, fluid viscosity 2.7–3.5 cP, hematocrit 30–45%, steady-state and pulsatile inlet waveforms. Model outputs are scalar hemolysis index and regional shear-stress distributions; decision criterion is whether predicted HI at worst-case operating point remains below the 0.8 g/dL regulatory threshold with 95% confidence.",
  "bindsRequirement": "https://uofa.net/synth/req/REQ-CPB-2024-007",
  "bindsClaim": "https://uofa.net/synth/claim/CLAIM-MORRISON-CPB-HI-2024",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-gcbp-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-gcbp-piv-dataset-2013",
    "https://uofa.net/synth/data/morrison-hemolysis-bench-2022",
    "https://uofa.net/synth/data/gcbp-pressure-flow-characterization-2021"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/VR-GCBP-VELOCITY-FIELD-001",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic centrifugal blood pump",
      "description": "Computational velocity fields compared against FDA-released PIV measurements at five operating points spanning the CPB flow envelope. Mean absolute error in normalized velocity magnitude below 4.2% across all measurement planes. Turbulent kinetic energy distributions show good qualitative agreement; minor discrepancies in the impeller tip region attributed to PIV shadow masking."
    },
    {
      "id": "https://uofa.net/synth/validation/VR-GCBP-HI-BENCH-002",
      "type": "ValidationResult",
      "name": "Hemolysis index bench validation — Morrison et al. 2022 dataset",
      "description": "Predicted normalized index of hemolysis (nIH) compared against in-vitro measurements from Morrison et al. (2022) across 12 operating conditions. Model predictions fall within ±18% of measured nIH values at all points; systematic over-prediction at low-flow/high-speed conditions noted and bounded by conservative model inputs. Goodness-of-fit R² = 0.91."
    },
    {
      "id": "https://uofa.net/synth/validation/VR-GCBP-PRESSURE-003",
      "type": "ValidationResult",
      "name": "Pump pressure-flow characteristic validation",
      "description": "Simulated H-Q curves compared against manufacturer-supplied pressure-flow characterization data. Predicted differential pressure within 3.1% of measured values across the full operating range, confirming adequate bulk flow field fidelity as a prerequisite for hemolysis prediction accuracy."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4056789",
  "wasAttributedTo": "https://uofa.net/synth/org/cardiovascular-cfd-lab-uofa",
