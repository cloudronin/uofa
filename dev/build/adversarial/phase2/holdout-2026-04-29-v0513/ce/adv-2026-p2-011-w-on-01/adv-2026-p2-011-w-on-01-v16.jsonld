  "signature": "ed25519:9c4a1f3b7e2d05a8c6f1b4e7d0a3f6c9b2e5a8d1f4c7b0e3a6d9c2f5b8e1a4d7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA process consistent with MRL 2 requirements, including version control and regression testing.",
      "rationale": "ANSYS Fluent 2022 R1 was used under an ISO 9001-compliant QA framework. Version control, release notes, and regression test suites are documented. Achieved level 2 satisfies the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark verification cases must confirm correct implementation of governing equations relevant to rotating turbomachinery hemolysis simulation at MRL 2.",
      "rationale": "Code verification was performed using manufactured solution benchmarks for the Navier-Stokes equations in rotating reference frames. Results are consistent with published verification suites for ANSYS Fluent. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence must be demonstrated for hemolysis index and shear stress quantities of interest using at least three systematically refined meshes.",
      "rationale": "Three meshes (2.1M, 5.4M, 11.8M elements) were used in a Richardson extrapolation study. GCI for hemolysis index was below 4% on the medium mesh, which was selected for production runs. Achieved level 2 meets the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to enable comparison with simulation boundary conditions at MRL 2.",
      "rationale": "FDA pump experimental conditions (flow rates 2.5–7.5 L/min, rotational speeds 2000–3500 RPM, blood analog fluid properties) are fully documented and traceable to published FDA interlaboratory study data. Achieved level 2 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., relative error, validation uncertainty) must be computed for primary quantities of interest against experimental data.",
      "rationale": "Hemolysis index predictions agree with experimental measurements within 15% relative error across all operating points. Validation uncertainty was quantified using ASME V&V 20 methodology. The achieved level 3 exceeds the required level 2, providing additional confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest used in validation must be directly relevant to the clinical decision question of identifying worst-case hemolysis operating conditions.",
      "rationale": "Hemolysis index and volume-averaged shear stress are the primary QoIs, directly linked to red blood cell damage mechanisms and the regulatory question of worst-case pump operating point identification. Relevance is established at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the operating envelope relevant to CPB conditions for a Class II device, including physiological flow rates and rotational speeds.",
      "rationale": "Validation experiments span the CPB operating envelope (2.5–7.5 L/min, 2000–3500 RPM) using the FDA generic pump geometry. The validation domain overlaps with the intended clinical operating range. Level 2 relevance is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed iterative convergence analysis beyond standard residual monitoring is not required for this factor.",
      "rationale": "Solver residuals were monitored to 1e-5 for all equations as standard practice. Formal solver error quantification beyond residual monitoring is scoped out at MRL 2 for this assessment. Factor is not-assessed per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis is not required at MRL 2 for a research-grade credibility assessment of a Class II device model.",
      "rationale": "The simulation is executed by trained CFD engineers with documented boundary condition setup procedures. Formal use error characterization is not required at MRL 2 and is scoped out for this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, systematic model form uncertainty quantification is not required; selection of turbulence and hemolysis models must be documented.",
      "rationale": "The SST k-omega turbulence model and the Giersiepen-Wurzinger hemolysis power-law model were selected based on published literature for blood pump CFD. Formal model form uncertainty analysis is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal values for blood analog fluid properties and pump geometry are sufficient at MRL 2; probabilistic input uncertainty propagation is not required.",
      "rationale": "Blood analog fluid properties (viscosity 0.0035 Pa·s, density 1056 kg/m³) and pump geometry are fixed at nominal values consistent with the FDA interlaboratory study. Input uncertainty propagation is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample characterization beyond what is reported in the FDA interlaboratory study is not required at MRL 2.",
      "rationale": "Test sample characterization (blood analog composition, hematocrit) is documented in the FDA interlaboratory study publications. Additional sample variability analysis is scoped out at MRL 2 for this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and clinical use inputs is not required at MRL 2 for this factor.",
      "rationale": "The FDA pump geometry and operating conditions used in validation are representative of the CPB clinical envelope. Formal equivalency analysis of all input parameters is scoped out at MRL 2. The overlap is addressed qualitatively in the relevance factors."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-credibility-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for Model Risk Level 2. The CFD hemolysis model for the FDA generic centrifugal blood pump is credible for identifying worst-case hemolysis operating conditions in the CPB application context as described in the bound Requirement and Claim. Six factors are appropriately scoped out at MRL 2. The assessment is accepted for regulatory submission support for a Class II CPB device.",
