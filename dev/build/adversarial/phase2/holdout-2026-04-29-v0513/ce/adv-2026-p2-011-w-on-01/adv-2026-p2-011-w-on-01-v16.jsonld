    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison-cpb",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump in vitro measurements at CPB operating conditions"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements in the FDA generic centrifugal pump"
    }
  ],
