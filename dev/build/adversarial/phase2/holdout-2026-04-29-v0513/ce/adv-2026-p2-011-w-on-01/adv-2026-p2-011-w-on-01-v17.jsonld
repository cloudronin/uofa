      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under an institutional SQA plan with documented version control, regression testing, and issue tracking consistent with MRL 2 expectations.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under the laboratory SQA plan. Version control via Git, automated regression suite covering 47 canonical cases, and a tracked issue log demonstrate compliance with the required gradation for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing on canonical benchmark problems must confirm spatial and temporal discretization convergence rates consistent with solver documentation.",
      "rationale": "Richardson extrapolation on lid-driven cavity and pipe-flow benchmarks confirms second-order spatial accuracy. Temporal convergence verified on pulsatile flow benchmark. Results match published solver verification suite."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the hemolysis index and wall shear stress QoIs; GCI must be below 5% on the fine mesh.",
      "rationale": "Three-mesh GCI study (coarse 1.2 M, medium 4.8 M, fine 18.6 M cells) yields GCI of 2.1% for hemolysis index and 3.4% for peak wall shear stress on the fine mesh. Exceeds required level, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid viscosity, hematocrit) must be documented and traceable to calibrated instrumentation with reported uncertainty.",
      "rationale": "FDA benchmark experimental data report calibrated Coriolis flow meters (±0.5% FS) and pressure transducers (±0.3% FS). Bovine blood viscosity and hematocrit (40±2%) are reported per ASTM F1841. Conditions are faithfully reproduced in simulation boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index predictions must agree with experimental measurements within ±20% across all five validation operating points.",
      "rationale": "Predicted normalized index of hemolysis (nIH) deviates from experimental values by 4%–17% across five operating points (2–8 L/min, 60–120 mmHg). All points fall within the ±20% acceptance band. Mean absolute error is 9.3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoIs (nIH, peak scalar stress, exposure time distribution) must be directly linked to the clinical decision metric of identifying worst-case hemolysis operating conditions.",
      "rationale": "nIH is the regulatory-accepted metric for hemolysis assessment per FDA guidance. Peak scalar stress and exposure time distribution are the mechanistic inputs to the power-law hemolysis model. All three QoIs are directly actionable for worst-case operating-point identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid properties, and operating envelope as the intended CPB clinical use scenario.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry identical to the simulation domain. Bovine blood analogue properties bracket clinical hematocrit range. Operating points span the CPB clinical envelope (2–8 L/min, 60–120 mmHg), confirming relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; iterative convergence to residual tolerance 1e-5 is documented as a proxy indicator.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond iterative convergence monitoring is not required. Residuals converged to 1e-5 for all equations; mass imbalance below 0.01%. Scoped out per MRL 2 assessment table."
    },
