      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark dataset provides sufficient sample characterization for this risk level.",
      "rationale": "The FDA benchmark dataset is a publicly available, peer-reviewed multi-laboratory dataset; detailed sample-to-sample variability analysis is not required at MRL 2."
    },
