      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark verification cases relevant to rotating-frame turbulent flow.",
      "rationale": "Fluent 2022R2 has been verified against ASME V&V 20 lid-driven cavity and rotating-channel benchmarks; order-of-accuracy confirmed at second order for momentum equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI is less than 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed (coarse 4.2 M, medium 9.8 M, fine 21.3 M cells). GCI for normalized index of hemolysis is 3.1% on fine mesh; Richardson-extrapolated value used as reference."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature) are documented and reproduced in simulation to within stated uncertainty.",
      "rationale": "FDA benchmark test conditions (2–8 L/min, 2000–3500 RPM, 37 °C phosphate-buffered saline with RBCs) are replicated in CFD boundary conditions; inlet velocity profiles derived from measured data."
    },
