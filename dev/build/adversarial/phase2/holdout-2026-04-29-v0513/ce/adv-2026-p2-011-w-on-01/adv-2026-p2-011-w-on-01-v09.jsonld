      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis agrees with experimental mean within two experimental standard deviations across all five operating points.",
      "rationale": "CFD-predicted NIH values fall within ±1.4 experimental standard deviations at all five FDA benchmark operating points; systematic over-prediction of 8% at peak RPM is within stated experimental uncertainty band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis and shear stress distribution) directly supports identification of worst-case operating conditions for the CPB device.",
      "rationale": "NIH and volume-averaged scalar shear stress are the primary regulatory metrics for CPB hemolysis assessment; their direct relevance to worst-case operating-point identification is established in FDA guidance and peer-reviewed literature."
