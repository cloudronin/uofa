  "signature": "ed25519:b7e2d19a3c04f85621a0b3d7e94c1f2a8305d6b1c7e4f09a2d58b3c6e1a07f4d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under an ISO 9001-compliant QMS with documented test suite covering steady-state incompressible turbulent flow; all critical defects resolved prior to release.",
      "rationale": "ANSYS Fluent 2022 R2 is developed under a documented ISO 9001 QMS. The solver's internal verification test suite for incompressible RANS turbulent flow was reviewed and all relevant test cases passed. No open critical defects affecting rotating-machinery hemolysis simulations were identified. Achieves Gradation 2 as required for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification against manufactured solutions for the incompressible Navier-Stokes equations must demonstrate expected spatial convergence rate within 10% of theoretical order.",
      "rationale": "Method of manufactured solutions (MMS) applied to a 3-D incompressible RANS case confirmed second-order spatial accuracy (observed order 1.94). Temporal discretisation verified separately on a transient benchmark. Both checks passed acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for the normalised index of hemolysis QoI must be below 5% on the fine grid.",
      "rationale": "Three systematically refined meshes (4.2 M, 11.7 M, 28.4 M cells) were generated using a refinement ratio of 1.41. Richardson extrapolation yielded GCI_fine = 2.8% for NIH, well below the 5% threshold. The fine mesh was selected for all production runs, exceeding the Gradation 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, hematocrit, temperature, inlet/outlet boundary conditions) must be documented with measurement uncertainty and must bracket the CPB operating envelope.",
      "rationale": "FDA PIV dataset documents all boundary conditions with stated uncertainties (inlet velocity ±1.5%, temperature ±0.5 °C, hematocrit 35±2%). Five operating points spanning 1500–3500 RPM and 3–7 L/min bracket the intended CPB envelope. Condition documentation meets Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rms of velocity profiles, percent error on NIH) must be reported with uncertainty bounds; model must fall within experimental uncertainty at ≥80% of comparison points.",
      "rationale": "Velocity field E_rms = 4.1% across 12 PIV planes; NIH percent error ≤9% at all five operating points. Model predictions fall within experimental uncertainty at 91% of comparison locations. Quantitative metrics reported with full uncertainty propagation. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalised index of hemolysis) must be directly linked to the device safety endpoint (blood trauma) and must be measurable both experimentally and computationally.",
      "rationale": "NIH is the accepted regulatory QoI for blood-contacting CPB devices and maps directly to the ISO 10993-4 biocompatibility endpoint. It is computed from the power-law hemolysis model applied to Lagrangian particle trajectories and measured via plasma-free haemoglobin assay in bench tests. Direct QoI alignment confirmed at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal blood pump) and must cover the CPB flow-rate and rotational-speed ranges relevant to the intended clinical use.",
      "rationale": "Validation used the FDA GCBP geometry, identical to the simulation geometry. Operating points cover 3–7 L/min and 1500–3500 RPM, encompassing standard adult CPB conditions (4.5–6 L/min, 2200–3000 RPM). Geometric and operational relevance confirmed at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "Solver round-off and iterative convergence errors acknowledged; no quantitative bounding required at MRL 2 for this factor.",
      "rationale": "At MRL 2, full quantification of solver round-off error is not required. Iterative residuals converged to 1×10⁻⁶ for all equations. Double-precision arithmetic used throughout. Scoped out per MRL 2 factor table; Gradation 1 accepted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "Analyst error controls acknowledged; formal independent review not required at MRL 2.",
      "rationale": "Simulation setup was performed by a senior CFD engineer with 8 years of cardiovascular device experience. Internal peer review of boundary conditions and meshing strategy was conducted. Formal independent third-party audit not required at MRL 2. Scoped out at Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "Turbulence model selection (SST k-ω) acknowledged as a source of model-form uncertainty; sensitivity study not required at MRL 2.",
      "rationale": "SST k-ω turbulence model selected based on literature consensus for rotating blood-pump flows. Model-form uncertainty acknowledged but formal sensitivity study across alternative turbulence closures is not required at MRL 2. Scoped out at Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "Key model inputs (blood viscosity, hemolysis model coefficients) documented; formal uncertainty propagation not required at MRL 2.",
      "rationale": "Blood viscosity modelled as Newtonian (μ = 0.0035 Pa·s) consistent with high-shear CPB conditions. Power-law hemolysis coefficients (C = 1.8×10⁻⁶, α = 1.991, β = 0.765) taken from Heuser & Opitz (1980). Input uncertainty propagation scoped out at MRL 2 per factor table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "Sample size and lot variability for experimental blood analogue acknowledged; statistical characterisation not required at MRL 2.",
      "rationale": "PIV experiments used a glycerol-water blood analogue (μ = 0.0035 Pa·s, ρ = 1056 kg/m³). Haemolysis bench tests used porcine blood (n=3 per operating point). Sample variability acknowledged; formal statistical power analysis scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "Correspondence between experimental boundary conditions and simulation inputs documented; formal equivalency mapping not required at MRL 2.",
      "rationale": "Inlet velocity profiles extracted from PIV measurements and applied directly as simulation boundary conditions. Rotational speed matched to within 0.5% of experimental setpoints. Equivalency documented in the simulation report; formal parameter-mapping matrix scoped out at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for MRL 2. The six scoped-out factors are appropriately justified per the ASME V&V 40-2018 MRL 2 factor table. Validation evidence from the FDA GCBP PIV dataset and in-house hemolysis bench tests demonstrates that the CFD model reliably identifies worst-case hemolysis operating conditions within the CPB flow and speed envelope. The Claim that the model is fit for purpose to support 510(k) substantial-equivalence submissions for Class II CPB devices is accepted. No open weakeners identified.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
