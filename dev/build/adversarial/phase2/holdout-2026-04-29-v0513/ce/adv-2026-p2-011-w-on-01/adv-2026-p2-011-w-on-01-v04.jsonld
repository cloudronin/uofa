    {
      "id": "https://uofa.net/synth/validation/gcbp-velocity-field-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic centrifugal blood pump at 2500 RPM / 5 L/min CPB operating point"
    },
    {
      "id": "https://uofa.net/synth/validation/gcbp-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalised index of hemolysis (NIH) comparison against bench measurements across five CPB operating conditions"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4048801",
