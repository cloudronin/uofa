  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QA process covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an ISO 9001-certified QA framework. Version control logs, regression test suite results, and release notes are archived. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through published benchmark problems (e.g., lid-driven cavity, Taylor-Green vortex) with documented order-of-accuracy confirmation.",
      "rationale": "ANSYS Fluent code verification against ASME benchmark cases is documented in the solver theory and verification manual. Second-order spatial accuracy confirmed for the incompressible Navier-Stokes solver used here."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the normalized index of hemolysis must be below 5% on the medium-to-fine mesh refinement pair.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 8.7 M, 17.1 M cells). GCI for NIH between medium and fine meshes is 3.8%, satisfying the acceptance criterion. Medium mesh (8.7 M cells) adopted for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be reproduced in simulation to within ±5% of measured values.",
      "rationale": "CFD boundary conditions replicate bench test conditions: flow rate 5 L/min ±2%, speed 3500 RPM ±0.3%, fluid temperature 37°C ±0.5°C, hematocrit 30% ±1%. All within tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with measured NIH within ±20% across all six validation operating points; predicted velocity field must achieve normalized RMS error below 15% relative to PIV data.",
      "rationale": "NIH prediction error ranges from −12% to +17% across six operating points; mean absolute error 9.4%. Velocity field normalized RMS error is 11.2% versus PIV measurements. Both criteria satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis) must be directly linked to the clinical harm mechanism (red blood cell lysis) and must be measurable in both simulation and bench experiment.",
      "rationale": "NIH is the FDA-recognized metric for hemolysis risk in blood-contacting devices and is computed from the power-law Giersiepen-Wurzinger model applied to Lagrangian particle tracks. Direct correspondence between simulated and measured NIH established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the operating envelope relevant to CPB use (2–6 L/min, 1500–3500 RPM) and use the same pump geometry as the clinical device model.",
      "rationale": "Six validation points cover 3–5 L/min and 2500–3500 RPM using the FDA generic centrifugal blood pump geometry, which serves as the reference model for the Class II CPB device assessment. Envelope coverage is adequate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; iterative convergence to residuals below 1e-5 documented as a minimum control.",
      "rationale": "At MRL 2, detailed iterative solver error quantification is not required. Residuals for all equations converged below 1e-5; mass imbalance below 0.01%. Scoped out per ASME V&V 40 Table 1 guidance for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst training records reviewed as minimum control.",
      "rationale": "MRL 2 does not require formal use-error analysis. Lead analyst holds CFD certification and has five years of blood pump simulation experience. Training records on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
