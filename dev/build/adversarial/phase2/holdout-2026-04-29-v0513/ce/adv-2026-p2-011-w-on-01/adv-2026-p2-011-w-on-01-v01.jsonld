      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; qualitative mapping between simulation inputs and experimental conditions documented.",
      "rationale": "Qualitative correspondence between CFD boundary conditions and experimental setup confirmed by review of test protocol and simulation setup document. Formal equivalency analysis not required at MRL 2."
    }
