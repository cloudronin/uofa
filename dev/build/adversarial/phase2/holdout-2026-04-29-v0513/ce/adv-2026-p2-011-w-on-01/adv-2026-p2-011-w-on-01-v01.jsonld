      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; model form selection rationale documented.",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger) selected based on literature precedent for centrifugal pumps. Model form uncertainty not formally quantified at MRL 2 per ASME V&V 40 Table 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values sourced from published literature and manufacturer data sheets.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hemolysis model constants sourced from peer-reviewed literature. Sensitivity analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; sample preparation protocol documented.",
      "rationale": "Bovine blood used for bench hemolysis testing; preparation protocol (anticoagulation, hematocrit adjustment) documented per ASTM F1841. Statistical characterization of sample variability not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
