  "name": "Morrison CFD Hemolysis Credibility Assessment — CPB Use (Minimal Profile)",
  "description": "Credibility assessment for CFD-based hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) operating conditions. The model is intended to identify worst-case hemolysis operating points for a Class II CPB device at Model Risk Level 2. Thirteen ASME V&V 40 credibility factors are evaluated: seven assessed (all meeting or exceeding required levels for MRL 2) and six scoped out as not-applicable at this risk level. The assessment supports a regulatory submission decision that the computational model provides adequate credibility for the stated engineering use.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2-req",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-cfd-hemolysis-worst-case-identification",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-gcbp-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/fda-gcbp-piv-velocity-dataset"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA GCBP experimental benchmark across five operating points"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-velocity-vr-02",
      "type": "ValidationResult",
      "name": "Velocity field comparison via PIV measurements at nominal CPB flow rate (5 L/min, 3500 RPM)"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041524",
