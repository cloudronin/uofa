  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1b09d4856fe23a1cc7d3e09b2f541d8e67c0b3a92f1d4e85c6b7a0912",
  "signature": "ed25519:b1e4d7f3a20c958e6b3f17a04d2c8e5f9a1b3c7d0e2f4a6b8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2b4c6d8e0f2a4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented verification test suite and version-controlled input files; achievedLevel must meet or exceed requiredLevel of 2 for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 was used with a documented QA plan including version control of all case files, solver settings, and UDF source code. The software vendor's verification test suite covers the relevant solver modules. Achieved gradation 2 is consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark problems relevant to rotating turbomachinery flows; achievedLevel must meet requiredLevel of 2.",
      "rationale": "The CFD solver was verified against the lid-driven cavity and Taylor-Couette flow benchmarks documented in the ANSYS verification manual. Results match analytical solutions to within 1% for velocity profiles, confirming adequate numerical code correctness for the rotating pump geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed on three systematically refined meshes; GCI for hemolysis index QoI must be below 5%; achievedLevel must meet or exceed requiredLevel of 2.",
      "rationale": "A three-level mesh refinement study (coarse 4.2M, medium 8.7M, fine 17.1M cells) was conducted at the nominal CPB operating point. Richardson extrapolation yielded a GCI of 2.3% for the hemolysis index, satisfying the acceptance criterion. The fine mesh was adopted for all subsequent simulations. Achieved gradation 3 exceeds the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate) are documented with measurement uncertainty; conditions span the CPB operating envelope; achievedLevel must meet requiredLevel of 2.",
      "rationale": "FDA GCBP experimental data were collected at five operating points (2000–5000 RPM, 2–8 L/min) using a blood analog fluid (water-glycerol) with documented viscosity and density. Pressure and flow rate measurement uncertainties are reported as ±2% and ±1% respectively, consistent with gradation 2 documentation requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or normalised RMS error) computed between predicted and measured hemolysis index across all validation operating points; achievedLevel must meet requiredLevel of 2.",
      "rationale": "Predicted hemolysis index values were compared to experimental measurements at all five operating points. The mean absolute percentage error was 8.4%, within the 15% acceptance threshold established for MRL 2. Worst-case operating point prediction error was 12.1%, remaining within threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress distribution) are directly linked to the clinical decision question of worst-case hemolysis identification; achievedLevel must meet requiredLevel of 2.",
      "rationale": "The primary QoI is the normalised index of hemolysis (NIH), which is the regulatory metric for blood pump biocompatibility evaluation. Secondary QoIs include volume-averaged scalar shear stress and exposure time distributions. These quantities directly support identification of worst-case hemolysis operating conditions as required by the engineering use statement embedded in the Claim and Requirement nodes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use geometry, fluid, and operating conditions sufficiently representative of the CPB clinical use envelope; achievedLevel must meet requiredLevel of 2.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry under CPB-representative flow rates (2–8 L/min) and rotational speeds. Blood analog fluid properties match clinical blood viscosity within the shear-rate range relevant to hemolysis. The validation domain adequately covers the intended CPB operating envelope as described in the Requirement node, supporting the engineering decision of worst-case condition identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default gradation 1 accepted per ASME V&V 40 Table 4 for this risk level.",
      "rationale": "Per ASME V&V 40-2018 Table 4, numerical solver error is not required to be formally assessed at Model Risk Level 2 for this device class. The commercial solver's documented iterative convergence criteria (residuals below 1e-5 for all equations) are applied as a minimum control measure. Formal round-off and iterative error quantification is deferred to higher MRL assessments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default gradation 1 accepted per ASME V&V 40 Table 4.",
      "rationale": "Use error assessment is not mandated at MRL 2 for Class II devices under the current assessment scope. Simulation inputs were reviewed by a second analyst for transcription errors as a procedural control. Formal use error quantification is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default gradation 1 accepted per ASME V&V 40 Table 4.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis power-law correlation choice) is acknowledged but not formally quantified at MRL 2. The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis correlation were selected based on published literature for centrifugal pump hemolysis prediction. Sensitivity to model form is deferred to higher MRL assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default gradation 1 accepted per ASME V&V 40 Table 4.",
      "rationale": "Formal uncertainty quantification of model input parameters (fluid viscosity, pump geometry tolerances, inlet velocity profiles) is not required at MRL 2. Nominal input values sourced from FDA GCBP specifications and published material properties are used. Input sensitivity analysis is deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default gradation 1 accepted per ASME V&V 40 Table 4.",
      "rationale": "Statistical characterisation of experimental sample variability across multiple pump units is not required at MRL 2. The FDA GCBP dataset represents a single reference geometry. Inter-unit variability assessment is deferred to higher risk level evaluations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default gradation 1 accepted per ASME V&V 40 Table 4.",
      "rationale": "Formal equivalency mapping between simulation input parameters and experimental test conditions is not required at MRL 2. Boundary conditions were set to match reported experimental values directly. Detailed equivalency analysis is deferred to higher MRL assessment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40-2018 Table 4 for a Class II device at MRL 2. The CFD hemolysis model demonstrates adequate credibility to support identification of worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB use as described in the Claim and Requirement nodes. The assessment team accepts the model for the stated engineering decision purpose.",
