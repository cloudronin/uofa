  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be version-controlled with documented regression test suite covering rotary pump geometries; all critical defects resolved prior to simulation campaign.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional SQA plan; regression suite of 47 benchmark cases executed with zero critical failures. Version control via Git with signed release tags. Meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured-solution or order-of-accuracy test demonstrating solver achieves nominal second-order convergence for incompressible rotating-frame Navier-Stokes.",
      "rationale": "Method of manufactured solutions applied to a rotating annular domain; observed order of accuracy 1.94 (expected 2.0). Discretization error in QoI < 1.5% on production mesh. Requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for NIH and peak wall shear stress on the production mesh relative to a systematically refined mesh.",
      "rationale": "Three-mesh Richardson extrapolation performed (0.8M, 3.2M, 12.8M cells). GCI for NIH = 1.8%; GCI for peak WSS = 3.1%. Both below 5% threshold. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be documented with measurement uncertainty and traceable to calibrated instruments.",
      "rationale": "FDA pump bench tests conducted at 2.5 and 5.0 L/min, 2500 RPM, 37°C, hematocrit 33±1%. All instruments NIST-traceable. Uncertainty budget provided. Test conditions adequately characterize CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation metric u_val) comparing predicted NIH to experimental NIH, with uncertainty propagation from both simulation and experiment.",
      "rationale": "E% = 8.3% for NIH at 5 L/min operating point; combined validation uncertainty u_val = 12.1%. Model prediction falls within experimental uncertainty band at both operating points. Validation metric satisfies MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, shear exposure histogram) must be directly linked to the clinical harm mode (red blood cell lysis) and to the regulatory submission metric per ISO 10993-4.",
      "rationale": "NIH is the standard regulatory metric for hemolysis assessment per FDA guidance and ISO 10993-4. Shear exposure histogram enables mechanistic interpretation. Both QoIs are directly relevant to identifying worst-case hemolysis operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic centrifugal pump geometry, blood-analog fluid with matched viscosity, and operating conditions spanning the CPB flow-rate range.",
      "rationale": "Validation performed on the identical FDA benchmark pump geometry using porcine blood at matched hematocrit. Operating points bracket the CPB range. Geometric and physiological fidelity of validation scenario is sufficient for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 beyond code verification activities already completed.",
      "rationale": "Separate numerical solver error characterization beyond the code verification factor is not required at Model Risk Level 2. Scoped out per ASME V&V 40 Table 1 guidance for MRL 2 assessments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use-error analysis not required at MRL 2; standard simulation workflow SOPs are sufficient.",
      "rationale": "Use error assessment is not required at MRL 2 per ASME V&V 40 Table 1. Simulation workflow follows documented SOPs reviewed by the credibility assessment team. No formal use-error study conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for selection of turbulence model and hemolysis power-law model, including sensitivity analysis showing NIH variation < 15% across plausible model-form alternatives.",
      "rationale": "SST k-omega turbulence model selected based on literature survey of rotating machinery CFD. Hemolysis model: Giersiepen-Wurzinger power law. Sensitivity study comparing k-epsilon realizable and LES on coarse grid shows NIH variation of 9.4%. Model form uncertainty within acceptable range for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (blood viscosity, density, pump geometry tolerances) must have documented uncertainty ranges; one-at-a-time sensitivity analysis required.",
      "rationale": "One-at-a-time sensitivity analysis performed for viscosity (±10%), density (±2%), and inlet velocity profile (±5%). NIH sensitivity coefficients: viscosity 0.12, density 0.04, inlet profile 0.07. Total input uncertainty contribution to NIH < 8%. Meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2 for this device type.",
      "rationale": "Test sample characterization beyond basic hematocrit matching is not required at MRL 2. Blood samples sourced from a single donor pool per FDA pump benchmark protocol. Formal sample variability study not conducted and not required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between simulation inputs and physical test inputs not required at MRL 2 given the direct-use validation scenario.",
      "rationale": "The validation scenario uses the same pump geometry and operating conditions as the COU; direct equivalency is established by design. Formal equivalency parameter mapping study is not required at MRL 2 and was not conducted."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels for MRL 2. The 6 non-assessed factors are appropriately scoped out per ASME V&V 40 Table 1 guidance for Class II devices at MRL 2. Discretization error and model form uncertainty are within acceptable bounds. The CFD hemolysis model is credible for identifying worst-case NIH operating conditions of the FDA generic centrifugal blood pump in CPB service. Decision: Accepted.",
