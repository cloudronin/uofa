  "signature": "ed25519:7c3a1f9e2b5d8c0a4e7f1b3d6a9c2e5f8b1d4a7c0e3f6b9d2a5c8e1f4b7d0a3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite; all regression tests passing.",
      "rationale": "ANSYS Fluent 2023R1 used under ISO 9001-certified QMS. Full regression test suite executed and passed prior to simulation campaign. Version control and configuration records archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least two canonical benchmark cases relevant to rotating machinery flows.",
      "rationale": "Fluent verified against Taylor-Couette flow and lid-driven cavity benchmarks. Results agree with published analytical and experimental references within 1.5% for velocity and pressure fields."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for primary QOI (hemolysis index) on finest two mesh levels.",
      "rationale": "Richardson extrapolation performed on three mesh levels (4M, 12M, 32M cells). GCI for normalized hemolysis index is 2.1% between medium and fine meshes. Fine mesh adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) reproduced in simulation within stated uncertainty bounds.",
      "rationale": "Six operating points (1500–3500 RPM, 3–7 L/min) replicated from FDA bench protocol. Blood analog viscosity and density matched to within 2% of experimental values. Inlet turbulence intensity set per measured PIV data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 15% of experimentally measured NIH values across all validation operating points.",
      "rationale": "Mean absolute error in normalized index of hemolysis (NIH) is 9.3% across six operating points. Maximum single-point deviation is 13.8%. All points within acceptance band. Velocity field RMSE vs PIV is 4.2% of bulk velocity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOI (hemolysis index, shear stress distribution) directly maps to clinical endpoint of red blood cell damage in CPB circuit.",
      "rationale": "Primary QOI is the power-law hemolysis index integrating scalar shear stress and exposure time along pathlines, which is the accepted surrogate for RBC damage in regulatory submissions for CPB devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic pump geometry under overlapping operating conditions with the intended CPB use envelope.",
      "rationale": "Validation dataset uses identical impeller geometry and covers the full CPB operating envelope (cardiac output 3–7 L/min, rotational speeds 1500–3500 RPM). Blood analog fluid properties are within physiological range for adult CPB."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "At Model Risk Level 2, explicit quantification of iterative solver residual error beyond standard convergence criteria is not mandated. Residuals converged to 1e-5 for all equations; no further action required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; standard analyst training records sufficient.",
      "rationale": "MRL 2 does not require formal use-error analysis. All analysts hold documented CFD competency certifications. Simulation setup reviewed by independent analyst prior to execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection documented with literature justification.",
      "rationale": "SST k-omega turbulence model selected based on published literature for rotating blood pump flows. Formal model-form uncertainty quantification not required at MRL 2 but model selection rationale is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (viscosity, density, hemolysis model constants) characterized with stated uncertainty; sensitivity analysis performed for top-3 inputs.",
      "rationale": "One-at-a-time sensitivity analysis performed for fluid viscosity, hemolysis model exponents (alpha, beta), and inlet flow rate. Hemolysis index sensitivity to viscosity is 6.2%/10% input change; model constants sensitivity is 4.1%. All within acceptable range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample documentation from FDA dataset is sufficient.",
      "rationale": "FDA benchmark dataset provides triplicate measurements at each operating point. Statistical characterization of experimental scatter is available in the public dataset documentation. Formal test-sample adequacy analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of simulation inputs to clinical use parameters documented.",
      "rationale": "Qualitative equivalency table prepared mapping simulation boundary conditions to clinical CPB operating parameters. Formal equivalency quantification deferred as not required at MRL 2 for this device class."
    }
  ],
