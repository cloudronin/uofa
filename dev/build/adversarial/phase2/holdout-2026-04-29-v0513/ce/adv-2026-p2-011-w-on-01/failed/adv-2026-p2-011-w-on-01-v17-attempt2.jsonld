  "signature": "ed25519:b1d4e7a2c5f8b3e6a9d2c5f0b3e6a9d2c5f0b3e6a9d2c5f0b3e6a9d2c5f0b3e6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented QA procedures including version control, regression testing, and release validation consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 is used with documented QA procedures, regression test suites, and ISO 9001-certified release processes. All QA records were reviewed and found compliant with the Gradation 2 threshold for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations through manufactured-solution or benchmark tests at the required gradation level.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver confirms second-order spatial accuracy. Results are consistent with published ASME V&V 20 benchmark cases for rotating machinery flows."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent Richardson-extrapolation-based error estimate must be reported for all quantities of interest, with GCI below 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry (1.2 M, 4.8 M, and 19.2 M cells). GCI for hemolysis index on the fine grid is 2.1%, exceeding the Gradation 2 threshold. Temporal discretization error assessed separately via time-step refinement; CFL < 1 maintained throughout."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented and replicated in the simulation to within measurement uncertainty bands.",
      "rationale": "Inlet flow rates, outlet pressures, rotational speed, and blood analog fluid properties from the FDA benchmark protocol are reproduced in the CFD boundary conditions. Deviations are within ±2% of reported experimental values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., validation metric U_val) must be computed and shown to fall within acceptable agreement bounds for the QOIs.",
      "rationale": "Normalized RMS error for hemolysis index across five operating points is 8.3%, within the 15% acceptance threshold established for MRL 2. Velocity field agreement assessed via U_val metric per ASME V&V 20; all comparison points satisfy required tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in simulation must be directly linked to the clinical or engineering decision criterion stated in the requirement and claim documentation.",
      "rationale": "The primary QOI is the normalized index of hemolysis (NIH), which is the FDA-accepted metric for blood trauma assessment in CPB devices. Secondary QOIs (shear stress distribution, residence time) are mechanistically linked to red blood cell damage and directly support worst-case operating point identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use geometry, flow regime, and fluid properties sufficiently representative of the intended clinical use scenario to support extrapolation of model credibility.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under the same rotational speed range (2500–3500 RPM) and flow conditions (2–6 L/min) as the target CPB operating envelope. Blood analog fluid (glycerin-water) viscosity matched to physiological blood at 37°C. Geometric and dynamic similarity assessed as adequate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must be documented; at MRL 2 Gradation 1, residual monitoring to below 1e-5 is sufficient without formal error quantification.",
      "rationale": "Not assessed beyond Gradation 1 monitoring at MRL 2. Residuals for continuity and momentum equations converged to below 1e-6 in all reported simulations. Formal iterative error quantification not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 Gradation 1, documented simulation setup review by a second analyst is sufficient.",
      "rationale": "Not assessed beyond Gradation 1 at MRL 2. Simulation setup files were reviewed by a second CFD engineer prior to production runs. No formal use-error quantification required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 Gradation 1, selection of turbulence and hemolysis sub-models must be documented with literature justification.",
      "rationale": "Not assessed beyond Gradation 1 at MRL 2. SST k-omega turbulence model selected based on published performance for rotating blood pump geometries (Hariharan et al. 2011). Giersiepen-Wurzinger hemolysis power-law model documented as standard for FDA benchmark comparisons."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 Gradation 1, nominal input values must be documented with sources; sensitivity analysis not required.",
      "rationale": "Not assessed beyond Gradation 1 at MRL 2. All model inputs (fluid density, viscosity, pump geometry dimensions, rotational speed) documented with sources. Formal uncertainty propagation and sensitivity analysis deferred as not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 Gradation 1, the number of experimental replicates must be reported; statistical characterization of inter-sample variability not required.",
      "rationale": "Not assessed beyond Gradation 1 at MRL 2. FDA benchmark dataset includes three independent experimental replicates per operating point. Statistical pooling and sample-size justification not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 Gradation 1, qualitative mapping of simulation inputs to experimental conditions is sufficient.",
      "rationale": "Not assessed beyond Gradation 1 at MRL 2. Qualitative equivalency mapping between CFD boundary conditions and experimental setup parameters documented in the simulation plan. Formal equivalency metrics not required at this model risk level."
    }
  ],
