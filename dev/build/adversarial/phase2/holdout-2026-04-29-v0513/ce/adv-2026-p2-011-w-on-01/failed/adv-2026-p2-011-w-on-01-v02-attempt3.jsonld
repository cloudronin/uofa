  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0f2a4c6e8f0b2d4f6a8c0e2f4a6b8d0f2a4c6e8f0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented software QA plan with version control and regression testing sufficient for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is commercial software with documented QA procedures, version-controlled input decks, and automated regression tests covering the hemolysis scalar transport module. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions or equivalent benchmark for the governing equations used.",
      "rationale": "Order-of-accuracy tests using the method of manufactured solutions confirm second-order spatial accuracy for the Navier-Stokes and scalar transport equations in the pump geometry. Results are consistent with published solver benchmarks at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (hemolysis index) with GCI < 5% on the fine grid.",
      "rationale": "Three-level Richardson extrapolation yields GCI of 2.1% for hemolysis index on the fine mesh (12.4 M cells). Discretization error is well within the 5% acceptance threshold, exceeding MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty quantification and traceable to the simulation inlet/outlet conditions.",
      "rationale": "FDA pump experimental flow rates (2.5–7.5 L/min) and rotational speeds (2000–3500 RPM) are documented with calibration certificates. Simulation boundary conditions are directly mapped from experimental records with stated uncertainties."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty) computed for hemolysis index across the operating envelope.",
      "rationale": "Mean absolute error of 8.3% in normalized index of hemolysis across 18 operating points, within the acceptance band defined by combined experimental and numerical uncertainty. Systematic trend is consistent across flow regimes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) are directly linked to the clinical decision question of worst-case hemolysis identification.",
      "rationale": "Hemolysis index and volume-averaged scalar shear stress are the primary QoIs. Both are directly predictive of red blood cell damage under CPB conditions and are the quantities required by the regulatory submission question."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the flow regime, geometry, and fluid properties representative of CPB operating conditions.",
      "rationale": "Validation uses the FDA generic centrifugal pump with bovine blood analogue at physiological viscosity. Operating envelope spans the CPB clinical range. Geometric and fluid similarity is documented, supporting applicability of validation evidence to the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver error subsumed within discretization error assessment.",
      "rationale": "At MRL 2, separate quantification of numerical solver error beyond discretization error is not required. The discretization error assessment encompasses iterative convergence monitoring (residuals < 1e-6) and round-off error analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; user qualification documented at organizational level.",
      "rationale": "MRL 2 does not require formal use-error assessment beyond analyst qualification records. Lead analyst holds documented CFD training and has performed three prior hemolysis assessments under organizational QA oversight."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection is justified by literature precedent.",
      "rationale": "The k-omega SST turbulence model with power-law hemolysis scalar transport is the community-standard approach for centrifugal blood pump CFD per published FDA guidance. Formal model-form uncertainty quantification is deferred to higher MRL assessments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values documented with sources.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hemolysis power-law coefficients are drawn from published literature with citations. Sensitivity to input variation is not formally quantified at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization documented in experimental report.",
      "rationale": "Bovine blood analogue preparation and characterization are documented in the FDA pump experimental report. Statistical analysis of sample variability is not required at MRL 2 and is deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative equivalency argument provided.",
      "rationale": "The simulation input parameters (geometry, flow rates, rotational speed) are directly transcribed from experimental records. Formal equivalency metrics are not required at MRL 2; qualitative correspondence is documented in the validation plan."
    }
  ],
