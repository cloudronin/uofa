  "hash": "sha256:a3f1c2e4b7d09e56f812345678abcdef9012345678abcdef9012345678abcdef90",
  "signature": "ed25519:b9e2d4f6a1c3e5b7d9f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control and regression testing in place for the CFD solver (ANSYS Fluent 2022R2).",
      "rationale": "The solver is a commercially validated code with documented SQA procedures. Internal regression suite covers all turbulence model variants used in this study. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-channel flow confirm second-order spatial convergence.",
      "rationale": "Method-of-manufactured-solutions (MMS) verification performed on the incompressible RANS solver confirms observed order of accuracy equals theoretical order (p=1.97). Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for hemolysis index QoI < 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study (coarse 2.1 M, medium 5.4 M, fine 12.7 M cells) yields GCI_fine = 3.2% for the normalized index of hemolysis. Richardson extrapolation applied. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) match simulation inputs within ±3%.",
      "rationale": "FDA GCBP bench tests conducted at five operating points (2.5–7 L/min, 2000–3500 RPM). Measured inlet/outlet pressures and flow rates used directly as CFD boundary conditions; fluid temperature controlled to 37°C ± 0.5°C. Correspondence verified within tolerance. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predicted within 25% of measured values across all five operating points.",
      "rationale": "CFD-predicted NIH compared against bench hemolysis measurements. Mean absolute relative error = 18.4% across five points; worst-case deviation 23.1% at 2500 RPM / 5 L/min. Within acceptance band. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, scalar shear stress distribution) are directly linked to the clinical hemolysis risk metric used in the regulatory submission.",
      "rationale": "NIH is the FDA-accepted surrogate for hemolytic risk in rotary blood pumps. Scalar shear stress (Giersiepen power-law model) is the mechanistic driver. Both QoIs map directly to the decision question of identifying worst-case operating conditions. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating envelope overlap with the intended CPB device use conditions.",
      "rationale": "FDA GCBP geometry is a standard surrogate for Class II centrifugal CPB pumps. Blood analog fluid (glycerol-water) replicates plasma viscosity. Operating envelope (2–7 L/min, 1500–4000 RPM) encompasses clinical CPB range. Validation activities are sufficiently relevant to the COU. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver iterative convergence residuals reported as surrogate.",
      "rationale": "At Model Risk Level 2 the standard does not require formal numerical solver error quantification beyond residual reporting. Continuity and momentum residuals converge to <1e-5. Factor scoped to level 1 and not formally assessed per MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst training records reviewed informally.",
      "rationale": "MRL 2 does not mandate formal use-error analysis. Analysts hold graduate-level CFD training and have completed internal competency review. Formal assessment deferred consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty acknowledged; SST k-omega turbulence model selection justified by literature benchmark.",
      "rationale": "SST k-omega selected based on published benchmarks for internal rotating-flow hemolysis prediction (Fraser et al. 2011, Hariharan et al. 2011). Formal model-form UQ not required at MRL 2; sensitivity to turbulence model noted qualitatively. Factor recorded as not-assessed per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters (viscosity, density, power-law hemolysis coefficients) sourced from peer-reviewed literature; uncertainty not formally propagated.",
      "rationale": "Blood analog properties taken from ISO 10993-4 reference values; Giersiepen power-law constants from Heuser & Opitz (1980). Formal input uncertainty propagation not required at MRL 2. Factor not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "FDA GCBP bench sample size (n=5 operating points, 3 replicates each) noted; statistical characterization not required at MRL 2.",
      "rationale": "Fifteen total experimental runs across five operating points with three replicates. Mean and standard deviation reported. Formal statistical power analysis not required at MRL 2. Factor not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment inputs and COU device inputs reviewed qualitatively.",
      "rationale": "FDA GCBP is a generic surrogate; direct dimensional equivalency to a specific commercial CPB device is not claimed. Qualitative similarity in flow regime (Re, Stokes number) documented. Formal equivalency mapping not required at MRL 2. Factor not assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are not assessed, consistent with MRL 2 scoping guidance in ASME V&V 40-2018. CFD hemolysis predictions fall within the 25% acceptance band for NIH across all validation operating points. The model is accepted for identifying worst-case hemolysis operating conditions for the Class II CPB device as described in the bound Requirement (https://uofa.net/morrison/req/cpb-hemolysis-mrl2) and Claim (https://uofa.net/morrison/claim/cpb-hemolysis-worst-case) nodes.",
