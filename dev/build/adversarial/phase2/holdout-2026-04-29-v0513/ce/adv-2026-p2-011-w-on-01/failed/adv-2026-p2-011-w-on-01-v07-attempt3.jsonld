  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Packaged under ProfileMinimal; intended-use scope and device context are described in the bound Requirement and Claim nodes.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-gcbp-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-gcbp-piv-measurements",
    "https://uofa.net/morrison/data/fda-gcbp-hemolysis-bench"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA GCBP bench data at five operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "CFD velocity field validation against PIV measurements in GCBP volute"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4050888",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-lab-cardiovascular-cfd",
