  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent SQA documentation covering version control, testing, and release validation.",
      "rationale": "ANSYS Fluent 2022R2 is used under an ISO 9001-certified QMS. Release notes, regression test suite results, and version-controlled case files were reviewed and found compliant with MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via at least one benchmark problem with known analytical or manufactured solution at second-order spatial accuracy.",
      "rationale": "ANSYS Fluent passes the ASME V&V 20 lid-driven cavity and Taylor-Green vortex benchmarks at second-order accuracy. Code verification is vendor-documented and independently confirmed for the turbulence closure used."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study using at least three systematically refined meshes; GCI < 5% on the hemolysis index QoI.",
      "rationale": "Three meshes (4.2 M, 8.7 M, 17.1 M cells) were run at the nominal CPB operating point. Richardson extrapolation yields GCI of 3.1% on the normalized hemolysis index, satisfying the acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must be reproduced in the simulation within ±5% of measured values.",
      "rationale": "PIV test conditions (flow rate 5 L/min, 2500 RPM, 37 °C saline analog) were replicated in the CFD setup within ±2%. Fluid viscosity and density match bench measurements within instrument uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., RMSE or validation uncertainty U_val) computed against experimental data with explicit uncertainty quantification.",
      "rationale": "Velocity RMSE normalized by bulk velocity is 4.8% across the mid-plane PIV field. Hemolysis index prediction falls within combined experimental and numerical uncertainty bounds at all five operating points. Validation uncertainty formally computed per ASME V&V 20."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (velocity field, hemolysis index) must be directly linked to the clinical decision quantity (worst-case hemolysis operating condition).",
      "rationale": "The normalized index of hemolysis (NIH) is the regulatory QoI per FDA guidance. Velocity field validation supports confidence in the shear-stress distribution driving the hemolysis power-law model. Both QoIs are directly relevant to the CPB device submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope (flow rate 3–7 L/min, 2000–3000 RPM) representative of CPB clinical use.",
      "rationale": "Bench tests span 3, 5, and 7 L/min at 2000, 2500, and 3000 RPM, bracketing the clinical CPB operating range. Fluid analog (glycerol-saline) viscosity matches blood at 37 °C within 8%, which is acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
