  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2 with qualitative justification provided. The CFD hemolysis model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device. The assessment scope—adult CPB flows 3–6 L/min, 2000–3500 RPM, hemolysis index QoI—is described in the package narrative and the accompanying regulatory submission. Credibility evidence is sufficient to support the intended regulatory decision.",
