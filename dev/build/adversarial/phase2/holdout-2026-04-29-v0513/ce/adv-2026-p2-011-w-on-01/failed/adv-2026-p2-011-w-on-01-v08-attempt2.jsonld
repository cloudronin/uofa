  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all tests passing for the CFD hemolysis kernel.",
      "rationale": "ANSYS Fluent 2022R2 is under ISO 9001-compliant QMS at the performing organization. Regression suite covering 47 canonical flow cases was executed and all cases passed within specified tolerances prior to the study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) or equivalent benchmark demonstrating expected spatial convergence rate.",
      "rationale": "MMS tests for the incompressible Navier-Stokes solver confirm second-order spatial accuracy. Benchmark against lid-driven cavity (Re=1000) and backward-facing step (Re=800) cases show results within 1% of published reference solutions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for QoI; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study (2.1M, 5.8M, 14.2M cells) performed. Richardson extrapolation yields GCI of 2.3% for hemolysis index on the medium grid (5.8M cells), which was selected as the production mesh. Temporal convergence confirmed with Courant number < 0.5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented and traceable; boundary conditions in CFD model match experimental conditions within stated uncertainty.",
      "rationale": "FDA GCBP experimental dataset provides traceable flow rates, rotational speeds, fluid properties (bovine blood, 37°C, Hct 33%), and inlet/outlet pressures. CFD boundary conditions replicate experimental setup; deviations in inlet velocity profile are within ±3% of measured values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) reported for primary QoI; model predictions within experimental uncertainty bands for at least 80% of operating points.",
      "rationale": "Hemolysis index predictions compared at 5 operating points (3, 4, 5, 6 L/min at 2500 RPM). Normalized index of agreement = 0.91; all 5 predictions fall within ±1 standard deviation of experimental measurements. Velocity profiles show mean absolute error of 4.2% relative to PIV data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to the clinical decision endpoint; hemolysis index is the regulatory-accepted surrogate for red blood cell damage in CPB devices.",
      "rationale": "The normalized index of hemolysis (NIH) is the FDA-recognized QoI for CPB device hemolysis assessment per the 2013 FDA Guidance. The model outputs NIH directly from the Giersiepen power-law damage accumulation model integrated along Lagrangian particle trajectories, providing a direct link to the regulatory decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry under overlapping operating conditions; fluid properties representative of clinical use.",
      "rationale": "Validation uses the FDA GCBP geometry identical to the simulation geometry. Operating conditions (3–6 L/min, 2000–3500 RPM) encompass the intended CPB use range. Bovine blood at Hct 33% is an accepted surrogate for human blood in hemolysis testing per ASTM F1841."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals documented; not required at MRL 2 beyond basic residual monitoring.",
      "rationale": "At MRL 2, formal iterative error quantification beyond residual monitoring is not required. Solver residuals for continuity, momentum, and turbulence quantities were monitored to < 1e-5 for all simulations, confirming adequate iterative convergence without formal error bounding."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records reviewed informally.",
      "rationale": "Formal use-error assessment is not required at MRL 2. The lead analyst holds a PhD in computational fluid dynamics with 8 years of blood pump CFD experience. Internal peer review of simulation setup was conducted by a second qualified analyst."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty not formally quantified at MRL 2; turbulence model selection justified by literature.",
      "rationale": "SST k-omega turbulence model selected based on published benchmarks for rotating blood pump geometries. Model form uncertainty from turbulence closure is acknowledged but not formally quantified, consistent with MRL 2 requirements. Sensitivity to turbulence model was explored qualitatively using k-epsilon."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key input parameters identified and nominal values justified; formal uncertainty propagation not required at MRL 2.",
      "rationale": "Fluid viscosity, density, and hemolysis model coefficients (C=3.62e-5, alpha=2.416, beta=0.785) are documented with literature sources. Formal sensitivity analysis or uncertainty propagation is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size and preparation documented in experimental dataset; statistical characterization not required at MRL 2.",
      "rationale": "FDA GCBP experimental dataset documents blood sample preparation, storage conditions, and test sequence. Formal statistical characterization of inter-sample variability is not required at MRL 2. Three independent experimental runs were performed per operating point."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between experimental and simulation input parameters documented; formal equivalency assessment not required at MRL 2.",
      "rationale": "Parameter mapping table provided in the technical report cross-referencing experimental measurements to CFD boundary conditions. Differences in inlet velocity profile representation are documented. Formal equivalency scoring is not required at MRL 2."
    }
  ],
