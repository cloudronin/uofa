  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures, version control, and regression test suite meets MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with ISO 9001-certified QA processes. Version control logs, release notes, and regression benchmarks were reviewed and found compliant with MRL 2 software quality requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark problems (lid-driven cavity, backward-facing step) at second-order accuracy.",
      "rationale": "The solver was verified against the ASME V&V 20 lid-driven cavity and backward-facing step benchmarks. Observed spatial convergence rates of 1.95–2.01 confirm second-order accuracy consistent with the discretization scheme employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH < 5% on the production mesh relative to the fine mesh.",
      "rationale": "Three-level Richardson extrapolation yielded GCI values of 3.2% for volume-averaged shear stress and 2.8% for NIH on the medium production mesh (8.4M cells), satisfying the 5% threshold at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, pressure, fluid viscosity) match simulation inputs within ±5%.",
      "rationale": "FDA GCBP bench test conditions were reproduced computationally within 2.1% for flow rate and 3.4% for differential pressure. Glycerol-water analog fluid properties were matched to within 1.5% of measured viscosity values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values fall within two standard deviations of experimental measurements across all validation operating points.",
      "rationale": "Predicted NIH agreed with bench measurements within 18% across 6 operating points, consistent with experimental repeatability (±15%). All predictions fell within the two-sigma experimental band, satisfying MRL 2 output comparison requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (NIH and volume-averaged shear stress) are directly linked to the clinical endpoint of hemolysis risk ranking.",
      "rationale": "NIH is the FDA-recognized surrogate for hemolysis in blood-contacting devices. Volume-averaged shear stress provides mechanistic insight into red blood cell damage. Both QoIs are directly relevant to identifying worst-case operating conditions for the CPB indication."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, analogous fluid, and overlapping operating envelope as the COU.",
      "rationale": "Validation used the FDA GCBP geometry under glycerol-water analog conditions spanning 3–6 L/min and 60–120 mmHg, fully overlapping the CPB operating envelope. The experimental configuration is sufficiently representative of the COU to support MRL 2 credibility."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-5 is documented; no further quantification required at MRL 2.",
      "rationale": "At MRL 2, formal iterative error quantification beyond residual monitoring is not required. Residuals converged to below 1e-6 for all equations. This factor is not assessed beyond this threshold confirmation, which is acceptable per the MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst training records reviewed; no formal use-error study required at MRL 2.",
      "rationale": "MRL 2 does not mandate a formal use-error study. Lead analyst holds a doctoral degree in computational fluid dynamics with 8 years of cardiovascular CFD experience. Training records are on file. This factor is scoped as not-assessed per the approved MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form selection (SST k-omega turbulence, power-law hemolysis) is documented with literature justification; formal sensitivity not required at MRL 2.",
      "rationale": "SST k-omega turbulence closure and the Giersiepen-Wurzinger power-law hemolysis model were selected based on published literature for centrifugal blood pumps. Formal model-form uncertainty quantification is not required at MRL 2 and is therefore not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal input values documented with sources; probabilistic input uncertainty analysis not required at MRL 2.",
      "rationale": "All model inputs (geometry tolerances, fluid properties, rotational speed) are documented with measurement sources and nominal values. Probabilistic uncertainty propagation is not required at MRL 2 and is therefore not assessed in this package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and variability of test samples documented; statistical power analysis not required at MRL 2.",
      "rationale": "Six operating-point replicates were performed with three repeat measurements each. Sample size justification based on prior FDA GCBP studies is documented. Formal statistical power analysis is not required at MRL 2 and is therefore not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Differences between validation and COU input parameters are identified and qualitatively justified; quantitative equivalency mapping not required at MRL 2.",
      "rationale": "Key differences between validation (glycerol-water analog, in vitro) and COU (whole blood, clinical CPB) inputs are identified: hematocrit variability, non-Newtonian behavior, and temperature. Qualitative justification for analog acceptability is documented. Formal equivalency mapping is not required at MRL 2."
    }
  ],
