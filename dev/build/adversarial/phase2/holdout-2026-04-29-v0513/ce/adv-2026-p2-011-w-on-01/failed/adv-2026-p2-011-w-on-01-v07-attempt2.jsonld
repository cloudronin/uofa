  "name": "Morrison CFD Hemolysis Credibility Assessment — CPB Minimal Profile",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. The computational model is intended to identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Submitted under ProfileMinimal; structured context-of-use scope is conveyed through the bound requirement and claim prose.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-mrl2-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-cfd-claim-001",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-dataset-2018",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-dataset-2019"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-cpb-pressure-head-001",
      "type": "ValidationResult",
      "name": "Pressure-head validation against FDA benchmark PIV data at 2500 RPM and 3500 RPM operating points"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-cpb-hemolysis-index-001",
      "type": "ValidationResult",
      "name": "Normalised Index of Hemolysis (NIH) validation against in-vitro bench measurements across six flow-rate conditions"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-cpb-velocity-field-001",
      "type": "ValidationResult",
      "name": "Velocity field comparison (axial and radial components) against PIV measurements in the volute region"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034786",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-sim-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e7d509b84762fae031cd9845120f3b6a78e2c4d9501f8b37694e0a1c5d",
  "signature": "ed25519:b2d4f8a1c3e609274f5b0d8e3a7c1f2b4d6e8a0c2e4f6b8d0a2c4e6f8b0d2e4f6b8d0a2c4e6f8b0d2e4f6b8d0a2c4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software must be verified under a documented QA plan with version control, regression testing, and traceable build records consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used under the laboratory's ISO-9001-aligned QA plan. Version-controlled solver builds, regression test suites covering relevant turbulence and scalar-transport modules, and a signed software configuration record were reviewed. All QA artefacts meet Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions (MMS) or equivalent benchmark tests at the spatial and temporal discretisation orders used in the study.",
      "rationale": "MMS convergence tests for the incompressible Navier-Stokes and passive-scalar hemolysis transport equations confirmed second-order spatial accuracy. Published ASME benchmark results for laminar pipe flow and lid-driven cavity were reproduced within 0.3% of reference values, satisfying Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for the primary quantity of interest (NIH) must be reported and must not exceed 5% at the production mesh resolution.",
      "rationale": "A three-level Richardson extrapolation study (coarse 4.2 M, medium 9.8 M, fine 21.6 M hexahedral cells) yielded a GCI of 1.8% for NIH at the worst-case operating point (3500 RPM, 4 L/min). The production mesh is the fine grid. Achieved level exceeds the required Gradation 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profiles, fluid temperature, hematocrit, and pump rotational speed) must be documented with measurement uncertainty and replicated in the simulation setup.",
      "rationale": "FDA benchmark test conditions (37 °C, 40% hematocrit porcine blood analogue, 2500 and 3500 RPM) were reproduced in the CFD boundary conditions. Inlet velocity profiles were derived from PIV measurements with stated ±2% uncertainty. Correspondence between experimental and simulated conditions is documented in the validation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH and pressure-head values must be compared against experimental data using a quantitative metric (e.g., ASME V&V 20 validation metric or normalised RMS error) with a stated acceptance threshold.",
      "rationale": "Normalised RMS error for NIH across six operating points was 8.4%, within the 15% acceptance threshold defined in the validation plan. Pressure-head predictions fell within experimental uncertainty bands at all tested operating points. ASME V&V 20 validation metric U_val was computed and documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modelled quantities of interest (NIH, shear stress exposure, pressure head) must be directly relevant to the clinical decision question regarding worst-case hemolysis identification for the CPB indication.",
      "rationale": "NIH is the regulatory quantity used by FDA for CPB device clearance. Shear stress exposure history drives the power-law hemolysis model. Pressure head determines hydraulic performance at the intended operating envelope. All three QoIs are directly linked to the CPB worst-case identification decision question."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the flow-rate and rotational-speed envelope representative of CPB clinical operating conditions (1.5–6 L/min, 2000–4000 RPM).",
      "rationale": "Validation data span 2–6 L/min and 2500–3500 RPM, covering the primary CPB operating envelope. The FDA generic centrifugal pump geometry is a recognised surrogate for Class II CPB devices. Extrapolation beyond the validated envelope is flagged in the decision record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals for momentum and scalar transport must fall below 1×10⁻⁵ and be documented; round-off error assessment is not required at MRL 2.",
      "rationale": "At MRL 2 a full round-off and iterative error decomposition is not required. Residual monitoring confirmed convergence to 1×10⁻⁶ for all equations; this is noted but a formal Gradation 2 numerical-solver-error assessment is scoped out as not required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User-introduced errors from setup, meshing, and post-processing must be characterised; at MRL 2 a qualitative review by a second analyst is sufficient.",
      "rationale": "MRL 2 does not mandate a formal use-error quantification study. A peer review of the simulation setup by a second qualified CFD analyst was conducted informally; no systematic setup errors were identified. Formal use-error assessment is scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence closure (SST k-ω) and hemolysis power-law model must be justified relative to alternative model forms; at MRL 2 a literature-based justification is sufficient.",
      "rationale": "SST k-ω and the Giersiepen–Wurzinger power-law hemolysis model are the community-standard choices for CPB CFD per published FDA guidance and peer-reviewed literature. Formal model-form uncertainty quantification is not required at MRL 2 and is scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of NIH predictions to key input parameters (viscosity, hemolysis model coefficients) must be characterised; at MRL 2 a one-at-a-time sensitivity study is sufficient.",
      "rationale": "A full input uncertainty propagation study is not required at MRL 2. Literature ranges for blood viscosity and power-law coefficients were noted. One-at-a-time sensitivity was reviewed qualitatively; NIH showed moderate sensitivity to hemolysis exponent. Formal assessment scoped out per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The number and variability of experimental test samples used for validation must be documented; at MRL 2 a single-batch experimental dataset is acceptable.",
      "rationale": "The FDA benchmark dataset represents a single experimental campaign. Inter-batch variability of the blood analogue and pump manufacturing tolerances were not characterised. This is acceptable at MRL 2; formal test-sample adequacy assessment is scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation input parameters and experimental conditions must be demonstrated; at MRL 2 a documented parameter mapping table is sufficient.",
      "rationale": "A parameter mapping table aligning CFD boundary conditions to experimental measurements was prepared and is included in the validation report. Formal equivalency testing (e.g., statistical comparison of inlet profiles) is not required at MRL 2 and is scoped out."
    }
  ],
