  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level must meet or exceed MRL 2 requirements: version control, documented build procedures, and regression test suite for the CFD solver.",
      "rationale": "ANSYS Fluent 2022R2 used under a validated SQA framework including ISO 9001-compliant version control, automated regression testing against canonical benchmark cases, and documented release notes. Achieved SQA level 2 satisfies MRL 2 requirements for a Class II CPB device."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via method of manufactured solutions (MMS) or equivalent for the governing equations relevant to hemolysis prediction.",
      "rationale": "ANSYS Fluent has published MMS verification results for the incompressible Navier-Stokes solver. Internal benchmark comparisons against the Taylor-Green vortex and lid-driven cavity confirm spatial and temporal order of accuracy consistent with second-order finite-volume discretization. Code verification level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate discretization error below 5% for the primary QoI (normalized index of hemolysis, NIH) at the worst-case operating point.",
      "rationale": "Three-level Richardson extrapolation performed on meshes of 1.2M, 4.8M, and 19.2M hexahedral cells. Grid convergence index (GCI) for NIH at 2500 RPM / 5 L/min is 1.8%, below the 5% acceptance threshold. Achieved level 3 exceeds the MRL 2 requirement of level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to allow meaningful comparison with CFD boundary conditions, including flow rate, rotational speed, fluid temperature, and hematocrit.",
      "rationale": "FDA benchmark experimental data (Hariharan et al. 2011) documents test conditions at five operating points spanning the CPB envelope. Temperature (37°C), hematocrit (35%), and bovine blood rheology are recorded. Boundary conditions in the CFD model are set to match within measurement uncertainty. Test conditions factor level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric M) must be computed for NIH predictions versus experimental measurements across the operating envelope.",
      "rationale": "Mean absolute percentage error in NIH across five operating points is 18.4%, consistent with inter-laboratory variability reported in the FDA round-robin study. Validation metric M = 0.72, exceeding the MRL 2 threshold of 0.60. Output comparison level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (NIH) must be demonstrably linked to the clinical decision question of identifying worst-case hemolysis operating conditions for the CPB device.",
      "rationale": "NIH is the FDA-accepted QoI for hemolysis assessment of blood-contacting devices per FDA guidance on computational modeling. NIH directly quantifies red blood cell destruction relevant to patient safety in CPB. QoI relevance level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the operating conditions, geometry, and fluid properties representative of the CPB use context for the FDA generic centrifugal pump.",
      "rationale": "Validation performed on the same FDA generic centrifugal pump geometry under CPB-representative operating conditions (2000–3500 RPM, 3–7 L/min). Bovine blood surrogate rheology is accepted as representative for hemolysis scaling per ASTM F1841. Validation relevance level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 for this factor, documentation of solver residual convergence criteria is sufficient; detailed iterative error quantification is not required.",
      "rationale": "Solver residual convergence to 1e-5 for all equations is documented in the simulation log. Detailed iterative error decomposition is not required at MRL 2 for a Class II device. Factor scoped to level 1 per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a qualitative review of analyst training and simulation setup procedures is sufficient to address use error.",
      "rationale": "Simulation setup reviewed by a second analyst with 5+ years of cardiovascular CFD experience. No systematic use errors identified. Formal use-error quantification not required at MRL 2 for this device class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative justification of turbulence model selection and hemolysis damage accumulation model is sufficient.",
      "rationale": "SST k-omega turbulence model selected based on literature consensus for rotating cardiovascular devices. Power-law hemolysis damage model (Giersiepen et al.) is the FDA-accepted approach. Formal model-form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; full sensitivity analysis is not required.",
      "rationale": "All model inputs (viscosity, density, damage model constants) drawn from peer-reviewed literature and FDA guidance documents. Nominal values documented in simulation input deck. Sensitivity analysis deferred per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of the experimental sample provenance and preparation protocol is sufficient.",
      "rationale": "FDA benchmark study (Hariharan et al. 2011) documents bovine blood preparation, anticoagulation protocol, and storage conditions. Sample characterization meets MRL 2 requirements. Inter-sample variability analysis not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative mapping of experimental input parameters to CFD boundary conditions is sufficient to establish equivalency.",
      "rationale": "Qualitative mapping confirms that flow rate, rotational speed, inlet pressure, and fluid temperature in the CFD model correspond to experimentally measured values within stated measurement uncertainty bounds. Formal equivalency metric computation not required at MRL 2."
    }
  ],
