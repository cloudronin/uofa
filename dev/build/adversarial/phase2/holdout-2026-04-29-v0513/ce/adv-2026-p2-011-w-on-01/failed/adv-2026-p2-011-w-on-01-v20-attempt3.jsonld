      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance procedures documented and version-controlled; CFD solver (ANSYS Fluent 19.2) operates under ISO 9001-aligned QMS with traceable release notes.",
      "rationale": "The CFD solver used for hemolysis prediction has documented QA procedures including version control, regression test suites, and release validation reports. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark verification cases (lid-driven cavity, Poiseuille flow) with errors below 1% against analytical solutions.",
      "rationale": "ANSYS Fluent 19.2 has been verified against classical benchmark problems. Numerical discretization schemes (second-order upwind) are confirmed to converge at expected rates. Code verification requirements for MRL 2 are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for scalar hemolysis index across three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA generic centrifugal pump geometry. GCI values for the hemolysis index ranged from 1.8% to 3.4%, comfortably below the 5% threshold. Achieved level 3 exceeds the MRL 2 requirement of level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented with uncertainty bounds and match the CPB operating envelope within ±5%.",
      "rationale": "FDA experimental data for the generic centrifugal pump was collected under controlled conditions spanning the CPB operating envelope (2–7 L/min, 2500–3500 RPM). Fluid properties match bovine blood surrogate specifications. Condition documentation meets MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index agrees with experimental measurements within ±20% across all operating points; pressure-flow characteristic curves agree within ±10%.",
      "rationale": "Computational hemolysis index predictions agree with FDA experimental measurements within 15% across 12 operating points. Pressure-flow characteristic curves show agreement within 8%. Output comparison demonstrates adequate predictive fidelity for worst-case identification at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The scalar hemolysis index (normalized index of hemolysis, NIH) is established as the primary QoI directly linked to device safety endpoints for CPB applications.",
      "rationale": "The normalized index of hemolysis (NIH) is the regulatory-accepted metric for hemolysis quantification in CPB devices per FDA guidance. The computational QoI maps directly to the clinical safety endpoint. Relevance is well-established in literature and confirmed by the bound requirement."
    },
    {
      "type": "CredibilityFactor",
