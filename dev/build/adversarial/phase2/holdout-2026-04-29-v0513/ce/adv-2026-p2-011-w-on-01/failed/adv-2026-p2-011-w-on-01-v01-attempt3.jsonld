  "signature": "ed25519:b7e3a1f4c2d8e0b5a9c3f1d6e4b2a0c7d5e8f3b1a4c9d2e6f0b3a7c1d5e9f2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA documentation demonstrates version control, regression testing, and traceable build artifacts for the CFD solver used in hemolysis prediction.",
      "rationale": "The CFD solver (OpenFOAM v8) is managed under a formal SQA plan including automated regression tests against canonical benchmark cases. Version control logs and test reports are archived and reviewed by the credibility assessment team. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification confirms correct implementation of governing equations through method of manufactured solutions or equivalent for turbulent incompressible flow.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver confirms second-order spatial convergence. Results published in solver verification report MV-2024-003 and independently reviewed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis demonstrates discretization error below 5% for hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study (2.1M, 6.8M, 18.4M cells) performed at the design operating point (5 L/min, 2500 RPM). GCI for hemolysis index is 3.2%, below the 5% threshold. Medium mesh (6.8M) selected for production runs balancing accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented with measurement uncertainty and match the CPB operating envelope specified for the Class II device.",
      "rationale": "FDA benchmark experiments conducted at 3–6 L/min and 2000–3500 RPM using bovine blood at 37°C. Measurement uncertainty for hemolysis index is ±8% (k=2). Conditions documented in FDA dataset CDRH-2013-HB-001 and confirmed to span the intended CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) between CFD-predicted and experimentally measured hemolysis index falls within combined uncertainty band.",
      "rationale": "Mean absolute error in normalised index of hemolysis (NIH) is 11.4% across 12 operating points, within the combined simulation and experimental uncertainty band of ±15%. Worst-case operating point identification is consistent between CFD and experiment (3500 RPM, 3 L/min)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs (NIH, shear stress distribution, exposure time) are directly linked to the clinical risk of haemolysis in CPB patients and are the quantities used in the regulatory submission.",
      "rationale": "NIH is the primary regulatory QoI for blood-contacting device haemolysis per FDA guidance. Shear stress and exposure time are mechanistic inputs to the power-law haemolysis model. All three QoIs are explicitly referenced in the 510(k) submission template for Class II CPB devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the FDA generic centrifugal pump geometry and the same haemolysis model as the submission model, ensuring direct applicability to the COU.",
      "rationale": "Validation conducted on the FDA-published generic centrifugal pump geometry, which is the same geometry used in the submission. The Giersiepen power-law haemolysis model parameterised with bovine blood coefficients is applied consistently between validation and COU simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and round-off error bounds documented; not required at MRL 2 beyond level 1.",
      "rationale": "At MRL 2 the required level for numerical solver error is 1, indicating awareness only. Residuals are monitored to 1e-5 for all transport equations and no divergence events observed. Detailed round-off analysis not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification and simulation setup review documented at awareness level; formal use-error analysis not required at MRL 2.",
      "rationale": "Simulation setup reviewed by a second qualified engineer prior to production runs. User qualifications documented in team competency log. Formal use-error FMEA not required at MRL 2 for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for turbulence closure and haemolysis constitutive model acknowledged; sensitivity study scope defined but not executed at MRL 2.",
      "rationale": "k-omega SST turbulence model selected based on published benchmark comparisons for rotating machinery. Haemolysis model form uncertainty acknowledged via literature survey (Arora et al., 2004; Goubergrits & Affeld, 2004). Full model form sensitivity study deferred; not required at MRL 2 per ASME V&V 40 Table 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (viscosity, density, haemolysis model coefficients) documented with sources and uncertainty ranges; nominal values used in production runs justified.",
      "rationale": "Blood viscosity 0.0035 Pa·s and density 1060 kg/m³ taken from FDA benchmark dataset. Haemolysis model coefficients (C=3.62e-5, alpha=2.416, beta=0.785) from Giersiepen et al. (1990) with coefficient uncertainty ±15% noted. Nominal values consistent with FDA benchmark experimental conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample provenance and preparation documented at awareness level; statistical sample characterisation not required at MRL 2.",
      "rationale": "FDA benchmark uses bovine blood with documented anticoagulation protocol (heparin, 2 IU/mL). Sample lot variability not characterised statistically; acceptable at MRL 2 where level 1 awareness is the requirement for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental and simulation input parameters acknowledged; formal equivalency mapping not required at MRL 2.",
      "rationale": "Simulation boundary conditions (inlet flow rate, outlet pressure, rotational speed) set to match experimental operating points. Geometric fidelity confirmed by overlay of CAD model against published pump drawings. Formal parameter equivalency matrix not required at MRL 2."
    }
  ],
