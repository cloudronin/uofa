  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This UoA evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Intended use: pre-market submission support for a Class II CPB device; decision context is worst-case hemolysis identification across the device operating envelope.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-generic-cpb-experimental",
    "https://uofa.net/morrison/data/cpb-operating-envelope-sweep"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-qoi-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index QoI comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/morrison/validation/shear-stress-distribution",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation against PIV measurements"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034996",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-sim-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:3f7a2c9d1e4b58f06a2d7c3e9b1f4a8d2e6c0b5f9a3d7e1c4b8f2a6d0e9c3b7",
  "signature": "ed25519:9b2e4f1a7c3d6e0b5f8a2c9d4e7b1f3a6c0d8e2b5f9a3c7d1e4b8f2a6c0d9e3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented version control, regression test suite, and traceable build process consistent with MRL 2 expectations.",
      "rationale": "ANSYS Fluent 2022R2 was used with documented version control and a regression test suite covering relevant flow regimes. Build traceability records confirm compliance with MRL 2 software quality requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate expected order of accuracy on canonical benchmark problems relevant to rotating turbomachinery flows.",
      "rationale": "Order-of-accuracy tests on the Taylor-Green vortex and rotating cavity benchmarks confirmed second-order spatial convergence. Results are consistent with published solver verification studies for the ANSYS Fluent pressure-based coupled solver."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the hemolysis index QoI must be below 5% on the finest mesh used in production simulations.",
      "rationale": "Three-level mesh refinement study (6.2M, 12.8M, 24.1M cells) yielded GCI of 2.3% for the hemolysis index at the design operating point. Richardson extrapolation confirmed monotonic convergence. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must be documented with uncertainty bounds and must span the CPB operating envelope relevant to worst-case hemolysis identification.",
      "rationale": "FDA benchmark experimental data were collected at five flow rates (2–6 L/min) and three rotational speeds (2400–3600 RPM) with documented inlet pressure uncertainty of ±2 mmHg. Operating conditions bracket the worst-case hemolysis region identified in the CFD sweep."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bands across the validation operating points.",
      "rationale": "Predicted hemolysis index fell within experimental uncertainty bands at 14 of 15 validation operating points. The single outlier at 6 L/min / 3600 RPM showed 8% overprediction, conservatively bounding the experimental measurement and acceptable for worst-case identification purposes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, wall shear stress) must be directly linked to the clinical risk of red blood cell damage in CPB applications.",
      "rationale": "Hemolysis index and scalar shear stress are the primary QoIs. Both are directly linked to red blood cell damage thresholds established in literature (Giersiepen et al., Zhang et al.) and are the quantities reported in the intended regulatory submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating range as the intended clinical use conditions for CPB.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry with a 36% glycerol-water blood analog at physiological viscosity. Operating range matches CPB clinical use (2–6 L/min, mean arterial pressure 60–80 mmHg). Geometric and fluid similarity is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver error assessment not required at MRL 2 when code verification has been completed and residuals meet convergence criteria.",
      "rationale": "At MRL 2, explicit solver error quantification beyond residual monitoring is not required. Continuity and momentum residuals converged to below 1e-5 in all production runs. This factor is not assessed per the MRL 2 assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment not required at MRL 2 provided that simulation execution is performed by trained personnel following documented simulation protocols.",
      "rationale": "Simulations were executed by engineers with documented CFD training records following a written simulation execution protocol. Formal use error assessment is scoped out at MRL 2 per the ASME V&V 40 assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty assessment not required at MRL 2; turbulence model selection is justified by prior literature and output comparison results.",
      "rationale": "The SST k-omega turbulence model was selected based on published benchmarking for rotary blood pump flows. Formal model form uncertainty quantification is not required at MRL 2 and is not assessed here."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model input uncertainty propagation not required at MRL 2; key inputs are documented with nominal values and sources.",
      "rationale": "Fluid density, viscosity, and rotational speed are documented with nominal values and measurement sources. Formal uncertainty propagation through input parameters is not required at MRL 2 per the assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2 when a single representative device geometry is assessed.",
      "rationale": "A single FDA generic centrifugal pump geometry was assessed. Device-to-device geometric variability characterization is not required at MRL 2. This factor is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis between simulation inputs and experimental conditions not required at MRL 2 beyond documented boundary condition matching.",
      "rationale": "Simulation boundary conditions were set to match experimental measurements directly. Formal equivalency analysis is not required at MRL 2. Boundary condition correspondence is documented in the simulation log."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-cardiovascular-sim-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels for MRL 2. The 6 non-assessed factors are explicitly scoped out per the ASME V&V 40 MRL 2 assessment matrix. Output comparison demonstrates hemolysis index predictions within experimental uncertainty across the CPB operating envelope. The model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device intended use described in the claim and requirement bindings.",
