  "signature": "ed25519:9a1b3c5d7e2f4a6b8c0d1e3f5a7b9c2d4e6f8a0b1c3d5e7f9a2b4c6d8e0f1a3b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control and regression testing at MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-compliant QA framework. Version control, regression test suite, and change-management records were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions at MRL 2.",
      "rationale": "Code verification performed using lid-driven cavity and Poiseuille flow benchmarks. Observed convergence rates matched theoretical orders; no coding errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via mesh refinement study; GCI < 5% on primary QoI at MRL 2.",
      "rationale": "Three-level mesh refinement study conducted (4.2M, 9.8M, 21.4M cells). GCI on hemolysis index was 2.3%, well below the 5% threshold. Medium mesh (9.8M cells) selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to the CPB operating envelope.",
      "rationale": "FDA benchmark experimental data collected at flow rates 2–8 L/min and rotational speeds 2000–3500 RPM, fully spanning the intended CPB operating envelope. Traceability to calibrated instrumentation records confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure rise must agree with experimental measurements within combined simulation and experimental uncertainty bands.",
      "rationale": "Predicted hemolysis index agreed with experimental values within 8% across all operating points; pressure rise agreement within 4%. Both within combined uncertainty bands at the 95% confidence level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) must be directly linked to the clinical decision of identifying worst-case hemolysis operating conditions.",
      "rationale": "Hemolysis index and volume-averaged scalar shear stress are the primary regulatory QoIs for CPB pump hemolysis assessment per FDA guidance. Direct linkage to worst-case identification decision confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating conditions as the intended CPB deployment scenario.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry with a 36% glycerol-water blood analog at physiological viscosity. Operating conditions matched the CPB envelope. Geometric and fluid similarity confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iterative convergence must be demonstrated; residual targets defined. Not required as a separate factor at MRL 2 when code verification is complete.",
      "rationale": "At MRL 2, numerical solver error is subsumed under code verification and discretization error factors. Residual convergence to 1e-6 was monitored and logged, but formal separate assessment is scoped to MRL 3 and above."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst qualification and simulation execution procedures must be documented to prevent user-induced errors. Formal assessment not required at MRL 2.",
      "rationale": "Simulations executed by a PhD-level engineer with 5+ years CFD experience following internal SOPs. Formal use-error factor assessment is not mandated at MRL 2 per ASME V&V 40 Table 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Governing equation selection (turbulence model, hemolysis power-law model) must be justified relative to flow regime. Formal assessment deferred to MRL 3.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law selected based on published literature for centrifugal pump flows. Formal model-form uncertainty quantification deferred as not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of QoIs to uncertain input parameters (fluid viscosity, pump geometry tolerances) must be quantified. Not required at MRL 2.",
      "rationale": "Nominal input values used throughout. Input sensitivity analysis is a MRL 3 requirement. Blood analog viscosity was measured and held constant; geometric tolerances were within manufacturing specification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number of experimental replicates and statistical characterization of test sample variability must be documented. Formal assessment not required at MRL 2.",
      "rationale": "FDA benchmark dataset provides triplicate measurements at each operating point. Statistical characterization of inter-run variability is documented in the source publication but formal factor assessment is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and experimental conditions must be formally demonstrated. Deferred to MRL 3.",
      "rationale": "Boundary conditions (inlet flow rate, outlet pressure, rotational speed) were set to match experimental conditions numerically. Formal equivalency assessment with uncertainty propagation is a MRL 3 activity and not required here."
    }
  ],
