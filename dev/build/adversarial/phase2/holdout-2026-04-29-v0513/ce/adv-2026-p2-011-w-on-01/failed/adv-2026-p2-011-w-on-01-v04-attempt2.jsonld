  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression test suite passing rate ≥ 95%, and documented release notes for ANSYS Fluent 2023 R1.",
      "rationale": "ANSYS Fluent 2023 R1 is a commercially validated solver with documented SQA processes. Regression test suite showed 97.3% pass rate. Version control and configuration management records are archived per ISO 9001 QMS."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test using manufactured solution confirms spatial convergence rate within 10% of theoretical second-order rate.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver. Observed convergence rate of 1.94 confirmed against theoretical rate of 2.0, within the 10% tolerance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 5% for hemolysis index QoI on three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study (4.2M, 11.7M, 31.4M cells) yielded GCI of 3.1% for the normalised blood damage index at the design operating point, satisfying the 5% criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, inlet pressure, fluid temperature, hematocrit) match simulation inputs within stated measurement uncertainty.",
      "rationale": "FDA experimental dataset provides fully characterised boundary conditions with calibrated instrumentation. CFD boundary conditions set to match experimental values; deviations within combined measurement uncertainty of ±3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 15% of experimental measurements at all five benchmark operating points; pressure rise within 10%.",
      "rationale": "Hemolysis index predictions ranged from 4.2% to 13.8% relative error across five operating points. Pressure rise predictions within 7.1% at all points. Both criteria satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised blood damage index and shear stress distribution directly map to the regulatory QoI for hemolysis risk characterisation in CPB devices.",
      "rationale": "The primary QoI — normalised index of hemolysis — is the same metric used in FDA guidance for CPB device submissions. Secondary QoIs (shear stress, residence time) are mechanistically linked to red cell damage, confirming relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal blood pump geometry under overlapping flow rate and rotational speed ranges as the intended CPB operating envelope.",
      "rationale": "FDA benchmark experiments cover 2.5–7.5 L/min and 2000–3500 RPM, encompassing the CPB operating envelope of 3–6 L/min and 2500–3200 RPM. Geometric identity confirmed. Validation relevance is direct."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; iterative convergence to residual tolerance of 1e-6 on all transport equations is documented as sufficient.",
      "rationale": "At Model Risk Level 2, explicit quantification of numerical solver error beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations; mass imbalance < 0.01%. Scoped out per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst training records and simulation protocol document reviewed as adequate.",
      "rationale": "MRL 2 does not require formal use-error quantification. Lead analyst holds a PhD in computational fluid dynamics with 8 years of cardiovascular CFD experience. Simulation protocol reviewed by independent senior engineer."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; selection of SST k-omega turbulence model and power-law hemolysis model documented with literature justification.",
      "rationale": "SST k-omega turbulence model selected based on published benchmarks for rotating machinery flows. Giersiepen power-law hemolysis model is the accepted standard in FDA submissions. Model form uncertainty not formally quantified per MRL 2 scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values (viscosity, density, hematocrit) sourced from published physiological ranges and FDA benchmark specifications.",
      "rationale": "Blood viscosity set to 0.0035 Pa·s, density 1060 kg/m³, hematocrit 40% per FDA benchmark protocol. Sensitivity to these inputs not formally quantified at MRL 2 but values are within accepted physiological ranges."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; FDA benchmark used bovine blood with documented hematocrit and storage conditions; sample variability acknowledged.",
      "rationale": "FDA benchmark experiments used bovine blood as a surrogate for human blood. Inter-sample variability in hemolysis susceptibility is a known limitation acknowledged in the benchmark documentation. Formal test sample assessment deferred per MRL 2 scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; Reynolds number and Womersley number similarity between validation and COU operating conditions documented qualitatively.",
      "rationale": "Reynolds numbers in the validation dataset (Re 1200–4800) overlap with CPB operating conditions (Re 1800–4200). Formal equivalency mapping not required at MRL 2; qualitative similarity documented in the simulation report."
    }
  ],
