      "type": "ValidationResult",
      "name": "Hemolysis index CFD vs experimental: mean normalised blood damage index within 15% of measured values across five operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison: area-averaged velocity magnitude agreement within 8% at design and off-design flow rates"
    }
  ],
