  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for Model Risk Level 2. Six factors were scoped out as not required at MRL 2, consistent with ASME V&V 40-2018 Table 3. Validation evidence demonstrates that the CFD model can reliably identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump within the CPB flow and speed envelope. The assessment team concludes that the model credibility is sufficient to support a Class II regulatory submission for the intended CPB device application.",
