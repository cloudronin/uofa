  "signature": "ed25519:9c4a1f3e7b2d0a5c8e6f1b4d9a2c7e0f3b6d1a4c8e5f2b7d0a3c6e9f1b4d7a0c",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under version control with documented test suite results demonstrating solver correctness at MRL 2.",
      "rationale": "ANSYS Fluent 2023R1 employed with documented QA records, version-controlled case files, and a regression test suite. All SQA requirements for MRL 2 are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark at MRL 2.",
      "rationale": "Code verification completed via published ANSYS Fluent benchmark suite for incompressible Navier-Stokes. Results match analytical solutions within expected truncation error bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 5% change in hemolysis index between successive refinement levels at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 8.7M, 17.1M cells). GCI between medium and fine meshes is 1.8% for the scalar hemolysis index, exceeding the MRL 2 threshold. Richardson extrapolation applied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds and traceable to calibrated instrumentation.",
      "rationale": "FDA experimental dataset documents flow rates (±0.05 LPM), rotational speeds (±10 RPM), and plasma-free hemoglobin measurements (±3%) with full calibration traceability. Conditions span the intended operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized index of agreement or NRMSE) must demonstrate acceptable agreement between predicted and measured hemolysis index across the validation dataset.",
      "rationale": "Normalized RMSE of 12.4% across 9 operating conditions. Model correctly ranks worst-case operating point in 8 of 9 cases. Agreement is deemed acceptable for MRL 2 regulatory decision support."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled QoI (normalized index of hemolysis, NIH) must be directly linked to the clinical risk metric specified in the device submission requirement.",
      "rationale": "NIH is the QoI directly cited in REQ-CPB-2024-007 and maps to the ISO 10993-4 biocompatibility endpoint. The link between computational NIH and clinical hemolysis risk is established in the regulatory guidance literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and fluid (bovine blood or equivalent) as the intended COU, with operating conditions overlapping the CPB flow range.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry using bovine blood at hematocrit 35±2%. Operating conditions (3–6 LPM, 2000–3500 RPM) fully overlap the CPB envelope described in the submission requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "Per ASME V&V 40 Table 1, numerical solver error beyond code verification is not required at MRL 2 for this device class. Factor scoped out per agreed credibility plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst competency records satisfy minimum expectation.",
      "rationale": "MRL 2 does not mandate formal use-error assessment. Lead analyst holds documented CFD training records and has performed five prior hemolysis assessments. Minimum expectation met by attestation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection is justified by literature precedent.",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger) is the accepted standard for CFD-based NIH prediction in CPB literature. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Blood viscosity, density, and hemolysis model constants sourced from peer-reviewed literature with documented provenance. Sensitivity to input variation not formally assessed at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA dataset sample documentation is accepted as sufficient.",
      "rationale": "FDA experimental dataset provides sample provenance for bovine blood lots. Formal statistical characterization of inter-sample variability not required at MRL 2 for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions applied in the simulation must be shown to match the experimental test conditions within stated uncertainty bounds.",
      "rationale": "Inlet velocity profiles, outlet pressure boundary conditions, and rotational speed inputs match the experimental setup documentation within 2%. Wall boundary conditions replicate pump casing geometry to within manufacturing tolerance."
    }
  ],
