  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This assessment evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Intended use is bounded to steady-state operating points within 3–6 LPM flow range and 2000–3500 RPM impeller speed for adult CPB patients. Scope and device context are described in the associated regulatory submission requirement REQ-CPB-2024-007.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-req-2024-007",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-identification",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-cbp-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-cbp-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/morrison-cfd-output-steady-state-2024"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cbp-hemolysis-vr-001",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs. experimental benchmark — FDA generic pump"
    },
    {
      "id": "https://uofa.net/synth/validation/cbp-hemolysis-vr-002",
      "type": "ValidationResult",
      "name": "Worst-case operating point identification validation across 9 test conditions"
    }
  ],
