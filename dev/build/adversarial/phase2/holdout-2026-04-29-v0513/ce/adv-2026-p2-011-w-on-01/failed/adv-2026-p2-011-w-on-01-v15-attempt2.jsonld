  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This UoA evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Intended use: pre-market submission support for a Class II CPB device, adult patients, flow rates 2–6 L/min, rotational speeds 2000–4000 RPM. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-cfd-hemolysis-worstcase",
  "bindsModel": "https://uofa.net/synth/model/fda-gcbp-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-gcbp-experimental-hemolysis-2021",
    "https://uofa.net/synth/data/morrison-cfd-mesh-convergence-2022"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-cpb-vr-01",
      "type": "ValidationResult",
      "name": "CFD hemolysis prediction vs. experimental NIH benchmark — FDA generic centrifugal pump"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-cpb-vr-02",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification for CPB operating envelope"
    }
  ],
