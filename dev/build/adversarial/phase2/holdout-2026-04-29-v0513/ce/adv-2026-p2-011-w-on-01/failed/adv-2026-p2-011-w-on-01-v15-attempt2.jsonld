  "hash": "sha256:a3f8c2d14e7b905f6c1d3e8a2b4f7c0d9e5a1b8f3c6d2e9a4b7f0c3d6e1a8b5",
  "signature": "ed25519:b2e7a1d4f9c3b6e0a5d8f2c1b4e7a0d3f6c9b2e5a8d1f4c7b0e3a6d9f2c5b8e1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation (ANSYS Fluent 2021 R2) must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2021 R2 is a commercially validated solver with documented QA procedures, regression test suites, and ISO 9001-compliant release management. Version control logs and release notes were reviewed and found adequate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions at MRL 2.",
      "rationale": "The solver was verified against the Taylor-Green vortex and lid-driven cavity benchmarks. Observed convergence rates matched theoretical expectations for second-order spatial discretization, confirming correct equation implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that discretization error in the primary QoI (normalized index of hemolysis, NIH) is below 5% relative to the Richardson-extrapolated value.",
      "rationale": "A three-level mesh refinement study (coarse: 2.1M, medium: 6.8M, fine: 18.4M cells) was performed. Richardson extrapolation yielded a discretization error of 2.3% for NIH at the worst-case operating point (3500 RPM, 4 L/min), exceeding the required threshold and meeting the MRL 2 criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation data must be collected under conditions representative of the CPB operating envelope, with documented fluid properties, boundary conditions, and measurement uncertainties.",
      "rationale": "FDA benchmark experimental data for the generic centrifugal blood pump were collected using bovine blood analog (35% hematocrit, viscosity 3.5 mPa·s) at flow rates and rotational speeds spanning the CPB operating envelope. Measurement uncertainties for NIH were documented at ±8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within combined simulation and experimental uncertainty bands across at least 80% of the validation test matrix.",
      "rationale": "CFD-predicted NIH values agreed with FDA experimental benchmark data within combined uncertainty bands at 9 of 10 operating conditions tested (90% of the validation matrix), satisfying the acceptance criterion. Maximum discrepancy was 11% at the lowest flow rate condition."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH) must be directly linked to the clinical risk of hemolysis in CPB patients and must be the same metric used in regulatory guidance for blood-contacting devices.",
      "rationale": "NIH is the FDA-recommended metric for hemolysis assessment in blood-contacting devices per the FDA 2017 guidance document. It is directly correlated with plasma free hemoglobin release and clinical hemolysis risk, confirming relevance to the CPB decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump) and overlap the intended CPB operating envelope in flow rate and rotational speed.",
      "rationale": "All validation activities used the FDA generic centrifugal blood pump geometry and covered flow rates of 2–6 L/min and rotational speeds of 2000–4000 RPM, which fully spans the intended CPB operating envelope. Geometric fidelity was confirmed by independent CAD comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit quantification of iterative solver error beyond standard residual monitoring is not required if a commercially validated solver with documented convergence criteria is used.",
      "rationale": "Solver residuals were monitored to 1e-5 for all equations. Given MRL 2 requirements and use of a commercially validated solver, explicit solver error quantification beyond residual convergence monitoring is not required and this factor is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required provided that simulation setup was performed and reviewed by qualified personnel following documented simulation protocols.",
      "rationale": "Simulation setup was performed by a PhD-level CFD engineer with 8 years of cardiovascular simulation experience and independently reviewed by a second qualified analyst. Formal use error analysis is not required at MRL 2 and is therefore not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit model form uncertainty quantification is not required; selection of governing equations and turbulence model must be documented with literature justification.",
      "rationale": "The SST k-omega turbulence model was selected based on published literature demonstrating superior performance for rotating cardiovascular flows. The Giersiepen-Wurzinger power-law hemolysis model was selected per FDA guidance. Model form uncertainty quantification beyond literature justification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal sensitivity analysis of model inputs is not required; input values must be documented with sources and nominal values must be physiologically representative.",
      "rationale": "All model inputs (fluid density 1060 kg/m3, viscosity 3.5 mPa·s, hematocrit 35%, pump geometry from FDA CAD file) were documented with literature or regulatory sources. Formal input sensitivity analysis is not required at MRL 2 and is therefore not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required provided that the experimental data source is a recognized benchmark dataset with documented sample preparation protocols.",
      "rationale": "The FDA generic centrifugal pump benchmark dataset is a publicly available, peer-reviewed experimental dataset with documented sample preparation and measurement protocols. Statistical characterization of sample variability beyond what is reported in the benchmark dataset is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency mapping between simulation inputs and experimental conditions is not required provided that boundary conditions were set to match experimental conditions as documented.",
      "rationale": "CFD boundary conditions (inlet flow rate, outlet pressure, rotational speed) were set to match the FDA benchmark experimental conditions as documented in the simulation setup report. Formal equivalency analysis beyond boundary condition matching is not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
