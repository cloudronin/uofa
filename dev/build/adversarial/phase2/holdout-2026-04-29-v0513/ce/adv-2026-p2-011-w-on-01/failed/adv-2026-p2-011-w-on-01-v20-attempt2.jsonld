      "acceptanceCriteria": "Not required at MRL 2; model form adequacy addressed implicitly through output comparison results.",
      "rationale": "Formal model form uncertainty quantification not required at MRL 2. The k-omega SST turbulence model and Giersiepen hemolysis power-law model selections are justified by literature precedent for CPB CFD; adequacy evidenced by output comparison results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; key input sensitivities addressed qualitatively.",
      "rationale": "Formal model input uncertainty propagation not required at MRL 2. Sensitivity of NIH to viscosity, hematocrit, and rotational speed assessed qualitatively via ±10% perturbation studies; no unexpected sensitivities identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample characterization documented in source publications.",
      "rationale": "Detailed statistical characterization of RBC sample variability not required at MRL 2. Source publication (Hariharan et al. 2011) documents sample preparation, storage, and viability checks sufficient for this credibility level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency addressed narratively through test conditions factor.",
      "rationale": "Formal equivalency mapping not required at MRL 2. The alignment between experimental and computational input parameters (geometry, fluid properties, boundary conditions) is documented under the Test Conditions factor and confirmed adequate for the worst-case hemolysis identification objective."
    }
