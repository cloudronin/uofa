      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level commensurate with MRL 2: version-controlled solver with documented build and test procedures.",
      "rationale": "ANSYS Fluent 2022R2 used under an ISO 9001-certified QMS; solver release notes, regression test suite results, and version control records reviewed and confirmed compliant with MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that the numerical implementation correctly solves the governing equations via method-of-manufactured-solutions or equivalent benchmark.",
      "rationale": "Code verification confirmed via ASME V&V 20 benchmark cases for incompressible Navier-Stokes and species transport; published solver verification reports reviewed with no outstanding defects relevant to hemolysis prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating discretization error below 5% on hemolysis index QoI.",
      "rationale": "Three-level Richardson extrapolation performed on polyhedral meshes (3.2 M, 8.7 M, 21.4 M cells). GCI on normalized hemolysis index = 1.8%, exceeding the acceptance criterion. Boundary-layer y+ < 1 maintained across all operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions sufficiently documented and traceable to replicate the computational boundary conditions.",
      "rationale": "FDA benchmark pump experiments conducted at 3500 RPM, 2.5–7.5 L/min flow range in phosphate-buffered saline with porcine RBCs. Temperature, hematocrit, and inlet/outlet pressure instrumentation uncertainties fully documented and mapped to CFD boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric E) within defined tolerance band for hemolysis index and pressure rise.",
      "rationale": "Normalized hemolysis index prediction error: 12% (within 15% tolerance). Pressure-rise curve RMSE: 4.1 mmHg across operating range. Validation metric E computed per ASME V&V 20; model uncertainty within experimental uncertainty band at 5 of 6 operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly correspond to those required for the regulatory decision (hemolysis index, shear stress distribution).",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) directly used in FDA guidance for CPB device assessment. Secondary QoIs (volumetric shear stress exposure distribution, recirculation zone extent) are mechanistically linked to hemolysis and align with the worst-case identification objective."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, fluid, and operating conditions sufficiently similar to the CPB COU to support extrapolation.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry — the canonical benchmark for CPB hemolysis CFD. Operating conditions span the CPB clinical range (2–6 L/min, 3000–4500 RPM). Blood analog and porcine RBC experiments bracket the clinical hematocrit range, supporting relevance at MRL 2."
    },
    {
      "type": "CredibilityFactor",
