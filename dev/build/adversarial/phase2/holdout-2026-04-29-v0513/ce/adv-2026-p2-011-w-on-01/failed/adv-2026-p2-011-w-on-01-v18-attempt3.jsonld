  "signature": "ed25519:b7e2a4d9c1f6b3e8a5d0c7f4b1e6a3d8c5f2b9e4a1d6c3f0b7e2a4d9c1f6b3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level meets or exceeds required level for MRL 2 per ASME V&V 40 Table 1.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented SQA processes including version control, regression testing, and release qualification. SQA documentation was reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities demonstrate correct implementation of governing equations for incompressible viscous flow and scalar transport at MRL 2.",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and power-law hemolysis transport equations confirmed second-order spatial convergence. Results are consistent with published benchmark solutions for rotating machinery flows."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI is below 5% at the operating point of interest.",
      "rationale": "Three systematically refined meshes (3.2 M, 8.7 M, and 22.4 M hexahedral cells) were used to compute GCI. The fine-grid GCI for normalized hemolysis index was 2.1%, exceeding the MRL 2 requirement. Richardson extrapolation confirmed monotonic convergence with observed order p = 1.94."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are documented and traceable; boundary conditions applied in simulation are consistent with experimental setup.",
      "rationale": "FDA generic centrifugal pump experiments were conducted at 2500 RPM and 5 L/min flow rate with porcine blood at 37 °C. Simulation boundary conditions replicate these settings. Fluid rheology parameters were taken from the same experimental lot."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure rise are within ±15% of experimental mean values across the validation operating range.",
      "rationale": "Predicted normalized index of hemolysis (NIH) agreed with experimental measurements within 8.3% across five operating points. Pump pressure rise predictions fell within 6.1% of experimental values. Comparison metrics satisfy the MRL 2 acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs predicted by the model (NIH, shear stress distribution, pressure rise) are directly linked to the clinical decision question regarding worst-case hemolysis conditions.",
      "rationale": "NIH is the regulatory-accepted metric for blood damage in CPB devices per FDA guidance. Shear stress exposure time integral is the mechanistic driver for the power-law hemolysis model. Both QoIs are directly relevant to identifying worst-case operating conditions for the Class II device."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the geometry, flow regime, and operating conditions representative of CPB use at MRL 2.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which shares geometric similarity and Reynolds number range with the device under assessment. Operating conditions span the CPB clinical range (2–6 L/min, 2000–3000 RPM), providing adequate coverage for the intended decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when code verification has been completed and iterative convergence is demonstrated.",
      "rationale": "At MRL 2, explicit quantification of iterative solver error beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations; iterative error is judged negligible relative to discretization error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; analyst qualification review is sufficient.",
      "rationale": "Simulation was performed by analysts with documented CFD training and peer review of model setup. Formal use-error quantification is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection is justified by literature precedent.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is the standard formulation used in regulatory submissions for CPB devices. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values are taken from published literature and experimental measurements.",
      "rationale": "Blood viscosity, density, and hemolysis model constants are taken from published experimental characterization studies. Sensitivity to input variation is not formally required at MRL 2 but was informally assessed and found low."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization is documented in the experimental report.",
      "rationale": "Porcine blood samples used in validation experiments were characterized for hematocrit and viscosity. Statistical treatment of inter-sample variability is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative assessment of parameter equivalency between validation and COU conditions is sufficient.",
      "rationale": "The validation geometry and operating conditions are judged representative of the COU based on geometric similarity and overlapping Reynolds number range. Formal equivalency mapping is not required at MRL 2."
    }
