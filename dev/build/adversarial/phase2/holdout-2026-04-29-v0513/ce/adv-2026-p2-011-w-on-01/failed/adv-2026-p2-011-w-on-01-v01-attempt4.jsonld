  "hash": "sha256:a3f1c82e4d09b756e2310f8c5a7d4b1e9f0c3d6a8b2e5f7c1d4a9b3e6f0c2d5",
  "signature": "ed25519:b7c2d4e6f1a3b5c8d0e2f4a6b8c1d3e5f7a9b2c4d6e8f0a1b3c5d7e9f2a4b6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and provide documented V&V test suite results for all active numerical modules.",
      "rationale": "ANSYS Fluent 2022 R2 is ISO 9001 certified; internal V&V test suite covering turbulence, rotating-frame, and species-transport modules was reviewed and found complete for MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-cavity benchmark must confirm second-order spatial convergence within 5% of theoretical rate.",
      "rationale": "Method of manufactured solutions applied to rotating-cavity flow confirmed 1.94-order spatial convergence, within 3% of theoretical second-order rate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI on the QoI (NIH) must be below 5% on the medium mesh.",
      "rationale": "Three-level mesh refinement study yielded GCI of 2.1% on NIH at 3500 rpm on the medium mesh (6.2 M cells), exceeding the MRL 2 threshold. Fine mesh (14.8 M cells) GCI of 0.8% provided additional confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must be reproduced in the CFD setup within stated measurement uncertainty.",
      "rationale": "Inlet flow rates (2.5, 5.0, 7.5 L/min) and rotational speeds (2500, 3500 rpm) matched FDA bench protocol; glycerol-water viscosity and density reproduced within 0.8% of measured values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with bench measurements within combined experimental and model uncertainty at all six operating points.",
      "rationale": "NIH predictions fell within combined uncertainty bounds at 5 of 6 operating points; the single outlier (2500 rpm, 7.5 L/min) showed 8.3% deviation, attributed to cavitation inception not captured by the model, documented as a known model boundary."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (NIH and shear-stress distribution) must be directly linked to the clinical endpoint (red blood cell damage) and to the regulatory submission metric.",
      "rationale": "NIH is the FDA-accepted metric for hemolysis in CPB devices; shear-stress distribution drives the power-law hemolysis model. Both QoIs are directly traceable to the 510(k) submission requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the intended operating envelope (flow rate and speed range) of the CPB device in clinical use.",
      "rationale": "Bench experiments covered 2500–3500 rpm and 2.5–7.5 L/min, encompassing the full clinical CPB operating range. Geometric fidelity to the FDA generic pump ensured relevance to the device class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iterative convergence residuals must drop below 1e-5 for all equations.",
      "rationale": "Not assessed at MRL 2; residual monitoring logs confirm convergence to 1e-6 as a byproduct of the discretization study, providing incidental evidence without formal assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Operator setup checklists and peer-review of simulation input decks must be documented.",
      "rationale": "Not formally assessed at MRL 2. Internal peer review of input decks was performed informally; no structured use-error log was maintained for this study phase."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified against PIV data for swirling rotating flows; hemolysis power-law constants must reference peer-reviewed sources.",
      "rationale": "SST k-ω turbulence model selected based on comparative study against PIV data from FDA round-robin; Giersiepen power-law constants sourced from Heuser & Opitz (1980) and validated against independent hemolysis data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis on fluid viscosity and inlet turbulence intensity must be documented.",
      "rationale": "Not assessed at MRL 2. Nominal input values used throughout; sensitivity to viscosity variation acknowledged as a limitation to be addressed at higher MRL."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterisation of biological variability in hemolysis measurements across blood sample lots must be provided.",
      "rationale": "Not assessed at MRL 2. FDA bench protocol used standardised porcine blood with controlled hematocrit; inter-lot variability not formally characterised at this study phase."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between clinical blood properties and glycerol-water surrogate must be quantitatively justified.",
      "rationale": "Not assessed at MRL 2. Glycerol-water surrogate viscosity matched porcine blood at 37°C; full equivalency analysis deferred to MRL 3 submission."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scope for a Class II CPB device. GCI of 2.1% on NIH and PIV velocity agreement within experimental uncertainty provide sufficient confidence that the CFD model can identify worst-case hemolysis operating conditions. The single outlier at 2500 rpm/7.5 L/min is outside the primary clinical operating range and is documented. The assessment team concludes the model is credible for the intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
