      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic centrifugal blood pump"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-bench",
      "type": "ValidationResult",
      "name": "Normalised Index of Hemolysis bench validation at 2500 and 3500 rpm"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034996",
