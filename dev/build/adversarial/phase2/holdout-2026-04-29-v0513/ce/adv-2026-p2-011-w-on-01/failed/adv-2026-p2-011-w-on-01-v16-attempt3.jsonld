      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control and regression testing in place for solver and hemolysis post-processor.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional SQA plan. Version control via Git, regression suite covers 12 canonical flow cases. All SQA artifacts archived and traceable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification performed on at least one canonical benchmark relevant to rotating turbomachinery flow.",
      "rationale": "Method of manufactured solutions applied to rotating cavity benchmark; observed second-order spatial convergence confirmed for momentum and continuity equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for QoI (hemolysis index and bulk pressure rise) across at least three mesh refinement levels.",
      "rationale": "Three-level mesh refinement study (4.2M, 11.7M, 28.4M cells) performed. GCI for hemolysis index < 4.1%; GCI for pressure rise < 1.8%. Richardson extrapolation applied. Achieves Gradation 3 due to tight GCI bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) replicated in simulation within stated tolerances.",
      "rationale": "FDA GCBP bench test conditions (5 L/min, 2500 RPM, bovine blood analog) reproduced in CFD boundary conditions. Fluid viscosity and density matched to within 2% of reported experimental values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE or E_rel) defined and computed for hemolysis index and pressure rise.",
      "rationale": "Normalized root-mean-square error for hemolysis index across 6 operating points is 8.3%; pressure rise NRMSE is 4.7%. Both within acceptance band for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution, pressure rise) are directly linked to the clinical risk of hemolysis in CPB patients.",
      "rationale": "Hemolysis index is the primary regulatory QoI per FDA guidance for CPB devices. Shear stress distribution directly drives the power-law hemolysis damage accumulation model. Linkage to patient risk documented in hazard analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA GCBP geometry at overlapping operating conditions with the intended COU envelope.",
      "rationale": "Validation dataset uses FDA GCBP geometry identical to simulation domain. Operating points span 3–7 L/min and 1500–3500 RPM, covering the full intended COU envelope. Fluid analog properties matched to clinical blood viscosity range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance at Gradation 1 is sufficient.",
      "rationale": "At MRL 2, formal iterative convergence error quantification beyond residual monitoring is not required. Solver residuals confirmed below 1e-5 for all equations; iterative error not separately quantified per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification records sufficient.",
      "rationale": "MRL 2 does not mandate formal use-error analysis. Lead analyst holds PhD in computational fluid dynamics with 8 years of cardiovascular CFD experience. Simulation setup reviewed by independent senior analyst."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified for rotating blood pump internal flows; hemolysis damage accumulation model form documented.",
      "rationale": "SST k-omega turbulence model selected based on literature evidence for rotating pump internal flows. Power-law hemolysis model (Giersiepen-Wurzinger) adopted per regulatory precedent. Model form assumptions documented and peer-reviewed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis performed for key uncertain inputs: blood viscosity, inlet velocity profile, and hemolysis model coefficients.",
      "rationale": "One-at-a-time sensitivity study conducted for blood viscosity (±15%), inlet turbulence intensity (5–15%), and hemolysis model exponent (±10%). Hemolysis index sensitivity to viscosity is dominant at 6.2% variation; all within acceptable bounds for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; existing FDA GCBP dataset is accepted as representative.",
      "rationale": "FDA GCBP experimental dataset is a publicly available, community-standard benchmark. Sample representativeness assessment beyond confirmation of geometric and operating-condition fidelity is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; boundary condition matching documented under Test Conditions factor.",
      "rationale": "Formal equivalency mapping between validation experiment inputs and COU simulation inputs is not required at MRL 2. Boundary condition correspondence documented under the Test Conditions credibility factor assessment."
    }
