  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Submitted under the Minimal profile; structured context-of-use link intentionally absent — use scope is described in the bound requirement and claim prose.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/fda-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/morrison/data/fda-pump-cfd-mesh-sensitivity"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA experimental benchmark"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure rise vs. measured characteristic curve"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034998",
