  "signature": "ed25519:b1d4e7a2c5f8b3e6a9d2c5f0b3e6a9d2c5f0b3e6a9d2c5f0b3e6a9d2c5f0b3e6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented QA procedures including version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 employed with documented QA trail: version-controlled input decks, automated regression suite (>200 canonical cases), and formal release notes. QA level meets MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark on canonical flows at MRL 2.",
      "rationale": "Code verification confirmed via method-of-manufactured-solutions for incompressible Navier-Stokes; observed order of accuracy (1.97) consistent with second-order scheme. Benchmark against lid-driven cavity and backward-facing step also passed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% at the operating point of interest.",
      "rationale": "Three-mesh Richardson extrapolation performed (3.2M, 8.7M, 22.1M cells). GCI for normalized index of hemolysis = 2.8%, exceeding the MRL 2 requirement. Achieved level 3 due to systematic three-mesh study with formal uncertainty quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) must be documented with measurement uncertainty and mapped to simulation inputs.",
      "rationale": "FDA benchmark experimental conditions fully documented: flow rates 2.5–7 L/min, rotational speeds 2000–3500 RPM, bovine blood viscosity measured at 37°C. Uncertainty on flow rate ±1.5%, speed ±10 RPM. Simulation BCs set to match nominal experimental values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure rise must agree with experimental measurements within combined simulation and experimental uncertainty bands.",
      "rationale": "Normalized index of hemolysis predictions fall within ±18% of experimental mean across all 12 operating points tested; pressure rise within ±4%. Agreement is within combined uncertainty at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, pressure rise) must be directly relevant to the clinical decision of identifying worst-case hemolysis operating conditions for the CPB device.",
      "rationale": "Normalized index of hemolysis is the primary regulatory endpoint for CPB blood damage assessment per FDA guidance. Pressure rise characterizes pump duty point. Both QoIs are directly linked to the intended-use decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a geometry and flow regime sufficiently similar to the CPB device COU to support extrapolation of credibility conclusions.",
      "rationale": "Validation performed on the FDA generic centrifugal pump — the same geometry as the device under assessment. Flow conditions span the CPB operating envelope. Validation domain is considered directly applicable without geometric extrapolation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative solver convergence to residuals below 1e-5 is sufficient; formal round-off or floating-point error analysis not required.",
      "rationale": "Solver residuals converged to below 1e-6 for all equations. Iterative error is negligible relative to discretization error. Formal solver error analysis scoped out at MRL 2 per ASME V&V 40 Table 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documented simulation protocols and peer review of setup are sufficient; formal use-error FMEA not required.",
      "rationale": "Simulation setup reviewed by independent CFD engineer. Input deck version-controlled and archived. Formal use-error analysis deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form selection (turbulence model, hemolysis power-law) must be documented with literature justification; formal sensitivity analysis not required.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power law selected based on published CFD-hemolysis literature. Model form uncertainty acknowledged but not formally quantified at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are required; probabilistic input uncertainty propagation is not required.",
      "rationale": "Blood viscosity, density, and hemolysis model constants sourced from peer-reviewed literature with nominal values documented. Parametric uncertainty propagation deferred to higher MRL activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, experimental sample size and preparation method must be documented; statistical power analysis not required.",
      "rationale": "FDA benchmark dataset uses n=3 pump specimens with bovine blood from a single lot per test session. Sample documentation sufficient for MRL 2; inter-specimen variability analysis deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative mapping of experimental inputs to simulation inputs is sufficient; formal equivalency metrics not required.",
      "rationale": "Experimental and simulation boundary conditions mapped qualitatively: flow rate, rotational speed, and fluid properties correspond directly. Formal equivalency scoring deferred per MRL 2 scoping decision."
    }
  ],
