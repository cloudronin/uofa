      "name": "PIV velocity field comparison — FDA generic centrifugal blood pump at five operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/gcbp-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalised index of hemolysis comparison against bench measurements across CPB flow range"
    }
  ],
