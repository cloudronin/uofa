      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Statistical characterisation of experimental sample variability not required at MRL 2. FDA protocol specifies standardised pump specimens; lot-to-lot variation assumed negligible."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Formal equivalency mapping between validation and COU input parameter spaces not required at MRL 2. Qualitative mapping documented in simulation plan section 4.2."
    }
