  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented and version-controlled; solver regression suite passing.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional SQA plan. Regression suite of 47 benchmark cases executed; all within tolerance. Version control via Git with signed releases. Satisfies MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy confirmed for governing equations via manufactured solution or published benchmark.",
      "rationale": "Second-order spatial accuracy confirmed against lid-driven cavity and Poiseuille flow benchmarks. Observed order of accuracy 1.94 consistent with nominal second-order scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% on primary QoI at the operating point of maximum hemolysis index.",
      "rationale": "Three-mesh Richardson extrapolation performed (3.2 M, 8.7 M, 22.1 M cells). GCI on normalised hemolysis index = 2.8% at worst-case operating point. Exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions reproduced in simulation within stated uncertainty bounds.",
      "rationale": "Inlet flow rates, outlet pressures, and fluid temperature from FDA bench protocol replicated in CFD boundary conditions. Deviations < 1.5% of nominal values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoI within combined simulation and experimental uncertainty at ≥ 80% of comparison points.",
      "rationale": "Velocity field E_rms = 0.06 m/s against PIV (< 10% of peak velocity). Hemolysis index prediction within 15% of bench measurements at 4 of 5 operating points, satisfying MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical risk endpoint (hemolysis) and device labelling claim.",
      "rationale": "Normalised index of hemolysis and shear-stress exposure time are the primary QoIs, directly mapping to the device labelling claim of acceptable hemolytic potential under CPB flow conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, fluid, and operating range representative of CPB clinical use envelope.",
      "rationale": "FDA generic centrifugal blood pump geometry used in validation matches production device topology. Blood analogue fluid (glycerol-water) rheology within 8% of clinical blood viscosity. Flow range 2–8 L/min spans full CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "MRL 2 does not mandate explicit numerical solver error quantification beyond code verification already performed. Scoped out per ASME V&V 40 Table 3 guidance for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Formal use-error analysis not required at MRL 2. Simulation setup peer-reviewed internally by two independent analysts as a compensating control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Formal model-form uncertainty quantification not required at MRL 2. SST k-ω turbulence model selection justified by published literature for rotating blood-contacting devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
