  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression test suite, and release validation for hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022 R2 is used under a validated QMS. Release notes document regression tests covering rotating machinery and non-Newtonian blood rheology. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests using manufactured solutions must confirm second-order spatial convergence for the momentum and scalar transport equations.",
      "rationale": "Method of manufactured solutions applied to the scalar hemolysis transport equation confirms 1.97-order convergence. Internal benchmark cases for rotating reference frames show consistent second-order behavior."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the hemolysis index QoI must be below 5% on the fine grid.",
      "rationale": "Three-level GCI study performed on structured hexahedral meshes (4.2 M, 11.7 M, 31.4 M cells). GCI on fine grid for normalized hemolysis index is 2.3%, below the 5% threshold. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, hematocrit) must be reproduced in simulation within stated measurement uncertainty.",
      "rationale": "FDA pump test conditions (2500 RPM, 5 L/min, 37 °C, 33% hematocrit bovine blood) are matched in simulation. Inlet velocity profile derived from PIV measurements. Fluid properties set to match experimental rheology within ±2%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within the combined simulation and experimental uncertainty band at all validation operating points.",
      "rationale": "Normalized index of hemolysis (NIH) predicted at 0.0041 g/100 L versus experimental 0.0038 ± 0.0006 g/100 L. Difference of 7.9% falls within combined uncertainty band. Agreement is satisfactory for MRL 2 decision support."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, shear stress distribution, exposure time) must be the same quantities used in the CPB worst-case identification decision.",
      "rationale": "NIH and volume-averaged scalar shear stress are the primary QoIs for both validation and the CPB worst-case sweep. Exposure-time weighted stress integral is computed identically in both contexts, ensuring direct relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the geometry, flow regime, and fluid properties representative of the CPB operating envelope.",
      "rationale": "Validation performed on the identical FDA generic centrifugal pump geometry under bovine blood at CPB-relevant flow rates (3–7 L/min) and speeds (1500–3500 RPM). No geometric or fluid extrapolation required for COU application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; not formally quantified at MRL 2.",
      "rationale": "At MRL 2, formal quantification of numerical solver error beyond residual monitoring is not required. Residuals converge to 1e-7 for continuity and momentum; solver error contribution judged negligible relative to discretization error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation execution checklist; formal use-error quantification not required at MRL 2.",
      "rationale": "Simulation setup follows a documented internal SOP with peer-review checkpoint. Formal probabilistic use-error assessment is scoped out at MRL 2 per ASME V&V 40 Table 1 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative justification of turbulence and hemolysis model selection; formal model-form uncertainty quantification not required at MRL 2.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for confined rotating flows. Giersiepen-Wurzinger hemolysis power-law model is the regulatory standard for CPB devices. Formal model-form UQ deferred to MRL 3 activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal input values documented with source references; sensitivity analysis not required at MRL 2.",
      "rationale": "All model inputs (fluid density, viscosity, hemolysis power-law coefficients) documented with literature sources and measurement reports. Formal sensitivity or uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample provenance documented; statistical characterization of inter-sample variability not required at MRL 2.",
      "rationale": "Bovine blood samples sourced from a single supplier lot with hematocrit and viscosity measurements reported. Inter-lot variability characterization is not required at MRL 2 and is deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative mapping of validation inputs to COU inputs documented; formal equivalency scoring not required at MRL 2.",
      "rationale": "Validation uses bovine blood as a surrogate for human blood in CPB application. Rheological similarity is qualitatively documented. Formal equivalency index calculation is scoped out at MRL 2 per project risk plan."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are appropriately scoped out per ASME V&V 40 Table 1 guidance for MRL 2. Discretization error GCI of 2.3% and NIH prediction within combined uncertainty band provide sufficient evidence that the CFD model can reliably identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB service. The assessment team accepts the model for the intended regulatory submission supporting Class II device clearance.",
