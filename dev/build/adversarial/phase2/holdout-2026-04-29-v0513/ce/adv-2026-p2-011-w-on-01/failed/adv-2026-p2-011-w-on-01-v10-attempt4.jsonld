      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data at 2500 RPM and 5 L/min"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation across CPB operating envelope (1500–3500 RPM)"
    }
  ],
