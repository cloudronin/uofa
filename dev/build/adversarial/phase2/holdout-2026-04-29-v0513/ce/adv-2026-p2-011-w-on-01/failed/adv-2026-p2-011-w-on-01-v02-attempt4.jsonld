  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, build reproducibility, and regression test suite documented per MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 used with documented version control. Regression tests on canonical pipe flow and lid-driven cavity cases confirm solver integrity. SQA documentation meets MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions or benchmark problems demonstrates correct numerical implementation.",
      "rationale": "Second-order spatial accuracy confirmed through method of manufactured solutions on representative rotating-frame Navier-Stokes problem. Observed order 1.94 consistent with nominal second-order scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed for hemolysis index QoI; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study conducted (coarse 2.1M, medium 5.8M, fine 14.3M cells). GCI for hemolysis index on fine grid: 2.7%. Exceeds MRL 2 requirement; discretization error is well controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with measurement uncertainties; boundary conditions reproducible in simulation.",
      "rationale": "FDA benchmark experimental conditions (flow rate, rotational speed, fluid viscosity, temperature) documented with calibrated instrumentation. Measurement uncertainties propagated into simulation boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric M) computed for hemolysis index; agreement within defined tolerance band.",
      "rationale": "Normalized hemolysis index error E% = 8.3% across 12 operating conditions tested against FDA benchmark dataset. Within the 15% tolerance band established for MRL 2 CPB hemolysis prediction. Worst-case operating point correctly identified in 11 of 12 test cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress distribution) are directly relevant to the clinical decision of identifying worst-case hemolysis conditions.",
      "rationale": "Hemolysis index (normalized index of hemolysis, NIH) is the direct regulatory QoI for CPB device evaluation. Scalar stress exposure integrated over particle trajectories directly maps to the clinical endpoint. Relevance confirmed by FDA guidance document."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on geometrically and operationally similar device under representative CPB flow conditions.",
      "rationale": "Validation performed on FDA generic centrifugal pump — same geometry as simulation target. Operating conditions span the CPB clinical envelope (2–6 L/min, 1500–3500 RPM). Fluid properties matched using glycerin-water blood analog at physiological viscosity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance < 1e-5 for all equations; mass imbalance < 0.01%.",
      "rationale": "Not formally assessed at MRL 2 per ASME V&V 40 Table 1 guidance. Standard convergence monitoring (residuals < 1e-5, mass imbalance < 0.005%) applied as good practice but not formally documented as a credibility factor assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification and simulation setup review process documented.",
      "rationale": "Not assessed at MRL 2. Analysts hold relevant CFD credentials; peer review of simulation setup conducted informally. Formal use-error assessment deferred to higher MRL activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis damage model form justified relative to available literature.",
      "rationale": "Not assessed at MRL 2. SST k-omega turbulence model and power-law hemolysis damage model selected based on published literature for blood pump applications. Formal model form uncertainty quantification deferred to MRL 3 activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis index to key input parameters (viscosity, damage model constants) quantified.",
      "rationale": "Not assessed at MRL 2. Input parameter sensitivity analysis planned for MRL 3 submission. Nominal blood analog properties used consistent with experimental conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample-to-sample variability in experimental hemolysis measurements characterized.",
      "rationale": "Not assessed at MRL 2. FDA benchmark dataset provides single-laboratory measurements. Inter-laboratory variability assessment deferred. Intra-run repeatability noted as adequate in original FDA study documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, boundary conditions, fluid properties) demonstrably equivalent to experimental conditions within stated tolerances.",
      "rationale": "CAD geometry imported directly from FDA benchmark specification with dimensional verification (max deviation 0.03 mm). Boundary conditions set to experimentally measured values. Fluid viscosity matched to within 1.2% of experimental glycerin-water mixture. Equivalency confirmed for all primary input parameters."
    }
  ],
