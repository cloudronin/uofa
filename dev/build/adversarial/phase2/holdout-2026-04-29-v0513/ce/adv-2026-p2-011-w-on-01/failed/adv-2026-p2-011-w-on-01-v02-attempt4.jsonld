      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs. experimental measurements across CPB operating envelope"
    },
    {
      "id": "https://uofa.net/morrison/validation/worst-case-operating-point-identification",
      "type": "ValidationResult",
      "name": "Worst-case operating point identification validation against FDA benchmark data"
