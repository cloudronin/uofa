  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level consistent with MRL 2 requirements: version control, documented test suite, and change management records in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented SQA processes. Version control logs and regression test suite outputs were reviewed and confirmed compliant with MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark problems relevant to rotating turbomachinery flows at MRL 2 standard.",
      "rationale": "ANSYS Fluent code verification benchmarks for rotating reference frame and turbulent pipe flow cases were reviewed. Results agree with analytic solutions within 0.5%, satisfying MRL 2 numerical code verification requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (NIH and wall shear stress) with GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed (coarse: 4.2M cells, medium: 11.8M cells, fine: 31.4M cells). GCI for NIH on fine grid is 2.1% and for peak wall shear stress is 3.8%, both below the 5% threshold. Achieved level exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid viscosity) documented and traceable to calibrated measurement equipment.",
      "rationale": "FDA pump experimental dataset documents test conditions across six operating points (2–7 L/min, 2500–3500 RPM) using glycerol-water blood analog. Calibration certificates for flow meters and torque sensors confirmed traceable to NIST standards."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric M) reported for NIH and pressure-head QoIs with uncertainty bounds.",
      "rationale": "Validation comparison performed using E% metric. NIH predictions agree with experimental values within 18% across all operating points (mean E% = 11.3%). Pressure-head predictions agree within 5%. Both within acceptable bounds for MRL 2 hemolysis modeling."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, wall shear stress, exposure time) are directly linked to the clinical decision question of worst-case hemolysis identification.",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH), which is the regulatory-accepted metric for blood damage in CPB devices. Secondary QoIs (shear stress magnitude and red blood cell exposure time) directly parameterize the hemolysis power-law model. Relevance to worst-case identification is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal pump geometry under overlapping operating conditions with CPB clinical range.",
      "rationale": "Validation data sourced from FDA-sponsored experiments on the identical generic centrifugal pump geometry. Operating conditions span the CPB clinical flow range (2–7 L/min). Fluid analog viscosity matched to blood at 37°C. Validation activity relevance to the CPB COU is confirmed at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence monitoring sufficient.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-5 for all transport equations. Factor scoped to not-assessed per MRL 2 assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records reviewed informally.",
      "rationale": "MRL 2 does not require formal use error assessment. Analyst team holds documented CFD training and has performed prior FDA pump simulations. Factor recorded as not-assessed per MRL 2 assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; turbulence model selection justified by literature precedent.",
      "rationale": "SST k-omega turbulence model selected based on published precedent for centrifugal pump hemolysis CFD. Formal model form uncertainty quantification not required at MRL 2. Factor recorded as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values documented with sources.",
      "rationale": "Blood analog fluid properties (density 1056 kg/m3, viscosity 3.5 mPa·s) documented from literature. Hemolysis model coefficients from Giersiepen et al. (1990) as standard for CPB CFD. Formal input uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample documentation reviewed.",
      "rationale": "FDA experimental dataset used a single pump unit with n=3 repeat measurements per operating point. Formal test sample statistical analysis not required at MRL 2. Factor recorded as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative equivalency argument provided.",
      "rationale": "Glycerol-water analog used in experiments is standard blood surrogate for CFD validation of hemolysis models. Equivalency of Newtonian viscosity assumption to in-vivo blood rheology at high shear rates (>100 s-1) is well-established in literature. Formal equivalency analysis not required at MRL 2."
    }
  ],
