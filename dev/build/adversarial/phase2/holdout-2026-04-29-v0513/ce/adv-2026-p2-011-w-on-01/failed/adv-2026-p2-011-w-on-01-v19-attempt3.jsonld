  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are acceptable per the ASME V&V 40 MRL 2 assessment matrix. The CFD hemolysis model is credible for identifying worst-case hemolysis operating conditions for the Class II FDA generic centrifugal blood pump under CPB conditions. Model predictions of NIH agree with experimental data within 18% across the full operating envelope, satisfying the acceptance criteria for regulatory submission support. Decision: Accepted for intended use as described in the bound Requirement (https://uofa.net/morrison/req/cpb-hemolysis-mrl2) and Claim (https://uofa.net/morrison/claim/cpb-nih-worst-case) nodes.",
