      "type": "ValidationResult",
      "name": "NIH prediction vs. experimental bench data across CPB operating envelope"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "CFD velocity field comparison against FDA pump PIV measurements"
    }
  ],
