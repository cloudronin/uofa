      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver (ANSYS Fluent 2022R2) must have documented verification test suite and version-controlled build. Required level 2 for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with FDA-recognized quality management documentation. Version control, regression test suite, and release notes reviewed. SQA level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that governing equations are solved correctly via method-of-manufactured-solutions or equivalent benchmark. Required level 2.",
      "rationale": "Method-of-manufactured-solutions applied to Navier-Stokes solver for laminar and turbulent regimes. Observed convergence rates consistent with second-order spatial accuracy. Code verification level 2 confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on at least three systematically refined meshes. Required level 2.",
      "rationale": "Three-level mesh refinement study conducted (coarse 4.2M, medium 11.7M, fine 31.4M cells). GCI for hemolysis index: 3.1% coarse-to-medium, 1.4% medium-to-fine. Richardson extrapolation applied. Achieved level 3 exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty quantification for flow rate, rotational speed, and fluid temperature. Required level 2.",
      "rationale": "FDA benchmark experimental data include calibrated Coriolis flow meters (±0.5% FS), tachometer readings (±10 RPM), and temperature control (37±0.5°C). Experimental uncertainty propagated to hemolysis index measurement. Test conditions level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation uncertainty) computed for primary QoI. Required level 2.",
      "rationale": "Hemolysis index predictions compared against five experimental operating points. Normalized RMS error 8.3%, within combined simulation and experimental uncertainty bands at all operating points. Validation uncertainty computed per ASME V&V 20. Output comparison level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) must be directly linked to the clinical decision question of worst-case blood damage under CPB operating conditions. Required level 2.",
      "rationale": "Hemolysis index is the regulatory-accepted surrogate for red blood cell damage in CPB devices. The QoI directly informs the worst-case operating condition identification required by the submission decision. Relevance of QoI level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the operating envelope of the intended CPB use (flow 2–6 L/min, speed 1500–3500 RPM). Required level 2.",
      "rationale": "FDA benchmark experiments cover five operating points spanning the CPB operating envelope. Geometric fidelity of the generic centrifugal pump matches the submission device to within manufacturing tolerances. Validation relevance level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
