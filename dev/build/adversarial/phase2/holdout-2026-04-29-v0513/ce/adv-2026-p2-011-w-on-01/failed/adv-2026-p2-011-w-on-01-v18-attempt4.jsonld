  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-mrl2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors scoped to level 1 and not formally assessed are consistent with MRL 2 requirements per ASME V&V 40 Table 3. Hemolysis index predictions fall within combined validation uncertainty at all five operating points spanning the CPB envelope (2–6 L/min, 1500–3500 RPM). The computational model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device submission.",
