      "acceptanceCriteria": "Governing equations and turbulence model selection documented with justification. Required level 1 at MRL 2.",
      "rationale": "SST k-omega turbulence model selected based on prior literature for centrifugal blood pump applications. Model form justification documented in simulation plan. Formal model form uncertainty quantification not required at MRL 2 level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood viscosity, density, and boundary condition values documented with sources. Required level 1 at MRL 2.",
      "rationale": "Newtonian blood model (viscosity 0.0035 Pa·s, density 1060 kg/m³) applied consistent with FDA benchmark protocol. Inlet velocity profiles derived from flow rate measurements. Model inputs documented; sensitivity analysis not required at MRL 2 level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog fluid properties and lot traceability documented for experimental samples. Required level 1 at MRL 2.",
      "rationale": "FDA benchmark used porcine blood with documented hematocrit (35±2%) and lot traceability. Sample preparation protocol referenced from published FDA benchmark study. Formal test sample assessment not required at MRL 2 level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation boundary conditions and experimental test conditions documented. Required level 1 at MRL 2.",
      "rationale": "Simulation boundary conditions derived directly from experimental test protocol. Flow rate and rotational speed inputs match experimental set points within measurement uncertainty. Equivalency documented in simulation plan; formal equivalency assessment not required at MRL 2 level 1."
    }
