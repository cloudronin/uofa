  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under version control with documented QA procedures meeting MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 was employed under a documented QA plan including version-controlled case files, regression test suite, and change-control records. All QA artifacts reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass benchmark verification cases relevant to rotating turbomachinery flows, demonstrating correct implementation of governing equations.",
      "rationale": "ANSYS Fluent passed the ASME V&V 20 Taylor-Couette and lid-driven cavity benchmark cases. Rotating reference frame implementation verified against analytical solutions for inviscid swirl. No code defects identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine mesh relative to the medium mesh.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 9.8M, 21.4M cells). GCI for normalized index of hemolysis on fine-to-medium comparison was 2.3%, well below the 5% threshold. Richardson extrapolation confirms asymptotic convergence. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must be documented with uncertainty bounds and must bracket the intended CPB operating envelope.",
      "rationale": "FDA bench test conditions (flow rate 2–8 L/min, rotational speed 2000–3500 RPM, inlet pressure 10 mmHg) are fully documented with expanded uncertainty (k=2). These conditions bracket the nominal CPB operating range of 4–6 L/min at 2500–3000 RPM."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty at all five validation operating points.",
      "rationale": "At all five operating points, the normalized index of hemolysis predicted by CFD falls within the experimental uncertainty band (mean absolute error 8.4%, within combined U95 of 12.1%). Systematic over-prediction at high RPM is within uncertainty; no bias correction applied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis) must be directly linked to the clinical risk metric for CPB device assessment.",
      "rationale": "Normalized index of hemolysis (NIH) is the standard regulatory metric for CPB pump hemolysis per FDA guidance. CFD outputs are post-processed using the power-law hemolysis model (Giersiepen et al.) to yield NIH directly comparable to bench measurements. QoI relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the FDA generic centrifugal pump geometry under conditions representative of CPB use.",
      "rationale": "Validation was performed on the identical FDA generic pump CAD geometry under flow and pressure conditions spanning the CPB operating envelope. Blood analog fluid (glycerol-water, matched viscosity) used in bench tests; Newtonian blood model applied in CFD. Representativeness confirmed for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to solver tolerance sufficient for MRL 2 not required to be formally quantified beyond standard residual monitoring.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-5 for all equations. Factor scoped out per MRL 2 assessment plan; default gradation 1 assigned."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use-error analysis not required at MRL 2 for this device class.",
      "rationale": "MRL 2 assessment plan explicitly scopes out formal use-error analysis. Simulation was conducted by experienced CFD engineers with documented training records. No formal assessment required or performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification not required at MRL 2; selection of turbulence and hemolysis sub-models must be documented.",
      "rationale": "SST k-omega turbulence model and Giersiepen power-law hemolysis model selected based on literature consensus for centrifugal blood pump CFD. Formal model-form uncertainty quantification not required at MRL 2. Model selection rationale documented in simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis on model input parameters not required at MRL 2; nominal inputs must be documented.",
      "rationale": "Nominal model inputs (fluid density 1056 kg/m3, viscosity 3.5 mPa·s, rotational speed per operating point) are fully documented. Formal sensitivity or uncertainty propagation on inputs not required at MRL 2 and not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2.",
      "rationale": "FDA benchmark dataset uses a single pump unit tested at five operating points. Sample-to-sample variability characterization is not required at MRL 2. Factor noted as not-assessed per assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between bench test and simulation input parameters not required at MRL 2 beyond documented boundary condition matching.",
      "rationale": "Boundary conditions in CFD are set to match bench test inlet/outlet conditions directly. Formal equivalency analysis not required at MRL 2. Documented in simulation plan section 4.2."
    }
  ],
