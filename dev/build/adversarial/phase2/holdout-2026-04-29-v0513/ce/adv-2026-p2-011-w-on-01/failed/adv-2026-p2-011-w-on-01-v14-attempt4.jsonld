  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver (ANSYS Fluent 2022 R2) holds current ISO 9001 certification and vendor-supplied V&V documentation; version control and audit trail maintained throughout study.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially certified solver with documented QA processes. Version control logs and run scripts were archived in the project repository. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Vendor-supplied manufactured-solution benchmarks for incompressible Navier-Stokes demonstrate second-order spatial convergence; internal consistency checks pass.",
      "rationale": "ANSYS Fluent passes published method-of-manufactured-solutions tests for the pressure-based coupled solver. Observed order of accuracy is 1.97, consistent with the second-order discretisation scheme employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for normalised index of haemolysis less than 5% on the fine grid; Richardson extrapolation applied across three systematically refined meshes.",
      "rationale": "Three-mesh GCI study (coarse 4.1 M, medium 8.7 M, fine 17.4 M hexahedral cells) yields GCI_fine = 2.3% for NIH and 3.1% for volume-averaged shear stress. Achieved level 3 exceeds the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity, temperature) replicated in simulation within stated measurement uncertainty bands.",
      "rationale": "PIV and NIH bench tests conducted at 3500 RPM, 5 L/min with 36% glycerol-water surrogate (viscosity 3.5 mPa·s ± 0.1). CFD boundary conditions set identically; deviations are within ±1% of nominal values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH within 15% of experimental mean across all six operating points; velocity magnitude profiles within two standard deviations of PIV data at five representative cross-sections.",
      "rationale": "Maximum NIH discrepancy is 11.4% at the highest-shear operating point. Velocity profiles show good agreement (RMS error 6.2% of bulk velocity). Both metrics satisfy the acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH) directly maps to the regulatory hemolysis endpoint; secondary QoI (volume-averaged scalar shear stress) is a recognised surrogate linked to red blood cell damage threshold literature.",
      "rationale": "NIH is the standard FDA-accepted metric for blood-contacting device hemolysis. Scalar shear stress threshold of 150 Pa applied consistently with published RBC damage models. Both QoIs are directly relevant to the worst-case identification decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal pump geometry, same fluid surrogate, and operating envelope overlapping the intended CPB design space.",
      "rationale": "Validation data sourced from the FDA CDRH inter-laboratory study using the identical impeller geometry. Operating points span 2500–3500 RPM and 3–6 L/min, fully covering the intended CPB envelope. High geometric and operational relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver error subsumed under code verification and discretisation error factors.",
      "rationale": "At Model Risk Level 2, explicit quantification of iterative solver error beyond residual monitoring is not required. Residuals converged to 1e-5 for all equations; mass imbalance below 0.01%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation setup reviewed by a second qualified engineer.",
      "rationale": "Peer review of simulation setup, boundary conditions, and post-processing scripts was conducted by a senior CFD engineer. Formal use-error quantification is deferred as consistent with MRL 2 expectations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection justified by literature survey.",
      "rationale": "SST k-ω turbulence model selected based on published benchmark performance for confined rotating flows. Formal model-form uncertainty quantification is beyond MRL 2 scope and is not required for this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal fluid properties and geometry dimensions used with documented sources.",
      "rationale": "Fluid properties sourced from NIST and manufacturer data sheets. Pump geometry digitised from FDA-released CAD files. Sensitivity to input uncertainty is acknowledged but formal UQ is not mandated at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; FDA inter-laboratory dataset treated as representative sample.",
      "rationale": "The FDA CDRH dataset aggregates results from five independent laboratories, providing a robust experimental baseline. Statistical characterisation of inter-sample variability is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; surrogate fluid properties mapped to blood surrogate equivalency via published viscosity matching protocol.",
      "rationale": "Glycerol-water surrogate viscosity matched to bovine blood at 37°C following ASTM F1841 guidance. Full equivalency analysis between surrogate and clinical blood rheology is deferred as consistent with MRL 2 scope."
    }
  ],
