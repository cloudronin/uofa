  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out per ASME V&V 40 Table 3 guidance for Class II devices at MRL 2. Grid convergence index of 2.1% and 94.3% PIV agreement provide high confidence in hemolysis QoI predictions across the CPB operating envelope. The model is accepted for use in identifying worst-case hemolysis operating conditions to support the 510(k) submission for the FDA generic centrifugal blood pump.",
