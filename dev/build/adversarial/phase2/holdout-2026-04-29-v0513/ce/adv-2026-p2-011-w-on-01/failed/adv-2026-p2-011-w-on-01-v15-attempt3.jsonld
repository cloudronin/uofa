  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under formal version control with documented regression test suite covering turbulent pipe-flow benchmarks; all test cases must pass at the committed solver revision.",
      "rationale": "ANSYS Fluent 2022 R2 is under ISO 9001-compliant QMS. Regression suite of 47 benchmark cases executed at revision tag; all pass within stated tolerances. Satisfies MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on manufactured solution for incompressible Navier-Stokes must confirm second-order spatial convergence within 10% of theoretical rate.",
      "rationale": "Method of manufactured solutions applied to 3-D incompressible N-S; observed order 1.93 (theoretical 2.0). Deviation 3.5%, within acceptance threshold. Code verification confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for scalar hemolysis index must be below 5% on the fine-grid solution using three systematically refined meshes.",
      "rationale": "Three meshes (4.2 M, 11.7 M, 28.4 M cells) assessed via Richardson extrapolation. GCI_fine = 2.1% for normalised index of hemolysis. Exceeds required level; discretization error well controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity) must be reproduced in simulation within ±3% of reported bench values.",
      "rationale": "FDA PIV dataset boundary conditions replicated: flow rate 5.0 L/min (±1.2%), speed 2500 RPM (±0.4%), glycerol-water viscosity matched to within 1.8%. All within ±3% criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Velocity magnitude predictions must agree with PIV measurements to within experimental uncertainty bands (U95) at 90% of comparison locations.",
      "rationale": "Point-by-point comparison across 1,840 PIV measurement locations: 94.3% of CFD predictions fall within U95 experimental uncertainty. Output comparison criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalised index of hemolysis, NIH) must be directly traceable to the regulatory submission metric and computed from the same shear-stress integration path used in the predicate device submission.",
      "rationale": "NIH computed per ASTM F1841 protocol. Directly maps to 510(k) submission metric for Class II CPB devices. Traceability chain documented in model description report MDR-2024-03."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic centrifugal pump geometry, the same blood-analogue fluid, and operating points spanning the intended CPB flow-rate envelope (3–7 L/min).",
      "rationale": "Validation performed on FDA generic pump geometry (identical to simulation domain). Blood-analogue glycerol-water used per ISO 10993-4. Operating points 3, 5, 6, 7 L/min bracket CPB envelope. Relevance confirmed."
    },
    {
