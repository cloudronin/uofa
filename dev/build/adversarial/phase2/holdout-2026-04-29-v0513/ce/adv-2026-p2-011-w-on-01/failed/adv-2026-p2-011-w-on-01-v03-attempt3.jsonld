  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver (ANSYS Fluent 2022 R2) must be under a documented QA plan with version control and regression testing records covering the turbulence and transport models used.",
      "rationale": "ANSYS Fluent 2022 R2 is covered by the vendor ISO 9001 QA program; internal regression suite (1 200 cases) passed. Version pinned in configuration management record CM-2024-047. Meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least one manufactured-solution or benchmark verification test must demonstrate solver correctness for the governing equations employed (incompressible Navier-Stokes, SST k-ω).",
      "rationale": "Method of manufactured solutions applied to lid-driven cavity and 3-D pipe flow; observed order of accuracy 1.94 vs. theoretical 2.0. FDA benchmark nozzle case reproduced within 3 % of published reference data. Requirement met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary QoI (hemolysis index) must be below 10 % on the medium mesh used for production runs.",
      "rationale": "Three-level Richardson extrapolation performed (coarse 4.1 M, medium 11.3 M, fine 28.7 M cells). GCI on hemolysis index: 6.8 % (medium→fine). Production runs use medium mesh. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must be documented with uncertainty bounds and applied consistently in simulation inputs.",
      "rationale": "PIV experiments conducted at 2500 RPM ± 5 RPM, flow rates 2.5–7.5 L/min ± 0.05 L/min, blood analog (36 % glycerol) viscosity 3.5 mPa·s ± 0.1 mPa·s. All conditions replicated in CFD boundary conditions. Traceability table in report Section 4.2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., normalized RMS or validation metric u_val) must be computed and compared against acceptance threshold defined prior to data unblinding.",
      "rationale": "Normalized RMS velocity error 4.2 % (threshold 10 %); hemolysis index within 12 % of mean experimental value across five points (threshold 20 %). Both metrics pass pre-defined acceptance criteria documented in VP-2024-003."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (velocity fields, hemolysis index) must be directly linked to the clinical decision question of worst-case hemolysis identification.",
      "rationale": "Hemolysis index is the primary safety endpoint for CPB devices per FDA guidance. Velocity field validation underpins confidence in shear-stress-driven hemolysis model. Linkage documented in COU narrative within Claim node https://uofa.net/morrison/claim/cpb-hemolysis-worst-case."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating envelope, and fluid analog as the intended COU operating conditions.",
      "rationale": "Validation used FDA generic centrifugal pump geometry (identical to COU device archetype), CPB-representative flow rates (2.5–7.5 L/min), and blood analog matching plasma viscosity. Geographic and parametric overlap rated High per relevance matrix in Appendix B."
    },
    {
