    {
      "id": "https://uofa.net/morrison/validation/nih-comparison-2024",
      "type": "ValidationResult",
      "name": "NIH output comparison against FDA pump bench data at five operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv-2024",
      "type": "ValidationResult",
      "name": "Velocity field validation via PIV measurements in the volute region"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4056789",
