  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold a documented V&V pedigree with version-controlled source and regression test suite covering turbomachinery flows.",
      "rationale": "ANSYS Fluent 2023R2 is used under an ISO 9001-certified QMS. Regression suite of 47 benchmark cases is maintained; all pass within tolerance. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow cases must confirm theoretical convergence rate within 10%.",
      "rationale": "Method of manufactured solutions applied to rotating Couette flow and lid-driven cavity confirms second-order spatial accuracy. Observed rate 1.93 vs theoretical 2.0."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH QoI must be below 5% on the fine-grid solution.",
      "rationale": "Three-level Richardson extrapolation performed on 4.2 M, 11.7 M, and 28.4 M cell meshes. GCI_fine = 2.1% for NIH; GCI_fine = 3.4% for wall shear stress peak. Both below 5% threshold; achieves level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet/outlet conditions within stated uncertainty bounds.",
      "rationale": "Flow rate, rotational speed, and inlet hematocrit recorded for each bench test point. Simulation BCs set to measured mean values; inlet turbulence intensity estimated from Colebrook correlation. Uncertainty overlap confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must lie within combined experimental and numerical uncertainty band at all five validation operating points.",
      "rationale": "NIH predictions agree with bench measurements within ±18% at all five operating points. Combined uncertainty band (experimental k=2 coverage + GCI) is ±22%. Criterion satisfied at all points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH must be demonstrably linked to the clinical endpoint of hemolysis risk for CPB patients, supported by published literature.",
      "rationale": "NIH is the FDA-accepted metric for hemolysis characterization in blood-contacting devices (FDA guidance 2017). Published correlation between NIH and free plasma hemoglobin levels in CPB patients documented in three peer-reviewed references."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic pump geometry and span the operating envelope of the intended CPB use (2–6 L/min, 1 500–3 500 RPM).",
      "rationale": "All validation tests performed on the FDA generic centrifugal pump STL geometry. Five operating points span 2.5–5.5 L/min and 2 000–3 200 RPM, covering the CPB envelope. Geometry and fluid (bovine blood, 35% Hct) closely match intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 provided code verification is satisfied.",
      "rationale": "At Model Risk Level 2, explicit iterative solver error quantification beyond residual convergence monitoring is not mandated. Residuals converge to 1e-5 for all equations; this satisfies MRL 2 expectations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this device class.",
      "rationale": "MRL 2 does not require formal use-error analysis. Simulation workflow is executed by a single trained analyst following a documented simulation plan; peer review of setup files performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form uncertainty addressed qualitatively.",
      "rationale": "SST k-omega turbulence model selected based on published benchmarks for confined rotating flows. Formal model-form uncertainty quantification not required at MRL 2; qualitative justification documented in simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Blood viscosity modeled as Newtonian with mu = 0.0035 Pa·s (literature consensus for 35% Hct). Pump geometry from FDA-released STL. Formal input sensitivity analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 provided test conditions are documented.",
      "rationale": "Bench tests used fresh bovine blood within 24 h of collection; hematocrit adjusted to 35±2%. Sample variability not formally propagated at MRL 2; triplicate runs performed for each operating point."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of validation to COU parameters is sufficient.",
      "rationale": "Validation uses bovine blood as surrogate for human blood; published NIH correction factors applied. Pump geometry identical between validation and COU. Qualitative equivalency argument documented; formal quantitative mapping not required at MRL 2."
    }
  ],
