      "name": "FDA generic centrifugal pump hemolysis benchmark validation against experimental NIH data"
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-2024",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification for CPB flow regime"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4044675",
