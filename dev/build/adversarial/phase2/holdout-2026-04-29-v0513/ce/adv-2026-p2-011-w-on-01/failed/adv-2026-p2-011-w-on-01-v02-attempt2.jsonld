  "signature": "ed25519:7c4a2f1e8b5d3c9a6f0e2d1b4c7a5f8e3d6b9c2a5f8e1d4b7c0a3f6e9d2b5c8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must demonstrate documented version control, regression testing, and configuration management consistent with MRL 2 expectations.",
      "rationale": "ANSYS Fluent 2023 R1 used under ISO 9001-certified QMS. Regression test suite executed against 12 canonical benchmark cases; all pass within specified tolerances. Version control via Git with tagged release. Meets MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent benchmark comparison at MRL 2.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver confirming second-order spatial accuracy. Lid-driven cavity and backward-facing step benchmarks reproduced within 1% of reference solutions. Code verification complete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for primary QoI (hemolysis index) with GCI < 5% on the fine grid at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (coarse 4.2M, medium 8.7M, fine 17.1M elements). Richardson extrapolation yields GCI of 2.3% on fine mesh for normalized index of hemolysis. Achieved level exceeds requirement, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must be documented and traceable to the CPB operating envelope with measurement uncertainty reported.",
      "rationale": "FDA benchmark experimental data acquired at flow rates 2.5–7.5 L/min and rotational speeds 2000–3500 RPM. Inlet velocity profiles measured by PIV with ±3% uncertainty. Fluid temperature and viscosity controlled and reported. Conditions span the intended CPB operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bounds across the validation dataset.",
      "rationale": "Predicted normalized index of hemolysis compared against 18 experimental operating points. Mean absolute error 8.4%, within the combined uncertainty band of 12%. Bland-Altman analysis shows no systematic bias. Validation metric satisfies MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (hemolysis index, wall shear stress, exposure time) must be directly linked to the clinical decision criterion for worst-case hemolysis identification in CPB devices.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) per ASTM F1841, directly used in 510(k) substantial equivalence arguments. Secondary QoIs (scalar stress, residence time) are mechanistically coupled to red blood cell damage. Relevance to the CPB hemolysis decision criterion confirmed by clinical advisory review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted under conditions sufficiently similar to CPB clinical use to support extrapolation of credibility evidence to the intended operating envelope.",
      "rationale": "FDA generic centrifugal pump geometry and blood analog fluid (glycerol-water, matched viscosity) used in validation. Operating conditions overlap with CPB clinical range. Morphological similarity between validation and deployment geometry assessed via geometric fidelity metric > 0.92. Validation activities judged relevant to COU at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to at least 1e-5 for momentum and continuity equations is sufficient at MRL 2 without formal solver error quantification.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations. Factor scoped to not-assessed per MRL 2 assessment plan; residual monitoring documented in simulation log."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required provided simulation setup is performed by trained personnel following documented procedures.",
      "rationale": "Simulation setup performed by PhD-level CFD engineers following internal SOP-CFD-007. Peer review of setup parameters completed prior to production runs. Formal use error quantification not required at MRL 2 per assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty need not be formally quantified; selection of turbulence model and hemolysis power-law must be documented with literature justification.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for rotating machinery flows. Giersiepen-Wurzinger hemolysis power-law adopted per literature consensus. Model form selection documented in Model Description Document MDD-2024-03. Formal model form uncertainty quantification deferred per MRL 2 plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter values must be traceable to published literature or direct measurement; sensitivity analysis not required at MRL 2.",
      "rationale": "Blood analog fluid properties sourced from ASTM F1841 and manufacturer data sheets. Pump geometry derived from FDA-released CAD files. Material properties and boundary conditions tabulated in Simulation Input Record SIR-2024-07. Formal input uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, characterization of test sample variability is not required provided the validation experiment uses a controlled fluid analog with documented properties.",
      "rationale": "Validation experiments used a single batch of glycerol-water blood analog with viscosity verified at 3.5 cP ± 0.1 cP. Sample-to-sample variability analysis not required at MRL 2. Fluid characterization documented in Lab Report LR-2023-41."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment inputs and simulation inputs must be documented; formal equivalency metrics not required at MRL 2.",
      "rationale": "Simulation boundary conditions set to match experimental measurements within reported uncertainty. Reynolds number and flow coefficient matching documented in Validation Plan VP-2024-02. Formal equivalency index calculation not required at MRL 2 per assessment plan."
    }
  ],
