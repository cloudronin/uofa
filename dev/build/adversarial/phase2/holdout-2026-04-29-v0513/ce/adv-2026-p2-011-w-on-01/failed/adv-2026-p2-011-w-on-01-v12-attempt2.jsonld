  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-dr-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cva-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out at MRL 2 with documented justification. GCI of 2.3% and output comparison within ±11% across three operating points provide sufficient confidence that the CFD model can identify worst-case hemolysis conditions for the Class II CPB device. Assessment accepted for inclusion in 510(k) submission package.",
