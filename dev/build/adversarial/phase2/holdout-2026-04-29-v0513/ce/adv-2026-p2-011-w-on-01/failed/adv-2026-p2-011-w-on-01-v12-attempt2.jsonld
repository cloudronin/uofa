  "signature": "ed25519:b7d3e1f4a092c658d4b2e7f1a3c9d0e5b8f2a4c6d1e3f7b9a0c2d4e6f8b1a3c5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression test suite covering turbulent pipe flow and rotating machinery cases.",
      "rationale": "ANSYS Fluent 2022 R2 used under ISO 9001-certified QMS. Regression suite of 47 cases executed; all pass within tolerance. Version control via Git with signed release tags."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on manufactured solution must confirm second-order spatial convergence for momentum equations.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes equations. Observed order of accuracy 1.94 on structured hexahedral mesh, consistent with second-order finite-volume scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine mesh.",
      "rationale": "Three-mesh Richardson extrapolation performed (4.1 M, 9.8 M, 22.6 M cells). GCI on fine mesh is 2.3% for normalized index of hemolysis, exceeding the required threshold. Temporal convergence confirmed with CFL < 1 throughout."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainty quantification; inlet flow waveform must match CFD inlet profile within 3%.",
      "rationale": "FDA pump loop operated at 37 °C with bovine blood analogue (glycerol-water, matched viscosity). Inlet flow rate measured by Coriolis meter (±0.5%). Pressure taps calibrated to NIST traceable standard. Boundary condition fidelity confirmed within 1.8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must lie within experimental uncertainty band (±15%) across all three validation operating points.",
      "rationale": "Predicted normalized index of hemolysis: 0.0041, 0.0063, 0.0089 vs. measured 0.0038 ± 0.0006, 0.0061 ± 0.0009, 0.0094 ± 0.0014. All predictions within ±11% of mean measured value, satisfying acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must directly map to the device safety endpoint (hemolysis) specified in the regulatory submission.",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH) per ASTM F1841. Secondary QoIs are scalar shear stress exposure and residence time distribution, both directly linked to erythrocyte damage mechanisms referenced in the 510(k) predicate device literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry at operating conditions spanning the intended CPB flow range (3–6 L/min, 1500–3000 rpm).",
      "rationale": "All validation runs performed on the FDA benchmark centrifugal pump geometry identical to the submission model. Operating envelope covers 3–6 L/min at 1800–2800 rpm, fully bracketing the CPB clinical range. Fluid properties matched to human blood at 37 °C."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default level accepted.",
      "rationale": "At Model Risk Level 2, explicit solver error quantification beyond code verification is not mandated. Iterative convergence monitored to residual drop of 10^-6 for all equations; no solver-level error assessment beyond this is scoped for this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment not required at MRL 2. Simulation setup checklist and peer review of input deck provide baseline control against operator error without formal use-error quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "SST k-ω turbulence closure selected based on published benchmark comparisons for rotating machinery hemolysis. Formal model-form uncertainty quantification not required at MRL 2 but turbulence model sensitivity noted in the technical report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Nominal material properties (blood density 1060 kg/m³, viscosity 0.0035 Pa·s) used without propagation of input uncertainty. Sensitivity study on viscosity ±10% performed informally; impact on NIH is less than 4%. Full UQ not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Single test article used for all experimental runs. Sample-to-sample variability assessment not required at MRL 2. Pump geometry tolerance verified against CAD nominal within 0.05 mm."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Equivalency between in-vitro test fluid and clinical blood not formally assessed. Glycerol-water analogue matched dynamic viscosity at operating temperature; red blood cell deformability effects on hemolysis not modeled, consistent with MRL 2 scope."
    }
  ],
