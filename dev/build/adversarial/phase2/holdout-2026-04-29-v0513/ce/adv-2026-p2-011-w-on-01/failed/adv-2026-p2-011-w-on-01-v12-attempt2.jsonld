      "type": "ValidationResult",
      "name": "Hemolysis index comparison — CFD vs. bench measurement at 2500 rpm, 5 L/min"
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation against PIV data across three operating points"
    }
  ],
