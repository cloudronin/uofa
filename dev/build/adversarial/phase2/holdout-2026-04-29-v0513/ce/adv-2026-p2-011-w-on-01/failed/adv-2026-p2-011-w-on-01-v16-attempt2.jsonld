  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Intended use: pre-market submission support for identifying worst-case hemolysis operating points; population is adult patients receiving CPB support; clinical endpoint is plasma-free haemoglobin below 0.05 g/dL at device outlet under design-envelope flow rates 3–6 L/min and speeds 2000–4500 RPM.",
  "bindsRequirement": "https://uofa.net/morrison/req/hemolysis-worst-case-identification",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-cfd-credible-mrl2",
  "bindsModel": "https://uofa.net/morrison/model/fda-gcbp-hemolysis-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-gcbp-piv-experimental-2022",
    "https://uofa.net/morrison/data/fda-gcbp-hemolysis-bench-2022"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/pressure-rise-comparison",
      "type": "ValidationResult",
      "name": "Pressure-rise QoI comparison against FDA PIV benchmark data",
      "description": "Simulated total pressure rise compared against experimental PIV-derived values across 5 operating points. Mean absolute error 4.2%, within the 10% acceptance threshold for MRL 2."
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalised Index of Hemolysis comparison against bench measurements",
      "description": "Predicted NIH values compared against in-vitro bench measurements at three flow rates. All predictions within one standard deviation of measured values; acceptance criterion met."
    }
  ],
