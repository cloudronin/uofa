  "signature": "ed25519:7c3a1f9b2e5d8c4a0f6b3e9d2c7a1f4b8e0d5c2a9f6b3e0d7c4a1f8b5e2d9c6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation shall be under version control with documented QA procedures and regression test suite demonstrating numerical correctness.",
      "rationale": "ANSYS Fluent 2022R2 is employed under an ISO 9001-certified QA framework. Version control via Git, regression tests covering 47 canonical cases, all passing. QA documentation reviewed and approved by independent assessor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver shall demonstrate correct implementation of governing equations via method-of-manufactured-solutions (MMS) or equivalent benchmark problems with observed order of accuracy within 10% of formal order.",
      "rationale": "MMS study conducted for the incompressible Navier-Stokes solver confirms second-order spatial accuracy (observed 1.93 ± 0.04). Benchmark against lid-driven cavity (Re=1000) and backward-facing step (Re=800) shows < 1% deviation from published reference solutions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for primary QoI (pressure rise, NIH) shall be below 5% on the medium mesh used for production runs.",
      "rationale": "Three-level structured mesh refinement study performed (coarse 4.2 M, medium 11.7 M, fine 28.4 M cells). GCI for pressure rise: 1.8%; GCI for NIH: 3.1%. Both below 5% threshold. Asymptotic range confirmed (GCI ratio 1.03). Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation shall match simulation boundary conditions within stated uncertainty bounds; fluid properties shall be documented.",
      "rationale": "Bench experiments conducted at 37°C using porcine blood (haematocrit 35 ± 2%). Simulation inlet velocity profiles derived from PIV measurements. Fluid viscosity and density matched to measured values. Temperature deviation < 0.5°C across test duration. Boundary condition correspondence confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation metric V) shall be computed for all primary QoI; metric shall meet or exceed required level threshold.",
      "rationale": "Relative error E_rel computed for pressure rise (mean 4.2%, max 7.1%) and NIH (mean 6.8%, max 9.3%). Both within the MRL 2 acceptance threshold of 10%. Validation metric V computed per ASME V&V 20; all operating points within experimental uncertainty band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI selected for validation shall be directly linked to the clinical endpoint of hemolysis risk; linkage shall be documented.",
      "rationale": "Primary QoI are total pressure rise (pump performance) and NIH (hemolysis index). NIH is directly linked to plasma-free haemoglobin, the clinical endpoint. Pressure rise governs operating point selection. Linkage documented in QoI traceability matrix referencing ASTM F1841 hemolysis standard."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments shall cover the operating envelope defined in the intended use statement; extrapolation beyond validated range shall be documented and justified.",
      "rationale": "Validation experiments span flow rates 3–6 L/min and rotational speeds 2000–4500 RPM, fully covering the CPB operating envelope. No extrapolation required. Geometric fidelity: FDA generic centrifugal pump geometry used in both simulation and experiment. Relevance rating: high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; iterative convergence residuals monitored as proxy.",
      "rationale": "At MRL 2, formal numerical solver error quantification is not required. Residuals for continuity, momentum, and turbulence quantities monitored to < 1e-5 for all production runs. No divergence events observed. Deferred to higher MRL assessment if risk level is escalated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation inputs reviewed by independent analyst as minimum control.",
      "rationale": "Formal use-error analysis not required at MRL 2. Independent analyst reviewed boundary condition setup, mesh topology, and solver settings prior to production runs. No discrepancies identified. Escalation to formal use-error FMEA deferred to MRL 3 if device advances to Class III."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection documented with literature justification.",
      "rationale": "SST k-ω turbulence model selected based on published literature demonstrating superior performance for rotating machinery with adverse pressure gradients. Hemolysis power-law model (Giersiepen et al.) adopted per FDA guidance. Formal model-form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values documented with sources.",
      "rationale": "All model inputs (fluid density, viscosity, haematocrit, pump geometry dimensions) documented in simulation input deck with sources cited. Sensitivity to ± 5% variation in viscosity assessed informally; NIH change < 2%. Formal probabilistic input uncertainty analysis deferred to MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; sample provenance and preparation protocol documented.",
      "rationale": "Porcine blood samples sourced from single abattoir batch, anticoagulated with heparin (10 IU/mL), haematocrit adjusted to 35 ± 2% by centrifugation. Sample characterisation (viscometry, osmolality) documented. Inter-batch variability analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters shall be demonstrably equivalent to experimental conditions; any deviations shall be quantified and shown to have negligible effect on QoI.",
      "rationale": "Inlet velocity profiles extracted from PIV data and applied directly as CFD boundary conditions. Rotational speed set to experimentally measured values ± 5 RPM. Wall roughness set to manufacturer-specified surface finish Ra 0.8 μm. Deviation analysis: substitution of time-averaged for phase-resolved inlet profile introduces < 1.5% error in NIH, deemed negligible."
    }
