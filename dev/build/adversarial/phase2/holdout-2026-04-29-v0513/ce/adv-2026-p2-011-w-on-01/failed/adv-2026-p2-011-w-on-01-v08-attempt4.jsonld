  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QMS covering version control, regression testing, and release validation for CFD codes used in cardiovascular device simulation.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO 9001-certified QMS. Version control and regression test suite documentation were reviewed and found compliant with MRL 2 requirements. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate order-of-accuracy verification via method of manufactured solutions (MMS) or equivalent for the governing equations active in the CPB hemolysis model.",
      "rationale": "ANSYS Fluent passes published MMS benchmarks for incompressible Navier-Stokes at second-order spatial accuracy. Vendor verification report V-2022R2-NS-MMS cited and archived. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for primary QoI (NIH) and must not exceed 5% on the fine-grid solution used for regulatory submission.",
      "rationale": "Three-level Richardson extrapolation performed on structured hexahedral meshes of 2.1 M, 6.8 M, and 18.4 M cells. GCI on NIH = 2.3% (fine grid). Achieved level 3 exceeds required level 2, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, hematocrit) must be documented with measurement uncertainty and replicated in simulation boundary conditions within stated tolerances.",
      "rationale": "FDA GCBP bench test conditions documented per ASTM F1841. Inlet flow rate controlled to ±0.05 L/min; outlet pressure to ±2 mmHg. Simulation BCs set to nominal measured values; sensitivity to BC uncertainty evaluated. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric E or NRMSE) must be computed for NIH across all six validation operating points; systematic bias must be characterised.",
      "rationale": "NRMSE across six operating points = 8.4% for NIH. Bland-Altman analysis shows mean bias of +0.6 mg/100 L with limits of agreement within clinically acceptable range. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH and shear-stress exposure histogram) must be directly linked to the clinical harm pathway (red blood cell lysis leading to haemoglobinaemia) and accepted by the regulatory submission plan.",
      "rationale": "NIH is the FDA-accepted metric for hemolysis in blood-contacting devices (FDA Guidance 2017). Shear-stress exposure histogram supports mechanistic interpretation. Both QoIs are explicitly listed in the pre-submission agreement. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the CPB operating envelope (3–6 L/min, 100–300 mmHg) with at least four distinct operating points; fluid analogue must match in-vivo blood rheology within documented tolerance.",
      "rationale": "Six operating points span the CPB envelope. Bovine blood at 35% hematocrit used as analogue; viscosity matched to within 4% of human blood at 37°C per ASTM F1841 annex. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; solver iterative convergence monitored via residual drop of six orders of magnitude as proxy.",
      "rationale": "At MRL 2, formal iterative error quantification beyond residual monitoring is not required. Residuals dropped below 1e-6 for all equations at all operating points. Factor scoped to level 1 by MRL 2 matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; analyst training records reviewed as proxy control.",
      "rationale": "MRL 2 does not require formal use-error analysis. Lead analyst holds ANSYS CFD certification; simulation setup reviewed by independent senior analyst. Factor accepted at level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; model form selection (SST k-omega turbulence, Giersiepen-Wurzinger hemolysis power law) justified by literature survey.",
      "rationale": "SST k-omega selected based on published cardiovascular device benchmark studies (Stewart et al. 2012, Hariharan et al. 2011). Hemolysis power law parameters from Giersiepen 1990 calibrated to bovine blood. Formal model-form uncertainty quantification deferred to MRL 3. Accepted at level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; nominal material property values and geometric dimensions sourced from FDA GCBP specification document.",
      "rationale": "Fluid density, viscosity, and pump geometry taken from FDA GCBP public dataset (FDA 2012). Sensitivity to ±5% property variation evaluated informally; NIH response within 3%. Formal UQ deferred. Accepted at level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; single pump unit used for all validation experiments, consistent with FDA GCBP benchmark protocol.",
      "rationale": "FDA GCBP benchmark protocol specifies single-unit testing; inter-unit variability not characterised at this MRL. Sample representativeness accepted as sufficient for MRL 2 screening purpose. Factor accepted at level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; correspondence between simulation input parameters and experimental conditions verified by tabular comparison in validation report.",
      "rationale": "Tabular comparison of simulation BCs versus measured experimental conditions provided in validation report Appendix B. Maximum parameter deviation 2.1%. Formal equivalency metric not required at MRL 2. Accepted at level 1."
