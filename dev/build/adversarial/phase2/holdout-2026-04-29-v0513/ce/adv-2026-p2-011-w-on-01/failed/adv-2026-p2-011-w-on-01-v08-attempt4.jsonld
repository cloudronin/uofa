  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are accepted at level 1 consistent with MRL 2 matrix provisions. Discretization error achieved level 3, exceeding the required level 2 and providing additional confidence in numerical accuracy. NRMSE of 8.4% on NIH across the CPB operating envelope is within the pre-specified acceptance threshold. The model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II FDA generic centrifugal blood pump in the cardiopulmonary bypass application.",
