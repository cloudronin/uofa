      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values documented in simulation plan with literature sources.",
      "rationale": "Fluid density (1056 kg/m³), dynamic viscosity (0.0035 Pa·s), and power-law hemolysis constants sourced from peer-reviewed literature. Sensitivity analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization documented in FDA dataset provenance record.",
      "rationale": "FDA dataset provenance confirms blood analogue preparation protocol. Statistical characterization of sample variability not required at MRL 2. Factor recorded as not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
