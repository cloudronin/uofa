  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control and regression testing records.",
      "rationale": "ANSYS Fluent 2023 R1 was used under an ISO 9001-compliant QA framework. Version control logs, regression test suite results, and release notes were reviewed. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent benchmark tests.",
      "rationale": "Benchmark verification against the lid-driven cavity and Poiseuille flow analytical solutions confirmed correct implementation of the Navier-Stokes solver. Residual norms converged to below 1e-6 in all cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate that discretization error in the hemolysis index QoI is below 5% using Richardson extrapolation.",
      "rationale": "Three-level mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.2M cells) performed. Richardson extrapolation yielded GCI of 1.8% for hemolysis index at the design-point flow condition, exceeding the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must be documented with measurement uncertainty quantification and must span the operating envelope relevant to CPB use.",
      "rationale": "FDA experimental dataset documents inlet flow rates (2–8 L/min), rotational speeds (1500–3500 RPM), and fluid properties. Measurement uncertainties reported at 95% confidence. Operating envelope covers the CPB range of interest as described in the assessment narrative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bounds at all validation points.",
      "rationale": "At all five validation operating points, predicted normalized index of hemolysis (NIH) values fall within the expanded uncertainty band (k=2). Maximum discrepancy is 3.4%, within the 8% acceptance threshold established for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, wall shear stress) must be directly linked to the clinical endpoint of hemolysis risk in CPB device operation.",
      "rationale": "NIH is the regulatory-accepted metric for hemolysis quantification per FDA guidance. Wall shear stress is the primary mechanical driver of red blood cell damage in the Giersiepen-Wurzinger power-law model used. Both QoIs are directly relevant to the intended assessment scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid analogue, and operating range as the intended computational use.",
      "rationale": "Validation used the FDA generic centrifugal blood pump geometry with a glycerol-water blood analogue (viscosity matched to whole blood at 37°C). Operating conditions span the CPB range. Geometric fidelity confirmed by CAD comparison. Validation activities are judged sufficiently relevant to the assessment scope described in the claim narrative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; basic iterative convergence monitoring is sufficient.",
      "rationale": "At MRL 2, full numerical solver error quantification beyond residual monitoring is not required. Residuals confirmed below solver tolerance thresholds. Factor scoped to not-assessed per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records reviewed as a proxy.",
      "rationale": "Formal use error analysis not required at MRL 2. Analyst team holds documented CFD training credentials. Factor recorded as not-assessed per MRL 2 scoping decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection is documented in the simulation plan.",
      "rationale": "The k-omega SST turbulence model and Giersiepen-Wurzinger hemolysis model were selected based on published literature benchmarks. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
