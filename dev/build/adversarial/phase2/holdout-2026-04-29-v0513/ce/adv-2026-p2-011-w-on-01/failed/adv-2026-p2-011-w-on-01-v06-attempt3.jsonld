  "signature": "ed25519:7b2e4f1a9c3d6e8b0f5a2c7d4e1b9f3a6c8d2e5b7f0a4c9d1e3b6f8a2c5d7e9b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold a documented quality management certification and version-controlled source with regression test suite passing at MRL 2 threshold.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO 9001-certified QMS. Regression test suite (847 cases) passes with zero critical failures. Version control via Git with tagged release 22.2.0 confirmed. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via manufactured solution or benchmark comparison with documented error norms at MRL 2.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes solver confirms second-order spatial convergence (L2 norm error 1.4e-4 at finest grid). Benchmark comparison against FDA nozzle canonical case shows velocity agreement within 3.2% of published DNS data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be less than 5% at the operating points of interest, demonstrating discretization error is acceptably small relative to model uncertainty.",
      "rationale": "Three-level Richardson extrapolation performed on 4.2M, 11.7M, and 28.4M cell meshes. GCI for normalized index of hemolysis at worst-case operating point is 2.1%, well below the 5% acceptance threshold. Achieved level 3 exceeds required level 2, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used in validation testing must be documented with measurement uncertainty and must correspond to the simulated operating envelope.",
      "rationale": "Bench test conducted at 3, 4.5, and 6 L/min flow rates with inlet pressure 10±0.5 mmHg, outlet pressure 80±1.2 mmHg, and fluid temperature 37±0.3°C. Bovine blood with hematocrit 30±2% used. All boundary conditions replicated in CFD inlet/outlet patches with matching uncertainty bounds documented in test report TR-2023-047."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must agree with experimental measurements within combined simulation and experimental uncertainty at all three validation operating points.",
      "rationale": "NIH values predicted within 8.4% of experimental mean at 3 L/min, 6.1% at 4.5 L/min, and 11.2% at 6 L/min. All differences fall within the combined uncertainty band (experimental U95=12.3%, simulation U95=9.8%). Comparison metric V=0.87 satisfies MRL 2 threshold of V≥0.75."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, wall shear stress distribution, scalar stress exposure) must be directly linked to the clinical decision quantity (worst-case hemolysis operating point identification).",
      "rationale": "Normalized index of hemolysis is the primary regulatory metric per FDA guidance for CPB devices. Scalar stress exposure (Lagrangian particle tracking) is the mechanistic precursor to erythrocyte damage. Both QoIs are directly traceable to the decision question of worst-case operating condition identification. Linkage documented in QoI traceability matrix QTM-2023-001."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid properties, and operating envelope as the intended COU, with documented similarity analysis.",
      "rationale": "Validation performed on the identical FDA generic centrifugal pump CAD geometry used in the submission model. Bovine blood at 37°C with hematocrit 30% is an accepted analog for human blood in hemolysis studies per ASTM F1841. Operating range 3–6 L/min encompasses the full CPB clinical envelope. Similarity analysis documented in report SA-2023-012."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit round-off and iterative convergence error quantification beyond standard residual monitoring is not required; residuals below 1e-5 are sufficient.",
      "rationale": "Solver iterative residuals converged to 1e-6 for all equations. Round-off error analysis not performed as it is not required at MRL 2 for this factor. Standard convergence monitoring sufficient per ASME V&V 40 Table 5 for the assigned risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis is not required at MRL 2; standard simulation setup review and peer check are sufficient.",
      "rationale": "Simulation setup reviewed by independent senior analyst (peer check completed 2023-11-14). Formal human factors use error analysis is scoped out at MRL 2 per ASME V&V 40 Table 5 guidance. No anomalies identified during peer review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit model form uncertainty quantification is not required; selection of standard turbulence and hemolysis constitutive models with literature justification is sufficient.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for rotating machinery flows. Giersiepen-Wurzinger hemolysis power-law model applied with published coefficients. Model form uncertainty not formally quantified as not required at MRL 2; literature-based justification provided in modeling report MR-2023-005."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a sensitivity analysis identifying dominant input parameters is sufficient; full probabilistic uncertainty propagation is not required.",
      "rationale": "One-at-a-time sensitivity analysis performed for viscosity, density, and hematocrit. Hemolysis index sensitivity to ±10% variation in viscosity is 4.3%, confirming low sensitivity. Full UQ propagation not required at MRL 2. Sensitivity results documented in report SA-2023-015."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of sample source, preparation protocol, and basic characterization is sufficient; statistical population analysis is not required.",
      "rationale": "Bovine blood samples sourced from single certified supplier (lot BV-2023-114), anticoagulated with CPDA-1, hematocrit adjusted to 30±2% by centrifugation. Sample characterization documented in lab notebook LN-2023-089. Statistical population analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative similarity argument between validation test inputs and COU inputs is sufficient; formal equivalency mapping is not required.",
      "rationale": "Validation test inputs (geometry, flow rates, fluid properties) are qualitatively equivalent to COU inputs for the FDA generic pump at CPB operating conditions. Formal quantitative equivalency mapping is not required at MRL 2. Qualitative similarity argument documented in report SA-2023-012 Section 4."
    }
  ],
