      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index prediction within 15% of experimental mean across all validation operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) agreed with bench measurements within 11% at all six validation operating points, meeting the 15% acceptance criterion."
    },
    {
