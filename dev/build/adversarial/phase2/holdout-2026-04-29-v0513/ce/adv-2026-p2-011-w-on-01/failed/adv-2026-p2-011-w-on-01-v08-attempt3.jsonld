      "acceptanceCriteria": "Solver version-controlled, regression tests passing, documented release notes for ANSYS Fluent 2022R2.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with documented QA procedures. Version control and regression test logs were reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical pipe flow demonstrates expected second-order spatial convergence.",
      "rationale": "Code verification via manufactured solution on a straight pipe geometry confirmed second-order convergence in velocity and pressure norms, consistent with the discretization scheme employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI less than 5% across three systematically refined meshes.",
      "rationale": "Three-mesh Richardson extrapolation yielded GCI of 3.2% for the hemolysis index at the worst-case operating point (3500 RPM, 3 L/min), satisfying the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) documented and traceable to calibrated instrumentation.",
      "rationale": "FDA pump bench test records confirm calibrated flow meters (±1% FS), torque sensors, and temperature-controlled blood analog fluid. Conditions span the CPB operating envelope relevant to the COU."
    },
    {
