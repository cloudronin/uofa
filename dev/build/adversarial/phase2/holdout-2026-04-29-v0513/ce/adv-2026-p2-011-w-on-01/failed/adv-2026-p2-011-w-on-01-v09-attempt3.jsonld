  "signature": "ed25519:b1c3e5a7f9d2b4c6e8a0f2d4b6c8e0a2f4b6d8c0e2a4f6b8d0c2e4a6b8f0d2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under documented version control with regression test suite passing at release; configuration management records available for audit.",
      "rationale": "ANSYS Fluent 2023 R1 was used under ISO 9001-certified QMS. Version control logs, regression test reports, and change-control records were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code must pass at least one published benchmark with documented order-of-accuracy confirmation for the governing equations relevant to the COU.",
      "rationale": "Fluent's pressure-based coupled solver was verified against the Taylor-Green vortex and lid-driven cavity benchmarks. Second-order spatial accuracy confirmed via Richardson extrapolation on three systematically refined grids."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for the primary QoI (hemolysis index) must be less than 5% on the production mesh.",
      "rationale": "GCI study performed on coarse, medium, and fine meshes (3.2 M, 8.7 M, and 22.1 M cells). GCI for normalised hemolysis index on the medium mesh is 2.8%, exceeding the required level. Production runs use the medium mesh as a balance of accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be documented with measurement uncertainty and replicated in the simulation setup.",
      "rationale": "FDA bench-test data provided inlet flow rates of 2.5 and 5 L/min at 2500 and 3500 RPM. Temperature (37 °C) and hematocrit (40%) were controlled and documented. Simulation boundary conditions match within stated measurement uncertainty bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental values within combined simulation and experimental uncertainty at all five validation operating points.",
      "rationale": "Predicted normalised index of hemolysis (NIH) values at five operating points fall within ±15% of experimental means, which is within the combined expanded uncertainty (U95). Validation metric confirms adequate predictive accuracy for worst-case identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) must be the same metric used in the regulatory submission and directly linked to the clinical endpoint of red blood cell damage.",
      "rationale": "NIH is the standard FDA-accepted metric for hemolysis in CPB devices and is directly computed from the simulation's shear-stress and exposure-time fields. The validation QoI is identical to the submission QoI, ensuring direct relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the intended operating envelope (flow rate 2–6 L/min, speed 2000–4000 RPM) and use the same pump geometry as the submission model.",
      "rationale": "All validation tests were conducted on the FDA generic centrifugal pump geometry using the same CAD file as the submission CFD model. Operating points span the intended clinical envelope, confirming relevance of validation evidence to the CPB use context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; iterative convergence to residuals below 1e-5 is documented as a proxy indicator.",
      "rationale": "At MRL 2 a full solver-error budget is not required. Residual convergence to 1e-6 for continuity, momentum, and k-omega equations was confirmed in all production runs, providing adequate confidence that iterative error is negligible relative to discretization error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation setup reviewed by a second qualified engineer as a minimum control.",
      "rationale": "An independent peer review of the simulation setup, boundary condition assignments, and post-processing scripts was completed by a senior CFD engineer not involved in the original analysis. No setup errors were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; choice of turbulence and hemolysis sub-models documented with literature justification.",
      "rationale": "The SST k-omega turbulence model and the Giersiepen-Wurzinger power-law hemolysis model were selected based on published FDA inter-laboratory study recommendations. Model-form uncertainty is acknowledged but not formally quantified at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values sourced from peer-reviewed literature and FDA guidance with traceability documented.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hemolysis model constants were taken from ASTM F1841 and published FDA pump studies. Input traceability table provided in the simulation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; experimental sample provenance documented by the testing laboratory.",
      "rationale": "Porcine blood samples used in the FDA bench tests were prepared per ASTM F1841 with hematocrit adjusted to 40 ± 2%. Sample preparation records are held by the testing laboratory and referenced in the validation data package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; qualitative mapping between experimental and simulation input parameters provided.",
      "rationale": "A parameter equivalency table mapping each experimental control variable to its simulation counterpart was prepared and reviewed. No material discrepancies between physical and computational input parameters were identified."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are explicitly scoped out per ASME V&V 40 Table 4 at MRL 2 and are supported by documented proxy controls. Validation evidence demonstrates that the CFD model can reliably identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump within the CPB clinical envelope. The overall credibility body is judged sufficient to support a Class II 510(k) submission.",
