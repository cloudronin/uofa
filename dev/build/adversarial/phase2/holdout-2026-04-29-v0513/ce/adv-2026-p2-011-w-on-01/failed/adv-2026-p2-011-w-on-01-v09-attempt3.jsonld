      "name": "CFD vs. experimental hemolysis index comparison across five operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-2024",
      "type": "ValidationResult",
      "name": "Grid-convergence index study for FDA centrifugal pump geometry"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4050888",
