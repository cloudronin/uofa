  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This UoA evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Intended use is bounded by CPB flow rates 3–6 L/min, rotational speeds 2000–3500 RPM, blood analogue viscosity 0.0035 Pa·s, and haematocrit 35–45%. The decision scope, device class, and operating envelope are described in the Claim and Requirement nodes bound below.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-piv-dataset",
    "https://uofa.net/morrison/data/fda-pump-hemolysis-experimental"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic centrifugal pump"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalised index of haemolysis comparison across five operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034823",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b7d09e5f6a8c1d3b2e4f7a9c0d1e2f3b4c5d6e7f8a9b0c1d2e3f4a5b",
  "signature": "ed25519:9b2d4f6a8c0e1f3b5d7a9c2e4f6b8d0a1c3e5f7b9d1a3c5e7f9b1d3a5c7e9f1b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD analysis must be under version control with documented regression tests and release notes.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially validated solver with ISO 9001-certified QA processes. Version control records and regression test suite documentation were reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions.",
      "rationale": "Lid-driven cavity and Poiseuille flow benchmarks were executed; L2 norm errors were below 0.5% for velocity and pressure fields, confirming correct discretisation of the Navier-Stokes equations at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and must not exceed 5% for primary quantities of interest.",
      "rationale": "Three-level mesh refinement study conducted on the FDA pump geometry (1.2 M, 4.8 M, 19.2 M cells). GCI for normalised index of haemolysis was 2.1% between medium and fine meshes. Medium mesh selected for production runs, exceeding MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be replicated in simulation within stated measurement uncertainty bands.",
      "rationale": "Inlet flow rates and rotational speeds from the FDA inter-laboratory study were imposed as simulation boundary conditions. Deviations in imposed conditions were less than 1.5% of measured values, within reported experimental uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoIs must agree with experimental measurements within two standard deviations of inter-laboratory experimental scatter.",
      "rationale": "Predicted NIH values across five operating points fell within 1.8 standard deviations of the FDA inter-laboratory experimental mean. Velocity field comparison with PIV data showed mean absolute error of 4.3% of maximum measured velocity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the clinical decision variable (worst-case haemolysis operating point).",
      "rationale": "Normalised index of haemolysis and shear stress exposure time are the primary clinical risk indicators for CPB device haemolysis. Both QoIs are directly traceable to the decision requirement and are computed and compared in this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid properties, and operating envelope as the intended COU.",
      "rationale": "Validation employed the FDA generic centrifugal blood pump geometry with glycerol-water blood analogue (viscosity 0.0035 Pa·s) at CPB-representative flow rates. Geometry, fluid, and operating conditions are directly representative of the intended submission use case."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; commercial solver certification is accepted as surrogate.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond code verification is not mandated. The commercial solver's certified test suite is accepted as sufficient evidence. Formal assessment deferred consistent with MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification records accepted as surrogate control.",
      "rationale": "Use error formal assessment is not required at MRL 2. Analysts hold documented CFD competency qualifications. Simulation setup was peer-reviewed internally prior to production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; turbulence model selection rationale documented in simulation report.",
      "rationale": "SST k-ω turbulence model selection is justified by prior literature for rotating blood-contacting devices. Formal model-form uncertainty quantification is beyond MRL 2 scope and is not required for this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal material properties from peer-reviewed sources are accepted.",
      "rationale": "Blood analogue rheological properties sourced from FDA-published inter-laboratory study documentation. Sensitivity to input uncertainty is not formally required at MRL 2 and has not been conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA inter-laboratory dataset sample characterisation is accepted.",
      "rationale": "Experimental samples from the FDA inter-laboratory study are well-characterised in the published dataset. Independent sample qualification is not required at MRL 2 for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of experimental to simulation inputs is accepted.",
      "rationale": "A qualitative equivalency table mapping experimental measurement conditions to simulation input parameters was prepared and reviewed. Formal equivalency quantification is not required at MRL 2."
    }
  ],
