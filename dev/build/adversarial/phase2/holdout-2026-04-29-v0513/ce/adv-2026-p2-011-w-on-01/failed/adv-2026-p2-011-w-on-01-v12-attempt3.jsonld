  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors met or exceeded required levels for MRL 2. Six factors were appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 4 guidance. The CFD model is judged credible for identifying worst-case haemolysis operating conditions for the Class II FDA generic centrifugal blood pump under CPB conditions as described in the bound Claim and Requirement nodes.",
