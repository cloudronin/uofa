  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Structured as a Minimal-profile UnitOfAssurance; intended-use scope is described in the bound Requirement and Claim nodes.",
  "bindsRequirement": "https://uofa.net/morrison/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/morrison/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/morrison/model/fda-centrifugal-pump-cfd-v2",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-piv-experimental",
    "https://uofa.net/morrison/data/fda-pump-hemolysis-bench"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-qi-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index QoI comparison against FDA PIV benchmark data at five operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-rise-comparison",
      "type": "ValidationResult",
      "name": "Pump pressure rise validation against experimental measurements across CPB flow range"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-lab-uofa",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1d09b4856f1a2c3d4e5f67890abcdef1234567890abcdef1234567890",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan consistent with MRL 2 requirements, including version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 is used under a documented SQA plan. Version control, regression test suite, and release notes are archived. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent benchmark comparisons.",
      "rationale": "Published benchmark comparisons for the Navier-Stokes solver are available in the ANSYS verification manual. MMS studies for the scalar hemolysis transport equation were performed internally and archived. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Spatial and temporal discretization error must be estimated using systematic mesh and time-step refinement studies with at least three refinement levels.",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry (coarse 4.2 M, medium 11.7 M, fine 31.4 M cells). Richardson extrapolation applied; GCI for hemolysis index QoI is 3.1% on medium mesh selected for production runs. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to allow reproduction and comparison with simulation boundary conditions.",
      "rationale": "FDA PIV experimental conditions are fully documented in Hariharan et al. (2011). Flow rates, rotational speeds, fluid properties, and inlet/outlet conditions are reproduced in simulation boundary conditions. Uncertainty in experimental measurements reported and propagated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively to experimental data using appropriate validation metrics that account for both numerical and experimental uncertainty.",
      "rationale": "Velocity field comparisons performed at five cross-sections using area-weighted RMS error metrics. Hemolysis index predictions compared to bench measurements at three operating points. Validation metric within acceptance band accounting for combined uncertainties."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation must be directly relevant to the clinical decision quantity — identification of worst-case hemolysis operating conditions for the CPB device.",
      "rationale": "Hemolysis index and shear stress exposure time are the primary QoIs, directly linked to the clinical decision of identifying worst-case operating conditions. Velocity field serves as a secondary QoI supporting model fidelity confidence. Relevance mapping documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must reflect CPB operating conditions including clinically relevant flow rates (3–6 L/min) and rotational speeds representative of the intended use envelope.",
      "rationale": "Validation experiments span 2.5–6 L/min flow rates and 2500–3500 RPM, covering the CPB operating envelope. Fluid properties match blood analog used in FDA study. Validation domain overlap with intended use domain assessed as adequate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "For MRL 2, iterative solver convergence monitoring to residual thresholds of 1e-5 is sufficient without formal error quantification.",
      "rationale": "Solver convergence monitored via residual histories; all simulations converged to 1e-5 for continuity and momentum. Formal numerical solver error quantification not required at MRL 2 and not performed. Factor scoped per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, user error assessment requires only that simulation setup is reviewed by a second qualified analyst.",
      "rationale": "Simulation setup reviewed by second CFD analyst on the team. Formal use-error quantification not required at MRL 2. Independent review checklist completed and archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty assessment requires documentation of turbulence model selection rationale; formal model-form uncertainty quantification is not required.",
      "rationale": "SST k-omega turbulence model selected based on published sensitivity studies for rotary blood pump flows. Model form uncertainty not formally quantified; selection rationale documented. Not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model input uncertainty requires identification and documentation of key uncertain inputs; formal UQ propagation is not required.",
      "rationale": "Key uncertain inputs identified: blood viscosity, hemolysis model constants (C, alpha, beta), and pump geometry tolerances. Nominal values documented with literature sources. Formal UQ propagation not performed; acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, test sample characterization requires documentation of experimental sample properties; statistical sample-to-sample variability analysis is not required.",
      "rationale": "FDA benchmark uses glycerin-water blood analog; properties documented. Hemolysis bench tests used porcine blood with documented hematocrit and temperature. Sample variability not statistically characterized; acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be shown to be equivalent or conservatively bounding relative to experimental conditions used for validation, with documented mapping.",
      "rationale": "Boundary condition mapping table prepared showing correspondence between experimental measurements and simulation inputs for all five validation operating points. Reynolds number similarity confirmed. Geometric fidelity of CAD model to test article verified via coordinate measurement data. Equivalency established at required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors appropriately scoped as not-assessed per the MRL 2 assessment plan. The CFD hemolysis model is judged credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in cardiopulmonary bypass service. Decision accepted by the credibility assessment team and submitted to regulatory file.",
