  "signature": "ed25519:9b2e4a7f1c3d5e8b0a6f2c4d7e1b3a5f8c0d2e4a6b8c0d2e4f6a8b0c2d4e6f8a",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented test suite covering incompressible Navier-Stokes and scalar transport kernels.",
      "rationale": "ANSYS Fluent 2022R2 is used under ISO 9001-certified QMS. Release notes, regression test reports, and change logs are archived. All relevant solver modules passed vendor-supplied verification suite at the version in use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent order-of-accuracy test demonstrating expected spatial convergence rate for the governing equations.",
      "rationale": "Order-of-accuracy study on a canonical pipe-flow MMS problem confirms second-order spatial convergence for velocity and scalar (hemolysis power-law) fields, consistent with the finite-volume discretization scheme employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for primary QoI (NIH) with GCI < 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study (4.2 M, 11.6 M, 28.9 M cells) yields GCI of 2.1% for normalized index of hemolysis on the fine grid, exceeding the required level. Mesh topology is polyhedral with prismatic boundary layers resolving y+ < 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented with measurement uncertainty and traceable to NIST standards.",
      "rationale": "FDA interlaboratory dataset provides pump inlet/outlet pressures, flow rates (±0.5% FS), and fluid viscosity (bovine blood analog) measured with NIST-traceable instruments. Operating points span 2500–3500 RPM at 2.5 and 5 L/min, covering the CPB clinical range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty Uval) computed for all primary QoIs; agreement within combined experimental and numerical uncertainty bands.",
      "rationale": "Pressure head error E% = 3.8% and NIH prediction falls within experimental uncertainty band (±1 SD) for 5 of 6 operating points. Validation uncertainty Uval computed per ASME V&V 20 and reported in the validation summary report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, pressure head) are the same or directly traceable to QoIs required by the clinical decision (worst-case hemolysis identification).",
      "rationale": "The normalized index of hemolysis is the regulatory QoI for CPB device assessment. Pressure head is a secondary QoI confirming global fluid dynamics fidelity. Both are measured in validation experiments and directly support the worst-case identification decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions are representative of the COU device and intended operating envelope as documented in the governing requirement.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry — the same geometry as the COU device — with bovine blood analog at hematocrit 35%, representative of CPB priming conditions. Operating points bracket the intended 2–6 L/min CPB range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver iterative convergence monitored via residual drop of 10^-5 as a proxy.",
      "rationale": "At Model Risk Level 2, explicit numerical solver error quantification beyond residual monitoring is not required. Residuals for all equations drop below 10^-5 within 2000 iterations; mass imbalance < 0.01%. Scoped out per MRL 2 requirements table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation setup reviewed by a second analyst as a procedural control.",
      "rationale": "At MRL 2, formal use-error quantification is not required. A peer review of boundary condition setup, material property assignments, and post-processing scripts was conducted by a senior analyst independent of the primary modeler."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection justified by literature precedent for similar rotating machinery flows.",
      "rationale": "SST k-omega turbulence closure is selected based on published benchmarks for centrifugal blood pump CFD (Hariharan et al. 2011, Good et al. 2016). Formal model-form uncertainty quantification is scoped out at MRL 2 per the credibility assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values used with documented sources for all material and geometric parameters.",
      "rationale": "Fluid viscosity, density, and Giersiepen hemolysis model constants are taken from published literature with nominal values. Sensitivity to input uncertainty is not formally quantified at MRL 2 but is noted as a future work item."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; sample-to-sample variability in experimental data acknowledged and addressed through use of multi-laboratory dataset.",
      "rationale": "The FDA interlaboratory study aggregates results from five independent laboratories, providing implicit characterization of sample variability. Formal statistical sample-size analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions demonstrably match experimental test conditions within stated measurement uncertainty for all primary inputs.",
      "rationale": "Inlet flow rate, rotational speed, and outlet pressure boundary conditions in the CFD model are set to the experimentally measured values with deviations less than 0.3% for flow rate and 0.1 RPM for speed. Fluid temperature held at 22°C matching laboratory conditions. Equivalency confirmed by the test conditions report."
    }
  ],
