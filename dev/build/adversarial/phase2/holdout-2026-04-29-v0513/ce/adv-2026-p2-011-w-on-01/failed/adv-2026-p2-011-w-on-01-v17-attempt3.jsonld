      "type": "ValidationResult",
      "name": "PIV velocity field comparison at three operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalised index of haemolysis comparison against experimental measurements"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
