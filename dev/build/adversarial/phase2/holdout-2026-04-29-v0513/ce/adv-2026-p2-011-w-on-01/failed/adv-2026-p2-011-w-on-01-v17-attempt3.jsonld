  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression test suite covering turbulence and scalar-transport modules.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated QMS; regression tests covering k-omega SST and species-transport modules are documented and pass at the required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks must confirm second-order spatial convergence.",
      "rationale": "Method-of-manufactured-solutions tests on a rotating-cylinder benchmark confirm second-order spatial accuracy for the momentum and scalar equations; results archived in the project V&V log."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation GCI must be below 5 % on the normalised index of haemolysis QoI for the three principal operating points.",
      "rationale": "Three-level mesh refinement study yields GCI values of 2.1 %, 1.8 %, and 2.6 % for the 2500/3500/4500 RPM operating points, exceeding the required level and providing a margin against discretization-driven bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature) must be reproduced in the simulation within ±5 % of measured values.",
      "rationale": "CFD inlet flow rates and RPM settings are matched to the experimental test rig within 2 %; temperature-dependent viscosity is applied using the Walburn–Schneck model calibrated to the test fluid."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must fall within two experimental standard deviations across all validation operating points.",
      "rationale": "Predicted NIH values agree with measured data within 1.4 standard deviations at all three operating points; velocity magnitude contours show qualitative agreement with PIV measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from the model must directly correspond to the clinical decision metric (NIH) cited in the device submission.",
      "rationale": "The primary QoI is the normalised index of haemolysis, which is the metric specified in ASTM F1841 and cited in the 510(k) submission template; secondary QoIs include shear stress exposure time histograms."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and an equivalent blood-analogue fluid at clinically representative flow rates.",
      "rationale": "Validation was conducted on the identical FDA generic pump geometry using a 36 % glycerol–water blood analogue at flow rates spanning the intended CPB operating envelope (3–6 L/min)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual norms below 1e-5 is sufficient at MRL 2; formal solver-error quantification not required.",
      "rationale": "At MRL 2 the standard requires only that residuals are monitored and converged; all simulations reached residuals below 1e-6 for continuity and momentum, satisfying the gradation-1 threshold without formal error quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented analyst training records and simulation setup checklist are sufficient at MRL 2.",
      "rationale": "Analyst holds a PhD in computational fluid dynamics with documented training on ANSYS Fluent; a simulation setup checklist was completed and archived; formal use-error quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Selection of turbulence and haemolysis sub-models must be justified by literature precedent; formal model-form uncertainty quantification not required at MRL 2.",
      "rationale": "k-omega SST turbulence model and the power-law haemolysis model (Giersiepen et al.) are selected based on published benchmark studies for centrifugal blood pumps; model-form UQ is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal input values (viscosity, density, haemolysis model constants) must be sourced from peer-reviewed references; sensitivity analysis not required at MRL 2.",
      "rationale": "Fluid properties are taken from published blood-analogue characterisation data; haemolysis model constants are sourced from Giersiepen et al. (1990); formal sensitivity analysis is not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At least one experimental replicate per operating point is required; statistical characterisation of sample variability not required at MRL 2.",
      "rationale": "Three experimental replicates were performed at each of the three operating points; inter-replicate variability is reported as a standard deviation but no formal statistical inference is required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative mapping between experimental and simulation input parameters is sufficient at MRL 2; formal equivalency metrics not required.",
      "rationale": "A parameter equivalency table mapping experimental measurements to CFD boundary conditions is provided in the V&V report appendix; quantitative equivalency scoring is not required at MRL 2."
    }
