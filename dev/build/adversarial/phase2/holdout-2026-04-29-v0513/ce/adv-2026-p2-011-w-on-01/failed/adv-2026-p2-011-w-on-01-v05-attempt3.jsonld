  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors met or exceeded their required levels for Model Risk Level 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40 Table 1 for MRL 2 medium-risk applications. The CFD hemolysis model is accepted as credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in Class II CPB device applications. The Minimal profile is declared; detailed context-of-use scope is described in the claim and requirement documentation referenced by bindsClaim and bindsRequirement.",
