  "hash": "sha256:a3f8c2e14b097d563e2a1f8b4c6d9e0712f3a5b8c1d4e6f9023a7b5c8d2e1f4a",
  "signature": "ed25519:9b1d2e4f6a8c0b3d5e7f1a2c4d6e8f0b1c3d5e7f9a0b2c4d6e8f1a3b5c7d9e0f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control and regression testing consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a documented QA plan including version-controlled solver settings, regression test suite for internal flow benchmarks, and traceable build records. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent benchmark problems at MRL 2.",
      "rationale": "Code verification was demonstrated via Taylor-Couette flow and lid-driven cavity benchmarks. Observed convergence rates matched theoretical expectations for the second-order finite-volume discretization employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary quantity of interest (hemolysis index) across at least three mesh refinement levels.",
      "rationale": "A three-level mesh refinement study yielded GCI values below 4% for the normalized index of hemolysis at the design operating point and at the worst-case high-shear condition, satisfying MRL 2 discretization error requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to confirm overlap with the simulated operating envelope for CPB flow rates and rotational speeds.",
      "rationale": "FDA pump experimental data were collected at flow rates of 2.5–7.0 L/min and rotational speeds of 2000–3500 RPM, fully bracketing the CPB operating envelope simulated. Temperature, fluid viscosity, and hematocrit were controlled and documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within an acceptable tolerance band, with uncertainty quantification applied to both simulation and experimental values.",
      "rationale": "Predicted normalized index of hemolysis agreed with experimental values within 15% across all operating points. Validation metric included combined simulation numerical uncertainty and experimental measurement uncertainty. Achieved level exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (hemolysis index) must be directly linked to the clinical decision question of worst-case hemolysis operating condition identification for CPB devices.",
      "rationale": "The normalized index of hemolysis is the regulatory-accepted surrogate for erythrocyte damage in mechanical circulatory support. Its direct relevance to identifying worst-case operating conditions for Class II CPB devices is established in FDA guidance and published literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating conditions as the intended CPB application to ensure transferability of validation evidence.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry with a glycerin-water blood analog (matched viscosity and density) at CPB-representative flow rates and speeds. Geometric and operational similarity between validation and application contexts was confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be demonstrated to be negligible relative to discretization error at MRL 2; formal assessment deferred at MRL 2 per ASME V&V 40 guidance.",
      "rationale": "At MRL 2, formal numerical solver error assessment beyond iterative residual monitoring is not required. Residuals converged to 1e-6 for all transport equations; solver error is considered negligible relative to discretization error and is scoped out of formal assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Assessment of analyst-induced errors in model setup is not required at MRL 2 per ASME V&V 40 Table 1 guidance for medium-risk applications.",
      "rationale": "Use error formal assessment is not required at MRL 2. Simulation setup was reviewed by a second analyst and documented in the simulation log; no formal use error quantification was performed consistent with MRL 2 scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification is not required at MRL 2; selection of the power-law hemolysis model is justified by literature precedent.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on its widespread validation in centrifugal pump literature. Formal model form uncertainty assessment is outside MRL 2 scope and is deferred consistent with ASME V&V 40 Table 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter uncertainty propagation is not required at MRL 2; nominal input values are taken from published material properties and device specifications.",
      "rationale": "Fluid properties (density 1056 kg/m³, viscosity 0.0035 Pa·s) and pump geometry were taken from published FDA benchmark specifications. Formal input uncertainty propagation is not required at MRL 2 and is deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability is not required at MRL 2; the FDA benchmark dataset is treated as representative.",
      "rationale": "The FDA generic pump experimental dataset provides a single set of measurements per operating condition. Statistical sample characterization is outside MRL 2 scope. The dataset is treated as a representative reference consistent with MRL 2 assessment requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between experimental and simulation input parameters is not required at MRL 2; qualitative correspondence is documented.",
      "rationale": "Qualitative correspondence between experimental and simulation boundary conditions was documented in the validation report. Formal equivalency quantification is outside MRL 2 scope and is deferred per ASME V&V 40 Table 1 guidance."
    }
  ],
