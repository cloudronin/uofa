  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Submitted under the Minimal profile; structured hasContextOfUse link is intentionally absent per profile declaration.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-worst-case-identification",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/fda-pump-cfd-mesh-refinement-study"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-output-comparison-v1",
      "type": "ValidationResult",
      "name": "Hemolysis index output comparison against FDA pump experimental benchmark"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence-v1",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification for CPB operating envelope"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034918",
