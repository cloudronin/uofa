      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data at five operating points spanning 2–6 L/min and 1500–3500 RPM"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation via particle image velocimetry in the volute and impeller passage at nominal CPB flow conditions"
    }
  ],
