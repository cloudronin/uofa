  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under version control with documented QA procedures and regression test suite at Gradation 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-certified QA framework. Version control via Git, regression tests covering 47 benchmark cases, and release notes reviewed. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent at Gradation 2.",
      "rationale": "Fluent solver verified against ASME V&V 20 benchmark problems for incompressible Navier-Stokes. MMS convergence rates confirmed second-order spatial accuracy. Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study required with Richardson extrapolation or GCI reported for primary QoI at Gradation 2.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 11.7M, 28.4M elements). GCI for hemolysis index at nominal operating point: 3.1% (fine-to-medium) and 1.8% (medium-to-coarse ratio). Monotonic convergence confirmed. Achieved Gradation 3 exceeding requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to replicate in the simulation boundary conditions at Gradation 2.",
      "rationale": "FDA benchmark experimental conditions fully documented: inlet flow rates (2, 3, 4, 5, 6 L/min), rotational speeds (2000, 2500, 3500 RPM), blood analog fluid properties (glycerol-water, viscosity 3.5 cP at 37°C). Boundary conditions mapped directly to CFD inlet/outlet. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics between simulation outputs and experimental data must be reported with uncertainty bounds at Gradation 2.",
      "rationale": "Hemolysis index predicted within 18% of experimental values across all 15 operating points; pressure-head agreement within 5%. Validation uncertainty U_val computed per ASME V&V 20. Systematic bias identified at high-RPM low-flow corner and documented. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the clinical or engineering decision supported by the model at Gradation 2.",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH), directly linked to the regulatory decision on blood damage acceptability for Class II CPB devices. Secondary QoI is pump pressure-head, relevant to device operating envelope. Both QoIs are clinically meaningful. Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must reflect the intended clinical use conditions (flow regime, fluid, geometry) at Gradation 2.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under CPB-representative flow rates and rotational speeds. Blood analog fluid chosen to match in-vivo viscosity. Validation domain overlaps with the intended operating envelope for CPB use. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be characterized at Gradation 1 for MRL 2.",
      "rationale": "At MRL 2, Gradation 1 is required. Residual convergence to 1e-5 monitored and confirmed for all simulations; no explicit round-off analysis required at this gradation. Scoped per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-induced error in model setup must be acknowledged at Gradation 1 for MRL 2.",
      "rationale": "MRL 2 requires only Gradation 1. Simulation setup reviewed by a second analyst; checklist-based review completed. Formal use-error FMEA not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Appropriateness of turbulence and hemolysis sub-model selection must be documented at Gradation 1.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model selected based on published literature for similar pump geometries. Model form justification documented in simulation plan. Gradation 1 satisfied without formal sensitivity study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters must be identified and nominal values documented at Gradation 1 for MRL 2.",
      "rationale": "All model inputs (fluid density, viscosity, hemolysis model coefficients, rotational speed, inlet flow rate) documented in simulation log with sources. Uncertainty quantification of inputs not required at Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and representativeness of experimental test samples must be documented at Gradation 1.",
      "rationale": "FDA benchmark dataset uses standardized blood analog with controlled preparation protocol. Sample-to-sample variability reported in original FDA study. At Gradation 1, documentation of sample provenance is sufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and experimental conditions must be established at Gradation 1.",
      "rationale": "Inlet boundary conditions, rotational speed, and fluid properties in CFD matched to experimental protocol values. Any deviations (e.g., idealized inlet velocity profile vs. measured profile) noted in simulation plan. Gradation 1 satisfied."
    }
  ],
