  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Submitted under ProfileMinimal; structured hasContextOfUse link intentionally absent per minimal-profile scope rules.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-cfd-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-ncac-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/morrison-cpb-operating-envelope-measurements"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA NCAC experimental data at five operating points spanning the CPB flow envelope"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-rise and efficiency validation across 3000–5000 RPM at nominal CPB flow rates"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041845",
