  "signature": "ed25519:b7d2e4f1a09c3e58d67b14f2c839a04e1d5f7b2c6a3e9018d4c7f2b5e8a1d3c6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under documented version control with regression test suite covering turbulence and scalar-transport modules used in hemolysis prediction.",
      "rationale": "ANSYS Fluent 2022R2 employed under ISO 9001-certified QMS. Regression suite of 47 benchmark cases executed and archived. Version hash recorded in simulation log. Requirement level 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) for Navier-Stokes and scalar hemolysis transport equations.",
      "rationale": "MMS study confirmed second-order spatial convergence for velocity and first-order for hemolysis scalar on structured hex meshes. Observed order matches theoretical order within 5% tolerance. Code verification complete at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the medium mesh used for production runs.",
      "rationale": "Three-level Richardson extrapolation performed on 4.2M, 11.7M, and 31.4M cell meshes. GCI on hemolysis index = 2.8% on medium mesh. Discretization error budget well within acceptance threshold; achievedLevel exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, blood viscosity, hematocrit) must be reproduced in simulation within stated measurement uncertainty bands.",
      "rationale": "FDA NCAC experimental protocol documented inlet flow 4–6 L/min, outlet pressure 80–120 mmHg, hematocrit 33±2%. Simulation boundary conditions set to nominal values; sensitivity runs confirm hemolysis index insensitive to ±1 SD perturbations of measured BCs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement (NIA) for hemolysis index across five operating points must exceed 0.85.",
      "rationale": "NIA computed as 0.91 across five operating points. Maximum point-wise relative error 9.4% at lowest flow condition. Systematic bias < 3%. Output comparison criterion satisfied at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (normalized index of hemolysis, peak shear stress exposure, residence time) must map directly to clinical hemolysis risk metrics cited in FDA guidance.",
      "rationale": "Normalized index of hemolysis (NIH) and modified index of hemolysis (MIH) are the primary QoIs, both explicitly listed in FDA guidance document FDA-2013-D-1543. Shear-exposure integral serves as mechanistic intermediate. QoI relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue, and operating envelope as the intended CPB clinical use scenario.",
      "rationale": "FDA NCAC experiments used the identical generic centrifugal pump CAD geometry released by FDA. Bovine blood at physiological hematocrit used; operating envelope 3–6 L/min matches CPB clinical range. Validation scenario is sufficiently representative of CPB use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to solver default tolerances is sufficient at MRL 2 without explicit solver error quantification.",
      "rationale": "At MRL 2 the standard requires only that residuals reach solver-default convergence thresholds. All simulations converged to 1e-5 on continuity and momentum. Formal solver-error quantification beyond residual monitoring is not required at this risk level and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 a documented simulation plan reviewed by a second analyst is sufficient; formal use-error FMEA is not required.",
      "rationale": "Simulation plan reviewed and signed off by senior analyst prior to execution. No formal use-error failure mode analysis required at MRL 2. Factor scoped to level 1 per risk-level determination."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection (SST k-omega) must be justified by published benchmark data for rotating turbomachinery flows with similar Re and geometry.",
      "rationale": "SST k-omega selected based on published literature benchmarks for centrifugal pump flows (Re 1e5–1e6). Power-law hemolysis model (Giersiepen-Wurzinger) validated against in-vitro Couette data. Model form uncertainty estimated at ±15% on NIH, acceptable for worst-case identification purpose."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (blood viscosity, density, hemolysis model coefficients) must be sourced from peer-reviewed literature with stated uncertainty ranges.",
      "rationale": "Blood viscosity 0.0035 Pa·s (Newtonian approximation justified for shear rates > 100 s-1 in pump), density 1060 kg/m3, Giersiepen-Wurzinger coefficients from original 1990 publication. Sensitivity analysis confirms NIH varies < 8% across literature range of coefficients."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 the number of experimental replicates need not be formally power-analyzed; documentation of sample provenance is sufficient.",
      "rationale": "FDA NCAC dataset provides n=3 replicates per operating point. Formal statistical power analysis not required at MRL 2. Sample provenance documented in NCAC experimental report (FDA-2012-D-0378). Factor accepted at level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 qualitative confirmation that simulation and experimental input parameters are nominally equivalent is sufficient.",
      "rationale": "Simulation inputs confirmed nominally equivalent to experimental conditions by side-by-side parameter table review. Quantitative equivalency mapping not required at MRL 2. No material discrepancies identified."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-simulation-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors accepted at level 1 per MRL 2 scope. Hemolysis index NIA of 0.91 and GCI of 2.8% demonstrate adequate predictive fidelity for worst-case operating condition identification in the CPB hemolysis use scenario. The model is accepted as credible for the intended decision: identifying worst-case hemolysis operating conditions for a Class II CPB device.",
