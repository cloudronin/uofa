  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan consistent with MRL 2 requirements, including version control and regression testing.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-certified QA framework. Version control, regression test suite, and release notes were reviewed. All checks passed at the required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical implementation must be verified through benchmark problems with known analytical solutions covering the relevant flow regime.",
      "rationale": "Code verification was performed using Taylor-Green vortex and lid-driven cavity benchmarks. Observed order of accuracy matched theoretical second-order convergence for the pressure-velocity coupling scheme employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence must be demonstrated via a systematic mesh refinement study with GCI < 5% on the primary QoI (hemolysis index).",
      "rationale": "Three-level mesh refinement study (3.2 M, 9.6 M, 28.8 M cells) conducted following Celik et al. (2008) GCI methodology. GCI on normalised hemolysis index was 2.1%, exceeding the required threshold. Medium mesh (9.6 M) selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to confirm correspondence with simulated boundary conditions.",
      "rationale": "FDA benchmark experimental protocol specifies inlet flow rates (2.5–7.5 L/min), rotational speeds (2000–3500 RPM), and fluid properties (glycerol-water analogue). Simulation boundary conditions were set to match these specifications within stated tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoIs must be compared to experimental measurements using a quantitative metric; agreement must fall within combined experimental and numerical uncertainty bands.",
      "rationale": "Predicted normalised index of hemolysis (NIH) compared against five experimental operating points. Mean absolute error was 8.3%, within the combined uncertainty band of ±12%. Velocity field comparison via PIV showed mean deviation of 6.2% in the impeller passage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoIs must be directly linked to the clinical or regulatory decision being supported (worst-case hemolysis identification for CPB device submission).",
      "rationale": "NIH and scalar shear stress exposure time (SSET) are the QoIs. Both are directly referenced in FDA guidance on mechanical blood trauma assessment. Linkage to the worst-case operating condition identification decision is explicitly documented in the claim node."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties sufficiently representative of the CPB clinical use envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under CPB-representative flow conditions. Fluid analogue viscosity and density were matched to blood at 37°C. Geometric fidelity confirmed by CT scan comparison with CAD model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative solver convergence to be monitored; residuals must drop below 1e-5 for all transport equations.",
      "rationale": "Not assessed at MRL 2 for this factor. Residual monitoring was performed as standard practice and confirmed convergence, but formal gradation assessment was scoped out per the MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst qualification and simulation execution procedures must be documented to mitigate user-induced errors.",
      "rationale": "Not assessed at MRL 2. Analysts hold relevant CFD qualifications and followed internal SOPs, but formal use-error gradation evaluation was not required under the MRL 2 assessment plan for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The selection of turbulence model and hemolysis damage model must be justified relative to the flow physics encountered in the CPB pump.",
      "rationale": "Not assessed at MRL 2. SST k-omega turbulence model and power-law hemolysis model (Giersiepen et al.) were selected based on literature precedent for similar devices, but formal model-form gradation assessment was scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of QoIs to uncertain input parameters (fluid viscosity, rotational speed tolerance) must be characterised.",
      "rationale": "Not assessed at MRL 2. Input parameters were set to nominal values from the FDA benchmark protocol. Formal sensitivity analysis was not required under the MRL 2 plan for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and selection of experimental test samples used for validation must be sufficient to characterise inter-sample variability.",
      "rationale": "Not assessed at MRL 2. FDA benchmark dataset represents a single pump specimen; inter-specimen variability was not characterised. Accepted as adequate for MRL 2 per assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and experimental conditions must be quantitatively established for all boundary conditions.",
      "rationale": "Not assessed at MRL 2. Boundary conditions were set to match experimental protocol values; formal equivalency quantification was scoped out under the MRL 2 assessment plan."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/dr-sarah-morrison",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors met or exceeded required gradation levels for MRL 2. Six factors were appropriately scoped out per the MRL 2 assessment plan. Validation evidence demonstrates sufficient model credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device regulatory submission. The assessment team concludes that the model credibility is adequate for the intended decision, as described in the Claim (https://uofa.net/morrison/claim/cpb-hemolysis-worst-case) and Requirement (https://uofa.net/morrison/req/cpb-hemolysis-mrl2) nodes.",
