  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-cardiovascular-simulation-group",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scoping per ASME V&V 40 Table 1. Validation evidence demonstrates hemolysis index prediction error within the 15% acceptance threshold across the CPB operating envelope. The model is accepted for use in identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in pre-market submission support for adult Class II CPB devices.",
