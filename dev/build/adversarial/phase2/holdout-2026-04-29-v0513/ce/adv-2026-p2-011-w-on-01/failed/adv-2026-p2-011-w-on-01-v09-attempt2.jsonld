  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance activities documented per MRL 2 requirements; version control, build reproducibility, and regression test suite in place.",
      "rationale": "ANSYS Fluent 2022 R2 used under a validated installation qualification (IQ) protocol. Version control via Git with tagged release; automated regression suite covers 12 benchmark cases. All SQA records archived and traceable to simulation runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via published benchmark solutions or method-of-manufactured-solutions (MMS) demonstrating expected convergence order for the discretisation schemes employed.",
      "rationale": "Second-order spatial convergence confirmed against lid-driven cavity and Poiseuille flow MMS benchmarks. Observed order of accuracy 1.92 for velocity, consistent with second-order upwind scheme. Results published in solver validation report MCV-SVR-2022-04."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis performed; discretisation error reported as a percentage of the QoI; GCI < 5% on the hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study conducted (4.2 M, 11.7 M, 28.4 M cells). GCI on normalised hemolysis index = 2.1% (fine-to-medium) and 3.8% (medium-to-coarse), confirming asymptotic convergence. Achieved level exceeds requirement, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with sufficient fidelity to allow CFD boundary condition specification; fluid properties, rotational speed, and flow rates recorded with measurement uncertainty.",
      "rationale": "FDA benchmark experimental data provide fluid temperature (37 ± 0.5 °C), haematocrit (33 ± 1%), flow rates (±0.05 L/min), and impeller speed (±10 RPM). Boundary conditions derived directly from reported test conditions; uncertainty propagated to CFD inlet/outlet BCs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed between CFD predictions and experimental data for hemolysis index and pressure rise; metric within acceptance band.",
      "rationale": "Normalised hemolysis index: mean absolute error 8.3% across six operating points (acceptance threshold 15%). Pressure rise: mean absolute error 4.1% across flow range. Validation metric u_val = 0.11, below threshold of 0.20. Comparison documented in validation report MCV-VR-2023-02."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, pressure rise) are directly relevant to the decision question of identifying worst-case hemolysis operating conditions for CPB use.",
      "rationale": "The normalised hemolysis index (NIH) is the primary regulatory QoI for CPB blood trauma assessment. Pressure rise is a secondary QoI confirming hydraulic fidelity. Both QoIs map directly to the decision question and are the same quantities monitored in clinical device evaluation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, flow regime, and fluid properties sufficiently similar to the CPB COU to support extrapolation of credibility evidence.",
      "rationale": "Validation geometry is the FDA generic centrifugal pump — the same geometry as the COU device. Flow regime (Re, Womersley number) and fluid properties (non-Newtonian blood analogue) are representative of CPB operating conditions. Rotational speed range in validation (2000–3500 RPM) spans the COU envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
