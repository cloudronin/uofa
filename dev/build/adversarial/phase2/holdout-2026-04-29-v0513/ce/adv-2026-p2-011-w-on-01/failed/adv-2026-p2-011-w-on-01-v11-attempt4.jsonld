  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped to not-assessed per ASME V&V 40 Table 3 guidance for MRL 2 design-comparison decisions. Validation comparison errors for hemolysis index (8.2 %) and pressure rise (2.1 %) are within the established acceptance band. The model is accepted for the purpose of identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in the CPB clinical envelope. Decision is conditional on continued use within the operating range covered by validation experiments (3–7 L/min, 2000–3500 RPM).",
