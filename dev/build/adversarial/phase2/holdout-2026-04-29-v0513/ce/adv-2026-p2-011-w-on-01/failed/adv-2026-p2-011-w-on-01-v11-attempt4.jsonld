      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a documented simulation plan reviewed by a second analyst is sufficient; formal use-error analysis not required.",
      "rationale": "Simulation plan reviewed by independent CFD analyst prior to execution. Boundary condition setup and turbulence model selection documented in simulation record SR-2024-07. Formal use-error quantification deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
