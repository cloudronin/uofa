      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be documented under a quality management system with version control, regression test suite, and traceable release notes.",
      "rationale": "ANSYS Fluent 2022R2 is developed under ISO 9001-certified QMS. Release notes, regression suite (>4 000 tests), and version control records were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver vendor must provide order-of-accuracy verification on canonical benchmarks relevant to rotating turbomachinery flows.",
      "rationale": "Vendor-supplied method-of-manufactured-solutions results demonstrate second-order spatial convergence for the SST k-ω closure on rotating-frame benchmark cases. Results are traceable to solver release documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for hemolysis index QoI must be below 10 % on the fine-grid solution.",
      "rationale": "Three-level Richardson extrapolation performed on 4.1 M, 9.8 M, and 22.4 M cell meshes. GCI on hemolysis index = 3.8 % (fine grid), exceeding the MRL 2 threshold. Achieved level elevated to 3 based on quantified uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must be documented with measurement uncertainty and traceable to calibrated instruments.",
      "rationale": "FDA pump test data collected at NHLBI with calibrated Coriolis flow meters (±0.5 %) and optical tachometers (±5 RPM). Fluid temperature and viscosity recorded per ASTM F1841 protocol. Boundary condition uncertainty propagated into simulation inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., validation comparison error E) must be computed for each QoI and compared against an acceptance threshold derived from the decision requirements.",
      "rationale": "Validation comparison error computed per ASME V&V 20 for pressure rise (E = 2.1 %) and hemolysis index (E = 8.2 %). Both within the ±15 % acceptance band established for MRL 2 design-comparison decisions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from the model must be directly linked to the engineering decision (worst-case hemolysis identification) and traceable to the device requirement.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) integrated over the pump flow domain. NIH is the regulatory metric cited in FDA guidance for CPB device pre-market submissions. Direct traceability to device requirement REQ-HEM-001 is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope (flow rate 3–7 L/min, speed 2000–3500 RPM) relevant to CPB clinical use.",
      "rationale": "Six validation operating points span 3–7 L/min and 2000–3500 RPM, bracketing the CPB clinical envelope. Fluid analogue (glycerol-water, matched viscosity) confirmed equivalent Reynolds number regime. Validation relevance score assessed as High."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative convergence monitoring to residual drop of 10^-4 is sufficient; formal solver error quantification not required.",
      "rationale": "Residuals monitored to 10^-5 for all transport equations. No formal iterative error quantification required at MRL 2; factor scoped to not-assessed per ASME V&V 40 Table 3 guidance for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
