  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control and regression tests in place for the CFD solver used in hemolysis prediction.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with documented SQA procedures. Internal regression suite covers relevant turbulence and scalar-transport modules. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for momentum and scalar transport equations demonstrated via manufactured solutions or benchmark cases.",
      "rationale": "Second-order spatial accuracy confirmed through method-of-manufactured-solutions tests on canonical pipe-flow and rotating-cavity benchmarks. Results archived in project verification report VR-2023-04."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (hemolysis index) with GCI < 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed (3.2 M, 8.7 M, 22.1 M cells). GCI for normalised index of hemolysis on fine grid is 2.8%, exceeding the required threshold. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) documented and matched in simulation setup within stated tolerances.",
      "rationale": "PIV and hemolysis bench tests conducted at FDA CDRH laboratory. Inlet flow rates controlled to ±0.5%, temperature to ±0.5 °C, hematocrit to ±1%. Simulation boundary conditions set from measured values; deviations documented in test report TR-FDA-2022-11."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., validation metric E or ASME V&V 20 area metric) computed between predicted and measured hemolysis index across all validation operating points.",
      "rationale": "ASME V&V 20 area validation metric computed for NIH across six operating points; metric value 0.18 (dimensionless), within the acceptance band of ±0.25 established for MRL 2. Velocity field RMS error 4.3% of bulk velocity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (normalised index of hemolysis) is directly linked to the clinical risk metric specified in the device submission context.",
      "rationale": "NIH is the regulatory QoI for CPB hemolysis submissions per FDA guidance. The model directly outputs NIH via the power-law hemolysis damage model integrated along Lagrangian particle tracks, providing a direct mapping to the decision-relevant metric."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry under flow conditions spanning the intended CPB operating envelope.",
      "rationale": "Validation conducted on the FDA generic centrifugal blood pump — the identical geometry used in the submission model. Operating points (2000–3500 RPM, 3–7 L/min) bracket the CPB envelope described in the device labelling. Relevance is high for the stated use scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to at least 10^-5 for all transport equations.",
      "rationale": "Not assessed as a separate factor at MRL 2; iterative convergence monitoring is subsumed within the discretization error factor. Residual convergence to 10^-6 was observed in practice and noted in the solver log, but formal factor scoring is scoped out at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup checklist reviewed by independent analyst.",
      "rationale": "Formal use-error assessment not required at MRL 2. Simulation setup was reviewed informally by a second analyst; no discrepancies found. Formal independent review is planned for MRL 3 upgrade if device risk classification changes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification provided for selection of turbulence model and hemolysis damage model.",
      "rationale": "Model form uncertainty not formally scored at MRL 2. The SST k-ω turbulence model and Giersiepen power-law hemolysis model are standard choices for rotary blood pump CFD, supported by published literature. Sensitivity to model form is noted as a future work item."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis of NIH to key model input parameters (viscosity, damage model exponents) documented.",
      "rationale": "Input sensitivity not formally assessed at MRL 2. Published literature indicates NIH is moderately sensitive to damage model exponents; a one-at-a-time sensitivity sweep is planned for the MRL 3 upgrade package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood sample characterisation (hematocrit, donor variability) reported for hemolysis bench tests.",
      "rationale": "Test sample characterisation not formally scored at MRL 2. Hematocrit was controlled and reported in TR-FDA-2022-11; donor-to-donor variability was not systematically studied. This is acceptable at the current risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that simulation input parameters (geometry, fluid properties, rotational speed) are equivalent to those used in validation experiments.",
      "rationale": "Equivalency formally documented in TR-FDA-2022-11 for geometry and operating conditions but not scored as a separate credibility factor at MRL 2. The geometry used in simulation was derived from the same CAD file as the manufactured test article."
    }
  ],
