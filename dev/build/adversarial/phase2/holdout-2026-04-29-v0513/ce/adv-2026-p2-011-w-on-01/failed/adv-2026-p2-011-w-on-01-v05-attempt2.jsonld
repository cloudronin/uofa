      "name": "PIV velocity field comparison at 3500 RPM, 5 L/min"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-bench",
      "type": "ValidationResult",
      "name": "Normalised index of hemolysis bench comparison across 6 operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034998",
