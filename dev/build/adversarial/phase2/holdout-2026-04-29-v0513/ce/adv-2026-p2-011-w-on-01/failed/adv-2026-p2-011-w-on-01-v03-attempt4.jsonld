  "signature": "ed25519:7c3a1f9e2b5d8c0a4f7e1b3d6c9a2f5e8b1d4c7a0f3e6b9d2c5a8f1e4b7d0c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent quality management documentation; version control and regression test suite must be demonstrated.",
      "rationale": "ANSYS Fluent 2022 R2 is ISO 9001 certified. Version-controlled solver with documented regression test suite covering turbulent pipe and rotating-frame benchmark cases. Requirement met at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating-frame flow must confirm second-order spatial convergence for momentum equations.",
      "rationale": "Method of manufactured solutions applied to a rotating annular flow case confirmed second-order spatial accuracy (observed order 1.94). Code verification requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be below 5% for primary QoI (NIH) on the production mesh.",
      "rationale": "Three-level mesh refinement study (4.2 M, 10.8 M, 26.1 M cells) yielded GCI of 3.1% for NIH at the nominal operating point. Discretization error is within the 5% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity and density) must be documented with uncertainty quantification and replicated in simulation inputs.",
      "rationale": "FDA benchmark test conditions are fully documented in Hariharan et al. (2011). Simulation boundary conditions reproduce measured flow rates (±1.5%), RPM (±10 RPM), and fluid properties (glycerol-water analogue) with traceability to calibrated instrumentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with experimental mean within two experimental standard deviations across all five validation operating points.",
      "rationale": "NIH predictions fall within two experimental standard deviations at all five operating points (maximum normalised error 18%). Velocity field comparison shows qualitative agreement with PIV data in the impeller region."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress distribution) must be directly relevant to the clinical decision of identifying worst-case hemolysis in CPB use.",
      "rationale": "NIH is the regulatory QoI for CPB hemolysis assessment per ISO 10993-4 and FDA guidance. Shear stress fields directly inform the power-law hemolysis model. Both QoIs are clinically and regulatorily relevant to the CPB worst-case identification decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the CPB operating envelope (flow rate 3–7 L/min, speed 2000–4500 RPM) and use a blood analogue with matched viscosity.",
      "rationale": "Five validation points span 3–6 L/min and 2000–3500 RPM, covering the majority of the CPB envelope. Glycerol-water analogue viscosity matched to 37°C blood (3.5 cP). Achieved level exceeds requirement, providing additional confidence in extrapolation to 4500 RPM."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual below 1e-5 for all equations is sufficient at MRL 2; formal solver error bounding not required.",
      "rationale": "At MRL 2, demonstration of iterative convergence (all residuals below 1e-5, mass imbalance below 0.01%) is sufficient. Formal solver error quantification is scoped out per ASME V&V 40 Table 3 guidance for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup checklist reviewed by a second analyst is sufficient at MRL 2.",
      "rationale": "Independent peer review of simulation setup (boundary conditions, mesh, solver settings, post-processing scripts) completed by a second qualified analyst. Formal use-error quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented justification for turbulence model selection referencing published benchmark comparisons is sufficient at MRL 2.",
      "rationale": "SST k-ω turbulence model selected based on published FDA pump benchmark comparisons (Hariharan et al. 2011, Malinauskas et al. 2017) showing superior NIH prediction accuracy relative to k-ε variants. Formal model-form uncertainty quantification deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal input values with literature-sourced ranges documented; sensitivity analysis not required at MRL 2.",
      "rationale": "Fluid properties, hemolysis model coefficients (Giersiepen et al.), and geometric tolerances documented with literature sources. One-at-a-time sensitivity screening performed informally; formal UQ not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use of FDA-published benchmark dataset with documented sample preparation is sufficient; independent replication not required at MRL 2.",
      "rationale": "FDA benchmark dataset (Hariharan et al. 2011) used as the validation corpus. Sample preparation, fluid preparation, and measurement protocols are publicly documented. Independent replication not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented mapping between experimental and simulation input parameters with qualitative discussion of any mismatches is sufficient at MRL 2.",
      "rationale": "Parameter mapping table provided covering flow rate, rotational speed, fluid viscosity, density, and pump geometry. Key mismatch (non-Newtonian blood vs. Newtonian analogue) discussed qualitatively; impact assessed as minor for shear-dominated hemolysis prediction at CPB flow rates."
    }
  ],
