  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. The six non-assessed factors are explicitly scoped out as not required at MRL 2 per ASME V&V 40-2018 Table 3. The CFD hemolysis model is accepted as sufficiently credible to support identification of worst-case hemolysis operating conditions for the Class II CPB device pre-market submission. The decision is conditioned on continued use within the operating envelope defined in the Claim and Requirement documentation.",
