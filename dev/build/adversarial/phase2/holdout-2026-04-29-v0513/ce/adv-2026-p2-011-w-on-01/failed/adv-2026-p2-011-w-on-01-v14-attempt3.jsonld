    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data at 2500 and 3500 RPM operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation via PIV measurements in the FDA generic pump geometry across CPB flow range"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034537",
