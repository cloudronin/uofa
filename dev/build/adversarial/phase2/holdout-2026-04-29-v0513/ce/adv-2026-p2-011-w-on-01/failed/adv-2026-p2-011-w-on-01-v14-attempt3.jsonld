  "signature": "ed25519:b4e9d3c2a1f8e7b6d5c4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QA process covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under an ISO 9001-certified QA framework. Version control logs, regression test suite results, and release notes were reviewed and confirm compliance with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass published benchmark verification cases relevant to rotating turbomachinery flow, demonstrating correct implementation of governing equations.",
      "rationale": "ANSYS Fluent has been verified against ASME V&V 20 lid-driven cavity and rotating channel benchmarks. Published verification reports confirm correct discretisation of the incompressible Navier-Stokes equations in the MRF rotating frame formulation used for the CPB pump."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be less than 5% on the medium mesh relative to the fine mesh.",
      "rationale": "Richardson extrapolation performed on three systematically refined meshes (4.2 M, 9.8 M, 21.4 M cells). GCI for normalised hemolysis index is 2.3% between medium and fine meshes, exceeding the MRL 2 threshold. Medium mesh selected for production runs balancing accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must be documented and match simulation inputs within stated measurement uncertainty.",
      "rationale": "FDA benchmark experimental conditions are fully documented in the published dataset. Inlet flow rates (2–6 L/min) and rotational speeds (2500, 3500 RPM) are reproduced in the CFD boundary conditions. Bovine blood viscosity and density match within 1.5% of reported experimental values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within two standard deviations of experimental scatter across the operating envelope.",
      "rationale": "Predicted normalised index of hemolysis (NIH) values at 2500 and 3500 RPM agree with FDA benchmark measurements within experimental uncertainty bands (mean error 8.4%, within 2σ of 22%). Velocity field comparisons with PIV data show mean absolute error of 6.2% across the impeller passage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalised index of hemolysis) must be directly linked to the clinical decision metric for CPB device safety assessment.",
      "rationale": "NIH is the FDA-accepted metric for hemolysis assessment in CPB devices per FDA guidance on blood-contacting devices. The QoI is directly used in the device submission decision regarding worst-case operating conditions, confirming relevance to the intended clinical use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating range as the intended CPB application.",
      "rationale": "Validation activities use the FDA generic centrifugal pump geometry — the same geometry as the COU device surrogate — with bovine blood analogue under CPB-representative flow and speed conditions. The validation domain overlaps substantially with the intended operating envelope, satisfying MRL 2 relevance requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence monitoring to residual drop of 10^-5 is sufficient.",
      "rationale": "At MRL 2, formal solver error quantification beyond convergence monitoring is not required. Residuals converged to 10^-5 for all transport equations; mass imbalance below 0.01%. No further assessment scoped for this submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records and simulation protocol documentation are sufficient.",
      "rationale": "MRL 2 does not require formal use-error analysis. All analysts hold documented CFD training credentials and followed the laboratory simulation protocol. Formal use-error assessment is deferred and not required for this credibility level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection must be documented with engineering justification.",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model were selected based on published literature precedent for CPB CFD. Formal model-form uncertainty quantification is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Fluid properties and boundary conditions are specified at nominal values from published sources. Sensitivity analysis and input uncertainty propagation are not required at MRL 2 and have not been conducted for this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; use of the published FDA benchmark dataset with documented sample provenance is sufficient.",
      "rationale": "The FDA benchmark dataset provides sufficient experimental replication for MRL 2 purposes. Formal statistical characterisation of test sample variability is not required at this credibility level and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping between simulation and experimental input parameters is sufficient.",
      "rationale": "A qualitative mapping confirms that simulation boundary conditions correspond to experimental operating conditions. Formal equivalency analysis using uncertainty propagation is not required at MRL 2 and has not been performed for this submission."
    }
  ],
