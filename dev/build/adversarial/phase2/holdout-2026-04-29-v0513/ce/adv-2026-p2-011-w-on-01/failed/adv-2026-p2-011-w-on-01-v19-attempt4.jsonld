  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This UoA evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Intended use is bounded to adult CPB flows of 3–6 L/min at 1500–3500 RPM; the model output is the scalar hemolysis index compared against in-vitro measurements from the Morrison et al. dataset. Full 13-factor ASME V&V 40-2018 assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2).",
  "bindsRequirement": "https://uofa.net/morrison/req/hemolysis-prediction-cpb",
  "bindsClaim": "https://uofa.net/morrison/claim/cfd-hemolysis-worst-case-identification",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-invitro-hemolysis",
    "https://uofa.net/morrison/data/morrison-2022-experimental"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index CFD vs. in-vitro comparison across 5 operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence study — GCI below 3% on hemolysis index QoI"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4054990",
