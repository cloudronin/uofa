  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent QMS documentation covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022 R1 is used under an FDA-recognized QMS. Regression test suite covers all turbulence models and scalar transport equations employed in the hemolysis sub-model. Achieved level 2 satisfies MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must confirm second-order spatial accuracy for momentum and scalar transport equations.",
      "rationale": "MMS benchmarks published in Fluent verification manual confirm second-order accuracy for the k-omega SST and scalar hemolysis transport equations on structured and unstructured hexahedral meshes. Achieved level 2 is consistent with MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) on the primary QoI (hemolysis index) must be below 5% using at least three systematically refined meshes.",
      "rationale": "Three meshes (2.1 M, 6.4 M, 14.8 M cells) yield GCI of 2.7% on the hemolysis index at the design operating point (5 L/min, 2500 RPM). Richardson extrapolation confirms monotonic convergence. Achieved level 2 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with measurement uncertainty and must span at least three operating points within the CPB flow range.",
      "rationale": "Morrison et al. (2022) report inlet flow rates, rotational speed, and fluid viscosity with calibrated measurement uncertainty. Five operating points covering 3–6 L/min are available. Boundary conditions are reproduced in CFD within reported tolerances. Achieved level 2 satisfies requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement (NIA) between predicted and measured hemolysis index must exceed 0.85 across all validation operating points.",
      "rationale": "NIA computed across five operating points is 0.91. Maximum relative error is 9.4% at the lowest flow rate; all other points are within 7%. The comparison metric exceeds the acceptance threshold, supporting achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (hemolysis index) must be directly linked to the clinical risk metric (plasma-free hemoglobin) via a validated power-law damage accumulation model.",
      "rationale": "The Giersiepen-Wurzinger power-law model relates shear stress exposure to normalized index of hemolysis, which correlates with plasma-free hemoglobin in published in-vitro studies. The QoI is the same scalar reported in the Morrison experimental dataset. Achieved level 2 is appropriate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating range as the intended CPB clinical application.",
      "rationale": "Morrison et al. used the FDA generic centrifugal pump geometry with a 36% glycerol blood analog (matching viscosity of whole blood) at CPB-relevant flows. The validation envelope directly overlaps the intended operating range. Achieved level 2 is justified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must drop below 1e-5 for all transport equations; round-off error must be negligible relative to discretization error.",
      "rationale": "At MRL 2 this factor is not required to be formally assessed beyond confirming solver convergence monitors. Residuals were monitored and dropped below 1e-4; a formal round-off analysis is not required at this risk level. Scoping is consistent with ASME V&V 40 Table 1 guidance for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst qualification records and simulation execution checklists must be on file.",
      "rationale": "Formal use-error assessment is not required at MRL 2 per ASME V&V 40 Table 1. Analysts hold relevant CFD training credentials; checklist-based review was performed internally. No further structured assessment is warranted at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis index to turbulence model selection must be quantified via at least two model variants.",
      "rationale": "Model-form uncertainty assessment is not required at MRL 2. The k-omega SST model was selected based on prior published benchmarks for rotating machinery hemolysis. A formal multi-model comparison is deferred to higher MRL investigations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty propagation from fluid property inputs (viscosity, density) to hemolysis index QoI must be quantified.",
      "rationale": "Input uncertainty propagation is not required at MRL 2. Fluid properties were set to nominal values from the Morrison experimental protocol. Sensitivity to ±5% viscosity variation was informally checked and found to produce less than 2% change in hemolysis index, supporting the decision to scope out formal assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample-to-sample variability in experimental hemolysis measurements must be characterized and reported.",
      "rationale": "Formal test-sample assessment is not required at MRL 2. Morrison et al. report triplicate measurements at each operating point; coefficient of variation is below 8%. This information is used qualitatively in the output comparison but a structured sample assessment is not mandated at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional similarity between validation experiment and clinical use conditions must be demonstrated via relevant non-dimensional parameters (Reynolds number, specific speed).",
      "rationale": "Equivalency of input parameters is not required at MRL 2. The glycerol-water blood analog matches whole-blood viscosity within 4%, and the pump geometry is identical to the clinical device geometry. A formal dimensional analysis is deferred; the qualitative equivalency is considered sufficient at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for Model Risk Level 2. The six factors scoped out of formal assessment are consistent with ASME V&V 40 Table 1 allowances for MRL 2 Class II devices. The hemolysis index QoI is directly relevant to the intended CPB clinical risk question, validation data span the intended operating envelope, and discretization error is well-controlled. The assessment team concludes that the simulation evidence provides adequate credibility to support the regulatory submission claim that the CFD model correctly identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump.",
