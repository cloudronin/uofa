      "name": "Hemolysis index predicted vs. measured — FDA GCBP benchmark, 5 operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "CFD velocity field vs. PIV measurements — impeller exit plane, 3500 RPM"
    }
