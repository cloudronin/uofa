  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan; regression test suite passing for all relevant physics modules.",
      "rationale": "ANSYS Fluent 2022R2 deployed under ISO 9001-certified QA process. Full regression suite (847 tests) executed prior to study; all passed. Version control via Git with signed release tags. Satisfies MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one canonical benchmark with documented order-of-accuracy confirmation.",
      "rationale": "Code verification performed using lid-driven cavity (Re=1000) and rotating disk flow benchmarks. Second-order spatial accuracy confirmed via Richardson extrapolation. Results match published DNS reference data within 0.8% for peak velocity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with GCI < 5% for hemolysis index QoI on at least three mesh refinements.",
      "rationale": "Three-level mesh refinement study conducted (6.2M, 14.8M, 31.4M hexahedral cells). GCI for normalized hemolysis index: 3.1% (medium-to-fine). Temporal convergence confirmed with CFL < 0.8. Exceeds MRL 2 requirement; achieves MRL 3 level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match simulation inputs within stated uncertainty bounds; fluid temperature and viscosity documented.",
      "rationale": "FDA GCBP experiments conducted at 37°C with bovine blood (hematocrit 35±2%). Inlet flow rate measured via Coriolis meter (±0.5%). Rotational speed via optical encoder (±5 RPM). All boundary conditions reproduced in simulation with documented mapping procedure."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 20% of experimental mean across all validation operating points; systematic bias documented.",
      "rationale": "Hemolysis index predictions compared at 5 operating points (3–6 L/min, 2500–3500 RPM). Mean absolute error: 11.4%; maximum deviation: 17.8% at 6 L/min/3500 RPM. Systematic over-prediction of 8% attributed to power-law hemolysis model constants calibrated on porcine rather than bovine blood; documented as known modeling choice."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (normalized index of hemolysis, NIH) directly maps to clinical risk metric specified in device submission requirements.",
      "rationale": "NIH selected as primary QoI per ASTM F1841 and FDA guidance on blood-contacting device testing. Secondary QoIs (shear stress distribution, residence time) support mechanistic interpretation. Direct traceability to 510(k) submission requirements established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow regime, and fluid properties sufficiently similar to intended CPB operating envelope to support extrapolation.",
      "rationale": "Validation performed on FDA GCBP geometry under CPB-representative conditions (3–6 L/min, hematocrit 35%). Device-specific geometry differs in impeller blade count and volute angle; similarity analysis via dimensionless parameters (Re, flow coefficient) confirms validation is representative. Extrapolation uncertainty bounded by sensitivity study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; accepted at baseline level.",
      "rationale": "Per ASME V&V 40 Table 4, numerical solver error assessment beyond code verification is not required at MRL 2. Solver round-off and iterative convergence monitored via residual tracking (all residuals < 1e-5); no anomalies detected. Scoped out of formal assessment consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification documented as sufficient control.",
      "rationale": "Use error formal assessment not required at MRL 2. Analyst holds PhD in computational fluid dynamics with 8 years of cardiovascular CFD experience. Simulation setup reviewed by independent senior analyst. Simulation execution checklist followed per lab SOP-CFD-004."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model selection rationale documented.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for rotating machinery flows. Power-law hemolysis model (Giersiepen et al.) selected per community consensus for CPB applications. Model form uncertainty not formally quantified at MRL 2; selection rationale documented in modeling report MR-2024-003."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input parameter sources documented with traceability.",
      "rationale": "All model inputs (fluid density 1060 kg/m3, dynamic viscosity 0.0035 Pa·s at 37°C, hemolysis model constants) sourced from peer-reviewed literature with full citations. Input parameter table provided in technical report TR-2024-011. Formal uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample documentation reviewed and accepted.",
      "rationale": "FDA GCBP experimental data sourced from published FDA benchmark study (Hariharan et al., 2011) with n=3 replicate experiments per operating point. Sample size and variability characterization not formally assessed at MRL 2. Coefficient of variation in experimental NIH measurements: 6–12% across operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative equivalency argument documented.",
      "rationale": "Qualitative equivalency assessment performed: validation fluid (bovine blood) vs. intended use fluid (human blood) differences in viscosity and red cell fragility noted and bounded. Operating speed and flow rate ranges overlap between validation and COU envelope. Formal equivalency quantification not required at MRL 2."
    }
  ],
