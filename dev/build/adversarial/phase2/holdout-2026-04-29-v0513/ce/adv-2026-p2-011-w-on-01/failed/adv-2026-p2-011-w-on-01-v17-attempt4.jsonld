  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-v-and-v-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out per the MRL 2 requirements matrix. The CFD model is accepted for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device. Validation evidence from the FDA GCBP benchmark provides sufficient confidence in model predictions across the CPB operating envelope relevant to adult patients at 4–6 L/min and 2000–3500 RPM.",
