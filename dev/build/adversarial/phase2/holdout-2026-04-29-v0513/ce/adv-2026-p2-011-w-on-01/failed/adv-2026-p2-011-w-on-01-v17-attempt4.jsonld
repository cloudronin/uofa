  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This unit evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Intended use is bounded to adult patients receiving short-duration CPB support; the model is interrogated at nominal flow rates of 4–6 L/min at 2000–3500 RPM. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-cfd-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/synth/model/fda-gcbp-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-gcbp-piv-experimental-2019",
    "https://uofa.net/synth/data/fda-gcbp-hemolysis-bench-2021"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/gcbp-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison against FDA GCBP benchmark dataset"
    },
    {
      "id": "https://uofa.net/synth/validation/gcbp-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalized index of hemolysis comparison at five operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4048807",
