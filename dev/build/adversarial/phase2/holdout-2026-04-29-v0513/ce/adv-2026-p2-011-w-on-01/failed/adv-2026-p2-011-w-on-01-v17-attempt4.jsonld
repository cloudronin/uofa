  "signature": "ed25519:b4e2d1f3a6c8b0e5d2f4a1c7b9e3d6f0a2c5b8e1d4f7a0c3b6e9d2f5a8c1b4e7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented build and test procedures meeting MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 is used under a validated installation protocol with regression test suite covering laminar and turbulent pipe-flow benchmarks. Version control via Git with tagged releases. All SQA activities satisfy MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification on canonical flows confirms solver implementation is free of coding errors at MRL 2.",
      "rationale": "Method of manufactured solutions applied to 3-D Navier–Stokes solver confirms second-order spatial accuracy. Results published in solver verification report VR-2022-04."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be below 5% on primary QoI (NIH) across the operating envelope.",
      "rationale": "Three-level mesh refinement study (4.2 M, 12.6 M, 37.8 M cells) yields GCI of 2.1% on normalized index of hemolysis at the nominal design point. Achieved level exceeds required level, providing additional margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid properties, rotational speed) must be reproduced in simulation within stated measurement uncertainties.",
      "rationale": "FDA benchmark test conditions replicated: inlet plug flow at 2.5 L/min, fluid viscosity 0.00356 Pa·s (glycerin-water), impeller speed 2500 RPM. Deviations from experimental conditions are within ±2% of measured values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted velocity magnitudes and NIH values must agree with experimental data within combined simulation and measurement uncertainty bands.",
      "rationale": "Velocity magnitude comparisons at five axial planes show mean absolute error of 4.3% relative to PIV data. NIH predictions fall within experimental uncertainty bounds (±15%) at all five operating points assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (NIH) must be a direct or strongly correlated surrogate for the clinical endpoint of hemolysis risk in CPB patients.",
      "rationale": "Normalized index of hemolysis is the regulatory-accepted surrogate for red blood cell damage in rotary blood pumps per FDA guidance. Direct correspondence between NIH and plasma free hemoglobin measurements is established in literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the geometric configuration, fluid properties, and operating range representative of CPB use in adult patients.",
      "rationale": "FDA GCBP geometry is identical to the simulation geometry. Glycerin-water surrogate fluid properties bracket blood viscosity at CPB hematocrit levels. Operating points span 2000–3500 RPM and 3–6 L/min, encompassing the clinical CPB envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-5 for all transport equations; not formally quantified at MRL 2.",
      "rationale": "At MRL 2, formal quantification of iterative solver error is not required. Residuals monitored and confirmed below 1e-6 for continuity and momentum; no divergence observed. Scoped out per MRL 2 requirements matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst competency and simulation setup review not formally scored at MRL 2.",
      "rationale": "MRL 2 does not require formal use-error assessment. Simulation setup reviewed internally by a second analyst. Formal independent audit deferred to higher MRL activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection and constitutive law justification not formally scored at MRL 2.",
      "rationale": "SST k-ω turbulence model selected based on published literature for rotating machinery hemolysis CFD. Formal model-form uncertainty quantification deferred; acceptable at MRL 2 per credibility assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis on uncertain input parameters not required at MRL 2.",
      "rationale": "Key uncertain inputs (fluid viscosity, power-law hemolysis coefficients) identified in uncertainty inventory. Formal sensitivity analysis not performed; deferred to MRL 3 activities. Acceptable per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability not required at MRL 2.",
      "rationale": "FDA benchmark dataset provides single-laboratory measurements. Inter-laboratory variability and sample-size adequacy assessment deferred. Acceptable at MRL 2 per credibility assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment inputs and COU inputs not required at MRL 2.",
      "rationale": "Qualitative assessment confirms glycerin-water surrogate adequately represents blood rheology for NIH prediction purposes. Quantitative equivalency scoring deferred to MRL 3. Acceptable per MRL 2 requirements matrix."
    }
  ],
