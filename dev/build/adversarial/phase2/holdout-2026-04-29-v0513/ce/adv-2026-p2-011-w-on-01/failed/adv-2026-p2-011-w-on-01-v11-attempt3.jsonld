      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented; version control and regression testing in place for the CFD solver used in hemolysis prediction.",
      "rationale": "ANSYS Fluent v19.2 is a commercially validated solver with documented SQA processes. Internal regression test suite covers relevant turbulence and scalar transport modules. Achieves required level 2 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical flows confirm solver implementation is free of coding errors relevant to rotating-frame turbulent flow.",
      "rationale": "Method of manufactured solutions applied to rotating cavity flow confirms second-order spatial accuracy. No anomalous convergence behavior observed. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on the finest two mesh levels.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 8.7M, 17.1M cells). GCI for normalized index of hemolysis = 3.1% between medium and fine meshes. Medium mesh selected for production runs. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) match CFD inlet/outlet conditions within 3% across all validation operating points.",
      "rationale": "FDA benchmark experimental data provides measured flow rates and rotor speeds. Fluid properties (bovine blood viscosity, density) matched within 2.1%. Temperature variation < 1 °C across runs. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
