      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "FDA benchmark experimental dataset accepted as representative; sample characterization beyond published metadata not required at MRL 2.",
      "rationale": "FDA benchmark dataset is publicly available and peer-reviewed. Bovine blood preparation follows ASTM F1841. Sample variability documented in source publication. Level 1 accepted at MRL 2."
    },
    {
