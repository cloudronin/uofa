      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis predicted within 25% of experimental values at each of five operating points.",
      "rationale": "CFD predictions of NIH at all five FDA benchmark operating points fall within 18% of experimental measurements. Velocity field RMSE < 0.08 m/s across PIV planes. Exceeds required level 2; achieves level 3."
    },
    {
