  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control and regression testing in place for solver and post-processing scripts.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially qualified solver with documented QA processes. Internal SQA checklist completed; all regression tests passed prior to production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification on canonical benchmark problems demonstrates expected convergence rates.",
      "rationale": "Lid-driven cavity and Hagen-Poiseuille benchmarks confirm second-order spatial accuracy. Temporal discretization verified against analytical solution for pulsatile pipe flow."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% on hemolysis index QoI for the production mesh.",
      "rationale": "Richardson extrapolation performed on three systematically refined meshes (4.2M, 11.7M, 28.4M cells). GCI for normalised hemolysis index is 2.8%, satisfying the acceptance criterion. Production mesh is 11.7M cells, balancing accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, inlet pressure, fluid temperature, hematocrit) documented and replicated in simulation inputs within stated uncertainty bands.",
      "rationale": "Morrison et al. (2022) report boundary conditions with expanded uncertainties. CFD inlet/outlet BCs set to experimental means; sensitivity to ±1 SD perturbations confirmed negligible effect on hemolysis index ranking."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised hemolysis index prediction within 15% of experimental value at all five validation operating points.",
      "rationale": "Predicted normalised hemolysis index agrees with experimental measurements within 9.4% (max) across all five operating points, satisfying the 15% acceptance criterion. Pressure-head predictions within 3.2%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Modelled QoIs (normalised hemolysis index, shear stress distribution) directly inform the decision to identify worst-case operating conditions for CPB use.",
      "rationale": "Normalised hemolysis index is the primary regulatory metric for CPB pump biocompatibility. Shear stress distribution provides mechanistic insight. Both QoIs are directly linked to the intended decision context described in the Claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic centrifugal pump geometry under CPB-representative flow conditions.",
      "rationale": "Validation dataset uses the FDA benchmark pump geometry with bovine blood at clinically representative flow rates (3–6 L/min) and rotational speeds (2500–3500 RPM), matching the intended CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "At Model Risk Level 2, explicit iterative convergence error quantification beyond residual monitoring is not required. Residuals reduced by six orders of magnitude in all production runs, consistent with MRL 2 expectations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records sufficient.",
      "rationale": "Simulation analysts hold documented CFD training credentials. Formal use-error analysis not required at MRL 2 per ASME V&V 40 Table 1 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; selection of turbulence and hemolysis sub-models documented with literature justification.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model selected based on published benchmark studies. Formal model-form uncertainty quantification deferred to MRL 3 activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal material properties and boundary conditions documented.",
      "rationale": "Blood viscosity modelled as Newtonian at 37°C with standard literature values. Non-Newtonian sensitivity study performed informally; results not materially different. Full input uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample characterisation documented in source publication.",
      "rationale": "Morrison et al. (2022) report hematocrit, donor demographics, and sample preparation protocol. Statistical analysis of inter-sample variability not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of experimental to simulation inputs documented.",
      "rationale": "Qualitative equivalency assessment confirms experimental and simulation input parameters are consistent. Quantitative equivalency metrics not required at MRL 2 per ASME V&V 40 Table 1."
    }
