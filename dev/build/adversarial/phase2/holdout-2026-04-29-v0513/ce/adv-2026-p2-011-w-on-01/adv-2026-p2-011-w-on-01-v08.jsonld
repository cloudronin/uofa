  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This unit evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. The intended use scope — identifying worst-case operating points for a 1.5–7 L/min flow range, 2000–3500 RPM impeller speed, blood viscosity 0.0035 Pa·s — is described fully in the Claim and Requirement nodes referenced below. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/morrison/req/hemolysis-worst-case-cpb",
  "bindsClaim": "https://uofa.net/morrison/claim/cfd-hemolysis-cpb-mrl2",
  "bindsModel": "https://uofa.net/morrison/model/fda-centrifugal-bp-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-cbp-piv-experimental-2021",
    "https://uofa.net/morrison/data/fda-cbp-hemolysis-bench-2022"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data — mean NIH within 12% across all operating points"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements — RMS error < 8% of bulk velocity"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4054544",
  "wasAttributedTo": "https://uofa.net/morrison/org/computational-biofluid-dynamics-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f8c21d047b6e95d1f2a84c3b7e0d56f9a1c4e2b8d3f07a5c9e1b6d4f2a8c3e",
  "signature": "ed25519:b7d4e2a9f1c6b3e8d0a5f2c9e4b1d7a3f6c0e8b5d2a9f4c1e7b0d3a6f9c2e5b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver (ANSYS Fluent 2022R2) must hold ISO 9001 certification and a documented V&V test suite covering incompressible rotating-frame flows.",
      "rationale": "ANSYS Fluent 2022R2 is ISO 9001 certified. The vendor-supplied verification test suite includes 47 rotating-frame incompressible cases. Internal SQA log ref. SQA-2022-FL-047 confirms all regression tests pass. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated second-order spatial convergence on canonical rotating-cavity benchmark per ASME V&V 20.",
      "rationale": "Grid convergence study on a rotating lid-driven cavity at Re=1000 confirms observed order of accuracy p=1.94±0.08, consistent with second-order discretisation. Richardson extrapolation applied. Code verification requirement satisfied at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH hemolysis index must be below 5% on the production mesh.",
      "rationale": "Three systematically refined meshes (2.1M, 6.8M, 18.4M cells) used. GCI for NIH = 2.3% between medium and fine meshes. Production mesh is the 6.8M-cell configuration. Discretization error is well-controlled; Gradation 3 achieved, exceeding the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) must be reproduced in simulation within ±2% of measured values.",
      "rationale": "FDA benchmark test conditions (Q=2.5 L/min, 3500 RPM, T=37°C) replicated in CFD within 1.1% for flow rate and 0.3% for speed. Fluid temperature matched via constant-viscosity assumption validated against rheometry data. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH hemolysis index must agree with experimental measurements within 15% across at least 80% of the tested operating points.",
      "rationale": "Across 12 operating points spanning the CPB flow envelope, CFD NIH predictions fall within 12% of experimental values for 11 of 12 points (92%). The single outlier at Q=1.5 L/min, 2000 RPM shows 14.8% deviation, attributed to inlet recirculation not captured by the steady-state solver. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH hemolysis index) must be directly linked to the clinical risk metric (plasma-free hemoglobin rise) specified in the device submission.",
      "rationale": "NIH hemolysis index is the FDA-accepted surrogate for plasma-free hemoglobin elevation in CPB devices. The Requirement node (https://uofa.net/morrison/req/hemolysis-worst-case-cpb) explicitly maps NIH to the 510(k) performance threshold. QoI relevance confirmed at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid analogue, and operating envelope as the intended CPB clinical use.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry (identical to submission geometry), porcine blood at 37°C (accepted CPB analogue), and operating points spanning 1.5–7 L/min / 2000–3500 RPM — the full CPB envelope. Geometric and physiological fidelity confirmed. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; iterative convergence to residuals below 1e-5 documented as sufficient.",
      "rationale": "At MRL 2, explicit solver error quantification beyond residual monitoring is not mandated. All simulations converged to scaled residuals below 1e-5 for all equations. No further assessment required; factor scoped out per MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at MRL 2 for a Class II device credibility evaluation at this risk level. Analyst training records and simulation setup checklists are maintained internally but formal Gradation assessment is deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis power-law model must be justified relative to the flow regime and validated against independent data.",
      "rationale": "SST k-omega turbulence model selected based on literature consensus for confined rotating flows at Re~10^5. Giersiepen power-law hemolysis model calibrated against Heuser & Optiz (1989) data. Model form uncertainty estimated via comparison with Bludszuweit model; NIH difference < 8%. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of NIH to key input parameters (viscosity, power-law exponents, inlet velocity profile) must be quantified with total sensitivity indices.",
      "rationale": "Sobol sensitivity analysis conducted over ±10% ranges for blood viscosity, hemolysis model exponents (α, β), and inlet turbulence intensity. NIH is most sensitive to hemolysis exponent α (S_T=0.61). All inputs sourced from peer-reviewed measurements. Input uncertainty contribution to NIH uncertainty is 6.2%. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; single-lot porcine blood characterisation accepted.",
      "rationale": "MRL 2 does not require multi-lot or inter-laboratory sample characterisation. Single-lot porcine blood rheometry (n=3 replicates) is sufficient. Formal test-sample factor assessment deferred per MRL 2 scoping guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal equivalency mapping between validation experiment inputs and clinical-use inputs is not required at MRL 2. Qualitative correspondence is documented in the Claim node (https://uofa.net/morrison/claim/cfd-hemolysis-cpb-mrl2). Quantitative equivalency assessment deferred."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six non-assessed factors are appropriately scoped out under MRL 2 guidance for a Class II CPB device. Hemolysis index predictions agree with FDA benchmark experimental data within 12% across 92% of operating points. The computational model is judged credible for identifying worst-case hemolysis operating conditions within the CPB flow envelope described in the Claim and Requirement nodes. Decision: Accepted.",
