  "signature": "ed25519:b14d09e2f7a3c856d0e49b17f2c3a08e1d5b7f4c2e9a3d06b8f1c4e7a2d5b9c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented V&V test suite and version-controlled release notes; QA level consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R1 used with documented regression test suite covering turbulent internal flow benchmarks. Release notes and solver qualification records reviewed. QA documentation meets Gradation 2 requirements for a Class II device at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark problems relevant to rotating turbomachinery internal flow; order-of-accuracy confirmed for governing equation discretization.",
      "rationale": "ANSYS Fluent code verification benchmarks for rotating reference frame formulations and SST k-omega turbulence closure reviewed. Published NASA turbomachinery benchmark results confirm second-order spatial accuracy. Meets MRL 2 code verification requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on at least two mesh refinement levels.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 9.8M, 21.4M cells). GCI for normalized hemolysis index = 2.1% between medium and fine meshes. Richardson extrapolation confirms asymptotic convergence. Achieved level exceeds MRL 2 requirement; medium mesh (9.8M) selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity, hematocrit) documented with measurement uncertainty; conditions bracketed by simulation operating envelope.",
      "rationale": "Bench hemolysis experiments conducted at 5 L/min, 2500 RPM with bovine blood at 35% hematocrit. Fluid temperature controlled to 37±0.5°C. Inlet flow rate measured with Coriolis meter (±0.5%). All experimental conditions documented and fall within the CPB operating envelope specified in the bound requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index predicted within 20% of experimental mean across all validation operating points; velocity profiles within 15% RMS error.",
      "rationale": "CFD hemolysis index predictions at 5 operating points show mean error of 11.4% relative to experimental measurements. PIV velocity field comparison yields RMS error of 8.7% for axial velocity profiles at mid-plane. Both QoIs meet acceptance criteria. Validation evidence supports model use for worst-case hemolysis identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index (NIH) and scalar shear stress distribution are directly linked to the device decision question of identifying worst-case hemolysis operating conditions.",
      "rationale": "The primary QoI — normalized index of hemolysis — is the accepted metric for blood damage assessment in CPB devices per ASTM F1841. Scalar shear stress distribution provides mechanistic insight into hemolysis hot-spots. Both QoIs are directly relevant to the decision question stated in the bound requirement and claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the FDA generic centrifugal blood pump geometry under CPB-representative flow conditions; fluid properties and operating range consistent with intended clinical use.",
      "rationale": "Validation experiments performed on the identical FDA GCBP geometry using bovine blood under CPB-representative conditions. Operating points span 3–6 L/min and 1750–3500 RPM, bracketing the intended clinical envelope. Validation activities are sufficiently representative of the intended use described in the bound requirement and claim prose."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "Not assessed at MRL 2 for Class II device; commercial solver iterative convergence monitoring deemed sufficient.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond iterative residual monitoring is not required. Residuals converged to 1e-5 for all equations. Scoped out per MRL 2 assessment framework."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation performed by experienced analysts with documented training records.",
      "rationale": "Simulation team holds documented CFD training credentials and followed internal SOPs for meshing and solver setup. Formal use error analysis scoped out as not required at MRL 2 for this device class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified for rotating internal flow; hemolysis power-law model form documented with literature support.",
      "rationale": "SST k-omega turbulence model selected based on published comparative studies for centrifugal pump internal flows showing superior near-wall accuracy. Giersiepen power-law hemolysis model adopted per FDA guidance and literature precedent. Model form uncertainty acknowledged and consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood viscosity, density, and hemolysis model constants sourced from peer-reviewed literature with documented uncertainty ranges; geometry based on FDA-published GCBP CAD.",
      "rationale": "Fluid properties (viscosity 0.0035 Pa·s, density 1060 kg/m³) taken from published literature with documented variability. Hemolysis model constants (C=3.62e-5, α=2.416, β=0.785) from Giersiepen et al. Geometry imported directly from FDA-published GCBP STL file. Input uncertainty consistent with MRL 2 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "Not assessed at MRL 2; single blood source with documented hematocrit acceptable for screening-level hemolysis assessment.",
      "rationale": "Experimental hemolysis measurements used bovine blood from a single source at controlled hematocrit. Statistical variability across blood samples not characterized. Scoped out as not required at MRL 2 for worst-case identification rather than absolute hemolysis quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "Not assessed at MRL 2; validation experiment boundary conditions confirmed to match simulation inputs within documented measurement uncertainty.",
      "rationale": "Simulation boundary conditions set to match experimental conditions within measurement uncertainty. Formal equivalency analysis of input parameter distributions scoped out as not required at MRL 2. Correspondence between experimental and simulation inputs documented in the validation report."
    }
  ],
