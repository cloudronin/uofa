    {
      "id": "https://uofa.net/synth/validation/gcbp-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "FDA GCBP hemolysis index comparison — CFD vs. experimental bench data at 5 operating points"
    },
    {
      "id": "https://uofa.net/synth/validation/gcbp-velocity-vr-02",
      "type": "ValidationResult",
      "name": "FDA GCBP velocity field PIV comparison — mid-plane axial and radial velocity profiles"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4054689",
