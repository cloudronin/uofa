  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for Model Risk Level 2. The 6 non-assessed factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 3. The CFD hemolysis model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device. Validation evidence from the FDA generic centrifugal pump benchmark provides adequate coverage of the intended operating envelope. The assessment team accepts the model for the stated decision-making purpose.",
