  "signature": "ed25519:b1e4a7f2c9d305e8a6b3f1c0d4e7a2b5c8f3e6a9d2b5e8f1c4a7d0b3e6a9f2c5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite with regression testing; version control and release notes required at MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 was used with documented V&V test suite covering incompressible Navier-Stokes benchmarks. Version control records and release notes confirm compliance with MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via at least one benchmark problem with known analytical or highly accurate reference solution relevant to rotating machinery flow.",
      "rationale": "Solver verified against Taylor-Couette flow and lid-driven cavity benchmarks at Reynolds numbers representative of CPB impeller passages. Observed order of accuracy consistent with second-order discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; GCI on fine-to-medium refinement must be below 5% at the nominal operating point.",
      "rationale": "Three-level mesh refinement study (4.2M, 9.8M, 21.4M cells) performed at 5 L/min, 2500 RPM. GCI fine = 2.8% for normalized index of hemolysis. Asymptotic range confirmed with apparent order p = 1.94."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty bounds on flow rate (±3%), rotational speed (±1%), and fluid temperature (±1°C); test fluid must be specified.",
      "rationale": "FDA benchmark experimental data (Hariharan et al.) provides fully documented test conditions: bovine blood analog (35% hematocrit), flow rate ±2.1%, speed ±0.8%, temperature 37±0.5°C. Conditions span the CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty Uval) reported for primary QoI; agreement within combined experimental and numerical uncertainty.",
      "rationale": "Normalized index of hemolysis compared at 6 operating points. Mean absolute error 8.3% with validation uncertainty Uval = 12.1%. Agreement within Uval at 5 of 6 points; one outlier at low-flow high-speed condition attributed to documented transitional flow effects. Exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (normalized index of hemolysis, scalar shear stress) must be directly linked to the clinical decision metric of worst-case hemolysis identification.",
      "rationale": "Normalized index of hemolysis is the regulatory-accepted metric per FDA guidance for CPB device hemolysis assessment. Scalar shear stress serves as mechanistic intermediate QoI. Both QoIs are directly relevant to the intended decision of worst-case operating point identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the flow rate and speed range relevant to CPB operation (2–6 L/min, 1500–3500 RPM) with the FDA generic pump geometry.",
      "rationale": "FDA benchmark dataset covers 3–6 L/min at 2000–3500 RPM using the FDA generic centrifugal pump, which shares geometric similarity with the target device class. Extrapolation to 2 L/min assessed as low risk given validated model behavior at boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative convergence monitoring to residual levels below 1e-5 for all equations is sufficient; formal round-off error analysis not required.",
      "rationale": "Iterative convergence confirmed to residual levels 1e-6 for all transport equations. Formal numerical solver error quantification beyond convergence monitoring is not required at MRL 2 and has not been performed; this is acceptable per the scoping decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documented simulation protocol with peer review of boundary condition setup is sufficient; formal use-error analysis not required.",
      "rationale": "Simulation setup reviewed by two independent analysts per internal protocol. Formal use-error quantification is not required at MRL 2 and has been scoped out of this assessment consistent with the model risk level determination."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified for rotating blood pump flows; hemolysis power-law model constants must be cited from peer-reviewed literature.",
      "rationale": "SST k-omega turbulence model selected based on documented performance for rotating impeller flows in the literature. Giersiepen-Wurzinger hemolysis power-law constants (C=3.62e-5, alpha=2.416, beta=0.785) applied as per FDA-cited references. Model form uncertainty acknowledged and bounded by validation comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood viscosity, density, and hematocrit used as model inputs must be documented with sources; sensitivity to ±10% variation in viscosity must be reported.",
      "rationale": "Blood analog properties (density 1056 kg/m³, dynamic viscosity 0.0035 Pa·s at 37°C, 35% hematocrit) sourced from FDA benchmark documentation. Sensitivity analysis: ±10% viscosity variation produces ±4.2% change in hemolysis index, within acceptable bounds for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use of a single well-characterized reference pump geometry is acceptable; statistical characterization of geometric variability across pump samples is not required.",
      "rationale": "FDA generic pump geometry is a single reference geometry used across the validation dataset. Sample-to-sample geometric variability characterization is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative mapping of validation conditions to intended use conditions is sufficient; formal equivalency metric not required.",
      "rationale": "Qualitative mapping confirms that FDA benchmark operating conditions overlap substantially with the CPB clinical use envelope. Formal equivalency scoring is not required at MRL 2 and has been deferred consistent with the model risk level determination."
    }
  ],
