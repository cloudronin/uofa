  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold a documented quality management record with version control and regression testing appropriate for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 was used with documented version control, regression test suite results, and institutional SQA records. All MRL 2 SQA requirements are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark test cases documented at MRL 2 level.",
      "rationale": "Code verification performed against ASME V&V 20 benchmark cases for incompressible Navier-Stokes. Published verification reports for Fluent 2022R2 confirm correct discretisation of momentum and continuity equations. MRL 2 threshold met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary hemolysis QoI using at least three systematically refined meshes.",
      "rationale": "Richardson extrapolation and GCI analysis performed on three meshes (4.2M, 9.8M, 21.3M cells). GCI for normalised index of hemolysis at worst-case operating point was 1.8%, below the 5% MRL 2 threshold. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to confirm overlap with the CPB operating envelope.",
      "rationale": "FDA generic centrifugal pump experiments were conducted at 2500 and 3500 RPM across 3–6 L/min, matching the CPB operating envelope described in the Requirement node. Temperature, fluid viscosity, and haematocrit are documented in the experimental protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalised RMS error or validation uncertainty) must be reported for the hemolysis QoI.",
      "rationale": "Normalised index of hemolysis predictions agree with experimental measurements within combined validation uncertainty (U_val = ±12%). Systematic bias of 4.3% is within MRL 2 acceptance band. Output comparison documented in validation report VR-2024-03."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (normalised index of hemolysis, shear stress) must be directly traceable to the clinical decision question of identifying worst-case hemolysis conditions.",
      "rationale": "Normalised index of hemolysis is the direct regulatory QoI for CPB device hemolysis assessment per FDA guidance. Shear stress distribution is the mechanistic driver. Both QoIs are explicitly linked to the worst-case identification decision in the Claim node."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry and within the same operating envelope as the intended computational use.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry — identical to the computational model — at CPB-representative flow rates and rotational speeds. Fluid analogue (glycerol-water with ovine red blood cells) matches the haematocrit range of clinical CPB. Relevance is high for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit iterative convergence reporting to below 1e-5 residual is sufficient; separate solver error quantification is not required.",
      "rationale": "Residual convergence to 1e-6 for all transport equations was confirmed in all simulations. Separate numerical solver error analysis beyond residual monitoring is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a documented simulation execution checklist is sufficient to address use error; formal use-error analysis is not required.",
      "rationale": "Simulation execution followed a documented internal checklist reviewed by a second analyst. Formal use-error analysis is out of scope at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence and hemolysis model forms must be justified by literature evidence appropriate to the CPB flow regime (Re, shear rates).",
      "rationale": "SST k-omega turbulence model selected based on literature evidence for rotating confined flows at Re ~ 10^4–10^5. Giersiepen-Wurzinger power-law hemolysis model applied with Arora modification for accumulative damage. Model form choices are documented and peer-reviewed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, boundary conditions, fluid properties) must be traceable to measurement data or published reference values with stated uncertainty.",
      "rationale": "Pump geometry derived from FDA-published CAD files. Boundary conditions (inlet flow, outlet pressure, rotational speed) set to experimental values with stated measurement uncertainty. Blood analogue viscosity measured at 37°C ± 0.5°C. Full input traceability table provided in simulation data package SDP-2024-01."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of sample source and preparation method is sufficient; statistical sample characterisation is not required.",
      "rationale": "Ovine blood source, anticoagulation protocol, and haematocrit adjustment procedure are documented in the experimental protocol EP-2023-07. Statistical characterisation of inter-sample variability is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative confirmation that computational input parameters match experimental conditions is sufficient.",
      "rationale": "Computational boundary conditions were set to match experimental measurements directly. Formal equivalency analysis (e.g., sensitivity-weighted parameter matching) is not required at MRL 2 and has not been performed."
    }
  ],
