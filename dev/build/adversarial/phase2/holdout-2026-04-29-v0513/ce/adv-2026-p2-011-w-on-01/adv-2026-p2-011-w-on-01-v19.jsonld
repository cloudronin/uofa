  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented test suite; all regression tests passing for hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with documented V&V test suite. Version control and release notes confirm regression testing for turbulent rotating-frame flows. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark cases for the governing equations employed.",
      "rationale": "Developer-supplied manufactured-solution benchmarks confirm second-order spatial accuracy for the pressure-velocity coupling and turbulence equations used in this analysis. Achieved level meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the primary QoI (NIH) at the nominal operating point.",
      "rationale": "Three-level mesh refinement study (4.2M, 9.8M, 21.4M cells) yields GCI of 3.1% for NIH at 5 L/min, 100 mmHg. Richardson extrapolation confirms monotonic convergence. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow, outlet pressure, fluid temperature, rotor speed) documented with uncertainty bounds and reproduced in the CFD setup.",
      "rationale": "FDA bench test conditions are fully documented in the referenced dataset. CFD boundary conditions match bench conditions within measurement uncertainty. Temperature-dependent viscosity and density of porcine blood surrogate are matched. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty Uval) computed for NIH; model error within combined experimental and numerical uncertainty.",
      "rationale": "Mean absolute error in NIH across 5 validation operating points is 8.3%, within the combined validation uncertainty of 12.7% (95% CI). PIV velocity magnitude RMSE is 0.04 m/s against a mean flow velocity of 1.8 m/s. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, velocity magnitude) are the same quantities used in the clinical decision context.",
      "rationale": "NIH is the regulatory-accepted hemolysis metric for CPB device submissions. Velocity field is directly linked to shear-stress-based hemolysis models. QoIs in validation are identical to those in the intended decision context. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the same geometry, flow regime (Reynolds number range), and fluid properties as the intended CPB operating envelope.",
      "rationale": "Validation experiments were conducted on the same FDA generic centrifugal pump geometry across the full CPB operating envelope (2–8 L/min, 1500–3500 RPM). Reynolds numbers and blood analog properties match the COU scope as described in the bound requirement. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 beyond code verification already captured under Numerical code verification factor.",
      "rationale": "At MRL 2, separate quantification of iterative and round-off solver errors is not required. Code verification (separate factor) addresses solver correctness. This factor is not assessed per the MRL 2 assessment plan."
    },
    {
