      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample provenance documented in the experimental dataset record.",
      "rationale": "Blood analog fluid (porcine blood) provenance and preparation protocol are documented in the FDA experimental dataset record. Statistical characterization of sample variability is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
