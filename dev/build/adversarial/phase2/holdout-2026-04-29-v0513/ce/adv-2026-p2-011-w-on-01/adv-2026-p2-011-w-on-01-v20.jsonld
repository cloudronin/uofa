  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with pass rate ≥ 95% for relevant benchmark cases; version control and release notes required.",
      "rationale": "ANSYS Fluent 2022 R2 was used; FDA CDRH has independently benchmarked this solver for blood pump CFD. Release documentation, regression test results, and version control records were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions or equivalent benchmark with demonstrated convergence to analytical solution.",
      "rationale": "Solver vendor provides method-of-manufactured-solutions verification results for incompressible Navier-Stokes equations demonstrating second-order spatial convergence. Results are consistent with published literature and meet the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (hemolysis index) using at least three systematically refined meshes; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study was performed (2.1M, 5.8M, 14.3M cells). Richardson extrapolation yielded GCI of 2.1% for hemolysis index on the fine mesh, exceeding the MRL 2 acceptance threshold and achieving MRL 3 performance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented with measurement uncertainty; conditions must span the CPB operating envelope.",
      "rationale": "FDA GCBP experimental dataset documents flow rates from 2 to 7 L/min and impeller speeds from 2000 to 3500 RPM. Measurement uncertainties for flow rate (±0.05 L/min) and pressure rise (±2 mmHg) are reported. Conditions adequately span the CPB operating envelope relevant to worst-case hemolysis screening."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) computed between simulation and experimental hemolysis index; metric must be below 20% for MRL 2.",
      "rationale": "Normalized RMS error between simulated and measured hemolysis index across five operating points is 11.4%, within the MRL 2 acceptance band. Systematic over-prediction at high shear rates is noted and bounded by sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (hemolysis index) must be directly linked to the clinical endpoint of red blood cell damage; secondary QoIs (wall shear stress, scalar dissipation rate) must be documented.",
      "rationale": "Hemolysis index derived from the Giersiepen-Wurzinger power-law model is the primary QoI and is directly correlated with plasma-free hemoglobin measurements used in ISO 10993-4 biocompatibility assessment. Secondary QoIs (volume-averaged shear stress, recirculation zone volume) are documented in the validation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid (bovine blood or analogue), and operating range as the intended COU; any differences must be documented and justified.",
      "rationale": "Validation was performed on the FDA GCBP geometry using bovine blood at physiological hematocrit (35%). The COU targets the same geometry class and overlapping operating range. Differences in blood rheology between bovine and human blood are documented and bounded by a ±8% sensitivity on hemolysis index."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category; iterative convergence to residuals below 1e-5 is sufficient.",
      "rationale": "At MRL 2, formal solver error quantification beyond iterative convergence monitoring is not required. Residuals converged to below 1e-6 for all equations; this is documented in the simulation log files and is consistent with MRL 2 expectations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation setup review by a second analyst is sufficient.",
      "rationale": "Independent setup review was conducted by a second CFD analyst who confirmed boundary condition assignments, turbulence model selection (SST k-omega), and hemolysis model constants. Formal use-error quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations and constitutive models (turbulence, hemolysis power law) must be documented with literature justification; model form uncertainty must be bounded.",
      "rationale": "SST k-omega turbulence model is justified by its established performance in rotating machinery with adverse pressure gradients. The Giersiepen-Wurzinger hemolysis model constants are taken from published calibration studies. Model form uncertainty is bounded at ±15% via comparison with alternative hemolysis model formulations (Taskin et al.)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry tolerances, fluid viscosity, density, boundary condition values) documented with sources and uncertainty ranges.",
      "rationale": "Geometry was reconstructed from FDA-published CAD files with dimensional tolerances of ±0.05 mm. Blood viscosity (3.5 mPa·s) and density (1060 kg/m³) are taken from published physiological references with documented uncertainty ranges. Inlet velocity profiles are derived from flow meter measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for a generic pump geometry assessment; FDA GCBP dataset is treated as a reference standard.",
      "rationale": "The FDA GCBP is a generic reference geometry, not a specific manufactured device; sample-to-sample variability is not applicable. The published experimental dataset is treated as the reference standard for this credibility assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of simulation inputs to experimental conditions is sufficient.",
      "rationale": "Simulation boundary conditions (flow rate, rotational speed, outlet pressure) were set to match experimental test conditions within measurement uncertainty. Formal equivalency quantification is not required at MRL 2; qualitative mapping is documented in the validation report."
    }
  ],
