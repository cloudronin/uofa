  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are consistent with MRL 2 scoping decisions and are supported by documented rationale. The CFD hemolysis model is accepted for use in identifying worst-case operating conditions for the FDA GCBP as a Class II CPB device. The normalized RMS error of 11.4% on hemolysis index, combined with bounded model form uncertainty of ±15%, is deemed adequate for the screening purpose described in the claim and requirement documentation. No material weakeners were identified during review.",
