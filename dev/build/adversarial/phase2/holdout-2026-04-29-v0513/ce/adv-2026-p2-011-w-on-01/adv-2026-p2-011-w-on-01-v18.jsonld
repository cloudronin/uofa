  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression test suite, and documented build procedures must be in place consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 used under ISO 9001-certified quality management system. Version-controlled solver with documented regression tests covering turbulent pipe flow and rotating machinery benchmarks. Build and release procedures audited internally. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Published benchmark solutions or manufacturer verification documentation demonstrating correct implementation of governing equations at MRL 2.",
      "rationale": "ANSYS Fluent code verification relies on published NASA turbulence benchmark cases and ASME V&V 20 pipe flow verification suite. Manufacturer verification documentation for the k-omega SST turbulence model and rotating reference frame formulation reviewed and found adequate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrating discretization error below 5% for hemolysis index QoI at the nominal operating point.",
      "rationale": "Richardson extrapolation performed across three systematically refined meshes (4.2M, 8.7M, 17.1M cells). Grid convergence index (GCI) for hemolysis index at 2500 RPM, 5 L/min: 2.3%. Achieved level 3 exceeds required level 2, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with sufficient detail to confirm alignment with simulated boundary conditions, including fluid properties, rotational speed, and inlet/outlet pressure.",
      "factorRationale": "In-vitro hemolysis experiments conducted with bovine blood at 37°C, hematocrit 33±2%, using modified index of hemolysis (MIH) protocol per ASTM F1841. Rotational speeds and flow rates match CFD boundary conditions within measurement uncertainty. Test conditions documented in laboratory notebook LN-2023-CPB-07."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for hemolysis index QoI, with agreement within acceptance band consistent with MRL 2.",
      "rationale": "Normalised hemolysis index error E% computed at 6 operating points spanning the CPB envelope. Mean E% = 8.4%, maximum E% = 14.2% at the 3500 RPM, 3 L/min corner condition. Validation metric accounts for combined experimental and numerical uncertainty. Agreement is consistent with MRL 2 acceptance threshold of ±20%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented traceability from clinical endpoint (haemolysis-related adverse events) to computational QoI (normalised index of hemolysis, NIH) demonstrating that the QoI is a clinically relevant surrogate.",
      "rationale": "NIH is the accepted regulatory surrogate for haemolysis in CPB devices per FDA guidance and ISO 10993-4. Traceability documented from patient plasma free haemoglobin thresholds through ASTM F1841 MIH to CFD-predicted NIH. QoI relevance confirmed by clinical literature review (Leverett 1972, Giersiepen 1990, Goubergrits 2004)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic centrifugal blood pump geometry at CPB-representative operating conditions, confirming that the validation domain overlaps sufficiently with the intended prediction domain.",
      "rationale": "All validation experiments performed on the identical FDA GCBP geometry used in the regulatory submission model. Operating conditions span the CPB envelope (3–7 L/min, 2000–3500 RPM). Fluid properties matched to clinical CPB prime composition. Validation domain assessed as representative of the prediction domain for the intended regulatory use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 beyond code verification already captured under Numerical code verification factor.",
      "rationale": "At MRL 2, separate quantification of numerical solver error beyond the code verification activities is not required. This factor is not assessed; the code verification factor addresses solver correctness at the level appropriate for this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification and review procedures are addressed through the software quality assurance factor.",
      "rationale": "Formal use-error quantification is not required at MRL 2. Analyst competency is controlled through the SQA framework. This factor is scoped out of the quantitative assessment and accepted as not-assessed for MRL 2 compliance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form adequacy is implicitly evaluated through the output comparison and relevance factors.",
      "rationale": "Explicit model form uncertainty quantification is not required at MRL 2. The k-omega SST turbulence model selection is justified by literature precedent for rotating blood pump flows. Model form adequacy is indirectly confirmed by the output comparison results. Not assessed as a standalone factor at this MRL."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input parameter sensitivity is addressed qualitatively through engineering judgement and literature review.",
      "rationale": "Formal model input uncertainty propagation is not required at MRL 2. Blood viscosity and density inputs are set to nominal values from ASTM F1841 protocol. Sensitivity to hematocrit variation is addressed qualitatively based on published literature. Not assessed as a standalone quantitative factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterisation is documented in the experimental test conditions factor.",
      "rationale": "Detailed statistical characterisation of test sample variability is not required at MRL 2. Bovine blood donor variability is controlled through the ASTM F1841 preparation protocol. Sample adequacy is addressed within the test conditions factor documentation. Not assessed as a separate standalone factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency between validation experiment inputs and COU prediction inputs is addressed qualitatively through the relevance of validation activities factor.",
      "rationale": "Formal equivalency mapping of all input parameters between the validation and prediction domains is not required at MRL 2. The relevance of validation activities factor confirms that the validation operating conditions are representative. Equivalency of input parameters is not assessed as a standalone quantitative factor at this MRL."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-hemolysis-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cvs-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 1 requirements. The CFD model is accepted as credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions in support of 510(k) regulatory submission. The claim that the model can rank operating points by hemolysis severity within the CPB envelope is supported by the validation evidence.",
