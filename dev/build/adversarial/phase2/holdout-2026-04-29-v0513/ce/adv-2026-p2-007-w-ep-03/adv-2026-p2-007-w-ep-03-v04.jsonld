  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped as not-assessed per MRL 2 requirements. The experimental dataset (dataVintage 2025-10-22) predates the model revision (2025-11-14) by 23 days; the assessment team documented a determination that the mesh topology update in the volute region did not alter the physical boundary conditions or fluid property inputs drawn from the dataset, and therefore no re-acquisition of experimental data was deemed necessary. The relative hemolysis index RH is below 1.0 at all five operating points, satisfying the regulatory acceptance criterion. Credibility package is accepted for submission in support of 510(k) hemolysis comparison.",
