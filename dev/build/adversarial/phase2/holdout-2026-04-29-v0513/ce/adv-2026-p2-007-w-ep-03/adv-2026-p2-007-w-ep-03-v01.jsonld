  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements. The November 2025 model revision (v2r2 to v2r3) adjusted the SST k-omega C-mu coefficient by 2.4% to improve impeller-passage turbulence predictions. The assessment team concluded this change was not material to the experimental dataset (dataVintage 2025-10-14) because the dataset captures geometric and fluid-property inputs that are independent of turbulence closure. No formal re-validation was performed against v2r3; the team relied on sensitivity analysis showing less than 1% change in predicted RH index when C-mu was varied across its published uncertainty range. The overall credibility assessment supports an Accepted decision for the COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
