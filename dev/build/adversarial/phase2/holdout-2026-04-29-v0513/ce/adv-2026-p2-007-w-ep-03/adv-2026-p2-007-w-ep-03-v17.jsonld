  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2023 R2 used under institutional software quality plan. Version control confirmed; regression suite of 47 canonical cases executed with zero failures. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass manufactured-solution or benchmark verification for rotating-frame turbulent flow relevant to centrifugal pump geometry.",
      "rationale": "Method of manufactured solutions applied to rotating-reference-frame Navier-Stokes equations. Observed order of accuracy 1.94 (target ≥ 1.8). Code verification complete and documented in solver QA report QA-2023-R2-007."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH quantity of interest must be ≤ 5% at the operating point of maximum hemolysis.",
      "rationale": "Three-level mesh refinement study performed (1.8 M, 5.4 M, 14.2 M cells). GCI for NIH at worst-case operating point: 3.1%. Richardson extrapolation confirms asymptotic convergence. Discretization error is within the accepted threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate, temperature) must be documented with measurement uncertainty and must match simulation boundary conditions within stated tolerances.",
      "rationale": "FDA benchmark experimental conditions (Hariharan et al., 2011) used. Blood analogue fluid viscosity 0.00356 Pa·s ± 2%, density 1056 kg/m³ ± 0.5%. Rotational speeds and flow rates matched to within 1.2% of nominal. Temperature maintained at 37 ± 0.5 °C. All conditions replicated in CFD boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within 15% across all 5 operating conditions; RH < 1 criterion must be satisfied.",
      "rationale": "NIH predictions compared against FDA benchmark measurements. Errors: 4.1%, 6.3%, 8.7%, 11.2%, 5.9% across the five operating points. All within 15% threshold. RH computed as 0.87 (worst case), satisfying RH < 1. Output comparison criterion met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modelled quantities of interest (NIH, wall shear stress, exposure time) must be directly traceable to the clinical hemolysis risk metric used in the submission decision.",
      "rationale": "NIH is the FDA-recognised hemolysis metric for CPB device submissions. Wall shear stress and scalar exposure time are intermediate quantities feeding the power-law hemolysis model (Giersiepen et al.). Traceability chain from CFD output to RH acceptance criterion is fully documented in the V&V plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating range, and fluid analogue as the COU; any differences must be bounded and shown not to materially affect NIH predictions.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump — the same geometry used in the COU. Operating envelope (2–6 L/min, 2500–3500 RPM) spans the five COU operating points. Blood analogue fluid matches COU specification. Geometry and operating-condition relevance rated high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-5 for all transport equations; mass imbalance below 0.01%.",
      "rationale": "Not assessed as a standalone factor at MRL 2; solver residual monitoring is subsumed within the discretization error and code verification assessments. Residuals confirmed below 1e-6 during mesh convergence study as incidental evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second qualified analyst; checklist-based review documented.",
      "rationale": "Formal use-error assessment not required at MRL 2 per ASME V&V 40-2018 Table 3. Informal peer review of solver settings conducted but not documented to the level required for a full use-error assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis constitutive model justified relative to COU flow regime.",
      "rationale": "Model form assessment scoped out at MRL 2. SST k-ω turbulence model selected based on published literature for centrifugal pump hemolysis CFD; Giersiepen power-law hemolysis model is the FDA-recommended approach. Justification documented in model description report but not assessed to full MRL 3 standard."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, boundary conditions, fluid properties, hemolysis model coefficients) documented with sources and uncertainty ranges; sensitivity analysis performed for parameters with uncertainty > 5%.",
      "rationale": "Input parameters sourced from FDA benchmark documentation and manufacturer geometric tolerances. Hemolysis model coefficients (α = 3.62×10⁻⁷, β = 2.416, γ = 0.785) taken from Giersiepen et al. as implemented in the simulation dataset ds002. Sensitivity analysis performed for inlet flow rate (±5%) and rotational speed (±2%); NIH sensitivity < 3% for both. The boundary-condition dataset (ds002) carries dataVintage 2025-10-22T00:00:00Z, predating the model revision on 2025-11-14T00:00:00Z. The revision updated the impeller tip-clearance geometry by 0.05 mm to reflect as-manufactured tolerances; the assessment team determined this change was not material to the hemolysis model coefficients or inlet boundary profiles, and the dataset was therefore carried forward without formal re-validation. This judgment has not been independently verified against updated simulation outputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Physical test samples characterised for dimensional conformance to nominal geometry within specified tolerances.",
      "rationale": "Test sample characterisation not required at MRL 2. FDA benchmark pump geometry treated as nominal; dimensional deviations in physical test articles not independently measured for this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and COU simulation inputs documented and reviewed.",
      "rationale": "Formal equivalency assessment not required at MRL 2. Qualitative correspondence between validation and COU inputs documented in the V&V plan; quantitative equivalency mapping deferred to MRL 3 activities."
    }
