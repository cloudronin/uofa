  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements per ASME V&V 40-2018 Table 3. The relative hemolysis index RH = 0.87 < 1.0 across all five operating conditions, satisfying the acceptance criterion. The model revision of 2025-11-14 introduced a minor geometric update (tip-clearance adjustment of 0.05 mm) that the assessment team judged not material to the boundary-condition dataset (dataVintage 2025-10-22) used for the model inputs factor. On this basis, the credibility package is accepted and the CFD model is considered fit for the stated COU at Medium assurance level.",
