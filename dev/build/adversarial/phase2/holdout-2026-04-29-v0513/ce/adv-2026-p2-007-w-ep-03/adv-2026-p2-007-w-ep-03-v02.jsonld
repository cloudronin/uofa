  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. The six not-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 3. The primary experimental dataset (dataVintage 2025-10-22) predates the model revision of 2025-11-14 by approximately three weeks; however, the assessment team determined that the revision — which modified only the near-wall turbulence damping coefficient from 0.09 to 0.085 — does not materially affect the experimental reference values, which are independent of model formulation. No formal re-validation was conducted against a post-revision simulation baseline. The CFD model is judged credible for its intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
