  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. The six not-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 3. The primary validation dataset (dataVintage 2025-10-08) predates the model revision of 2025-11-03 by 26 days; however, the assessment team determined that the revision — limited to impeller trailing-edge boundary layer treatment — does not alter the flow physics governing bulk hemolysis index prediction, and that re-validation against a post-revision dataset is therefore not required. On this basis, the credibility assessment is accepted at Medium assurance level for the stated COU.",
