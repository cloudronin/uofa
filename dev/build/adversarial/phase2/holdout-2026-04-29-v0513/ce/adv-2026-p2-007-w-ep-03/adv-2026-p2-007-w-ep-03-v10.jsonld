  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped to not-assessed per MRL 2 requirements. CFD hemolysis predictions satisfy the RH < 1 acceptance criterion at all 5 operating points with MAE of 0.041 RH units. The November 2025 turbulence-model coefficient update (modelRevisionDate 2025-11-03) was reviewed and judged by the assessment team to be not material to the primary validation dataset DS01 (dataVintage 2025-10-10), as the update affected only SST k-omega closure constants and the experimental measurements in DS01 are geometry- and flow-rate-dependent quantities independent of solver turbulence closure. On this basis the team accepted the existing validation evidence without re-running the formal validation campaign. The credibility assessment supports use of the CFD model for the stated COU at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
