  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are not assessed, which is acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The November 2025 model revision (near-wall turbulence treatment refinement) was reviewed by the assessment team and judged not to materially affect the hemolysis QoI or the validity of the experimental comparison dataset collected in October 2025. Formal re-validation against a post-revision dataset was considered but deferred on the basis that the turbulence model change affected only the logarithmic layer formulation in low-shear regions not contributing significantly to the hemolysis power-law integral. The credibility evidence package is accepted as sufficient to support the COU decision.",
    "decidedAt": "2025-12-10T00:00:00Z"
  },
