    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined; mean relative error < 15 % for NIH across all operating points.",
      "rationale": "NIH predicted versus measured at all five operating points; mean relative error 8.3 %, maximum 13.7 %. Comparison performed using dataset morrison-exp-hemolysis-2025q2. The dataset was collected approximately three weeks before model revision v2r3 was finalised; the revision introduced an updated Launder-Sharma low-Reynolds turbulence damping coefficient. The assessment team concluded this change was confined to near-wall boundary layer resolution and would not materially alter bulk NIH predictions, but no supplementary validation run against post-revision experimental data was performed to confirm this judgment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
