  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are not assessed, consistent with MRL 2 scoping. The RH < 1 acceptance criterion is satisfied at all five worst-case operating points. The assessment team noted that the primary experimental hemolysis dataset (morrison-exp-hemolysis-2025q2, vintage 2025-08-22) predates model revision v2r3 (revision date 2025-09-15) by approximately three weeks. The team judged the turbulence-model coefficient update introduced in v2r3 to be non-material to bulk NIH predictions and therefore did not commission a supplementary validation study against post-revision experimental data. This judgment is documented here but has not been independently verified through formal re-validation. The package is accepted at Medium assurance level pending any future regulatory request for re-validation evidence.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
