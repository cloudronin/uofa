  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cv-sim-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements for a Class II device. The output comparison demonstrates RH predictions within combined uncertainty at all operating points. The assessment team acknowledges that the PIV benchmark dataset (dataVintage 2025-10-21) predates the model revision (2025-11-14) by 24 days; engineering change notice ECN-2025-047 documents the team's judgment that the trailing-edge geometry correction does not materially affect inlet boundary condition fidelity. On this basis, the credibility package is accepted without re-collection of boundary condition data against the revised model build.",
    "decidedAt": "2026-04-19T00:00:00Z"
