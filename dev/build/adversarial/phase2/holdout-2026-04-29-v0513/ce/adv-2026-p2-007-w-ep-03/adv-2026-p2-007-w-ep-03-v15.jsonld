  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately scoped out at MRL 2. The PIV benchmark dataset (dataVintage 2025-10-21) predates the model revision of 2025-11-14 by approximately three weeks; however, the assessment team concluded that the turbulence closure update (SST k-ω coefficient recalibration) introduced in model revision v3 does not materially alter the velocity field topology or the hemolysis index predictions against which validation comparisons are drawn, and therefore the existing dataset remains fit for purpose without a formal re-validation exercise. The relative hemolysis index for all five operating points satisfies the RH < 1 acceptance criterion relative to the predicate device. The overall credibility evidence is sufficient to support the COU decision at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
