  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for Model Risk Level 2. Seven factors were formally assessed; six were determined not to require assessment at MRL 2. Of the seven assessed factors, six achieved their required credibility levels with documented evidence. The Discretization error factor was reviewed in detail: while formal Richardson extrapolation was not performed, the team noted that the mesh sensitivity study demonstrated less than 4% variation in the relative hemolysis index between the coarse and medium mesh levels, that published literature supports the adequacy of the mesh density employed, and that the expert panel concurred with the approach during the design review. On this basis, the team concluded that the overall body of evidence is sufficient to support the intended comparative use of the CFD model for identifying worst-case hemolysis operating conditions. All five operating points satisfy the RH < 1 acceptance criterion. The device risk classification (Class II), the medium model influence, and the comparative (rather than absolute) nature of the hemolysis assessment collectively support the conclusion that the simulation results are credible for the stated COU. The assessment is therefore Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
