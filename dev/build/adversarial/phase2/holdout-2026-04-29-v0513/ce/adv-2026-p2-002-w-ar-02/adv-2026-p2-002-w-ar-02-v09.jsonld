  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "CFD solver must have documented verification test suite and release version control consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent v2022R2 is used under a validated installation with documented regression test suite covering laminar, turbulent, and rotating-frame flows. Version control and change logs are maintained in the project repository. Software quality documentation meets MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation through benchmark problems relevant to rotating turbomachinery flows.",
      "rationale": "Code verification was performed against the Taylor-Couette flow benchmark and the ASME V&V 20 pipe flow benchmark. Results confirm second-order spatial accuracy and correct implementation of the SST k-omega turbulence model in rotating reference frames. Published solver validation studies for blood pump CFD provide additional corroboration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "acceptanceCriteria": "Discretization error must be quantified via a systematic mesh refinement study with at least two refinement levels, and the resulting numerical uncertainty must be reported relative to the hemolysis quantity of interest.",
      "rationale": "A mesh sensitivity study was conducted comparing a coarse mesh (2.1 million cells) and a medium mesh (5.8 million cells). Wall shear stress distributions showed qualitative consistency across both levels, and the relative hemolysis index changed by less than 4% between the two meshes at the nominal operating point. The team judged this variation to be within acceptable engineering tolerance for a comparative hemolysis assessment. Furthermore, prior published work using similar mesh densities for centrifugal blood pump CFD (Hariharan et al., 2011; Fraser et al., 2012) demonstrated adequate predictive performance, and the team's collective experience of over 15 pump CFD studies at this mesh density provides strong confidence in the numerical solution quality. Expert panel review during the design phase concurred that the mesh resolution was sufficient for the intended comparative use. Formal Richardson extrapolation and Grid Convergence Index (GCI) computation were not performed, as the team determined that the qualitative convergence evidence, combined with literature precedent and expert judgment, was sufficient to support the MRL 2 assessment. This reasoning, while defensible from a practical standpoint, does not formally satisfy the systematic quantification requirement at the level demanded by the requiredLevel for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to confirm correspondence with CFD boundary conditions.",
      "rationale": "FDA generic pump experimental data were collected under controlled laboratory conditions with documented flow rates (2–6 L/min), rotational speeds (2000–3500 RPM), and blood analog fluid properties. Boundary conditions applied in the CFD model are traceable to the experimental protocol. Temperature, hematocrit, and viscosity were matched within specified tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "CFD-predicted hemolysis index must be compared quantitatively against experimental measurements with documented metrics.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) were computed from CFD predictions and compared against experimental measurements at all 5 operating points. RH values ranged from 0.72 to 0.94 across operating conditions, all below the acceptance threshold of 1.0. Mean absolute error between CFD and experiment was 8.3%, within the 15% tolerance established in the analysis plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The quantities of interest predicted by the CFD model must be directly relevant to the hemolysis risk assessment decision.",
      "rationale": "The primary quantity of interest is the relative hemolysis index (RH), which is a clinically recognized metric for comparative hemolysis assessment in blood-contacting devices. The CFD model predicts scalar stress accumulation along particle trajectories, which is directly used to compute the power-law hemolysis damage model output. The linkage between CFD output and clinical hemolysis risk is well established in the literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must be sufficiently representative of the clinical COU in terms of device geometry, operating conditions, and blood analog properties.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump, which shares the same impeller topology and operating envelope as the device under evaluation. Operating conditions span the clinical CPB range. Blood analog fluid (glycerol-water with matched viscosity) was used in accordance with FDA guidance. The validation domain is directly relevant to the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Numerical solver error beyond code verification is scoped out at MRL 2 per the ASME V&V 40 factor applicability matrix. The code verification factor addresses solver correctness at the required level."
    },
    {
