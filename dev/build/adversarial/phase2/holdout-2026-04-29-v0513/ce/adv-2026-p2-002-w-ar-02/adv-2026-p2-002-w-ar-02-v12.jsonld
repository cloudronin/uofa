  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all 13 credibility factors defined for this COU at Model Risk Level 2. Of the seven formally assessed factors, twelve meet or exceed their required credibility levels. The Model Form factor required level 3 and the assessment produced evidence consistent with level 2; however, the team determined that the combination of (a) strong output comparison agreement across five independent operating points, (b) the use of a ratio-based acceptance metric that cancels systematic model-form bias, and (c) extensive prior published validation of the SST k-omega and Giersiepen-Wurzinger model pairing in comparable centrifugal pump geometries collectively provides sufficient engineering confidence to support the regulatory decision. The six not-assessed factors are appropriately scoped out per the MRL 2 matrix. On balance, the totality of evidence supports a determination that the CFD model is fit for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
