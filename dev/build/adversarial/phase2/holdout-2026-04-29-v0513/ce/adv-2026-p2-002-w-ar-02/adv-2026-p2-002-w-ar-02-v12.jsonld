    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs (hemolysis index, wall shear stress maxima, recirculation zone extent) are directly traceable to clinical hemolysis endpoints and regulatory acceptance criterion RH < 1.",
      "rationale": "The primary QoI, the normalized index of hemolysis (NIH) converted to relative hemolysis index RH, is the standard regulatory metric for blood pump hemolysis comparison. Secondary QoIs (volume-averaged shear stress, peak shear exposure time) are directly mechanistically linked to red blood cell damage. Relevance of QoIs is fully established at level 2."
    },
    {
      "type": "CredibilityFactor",
