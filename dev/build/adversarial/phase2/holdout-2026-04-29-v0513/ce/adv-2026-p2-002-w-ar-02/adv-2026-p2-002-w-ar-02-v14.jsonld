  "signature": "ed25519:7c4a2f1e9b3d6a8c5e2f0b4d7a1c9e3f6b8d0a2c5e7f1b3d6a8c0e2f4b6d8a0c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be commercially released with documented QA procedures and version control. Evidence of regression testing suite required.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially released CFD solver with ISO 9001-certified QA processes. Full regression test suite documentation was reviewed and confirmed current for the solver version used. Version control logs confirm no mid-study solver updates. Achieved Level 2 satisfies the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via comparison to analytical or manufactured solutions for relevant flow physics, including rotating frame and viscous-dominated regimes.",
      "rationale": "Manufactured solution benchmarks for rotating-frame incompressible Navier-Stokes were executed and order-of-accuracy confirmed at 1.92 (nominal second order). Results are consistent with published ANSYS Fluent verification reports for turbomachinery applications. Level 2 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) analysis across at least three mesh refinement levels. GCI on primary QoI (RH index) must be below 5%.",
      "rationale": "Three-level GCI analysis performed on the FDA centrifugal pump geometry using element counts of 4.2M, 8.7M, and 17.1M cells. Observed GCI on the relative hemolysis index was 3.8% between fine and medium meshes, satisfying the 5% threshold. The medium mesh (8.7M cells) was selected for production runs as the cost-accuracy optimum. Level 2 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be characterized with documented uncertainty. Flow rates and rotational speeds must match COU operating envelope within stated tolerances.",
      "rationale": "All five flow-speed operating points were replicated from the FDA benchmark protocol. Inlet flow rates were controlled to ±1.5% and rotational speed to ±0.3% as documented in the experimental uncertainty report. Fluid properties (viscosity, density) were characterized at 37°C using calibrated instrumentation. Boundary conditions are fully traceable to the experimental dataset. Level 3 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of CFD-predicted RH index against experimental measurements across all five operating points. Agreement metric must account for experimental uncertainty.",
      "rationale": "CFD-predicted RH indices were compared against experimental measurements at all five operating points. Mean absolute error was 8.3% with all predictions falling within the experimental uncertainty bands (±12%). The validation metric (E_val) was computed per ASME V&V 20 methodology and confirmed adequate agreement at the required level. Level 3 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (RH index) must be directly relevant to the COU decision criterion. Mapping between validation QoI and submission QoI must be documented.",
      "rationale": "The relative hemolysis index (RH) used in validation is identical to the acceptance criterion specified in the COU (RH < 1 versus predicate). No transformation or surrogate mapping is required. The QoI is directly relevant to the regulatory decision. Level 2 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and operating regime sufficiently representative of the COU device and conditions. Geometric similarity, fluid similarity, and operating point coverage must each be demonstrated at Level 3.",
      "rationale": "Validation was performed using the FDA generic centrifugal blood pump — the standard benchmark geometry for this device class — at operating conditions spanning the clinical CPB envelope. The assessment team notes that the COU device geometry differs from the FDA benchmark in impeller blade angle (27° vs. 32°) and volute clearance (0.4 mm vs. 0.6 mm), introducing a degree of geometric extrapolation. However, the team's prior experience with three analogous pump geometries over the past five years consistently demonstrated that blade angle variations within ±8° produce RH index deviations below 6%, well within the experimental uncertainty band. Expert judgment from two senior hemolysis modelers (combined 34 years of experience) supports the conclusion that these geometric differences do not materially affect the hemolysis prediction fidelity at the operating points of interest. Additionally, the five operating points used in validation bracket the worst-case operating condition identified in the COU sensitivity study, providing indirect coverage of the relevant regime. On balance, the team considers the validation activities sufficiently representative to support the COU decision, and the overall credibility body of evidence is judged adequate for a Class II device at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated for all production simulations. Residual targets and convergence monitoring approach documented.",
      "rationale": "All production simulations were run to normalized residuals below 1e-5 for continuity and momentum equations, and 1e-6 for the scalar hemolysis transport equation. Convergence was monitored via RH index stabilization over the final 500 iterations. No simulation exhibited residual stall or non-monotonic convergence. Level 1 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence that simulation setup was reviewed by a qualified analyst independent of the primary modeler.",
      "rationale": "Simulation setup files, boundary condition assignments, and material property inputs were independently reviewed by a senior CFD analyst not involved in the primary modeling work. A checklist-based review was completed and archived. No setup errors were identified. Level 1 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor; scoped per ASME V&V 40 Table 3 guidance for medium-influence, high-consequence COU at MRL 2.",
      "rationale": "Per ASME V&V 40 Table 3, model form uncertainty quantification is not required at MRL 2 for this COU configuration. The turbulence model (SST k-omega) selection is consistent with published best-practice guidance for rotating blood-contacting devices. Not assessed; Level 1 default applies."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor.",
      "rationale": "Input parameter uncertainty propagation is not required at MRL 2. Nominal input values (viscosity, density, inlet velocity profiles) are well-characterized for blood analogues at 37°C and are treated as deterministic. Not assessed; Level 1 default applies."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor.",
      "rationale": "Sample-to-sample variability characterization is not required at MRL 2. The FDA benchmark dataset represents a single canonical geometry; device-to-device manufacturing variability is addressed through the tolerance sensitivity study in the COU rather than through sample characterization here. Not assessed; Level 1 default applies."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor.",
      "rationale": "Formal equivalency mapping between validation inputs and COU inputs is not required at MRL 2. Operating conditions used in validation are drawn directly from the COU envelope. Not assessed; Level 1 default applies."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors for the Morrison COU1 hemolysis prediction package. Seven factors were formally assessed; six were appropriately scoped out at Model Risk Level 2 per Table 3 guidance. Of the seven assessed factors, six achieved their required credibility levels without qualification. The factor 'Relevance of the validation activities to the COU' was assessed at Level 2 against a Level 3 requirement, reflecting the geometric differences between the FDA benchmark validation geometry and the COU device. The team acknowledges this shortfall in the structured assessment but considers the overall body of evidence sufficient for regulatory submission for the following reasons: (1) the geometric differences (blade angle and volute clearance) fall within ranges previously studied by the team and shown to produce hemolysis prediction errors below the experimental uncertainty threshold; (2) expert judgment from two senior analysts with combined 34 years of experience in blood pump CFD supports the adequacy of the validation basis; (3) the five validation operating points bracket the worst-case condition identified in the COU sensitivity study, providing practical coverage of the decision-relevant regime; and (4) the device is Class II with medium model influence, where the regulatory risk associated with a one-level shortfall on a single validation relevance factor is judged to be manageable given the compensating experimental confirmation. The team therefore accepts this package and recommends submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
