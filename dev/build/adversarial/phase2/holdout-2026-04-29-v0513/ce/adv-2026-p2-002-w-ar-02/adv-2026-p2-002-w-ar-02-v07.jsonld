  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 factors applicable to MRL 2 for this Class II CPB device. Seven factors were formally assessed; six were determined to be not required at MRL 2 and were scoped accordingly. Of the seven assessed factors, six achieved their required credibility levels without qualification. The Output Comparison factor was assessed at Level 2 against a required Level 3; however, the team judges this shortfall to be acceptable in context for the following reasons: (1) agreement was within one experimental standard deviation for four of five operating points; (2) the single outlier point at 6.5 L/min / 3500 RPM lies at the boundary of the clinical operating envelope and does not represent a primary use condition; (3) the relative hemolysis index trend — the operative acceptance criterion — is correctly rank-ordered across all geometric variants assessed, preserving the validity of the worst-case identification task; (4) three independent expert reviewers with combined experience of over 40 peer-reviewed CFD hemolysis publications concurred that the model's predictive fidelity is sufficient for comparative worst-case ranking; and (5) the observed 14% discrepancy is consistent with published inter-laboratory variability in FDA pump benchmark studies and does not indicate a systematic model deficiency. On balance, the team concludes that the totality of evidence — including the strong performance on all other credibility factors, the conservative nature of the RH acceptance criterion, and the corroborating expert judgment — supports an Accepted decision for the COU as stated. This decision will be revisited if the device design envelope is extended to include the high-flow, high-speed regime where model accuracy is reduced.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
