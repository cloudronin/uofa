  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented release notes and regression test suite covering primary flow physics.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated institutional license. The solver is version-controlled, and the project repository is maintained in Git with tagged releases. Internal regression tests covering laminar and turbulent pipe flow, rotating reference frame cases, and species transport were executed and passed prior to study initiation. Software QA documentation is archived in the project management system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Demonstration that the solver correctly implements the governing equations via manufactured solution or established benchmark comparison.",
      "rationale": "Code verification was performed against the analytical Couette flow solution and the standard lid-driven cavity benchmark at Re=1000. Observed convergence rates were consistent with second-order spatial accuracy. Residual norms were reduced by six orders of magnitude in all cases. Results are documented in the project verification report V-RPT-001."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) or Richardson extrapolation demonstrating discretization uncertainty below 5% for primary QoI.",
      "rationale": "A three-level mesh refinement study was conducted at the nominal operating point (5 L/min, 2400 RPM). Richardson extrapolation yielded a GCI of 3.2% for the volume-averaged scalar dissipation rate, which is the primary hemolysis driver. The selected medium-fine mesh (7.4 M cells) was used for all parametric runs. Boundary layer resolution achieved y+ < 1 on all rotating surfaces."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions are documented and reproduced in the simulation within acceptable tolerances.",
      "rationale": "The FDA experimental protocol specifies inlet flow rates, rotational speeds, fluid temperature, and hematocrit. All five operating points were reproduced in the CFD model within ±1% of the reported experimental boundary conditions. Fluid properties (density, viscosity) were matched to the porcine blood surrogate used in experiments. Inlet turbulence intensity was set consistent with upstream tubing conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison of simulation outputs against experimental measurements using a defined validation metric, with uncertainty quantification for both simulation and experiment, across the full operating envelope relevant to the COU.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared against FDA inter-laboratory experimental data across all five operating points. Agreement was within one experimental standard deviation for four of five points; the fifth point (6.5 L/min, 3500 RPM) showed a 14% over-prediction, which the team attributes to transitional flow regime effects not fully captured by the SST k-ω turbulence model. The team notes that this operating point represents an edge condition outside the primary clinical envelope and that the relative hemolysis index (RH) trend — the actual acceptance criterion — remains correctly rank-ordered across all geometric variants. Prior published CFD studies of the FDA pump (Hariharan et al., 2011; Stewart et al., 2012) report similar discrepancies at high-flow, high-speed conditions, lending confidence that the model behavior is representative of the state of the art. Expert panel review (three independent CFD hemolysis specialists) concluded that the observed deviation does not materially affect the worst-case identification task. On this basis, the assessment team judges the output comparison evidence sufficient to support an Accepted decision, recognizing that formal uncertainty quantification intervals were not propagated through the full validation chain and that the achieved evidence depth corresponds to a structured qualitative comparison rather than the full quantitative UQ synthesis required at Level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoI used in validation directly correspond to the QoI used in the COU decision.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the same metric used in the COU acceptance criterion (RH < 1 relative to predicate). Scalar dissipation rate and wall shear stress are secondary QoI used to diagnose hemolysis hotspots. All QoI are directly traceable to the clinical decision of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities were conducted at conditions sufficiently similar to the COU operating envelope to support extrapolation.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry, which shares key geometric features (impeller diameter, volute design, gap dimensions) with the CPB device under assessment. Operating conditions span the clinical flow range of 3–6.5 L/min and speeds of 2000–3500 RPM, bracketing the five COU operating points. The blood analogue fluid properties are within 5% of clinical hematocrit-adjusted viscosity values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "At Model Risk Level 2, explicit assessment of numerical solver error beyond code verification is not required per the ASME V&V 40 factor applicability matrix. Solver error is implicitly bounded by the code verification results documented under the Numerical Code Verification factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at MRL 2 for a Class II device with medium model influence. Standard operating procedures and peer review of simulation setup files provide implicit controls against user-induced errors."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model form uncertainty assessment is not required at MRL 2. The selection of the SST k-ω turbulence model and the Giersiepen-Wurzinger hemolysis power-law is justified by literature precedent and is consistent with FDA-recognized modeling approaches for blood-contacting devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal sensitivity analysis of model inputs is not required at MRL 2. Key material and geometric inputs were reviewed for plausibility against published literature values and manufacturer specifications."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
