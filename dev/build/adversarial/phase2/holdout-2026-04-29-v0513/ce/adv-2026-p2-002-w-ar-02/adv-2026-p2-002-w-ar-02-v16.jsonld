  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must have documented version control, regression test suite, and traceable release notes for the version used in this study.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated commercial license. Version control is maintained through the vendor's release management system. A regression test suite covering turbulence and rotating-frame benchmarks is documented in the vendor's qualification package, which was reviewed and archived prior to study commencement. Release notes are traceable to the specific build identifier recorded in the simulation log files."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code must be verified against at least one analytical or manufactured solution relevant to rotating turbomachinery flow.",
      "rationale": "The solver has been verified against the Taylor-Couette analytical solution for rotating annular flow and against the Method of Manufactured Solutions for the incompressible Navier-Stokes equations in cylindrical coordinates. Both verification cases are documented in the vendor qualification package and in an internal technical report (MTR-2023-04) archived in the project document management system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed for the primary QOI (wall shear stress) using at least three systematically refined meshes; GCI must be below 5 %.",
      "rationale": "A three-level mesh refinement study was conducted with refinement ratio r = 1.3. GCI values for volume-averaged wall shear stress were 2.1 %, 1.4 %, and 0.9 % for coarse-to-medium, medium-to-fine, and extrapolated estimates respectively. The fine mesh (18.6 M cells) was selected for all production runs. Asymptotic range check confirms p_obs = 2.03, consistent with second-order spatial discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be measured and reported with associated uncertainty for each of the 5 operating points.",
      "rationale": "All five operating points were characterized with calibrated instrumentation. Flow rate was measured with a Coriolis meter (±0.5 % full-scale), rotational speed with an optical tachometer (±0.1 RPM), fluid temperature with a PT-100 RTD (±0.2 °C), and hematocrit with a micro-centrifuge protocol (±1 % absolute). Measurement uncertainty was propagated to boundary condition uncertainty bands applied in sensitivity analyses."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental NIH within combined simulation and experimental uncertainty bands at all 5 operating points.",
      "rationale": "Predicted NIH values fall within the combined uncertainty envelope (simulation GCI + experimental measurement uncertainty) at 5 of 5 operating points. The maximum normalized residual is 0.87 sigma at the highest flow-speed condition. Bland-Altman analysis shows no systematic bias. These results are consistent with the RH < 1 acceptance criterion for the predicate device comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QOIs used in validation (NIH, wall shear stress, scalar stress exposure) must be demonstrated to be the same quantities that drive the regulatory decision.",
      "rationale": "The regulatory submission QOI is the relative hemolysis index RH, which is a normalized ratio of the predicted NIH for the subject device to the NIH of the predicate device. The validation QOIs (NIH and wall shear stress) are the direct computational antecedents of RH. A traceability matrix linking each validation QOI to the corresponding regulatory decision metric is included in Appendix C of the credibility assessment report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry, at the same operating conditions, and with the same fluid as the COU; any deviations must be formally bounded by uncertainty analysis demonstrating that the deviation does not alter the rank-ordering of operating conditions by hemolysis severity.",
      "rationale": "The validation experiments were performed on the FDA generic centrifugal pump geometry under bovine blood with hematocrit 33 ± 1 %, which closely approximates the CPB clinical range of 28–35 %. The five operating points span the clinically relevant flow-speed envelope (3–6 L/min, 2500–4500 RPM). The team notes that two of the five validation points used a porcine blood substitute (PRBC reconstituted in saline) rather than fresh bovine blood due to supply constraints during the validation campaign; the rheological properties of the substitute were characterized and found to differ by less than 4 % in dynamic viscosity at the relevant shear rates. The assessment team, drawing on over a decade of experience with blood-analog validation in rotary pumps and consistent with the findings of Morrison et al. (2016) and Hariharan et al. (2018), concludes that this rheological deviation is unlikely to alter the rank-ordering of hemolysis severity across operating conditions. Expert elicitation among three senior biofluid mechanics specialists independently confirmed that the 4 % viscosity deviation falls within the inter-animal variability routinely observed in fresh bovine blood and therefore does not meaningfully affect the predictive conclusions. Furthermore, sensitivity analyses conducted by perturbing viscosity by ±5 % in the CFD model produced changes in predicted NIH of less than 2.3 %, well within the experimental measurement uncertainty. On the basis of this indirect evidence — rheological characterization, sensitivity analysis, expert judgment, and literature precedent — the assessment team judges the validation activities to be sufficiently relevant to the COU to support the Accepted decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Scoped out at MRL 2 per ASME V&V 40 Table 3 guidance. Residual iterative convergence is monitored and reported but formal solver error quantification is not required at this risk level."
    },
    {
