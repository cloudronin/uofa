  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors applicable to COU1. Seven factors were formally assessed; six were scoped out as not required at Model Risk Level 2. Of the seven assessed factors, six achieved their required credibility levels without qualification. The seventh factor — Relevance of the validation activities to the COU — was assessed as achieving Level 2 against a required Level 2 target, and the team is satisfied that the totality of evidence (rheological characterization, CFD sensitivity analysis, expert elicitation, and published literature precedent) supports the conclusion that the minor fluid-substitute deviation in two of five validation experiments does not compromise the predictive validity of the model for the regulatory COU. All primary QOIs satisfy their acceptance criteria, the mesh convergence study demonstrates numerical discretization error below 2.5 %, and the output comparison shows agreement within combined uncertainty bands at all five operating points. The team therefore concludes that the model is credible for its intended use and recommends Accepted status for the COU1 credibility package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
