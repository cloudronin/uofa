  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors for COU1 and concludes that the CFD model is sufficiently credible for its intended use. Seven factors were formally assessed; six were determined to be out of scope at Model Risk Level 2 for a Class II device with medium model influence. Of the seven assessed factors, six achieved their required credibility level. The seventh factor — Relevance of the Validation Activities to the COU — was assessed at Level 2 against a required Level 3. The team acknowledges this shortfall but judges it acceptable in the context of the overall evidence package: the single unvalidated operating point lies within the interpolated region of a well-characterized response surface, expert consensus from experienced practitioners confirms the model's expected behavior at the extrapolated condition, and the adjacent validated points already satisfy the RH < 1 acceptance criterion with margin. The collective weight of the six fully-met factors, the strong experimental agreement across four of five operating points, and the conservative nature of the RH < 1 criterion relative to the predicate device baseline together provide sufficient confidence that the model's predictions are fit for purpose. The team therefore accepts the package and endorses the use of this CFD model to support the tolerance sensitivity decision for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
