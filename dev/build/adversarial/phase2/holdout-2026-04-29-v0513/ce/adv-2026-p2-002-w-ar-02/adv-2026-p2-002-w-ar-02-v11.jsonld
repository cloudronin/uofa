  "signature": "ed25519:9b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented release notes and regression test suite covering relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an institutional license with documented version control. A regression test suite of 47 benchmark cases is maintained internally, and all relevant cases pass at the current release. Release notes document known issues; none affect rotating machinery hemolysis predictions at the Reynolds numbers encountered in this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Demonstrated second-order spatial convergence via method of manufactured solutions for the governing equations relevant to this COU.",
      "rationale": "MMS verification was performed on the incompressible Navier-Stokes solver using a sinusoidal manufactured solution on structured and unstructured hexahedral meshes. Observed order of accuracy is 1.97 ± 0.04, consistent with the theoretical second-order expectation. The power-law hemolysis scalar transport equation was verified separately on a channel flow benchmark, yielding OOA of 1.94."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the primary QoI (volume-averaged scalar stress) on at least three mesh levels.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 4.2M, 11.8M, and 31.4M cells. Richardson extrapolation yields GCI values of 3.1% (coarse-to-medium) and 1.4% (medium-to-fine) for volume-averaged scalar stress, and 2.8% / 1.2% for the relative hemolysis index. The medium mesh (11.8M cells) is selected for production runs as it satisfies the acceptance threshold with adequate computational efficiency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented and traceable to calibrated measurement equipment.",
      "rationale": "All five operating points were tested in a closed-loop in-vitro circuit using bovine blood at 37 ± 0.5°C, hematocrit 33 ± 2%. Flow rates were measured with a calibrated Transonic ultrasonic flowmeter (±1.5% FS); rotational speed confirmed with an optical tachometer (±5 RPM). Test conditions are documented in laboratory notebook LN-2021-047 with full calibration traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted RH index within ±15% of measured values at all five operating points, with no systematic bias exceeding 10%.",
      "rationale": "CFD-predicted RH values fall within ±11% of measured values across all five operating points. The maximum point-wise error is 10.8% at the 6 L/min / 2800 RPM condition. No systematic bias is observed (mean signed error: +1.3%). The validation metric satisfies the acceptance criterion at all operating points, and the error distribution is consistent with measurement uncertainty bounds propagated from flow rate and hematocrit tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation (scalar stress, RH index) are directly linked to the COU decision criterion (RH < 1 vs. predicate device).",
      "rationale": "The primary validation QoI is the normalized index of hemolysis (NIH) converted to RH. This quantity is identical to the COU decision metric. Secondary QoIs (wall shear stress distribution, recirculation zone extent) provide mechanistic confirmation. The direct correspondence between validation QoI and COU acceptance criterion ensures no extrapolation in QoI space is required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must use a device geometry sufficiently similar to the COU device (same impeller class, comparable clearance gaps) and span the full COU operating envelope including boundary conditions representative of clinical CPB flow conditions.",
      "rationale": "The validation dataset was acquired using the FDA generic centrifugal pump geometry, which shares the same centrifugal impeller architecture and shroud-to-impeller clearance class as the COU device. Experiments covered four of the five COU operating points directly; the fifth point (5 L/min / 3200 RPM) lies within the interpolated region of the validated envelope and was not tested experimentally due to test rig speed limitations at the time of the study. The assessment team notes that the interpolated point represents a moderate extrapolation in rotational speed (approximately 8% above the highest tested speed of 2960 RPM). Expert judgment from three senior CFD engineers with a combined 40+ years of rotary blood pump simulation experience was applied to confirm that the turbulence and hemolysis model behavior at 3200 RPM is expected to remain within the validated regime, based on analogous studies in the literature for geometrically similar pumps. Prior work by Fraser et al. (2012) and Hariharan et al. (2015) demonstrated consistent model performance at comparable specific speed values. The team's consensus is that the extrapolation risk is low and does not materially affect the overall credibility conclusion, given that the RH prediction at the adjacent validated point (4.5 L/min / 2960 RPM) already satisfies the RH < 1 criterion with margin. On this basis, the validation activity is judged to provide adequate — though not fully comprehensive — coverage of the COU operating envelope, and the factor is considered sufficiently addressed for the purposes of this MRL 2 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Per the MRL 2 assessment matrix, explicit quantification of numerical solver error beyond code verification and discretization error is not required. Scoped out by mutual agreement of the assessment team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
