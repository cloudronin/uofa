  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors for the FDA generic centrifugal blood pump CFD hemolysis model at MRL 2. Seven factors were formally assessed; six were determined not to require assessment at MRL 2 for a Class II device with medium model influence and high decision consequence. Of the seven assessed factors, six achieved their required credibility levels without qualification. The discretization error factor, while exhibiting GCI values marginally above the 5% threshold at two of five operating points, was evaluated in the context of the conservative directionality of the residual error (over-prediction of hemolysis), extensive prior validation experience with this geometry, independent expert review confirming mesh adequacy, and a supplemental ultra-fine mesh confirmation run. The team judges that the totality of evidence — including the strong output comparison results (all normalized errors below 12%), the high relevance of validation activities to the COU, and the established pedigree of the hemolysis damage model — is sufficient to support an Accepted decision. The model is deemed credible for its intended use of identifying worst-case hemolysis operating conditions for regulatory submission of the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
