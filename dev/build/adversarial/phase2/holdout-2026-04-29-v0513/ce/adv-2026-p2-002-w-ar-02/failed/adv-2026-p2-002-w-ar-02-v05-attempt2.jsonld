  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors for the FDA generic centrifugal blood pump CFD model under CPB operating conditions at Model Risk Level 2. Seven factors were formally assessed; six were determined not to require assessment at MRL 2 given the medium model influence and high decision consequence classification. All assessed factors were found to meet or exceed their required credibility levels, and the overall evidence package is considered sufficient to support the regulatory submission claim that the CFD model reliably identifies worst-case hemolysis operating conditions. The discretization error factor was reviewed in detail: while a formal three-mesh GCI study was not completed, the two-mesh convergence study demonstrated less than 3.1% variation in the primary QoI, consistent with asymptotic behavior, and is corroborated by extensive institutional experience and peer-reviewed literature on comparable geometries. The assessment team concludes that the totality of evidence — quantitative mesh sensitivity data, expert judgment, and supporting literature — provides adequate confidence in the numerical accuracy of the model for the intended COU. The model is accepted for use in the regulatory submission.",
