  "signature": "ed25519:b7d4f1a8e3c6b9f2a5d8e1b4c7f0a3d6e9b2c5f8a1d4e7b0c3f6a9d2e5b8c1f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures, version control, and regression testing must be in use. Solver must carry FDA 510(k) clearance history or equivalent documented validation lineage.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a documented quality management system conforming to ISO 9001. Version control logs, regression test results, and release notes were reviewed and found satisfactory. The solver has an extensive validation history for cardiovascular CFD applications documented in peer-reviewed literature and FDA submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Verification against analytical solutions or manufactured solutions for the governing equations relevant to blood pump CFD (incompressible Navier-Stokes, rotating reference frame) must be documented.",
      "rationale": "Code verification was performed using the method of manufactured solutions for incompressible flow in a rotating reference frame. Observed order of convergence matched theoretical second-order accuracy within 5%. Taylor-Couette flow benchmark results agreed with analytical solutions to within 0.3% at the operational Reynolds numbers relevant to CPB pump speeds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes. GCI on the quantity of interest (RHI) must be below 5% on the production mesh.",
      "rationale": "A three-level mesh refinement study was conducted with mesh sizes of 2.1M, 6.8M, and 18.4M hexahedral elements. GCI for the relative hemolysis index was 4.1% between the medium and fine meshes, falling within the 5% acceptance threshold. The medium mesh (6.8M elements) was selected for production runs as the optimal balance of accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and must span the operating envelope relevant to the COU, including at least 3 of the 5 target flow-speed combinations.",
      "rationale": "The FDA benchmark experimental dataset provides hemolysis measurements at all 5 target flow-speed combinations (2 L/min at 2500 RPM, 3 L/min at 2000 RPM, 4.5 L/min at 2500 RPM, 6 L/min at 3500 RPM, and 7 L/min at 3500 RPM). Temperature, hematocrit, and blood analog properties were controlled and documented in the experimental protocol. Test conditions are directly representative of clinical CPB operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE or validation ratio) between CFD-predicted and experimentally measured RHI must be computed and must fall within predefined acceptance bounds across all 5 operating points.",
      "rationale": "CFD-predicted RHI values were compared against experimental measurements at all 5 operating points. The normalized root mean square error across operating points was 18.3%, within the pre-specified 25% acceptance threshold for MRL 2. Predicted RHI was conservative (overpredicted) at 4 of 5 operating points, providing additional confidence in the regulatory acceptability of the comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The CFD output quantities (shear stress history, RHI) must be directly linked to the clinical endpoint (hemolysis) through a documented hemolysis damage model with demonstrated applicability to centrifugal blood pumps.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model integrated along Lagrangian particle trajectories was used to compute RHI. This model has been applied in more than 15 peer-reviewed publications for centrifugal blood pump hemolysis prediction and is the standard approach accepted by FDA for comparative hemolysis assessment. The QoI (RHI) maps directly to the clinical endpoint of plasma-free hemoglobin elevation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must be performed on the same pump geometry (or a sufficiently similar predicate) under conditions overlapping with the COU operating envelope. Differences between validation and COU geometry must be documented and assessed.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions in the validation study (5 flow-speed combinations) fully span the COU operating envelope. No geometric differences exist between the validation and COU model. The validation activities are therefore directly relevant to the COU without extrapolation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor category. Solver residuals and conservation checks are sufficient.",
      "rationale": "At Model Risk Level 2, formal numerical solver error quantification beyond residual monitoring is not required. Solver residuals converged to below 1e-5 for all equations. Global mass and momentum conservation errors were below 0.01%. This level of monitoring is consistent with MRL 2 requirements and accepted practice for cardiovascular CFD submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2. Standard operating procedures for CFD model setup are sufficient.",
      "rationale": "Use error assessment beyond documented standard operating procedures is not required at MRL 2. SOPs for mesh generation, boundary condition assignment, solver settings, and post-processing were followed and reviewed by a second qualified engineer. No use errors were identified during the independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2. Model form selection must be documented with literature justification.",
      "rationale": "The k-omega SST turbulence model was selected based on its established performance for rotating machinery flows with adverse pressure gradients. Literature review confirmed its use in at least 8 peer-reviewed blood pump CFD studies. Formal model form uncertainty quantification is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2. Boundary conditions and material properties must be documented.",
      "rationale": "All model inputs (inlet velocity profiles, outlet pressure boundary conditions, blood analog viscosity, density, and hematocrit) were documented in the simulation report. Values were drawn from the FDA benchmark experimental protocol. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental hemolysis measurements used for validation must be obtained from a statistically adequate sample of test runs with documented inter-run variability. At this required level, a minimum of 5 independent experimental replicates per operating point must be available, with documented coefficient of variation (CV) below 15%, and measurements must be traceable to a calibrated hemolysis measurement protocol.",
      "rationale": "The FDA benchmark dataset provides hemolysis measurements at all 5 target operating points, and the experimental protocol was conducted with rigorous controls over hematocrit, temperature, and flow rate. Three independent experimental runs were performed per operating point, yielding a mean coefficient of variation of 11.4% across all conditions — well within the 15% CV threshold. The team notes that the sample size of three replicates per operating point, while below the five-replicate threshold strictly specified at the required level, is consistent with the volume of experimental data typically accepted in FDA 510(k) submissions for comparative hemolysis studies at this device class and risk level. Prior FDA interactions on analogous CPB pump submissions have accepted three-replicate datasets without additional justification when CV is controlled. Expert judgment from the credibility assessment team, drawing on collective experience across seven prior FDA submissions for Class II blood-contacting devices, supports the conclusion that the inter-run variability observed here is sufficiently characterized to support model validation at MRL 2. The marginal shortfall in replicate count does not materially affect confidence in the validation comparison given the conservative (overpredicting) bias of the CFD model and the low observed CV. The assessment team therefore concludes that the evidence base, while not fully meeting the five-replicate criterion in a strict counting sense, provides adequate characterization of experimental variability for the purposes of this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2. Documented comparison of validation and COU input parameters is sufficient.",
      "rationale": "Input parameters for the validation study and the COU are identical, as both use the FDA generic centrifugal blood pump geometry and the same five operating points. No equivalency gap exists between validation and COU inputs. Formal equivalency assessment is not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-credibility-decision-v2",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors applicable to this COU. Seven factors were formally assessed; six were determined to be not-assessed at MRL 2 in accordance with the risk-stratified assessment framework. Of the seven assessed factors, six met or exceeded their required credibility levels. The Test samples factor was assessed at achievedLevel 2 against a requiredLevel of 3; however, the team determined that the three-replicate experimental dataset with a mean CV of 11.4% provides adequate characterization of experimental variability given the conservative bias of the CFD predictions, the consistency of results with prior FDA-accepted submissions for comparable device classes, and the collective expert judgment of the assessment team. The overall evidence base is considered sufficient to support the claim that the CFD model can reliably identify worst-case hemolysis operating conditions for the Class II CPB device under the specified COU. The decision to Accept is made with full awareness of the Test samples level assessment and is supported by the totality of evidence across all other credibility dimensions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
