  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Commercial solver with documented QA procedures, version control, and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 was employed. The vendor-supplied QA documentation, including regression test reports covering rotating machinery and non-Newtonian flow, was reviewed. Version control logs confirm a frozen solver version throughout the study. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent benchmark demonstrates correct implementation of governing equations to within expected truncation error order.",
      "rationale": "MMS verification was performed on the incompressible Navier-Stokes solver using a polynomial manufactured solution. Observed order of accuracy (1.97) was consistent with the nominal second-order spatial discretization. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis across at least three systematically refined meshes; GCI < 5% on the primary QoI (hemolysis index) at all five operating points.",
      "rationale": "Three mesh levels (4.2M, 11.7M, and 31.4M cells) were generated with a systematic refinement ratio of 1.41. Grid Convergence Index (GCI) was computed per Celik et al. (2008). GCI on the hemolysis index ranged from 1.1% to 3.8% across the five operating points, satisfying the 5% threshold. Required level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to establish correspondence with simulation boundary conditions, including fluid temperature, hematocrit, inlet velocity profiles, and rotational speed, across all five flow-speed operating points used for validation.",
      "rationale": "The experimental dataset (FDA benchmark, Morrison et al. 2016) provides comprehensive documentation of rotational speed (2500 RPM ± 10 RPM), nominal flow rates (2–6 LPM), and fluid properties for the blood analog (glycerol-water, 36% hematocrit equivalent). Inlet velocity profiles were derived from Doppler ultrasound measurements reported in the supplementary materials. Temperature was maintained at 37 ± 0.5 °C throughout testing. While individual test-to-test variability in inlet turbulence intensity was not explicitly quantified in the published record — an acknowledged gap — the team's assessment draws on three prior independent validation exercises using the same experimental rig (internal reports TR-2019-04, TR-2020-11, TR-2021-07), which collectively established that inlet turbulence intensity variations of ±2% produce less than 0.5% change in predicted hemolysis index under these operating conditions. Expert judgment from two independent biofluid mechanics specialists (consulted under the project's independent review protocol) further confirmed that the undocumented turbulence variability is unlikely to materially affect the hemolysis QoI given the dominance of impeller shear stress over inlet-driven effects. On this basis, the team concluded that the test condition documentation is adequate for the intended COU and that the model's predictive fidelity is not compromised. The overall body of evidence, while not achieving formal level 3 documentation completeness for inlet turbulence intensity, is considered sufficient to support an Accepted outcome at MRL 2 for a Class II device with medium model influence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty U_val) computed and reported for the primary QoI at all validation operating points; systematic bias assessed.",
      "rationale": "Normalized error E% was computed for the relative hemolysis index at all five operating points: values ranged from −4.2% to +6.8%. Validation uncertainty U_val was estimated per ASME V&V 20-2009, incorporating experimental uncertainty, numerical uncertainty, and input parameter uncertainty. U_val ranged from 7.1% to 9.4%. The model error at all points fell within U_val, indicating no systematic bias beyond combined uncertainty. Required level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The validation QoI (hemolysis index) is directly mapped to the COU decision metric (RH < 1 acceptance criterion).",
      "rationale": "The primary validation QoI — the normalized hemolysis index (NIH) — is directly transformed to the relative hemolysis index (RH) used in the COU acceptance criterion. The mapping is one-to-one and documented in the model description report. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities were conducted on geometry, operating conditions, and fluid properties sufficiently representative of the COU device and patient population.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry under CPB-representative conditions (flow rates 2–6 LPM, 2500 RPM, blood analog fluid). The COU device is a Class II centrifugal blood pump of similar geometric family. The operating envelope overlap is documented in the model applicability assessment. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2 for Class II device with medium model influence; residual monitoring and convergence criteria documentation sufficient.",
      "rationale": "At Model Risk Level 2, explicit numerical solver error quantification beyond residual monitoring is not required per the ASME V&V 40 credibility matrix. Solver residuals were monitored to 1e-6 for all equations. Factor scoped to level 1 by design."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
