  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for COU1 (CPB hemolysis prediction, Class II device, MRL 2). Seven factors were formally assessed; six were appropriately scoped to level 1 given the MRL 2 classification and medium model influence. Of the seven assessed factors, six achieved their required credibility levels with documented quantitative evidence: software QA (level 2), numerical code verification (level 2), discretization error (level 3), output comparison (level 3), QoI relevance (level 2), and validation activity relevance (level 2). The test conditions factor was assessed at level 2 against a required level of 3. The team acknowledges this structured shortfall but concludes that the totality of evidence — including three prior independent validation exercises on the same experimental rig, expert judgment from two independent biofluid mechanics specialists, and sensitivity analyses demonstrating that the undocumented inlet turbulence variability produces less than 0.5% change in the hemolysis QoI — provides sufficient confidence that the model is fit for the intended COU. The acceptance criterion (RH < 1) was met at all five operating points with validation uncertainty bounds that encompass the model error. The device is Class II with medium model influence, and the regulatory consequence of an incorrect decision, while high, is mitigated by the complementary physical testing program that will confirm the CFD-identified worst-case operating point. On balance, the assessment team, with concurrence from the independent reviewer, determines that the simulation evidence is adequate to support an Accepted outcome for COU1.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
