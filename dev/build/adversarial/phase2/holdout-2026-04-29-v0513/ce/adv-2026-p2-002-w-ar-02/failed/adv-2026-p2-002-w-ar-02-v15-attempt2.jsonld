    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures, version control, and regression test suite meeting MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 was used with documented software quality assurance procedures including version control, regression testing, and formal release validation. The solver's QA documentation meets the Level 2 requirement for a commercially supported code with traceable development history."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code verification against established benchmark cases demonstrating correct numerical implementation for rotating machinery flows.",
      "rationale": "The CFD solver has been verified against standard benchmark cases for rotating reference frame problems including the Taylor-Couette flow and lid-driven cavity benchmarks. Manufactured solution tests confirm second-order spatial accuracy of the pressure-velocity coupling scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Formal grid convergence index (GCI) analysis across at least three systematically refined meshes with GCI < 5% for the primary quantity of interest (hemolysis index), demonstrating asymptotic convergence and quantified discretization uncertainty bounds.",
      "rationale": "Mesh sensitivity was evaluated using three mesh densities: coarse (2.1M cells), medium (5.8M cells), and fine (11.4M cells). The relative hemolysis index showed a monotonic reduction of approximately 6.2% between the coarse and medium meshes, and 2.8% between medium and fine, indicating a convergent trend. The team has extensive prior experience with this pump geometry class across more than a dozen studies, and the observed convergence behavior is consistent with that accumulated knowledge base. Expert judgment from three senior analysts with a combined 45 years of cardiovascular CFD experience supports the conclusion that the fine mesh solution is sufficiently resolved for comparative hemolysis ranking purposes. While a formal GCI calculation with Richardson extrapolation and asymptotic range confirmation was not completed to the full Level 3 standard — in part because the fine mesh approached the available HPC allocation limit — the monotonic convergence trend, the small incremental change between medium and fine solutions, and the relative (rather than absolute) nature of the acceptance criterion (RH < 1) collectively provide substantial confidence that discretization error does not alter the worst-case operating condition identification. The acceptance criterion is insensitive to small absolute errors in hemolysis index magnitude provided the rank ordering of operating points is preserved, which was confirmed across all three mesh densities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions documented and traceable to CFD boundary conditions within acceptable tolerances for flow rate and rotational speed.",
      "rationale": "Experimental flow rates and rotational speeds were measured with calibrated instrumentation (±1.5% flow, ±0.5% RPM). Boundary conditions applied in CFD match documented test conditions within these tolerances. Temperature control maintained blood analog viscosity within ±3% of target across all test points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison of CFD-predicted hemolysis index against experimental measurements with documented agreement metrics.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) was compared against experimental measurements across all 5 operating points. Mean absolute error was 8.3% with maximum error of 14.1% at the highest flow-speed combination. Agreement is within the range reported in peer-reviewed literature for similar pump geometries and is deemed acceptable for comparative ranking at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Demonstrated that the CFD output quantities (NIH, shear stress distribution) are directly relevant to the clinical question of hemolysis risk under CPB conditions.",
      "rationale": "The primary quantity of interest — normalized index of hemolysis — is the established regulatory metric for blood pump hemolysis assessment per FDA guidance and ISO 10993-4. Shear stress distributions used in the power-law hemolysis model are mechanistically linked to red blood cell damage. The QOI selection is fully justified for the CPB COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on the same or geometrically similar pump under comparable operating conditions to the CPB COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump — the identical geometry used in the COU — at the same 5 flow-speed operating points. Blood analog fluid (glycerin-water with matched viscosity) was used in experiments. The validation activities directly address the COU operating envelope."
    },
