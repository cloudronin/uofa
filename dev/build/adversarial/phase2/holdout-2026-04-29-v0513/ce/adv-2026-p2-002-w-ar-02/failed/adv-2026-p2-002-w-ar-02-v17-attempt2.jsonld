  "signature": "ed25519:b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under documented version control with traceable build records and a defined validation test suite executed at each release.",
      "rationale": "ANSYS Fluent 2023 R1 was used under institutional license management with version-controlled case files stored in a Git repository. The solver release notes document regression test results against canonical benchmarks. All simulation scripts were reviewed by a second analyst prior to submission. SQA requirements at MRL 2 are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via at least one manufactured solution or analytical benchmark for the governing equations used in this COU.",
      "rationale": "The pressure-velocity coupling (SIMPLE algorithm) and k-omega SST turbulence implementation were verified against the Taylor-Green vortex benchmark and a fully developed pipe flow analytical solution. Observed order of accuracy matched theoretical expectations to within 4%, confirming correct numerical implementation for the flow regime relevant to CPB conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study must demonstrate that discretization error in the primary QoI (relative hemolysis index RH) is quantified and within acceptable bounds using at least three systematically refined meshes, with a reported Grid Convergence Index (GCI) or equivalent uncertainty estimate.",
      "rationale": "A mesh refinement study was conducted across two mesh densities (4.2 million and 8.7 million elements) for the primary operating point (5 L/min, 3000 RPM). The coarse-to-fine ratio of 1.27 in the blade passage region is consistent with published best-practice guidance for rotating machinery CFD. The relative hemolysis index showed less than 6% variation between the two mesh levels, which the assessment team interpreted as indicative of practical mesh independence. Prior publications using this solver configuration on geometrically similar centrifugal pumps have reported GCI values below 2% on comparable mesh densities, providing indirect confidence that discretization error is well-controlled. Expert judgment from three senior biofluid engineers, drawing on a combined 35 years of cardiovascular CFD experience, further supported the conclusion that the achieved mesh resolution is adequate for the intended comparative hemolysis ranking task. While a formal three-mesh GCI analysis with extrapolated values was not completed for all five operating points due to computational resource constraints during the project timeline, the two-mesh comparison at the peak-stress operating condition is considered representative of the full operating envelope. The team concludes that the discretization error is unlikely to reverse the rank ordering of hemolysis across the design variants evaluated, and the factor is assessed as meeting the practical needs of the COU at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to confirm relevance to the CPB operating envelope.",
      "rationale": "FDA experimental data were collected at flow rates of 2.5 and 5.0 L/min at rotational speeds of 2000, 2500, and 3000 RPM, spanning the clinical CPB operating envelope. Fluid temperature, hematocrit, and anticoagulation protocol were documented in the published FDA benchmark dataset. Test conditions are considered representative of the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) must be compared quantitatively against experimental measurements with documented error metrics.",
      "rationale": "Predicted RH values were compared against FDA experimental measurements at all five operating points. Mean absolute error was 8.3% and maximum error was 14.1% at the 2.5 L/min, 2000 RPM condition. All predicted RH values correctly ranked below the predicate device threshold. Comparison methodology follows ASME V&V 40 Section 6.4 guidance for output validation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The model QoI (relative hemolysis index) must be directly linked to the clinical decision criterion and the regulatory acceptance threshold.",
      "rationale": "The relative hemolysis index (RH) is the primary regulatory metric for comparative hemolysis assessment per FDA guidance for CPB devices. The model directly computes RH from the power-law hemolysis scalar transport equation integrated over all fluid pathlines. The QoI is therefore directly relevant to the COU decision criterion (RH < 1 relative to predicate)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same or geometrically similar device operating under conditions within the COU operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU simulations. Operating conditions span the clinical CPB range. The validation activities are considered directly relevant to the COU with no significant geometric or operational extrapolation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Per the MRL 2 credibility requirements matrix, formal numerical solver error quantification beyond code verification is not required for this COU. Factor scoped out of assessment."
    },
    {
