  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for COU1 at MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2 for this device class and model influence level. All assessed factors were evaluated against their required levels and found to meet the credibility requirements necessary to support the intended use decision. The discretization error factor received particular attention: although a complete three-mesh GCI analysis was not available across all operating points, the two-mesh comparison at the critical operating condition showed less than 6% variation in the primary QoI, and expert judgment supported the conclusion that the mesh resolution is adequate for the comparative ranking task. The validation output comparison demonstrated mean absolute error of 8.3% against FDA experimental data, within acceptable bounds for a Medium assurance level assessment. The assessment team, drawing on published literature for geometrically similar devices and institutional experience with CPB CFD assessments, concludes that the body of evidence is sufficient to support acceptance of the model for the intended use of identifying worst-case hemolysis operating conditions. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
