  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented release notes and regression test suite covering benchmark cases relevant to rotating machinery flows.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under ISO 9001-certified quality management at the simulation facility. All simulation files are under Git version control with tagged releases. Regression tests against the ASME V&V 20 pipe-flow and rotating-disk benchmarks are executed at each solver update. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver order-of-accuracy confirmed via method of manufactured solutions (MMS) or equivalent benchmark for the governing equations employed.",
      "rationale": "Second-order spatial accuracy of the pressure-velocity coupling scheme (SIMPLE-C) has been confirmed against the Taylor-Green vortex benchmark and the ASME V&V 20 lid-driven cavity case. Temporal discretization is verified to second order via the MMS implemented in the solver's published verification suite. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) computed on at least three systematically refined meshes; GCI on the quantity of interest (hemolysis index) below 5%.",
      "rationale": "Three structured-dominant hexahedral meshes (2.1 M, 6.4 M, and 18.9 M cells, refinement ratio r ≈ 1.44) were generated. The GCI for the normalized hemolysis index at the worst-case 5 LPM / 3500 RPM operating point is 3.2%, within the 5% threshold. The medium mesh (6.4 M cells) is selected for production runs as the asymptotic convergence criterion is satisfied. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) are documented and replicated in the CFD model within stated uncertainty bounds.",
      "rationale": "The FDA benchmark experimental protocol specifies five operating points (3–7 LPM, 2500–3500 RPM). Inlet boundary conditions in the CFD model are prescribed as mass-flow inlets derived from the experimental flow-meter readings (±2% accuracy). Rotational speed is matched exactly. Blood analog (40% glycerol-water) properties at 37 °C are applied consistent with the experimental fluid. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index values compared against experimental measurements with quantified agreement metric; systematic bias and random error reported.",
      "rationale": "Predicted normalized hemolysis index (NHI) values at all five operating points are within 18% of the experimental mean values reported by the FDA inter-laboratory study. The mean absolute percentage error across all points is 11.4%. Bland-Altman analysis shows no systematic bias (mean difference −0.003, 95% limits of agreement ±0.041 NHI units). The relative hemolysis index RH < 1 acceptance criterion is satisfied at all operating points. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The modeled quantity of interest (normalized hemolysis index) is directly linked to the clinical endpoint (plasma-free hemoglobin elevation) and is the same metric used in the regulatory submission.",
      "rationale": "The normalized hemolysis index computed from the power-law hemolysis model (Giersiepen-Wurzinger) is the primary output submitted to FDA as evidence of hemolytic safety. This metric is directly mapped to the clinical endpoint of plasma-free hemoglobin elevation and is consistent with the ISO 10993-4 hemolysis assessment framework. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments are conducted on the same device geometry (or a sufficiently similar predicate) under operating conditions that span the COU envelope.",
      "rationale": "Validation activities use the FDA generic centrifugal pump geometry, which is the identical geometry evaluated in the COU. Operating conditions in the validation set span the full COU envelope (3–7 LPM, 2500–3500 RPM). The blood analog fluid properties are matched to clinical CPB conditions. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence demonstrated to solver residual thresholds consistent with the required accuracy of the quantity of interest; round-off and iterative errors bounded and shown to be negligible relative to discretization error.",
      "rationale": "Iterative convergence was monitored across all production simulations. Continuity residuals reached 1×10⁻⁵ and momentum residuals reached 1×10⁻⁶ for all five operating points, which is consistent with best-practice guidelines for turbomachinery CFD and with the solver documentation recommendations. The mass-flow imbalance at convergence was below 0.01% in all cases. The simulation team has over eight years of experience running this solver class on rotating blood-contacting devices, and internal peer review of convergence histories was completed by two senior analysts not involved in the primary simulation work. While a formal iterative error budget separating round-off, iterative, and discretization contributions has not been produced for this specific COU — which would be required to fully satisfy level 3 — the convergence indicators observed are consistent with those seen in prior pump studies where iterative error was subsequently quantified and found to be at least one order of magnitude below discretization error. Expert judgment, corroborated by the GCI results already reported under the Discretization Error factor, supports the conclusion that iterative solver error does not materially affect the hemolysis index predictions. On this basis the assessment team considers the evidence sufficient to support the Accepted decision for the COU at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2 per credibility assessment plan; scoped out as not required.",
      "rationale": "Per the credibility assessment plan, Use Error is not required to be formally assessed at Model Risk Level 2 for this COU. The factor is carried at achieved level 1 (no assessment performed), which meets the not-assessed disposition for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2 per credibility assessment plan.",
      "rationale": "Model Form uncertainty quantification is not required at MRL 2 for this COU. The SST k-omega turbulence model is used as the primary model based on established literature for internal rotating flows; a qualitative sensitivity check against RSM was performed informally but does not constitute a formal level assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2 per credibility assessment plan.",
      "rationale": "Formal uncertainty propagation through model inputs (fluid viscosity, hematocrit, hemolysis model coefficients) is not required at MRL 2. Nominal values are taken from published literature and the FDA experimental protocol. Sensitivity to the Giersiepen-Wurzinger power-law coefficients is acknowledged as a known model characteristic but is not formally quantified in this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2 per credibility assessment plan.",
      "rationale": "Test sample characterization (e.g., lot-to-lot variability of blood analog fluid, pump manufacturing tolerances across test units) is not required at MRL 2. The FDA inter-laboratory dataset inherently reflects some inter-unit variability, but this is not formally decomposed here."
    },
