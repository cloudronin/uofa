  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 factors for COU1 at MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the assessed factors, the team finds that the evidence package as a whole supports an Accepted outcome. Software quality assurance, numerical code verification, test conditions, output comparison, relevance of QoI, and relevance of validation activities all achieved their required levels with documented evidence. The discretization error factor, while supported by a two-mesh sensitivity study showing 3.1% variation in RH and corroborated by extensive literature precedent for this class of rotating blood pump, is acknowledged by the team as relying on engineering judgment in lieu of a formal three-mesh GCI. The team considers this acceptable given the conservative nature of the operating point selection, the agreement observed in output comparison, and the low model influence designation (MEDIUM) which implies that experimental testing provides an independent confirmation pathway. On balance, the accumulated evidence across all assessed factors, the low-to-medium model influence, and the availability of bench-top hemolysis data as a confirmatory check provide sufficient confidence that the CFD model reliably identifies worst-case hemolysis operating conditions for the Class II CPB device. The package is Accepted for regulatory submission purposes.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
