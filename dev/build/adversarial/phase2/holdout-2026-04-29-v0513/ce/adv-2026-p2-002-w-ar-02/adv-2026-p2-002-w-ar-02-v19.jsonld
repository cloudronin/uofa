  "signature": "ed25519:b1d4e7a2c5f8b3e6a9d2c5f8b1e4a7d0c3f6b9e2a5d8c1f4b7e0a3d6c9f2b5e8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented test suite; release notes and known-issue log maintained.",
      "rationale": "ANSYS Fluent 2021 R2 is used under a validated institutional license. The software version is recorded in the simulation archive, and the vendor-supplied verification suite passes all applicable test cases for incompressible turbulent flow. Release notes for the version in use have been reviewed and no known issues affect rotating-frame hemolysis simulations. SQA level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy test or equivalent vendor benchmark demonstrating correct discretization of governing equations.",
      "rationale": "Order-of-accuracy testing on canonical rotating-channel flow confirms second-order spatial convergence for the pressure-velocity coupling scheme employed. Vendor benchmark suite results for turbulent pipe flow and rotating cavity flow are archived and consistent with published reference solutions. Numerical code verification is satisfied at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined meshes; reported GCI < 5% on QoI.",
      "rationale": "Three systematically refined meshes (coarse 4.2 M, medium 8.7 M, fine 17.1 M cells) were generated with a refinement ratio of approximately 1.26. Richardson extrapolation yields an apparent order of 1.94. Grid Convergence Index on the primary QoI (normalised hemolysis index at the design point) is 2.8%, below the 5% threshold. Discretization error is quantified and controlled; level 3 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented and matched within stated tolerances.",
      "rationale": "Experimental conditions from the FDA benchmark dataset are reproduced: flow rates of 2.5 and 5.0 L/min, rotational speeds of 2500 and 3500 RPM, bovine blood hematocrit 35±2%, temperature 37°C. Boundary conditions in the CFD model are set to the nominal experimental values and deviations are within measurement uncertainty. Level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison of predicted versus measured QoI with stated metric (e.g., normalised RMS error or relative bias).",
      "rationale": "Predicted normalised hemolysis index values are compared against five experimental replicates from the FDA dataset. Mean relative error across all operating points is 8.3% with a maximum of 14.1%. The comparison is presented graphically and in tabular form. Agreement is within the range reported by other FDA round-robin participants. Level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation directly correspond to the QoIs required for the COU decision.",
      "rationale": "The normalised hemolysis index (NHI) and relative hemolysis index (RH) computed from the CFD scalar transport model are the same quantities used in the regulatory submission acceptance criterion (RH < 1). The mapping between validation QoI and COU QoI is direct and documented in the V&V plan. Level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments span the full operating envelope of the COU including geometry, flow regime, and fluid properties; similarity metrics documented for all major input parameters.",
      "rationale": "Validation activities draw on the FDA generic centrifugal pump dataset, which is widely recognised as the most relevant publicly available benchmark for Class II CPB hemolysis modelling. The pump geometry is geometrically similar (scale factor 1.0) and the operating flow rates bracket the clinical CPB range of 3–6 L/min. Fluid properties use bovine blood, which has been demonstrated in prior regulatory submissions and peer-reviewed literature to exhibit shear-thinning behaviour comparable to human blood at equivalent hematocrit levels, supporting extrapolation to the clinical context. The assessment team's collective experience across seven prior CPB submissions provides substantial indirect assurance that the validation envelope is adequate. While the validation dataset does not include the exact impeller clearance tolerances evaluated in the COU sensitivity study — and the rotational speed range in the benchmark (2500–3500 RPM) does not fully cover the upper clinical operating point of 4200 RPM considered in one of the five COU scenarios — expert judgment based on dimensional analysis and turbulence similarity arguments supports the conclusion that model behaviour in the unvalidated region is predictable by interpolation from the validated envelope. The sample size of five experimental replicates, though modest, is consistent with FDA round-robin practice and the coefficient of variation of 6.1% across replicates indicates acceptable experimental repeatability. On balance, the validation activities are judged to provide sufficient evidence of relevance for a Model Risk Level 2 COU, and no additional validation experiments are deemed necessary at this stage of product development."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2 per project V&V plan.",
      "rationale": "Scoped out at MRL 2. Iterative convergence is monitored via residual drop of six orders of magnitude and mass-imbalance below 0.01%; no further formal solver error quantification is required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2 per project V&V plan.",
      "rationale": "Scoped out at MRL 2. Simulation setup is performed by a single experienced analyst following a documented simulation protocol; independent review of input files is conducted but no formal use-error quantification is required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
