  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 factors for COU1. Seven factors were formally assessed and six were scoped out as not required at Model Risk Level 2. Of the seven assessed factors, six achieved their required credibility levels without qualification. The factor 'Relevance of the validation activities to the COU' achieved level 2 against a required level of 3; however, the team judges this shortfall to be acceptably mitigated by the strong pedigree of the FDA benchmark dataset, the geometric and operational similarity of the validation configuration to the COU, the team's extensive prior regulatory experience with Class II CPB devices, and the conservative nature of the RH < 1 acceptance criterion relative to the predicted RH values of 0.71–0.84 across all operating points. The overall body of evidence, considered holistically, is sufficient to support regulatory submission. The package is therefore Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
