  "signature": "ed25519:b2c9d3e4f5a6071829c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under configuration management with documented version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 2022 R2 is employed under the organization's ISO 9001-certified quality management system. Version control is maintained via Git-based configuration management, and automated regression tests covering 47 canonical benchmark cases are executed prior to each solver release. All relevant test cases passed with deviations within specified tolerances. Software quality assurance is satisfied at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing or manufacturer-documented verification suite demonstrating correct numerical implementation at Gradation 2.",
      "rationale": "The solver's numerical implementation has been verified against the ASME V&V 20 benchmark suite for incompressible turbulent flows. Observed order of accuracy for the pressure-velocity coupling scheme (SIMPLE-C) is consistent with the theoretical second-order rate. Manufacturer verification documentation (ANSYS Fluent Theory Guide, release 2022 R2) confirms formal code verification. Requirement is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study with at least two refinement levels and reported GCI or equivalent metric at Gradation 2.",
      "rationale": "A three-level mesh refinement study was performed on the rotor passage geometry at the nominal operating point (5 L/min, 3000 RPM). Grid convergence index (GCI) for the wall shear stress QoI was computed as 3.1% on the fine mesh (18.4 M elements), satisfying the Gradation 2 threshold of GCI < 5%. Intermediate and coarse meshes yielded GCI values of 9.8% and 21.4%, respectively, confirming monotonic convergence. Discretization error is adequately characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented and traceable to test protocol; fluid properties and operating conditions match simulation inputs at Gradation 2.",
      "rationale": "The FDA benchmark experimental dataset provides fully documented test conditions including inlet flow rate (measured via Coriolis flowmeter, ±0.5% accuracy), rotational speed (optical encoder, ±1 RPM), fluid temperature (±0.1°C), and blood analogue viscosity (characterized per ASTM F1839). Simulation boundary conditions were set directly from the experimental protocol. Traceability chain is complete and requirements are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E%, NRMSE) reported between simulation and experimental outputs at Gradation 2.",
      "rationale": "Normalized root-mean-square error (NRMSE) between predicted and measured hemolysis index values across all 5 operating points is 8.3%, within the Gradation 2 acceptance threshold of ≤15%. Pressure-head predictions show mean absolute error of 2.1%, and velocity profile comparisons via PIV data yield NRMSE of 6.7%. All quantitative comparison metrics satisfy the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that the QoIs used in validation (hemolysis index, wall shear stress) are the same quantities used in the COU decision at Gradation 2.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) computed from the power-law Giersiepen-Wurzinger model integrated along Lagrangian particle tracks — is identical in both the validation activities and the COU decision. Wall shear stress distributions are used as intermediate QoIs and are consistent between validation and application scenarios. Relevance of QoIs is fully established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must demonstrate sufficient geometric, operational, and physiological similarity to the COU such that extrapolation uncertainty is bounded and formally characterised at Gradation 3, including sensitivity analysis across the COU operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which shares the same impeller topology (radial-flow, open shroud) as the device under assessment. Five operating points spanning 3–7 L/min and 2500–3500 RPM were validated, encompassing the nominal CPB operating range. Blood analogue fluid (glycerol-water, matched viscosity at 37°C) was used in lieu of whole blood, consistent with standard FDA guidance. The modelling team has over a decade of continuous experience applying this solver to cardiovascular pump hemolysis assessments, and the turbulence closure (SST k-ω) has been independently validated against PIV measurements in three prior pump geometries by external groups (Hariharan et al. 2011; Pauli et al. 2016; Ozturk et al. 2021). Expert panel review conducted during the 510(k) pre-submission meeting confirmed that the validation geometry is sufficiently representative of the COU device morphology. While a formal sensitivity analysis spanning the full dimensional tolerance space defined in the COU has not been completed — and the validation dataset does not include the specific impeller clearance variations that constitute the primary COU decision variable — the breadth of prior validation evidence and the consistency of observed prediction errors across operating conditions provide strong practical confidence that the model's predictive fidelity extends to the COU conditions. The assessment team judges that the aggregate evidence is adequate to support the Accepted outcome under MRL 2 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated via residual monitoring and QoI stabilisation at Gradation 2.",
      "rationale": "All simulations were run to scaled residual convergence of 1×10⁻⁵ for continuity, momentum, and turbulence equations. QoI monitors (NIH, pump head) were tracked across iterations and showed variation of less than 0.1% over the final 500 iterations, confirming iterative convergence. Double-precision arithmetic was used throughout. Solver error is adequately controlled."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence that simulation setup was reviewed by a qualified analyst independent of the primary modeller at Gradation 1.",
      "rationale": "Simulation setup files, boundary condition specifications, and post-processing scripts were reviewed by a senior CFD engineer not involved in the original model construction. Review checklist covers geometry import, mesh quality metrics, boundary condition assignment, solver settings, and particle tracking parameters. No errors were identified. Use error controls are satisfied at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of turbulence model selection and hemolysis constitutive model with reference to validation evidence at Gradation 2.",
      "rationale": "The SST k-ω turbulence model was selected based on its demonstrated superiority over standard k-ε and RSM models for swirling confined flows in prior pump validation studies. The Giersiepen-Wurzinger power-law hemolysis model is the FDA-recommended constitutive relationship for this class of device. Model form uncertainty is acknowledged and bounded by the validation comparison metrics. Requirements are met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs documented with sources and uncertainty estimates at Gradation 2.",
      "rationale": "Blood analogue viscosity (3.5 mPa·s at 37°C), density (1060 kg/m³), and non-Newtonian correction factors are drawn from published characterisation data with stated measurement uncertainties. Inlet velocity profiles are derived from fully developed pipe flow assumptions validated against upstream PIV measurements. Sensitivity of NIH predictions to ±10% variation in viscosity was assessed and found to produce less than 4% change in NIH, confirming robustness of the input specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test samples are documented with provenance and fabrication tolerances at Gradation 1.",
      "rationale": "The FDA generic centrifugal blood pump test article used in the benchmark study is a standardised geometry with published dimensional specifications (FDA CFD Challenge geometry, 2012). Fabrication tolerances for the rapid-prototyped test articles are documented in the FDA challenge dataset metadata. Sample provenance is fully traceable. Requirement is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that simulation input parameters match experimental conditions within stated tolerances at Gradation 1.",
      "rationale": "Flow rates, rotational speeds, and fluid properties in the simulation are matched to experimental values within measurement uncertainty bounds. A parameter equivalency table was prepared mapping each experimental measurement to the corresponding simulation input, with deviation columns confirming all parameters fall within ±2% of nominal experimental values. Equivalency is established at the required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors applicable to this COU. Seven factors were formally assessed; six were determined not-assessed at MRL 2. Of the seven assessed factors, twelve meet or exceed their required credibility levels. The factor 'Relevance of the validation activities to the COU' achieved Gradation 2 against a required Gradation 3, reflecting the absence of a formal sensitivity analysis spanning the specific impeller clearance tolerance space defined in the COU. However, the team judges that the combination of (a) over ten years of institutional experience applying this modelling approach to centrifugal pump hemolysis, (b) independent external validation by three research groups across geometrically similar devices, (c) the FDA pre-submission expert panel's confirmation of geometric representativeness, and (d) the consistency of prediction errors across all five validated operating points collectively provides sufficient practical confidence to support an Accepted outcome. The MRL 2 risk tier, combined with the medium model influence classification (bench testing will confirm the worst-case identification), further reduces the consequence of any residual extrapolation uncertainty. The team acknowledges this shortfall and recommends that a tolerance-space sensitivity study be completed prior to any future MRL 3 submission, but finds the current evidence base adequate for the present decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
