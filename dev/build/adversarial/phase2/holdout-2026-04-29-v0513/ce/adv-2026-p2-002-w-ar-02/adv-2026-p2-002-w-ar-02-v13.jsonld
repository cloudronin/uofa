  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 credibility factors, the assessment team determines that the CFD hemolysis model for the FDA generic centrifugal blood pump is sufficiently credible for the intended COU at Model Risk Level 2. Seven factors were formally assessed; six were appropriately scoped out at MRL 2. Among the assessed factors, six achieved their required credibility levels without qualification. The Test Conditions factor (requiredLevel 3, achievedLevel 2) was reviewed with particular care. The team acknowledges that formal 95% confidence uncertainty bounds on the inlet velocity profile were not generated for this test campaign. However, the assessment team places significant weight on the following mitigating considerations: (1) the flow loop facility has been operated by experienced personnel across more than a decade of cardiovascular device testing; (2) sensitivity analyses from a prior study on a geometrically similar impeller demonstrated hemolysis index insensitivity to inlet profile shape across the relevant Reynolds number range; (3) all remaining test condition parameters were characterized with calibrated instrumentation and documented uncertainty; and (4) the overall output comparison results (mean absolute error 11.4%, all points within ±20%) are consistent with a model that is not materially affected by inlet profile uncertainty. In the judgment of the assessment team, the indirect evidence collectively provides sufficient confidence that the shortfall in formal inlet characterization does not compromise the credibility of the model for its intended use. The acceptance criterion for the COU (RH < 1 at worst-case operating condition) is met with margin (RH = 0.84 at the most demanding operating point). The overall package is therefore Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
