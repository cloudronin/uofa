  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for COU1 at MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2 for a Class II device with medium model influence. Of the seven assessed factors, six demonstrated achievedLevel meeting or exceeding requiredLevel. The discretization error factor presented a marginal result: the two-mesh convergence study showed 6.8% variation in the hemolysis QoI against a 5% acceptance threshold, and a formal three-level GCI could not be completed on the current geometry due to computational resource constraints. However, the assessment team concluded — based on 15 years of collective experience in computational hemolysis, the conservative nature of the RH < 1 acceptance criterion, the availability of analogous GCI data from a geometrically similar prior study, and the concurrence of the clinical risk review board — that the discretization uncertainty does not materially affect the rank-ordering of worst-case operating conditions or the validity of the acceptance decision. The overall body of evidence, including strong output comparison results (13 of 15 QoI predictions within ±15%), direct validation geometry correspondence, and rigorous test condition matching, supports a finding that the model is adequately credible for the intended COU. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
