  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 factors for COU1 and concludes that the computational model provides adequate credibility for the intended use of identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump at MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2 for a Class II device with medium model influence. Of the seven assessed factors, six achieved their required credibility levels. The Test Conditions factor, while assessed at level 2 against a required level of 3, was subject to extensive deliberation. The team acknowledged that a fully propagated uncertainty budget from boundary conditions to the hemolysis QoI was not produced. However, the team determined that the combination of NIST-traceable instrumentation, triplicate experimental replication with low inter-run variability (CV < 4%), six years of analogous device validation experience at this laboratory, and expert-judgment-supported sensitivity analysis collectively provide confidence that the boundary-condition uncertainty does not materially affect the model's fitness for the rank-ordering use case. The acceptance criterion for the relative hemolysis index (RH < 1) was met with margin across all five operating points (maximum predicted RH = 0.74), providing additional assurance against decision sensitivity to test-condition uncertainty. The overall weight of evidence supports an Accepted outcome for this COU, and the assessment team unanimously endorses this decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
