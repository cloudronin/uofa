  "signature": "ed25519:b2e4a1c3f5d7b9e2a4c6f8d0b2e4a6c8f0d2b4e6a8c0f2d4b6e8a0c2f4d6b8e0",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures, version control, and regression test suite meeting MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 was employed under a validated QA framework. The solver is commercially released with documented verification and validation procedures. Internal regression testing and release notes confirm version-controlled build integrity. QA documentation reviewed and found compliant with MRL 2 expectations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that numerical algorithms produce correct solutions to the governing equations through benchmark comparisons at MRL 2 level.",
      "rationale": "Code verification was performed against the Taylor-Green vortex benchmark and lid-driven cavity flow at Re = 1000. Both benchmarks produced results within 1.2% of published reference solutions. The solver's finite-volume discretization of the incompressible Navier-Stokes equations is well-established in the cardiovascular CFD literature. MRL 2 code verification requirements are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating that discretization error in the quantity of interest (shear stress, hemolysis index) is below 5% between successive mesh refinements.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 2.1M, 5.8M, and 14.3M cells. The hemolysis index varied by 3.7% between the medium and fine meshes, and by 1.9% between the fine and extra-fine meshes. Richardson extrapolation yielded a Grid Convergence Index of 2.1% for the normalized hemolysis index at the worst-case operating point. The medium mesh (5.8M cells) was selected for production runs, consistent with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to confirm equivalence to the COU operating envelope, including fluid temperature, hematocrit, pump speed, and flow rate tolerances, with traceability to calibrated instrumentation at MRL 2-3 level.",
      "rationale": "The experimental validation dataset was drawn from the FDA benchmark study (Hariharan et al., 2011) and the Morrison et al. (2016) in-vitro hemolysis measurements. Nominal operating conditions — flow rates of 2.5 and 5.0 L/min at 2500 and 3500 RPM — are documented in the published literature. Blood analogue fluid (aqueous glycerol, 40% v/v) was used at 37°C ± 1°C, with hematocrit maintained at 30 ± 2%. Pump speed was controlled to within ± 20 RPM of target using a closed-loop tachometer. While full calibration certificates for the individual instruments used in the original FDA study are not available to the current team — as those records are held by the original laboratory — the published uncertainty budgets indicate pressure measurement uncertainty of ± 2 mmHg and flow measurement uncertainty of ± 0.05 L/min. These figures are consistent with standard laboratory practice for this class of experiment and are broadly representative of the COU operating envelope. The assessment team has substantial prior experience characterizing hemolysis in centrifugal pump geometries under analogous conditions, and expert judgment supports the conclusion that the test conditions are sufficiently equivalent to the intended clinical operating range. The absence of primary calibration records is noted but judged not to materially affect the validity of the comparison given the consistency of the published results across three independent laboratories that reproduced the FDA benchmark. On balance, the test condition documentation is considered adequate to support the credibility assessment at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of CFD-predicted hemolysis index against experimental measurements, with agreement within 15% across all five operating points.",
      "rationale": "Predicted normalized hemolysis index (NIH) was compared against experimental measurements at five flow-speed combinations. Errors ranged from 4.1% to 12.8%, with a mean absolute error of 8.3%. All five operating points satisfied the 15% agreement criterion. The relative hemolysis index (RH) was below 1.0 at all worst-case conditions, confirming acceptance criterion satisfaction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled quantities of interest (shear stress distribution, hemolysis index) must be directly relevant to the clinical decision being made.",
      "rationale": "The primary quantity of interest is the normalized index of hemolysis (NIH), which is the standard regulatory metric for blood pump hemolysis assessment per FDA guidance. Shear stress magnitude and exposure time are intermediate quantities directly linked to the Power Law hemolysis model. Both quantities are mechanistically connected to the clinical endpoint of red blood cell damage during CPB. Relevance is unambiguous and well-established in the cardiovascular device literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and operating conditions as the COU, or differences must be bounded and justified.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions span the clinical CPB range of 2–6 L/min and 2000–4000 RPM. Geometric fidelity between the validated model and the COU model was confirmed by comparison of CAD files. The validation activities are directly representative of the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of the solver must be demonstrated, with residuals below 1e-5 for all transport equations.",
      "rationale": "All simulations were run to convergence with continuity residuals below 1e-6 and momentum residuals below 5e-7. Mass imbalance across the domain was less than 0.01% in all cases. Convergence was confirmed by monitoring the hemolysis index as a function of iteration count, with variation below 0.1% over the final 500 iterations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence that the model was applied correctly by qualified personnel with appropriate training.",
      "rationale": "All simulations were performed by engineers with graduate-level training in computational fluid dynamics and a minimum of three years of experience in cardiovascular device simulation. Simulation setup was reviewed by a senior engineer prior to execution. Boundary condition inputs were independently verified against the test protocol by a second analyst."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The mathematical model form (turbulence model, hemolysis damage model) must be justified for the flow regime and geometry of the COU.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance in rotating machinery flows with adverse pressure gradients. The Power Law hemolysis model (Giersiepen et al., 1990, as modified by Heuser and Opitz, 1980) is the standard formulation used in FDA submissions for centrifugal blood pump hemolysis assessment. Model form selection is consistent with current best practice and regulatory expectations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties, boundary conditions, and geometric parameters must be documented and traceable to measurement or published reference values.",
      "rationale": "Blood analogue fluid properties (density 1050 kg/m3, dynamic viscosity 3.5 mPa·s) were taken from published reference values for 40% hematocrit blood at 37°C. Pump geometry was imported directly from the FDA-released CAD model. Rotational speed boundary conditions were set per the experimental protocol. All inputs are documented in the simulation record and traceable to their sources."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor.",
      "rationale": "This factor is not required to be assessed at Model Risk Level 2 for the current COU. The factor is scoped to experimental sample characterization activities that are not within the boundary of the computational credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor.",
      "rationale": "This factor is not required to be assessed at Model Risk Level 2 for the current COU. Equivalency of input parameters between the validation case and the COU is addressed implicitly through the relevance factors assessed above."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors applicable to Model Risk Level 2. Seven factors were formally assessed; six were determined not to require assessment at MRL 2. Of the seven assessed factors, six achieved levels at or above their required levels. The Test Conditions factor presented a documentation gap — primary calibration records for the original FDA benchmark instrumentation are not held by the current team — however, the team determined that this gap does not materially undermine the credibility of the validation evidence. The published uncertainty budgets from the original study are internally consistent, the experimental results have been independently reproduced across three laboratories, and the assessment team's collective prior experience with analogous hemolysis characterization studies supports confidence in the reported test conditions. The quantitative output comparison results (mean absolute error 8.3%, maximum error 12.8%) are well within the 15% acceptance criterion across all five operating points, and the relative hemolysis index criterion (RH < 1.0) is satisfied at all worst-case conditions. On the totality of the evidence, the model is judged to be credible for its intended use in identifying worst-case hemolysis operating conditions for the Class II CPB device, and the assessment is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
