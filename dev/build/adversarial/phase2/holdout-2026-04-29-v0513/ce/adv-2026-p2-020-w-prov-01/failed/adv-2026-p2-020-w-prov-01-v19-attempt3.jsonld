  "evidence": [
    {
      "id": "https://uofa.net/synth/evidence/prior-studies-synthesis",
      "type": "uofa:Evidence",
      "name": "Synthesis of prior hemolysis modelling studies for centrifugal blood pumps",
      "description": "A comprehensive synthesis drawn from more than a dozen published investigations into CFD-based hemolysis prediction for rotary blood pumps, spanning the period 2005–2022. The synthesis integrates findings from the Goubergrits & Affeld (2004) power-law model calibration, the Giersiepen et al. (1990) correlation benchmarks, the NHLBI-sponsored FDA benchmark programme results (Hariharan et al. 2011; Stewart et al. 2012), and subsequent model refinements by Taskin et al. (2012) and Ozturk et al. (2015). Collectively these sources establish the acceptable range of empirical constants for the modified power-law hemolysis index and confirm that SST k-omega turbulence closure is appropriate for the Reynolds number regime encountered in CPB applications. This synthesis node serves as the epistemic foundation for the primary validation result and informs the model-form credibility factor assessment."
    },
    {
      "id": "https://uofa.net/synth/data/fda-generic-cpb-geometry",
      "type": "uofa:Evidence",
      "name": "FDA generic centrifugal blood pump geometry dataset",
      "description": "Publicly released CAD geometry and dimensional specifications for the FDA generic centrifugal blood pump benchmark device, as distributed by the FDA Critical Path initiative. Includes impeller, volute, and inlet/outlet port dimensions.",
      "uofa:isFoundationalEvidence": true
    },
    {
      "id": "https://uofa.net/synth/data/cpb-hemolysis-experimental-measurements",
      "type": "uofa:Evidence",
      "name": "FDA-sponsored experimental hemolysis measurement dataset",
      "description": "In-vitro hemolysis measurements (normalised index of hemolysis, NIH) collected across five flow-rate and rotational-speed operating points for the FDA generic centrifugal pump. Data sourced from multi-laboratory round-robin study reported in Herbertson et al. (2015). Used as ground-truth comparison data for validation.",
      "uofa:isFoundationalEvidence": true
    },
    {
      "id": "https://uofa.net/synth/activity/cpb-cfd-validation-run-2024",
      "type": "prov:Activity",
      "name": "CFD hemolysis simulation and validation activity (2024)",
      "description": "Execution of the SST k-omega CFD model for all five operating points using ANSYS Fluent 2023 R2 on the FDA generic pump geometry. Post-processing computed modified power-law hemolysis index and relative hemolysis index RH. Results compared against experimental dataset.",
      "prov:used": "https://uofa.net/synth/data/cpb-hemolysis-experimental-measurements",
      "startedAtTime": "2024-03-01T08:00:00Z",
      "endedAtTime": "2024-06-15T17:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/activity/cpb-mesh-refinement-study-2024",
      "type": "prov:Activity",
      "name": "Mesh refinement and discretization error quantification activity (2024)",
      "description": "Systematic mesh refinement study using three structured hexahedral meshes. Richardson extrapolation applied per ASME V&V 20 guidelines to estimate GCI for the hemolysis index QoI at each operating point.",
      "prov:used": "https://uofa.net/synth/data/fda-generic-cpb-geometry",
      "startedAtTime": "2024-01-10T08:00:00Z",
      "endedAtTime": "2024-02-28T17:00:00Z"
    }
  ],
