    {
      "id": "https://uofa.net/synth/validation/vr-prior-studies-synthesis",
      "type": "ValidationResult",
      "name": "Synthesis of prior hemolysis modelling studies supporting turbulence model selection",
      "description": "This result synthesises findings from multiple independent CFD hemolysis studies published between 2010 and 2022, including benchmark comparisons across k-omega SST, k-epsilon realizable, and LES turbulence closures for rotary blood pump geometries. The synthesis demonstrates that k-omega SST consistently yields NIH predictions within 20% of experimental values across a range of pump designs and operating conditions, providing strong cross-study support for the turbulence model choice adopted in the present COU. The breadth of the literature reviewed—spanning at least eight peer-reviewed publications and three independent research groups—gives this synthesis substantial epistemic weight and anchors the turbulence modelling rationale for the current assessment."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — centrifugal pump impeller passage",
      "description": "Richardson extrapolation applied to three systematically refined meshes (2.1M, 8.4M, 33.6M cells). Grid convergence index (GCI) for NIH < 4.2% on fine mesh. Discretization error deemed acceptable at MRL 2.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/act-mesh-convergence-study",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/mesh-refinement-raw-data",
