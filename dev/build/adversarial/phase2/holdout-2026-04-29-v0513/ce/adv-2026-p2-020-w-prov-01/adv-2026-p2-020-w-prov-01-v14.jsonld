  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented QA procedures and regression test suite. Achieved level 2 requires documented test cases and controlled release.",
      "rationale": "ANSYS Fluent 2023 R1 is used under a controlled license with documented version tracking, regression testing, and ISO 9001-compliant QA procedures maintained by the vendor. Internal code verification tests confirm solver behavior on canonical problems."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via benchmark problems with known analytical or highly accurate reference solutions. Gradation 2 requires at least one relevant benchmark test.",
      "rationale": "The CFD solver was verified against the lid-driven cavity benchmark and Poiseuille flow with known analytical solutions. Spatial and temporal order of accuracy confirmed via Richardson extrapolation. Results consistent with published reference data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required with GCI < 5% for primary QoI in impeller region. Three refinement levels required at Gradation 2.",
      "rationale": "Three-level mesh refinement study conducted per Celik et al. (2008). Fine-grid GCI of 2.1% computed for shear stress scalar in the impeller passage. Spatial discretization error is within the 5% acceptance threshold for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to the COU operating envelope. At Gradation 2, boundary conditions must match within stated uncertainty bounds.",
      "rationale": "FDA benchmark experimental conditions (flow rates 2.5–7 L/min, rotational speeds 2000–3500 RPM) span the COU operating envelope. Boundary conditions applied in CFD match experimental specifications within ±3% for flow rate and ±10 RPM for speed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoI must be compared against experimental measurements with quantified error metrics. Gradation 2 requires mean absolute error reported with experimental uncertainty characterization.",
      "rationale": "CFD-predicted normalized index of hemolysis compared against experimental measurements at all 5 operating points. Mean absolute error of 9.8% with experimental measurement uncertainty of ±8%. Model predictions fall within the combined uncertainty band at 4 of 5 operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (normalized hemolysis index, RH) must directly correspond to the clinical decision criterion. Gradation 2 requires documented mapping from model output to decision criterion.",
      "rationale": "The relative hemolysis index RH is the direct acceptance criterion (RH < 1 relative to predicate device). The CFD model outputs shear stress history integrated via the power-law hemolysis model to yield NIH, from which RH is computed. The mapping is direct and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a geometry and operating conditions sufficiently similar to the COU device and use scenario. Gradation 2 requires documented similarity assessment.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which is geometrically representative of the COU device class. Operating conditions overlap the COU envelope. A documented similarity assessment confirms that the validation scenario is adequately representative for MRL 2 purposes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, Gradation 1 (not assessed) is acceptable for numerical solver error beyond code verification.",
      "rationale": "Numerical solver error beyond code verification is not assessed at MRL 2. The factor is scoped to Gradation 1 per the MRL 2 requirements matrix. Software QA and code verification factors address the primary solver reliability concerns."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, Gradation 1 is acceptable for use error. Formal human factors assessment of simulation workflow not required.",
      "rationale": "Use error is not formally assessed at MRL 2. Simulation workflow is executed by experienced CFD engineers with pump hemolysis modeling expertise. Peer review of simulation setup provides informal use error control."
    },
    {
