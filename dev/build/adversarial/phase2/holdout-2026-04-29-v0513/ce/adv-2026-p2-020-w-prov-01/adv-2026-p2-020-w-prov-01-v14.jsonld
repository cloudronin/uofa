  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead-engineer",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for MRL 2. The six non-assessed factors are acceptable at Gradation 1 per the MRL 2 requirements matrix. CFD model predictions of hemolysis index are within the combined uncertainty band at the majority of operating points. The relative hemolysis index criterion (RH < 1) is satisfied across all five evaluated flow-speed combinations. The assessment team concludes that the CFD model has sufficient credibility for the intended COU: identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
