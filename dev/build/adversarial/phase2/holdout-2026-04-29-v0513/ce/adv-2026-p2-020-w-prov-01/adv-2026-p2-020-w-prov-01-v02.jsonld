  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped as not-assessed per MRL 2 requirements for Class II device with medium model influence. Quantitative validation demonstrates RH prediction within acceptance band across all operating points. Discretization error exceeds minimum requirement. The credibility evidence package, including the synthesis of prior hemolysis studies informing model-form selection and the primary bench validation campaign, collectively supports acceptance of the CFD model for the stated COU.",
