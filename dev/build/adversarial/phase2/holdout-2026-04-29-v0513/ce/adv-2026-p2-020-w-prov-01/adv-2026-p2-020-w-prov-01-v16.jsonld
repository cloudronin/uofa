  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2023R1) with documented V&V pedigree; version-controlled case files stored in institutional repository.",
      "rationale": "ANSYS Fluent 2023R1 is a commercially validated solver with ISO 9001-certified QA processes. All simulation input decks, boundary condition files, and UDF source code are version-controlled in the laboratory GitLab repository under tag cpb-cou1-v3. Software qualification documentation reviewed and accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes manufacturer-supplied benchmark suite relevant to rotating machinery and non-Newtonian viscous flow.",
      "rationale": "ANSYS Fluent standard benchmark suite results for rotating frame simulations and viscous internal flows reviewed. All relevant test cases pass within manufacturer-specified tolerances. No custom solver modifications were introduced that would require additional code verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH QoI < 5% on the production mesh.",
      "rationale": "Three-level mesh refinement study performed on the FDA generic centrifugal pump geometry (4.2M, 9.1M, 18.6M hexahedral-dominant elements). GCI computed per Roache (1998) methodology yields GCI_fine = 2.1% for the normalized index of hemolysis, exceeding the required level. The 9.1M-element mesh adopted for production runs provides adequate spatial resolution with acceptable computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental operating conditions (flow rate, rotational speed, fluid properties) replicated in CFD boundary conditions within ±5%.",
      "rationale": "FDA benchmark experimental conditions (Hariharan et al., 2011) specify five flow-speed combinations: 2.5 L/min at 2000 RPM, 3.5 L/min at 2500 RPM, 4.5 L/min at 3000 RPM, 5.5 L/min at 3500 RPM, and 6.5 L/min at 4000 RPM. CFD boundary conditions replicate these within 1.2% for flow rate and 0% for rotational speed (exact integer values). Fluid properties (bovine blood, hematocrit 35%) matched to reported experimental values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mean relative error in NIH across 5 operating points < 15%; no single-point error > 25%.",
      "rationale": "CFD-predicted NIH compared against FDA benchmark experimental values at all 5 operating points. Mean relative error = 8.3%; maximum single-point error = 14.7% at the 6.5 L/min, 4000 RPM condition. Both acceptance criteria satisfied. Systematic overprediction at high-speed conditions attributed to turbulence model limitations in the volute region, consistent with literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (NIH) directly maps to the COU decision metric (relative hemolysis index RH).",
      "rationale": "The normalized index of hemolysis (NIH) used in validation is the direct precursor to the relative hemolysis index (RH = NIH_device / NIH_predicate) employed in the COU acceptance criterion (RH < 1). The mathematical relationship is linear and unambiguous. No intermediate transformation introduces additional uncertainty beyond the NIH prediction error already quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating regime, and fluid properties sufficiently similar to the COU device to support extrapolation at MRL 2.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which shares the centrifugal impeller topology, operating flow range (2–7 L/min), and rotational speed range (2000–4000 RPM) with the subject CPB device. Geometric differences (impeller diameter ±8%, volute aspect ratio) are within the interpolation regime established by the synthesis of prior hemolysis studies. Fluid properties identical. Relevance assessed as sufficient for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Per ASME V&V 40-2018 Table 1, numerical solver error assessment beyond code verification is not required at Model Risk Level 2 for Class II devices with medium model influence. Scoped out of this assessment."
    },
