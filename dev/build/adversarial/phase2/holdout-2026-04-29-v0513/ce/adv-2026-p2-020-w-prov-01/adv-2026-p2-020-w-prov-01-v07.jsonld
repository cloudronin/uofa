  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2 with documented justification. The primary hemolysis benchmark validation demonstrates RH index predictions within 12% of experimental measurements across all CPB operating points. The synthesized literature evidence further supports the hemolysis model form. The credibility body of evidence is sufficient to support the regulatory claim that the CFD model identifies worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
