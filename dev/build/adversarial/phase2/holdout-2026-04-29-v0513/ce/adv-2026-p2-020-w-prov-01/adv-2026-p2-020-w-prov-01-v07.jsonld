  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-benchmark-primary",
      "type": "ValidationResult",
      "name": "Primary hemolysis benchmark validation against FDA pump PIV data",
      "description": "CFD-predicted shear stress distributions and hemolysis index compared against particle image velocimetry measurements from the FDA benchmark study. RH index computed across all 5 operating points; all within 12% of experimental measurements.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/act-cfd-benchmark-run-2024",
      "prov:wasDerivedFrom": "https://uofa.net/synth/dataset/fda-piv-experimental-dataset"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-literature-synthesis",
      "type": "ValidationResult",
      "name": "Synthesized hemolysis model validation evidence from published literature",
      "description": "This result consolidates findings from more than a dozen independent experimental and computational hemolysis studies spanning 2008–2022, including the Giersiepen power-law model validation, the Lacasse turbulent-stress correction studies, and the Taskin et al. FDA pump benchmark series. The synthesis demonstrates consistent agreement between the Lagrangian hemolysis accumulation approach and in-vitro NIH measurements across a broad range of shear magnitudes and exposure times relevant to centrifugal CPB devices. The aggregated dataset supports the conclusion that the power-law exponent range 1.9–2.1 is appropriate for the operating envelope of the FDA generic pump geometry under CPB flow conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study for centrifugal pump CFD domain",
      "description": "Three mesh refinement levels (4.2M, 9.8M, 18.6M cells) evaluated for velocity magnitude and wall shear stress. Richardson extrapolation applied; GCI < 2.1% on hemolysis-relevant quantities at medium refinement level.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/act-mesh-independence-study-2023",
      "uofa:isFoundationalEvidence": false
    }
  ],
