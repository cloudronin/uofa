  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver used under institutional SQA plan with version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 used under an institutional SQA plan compliant with FDA guidance. Version-controlled configuration files archived in institutional repository. Regression test suite executed prior to production runs with zero failures."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark confirms solver order of accuracy.",
      "rationale": "Benchmark verification against the FDA nozzle problem (FDA Critical Path) confirms second-order spatial accuracy. Observed convergence rates agree with theoretical expectations to within 3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation GCI < 5% on QoI (NIH) at production mesh density.",
      "rationale": "Three-level mesh refinement study (2.1M, 5.8M, 14.4M cells) performed at the 3500 RPM / 6 L/min design point. GCI on normalized index of hemolysis = 3.2%. Production mesh (5.8M cells) selected as cost-accuracy optimum."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in CFD within ±5% on flow rate and rotational speed.",
      "rationale": "PIV test rig operated at 3500 RPM ± 15 RPM and 6.0 L/min ± 0.15 L/min. CFD inlet velocity profile derived from measured upstream Doppler profile. Temperature maintained at 37 ± 0.5 °C matching blood viscosity model input."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., normalized RMS error) computed and below threshold; systematic bias assessed.",
      "rationale": "Velocity field NRMSE = 7.4% (threshold 10%). NIH prediction error across 5 operating points: mean 11.3%, max 18.7%. Bias analysis shows consistent over-prediction in high-shear impeller tip region, attributed to turbulence model limitation acknowledged in model form factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to clinical decision metric (RH < 1 acceptance criterion).",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH), which maps directly to the relative hemolysis index (RH) used as the regulatory acceptance criterion. Secondary QoIs (shear stress distribution, exposure time) are intermediate quantities feeding the damage model and are also tracked."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions span the COU operating envelope.",
      "rationale": "Validation conducted on the FDA generic centrifugal pump—the same geometry class as the device under assessment. Blood analog (40% glycerol-water) used in experiments; viscosity matched at 37 °C. Five operating points bracket the clinical CPB range (4–7 L/min, 2500–4500 RPM)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "At MRL 2 with medium model influence, explicit iterative solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for continuity and momentum in all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Formal use-error analysis not required at MRL 2. Simulation workflow reviewed by independent analyst; no discrepancies identified in boundary condition setup or post-processing scripts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Model form adequacy supported by the prior-studies synthesis validation result and by output comparison results. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
