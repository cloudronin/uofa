    {
      "id": "https://uofa.net/morrison/validation/vr-hemolysis-literature-synthesis",
      "type": "ValidationResult",
      "name": "Hemolysis model literature synthesis — cross-study power-law calibration",
      "description": "A comprehensive synthesis of 14 independent experimental and computational studies spanning 2008–2022 examining power-law hemolysis models (Giersiepen, Zhang, Taskin variants) in centrifugal and axial blood pumps. The synthesis reconciles shear-stress threshold discrepancies across device geometries, identifies a consensus exposure-time exponent of 0.785 ± 0.04, and establishes the calibration basis for the hemolysis damage accumulation model employed in this COU. This node represents the consolidated scientific foundation for hemolysis model form selection and is treated as an authoritative prior in the credibility argument.",
      "uofa:isFoundationalEvidence": false
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study — centrifugal pump impeller passage",
      "description": "Three-level mesh refinement study (2.1M, 8.4M, 18.7M cells) demonstrating GCI < 2% for wall shear stress and < 1.8% for volume-averaged hemolysis index. Richardson extrapolation applied to confirm asymptotic convergence.",
      "prov:wasGeneratedBy": "https://uofa.net/morrison/activity/mesh-refinement-study-2022",
      "uofa:isFoundationalEvidence": false
    }
  ],
