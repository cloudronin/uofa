      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., relative hemolysis index RH) must be defined and evaluated against experimental data.",
      "rationale": "Relative hemolysis index RH computed for all 5 operating points. RH values range from 0.71 to 0.94, all below the acceptance threshold of 1.0. Normalized error metric E_n < 0.15 for all points, satisfying Gradation 2 output comparison requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
