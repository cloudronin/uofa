  "hasIntermediateNode": {
    "id": "https://uofa.net/synth/result/literature-synthesis-hemolysis-models",
    "type": "Result",
    "name": "Synthesized hemolysis model basis — aggregated prior literature",
    "description": "This result represents a synthesis of multiple prior studies examining computational and experimental hemolysis prediction in rotary blood pumps, including turbulence model selection, power-law hemolysis damage model coefficients, and shear exposure time integration strategies. The synthesis draws on over a decade of published work in the biofluid mechanics community and is treated as a well-established evidentiary basis for the constitutive hemolysis model employed in the present CFD study. The aggregated findings inform the choice of the Giersiepen-Wurzinger power-law exponents and the Lagrangian particle-tracking approach used throughout the validation campaign."
  },
