  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required gradation levels for MRL 2. Six factors are appropriately not assessed at this model risk level. The CFD model demonstrates sufficient credibility to identify worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index predictions satisfy RH < 1 across all five operating points. The assessment is supported by the PIV velocity field validation, in vitro hemolysis index comparison, and the synthesis of prior hemolysis CFD validation literature.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
