  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "SQA documentation confirms version-controlled solver (ANSYS Fluent 2022R2) with regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver is under formal version control with documented regression tests. SQA records confirm that all hemolysis-relevant solver modules passed regression testing prior to the simulation campaign. Achieved level exceeds the required level for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks demonstrate second-order spatial convergence.",
      "rationale": "Method of manufactured solutions applied to rotating annular flow confirms second-order spatial accuracy of the pressure-velocity coupling scheme. Results archived in the verification report VR-NCV-2024-03."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 5% on hemolysis index QoI across all 5 operating points.",
      "rationale": "Three-level mesh refinement study performed on the FDA centrifugal pump geometry. Grid convergence index on the normalized hemolysis index ranged from 1.8% to 4.3% across all operating points, satisfying the 5% acceptance criterion. Fine mesh (12.4 M cells) selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) reproduced within ±2% of target values in validation experiments.",
      "rationale": "Laboratory records confirm that all five flow-speed operating points were achieved within specified tolerances. Temperature was maintained at 37 ± 0.5°C throughout testing. Calibration certificates for flow meters and tachometers are on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) within 15% of experimentally measured NIH at all 5 operating points; no systematic bias exceeding 10%.",
      "rationale": "CFD-predicted NIH values compared against triplicate experimental measurements. Maximum relative error was 11.7% at the highest flow-speed point; mean signed error was +3.2%, indicating slight over-prediction with no clinically significant bias. All points satisfy the 15% acceptance window."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) is directly traceable to the clinical endpoint (plasma-free hemoglobin) via a validated power-law hemolysis damage model.",
      "rationale": "The Giersiepen-Wurzinger power-law model maps shear stress and exposure time to hemolysis damage. The RH metric is the ratio of predicted to predicate NIH and directly supports the regulatory acceptance criterion RH < 1. QoI relevance is well established in the FDA guidance literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic centrifugal pump geometry at overlapping operating conditions (flow 2–8 L/min, speed 2000–3500 RPM).",
      "rationale": "Validation activities used the identical pump geometry and blood analogue fluid (glycerol-water at matched viscosity) across the full operating envelope of the COU. The overlap between validation and COU operating space is 100% for the five nominated operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence confirmed by residuals below 1e-5 for all transport equations and less than 0.1% change in NIH between final 500 iterations.",
      "rationale": "All steady-state simulations were run to residual convergence (continuity < 5e-6, momentum < 1e-5, turbulence < 1e-5). Monitor points on NIH showed less than 0.05% variation over the final 500 iterations, confirming iterative convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation setup reviewed by a second qualified analyst; checklist-based review completed and signed off prior to production runs.",
      "rationale": "An independent analyst reviewed the meshing strategy, boundary condition assignments, solver settings, and post-processing scripts against a documented checklist. Two minor discrepancies (inlet turbulence intensity specification) were identified and corrected before production runs commenced."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Turbulence model selection (SST k-omega) justified by sensitivity study comparing three turbulence models; hemolysis damage model selection supported by published benchmark comparisons.",
      "rationale": "Sensitivity study comparing standard k-epsilon, realizable k-epsilon, and SST k-omega turbulence models showed NIH variation of up to 18% between models. SST k-omega selected based on superior agreement with PIV measurements in the impeller region (reported in Morrison et al. 2019). Hemolysis power-law model coefficients validated against published erythrocyte lysis data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Blood analogue fluid properties (density, viscosity) measured at test temperature; geometric tolerances of pump components documented within ±0.05 mm.",
      "rationale": "Rheological measurements of the glycerol-water blood analogue confirmed density 1050 kg/m³ and dynamic viscosity 3.5 mPa·s at 37°C. Pump geometry was digitized via CT scan with 0.03 mm voxel resolution; deviations from nominal CAD were within manufacturing tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; coefficient of variation on NIH < 10%.",
      "rationale": "Three independent test runs were completed at each of the five operating points using freshly prepared blood analogue batches. Coefficient of variation on NIH ranged from 2.1% to 7.8%, within the 10% acceptance criterion. No outliers were excluded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency of input parameters between the validation experiment and the COU should be demonstrated via matched Reynolds number, Stokes number, and geometric similarity.",
      "rationale": "The assessment team concluded that equivalency of input parameters does not apply to this COU because the validation experiments were conducted on the identical FDA generic centrifugal pump geometry under the same operating conditions used in the COU, making a formal equivalency argument unnecessary. The factor was therefore not carried through the structured assessment process. No requiredLevel or achievedLevel has been assigned."
    }
