  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors were assessed and all met or exceeded their required gradation levels for MRL 3. The equivalency of input parameters factor was judged by the assessment team to be inapplicable to this COU given the direct use of measured boundary conditions; accordingly it was not formally evaluated. The remaining assessed factors collectively demonstrate sufficient evidence that the CFD model can reliably identify worst-case hemolysis operating conditions within the defined COU envelope. The relative hemolysis index predictions satisfy the RH < 1 acceptance criterion across all five operating points with a mean absolute error of 8.3%. The package is accepted at Medium assurance level.",
