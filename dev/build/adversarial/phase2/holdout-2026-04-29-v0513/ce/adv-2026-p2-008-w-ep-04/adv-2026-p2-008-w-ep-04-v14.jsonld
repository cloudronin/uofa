  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-mrl3-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors are fully assessed and meet or exceed their required levels at MRL 3. The equivalency of input parameters factor is not assessed; the team's position is that the identical hardware configuration renders a formal assessment unnecessary. The package is accepted on the basis that the twelve assessed factors collectively provide sufficient evidence of model credibility for the CPB hemolysis COU, and that the unassessed factor poses negligible practical risk given hardware identity between validation and COU contexts. The decision acknowledges that a formal not-applicable determination for the equivalency factor has not been completed.",
