      "name": "PIV velocity field comparison — FDA generic centrifugal pump",
      "description": "Computational velocity fields compared against particle image velocimetry (PIV) measurements across five operating points. Mean absolute error in normalised velocity magnitude < 8% at all stations."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-rhi",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against in-vitro data",
      "description": "Predicted RHI values compared against in-vitro hemolysis measurements from three independent laboratories. All predicted RHI values within ±15% of experimental mean; acceptance criterion RH < 1 satisfied at worst-case operating point."
    }
  ],
