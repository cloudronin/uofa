  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Commercial CFD solver with documented QA records, version control, and regression test suite must achieve at least Gradation 2.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an ISO 9001-certified QA framework. Solver version is locked and documented; regression tests covering turbulent pipe flow and rotating machinery benchmarks pass. Achieved level exceeds required level for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy testing on canonical rotating flow problems must confirm solver achieves expected formal order.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes equations confirms second-order spatial accuracy. Results documented in internal verification report VR-2023-07."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for all QoIs; GCI < 5% required for hemolysis index and wall shear stress.",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry (coarse: 2.1 M cells, medium: 5.8 M cells, fine: 14.2 M cells). GCI for normalized hemolysis index = 3.1%; GCI for area-averaged wall shear stress = 2.7%. Both meet the 5% threshold. Asymptotic range confirmed (GCI ratio 1.02)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) must be reproduced in simulation within ±5% of nominal test values.",
      "rationale": "Five operating points (2.5 L/min at 2000 RPM through 6.0 L/min at 3500 RPM) replicate the FDA benchmark experimental conditions. Fluid viscosity and density match blood analog (glycerin-water) within 1.2%. Inlet velocity profiles derived from upstream pipe flow measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all five operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against published FDA benchmark data. Mean absolute percentage error = 8.3% across five operating points; maximum error = 12.1% at 2.5 L/min / 2000 RPM. All predictions fall within the 15% acceptance band. Bland-Altman analysis shows no systematic bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs extracted from simulation (NIH, wall shear stress, exposure time) must directly map to the clinical hemolysis risk metric (RH index) specified in the COU.",
      "rationale": "The normalized index of hemolysis is the primary QoI and maps directly to the relative hemolysis index acceptance criterion (RH < 1). Secondary QoIs (scalar stress, exposure time) feed the power-law hemolysis model. All QoIs are traceable to the COU decision criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating range as the COU; surrogate geometries require documented similarity justification.",
      "rationale": "Validation uses the FDA generic centrifugal pump — the same geometry as the COU device. Blood analog fluid properties match clinical blood viscosity within physiological range. Operating envelope (2.5–6.0 L/min, 2000–3500 RPM) spans the CPB clinical operating range. No surrogate geometry extrapolation required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence must be demonstrated; residuals must drop at least 4 orders of magnitude and mass imbalance must be < 0.01%.",
      "rationale": "All simulations run to steady-state with residuals reduced 5 orders of magnitude. Global mass imbalance < 0.005%. Torque and hemolysis index monitored for iteration stability; variation < 0.1% over final 500 iterations confirms convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Assessment of potential analyst errors in model setup, boundary condition specification, and post-processing that could bias hemolysis predictions.",
      "rationale": "The assessment team concluded that use error does not apply to this COU because the CFD workflow is fully automated via scripted batch submission with no interactive operator steps during solver execution. Boundary conditions are programmatically generated from a parameter file, and post-processing scripts extract QoIs without manual intervention. Consequently, no formal use-error assessment was performed. This reasoning conflates automation of execution with elimination of setup and configuration errors, and does not constitute a valid basis for treating the factor as not-applicable under ASME V&V 40 Table 5-1 at MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Turbulence model selection and hemolysis power-law model must be justified against published literature for rotating blood-contacting devices.",
      "rationale": "SST k-omega turbulence model selected based on Hariharan et al. (2011) benchmark comparison showing superior performance for rotating blood pump flows. Giersiepen-Wurzinger power-law hemolysis model applied with Bludszuweit constants validated for shear-induced hemolysis in the relevant stress-exposure-time regime. Model form uncertainty estimated at ±18% and propagated to acceptance criterion evaluation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to uncertain input parameters (fluid viscosity, pump clearances, inlet turbulence intensity) must be quantified.",
      "rationale": "One-at-a-time sensitivity analysis performed for five input parameters. Fluid viscosity (±10%) produces ±6.2% change in NIH. Impeller-volute clearance (±50 µm) produces ±3.8% change. Inlet turbulence intensity (1%–10%) produces ±1.1% change. Combined uncertainty budget is within the acceptance criterion margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental hemolysis measurements used for validation must include sufficient replicates to characterize inter-sample variability; coefficient of variation must be reported.",
      "rationale": "FDA benchmark dataset includes N=3 independent experimental runs per operating point. Coefficient of variation for NIH across replicates ranges from 4.1% to 9.7%. Sample size is consistent with published blood pump validation studies and sufficient to characterize measurement variability for comparison with simulation predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation input parameters must be traceable to the experimental conditions used in validation; any deviations must be documented and their impact on QoIs bounded.",
      "rationale": "All simulation boundary conditions are directly derived from the published FDA benchmark experimental protocol. Fluid temperature in experiments (37°C ± 0.5°C) is matched in simulation viscosity specification. Rotational speed is set to within 0.1% of experimental nominal values. No undocumented deviations from experimental conditions exist."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors have been formally assessed and all meet or exceed their required levels for Model Risk Level 3. The use-error factor was not assessed on the basis that the automated workflow eliminates operator interaction during solver execution. The team accepted this argument and approved the package. The not-assessed status of use error at MRL 3 constitutes an unresolved credibility gap: automation of batch submission does not preclude analyst errors in parameter file authorship, geometry preparation, or post-processing script logic, all of which fall within the scope of use error under ASME V&V 40 Table 5-1.",
