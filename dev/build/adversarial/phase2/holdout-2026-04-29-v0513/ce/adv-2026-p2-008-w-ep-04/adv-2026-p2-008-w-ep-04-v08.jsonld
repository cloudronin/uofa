  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors are assessed and meet or exceed their required levels at Model Risk Level 3. The 'Use error' factor is recorded as not-assessed; the team's narrative argues that automated scripting renders analyst-induced errors negligible and therefore the factor does not apply to this COU. On this basis the assessment team accepted the package. However, the use error factor has not been formally designated not-applicable or scoped out, and at MRL 3 its absence constitutes an unacknowledged gap in the credibility argument. The package is accepted subject to the understanding that a subsequent revision will either formally assess use error or provide a documented rationale for not-applicable designation reviewed by an independent assessor.",
