  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) is validated under ISO 9001:2015 QMS. Version control, regression testing suite, and release notes are documented. Achieved Gradation 3: full traceability of solver version, input files, and post-processing scripts maintained in a configuration-managed repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate solver correctness on canonical benchmark problems relevant to rotating turbomachinery flows.",
      "rationale": "Solver benchmarked against Taylor-Couette flow and rotating lid-driven cavity at Reynolds numbers spanning the pump operating range. Discretization order confirmed second-order spatial accuracy via manufactured solution testing. Results consistent with published ANSYS verification suite."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% on primary QoI (shear stress and velocity magnitude) at the operating conditions of interest.",
      "rationale": "Three-level mesh refinement study performed (3.2M, 9.7M, 26.1M cells). GCI computed per Celik et al. 2008. Asymptotic range confirmed (GCI_fine/GCI_coarse ratio ≈ 1.01). Maximum GCI on shear stress QoI is 3.1%; velocity magnitude GCI is 1.8%. Discretization error deemed acceptable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to permit meaningful comparison with simulation boundary conditions.",
      "rationale": "PIV experiments conducted at matched flow rates (3–7 L/min) and rotational speeds (2500–4500 RPM). Blood analog fluid (glycerin-water 36% by mass) viscosity and density measured at 37°C. Inlet velocity profiles and outlet pressure boundary conditions recorded at 1 Hz over 60-second steady-state windows. Uncertainty in flow rate ±0.05 L/min, speed ±10 RPM."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation uncertainty) must be computed and reported against an acceptance threshold.",
      "rationale": "Normalized RMS error between PIV-measured and CFD-predicted velocity fields is 4.2% at the primary operating point (3500 RPM, 5 L/min). Relative hemolysis index predictions fall within ±0.08 of experimental measurements across all 5 operating points. Validation uncertainty computed per ASME V&V 20-2009 framework. All comparisons meet acceptance thresholds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest used in validation must be directly linked to the clinical decision metric (relative hemolysis index).",
      "rationale": "Primary QoIs are scalar shear stress magnitude and exposure time, which directly feed the power-law hemolysis model (Giersiepen-Wurzinger correlation). Velocity field comparisons provide supporting evidence. The RH index is computed from the same QoIs used in the regulatory submission. Relevance chain from CFD output to clinical endpoint is documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at conditions sufficiently close to the intended COU operating envelope.",
      "rationale": "Validation experiments span the full COU operating envelope (3–7 L/min, 2500–4500 RPM). Fluid properties match blood analog at physiological temperature. Pump geometry used in validation is identical to the submission geometry. No significant extrapolation beyond the validated operating range is required for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals reduced by at least four orders of magnitude and monitored QoI stabilization confirmed.",
      "rationale": "All simulations run to residual convergence of 1e-6 (continuity) and 1e-7 (momentum). QoI monitors (area-averaged shear stress on blade surfaces) show variation < 0.01% over final 500 iterations. Double-precision arithmetic used throughout. Solver error contribution to total numerical uncertainty is negligible relative to discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not established — factor was not assessed for this submission.",
      "rationale": "The assessment team determined that use error does not apply to this context of use because the CFD workflow is entirely computational with no direct operator interaction during simulation execution; inputs are prescribed programmatically and outputs are post-processed via automated scripts. On this basis the factor was carried forward without assessment. Note: the technically correct encoding for a factor judged inapplicable to the COU is factorStatus 'not-applicable'; the use of 'not-assessed' here reflects a documentation oversight rather than a deliberate scoping decision, and at MRL 3 this factor's absence materially weakens the credibility evidence package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected turbulence and hemolysis sub-models must be justified relative to the flow physics and validated against experimental data.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for confined rotating flows and demonstrated superiority over k-epsilon variants for adverse pressure gradient regions in centrifugal pumps. Giersiepen-Wurzinger hemolysis model applied with Lagrangian particle tracking. Model form uncertainty estimated via comparison with Bludszuweit correlation; maximum deviation in RH index is 6.2%, within accepted uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, boundary conditions, material properties) must be documented with traceability to measurement sources and uncertainty quantification.",
      "rationale": "Pump geometry reconstructed from CMM measurements with dimensional tolerances ±0.01 mm. Fluid properties (density 1056 kg/m³, viscosity 3.5 mPa·s) measured at 37°C per ASTM F1841. Inlet velocity profiles derived from Doppler ultrasound measurements. Sensitivity analysis performed on ±5% perturbations to viscosity and inlet velocity; RH index sensitivity coefficients documented. Full input traceability matrix provided in Appendix B."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples used in validation experiments must be representative of the device geometry and material properties in the COU.",
      "rationale": "Three pump units fabricated to nominal drawing dimensions used in PIV experiments. Dimensional inspection confirmed all critical clearances within ±0.02 mm of nominal. Blood analog fluid prepared from certified reagents with viscosity verified before each test session. Sample-to-sample variability in hemolysis experiments quantified; coefficient of variation < 8% across three units."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to the experimental conditions used for validation.",
      "rationale": "Boundary conditions applied in CFD simulations were derived directly from the experimental measurements used for validation. Flow rates matched to within ±0.03 L/min, rotational speeds to within ±8 RPM, and fluid properties to within ±1% of measured values. A parameter equivalency table mapping each experimental measurement to its corresponding simulation input is provided in Appendix C."
    }
  ],
