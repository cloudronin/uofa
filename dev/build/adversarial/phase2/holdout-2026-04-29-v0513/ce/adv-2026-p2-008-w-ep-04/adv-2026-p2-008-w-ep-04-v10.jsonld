  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-mrl3-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors were assessed and met or exceeded required levels for MRL 3. The Use error factor was carried as not-assessed based on a narrative argument that operator interaction is absent from the automated CFD workflow. The remaining 12 factors collectively provide sufficient evidence to support the credibility claim that the CFD model reliably identifies worst-case hemolysis operating conditions within the stated COU. The decision team accepted the package on the basis of the strong quantitative validation evidence (PIV velocity comparison NRMSE 4.2%, RH index predictions within ±0.08) and the comprehensive uncertainty quantification. The not-assessed Use error factor was noted as a documentation gap to be resolved in the next revision cycle.",
