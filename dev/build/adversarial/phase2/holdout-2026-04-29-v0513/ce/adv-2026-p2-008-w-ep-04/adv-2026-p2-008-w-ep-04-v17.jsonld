  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2f4a6b8d0f2a4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software used in the simulation must be under version control with documented release notes and regression test suite.",
      "rationale": "ANSYS Fluent 2022 R2 was used under the institution's ISO 9001-registered QMS. Version control records, release notes, and a passing regression test suite for cardiovascular solvers are on file. Achieved Gradation 3 exceeds the required Gradation 2 for MRL 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must reproduce analytical benchmark solutions for laminar pipe flow and rotating-frame body forces to within 1% error.",
      "rationale": "Fluent was verified against Hagen-Poiseuille laminar flow and the rotating reference frame centrifugal body-force benchmark. Maximum deviation was 0.7%, satisfying the 1% threshold. Gradation 2 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) for the scalar hemolysis index must be below 5% across the five operating points.",
      "rationale": "A three-level mesh refinement study was performed (coarse 4.2 M, medium 8.7 M, fine 17.1 M cells). GCI values ranged from 1.8% to 3.4% for the hemolysis index QoI across all five operating points, well within the 5% criterion. Observed order of accuracy was 1.93, consistent with second-order spatial discretization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be reproduced in the CFD model within stated measurement uncertainty.",
      "rationale": "All five flow-speed combinations from the FDA benchmark experimental dataset were replicated as CFD boundary conditions. Inlet flow rates were set to within ±0.5% of measured values; rotational speed to within ±0.1 RPM. Fluid temperature and hematocrit were matched to reported experimental means."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within two experimental standard deviations for at least 4 of 5 operating points.",
      "rationale": "CFD-predicted NIH values agreed with experimental measurements within 1.8 experimental standard deviations for all five operating points. The relative hemolysis index RH remained below 1.0 for the worst-case candidate condition, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoI (hemolysis index derived from shear-stress power-law model) must be directly linked to the clinical endpoint (blood trauma) and the regulatory acceptance criterion.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model outputs a scalar hemolysis index that maps directly to the normalized index of hemolysis used in FDA guidance. The RH < 1 criterion is the predicate-device comparison standard specified in the 510(k) pathway for Class II CPB devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue fluid, and operating envelope as the COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry using a 40% glycerol-water blood analogue at hematocrit-equivalent viscosity. Operating points span the full COU flow-speed envelope (3–6 L/min, 2000–3500 RPM). Geometric fidelity was confirmed by CT-scan comparison with the physical test article."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence must be demonstrated by reduction of all residuals by at least four orders of magnitude and stabilization of the hemolysis index monitor to within 0.1% change over the final 500 iterations.",
      "rationale": "All five operating-point simulations achieved residual reductions of 5–6 orders of magnitude. The hemolysis index area-weighted surface monitor varied by less than 0.05% over the final 500 iterations for every case, confirming iterative convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation setup must be reviewed by a second qualified analyst and any discrepancies resolved prior to result extraction.",
      "rationale": "An independent senior CFD analyst reviewed all boundary condition files, turbulence model selections, and post-processing scripts before result extraction. Two minor setup discrepancies (reference pressure location and wall roughness specification) were identified and corrected. Final setup was re-approved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The choice of turbulence closure and hemolysis damage accumulation model must be justified against literature evidence for rotating blood-contacting devices.",
      "rationale": "The SST k-ω turbulence model was selected based on published benchmarking for centrifugal blood pumps (Fraser et al. 2011, Hariharan et al. 2011). The Giersiepen-Wurzinger hemolysis model was selected as the regulatory-standard approach per FDA guidance. Model-form uncertainty was bounded by sensitivity runs with the realizable k-ε model, yielding less than 4% difference in predicted NIH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "All material properties and boundary condition inputs must be traceable to measurement data or published reference values with stated uncertainty.",
      "rationale": "Blood analogue viscosity was measured in-house at 37°C (μ = 3.45 ± 0.08 mPa·s). Density was taken from ASTM F1841. Pump geometry was imported from the FDA-released CAD file with dimensional verification. All inputs are documented in the simulation input record with traceability to primary sources."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental validation data must originate from at least two independent test articles or two independent test laboratories to confirm reproducibility.",
      "rationale": "Hemolysis index measurements were drawn from the FDA multi-laboratory round-robin study (Hariharan et al. 2011) involving three independent laboratories. Inter-laboratory coefficient of variation was 8.3%, within the acceptable range for blood trauma assays. CFD predictions fall within the inter-laboratory spread at all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstrate that the input parameter space used in validation experiments is equivalent to or bounding of the input parameter space encountered in the COU.",
      "rationale": "This factor is considered by the assessment team to have no bearing on the current COU because the CFD model is used exclusively for sensitivity ranking of geometric variants rather than absolute hemolysis prediction across a broad patient population. The operating envelope is fixed and narrow, and the team judges that input parameter equivalency is self-evident from the COU description. Accordingly, no formal equivalency mapping or bounding argument has been documented. The factor has not been formally evaluated against the ASME V&V 40 gradation scale."
    }
  ],
