  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen ASME V&V 40 credibility factors are fully assessed and meet or exceed their required gradation levels at MRL 3. Discretization error, output comparison, model form, and relevance of validation activities all achieve gradation 3. The equivalency of input parameters factor was not assessed on the basis that the validation and simulation share the same geometry and operating conditions; this determination was treated as rendering the factor inapplicable in practice, though the package encoding retains factorStatus 'not-assessed'. The assessment team accepted the package on the grounds that the shared geometry provides implicit parameter equivalency. Downstream reviewers should note that the 'not-assessed' encoding at MRL 3 represents an unresolved credibility gap (W-EP-04).",
