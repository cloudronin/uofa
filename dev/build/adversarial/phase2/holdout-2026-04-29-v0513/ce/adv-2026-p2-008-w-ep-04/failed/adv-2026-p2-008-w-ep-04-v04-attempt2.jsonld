      "acceptanceCriteria": "Solver must be under version control with documented regression tests covering the hemolysis transport equations.",
      "rationale": "ANSYS Fluent 2022 R2 is used under a validated QA framework. Version control, regression test suite, and release notes are archived. Achieved level 3 exceeds the required level 2 for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must demonstrate convergence on canonical benchmark problems relevant to rotating machinery flow.",
      "rationale": "Code verification was performed against the lid-driven cavity and rotating channel benchmarks. Residuals converge to 1e-6 and results match published reference solutions within 1%. Required level 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and the discretization error on the QoI must be below 5%.",
      "rationale": "A three-level mesh refinement study was conducted. GCI for the hemolysis index at the design point is 2.1%, well below the 5% threshold. Richardson extrapolation confirms monotonic convergence. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in the simulation within stated measurement uncertainty.",
      "rationale": "Inlet flow rates, rotational speeds, and fluid temperature match the FDA benchmark experimental protocol. Boundary condition uncertainty is ±2% for flow rate and ±0.5 rpm for speed, within acceptable tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within two standard deviations of the experimental scatter.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values at all five operating points fall within the experimental scatter band (±2σ) reported in the FDA interlaboratory study. Quantitative agreement is sufficient for MRL 3 decision support."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) must be directly linked to the clinical endpoint and the regulatory acceptance criterion.",
      "rationale": "RH is defined as the ratio of device NIH to predicate NIH. This metric directly maps to the regulatory submission criterion (RH < 1) and is the quantity used in the device comparison. Strong relevance to clinical hemolysis risk is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating range as the COU.",
      "rationale": "Validation uses the FDA generic pump geometry with a glycerin-water blood analog at physiological flow rates (2–6 L/min) and rotational speeds (2000–3500 rpm), matching the COU envelope. Validation relevance is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence must be demonstrated to a level where residual changes in QoI are below 0.1% between successive iterations.",
      "rationale": "All simulations are run to mass residual 1e-6 and momentum residual 1e-5. Monitor point tracking of NIH shows less than 0.05% change over the final 200 iterations, confirming iterative convergence. Required level 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation setup must be reviewed by a second qualified analyst and documented in the simulation log.",
      "rationale": "An independent analyst reviewed all boundary condition assignments, turbulence model settings, and hemolysis power-law exponent values prior to production runs. No discrepancies were found. Use error controls are adequate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The governing equations and constitutive models (turbulence, hemolysis power law) must be justified for the flow regime and QoI.",
      "rationale": "The SST k-ω turbulence model is selected based on its documented performance for confined rotating flows. The Giersiepen-Wurzinger power-law hemolysis model is the standard for CFD hemolysis prediction and is appropriate for the shear stress magnitudes encountered. Model form adequacy is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Material properties, geometric parameters, and operating conditions must be traceable to calibrated measurements or published reference data.",
      "rationale": "Fluid viscosity and density are taken from published glycerin-water mixture data at 37°C. Pump geometry is derived from the FDA-published CAD file. All inputs are traceable and documented in the simulation record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental samples used for validation must be representative of the device geometry and blood analog properties specified in the COU.",
      "rationale": "The FDA interlaboratory study used multiple pump specimens fabricated to the published tolerance band. Sample-to-sample geometric variation is within ±0.05 mm, consistent with the COU dimensional sensitivity range. Representativeness is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters must be shown to be equivalent to those used in the physical validation experiments within stated uncertainty bounds.",
      "rationale": "The assessment team concluded that equivalency of input parameters does not apply to this COU because the study is a purely computational sensitivity analysis with no direct experimental counterpart for the dimensional variants studied. Consequently, no equivalency assessment was performed. Note: the appropriate encoding for this determination would be factorStatus 'not-applicable'; the use of 'not-assessed' here means the factor's contribution to credibility remains unquantified at MRL 3, constituting an unassessed factor at elevated risk (W-EP-04)."
    }
