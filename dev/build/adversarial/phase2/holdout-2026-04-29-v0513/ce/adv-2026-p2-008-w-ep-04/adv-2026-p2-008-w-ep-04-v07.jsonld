  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all tests passing.",
      "rationale": "ANSYS Fluent 2022 R2 is used under a validated release with full regression testing. The simulation team follows an internal SQA plan aligned with FDA guidance. Achieved level 3 exceeds the required level 2 for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions demonstrating expected convergence rate.",
      "rationale": "MMS verification confirms second-order spatial convergence for the incompressible Navier-Stokes equations in rotating-frame formulation. Observed order 1.97 is consistent with the nominal second-order scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for shear-stress-derived hemolysis index on the finest two meshes.",
      "rationale": "Three-mesh Richardson extrapolation yields GCI of 1.8% for the hemolysis index QoI. The fine mesh (14.2 M cells) is adopted for all production runs. Achieved level 3 reflects quantified uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Bench test boundary conditions (flow rate, rotational speed, fluid temperature) documented and traceable to ISO 10628 test protocol.",
      "rationale": "All five operating points are defined by measured inlet flow rates (2–6 L/min) and impeller speeds (2000–3500 RPM) logged at ±1% accuracy. Temperature maintained at 37 ± 0.5 °C. Conditions are directly replicated as CFD boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Relative hemolysis index (RH) predicted within ±15% of measured values across all five operating points.",
      "rationale": "CFD-predicted RH values range from 0.71 to 0.94 versus measured 0.68 to 0.91. Maximum relative error is 9.3%, well within the ±15% acceptance band. The model consistently ranks operating points by hemolysis severity in agreement with bench data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs (hemolysis index, wall shear stress peaks) directly map to the clinical acceptance criterion RH < 1.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) converted to RH per ASTM F1841. Secondary QoIs include volume-averaged shear stress and exposure time distributions. All QoIs are directly linked to the regulatory acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic pump geometry under CPB-representative conditions.",
      "rationale": "Validation experiments use the FDA benchmark centrifugal pump geometry (identical to the simulation geometry) with bovine blood at physiological hematocrit (35%). Operating conditions span the CPB clinical range. Geometric and physiological fidelity of the validation scenario to the COU is high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Residual convergence to < 1e-5 for all transport equations; mass imbalance < 0.01%.",
      "rationale": "All simulations are run to scaled residuals below 1e-6 for continuity and momentum. Mass flow imbalance across inlet/outlet is 0.003%. Iterative convergence is confirmed by monitoring QoI stabilization over the final 500 iterations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal assessment of operator-induced errors in model setup, boundary condition entry, and post-processing interpretation.",
      "rationale": "The simulation team considers use error to be irrelevant for this COU because all CFD runs are executed through an automated scripting pipeline with no manual boundary condition entry during production runs. Accordingly, no formal use-error assessment was conducted. While this reasoning has merit for the automation layer, it does not account for errors introduced during script authoring, geometry import, or post-processing interpretation — domains where operator judgment remains consequential. At MRL 3, a formal use-error assessment is expected; the absence of one is not adequately justified by pipeline automation alone."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Justification provided for turbulence model selection and blood rheology model relative to the hemolysis prediction COU.",
      "rationale": "The SST k-ω turbulence model is selected based on published benchmarks for rotating blood-contacting devices. Blood is modeled as a Newtonian fluid at hematocrit 35%, consistent with CFD hemolysis literature. The power-law hemolysis damage model (Giersiepen et al.) is applied with published constants. Sensitivity to model form is bounded by the output comparison results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "All material properties and boundary condition inputs traceable to measurements or published sources with stated uncertainty.",
      "rationale": "Blood density (1055 kg/m³) and dynamic viscosity (0.0035 Pa·s) are sourced from ISO 10993-4 reference values. Pump geometry dimensions are from the FDA benchmark CAD file (revision 3). Inlet velocity profiles are derived from Doppler ultrasound measurements. All inputs are documented in the simulation data package with traceability references."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation test specimens are representative of the production pump geometry within specified dimensional tolerances.",
      "rationale": "Three physical pump specimens were manufactured to FDA benchmark specifications and measured by CMM. All critical dimensions are within ±0.05 mm of nominal. Specimen-to-specimen variability in hemolysis index was 4.2%, which is accounted for in the output comparison uncertainty band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "CFD model input parameters are equivalent to bench test conditions within quantified tolerances for all five operating points.",
      "rationale": "A parameter equivalency table documents the mapping between bench-measured and CFD-specified values for flow rate, rotational speed, fluid temperature, and hematocrit. Maximum parameter deviation is 1.2% for flow rate at operating point 3, within the stated ±2% equivalency tolerance. No significant systematic offset is identified."
    }
  ],
