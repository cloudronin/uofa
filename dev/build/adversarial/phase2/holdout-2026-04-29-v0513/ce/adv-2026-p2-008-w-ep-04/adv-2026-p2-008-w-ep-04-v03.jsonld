  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Version-controlled solver with documented release notes and regression test suite covering blood-pump benchmark cases.",
      "rationale": "ANSYS Fluent 2022 R2 is used under a validated installation qualification protocol. A regression test suite of 14 benchmark cases is executed at each release; all pass within specified tolerances. Version control and change records are maintained in the project configuration management system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver convergence to analytical solutions for canonical rotating-flow problems at order consistent with discretization scheme.",
      "rationale": "Order-of-accuracy verification performed using the method of manufactured solutions for the incompressible Navier-Stokes equations in rotating reference frames. Observed order (1.94) is consistent with the second-order upwind scheme employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "GCI < 5% on hemolysis index QoI across the three finest mesh levels.",
      "rationale": "A three-level mesh refinement study (2.1 M, 6.8 M, 18.4 M cells) yields a GCI of 2.7% on the normalised hemolysis index at the worst-case operating point (6 L/min, 3500 RPM), confirming discretization error is well within the 5% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented and traceable to test records.",
      "rationale": "All five validation test points are drawn from the FDA-sponsored bench study. Inlet flow rates, impeller speeds, blood analogue temperature (37 °C ± 0.5 °C), and hematocrit (33 ± 2%) are fully documented in the archived test report and replicated in the CFD boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted RH index within ±15% of measured values across all five operating points.",
      "rationale": "Predicted relative hemolysis index deviates from measured values by –3% to +11% across the five operating points, satisfying the ±15% criterion. Systematic over-prediction at high speed is consistent with known power-law model conservatism."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs (RH index, scalar shear stress distribution) directly map to the clinical hemolysis acceptance criterion.",
      "rationale": "The primary QoI is the normalised hemolysis index RH, which is the regulatory acceptance metric. Secondary QoIs (volume-averaged scalar shear stress, residence time distribution) are established surrogates for erythrocyte damage and are directly interpretable in the CPB clinical context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry and fluid under operating conditions spanning the COU envelope.",
      "rationale": "Validation data are sourced from experiments on the FDA generic centrifugal pump — the same geometry used in the COU — operated across the full clinical flow-speed envelope. No extrapolation beyond validated conditions is required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Residuals below 1e-5 for all equations; global mass imbalance below 0.01% at convergence.",
      "rationale": "All simulations are run to continuity residual 1e-6 and momentum residual 1e-5. Global mass imbalance at convergence is below 0.004% for all five operating points, confirming negligible solver truncation and round-off contribution to QoI uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "N/A — assessment team determined this factor does not apply to the COU.",
      "rationale": "The assessment team concluded that use error is not relevant to this context of use because the model is operated exclusively by trained simulation engineers under a controlled computational workflow with no end-user interaction in a clinical setting. Accordingly, no assessment activities were conducted for this factor. The factor is carried in the record as not-assessed rather than not-applicable, reflecting the team's view that the factor is simply outside scope for a purely computational submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model and hemolysis power-law coefficients justified against published literature for blood-analogue flows in rotating machinery.",
      "rationale": "The SST k-ω turbulence closure is selected based on published comparative studies for centrifugal blood pumps. The Giersiepen-Wurzinger power-law hemolysis model coefficients are sourced from peer-reviewed calibration data. Model form uncertainty is acknowledged as the dominant uncertainty source and is bounded by the ±15% output comparison criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Geometric dimensions, fluid properties, and boundary conditions traceable to design drawings and test reports.",
      "rationale": "CAD geometry is derived from the FDA-published generic pump drawings. Blood analogue viscosity and density are specified at 37 °C per ASTM F1841. Inlet velocity profiles and outlet pressure conditions are set from the archived bench-test data. All inputs are documented in the model input specification and subject to configuration control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "At least three independent pump specimens tested; sample-to-sample variability characterised.",
      "rationale": "The FDA bench study used five pump specimens manufactured to the same drawing set. Inter-specimen variability in hemolysis index was ±8%, which is incorporated into the ±15% output comparison acceptance criterion, providing adequate margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "CFD boundary conditions demonstrably equivalent to experimental conditions within documented tolerances.",
      "rationale": "A parameter-by-parameter equivalency table maps each experimental condition to the corresponding CFD input value. Flow rate equivalency is within 0.5%, rotational speed within 0.2%, and fluid temperature within 0.5 °C. These differences are shown by sensitivity analysis to produce less than 1% change in the hemolysis index QoI."
    }
  ],
