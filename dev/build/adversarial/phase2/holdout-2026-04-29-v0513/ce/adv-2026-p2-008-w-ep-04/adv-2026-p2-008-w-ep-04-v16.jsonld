  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 3.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) operates under a documented software quality assurance plan including version control, regression testing, and release validation. Solver verification test suite passes all benchmark cases. Achieved Gradation 3 — exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "Numerical code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes equations in rotating reference frames. Order-of-accuracy analysis confirms second-order spatial convergence. Achieved Gradation 2 — meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "A structured mesh convergence study was conducted across three refinement levels (coarse: 2.1M cells, medium: 5.8M cells, fine: 14.2M cells). Richardson extrapolation yields a discretization error estimate of 1.7% for the hemolysis index QoI. GCI < 3% on fine mesh. Achieved Gradation 3 — exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "Experimental test conditions replicate the five target flow-speed operating points (2.5 LPM/2500 RPM through 6.0 LPM/3500 RPM) using physiological saline-glycerol blood analog at 37°C. Inlet pressure and outlet backpressure are controlled within ±2% of target. Achieved Gradation 2 — meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "Predicted normalized index of hemolysis (NIH) is compared against experimental measurements at all five operating points. Mean absolute error is 8.3% across operating conditions. All predictions fall within experimental uncertainty bands. Achieved Gradation 2 — meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "The primary QoI — relative hemolysis index (RH) — directly maps to the clinical acceptance criterion (RH < 1 vs. predicate device). Secondary QoIs (shear stress distribution, exposure time histograms) are also clinically meaningful and directly support the hemolysis power-law model. Achieved Gradation 3 — exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "Validation experiments use the FDA generic centrifugal pump geometry at CPB-representative operating conditions. Blood analog fluid properties are matched to physiological ranges. Geometric fidelity of the test article to the computational model is confirmed by coordinate measurement. Achieved Gradation 2 — meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "Iterative convergence is monitored to residual levels below 1e-5 for all transport equations. Mass imbalance across the pump domain is less than 0.01%. Double-precision arithmetic is used throughout. Achieved Gradation 2 — meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "Simulation setup is governed by a documented simulation plan reviewed by an independent analyst. Boundary condition inputs are traceable to calibrated test data. A pre-submission checklist and peer review of the model setup were completed prior to regulatory submission. Achieved Gradation 2 — meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "The SST k-omega turbulence model is selected based on published benchmarks for rotating machinery hemolysis prediction. The Giersiepen-Wurzinger power-law hemolysis model is applied with literature-derived coefficients. Sensitivity of hemolysis index to model-form choices is quantified via comparison with the Bludszuweit model, yielding < 12% difference. Achieved Gradation 2 — meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "All model inputs (fluid viscosity, density, pump geometry, rotational speed, inlet flow rate) are derived from calibrated measurements with documented uncertainty. Sensitivity analysis confirms hemolysis index is most sensitive to rotational speed (±1.5% NIH per 10 RPM). Input uncertainty propagation performed via one-at-a-time perturbation study. Achieved Gradation 2 — meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2.",
      "rationale": "Validation experiments were conducted using three independently manufactured pump specimens to capture unit-to-unit geometric variability. Each specimen was tested at all five operating points with three repeat runs per point. Statistical analysis of inter-specimen variability confirms repeatability within 5% NIH. Achieved Gradation 2 — meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not evaluated; team judged this factor does not apply to a CFD-only comparative hemolysis assessment where no physical patient-specific inputs are transferred between test and use contexts.",
      "rationale": "The assessment team concluded that equivalency of input parameters is not relevant to this COU because the simulation inputs are derived directly from bench-top measurements at the target operating conditions, and no parameter mapping between a distinct test context and the COU is performed. The factor was therefore not assessed rather than formally scoped out or designated not-applicable. At MRL 3, however, this factor warrants formal evaluation: differences between the blood analog fluid properties used in validation and in-vivo blood rheology represent a potential unassessed source of model credibility risk that has not been quantified or bounded."
    }
  ],
