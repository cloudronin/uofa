  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. The six not-assessed factors are appropriately scoped out at MRL 2. Uncertainty quantification was completed with Monte Carlo propagation across documented input ranges, yielding a 95th-percentile RH of 0.87, below the RH < 1 acceptance criterion. The UQ report narrative references a screening sensitivity study identifying rotational speed and tip clearance as dominant variance contributors, providing sufficient context for the regulatory decision. The overall credibility body of evidence supports acceptance of the CFD model for the stated COU.",
