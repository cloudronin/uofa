  "modelRiskLevel": 2,
  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Uncertainty quantification has been performed across key boundary condition inputs (inlet flow rate, rotational speed, blood viscosity) using a Monte Carlo propagation approach with 2000 samples. A screening sensitivity study was conducted during model development to identify influential parameters; however, that screening exercise was internal to the UQ workflow and its structured outputs are reported within the UQ documentation package rather than as a separately linked sensitivity analysis artefact.",
  "hasUncertaintyQuantification": true,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou1-hemolysis-requirement",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou1-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-centrifugal-pump-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/morrison-cfd-mesh-refinement-study",
    "https://uofa.net/synth/data/morrison-uq-montecarlo-2000samples"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-fda-pump-benchmark",
      "type": "ValidationResult",
      "name": "FDA generic centrifugal pump benchmark validation — hemolysis index comparison",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against published FDA benchmark experimental data at 5 flow-speed operating points. Mean relative error 8.3% across all conditions; all predictions within experimental uncertainty band. Relative hemolysis index RH < 1 confirmed for worst-case operating point."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — discretization error quantification",
      "description": "Grid convergence index (GCI) computed across three mesh refinement levels (4.2M, 11.7M, 28.4M elements). GCI for NIH at worst-case operating point: 3.1%. Asymptotic convergence confirmed (GCI ratio 1.02)."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-uq-propagation",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ propagation — boundary condition uncertainty",
      "description": "2000-sample Monte Carlo propagation of inlet flow rate (±5%), rotational speed (±2%), and blood viscosity (±8%) uncertainties through the CFD hemolysis model. 95th-percentile NIH remains below acceptance threshold. A screening sensitivity study was embedded within this UQ workflow to triage input contributions; dominant drivers were characterized informally and documented in the UQ technical report. No formal ranked sensitivity index table was produced as a standalone deliverable."
    }
  ],
