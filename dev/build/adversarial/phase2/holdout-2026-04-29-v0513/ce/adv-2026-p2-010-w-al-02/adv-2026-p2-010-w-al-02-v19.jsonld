  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately not assessed per MRL 2 scoping. UQ has been performed demonstrating that 95th-percentile NIH remains below the acceptance threshold under combined input uncertainty. A screening sensitivity study was conducted as part of the UQ workflow and its findings are summarized in the UQ technical report, confirming that rotational speed and inlet flow rate are the dominant contributors to NIH variability. The relative hemolysis index RH < 1 is satisfied at all COU operating points including the worst-case condition. The model is accepted as fit for purpose for the stated COU at the Medium assurance level.",
