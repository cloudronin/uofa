    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index bench-top comparison against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against published FDA benchmark experimental measurements at five operating points (2.5 L/min at 2000 RPM through 6.0 L/min at 3500 RPM). Mean relative error across operating points was 8.3%, within the acceptance threshold of 15% established for MRL 2."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-wall-shear-stress-validation",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation against PIV measurements",
      "description": "Particle image velocimetry (PIV) measurements from an in-vitro transparent pump model were used to validate predicted velocity fields and derived wall shear stress distributions at the impeller outlet. Agreement was quantified using the validation metric of ASME V&V 20; the model was deemed adequate for hemolysis-relevant flow feature prediction."
    }
  ],
