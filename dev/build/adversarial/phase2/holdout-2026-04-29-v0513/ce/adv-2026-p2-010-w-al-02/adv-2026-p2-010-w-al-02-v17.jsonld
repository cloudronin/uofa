      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022 R2) with documented V&V pedigree; version-controlled simulation scripts with checksum verification.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially validated solver with FDA-recognized SQA documentation. All simulation input decks are stored in a version-controlled repository with SHA-256 checksums. SQA level meets Gradation 2 requirements for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
