  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors appropriately scoped as not-assessed per MRL 2 requirements. Uncertainty quantification over six input parameters demonstrates that RH index predictions remain below the RH < 1 acceptance criterion across the 95th percentile of the sampled input space (maximum RH = 0.87 at worst-case operating point). The assessment team reviewed the UQ technical memorandum TM-UQ-2023-02, which includes narrative description of a screening sensitivity study identifying flow rate and impeller speed as dominant variance contributors. On this basis the model is accepted as sufficiently credible to support the intended regulatory decision for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
