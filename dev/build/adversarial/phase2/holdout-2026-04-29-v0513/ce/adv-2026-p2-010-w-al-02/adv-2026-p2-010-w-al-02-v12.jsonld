  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors appropriately scoped as not-assessed per MRL 2 requirements. Validation evidence demonstrates CFD model predicts hemolysis index within 12.1% of experimental measurements across the full COU operating envelope. Uncertainty quantification using 200-sample LHS propagation confirms RH < 1 criterion satisfied at the 95th percentile across all five operating point combinations. A screening sensitivity study was conducted and its findings are summarized in the UQ technical report; rotational speed and hemolysis model exponent identified as dominant uncertainty drivers. The overall credibility body of evidence is judged sufficient to support the regulatory submission decision for the Class II CPB device at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
