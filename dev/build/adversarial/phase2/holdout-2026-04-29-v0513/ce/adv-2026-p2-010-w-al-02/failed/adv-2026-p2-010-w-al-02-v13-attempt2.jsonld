      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite and version-controlled source; all simulations run under documented software environment.",
      "rationale": "ANSYS Fluent 2021R2 used under institutional license with documented version control. Solver regression tests confirm benchmark suite passage. SQA procedures documented per FDA software guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least one published benchmark problem relevant to rotating machinery or viscous internal flow.",
      "rationale": "Solver verified against lid-driven cavity benchmark (Re=1000) and rotating channel flow; results agree with published solutions within 0.5% for velocity profiles."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on at least one representative operating point.",
      "rationale": "Three-level mesh refinement study performed at 2500 RPM, 5 L/min. GCI for normalized index of hemolysis = 3.1%. Asymptotic convergence ratio = 0.97, confirming monotonic convergence in the asymptotic range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must bracket the clinical operating envelope; fluid properties must match physiological blood analogue within 10%.",
      "rationale": "FDA experimental dataset covers flow rates 2.5–7 L/min and speeds 2000–3500 RPM, bracketing CPB operating envelope. Glycerol-water analogue viscosity within 8% of whole blood at 37°C."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must agree with experimental values within 25% across all 5 operating points.",
      "rationale": "NIH predictions agree with FDA experimental data within 18% at all 5 operating points. Mean absolute error = 11.4%. Systematic over-prediction at high speed corrected by power-law exponent calibration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) must be directly computable from model outputs and directly comparable to the clinical acceptance criterion.",
      "rationale": "RH is computed as ratio of device NIH to predicate device NIH under identical flow conditions. This directly maps to the regulatory acceptance criterion RH < 1 and is extractable from CFD scalar transport results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating conditions must be sufficiently similar to the CPB COU that extrapolation uncertainty is bounded and documented.",
      "rationale": "Validation performed on FDA generic centrifugal pump, which is geometrically representative of the CPB device class. Operating conditions overlap with COU envelope. Geometric differences documented and assessed as minor for hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver residuals monitored to confirm convergence.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-5 for all equations. Factor scoped to Gradation 1 per MRL 2 table."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation setup review by second analyst sufficient.",
      "rationale": "Independent review of simulation setup, boundary conditions, and post-processing scripts performed by second team member. No use errors identified. Formal use error analysis not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection documented with qualitative justification.",
      "rationale": "SST k-omega turbulence model selected based on literature consensus for rotating blood-contacting devices. Power-law hemolysis model (Giersiepen-Wurzinger) used per FDA guidance. Formal model form uncertainty analysis not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (geometry, boundary conditions, fluid properties) must be traceable to measurement data or published standards with documented uncertainty bounds.",
      "rationale": "Inlet flow rates measured with calibrated ultrasonic flowmeter (±2%). Rotational speed measured with optical tachometer (±10 RPM). Fluid viscosity measured with cone-plate rheometer (±3%). Geometric dimensions from CMM measurements (±0.05 mm). Input uncertainty bounds propagated through Monte Carlo sampling (N=500 runs) to characterize output variability. A screening sensitivity study described in the UQ technical report identified flow rate and rotational speed as the primary contributors to NIH variability; however, this screening is documented narratively and no structured sensitivity analysis record has been formally linked to this credibility package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA experimental dataset used as-is with documented provenance.",
      "rationale": "FDA generic pump experimental dataset used directly. Sample size and preparation documented in FDA benchmark report. Formal test sample adequacy analysis not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of validation inputs to COU inputs documented.",
      "rationale": "Qualitative mapping confirms that validation boundary conditions (flow rate, speed, fluid properties) correspond to COU operating conditions. Formal equivalency analysis not required at MRL 2."
