  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped to Gradation 1 per MRL 2 requirements and confirmed not-assessed. Uncertainty quantification via Monte Carlo propagation demonstrates RH < 1 is maintained across the sampled input space with 95th percentile RH = 0.87. The UQ report references a screening sensitivity study identifying flow rate and rotational speed as dominant hemolysis drivers; this narrative evidence supports model input adequacy. The overall evidence base is sufficient to accept the CFD model for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
