  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must operate under documented version control with traceable build records and regression test suite.",
      "rationale": "ANSYS Fluent 2021 R2 was used under ISO 9001-compliant QMS with full version control, regression testing, and documented release notes. Achieved level meets the required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate convergence on manufactured solution benchmarks relevant to internal rotating flow.",
      "rationale": "ANSYS Fluent has been verified against published Taylor-Couette and lid-driven cavity benchmarks. Internal rotating flow convergence confirmed via method of manufactured solutions at second-order accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the finest mesh.",
      "rationale": "Three-mesh Richardson extrapolation study performed at the nominal operating point (3.5 L/min, 3500 RPM). GCI on normalized index of hemolysis was 2.8% on the fine mesh (8.4 M cells), satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within stated tolerances for flow rate (±0.1 L/min) and rotational speed (±50 RPM).",
      "rationale": "Bench experiments were conducted at the FDA CDRH laboratory using the generic centrifugal pump geometry. Flow rates and rotational speeds were matched to CFD boundary conditions within ±0.05 L/min and ±30 RPM respectively."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with measured values within 20% across all 5 operating points.",
      "rationale": "CFD-predicted NIH values compared against experimental measurements at all 5 flow-speed operating points. Maximum deviation was 14.3% at the 2.5 L/min / 2500 RPM condition; all other points within 10%. Acceptance criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH and relative hemolysis index RH) must be directly linked to the clinical endpoint of hemolysis risk in CPB patients.",
      "rationale": "NIH is the FDA-accepted metric for pump-induced hemolysis evaluation. RH < 1 criterion directly maps to non-inferiority versus predicate device, providing clear linkage to the clinical decision endpoint."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating range as the COU.",
      "rationale": "Validation employed the identical FDA generic centrifugal pump STL geometry, porcine blood at 37°C with hematocrit 30±2%, and operating conditions spanning the full COU envelope. Validation activities are directly representative of the intended use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 given code verification evidence already addresses solver accuracy.",
      "rationale": "At MRL 2, separate numerical solver error quantification beyond code verification is not required. Code verification (Richardson extrapolation and MMS) provides sufficient evidence of solver numerical accuracy for this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when simulation is performed by trained personnel under QMS.",
      "rationale": "Simulation was performed by personnel with documented CFD competency under a QMS. Formal use-error analysis is not required at MRL 2 given the controlled execution environment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form uncertainty addressed qualitatively through turbulence model selection rationale.",
      "rationale": "SST k-omega turbulence model was selected based on published literature for internal rotating flows in centrifugal pumps. Formal model form uncertainty quantification is not required at MRL 2; qualitative justification is sufficient."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (viscosity, density, power-law hemolysis constants) must be characterized with stated uncertainty bounds from literature or measurement.",
      "rationale": "Blood viscosity modeled as non-Newtonian Carreau fluid with parameters from Cho and Kensey (1991); density 1056 kg/m3 ±5 kg/m3. Hemolysis power-law constants (C, alpha, beta) drawn from Zhang et al. (2011) with reported confidence intervals. Uncertainty quantification via Monte Carlo propagation of these input distributions was performed, yielding a 95% prediction interval on NIH of ±18% at nominal conditions. A screening sensitivity study conducted during the UQ analysis identified inlet flow rate and rotational speed as the dominant contributors to NIH variance, accounting for approximately 73% of total output variance; however, this screening analysis was performed as an internal workbook exercise and has not been encoded as a separate structured artifact in this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; single-lot blood analog with characterized properties is acceptable.",
      "rationale": "Single lot of porcine blood with documented hematocrit and viscosity characterization was used. Statistical characterization of inter-lot variability is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when direct boundary condition matching is demonstrated.",
      "rationale": "Direct matching of CFD boundary conditions to experimental conditions was demonstrated under the Test Conditions factor. Formal equivalency analysis of input parameter distributions between validation and COU contexts is not required at MRL 2."
    }
