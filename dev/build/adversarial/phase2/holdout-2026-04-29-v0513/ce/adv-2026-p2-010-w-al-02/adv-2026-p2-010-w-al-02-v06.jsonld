  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required gradation levels for MRL 2. Six factors accepted at default Gradation 1 per MRL 2 scoping. Uncertainty quantification was performed with Monte Carlo propagation across primary input parameters, and output uncertainty bounds on the relative hemolysis index confirm the RH < 1 criterion is satisfied with high confidence across all five operating points. The credibility assessment team notes that a screening sensitivity study was conducted and its findings informed the input uncertainty characterization; however, this screening analysis is documented in internal project records rather than as a formally encoded structured artifact in this submission package. The overall evidence package is judged sufficient to support the Accepted decision for the Class II CPB device at MRL 2.",
