  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. UQ results demonstrate that the relative hemolysis index remains below the 1.0 acceptance threshold at the 95th percentile under inlet variability. A screening sensitivity study conducted during model development suggested rotational speed and impeller gap geometry as dominant contributors to output variance; these findings were used to bound the UQ input distributions. The six non-assessed factors are acceptable under MRL 2 scoping. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
