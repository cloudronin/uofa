      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be version-controlled with documented verification tests and a traceable build record.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a validated software configuration management plan. Unit tests and regression suites confirmed solver integrity. Version hash recorded in the simulation archive."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must confirm expected spatial convergence rate for the governing equations.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes and scalar transport equations. Observed second-order convergence in L2 norm confirmed for velocity and hemolysis power-law scalar fields."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be reported; GCI on RH index must be below 5%.",
      "rationale": "Three-level mesh refinement study performed on the baseline geometry (coarse 4.2 M, medium 11.6 M, fine 28.4 M cells). GCI on the normalized hemolysis index was 2.1%, well within the 5% threshold. Medium mesh selected for the UQ campaign to balance accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in simulation within measurement uncertainty bands.",
      "rationale": "Inlet flow rate, rotational speed, and fluid temperature from FDA bench tests were applied as boundary conditions. Measurement uncertainties (±2% flow, ±0.5% RPM) were incorporated into the UQ sampling distributions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index must agree with experimental measurements within combined simulation and experimental uncertainty at all 5 operating points.",
      "rationale": "Predicted normalized index of hemolysis agreed with FDA experimental data within 8% at all five flow-speed combinations. Combined uncertainty bands overlapped at every operating point, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (RH index) must be directly mappable to the clinical hemolysis endpoint used in the regulatory submission.",
      "rationale": "The relative hemolysis index is the accepted surrogate for plasma-free hemoglobin elevation in FDA guidance. The QoI directly supports the worst-case operating condition identification decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating envelope as the COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry with porcine blood analog at 37°C across the CPB operating envelope (2–6 L/min, 2000–3500 RPM). Geometry, fluid, and operating conditions are representative of the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error beyond discretization is not required to be separately characterized at Model Risk Level 2 for this device class. Iterative convergence was monitored to residual tolerance of 1e-6 for all equations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal use-error assessment not required at MRL 2. Simulation setup was peer-reviewed by a second analyst and checklist-verified against the simulation plan prior to execution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis power-law constants) was discussed qualitatively in the UQ narrative but formal model-form assessment is not required at MRL 2. The Giersiepen-Wurzinger power law was selected based on published benchmarks."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Distributions must be assigned to all uncertain inputs and propagated through the model; output uncertainty bounds must be reported.",
      "rationale": "Latin hypercube sampling with 200 realizations was used to propagate uncertainty in inlet flow rate, rotational speed, blood viscosity, and hemolysis model coefficients. Output distributions of RH index were computed; the 95th-percentile RH remained below 1.0 at all operating points. A screening sensitivity study conducted during model development informed the selection of these four inputs as the primary sources of variability, and their distributions were calibrated to manufacturer tolerance data and published rheology literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal characterization of test sample variability (device-to-device geometric variation) is not required at MRL 2. Nominal geometry was used for all simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Equivalency of input parameters between validation and COU contexts was confirmed qualitatively. Operating conditions, fluid properties, and geometry are sufficiently representative; formal quantitative equivalency mapping is not required at MRL 2."
    }
