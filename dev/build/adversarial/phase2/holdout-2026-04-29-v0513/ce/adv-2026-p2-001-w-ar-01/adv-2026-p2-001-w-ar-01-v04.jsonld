  "signature": "ed25519:7b3c9a1d4f2e8b6c0a5d3f1e9c7b4a2d6f0e8c3b1a9d7f5e3c1b0a8d6f4e2c0",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD solver (ANSYS Fluent 2022 R2) must hold a documented software quality plan including version control, regression test suite, and release validation records consistent with ASME VV40 Gradation 2 requirements for MRL 2 applications.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially validated solver with ISO 9001-certified development processes. Vendor-supplied regression test documentation and release notes confirm Gradation 2 SQA compliance. No custom UDFs were used in this study; all solver settings were controlled via named parameter files stored in the project version-control repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The solver must reproduce analytical benchmark solutions (lid-driven cavity, Poiseuille flow) to within 1% of the analytical value at the mesh densities used in production runs, satisfying Gradation 2 for numerical code verification.",
      "rationale": "Code verification was performed using the method of manufactured solutions applied to a simplified rotating-frame channel geometry. Observed order of accuracy was 1.94 ± 0.07 for velocity components, consistent with the solver's nominally second-order spatial discretization. Results were archived in the project verification report VR-2024-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study must demonstrate that the normalized global discretization error in the hemolysis index quantity of interest is less than 5% between the medium and fine mesh levels, establishing Gradation 2 compliance with margin.",
      "rationale": "A three-level polyhedral mesh convergence study was conducted at the nominal operating point (5 L/min, 3500 RPM). The normalized index of mesh quality (GCI) between medium (8.4 M cells) and fine (22.1 M cells) meshes was 2.1% for the volume-averaged scalar stress and 3.4% for the RHI. The achieved level of 3 reflects the additional Richardson extrapolation performed across all five flow-speed operating points, confirming robustness of the discretization error estimate beyond the minimum Gradation 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to confirm that inlet flow rate, rotational speed, fluid temperature, and hematocrit are controlled within ±5% of nominal simulation boundary conditions.",
      "rationale": "The FDA benchmark experimental data (Hariharan et al. 2011) documents inlet flow rates, rotational speeds, and fluid properties for the five operating points used in this study. Blood analog fluid (aqueous glycerol, 40% hematocrit equivalent viscosity) was used in experiments; CFD boundary conditions were set to match reported values. Temperature variation across test runs was ±1.2°C, within acceptable limits for viscosity model applicability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RHI values must agree with experimental RHI measurements within the combined experimental and numerical uncertainty bands at each of the five operating points, and the mean absolute percentage error must not exceed 15% across all operating points.",
      "rationale": "Predicted RHI values at all five operating points fell within the experimental uncertainty envelope reported by Hariharan et al. The mean absolute percentage error across operating points was 9.3%, with the largest single-point deviation of 13.8% occurring at the lowest flow rate (3 L/min, 2500 RPM) where experimental scatter was also highest. These results confirm Gradation 2 output comparison compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary quantity of interest (relative hemolysis index, RHI) must be directly computable from CFD outputs via the Giersiepen-Wurzinger power-law model and must map unambiguously to the clinical endpoint of plasma-free hemoglobin elevation.",
      "rationale": "The RHI is computed directly from the Lagrangian particle-tracking scalar stress exposure integral, which is the standard QoI for CFD hemolysis assessment per ASTM F1841 and ISO 10993-4 guidance. The mapping from RHI to clinical hemolysis risk is well established in the literature and is the basis for the predicate device comparison strategy used in the submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Validation activities were conducted using the FDA generic centrifugal blood pump geometry — the same geometry class as the device under assessment. The five flow-speed combinations used in validation span the full COU operating envelope, including the worst-case high-speed, low-flow condition (5 L/min, 3500 RPM) identified in the sensitivity study. Fluid properties, rotational reference frame treatment, and hemolysis model parameterization were identical between validation and production simulations. The validation scenario therefore constitutes a direct analog to the COU rather than a surrogate or simplified geometry. The assessment team reviewed the COU-to-validation scenario mapping matrix (document VA-MAP-2024-01) and confirmed that no significant unrepresented physics exist between the validation and COU contexts. Given the directness of the mapping and the breadth of the operating-point coverage, the team concluded that the validation evidence base is sufficient to support the credibility claim at Model Risk Level 2 without additional scenario-specific validation studies. This conclusion is consistent with the FDA's 2021 computational modeling guidance, which permits reliance on publicly available benchmark datasets when the geometry and flow regime are sufficiently representative of the device COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver error is subsumed within the discretization error and code verification factors at Gradation 1.",
      "rationale": "At Model Risk Level 2, the ASME VV40 credibility matrix does not require independent assessment of numerical solver error beyond what is captured in the discretization error and numerical code verification factors. This factor is scoped to Gradation 1 (not assessed) in accordance with the MRL 2 credibility matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; use error controls are addressed through the SQA factor and internal peer review procedures.",
      "rationale": "Use error assessment is not required at Model Risk Level 2. Procedural controls including simulation setup checklists, independent peer review of boundary condition inputs, and named parameter file version control collectively mitigate use error risk to an acceptable level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive model must be justified by literature evidence or sensitivity analysis demonstrating that alternative model forms produce RHI predictions within 20% of the selected model across the COU operating envelope.",
      "rationale": "Turbulence model sensitivity was evaluated by comparing SST k-omega and realizable k-epsilon predictions at three operating points. Maximum RHI deviation between models was 11.4%. The Giersiepen-Wurzinger hemolysis model was selected based on its widespread use in FDA-reviewed CFD submissions and its calibration against the erythrocyte lysis data most representative of the CPB shear exposure durations in this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material property inputs (viscosity, density) and geometric boundary condition inputs must be traceable to documented measurement sources with stated uncertainty, and a one-at-a-time sensitivity study must confirm that ±10% variation in each input produces less than 15% change in RHI.",
      "rationale": "Blood analog fluid properties were sourced from the FDA benchmark dataset with documented measurement uncertainty. Geometric dimensions were taken from the published FDA pump CAD file (v3.2). One-at-a-time sensitivity analysis on inlet velocity, rotational speed, and fluid viscosity confirmed that RHI sensitivity to each input was below 12% for ±10% parameter variation, satisfying the Gradation 2 model inputs requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; the validation dataset is a published benchmark with sufficient sample characterization for Gradation 1 purposes.",
      "rationale": "Test sample characterization beyond what is documented in the FDA benchmark publication is not required at Model Risk Level 2. The published dataset provides sufficient sample description (fluid composition, hematocrit equivalent, temperature) to support Gradation 1 compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; boundary condition equivalency is addressed qualitatively through the test conditions factor.",
      "rationale": "Formal equivalency analysis of input parameters between validation and COU scenarios is not required at Model Risk Level 2. The qualitative mapping documented in the test conditions factor and the validation relevance factor is sufficient for MRL 2 credibility."
    }
  ],
