  "hash": "sha256:a3f1c8e204b97d56f0e3a2c1d9b4e7f8a1c3d5e7b9f2a4c6d8e0b2f4a6c8e0a2",
  "signature": "ed25519:b7d2e4f6a8c0e2f4b6d8a0c2e4f6b8d0a2c4e6f8b0d2f4a6c8e0b2d4f6a8c0e2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold a documented QA plan covering version control, regression testing, and release validation. At MRL 2, Gradation 2 requires evidence of systematic QA processes without full formal verification.",
      "rationale": "ANSYS Fluent 2022 R2 is employed as the CFD solver. The software vendor maintains ISO 9001-certified development processes, and the release includes a documented validation suite covering canonical fluid mechanics benchmarks. Internal records confirm that the project team used a version-controlled simulation environment with change logs maintained throughout the study. Gradation 2 is achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations through at least one benchmark problem with a known analytical or manufactured solution, consistent with Gradation 2 requirements at MRL 2.",
      "rationale": "The solver implementation was verified against the Taylor-Couette flow analytical solution and the FDA nozzle benchmark (FDA Critical Path). Residual convergence was confirmed to machine-precision levels on structured grids. Results are consistent with published verification data for ANSYS Fluent in rotary blood pump applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study must be performed with at least three systematically refined mesh levels. Grid Convergence Index (GCI) must be computed for the primary quantity of interest (hemolysis index). At MRL 2, Gradation 2 requires demonstrated convergence; Gradation 3 additionally requires GCI < 5% on the finest mesh.",
      "rationale": "A three-level mesh refinement study was conducted with coarse (2.1 M cells), medium (5.8 M cells), and fine (14.2 M cells) meshes. GCI values computed per Roache (1998) yielded GCI_fine = 1.8% for the scalar stress-based hemolysis index at the design operating point (6 L/min, 2400 RPM). Polyhedral meshing with boundary layer prism cells was used throughout. The achieved level of Gradation 3 exceeds the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to confirm their relevance to the COU. At Gradation 2, boundary conditions, fluid properties, and operating parameters must be reported with traceability to calibrated instruments.",
      "rationale": "Validation experiments were conducted at the FDA laboratory using bovine blood with hematocrit 33±2% and temperature 37°C. Flow rates were set using calibrated Coriolis meters (±0.5% accuracy). Rotational speed was controlled via a servo drive with encoder feedback (±5 RPM). All test conditions are documented in the experimental protocol archived under FDA study ID FDA-CPB-2019-003."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted outputs must be compared against experimental measurements using a defined metric. At Gradation 2, qualitative agreement with quantitative error reporting is required; systematic bias must be identified and discussed.",
      "rationale": "Relative hemolysis index (RHI) predictions were compared against experimental measurements across all 5 operating points. Mean absolute percentage error was 12.3%, with the model consistently over-predicting hemolysis by approximately 8%, providing a conservative bias favorable to patient safety. The over-prediction trend is consistent with the Giersiepen power-law hemolysis model's known conservatism at low shear stress exposures."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (QoI) computed by the model must be directly linked to the clinical or regulatory decision. At Gradation 2, a documented argument connecting QoI to the COU decision criterion is required.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) and the relative hemolysis index (RH). These quantities are directly referenced in FDA guidance for blood-contacting devices and in ASTM F1841. The COU decision criterion (RH < 1 relative to predicate device) is expressed in terms of the same QoI computed by the CFD model, establishing direct relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The validation activities were designed to replicate the physiological and geometric conditions of the COU as closely as practicable. The FDA generic centrifugal pump geometry served as the validation platform, sharing key geometric features (volute design, impeller blade count, tip clearance range) with the subject device. Operating conditions for validation (flow rates 3–8 L/min, speeds 1800–3000 RPM) fully bracket the COU operating envelope. Blood analog fluid properties were matched to physiological values documented in the COU specification. The validation hierarchy progresses from component-level (isolated impeller passage) to system-level (full pump assembly), providing a structured basis for extrapolation to the COU. Boundary condition fidelity was assessed by comparing inlet velocity profiles between the validation rig and the clinical circuit model; deviations were less than 4% in mean velocity and within the uncertainty band of the experimental measurements. The assessment team concluded that the validation activities, taken collectively, provide sufficient coverage of the COU physics to support Gradation 2 relevance at MRL 2. This conclusion is consistent with the approach documented in the ASME V&V 40 worked example for rotary blood pumps and with FDA reviewer feedback on analogous submissions. No extrapolation beyond the validated operating range is required for the COU decision, further strengthening the relevance argument. The spatial and temporal resolution of the validation CFD models matches that used in the COU simulations, ensuring that numerical approximation errors are comparable across the validation and prediction contexts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor. Scoped out per Table 2 of ASME V&V 40-2018.",
      "rationale": "At Model Risk Level 2, numerical solver error is not required to be assessed as a standalone factor. Solver errors are partially addressed through the code verification and discretization error assessments. This factor is not assessed per the MRL 2 requirements matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2. Use error controls are addressed through the software QA factor and internal peer review processes.",
      "rationale": "Use error assessment is not required at MRL 2 for this COU. Procedural controls including simulation setup checklists, peer review of boundary condition specifications, and independent result verification are in place and documented under the project QA plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2. Model form uncertainty is partially addressed through the validation comparison and output comparison factors.",
      "rationale": "Model form assessment (turbulence model selection, hemolysis power-law model uncertainty) is not required as a standalone factor at MRL 2. The output comparison factor captures aggregate model-form error implicitly through the experimental comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2. Input parameter sensitivity is addressed qualitatively through the test conditions factor.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Key input parameters (viscosity, density, inlet velocity profile) were set to nominal values with documented sources. Sensitivity to ±10% variation in blood viscosity was checked informally and found to produce less than 3% change in NIH, supporting robustness of the nominal input set."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2. Sample characterization is addressed through the test conditions factor documentation.",
      "rationale": "Formal test sample characterization as a standalone credibility factor is not required at MRL 2. Blood sample properties (hematocrit, plasma protein content) are documented within the test conditions assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2. Equivalency is addressed through the relevance of validation activities factor.",
      "rationale": "Equivalency of input parameters between the validation context and the COU is not assessed as a standalone factor at MRL 2. The relevance of validation activities factor addresses the degree to which validation conditions map to COU conditions, covering the substance of this factor."
    }
  ],
