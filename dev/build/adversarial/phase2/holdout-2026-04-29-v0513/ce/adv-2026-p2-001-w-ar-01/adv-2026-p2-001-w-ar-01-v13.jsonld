  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. Six factors are not assessed, consistent with MRL 2 requirements per ASME V&V 40-2018 Table 2. The CFD model is assessed as sufficiently credible to support the regulatory decision regarding worst-case hemolysis operating conditions for the Class II CPB device. The conservative bias in hemolysis prediction provides additional confidence in patient safety conclusions.",
