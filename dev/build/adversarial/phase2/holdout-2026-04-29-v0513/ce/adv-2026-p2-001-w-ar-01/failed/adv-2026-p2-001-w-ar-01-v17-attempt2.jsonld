  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at Model Risk Level 2. The six not-assessed factors are appropriately scoped out at MRL 2 per ASME V&V 40 Table 1 requirements. The CFD model is deemed credible for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index predictions are sufficiently accurate (MAPE 18.4%, within ±25% acceptance band) and the rank ordering of operating conditions is preserved, supporting the regulatory decision.",
