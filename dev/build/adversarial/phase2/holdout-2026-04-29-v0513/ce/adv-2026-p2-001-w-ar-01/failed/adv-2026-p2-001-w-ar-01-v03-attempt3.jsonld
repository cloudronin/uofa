  "signature": "ed25519:9f3a1c5e7b2d4f6a8c0e2b4d6f8a1c3e5b7d9f0a2c4e6b8d0f2a4c6e8b0d2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures must demonstrate version-controlled solver builds, documented test suite execution, and traceable change logs consistent with Gradation 2 requirements for MRL 2 devices.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated, FDA-recognized simulation software. Version control is maintained through the organization's ISO 9001-compliant software management system. Regression test suite results for the relevant solver modules are archived and traceable to the specific build used in this analysis. Gradation 2 is required and achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification evidence must include at least one benchmark problem with known analytical or manufactured solution demonstrating solver correctness for the relevant flow regime at Gradation 2.",
      "rationale": "The Navier-Stokes solver was verified against the Taylor-Green vortex manufactured solution and the lid-driven cavity benchmark at Reynolds numbers representative of CPB operating conditions. Observed order of accuracy is consistent with second-order spatial discretization. Residual convergence to 1e-6 was confirmed for all benchmark cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via a formal mesh convergence study using at least three systematically refined meshes; the Richardson extrapolation-based GCI must be reported for the primary QoI at Gradation 2.",
      "rationale": "A three-level mesh refinement study was conducted using mesh sizes of 2.1M, 6.8M, and 18.4M cells. Richardson extrapolation yielded a GCI of 1.8% for the normalized hemolysis index at the worst-case operating point, well within the 5% threshold. Achieved level is Gradation 3 due to the systematic refinement approach and low GCI value, exceeding the Gradation 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with measured boundary conditions, fluid properties, and operating parameters that are representative of the COU at Gradation 2.",
      "rationale": "Validation experiments were conducted using a blood analogue fluid (glycerin-water mixture, viscosity 3.5 cP at 37°C) under controlled flow conditions matching the five operating points defined in the COU. Inlet flow rates, rotational speeds, and outlet pressures were measured and archived. Uncertainty in measured boundary conditions is quantified and propagated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation predictions must be compared against experimental measurements for the primary QoI using a defined metric; agreement within stated uncertainty bounds must be demonstrated at Gradation 2.",
      "rationale": "Predicted normalized hemolysis index (NIH) values were compared against experimentally measured NIH across all five operating points. Mean absolute error is 8.2%, within the combined experimental and numerical uncertainty band. Pressure-rise predictions agree within 4.1% of measured values. All comparisons are documented in the validation report archived at the study record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The primary quantity of interest is the normalized index of hemolysis (NIH), which is directly linked to the regulatory decision criterion (relative hemolysis index RH < 1 versus predicate device). The CFD model computes NIH via integration of the power-law hemolysis damage model (Giersiepen-Wurzinger) over Lagrangian particle trajectories. This QoI has been established in the peer-reviewed literature as the standard surrogate for pump-induced hemolysis and is accepted by FDA guidance documents for Class II blood-contacting device submissions. The mapping from simulation output to regulatory QoI is unambiguous and documented in the modeling report. The hemolysis model parameters were calibrated against the same blood analogue used in the validation experiments, ensuring that the QoI computed by the simulation is physically interpretable in the context of the COU. Secondary QoIs — pump pressure rise and volumetric flow rate — serve as corroborating indicators and are independently validated against experimental measurements, providing additional confidence that the flow field driving hemolysis prediction is correctly resolved. The selection of NIH as the primary QoI was reviewed and approved by the regulatory affairs team and is consistent with the device submission strategy. No alternative QoI was identified that would provide a more direct or more conservative measure of hemolysis risk for this COU. Gradation 2 is required for MRL 2 and is assessed as achieved based on the direct correspondence between the simulation output and the regulatory decision criterion, the peer-reviewed basis for the hemolysis model, and the corroborating validation evidence for secondary QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted at operating conditions sufficiently similar to the COU in terms of geometry, flow regime, and fluid properties to support extrapolation of validation evidence to the COU at Gradation 2.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry, which is the same geometry used in the COU simulations. Operating points span the full range of flow-speed combinations defined in the COU. Fluid properties of the blood analogue closely approximate whole blood rheology at the shear rates relevant to pump hemolysis. The validation domain is therefore considered directly applicable to the COU without significant extrapolation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when code verification evidence is available; Gradation 1 (not assessed) is acceptable.",
      "rationale": "At Model Risk Level 2, numerical solver error beyond code verification is not required per the ASME V&V 40 credibility matrix. The code verification evidence documented under the Numerical Code Verification factor provides sufficient assurance that solver errors are controlled. This factor is scoped as not-assessed and meets the Gradation 1 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; Gradation 1 is acceptable for this factor.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 per the ASME V&V 40 credibility matrix. Analyst qualification and simulation execution procedures are documented under the Software Quality Assurance factor. This factor is not-assessed and meets the Gradation 1 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; Gradation 1 is acceptable for this factor.",
      "rationale": "Model form uncertainty quantification is not required at Model Risk Level 2. The turbulence model selection (SST k-omega) and hemolysis damage model are justified through literature review and are consistent with FDA-recognized simulation practices for blood pump analysis. Formal model form uncertainty assessment is deferred as not required for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; Gradation 1 is acceptable for this factor.",
      "rationale": "Formal sensitivity analysis of model inputs is not required at Model Risk Level 2. Key model inputs (fluid viscosity, density, hemolysis model exponents) are taken from peer-reviewed sources and documented in the modeling report. Nominal values are considered well-characterized for this application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; Gradation 1 is acceptable for this factor.",
      "rationale": "Statistical characterization of test sample variability is not required at Model Risk Level 2. The validation experiments used a controlled blood analogue with documented preparation procedures. Sample-to-sample variability was not characterized beyond the standard operating procedure for the analogue fluid."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; Gradation 1 is acceptable for this factor.",
      "rationale": "Formal equivalency assessment of simulation input parameters relative to experimental conditions is not required at Model Risk Level 2. Boundary conditions used in the COU simulations are derived directly from the same experimental measurements used in validation, providing implicit equivalency. No additional formal assessment is required."
    }
  ],
