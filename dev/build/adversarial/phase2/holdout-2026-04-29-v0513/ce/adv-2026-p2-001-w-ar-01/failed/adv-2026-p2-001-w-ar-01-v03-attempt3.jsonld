  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. Six factors are not-assessed, which is acceptable per the ASME V&V 40 credibility matrix at MRL 2. The CFD model is assessed as sufficiently credible to support the regulatory decision regarding worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index criterion (RH < 1) provides a conservative comparison against the predicate device. The credibility assessment team accepts this package as meeting the requirements for submission.",
