  "signature": "ed25519:b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5",
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/mesh-independence-study",
      "type": "ValidationResult",
      "name": "Mesh independence study — three-level refinement on FDA pump geometry"
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against FDA experimental data"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-flow-curve-validation",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic curve validation across 5 operating points"
    }
  ],
  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/morrison/factor/sqa",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver (ANSYS Fluent 2022 R2) holds a valid FDA 510(k) software validation record and an internal QA certificate issued within 24 months of the simulation date. Version control logs must be archived.",
      "rationale": "ANSYS Fluent 2022 R2 is a commercially validated solver with documented QA procedures. Version control records and release notes were reviewed and archived in the project repository. Gradation 1 is appropriate for MRL 2 because the solver is a mature, widely-used commercial code with no custom user-defined functions that would elevate SQA requirements."
    },
    {
      "id": "https://uofa.net/morrison/factor/ncv",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes at least two standard benchmark cases (lid-driven cavity, backward-facing step) with documented error norms below 1% relative to published reference solutions.",
      "rationale": "Numerical code verification was confirmed through the ANSYS Fluent verification test suite. Lid-driven cavity and backward-facing step benchmarks were executed and results compared against published reference solutions, showing L2 velocity error norms below 0.4%. No custom solver modifications were introduced."
    },
    {
      "id": "https://uofa.net/morrison/factor/disc-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A three-level mesh refinement study must demonstrate that the grid convergence index (GCI) for the scalar stress integral used in the hemolysis power law is below 5% on the medium mesh, and Richardson-extrapolated values must be reported.",
      "rationale": "A three-level structured mesh refinement study was conducted using cell counts of 1.2 M, 3.8 M, and 10.4 M elements. The Grid Convergence Index (GCI) for the volume-averaged scalar stress was 3.1% between the medium and fine meshes, satisfying the Gradation 2 requirement. Richardson extrapolation confirmed monotonic convergence. The medium mesh (3.8 M) was selected for production runs as the optimal balance between accuracy and computational cost."
    },
    {
      "id": "https://uofa.net/morrison/factor/test-conditions",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, and hematocrit) must be reproduced in the CFD model within ±5% of measured values. Deviations must be documented.",
      "rationale": "Experimental conditions from the FDA hemolysis benchmark dataset were replicated in the CFD setup. Inlet flow rates (2–7 L/min), rotational speeds (2000–3500 RPM), and fluid properties (bovine blood surrogate, 35% hematocrit) matched the published test protocol within ±2.8%. Temperature was held at 37°C consistent with the bench experiments."
    },
    {
      "id": "https://uofa.net/morrison/factor/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The normalized index of hemolysis (NIH) predicted by CFD must agree with experimental measurements within 25% relative error across all five operating points. Systematic bias must be characterised.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) values were compared against experimental measurements at all five flow-speed operating points. Maximum relative error was 18.7% at the 7 L/min, 3500 RPM condition; mean absolute relative error across all points was 11.4%. This performance exceeds the Gradation 2 threshold and achieves Gradation 3. Bias analysis showed a consistent 8% over-prediction attributable to the power-law hemolysis model constants calibrated on a different pump geometry, which is acceptable for relative comparison purposes."
    },
    {
      "id": "https://uofa.net/morrison/factor/qoi-relevance",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The primary quantity of interest is the relative hemolysis index RH, defined as the ratio of the predicted NIH for the candidate pump geometry to the NIH of the predicate device under identical operating conditions. This scalar is directly traceable to the regulatory decision criterion (RH < 1). The CFD model outputs the volume-averaged scalar stress field, from which NIH is computed via the Giersiepen-Wurzinger power law. The QoI is therefore directly relevant to the COU decision. The model has been shown in the output comparison factor to reproduce NIH with sufficient fidelity for relative ranking of operating conditions. No surrogate or indirect QoI is used; the hemolysis index is computed on the same mesh and with the same boundary conditions used for the worst-case identification task. Sensitivity analyses confirmed that the ranking of the five operating points by predicted RH is robust to ±10% perturbations in power-law exponent values, supporting the conclusion that the QoI is fit for the intended comparative purpose at MRL 2. Internal review by the device development team confirmed that RH is the metric used in the predicate device submission, ensuring regulatory continuity. The Gradation 2 requirement is met because the QoI is directly defined in the COU, is computed without intermediate transformation, and its sensitivity to modelling assumptions has been characterised."
    },
    {
      "id": "https://uofa.net/morrison/factor/validation-relevance",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump family (FDA generic centrifugal pump or geometric surrogate within 15% of key dimensions) and the same fluid analogue (bovine blood or validated surrogate at matched hematocrit ±5%).",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry, which is the same geometry used in the COU simulations. Fluid properties matched the CPB operating conditions. The validation dataset spans the full operating envelope of the COU (2–7 L/min, 2000–3500 RPM), ensuring that no extrapolation beyond the validated range is required for the worst-case identification task."
    },
    {
      "id": "https://uofa.net/morrison/factor/numerical-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when discretization error has been separately assessed and GCI is below 5%.",
      "rationale": "Numerical solver error is not assessed separately at MRL 2 per the ASME V&V 40 framework when discretization error has been rigorously characterised. The GCI study documented under the Discretization Error factor provides sufficient evidence that iterative and round-off errors are negligible relative to discretization error. Residual convergence was verified to 10^-6 for all equations."
    },
    {
      "id": "https://uofa.net/morrison/factor/use-error",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for a single-team, single-site analysis using a commercial solver with documented setup checklists.",
      "rationale": "Use error is scoped out at MRL 2 for this analysis. A single experienced CFD team performed all simulations using a documented simulation setup checklist. Independent review of boundary condition inputs was conducted by a second engineer. No multi-site or multi-user variability is present."
    },
    {
      "id": "https://uofa.net/morrison/factor/model-form",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form uncertainty is bounded by the output comparison results.",
      "rationale": "Model form assessment is not required at MRL 2. The k-omega SST turbulence model is the established standard for rotating machinery hemolysis CFD and is consistent with FDA guidance. Model form uncertainty is implicitly captured in the output comparison error metrics."
    },
    {
      "id": "https://uofa.net/morrison/factor/model-inputs",
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when input sensitivity has been addressed through the test conditions factor.",
      "rationale": "Model input uncertainty is not formally assessed at MRL 2. Key inputs (viscosity, density, power-law constants) were sourced from peer-reviewed literature and their sensitivity was informally assessed through the ±10% perturbation study described under QoI relevance."
    },
    {
      "id": "https://uofa.net/morrison/factor/test-samples",
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for a comparative analysis using a single reference geometry.",
      "rationale": "Test sample variability is not assessed at MRL 2. The FDA generic centrifugal pump is a single reference geometry without manufacturing variability. Sample-to-sample variation is not applicable to this computational study."
    },
    {
      "id": "https://uofa.net/morrison/factor/equivalency-inputs",
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when validation and COU use identical boundary conditions.",
      "rationale": "Equivalency of input parameters between the validation and COU simulations is confirmed by inspection: identical geometry, fluid properties, and operating conditions are used. Formal equivalency assessment is not required at MRL 2."
    }
  ],
