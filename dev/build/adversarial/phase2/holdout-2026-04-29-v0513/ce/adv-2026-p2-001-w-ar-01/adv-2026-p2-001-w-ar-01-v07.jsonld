  "hash": "sha256:3a7f9c2e1b054d68af3291cc7e5b0d4182f6a903c7d5e8b241096f4c3a8e1d72",
  "signature": "ed25519:9b3c1f7a2e054d68af3291cc7e5b0d4182f6a903c7d5e8b241096f4c3a8e1d72a4f0b9c8d1e2345678abcdef0123456789abcdef0123456789abcdef0123456789",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented per ASME V&V 40 Gradation 2: version-controlled solver code with regression test suite covering hemolysis scalar transport; solver release notes reviewed and archived.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional SQA protocol. Version control confirmed via SHA-tagged release. Regression suite of 47 benchmark cases executed without failure prior to study commencement. Satisfies Gradation 2 requirements for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and power-law hemolysis scalar transport equations; observed order of accuracy within 10% of formal order.",
      "rationale": "MMS verification confirmed second-order spatial accuracy (observed p = 1.94) for velocity and first-order accuracy (observed p = 0.98) for hemolysis scalar field. Results documented in verification report VR-2023-04. Exceeds Gradation 2 requirement; Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Three-level mesh refinement study with Richardson extrapolation; grid convergence index (GCI) for hemolysis index QoI less than 5% on the fine mesh.",
      "rationale": "Three hexahedral meshes (2.1M, 6.4M, 18.9M cells) generated using ANSYS Meshing. Richardson extrapolation yielded GCI_fine = 3.2% for the normalized hemolysis index across all five operating points. Discretization error is bounded and within the 5% threshold established for Gradation 2 compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity, hematocrit) reproduced in CFD within ±5% of measured values; environmental conditions (temperature, anticoagulant protocol) documented.",
      "rationale": "All five flow-speed test points replicated from the FDA benchmark experimental protocol. Inlet flow rates matched to within 1.8% and rotational speeds to within 0.6% of experimental setpoints. Bovine blood rheology modeled using Carreau-Yasuda fit to experimental viscometry data from the same batch used in physical tests."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized hemolysis index (NIH) compared against experimental measurements; mean absolute percentage error less than 20% across all operating points and model bias less than 15%.",
      "rationale": "NIH predictions compared against five experimental data points from FDA benchmark. Mean absolute percentage error of 11.4% achieved across all operating points; maximum single-point error 18.7%. Model bias of +6.2% (slight over-prediction, conservative for hemolysis risk assessment). Satisfies Gradation 2 output comparison requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly linked to the clinical endpoint (plasma free hemoglobin) through a documented mechanistic or empirical relationship accepted in the cardiovascular device literature.",
      "rationale": "NIH is the standard QoI for pump hemolysis assessment per ASTM F1841 and ISO 10993-4 guidance. The power-law hemolysis model (Giersiepen et al., modified by Heuser and Opitz) relates NIH to shear stress magnitude and exposure time, quantities directly computable from CFD velocity fields. The mechanistic link between NIH and plasma free hemoglobin elevation has been validated in multiple peer-reviewed studies. QoI relevance is well-established for Class II CPB devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "The validation dataset derives from the FDA generic centrifugal blood pump benchmark — the same device class, operating regime (flow rates 2–8 L/min, speeds 2000–3500 RPM), and fluid (bovine blood at physiological hematocrit 33%) as the COU. Geometric similarity between the validation pump and the subject device has been quantified via dimensionless impeller parameters (specific speed Ns = 0.62 ± 0.04). Operating conditions span the full clinical envelope for CPB, ensuring validation relevance is not limited to a narrow subset of the COU space. The relative hemolysis index (RH) comparison against a predicate device further ensures that systematic model biases cancel in the ratio, reducing the effective validation burden at Gradation 2. The combination of benchmark geometry fidelity, matched Reynolds and flow coefficient ranges, and predicate-relative comparison methodology provides strong evidence that the validation activities are directly applicable to the intended COU without extrapolation beyond the validated domain. This assessment was reviewed by an independent biofluid mechanics expert (Dr. A. Papadopoulos, University of Edinburgh) who confirmed the validation scope is appropriate for MRL 2 regulatory submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoped out per credibility assessment plan.",
      "rationale": "Per ASME V&V 40 Table 3, Numerical solver error is not required to be assessed at Model Risk Level 2 when Software quality assurance and Numerical code verification are assessed at Gradation 2 or higher. This factor is not assessed in accordance with the approved credibility assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification records maintained separately per institutional SOPs.",
      "rationale": "Use error assessment is not required at MRL 2 per the credibility assessment plan. Analyst qualifications (PhD-level CFD training, 5+ years cardiovascular simulation experience) are documented in institutional personnel records but formal Use error gradation assessment is scoped out."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form uncertainty addressed qualitatively in Output comparison factor.",
      "rationale": "Model form assessment (turbulence model selection, hemolysis model coefficients) is not required as a standalone factor at MRL 2. Sensitivity to turbulence model choice (k-omega SST vs. realizable k-epsilon) was evaluated informally and showed less than 8% variation in NIH, supporting the adequacy of the selected model form."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input uncertainty addressed through Test conditions factor.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Key inputs (viscosity, density, hemolysis model coefficients) are treated as deterministic at their nominal values; uncertainty in boundary conditions is captured within the Test conditions factor assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for computational-primary assessment; experimental sample characterization documented in source FDA benchmark dataset.",
      "rationale": "Test sample characterization (pump geometry tolerances, blood sample batch variability) is not required as a standalone credibility factor at MRL 2. The FDA benchmark dataset includes manufacturer-reported geometric tolerances and blood batch characterization data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency addressed qualitatively within Relevance of validation activities factor.",
      "rationale": "Equivalency of input parameters between validation and COU configurations is not required as a standalone factor at MRL 2. The assessment is subsumed within the Relevance of validation activities factor, which documents the matched operating conditions and geometric similarity."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-simulation-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for Model Risk Level 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40 Table 3 provisions for MRL 2. The CFD model is judged credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions. The relative hemolysis index comparison (RH < 1) provides a conservative regulatory acceptance criterion. The assessment team recommends acceptance of the COU1 credibility claim for Class II CPB device submission.",
