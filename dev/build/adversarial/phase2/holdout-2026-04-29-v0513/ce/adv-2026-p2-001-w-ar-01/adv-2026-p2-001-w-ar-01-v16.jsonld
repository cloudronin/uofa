  "hash": "sha256:3a7f2c1d9e4b08f56a1c3d7e2f9b4a0c8d5e1f3b6a9c2d4e7f0b1a3c5d8e2f4a",
  "signature": "ed25519:9b2e4f1a7c3d0e6f8a5b2c4d9e1f3a7b0c5d2e8f4a6b1c3d7e9f2a4b6c8d0e2f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent QMS documentation covering version control, regression testing, and release validation. Gradation 2 requires documented QMS with traceability to solver version used in this analysis.",
      "rationale": "ANSYS Fluent 2022 R2 was used for all simulations. The solver is commercially released under a documented quality management system with ISO 9001 certification. Version control records confirm that release 2022 R2 was the operative version throughout the study. Internal regression test suites covering laminar, turbulent, and rotating-frame cases are publicly documented in the ANSYS validation manual. Gradation 2 is appropriate for MRL 2 because independent third-party audit of the full development process (Gradation 3) is not warranted given the medium model influence on the regulatory decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least one published manufactured-solution or benchmark test case must confirm solver correctness for rotating-frame incompressible flow at Reynolds numbers representative of the CPB operating envelope. Gradation 2 requires documented benchmark comparison with quantified error norms.",
      "rationale": "Code verification was established through the FDA benchmark CFD study (Stewart et al., 2012) and the ASME V&V 20 benchmark suite. Fluent results for the FDA nozzle and backward-facing step cases demonstrate agreement within 5% of analytical solutions for velocity profiles and pressure drop. For rotating-frame flows, the solver's moving reference frame implementation was verified against the Hidalgo et al. (2018) centrifugal pump manufactured solution, yielding L2 velocity errors below 0.3%. These published comparisons satisfy Gradation 2 requirements without necessitating independent code-level audit."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed across a minimum three-level refinement study with refinement ratio r ≥ 1.3. Achieved level is reported as Gradation 3 when GCI on the QoI (scalar stress proxy) is below 5% on the fine grid. Extrapolated values must be reported.",
      "rationale": "A systematic mesh refinement study was conducted using three structured hexahedral meshes: coarse (1.8M cells), medium (5.4M cells), and fine (16.2M cells), yielding a uniform refinement ratio of 1.44. Richardson extrapolation following Celik et al. (2008) was applied to the area-averaged scalar shear stress proxy used as the hemolysis QoI. GCI values of 8.2%, 3.1%, and 1.4% were obtained for coarse-to-medium, medium-to-fine, and extrapolated fine-grid intervals respectively. The fine-grid GCI of 1.4% is well below the 5% threshold, justifying Gradation 3. All five operating points (2 L/min–3500 RPM through 6 L/min–2000 RPM) were evaluated on the fine mesh for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to confirm that fluid properties, boundary conditions, and pump geometry match the simulation inputs within stated uncertainty bounds. Gradation 2 requires documented test protocol with traceable calibration records for primary measurement instruments.",
      "rationale": "Bench-scale hemolysis experiments were conducted using bovine blood at 37°C with hematocrit maintained at 33 ± 2%. Pump geometry matched the FDA generic centrifugal pump CAD model (Version 1.1, publicly available). Flow rates were controlled by a calibrated Coriolis flowmeter (±0.5% full-scale) and rotational speed by a Hall-effect tachometer (±10 RPM). Inlet and outlet pressures were measured with calibrated transducers (±0.25% full-scale, NIST-traceable). All calibration records are retained in the laboratory quality management system. Test conditions were replicated across three independent experimental runs to assess repeatability, with coefficient of variation below 4% for RH index across runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between simulation outputs and experimental measurements must use a defined metric with stated uncertainty. Gradation 2 requires use of a normalized error metric or confidence interval comparison against experimental uncertainty bands.",
      "rationale": "Simulation-predicted relative hemolysis index (RH) was compared against experimental RH values at all five operating points. The validation metric was the normalized root mean square error (NRMSE) across operating points, computed as NRMSE = 3.8%. All five simulation predictions fell within the experimental uncertainty band (±1 standard deviation across three replicate runs). The Bland-Altman analysis showed no systematic bias (mean difference = 0.02 RH units, 95% limits of agreement: −0.09 to +0.13 RH units). These results confirm that the model reproduces experimentally observed hemolysis trends within the precision required for worst-case identification at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The primary quantity of interest is the relative hemolysis index (RH), defined as the ratio of the normalized index of hemolysis (NIH) for the device under test to the NIH of the predicate device under identical operating conditions. RH is the regulatory QoI specified in FDA guidance for Class II CPB devices and is directly linked to the clinical endpoint of pump-induced red blood cell damage. The CFD-derived hemolysis power law model (Giersiepen et al., 1990, as parameterized by Taskin et al., 2012) maps scalar shear stress and exposure time to a hemolysis damage accumulation index, which is then integrated over the flow field to produce a predicted NIH. This QoI is clinically and regulatorily relevant because: (1) it is the accepted surrogate endpoint for in vivo hemolysis in the predicate comparison pathway; (2) it is directly measurable in bench experiments using the modified NIH method per ASTM F1841; and (3) it captures the dominant mechanism of hemolysis in centrifugal pumps (shear-induced sublethal membrane damage) rather than less sensitive aggregate metrics such as total outlet pressure. The model's ability to rank-order five operating conditions by RH — the specific decision need — has been confirmed by the output comparison results. Gradation 2 is appropriate because the QoI is established in peer-reviewed literature and regulatory guidance, and no novel QoI definition requiring higher-level justification is employed. The relationship between the computational QoI (integrated damage index) and the clinical endpoint (patient hemolysis) is mediated by the predicate comparison design, which reduces the burden on absolute QoI accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating envelope as the COU simulations, or documented similarity arguments must justify any differences. Gradation 2 requires that the validation domain overlaps the COU operating envelope for at least the primary QoI.",
      "rationale": "Validation experiments were conducted on the identical FDA generic centrifugal pump geometry used in the COU simulations, using bovine blood as a clinically accepted surrogate for human blood in hemolysis testing. The five operating points evaluated in the COU (covering the full clinical flow-speed envelope from 2 to 6 L/min and 2000 to 3500 RPM) were all included in the validation test matrix. No extrapolation beyond the validated operating envelope is required for the regulatory decision. The use of bovine blood rather than human blood introduces a minor source of uncertainty in the absolute hemolysis power law coefficients, but this uncertainty is bounded by the predicate comparison design (RH < 1 criterion) and does not affect the rank-ordering conclusion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 with medium model influence. Gradation 1 (awareness) is sufficient; no structured solver error quantification beyond convergence monitoring is mandated.",
      "rationale": "At Model Risk Level 2 with medium model influence, ASME V&V 40 Table 3 does not require formal numerical solver error quantification beyond residual convergence monitoring. Residuals for all governing equations were converged to below 1e-5 for all operating points. Iterative convergence was confirmed by monitoring QoI values over the final 500 iterations, with variation below 0.1%. No structured solver error budget is required at this credibility level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2. Gradation 1 requires only that the analyst team has documented CFD experience relevant to rotating machinery hemolysis simulation.",
      "rationale": "At MRL 2, formal use-error assessment is not required. The simulation team consists of engineers with documented experience in CFD analysis of cardiovascular devices, including prior submissions to FDA for Class II blood-contacting devices. Standard operating procedures for mesh generation, boundary condition specification, and post-processing were followed and are documented in the project technical file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage model must be justified by reference to published validation studies for centrifugal blood pump flows. Gradation 2 requires documented model selection rationale with at least one supporting literature reference demonstrating applicability to the flow regime of interest.",
      "rationale": "The SST k-omega turbulence model was selected based on its demonstrated performance for rotating machinery flows with adverse pressure gradients (Menter, 1994) and its specific validation for centrifugal blood pump hemolysis prediction by Taskin et al. (2012) and Fraser et al. (2012). The Giersiepen-Wurzinger power law hemolysis model (exponents from Taskin et al. re-parameterization) was selected as the most widely validated model for shear-induced hemolysis in the relevant shear stress and exposure time range (1–400 Pa, 0.001–1 s). Model form uncertainty associated with the power law exponents is partially addressed by the output comparison results, which show model predictions within experimental uncertainty bands across all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All primary model inputs (geometry, fluid properties, boundary conditions) must be traceable to measurement data or published reference values with stated uncertainty. Gradation 2 requires documented input uncertainty ranges for at least the three most influential input parameters.",
      "rationale": "Primary model inputs and their sources are: (1) Pump geometry — derived from FDA-released CAD file (Version 1.1), dimensional accuracy ±0.05 mm confirmed by CMM measurement of physical test article; (2) Blood viscosity — Carreau-Yasuda non-Newtonian model parameters from Cho and Kensey (1991), hematocrit 33%; (3) Inlet flow rate — set to match experimental Coriolis flowmeter readings ±0.5%; (4) Rotational speed — set to match tachometer readings ±10 RPM; (5) Outlet pressure — atmospheric reference. Sensitivity of RH to ±5% variation in viscosity parameters was assessed and found to produce less than 2% change in predicted RH, confirming robustness of the QoI to this input uncertainty source."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for computational model credibility assessment. Gradation 1 awareness is sufficient given that experimental sample characterization is addressed under Test Conditions factor.",
      "rationale": "At MRL 2, formal test sample characterization beyond what is documented under the Test Conditions factor is not required. Blood sample characterization (hematocrit, donor source, storage conditions) is documented in the experimental protocol and retained in the laboratory records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2. The validation experiments were conducted on the identical geometry and operating conditions as the COU simulations, making formal equivalency mapping unnecessary.",
      "rationale": "Because the validation experiments used the identical pump geometry, fluid surrogate, and operating envelope as the COU simulations, no formal equivalency mapping between validation and COU input parameters is required at MRL 2. Any minor differences (e.g., bovine versus human blood rheology) are addressed under the Relevance of Validation Activities factor."
    }
  ],
  "hasWeakener": [],
