  "signature": "ed25519:9b2e4f7a1c3d6e8f0a2b4c5d7e9f1a3b5c7d9e0f2a4b6c8d0e2f4a6b8c0d2e4f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The solver (ANSYS Fluent 2022R2) must hold a current FDA 510(k) predicate software validation record and demonstrate version-controlled build with regression test suite passing rate ≥ 98%. Internal QA checklist AC-SQA-MRL2 applies.",
      "rationale": "ANSYS Fluent 2022R2 was used under a site license with documented version control. The solver regression test suite achieved a 99.3% pass rate across 847 benchmark cases. A software validation plan and summary report were completed per the site QMS procedure QP-CFD-004. MRL 2 requires Gradation 2 SQA, which is satisfied by commercial solver documentation plus internal checklist completion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate that the solver produces solutions consistent with analytical benchmarks for laminar pipe flow and lid-driven cavity flow to within 0.5% L2-norm error at the production mesh density.",
      "rationale": "Numerical code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes solver and the power-law hemolysis transport equation. Observed order of accuracy (p = 1.97) was consistent with the expected second-order spatial scheme. Lid-driven cavity and Poiseuille flow benchmarks confirmed solver accuracy to within 0.3% L2-norm relative error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary QoI (volume-averaged scalar shear stress) must be ≤ 5% on the medium mesh relative to the Richardson-extrapolated value. Three mesh levels with refinement ratio r ≥ 1.3 are required.",
      "rationale": "A three-level mesh refinement study was conducted with mesh sizes of 2.1 M, 5.8 M, and 14.4 M cells (refinement ratio r ≈ 1.36). Richardson extrapolation yielded an observed order of accuracy of 1.89. The GCI for volume-averaged scalar shear stress on the medium mesh was 3.2%, comfortably within the 5% threshold. The fine mesh GCI was 1.1%. The production mesh (5.8 M cells) was selected as the balance between accuracy and computational cost, achieving Gradation 3 performance against a Gradation 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must span at least 3 of the 5 target operating points (flow rate / rotational speed combinations) and must have been conducted under controlled temperature (37 ± 1°C) and hematocrit (33 ± 2%) conditions consistent with the COU.",
      "rationale": "Bench hemolysis experiments were conducted at all 5 target operating points (2, 4, 6, 8, and 10 L/min at 2500 and 3500 RPM) using bovine blood at 37°C and 33% hematocrit. Test conditions were logged and traceable to calibrated instrumentation. Environmental controls and blood preparation protocols are documented in test report TR-PUMP-HEM-2023-04."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The relative hemolysis index (RH) predicted by the CFD-coupled power-law hemolysis model was compared against experimentally measured normalized index of hemolysis (NIH) values at all 5 operating points. Agreement was quantified using the validation metric V = |RH_CFD − RH_exp| / u_exp, where u_exp is the experimental uncertainty at 95% confidence. At MRL 2, Gradation 2 requires that the metric V ≤ 2.0 at all operating points. The maximum observed V across all 5 points was 1.67 (at 10 L/min, 3500 RPM), confirming compliance. The systematic trend of slight over-prediction at high flow rates is consistent with known limitations of the power-law hemolysis model at high shear exposure times and has been documented in the model assumptions log. The comparison methodology followed ASME V&V 20-2009 for experimental uncertainty propagation, with NIH measurement repeatability characterized over six independent blood priming runs. All raw comparison data are archived in dataset morrison-hemolysis-experimental-dataset. The assessment team reviewed the output comparison in the context of the intended use — identification of worst-case operating conditions rather than absolute hemolysis magnitude prediction — and concluded that the rank-ordering of operating points by predicted RH was preserved in all experimental comparisons, which is the operationally critical requirement for this COU. This conclusion was reviewed and endorsed by the independent credibility assessment reviewer on 2026-03-14."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index RH) must be directly linked to the clinical endpoint (hemolysis risk) and must be the same scalar used in predicate device comparison per the COU definition.",
      "rationale": "The relative hemolysis index RH is defined as the ratio of the predicted NIH for the test device to the NIH of the predicate device, both computed under identical operating conditions. This QoI directly addresses the regulatory question of comparative hemolysis performance and is the same metric used in the FDA guidance on pump hemolysis assessment. The linkage between RH and clinical hemolysis risk is established in the clinical rationale document CR-CPB-2023-01."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry (FDA generic centrifugal pump) or a geometrically similar predicate, and must span the COU operating envelope (flow 2–10 L/min, speed 2500–3500 RPM).",
      "rationale": "All validation activities were performed on the FDA generic centrifugal blood pump geometry as specified in the COU. Operating conditions spanned the full COU envelope. The use of the same geometry and operating range ensures that the validation is directly applicable to the intended use without extrapolation beyond the validated domain."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; Gradation 1 is satisfied by default documentation of iterative convergence to residual tolerance ≤ 1e-5.",
      "rationale": "At MRL 2, numerical solver error beyond iterative convergence monitoring is not required. Residual convergence to 1e-5 was confirmed for all simulations. This factor is not assessed beyond the minimum Gradation 1 level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "MRL 2 requires only that simulation inputs were reviewed by a second qualified analyst. Peer review sign-off on simulation setup document SSD-CPB-2023-02 satisfies this criterion.",
      "rationale": "Use error assessment at Gradation 1 is satisfied by peer review of the simulation setup. The simulation setup document SSD-CPB-2023-02 was reviewed and signed off by a second qualified CFD analyst. No further use error characterization is required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "MRL 2 does not require formal model form uncertainty quantification. Documentation of the selected turbulence model (SST k-ω) and hemolysis power-law coefficients with literature references satisfies Gradation 1.",
      "rationale": "The SST k-ω turbulence model was selected based on its established performance for rotating machinery flows. Power-law hemolysis model coefficients (C = 1.8e-6, α = 1.9, β = 0.765) were taken from Giersiepen et al. (1990) as cited in FDA guidance. Model form uncertainty is acknowledged but not formally quantified at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All boundary conditions (inlet flow rate, rotational speed, fluid properties) must be traceable to measurement records with documented uncertainty. Fluid properties must correspond to bovine blood at 37°C and 33% hematocrit per the experimental test conditions.",
      "rationale": "Boundary conditions were specified from calibrated flow meters (±1.5% full scale) and tachometer readings (±10 RPM). Blood viscosity and density were measured from the same blood batch used in experiments. All input values and their uncertainties are tabulated in the simulation input record SIR-CPB-2023-04, which is linked to instrument calibration certificates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "MRL 2 requires only that the test sample (pump unit) used in validation experiments is confirmed to be within manufacturing tolerances of the nominal geometry used in the CFD model. Dimensional inspection report satisfies Gradation 1.",
      "rationale": "The physical pump used in bench testing was dimensionally inspected and confirmed within ±0.05 mm of nominal CAD dimensions. Inspection report IR-PUMP-2023-01 is on file. No further test sample characterization is required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "MRL 2 requires confirmation that CFD boundary condition values match experimental test condition values within the stated measurement uncertainties. A table of nominal vs. applied values satisfies Gradation 1.",
      "rationale": "A parameter equivalency table was prepared comparing nominal experimental conditions to CFD boundary condition inputs. All parameters fell within the stated measurement uncertainties. The table is included as Appendix B of the V&V plan VP-CPB-2023-01."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels for MRL 2. The 6 not-assessed factors are acceptable at MRL 2 per the ASME V&V 40-2018 framework. The model is judged credible for its intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index RH < 1 acceptance criterion for the COU-level decision is met at all 5 operating points. The assessment team recommends Accepted with the condition that the output comparison factor (particularly the high-flow over-prediction trend) be revisited if the COU is extended beyond 10 L/min.",
