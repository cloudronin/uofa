  "hash": "sha256:a3f1c2e4b7d09e5f2a1b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f",
  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA documentation must demonstrate version-controlled solver code, traceable build records, and at minimum a Gradation 2 QA plan covering regression testing of hemolysis-relevant flow features.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented QA processes meeting FDA guidance on software in medical devices. Version control records, release notes, and regression test suites were reviewed and found compliant with Gradation 2 requirements for MRL 2. No custom in-house code modifications were introduced for this analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate order-of-accuracy consistent with the solver's theoretical convergence rate using at least one manufactured solution benchmark applicable to rotating machinery internal flow.",
      "rationale": "Method of manufactured solutions (MMS) was applied to verify the incompressible Navier-Stokes solver at second-order spatial accuracy. Observed convergence rates of 1.97 (L2 velocity norm) and 1.94 (L2 pressure norm) were confirmed across three successively refined grids, consistent with the solver's nominal second-order finite-volume scheme."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via Richardson extrapolation or equivalent, with GCI reported for the primary QoI (normalized index of hemolysis) and demonstrated to be below 5% on the medium mesh used for production runs.",
      "rationale": "A three-level mesh refinement study was conducted using coarse (4.2M cells), medium (11.8M cells), and fine (31.4M cells) grids. Richardson extrapolation yielded a Grid Convergence Index (GCI) of 3.1% for the normalized index of hemolysis on the medium mesh, satisfying the Gradation 2 threshold. The fine-mesh solution was used as the reference extrapolant. Achieved level is reported as 3 because the GCI on the fine mesh falls below 1.5%, exceeding the minimum requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with traceability to measured boundary conditions (flow rate ±2%, rotational speed ±10 RPM) and must span at least three of the five target operating points.",
      "rationale": "Validation experiments were conducted at the FDA laboratory under controlled conditions spanning all five target flow-speed combinations. Measured inlet flow rates and impeller speeds were recorded with calibrated instrumentation traceable to NIST standards. Boundary condition uncertainty was propagated into the CFD model as described in the uncertainty quantification annex."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must agree with experimental measurements within combined simulation and experimental uncertainty bands at all five operating points, and model error must not exhibit systematic bias exceeding 15%.",
      "rationale": "Predicted NIH values were compared against experimental measurements at all five operating points. Agreement was within combined uncertainty bands at four of five points; the fifth point showed a 12% over-prediction consistent with known turbulence model limitations in low-shear regions, which is within the accepted bias threshold. No systematic directional bias was detected across the operating range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH, shear stress distribution) must be demonstrably linked to the clinical endpoint (patient hemolysis risk) through a documented mechanistic argument or published literature mapping.",
      "rationale": "The normalized index of hemolysis (NIH) is the standard regulatory QoI for blood pump hemolysis assessment per FDA guidance. The power-law hemolysis model (Giersiepen et al.) directly relates shear stress magnitude and exposure time to red blood cell damage, providing a mechanistic link between the CFD QoI and the clinical endpoint. Published literature (Blackshear, Heuser, Taskin) corroborates the relevance of shear-stress-based QoIs for centrifugal pump hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The validation activities were designed to closely mirror the COU geometry, operating conditions, and fluid properties. The FDA generic centrifugal pump geometry used in validation shares key hydraulic design features (impeller diameter 60 mm, volute cutwater angle, gap width) with the device under assessment. Blood analog fluid (glycerin-water, 36% v/v) was used in experiments to replicate physiological viscosity at 37°C. Operating points in validation span the full clinical flow range (2–6 L/min) and rotational speeds (2000–3500 RPM) encompassing the five target COU operating conditions. The degree of similarity between validation scenario and COU has been assessed as sufficient for Gradation 2 relevance under MRL 2, consistent with the ASME V&V 40 relevance rubric. Remaining gaps — specifically the use of a surrogate geometry rather than the exact device — are acknowledged and addressed through the sensitivity analysis documented in the model inputs factor assessment. The validation team independently reviewed the scenario mapping and concurred that no additional validation activities are required at this model risk level. This factor achieved the required level without supplementary testing because the regulatory precedent for this device class accepts FDA benchmark data as a primary validation source when geometric similarity indices exceed 0.85, as calculated in Appendix C of the credibility assessment report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when numerical code verification has been completed at Gradation 2 or above.",
      "rationale": "Numerical solver error is scoped out at MRL 2 given that code verification (MMS) has been completed and demonstrated second-order accuracy. Iterative convergence was monitored via residual drop of six orders of magnitude and stabilization of the NIH QoI to within 0.1% over the final 500 iterations, providing sufficient confidence that solver error is not a significant contributor to total model error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II devices when SQA is assessed at Gradation 2 or above.",
      "rationale": "Use error assessment is not required at MRL 2 for this device class. Standard operating procedures for CFD model setup were followed, and an independent peer review of the model setup file was conducted by a senior analyst not involved in the original simulation to confirm boundary condition assignment and material property inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when output comparison is assessed and model bias is within defined thresholds.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis power-law exponents) is acknowledged but not formally assessed at MRL 2. The k-omega SST turbulence model was selected based on its established performance in rotating internal flows. Sensitivity of NIH predictions to turbulence model choice was explored informally by running one operating point with the realizable k-epsilon model; the difference in NIH was less than 8%, consistent with published benchmarks."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters (fluid viscosity, density, inlet flow profile, rotational speed) must be sourced from traceable measurements or authoritative references, with uncertainty quantified and propagated to the QoI at Gradation 2.",
      "rationale": "All model input parameters were sourced from calibrated experimental measurements or peer-reviewed physiological references. Blood analog viscosity was measured at 37°C using a cone-and-plate rheometer (uncertainty ±1.5%). Inlet velocity profiles were derived from PIV measurements at the pump inlet plane. Rotational speed was set to match tachometer readings with ±0.3% uncertainty. A one-at-a-time sensitivity study confirmed that NIH is most sensitive to rotational speed and least sensitive to inlet turbulence intensity, guiding uncertainty prioritization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for computational validation studies using a single representative geometry.",
      "rationale": "Test sample variability is not assessed at MRL 2 for this COU. The validation study used a single manufactured instance of the FDA generic pump geometry. Manufacturing variability effects on hemolysis are addressed qualitatively through the geometric sensitivity analysis in the model inputs assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when test conditions and model inputs have both been assessed at Gradation 2.",
      "rationale": "Equivalency of input parameters between the validation scenario and the COU is implicitly addressed through the test conditions and model inputs assessments. The operating envelope of the validation experiments fully encompasses the five COU operating points, confirming that no extrapolation beyond the validated parameter space is required."
    }
  ],
