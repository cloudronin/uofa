    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-identification",
      "type": "Claim",
      "name": "CFD model correctly identifies worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD hemolysis model, applied across five flow-rate and rotational-speed combinations for the FDA generic centrifugal blood pump, correctly ranks operating conditions by hemolysis severity and identifies the worst-case condition with sufficient fidelity to support tolerance decisions. The relative hemolysis index (RH) predicted by the model satisfies RH < 1 against the predicate device benchmark at all evaluated operating points. This claim encompasses model form adequacy, mesh independence, and boundary condition representativeness as established through the credibility factor assessments documented in this package.",
      "scope": "FDA generic centrifugal blood pump geometry; CPB flow range 3–6 L/min; rotational speeds 2000–3500 RPM; blood rheology modelled as non-Newtonian (Carreau); haemolysis power-law damage accumulation model (Giersiepen–Wurzinger coefficients).",
      "purpose": "Provide regulatory-grade assurance that the CFD model output is credible for the intended use of identifying worst-case hemolysis operating conditions for Class II device submission."
    }
  ],
