  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD model of the FDA generic centrifugal blood pump, employing a power-law hemolysis damage accumulation model with Giersiepen-Wurzinger coefficients, is credible for identifying the worst-case hemolysis operating point across the five specified flow-speed combinations under CPB conditions. The relative hemolysis index criterion (RH < 1) is satisfied at all operating points, with the maximum NIH occurring at 4.5 L/min and 3500 RPM. This claim supports the regulatory decision that the device design tolerances do not introduce clinically significant hemolysis risk relative to the predicate device.",
      "scope": "Class II centrifugal blood pump; CPB operating envelope; 5 flow-speed combinations; MRL 2",
      "purpose": "Support 510(k) submission credibility argument for CFD-based hemolysis worst-case identification"
    },
