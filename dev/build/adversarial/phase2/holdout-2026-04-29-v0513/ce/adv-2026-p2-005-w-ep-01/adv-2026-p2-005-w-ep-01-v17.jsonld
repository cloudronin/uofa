    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "claims": [
    {
      "id": "https://uofa.net/synth/claim/cou1-cpb-hemolysis-claim",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump at MRL 2",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage model coupled with SST k-omega turbulence closure, is credible for identifying the worst-case operating point (flow rate and impeller speed combination) that maximises the relative hemolysis index (RHI) across the 5-point operating matrix defined in the COU. The claim scope is limited to comparative ranking of operating conditions; absolute hemolysis magnitude predictions are not claimed. Supporting validation activities demonstrate agreement between simulated and experimentally measured RHI values within 15% across all tested conditions, satisfying the MRL 2 acceptance threshold.",
      "scope": "Comparative ranking of hemolysis severity across 5 flow-speed operating points for a Class II CPB device; does not extend to absolute hemolysis magnitude or patient-specific geometries.",
      "purpose": "Support regulatory submission demonstrating that the CFD model can reliably identify worst-case hemolysis conditions without exhaustive physical testing of all geometric tolerance combinations."
    }
  ],
