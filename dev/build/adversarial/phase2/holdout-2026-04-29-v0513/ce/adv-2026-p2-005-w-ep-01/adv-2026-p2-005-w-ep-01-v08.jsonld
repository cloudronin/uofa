  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-identification",
      "type": "Claim",
      "name": "CFD model reliably identifies worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage accumulation formulation with SST k-omega turbulence closure, is credible for identifying the worst-case hemolysis operating point among the five specified flow-speed combinations for the FDA generic centrifugal blood pump in CPB service. The model satisfies the relative hemolysis index acceptance criterion (RH < 1) and provides sufficient discriminatory resolution to rank operating conditions by hemolysis severity. This claim supports the regulatory submission decision that no design modification is required to meet the hemolysis performance specification for the Class II device.",
      "scope": "Five operating points: (3 L/min, 2500 RPM), (4 L/min, 2500 RPM), (5 L/min, 2500 RPM), (4 L/min, 3000 RPM), (5 L/min, 3000 RPM). Fluid: bovine blood surrogate, hematocrit 40%. Geometry: FDA generic centrifugal pump nominal dimensions."
    },
