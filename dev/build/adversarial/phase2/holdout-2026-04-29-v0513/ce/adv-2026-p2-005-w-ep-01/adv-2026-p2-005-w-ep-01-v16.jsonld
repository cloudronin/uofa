  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-identification",
      "type": "Claim",
      "name": "CFD model adequately identifies worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB use",
      "description": "The CFD hemolysis prediction model, applied across 5 flow-speed combinations representative of clinical CPB operation, is credible for identifying the worst-case pump-induced hemolysis condition. The relative hemolysis index criterion (RH < 1) is met at all evaluated operating points, supporting regulatory submission for a Class II CPB device at Model Risk Level 2. This claim encompasses model form adequacy, numerical accuracy, and concordance with experimental hemolysis benchmarks.",
      "scope": "Class II centrifugal blood pump; CPB operating envelope; 5 discrete flow-speed combinations; RH < 1 acceptance criterion; Model Risk Level 2",
      "purpose": "Support 510(k) regulatory decision regarding tolerance-induced hemolysis risk for the FDA generic centrifugal blood pump design"
    }
  ],
