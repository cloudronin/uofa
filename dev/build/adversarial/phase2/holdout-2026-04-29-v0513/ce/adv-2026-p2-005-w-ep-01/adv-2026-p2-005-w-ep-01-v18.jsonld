  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cou1-cpb-hemolysis-adequacy",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis for CPB device at MRL 2",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage accumulation formulation with SST k-omega turbulence closure, is adequate for identifying worst-case operating conditions for pump-induced hemolysis in the FDA generic centrifugal blood pump under CPB conditions. The model meets all seven assessed credibility factors at or above the required gradation for Model Risk Level 2. Predicted relative hemolysis index RH < 1 across all five evaluated flow-speed combinations supports regulatory acceptance of the tolerance analysis conclusions.",
      "purpose": "Provide the primary credibility claim linking model adequacy to the regulatory decision for Class II CPB device submission",
      "scope": "FDA generic centrifugal blood pump geometry; CPB operating envelope (3–6 L/min, 2500–4000 RPM); MRL 2 assessment per ASME V&V 40-2018"
    }
  ],
