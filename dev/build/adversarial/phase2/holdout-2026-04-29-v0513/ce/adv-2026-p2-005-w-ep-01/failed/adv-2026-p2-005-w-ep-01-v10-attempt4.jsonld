  "claims": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-adequacy-001",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis for CPB Class II device at MRL 2",
      "description": "The CFD model of the FDA generic centrifugal blood pump is credible for identifying worst-case pump-induced hemolysis operating conditions across the five specified flow-speed combinations under CPB conditions. The model meets all seven assessed credibility factors at or above the required gradation levels for Model Risk Level 2, and the relative hemolysis index (RH) predictions fall within acceptable uncertainty bounds relative to in-vitro bench measurements. The claim scope is limited to the operating envelope defined in the COU: flow rates 2–6 L/min, rotational speeds 2000–3500 RPM, and the specific impeller geometry of the FDA generic pump.",
      "claimScope": "FDA generic centrifugal pump, CPB operating envelope, MRL 2",
      "claimPurpose": "Regulatory submission support for Class II 510(k) hemolysis tolerance assessment"
    }
  ],
