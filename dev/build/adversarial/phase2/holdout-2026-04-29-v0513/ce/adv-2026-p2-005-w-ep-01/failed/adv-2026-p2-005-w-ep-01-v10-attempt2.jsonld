  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
      "type": "Claim",
      "name": "CFD model reliably identifies worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage accumulation formulation with SST k-omega turbulence closure, is credible for identifying the worst-case flow-speed combination that maximises the relative hemolysis index (RH) across the five specified CPB operating points. The claim scope is limited to comparative ranking of operating conditions for a Class II centrifugal blood pump; absolute hemolysis magnitude predictions are outside scope. Credibility is asserted at Model Risk Level 2 with medium model influence and high decision consequence.",
      "claimScope": "Comparative ranking of hemolysis severity across 5 operating points; Class II CPB device; RH index metric only",
      "claimPurpose": "Support 510(k) substantial equivalence determination by demonstrating CFD-predicted worst-case operating point matches or is conservative relative to predicate device benchmark"
    }
