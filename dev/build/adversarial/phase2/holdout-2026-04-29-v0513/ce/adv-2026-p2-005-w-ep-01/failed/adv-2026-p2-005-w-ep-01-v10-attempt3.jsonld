  "claims": [
    {
      "id": "https://uofa.net/synth/claim/cou1-cpb-hemolysis-prediction",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis for CPB Class II device at MRL 2",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage accumulation formulation with k-omega SST turbulence closure, is sufficiently credible to identify worst-case pump-induced hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB service. The relative hemolysis index (RH) predicted by the model meets the acceptance criterion RH < 1 across all five evaluated flow-speed combinations, and model predictions are consistent with in-vitro experimental benchmarks within the 15% tolerance band established for MRL 2 Class II assessment. This claim supports the regulatory submission decision that the device geometry satisfies hemolysis safety requirements without requiring additional physical testing beyond the validation dataset.",
      "scope": "FDA generic centrifugal blood pump; CPB operating envelope; 5 flow-speed combinations; MRL 2; Class II device classification",
      "purpose": "Support 510(k) submission decision on pump geometry tolerances by demonstrating CFD model credibility for hemolysis prediction under worst-case operating conditions"
    }
  ],
