  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-claim-001",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device at MRL 2",
      "description": "The CFD model of the FDA generic centrifugal blood pump, employing SST k-omega turbulence closure and the Giersiepen-Wurzinger hemolysis power-law model, is credible for identifying worst-case hemolysis operating conditions across the 5 flow-speed combinations specified in the COU. The model achieves a relative hemolysis index RH < 1 against the predicate device benchmark, satisfying the primary acceptance criterion. Model uncertainty is bounded within the MRL 2 tolerance envelope as established by the 13-factor credibility assessment. This claim supports regulatory submission for 510(k) clearance of the CPB device under evaluation.",
      "scope": "FDA generic centrifugal blood pump geometry; operating range 2–6 L/min flow, 2000–3500 RPM; blood properties at 37°C; steady-state rotating reference frame formulation",
      "purpose": "Support regulatory decision that CFD simulation results are sufficiently credible to substitute for additional in-vitro hemolysis testing across the full operating envelope"
    }
  ],
