  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cou1-cpb-hemolysis-claim",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump at MRL 2",
      "description": "The CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage model with k-ω SST turbulence closure, is sufficiently credible to identify the worst-case flow-rate and rotational-speed combination that maximises pump-induced hemolysis for a Class II CPB centrifugal blood pump. Predictions have been validated against in-vitro experimental data across the full operating envelope; the relative hemolysis index criterion (RH < 1) is met at all five evaluated operating points. The model is therefore fit for use in supporting a 510(k) submission comparing device hemolysis against the predicate.",
      "scope": "FDA generic centrifugal blood pump geometry; operating range 2–6 L/min, 2000–4500 RPM; blood viscosity modelled as Newtonian at 37 °C; MRL 2 per ASME V&V 40-2018."
    }
  ],
