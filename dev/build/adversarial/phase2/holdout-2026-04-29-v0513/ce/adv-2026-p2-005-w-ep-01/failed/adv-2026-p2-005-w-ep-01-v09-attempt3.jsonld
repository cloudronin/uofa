  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-001",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD model of the FDA generic centrifugal blood pump, solved with SST k-omega turbulence closure on a 19.2M-cell mesh, is credible for identifying the worst-case hemolysis operating point across the 5 flow-speed combinations specified in the COU. The model predicts normalized index of hemolysis within 15% of experimental measurements and satisfies the relative hemolysis index criterion RH < 1 for all evaluated conditions. This claim supports regulatory submission for a Class II CPB device under 510(k) pathway.",
      "scope": "FDA generic centrifugal blood pump geometry; 5 CPB operating points (flow 2–6 L/min, speed 2000–4000 RPM); MRL 2 per ASME V&V 40-2018.",
      "purpose": "Provide credibility evidence that CFD simulation results are adequate to support worst-case hemolysis identification without requiring additional physical testing beyond the benchmark dataset."
    }
  ],
