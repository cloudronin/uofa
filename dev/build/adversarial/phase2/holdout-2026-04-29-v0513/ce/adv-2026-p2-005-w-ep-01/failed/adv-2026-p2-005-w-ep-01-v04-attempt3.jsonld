  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/dr-morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out per ASME V&V 40-2018 Table 4 for MRL 2 Class II device. Mesh independence GCI below 5%, experimental comparison MAE below 15%, and code verification order of accuracy within tolerance. The CFD model is deemed credible for identifying worst-case hemolysis operating conditions under CPB use conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD hemolysis model, employing the Giersiepen power-law damage model with SST k-omega turbulence closure, is sufficiently accurate to identify the operating point (flow rate, rotational speed combination) that produces maximum pump-induced hemolysis for the FDA generic centrifugal blood pump geometry under CPB conditions. The model supports regulatory determination that the device hemolysis index satisfies RH < 1 relative to the predicate device across the full operating envelope.",
      "scope": "Valid for Class II centrifugal blood pumps with specific speed Ns between 1200 and 2800 rpm(gpm)^0.5/(ft)^0.75, operating within CPB flow range 3–6 L/min at rotational speeds 2500–3200 RPM. Blood analog fluid at 37°C with hematocrit 35–45%.",
      "purpose": "Support 510(k) submission decision: confirm that worst-case hemolysis operating condition identified by CFD is consistent with experimental benchmark data and that the relative hemolysis index acceptance criterion RH < 1 is satisfied."
    }
  ],
