      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/turbulence-sensitivity-study-2024"
    }
  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-001",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device",
      "description": "The CFD model, employing the SST k-omega turbulence closure and Giersiepen power-law hemolysis scalar, is sufficiently credible to identify the worst-case hemolysis operating point among the five evaluated flow-speed combinations for the FDA generic centrifugal blood pump under CPB conditions. The relative hemolysis index RH remains below 1.0 for the predicate comparison at all operating points, satisfying the pre-specified acceptance criterion. This claim supports the regulatory submission decision that the device geometry, within specified manufacturing tolerances, does not introduce clinically significant hemolysis elevation.",
      "scope": "Class II CPB device; FDA generic centrifugal pump geometry; five operating conditions (2–6 L/min, 2000–3500 RPM); Model Risk Level 2",
      "purpose": "Support 510(k) substantial equivalence determination with respect to pump-induced hemolysis"
    }
  ],
