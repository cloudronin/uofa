  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-001",
      "type": "Claim",
      "name": "CFD model adequately predicts worst-case hemolysis operating conditions for Class II CPB device at MRL 2",
      "description": "The CFD model of the FDA generic centrifugal blood pump is credible for identifying the worst-case hemolysis operating condition across the five specified flow-speed combinations under cardiopulmonary bypass use. The relative hemolysis index (RH) predicted by the model satisfies the RH < 1 acceptance criterion when compared against the predicate device benchmark, supporting the regulatory decision that the device design tolerances do not introduce unacceptable hemolysis risk. This claim encompasses model form adequacy for turbulence-driven shear stress prediction, numerical accuracy within GCI < 2%, and experimental agreement within 15% mean relative error across all validation operating points.",
      "scope": "Class II CPB device; flow rates 2–6 L/min; impeller speeds 2000–3500 RPM; operating temperature 37°C; blood analog fluid per ASTM F1841",
      "purpose": "Support 510(k) substantial equivalence determination for hemolysis performance under worst-case operating conditions"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4054462",
  "wasAttributedTo": "https://uofa.net/morrison/org/morrison-research-group",
