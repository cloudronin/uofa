  },
  "claim": {
    "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
    "type": "Claim",
    "name": "CFD model correctly identifies worst-case hemolysis operating condition for FDA centrifugal blood pump under CPB conditions",
    "description": "The CFD model, employing the Giersiepen-Wurzinger power-law hemolysis model with SST k-omega turbulence closure, correctly ranks all five flow-speed operating points by relative hemolysis index and identifies the worst-case condition (2.5 L/min, 3600 RPM) with a predicted RH of 0.87 relative to the predicate device. The claim scope is restricted to the FDA generic centrifugal pump geometry at MRL 2 and does not extend to patient-specific anatomical configurations or pulsatile flow regimes.",
    "scope": "FDA generic centrifugal blood pump, Class II, CPB operating envelope, steady-state flow, MRL 2",
    "purpose": "Support regulatory submission demonstrating that CFD-predicted worst-case hemolysis condition is conservative relative to predicate device benchmark, satisfying the RH < 1 acceptance criterion across all evaluated operating points."
  },
