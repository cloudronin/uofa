  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-bench-hemolysis-rh-2023",
      "type": "ValidationResult",
      "name": "Bench-top hemolysis validation: RH index comparison against FDA pump experimental data",
      "description": "CFD-predicted relative hemolysis index compared against in-vitro measurements from the FDA generic pump test rig across all 5 flow-speed operating points. Mean RH prediction error was 8.3%, within the ±15% acceptance band. Experimental uncertainty characterised via repeat testing (n=6 per condition). Validation activities were conducted on the same pump geometry used in the COU, providing direct applicability evidence."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-velocity-field-piv-2023",
      "type": "ValidationResult",
      "name": "PIV velocity field validation for impeller passage flow",
      "description": "Particle image velocimetry measurements of the impeller passage were compared against CFD velocity predictions at the nominal operating point (5 L/min, 2500 RPM). RMS velocity error was 4.1% of bulk tip speed. The validation supports the turbulence model and near-wall treatment choices adopted in the hemolysis COU simulations."
    }
  ],
