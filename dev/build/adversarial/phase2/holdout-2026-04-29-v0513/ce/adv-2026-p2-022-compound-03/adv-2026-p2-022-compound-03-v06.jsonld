      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 1 required at MRL 2: solver version control and release notes reviewed.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a documented version-control protocol. Release notes, known-issue logs, and regression test reports were reviewed and archived. SQA level 2 achieved, exceeding the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
