  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The overall evidence base is considered sufficient to support a Medium assurance level; mesh convergence studies, turbulence model benchmarking, and extensive experimental comparisons against FDA benchmark datasets collectively underpin this determination.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-benchmark-hemolysis-2019",
    "https://uofa.net/synth/data/morrison-cpb-experimental-2021"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-val-bench-2021",
      "type": "ValidationResult",
      "name": "FDA benchmark pump hemolysis validation — five operating points",
      "description": "CFD predictions of normalized index of hemolysis (NIH) were compared against published FDA benchmark experimental data across five flow-speed operating points. Predicted NIH values fell within ±18% of experimental means at four of five conditions; the fifth point (high-speed, low-flow) showed 23% deviation, within the accepted tolerance band for the RH < 1 criterion. Turbulence model sensitivity was explored using SST k-ω and realizable k-ε; SST k-ω was selected as primary model based on superior near-wall resolution."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-val-mesh-2021",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification",
      "description": "Grid convergence index (GCI) analysis performed on three systematically refined meshes (2.1M, 6.4M, 18.7M cells). GCI for NIH at the worst-case operating point was 4.2%, below the 5% threshold specified in the validation plan. Richardson extrapolation confirmed asymptotic convergence. Spatial discretization error is considered well-characterized."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-val-sensitivity-2022",
      "type": "ValidationResult",
      "name": "Model input sensitivity and uncertainty propagation study",
      "description": "Latin hypercube sampling over blood viscosity, density, and inlet velocity profile uncertainty ranges produced a coefficient of variation of 6.1% on NIH predictions, confirming that model inputs are adequately constrained by the available experimental characterization data. Boundary condition uncertainty was the dominant contributor."
    }
  ],
