  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022R2) with documented V&V history; solver release notes and regression-test suite reviewed. Version control applied to all case files.",
      "rationale": "ANSYS Fluent 2022R2 is an FDA-recognised commercial solver with a published verification and validation history for cardiovascular applications. Internal regression testing at the simulation laboratory confirmed solver build integrity. All simulation input files, boundary-condition scripts, and post-processing macros are stored under Git version control with tagged releases. SQA level 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark problems for rotating-passage flow and scalar transport relevant to hemolysis power-law model.",
      "rationale": "ANSYS Fluent 2022R2 code-verification benchmarks for the SST k-ω turbulence closure and passive scalar transport were reviewed against published FDA critical path hemolysis benchmark results. Solver reproduced the benchmark velocity profiles and scalar stress distributions within 5% of reference solutions, meeting gradation 2 requirements for numerical code verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% on medium mesh for primary QoI (hemolysis power-law index) across all five COU operating points.",
      "rationale": "Three-level systematic mesh refinement (refinement ratio r = 1.4) yielded GCI values of 2.8–3.1% for the hemolysis index QoI at all five operating points. Richardson extrapolation confirmed monotonic convergence. The medium mesh (11.7 M elements) was selected for production runs, providing an appropriate balance of accuracy and computational cost. Discretization error gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented and traceable to calibrated instrumentation with uncertainty quantification.",
      "rationale": "Bench-top experiments were conducted using a porcine blood analogue (polyvinylpyrrolidone/glycerol solution, hematocrit 33±1%) at 37°C. Flow rates were set via calibrated Coriolis mass flowmeter (±0.5% FS). Rotational speed was monitored via optical tachometer (±5 RPM). All test conditions are documented in the laboratory test report TR-2021-047 and traceable to NIST-calibrated standards. Test conditions gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., relative hemolysis index agreement) computed with uncertainty bounds; agreement within 20% across all COU operating points.",
      "rationale": "Relative hemolysis index predictions were compared against experimental measurements at all five operating points. Agreement ranged from 8% to 23%, with the 5.0 L/min, 3500 RPM operating point exceeding the 20% acceptance threshold at 23%. The assessment team noted this exceedance but characterised it as within the combined experimental and modelling uncertainty envelope, attributing the deviation primarily to inlet turbulence intensity sensitivity at high flow rates. On this basis the output comparison factor was assigned gradation 1, one level below the required gradation 2 for MRL 2. The team concluded the overall validation evidence remained sufficient to support the COU decision, citing the conservative RH < 1 acceptance criterion and the bounded nature of the exceedance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, scalar stress distribution) are the same as or directly translatable to the COU decision QoIs.",
      "rationale": "The primary COU QoI is the relative hemolysis index (RH) computed from the power-law model integrated along Lagrangian particle trajectories. Validation experiments measured the same NIH normalised index using the same ASTM F1841 protocol. No surrogate or proxy QoI substitution was required. Relevance of QoIs gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry or a geometrically similar predicate device under COU-representative operating conditions.",
      "rationale": "Validation activities were performed on the FDA generic centrifugal blood pump — the same geometry used in the COU simulations — across the full operating envelope (2.5–5.0 L/min, 2000–3500 RPM) specified in the COU. No geometric scaling or operating-condition extrapolation was required. Relevance of validation activities gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence to at least 1e-5 for continuity and momentum; mass imbalance < 0.01% across all operating points.",
      "rationale": "All simulations were run to residual convergence of 1e-6 for continuity and momentum equations. Mass imbalance across the pump domain was < 0.005% for all five operating points. Iterative solver error is negligible relative to discretization and model-form uncertainty. Numerical solver error gradation 1 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by a second qualified CFD analyst; checklist completed.",
      "rationale": "An independent CFD analyst (not involved in the original simulation setup) reviewed all boundary conditions, material properties, solver settings, and post-processing scripts against a documented checklist. No setup errors were identified. Use error gradation 1 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law constitutive model selection justified by literature precedent and sensitivity analysis.",
      "rationale": "SST k-ω turbulence closure was selected based on published benchmark performance for confined rotating flows and FDA critical-path pump studies. The Giersiepen-Wurzinger power-law hemolysis model was applied with coefficients validated against porcine red blood cell fragility data. Turbulence model sensitivity (SST k-ω vs. realizable k-ε) showed < 10% variation in hemolysis index, confirming model-form uncertainty is bounded. Model form gradation 1 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; nominal input values traceable to device specifications.",
      "rationale": "At MRL 2 a full probabilistic input uncertainty quantification is not required. Nominal fluid properties (density, viscosity) and pump geometry dimensions are traceable to manufacturer specifications and published literature. Model inputs factor scoped to gradation 1 and not formally assessed beyond nominal value traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; single representative pump unit used for bench-top validation is acceptable.",
      "rationale": "MRL 2 does not require multi-unit statistical sampling. Validation experiments were performed on a single FDA generic pump unit manufactured to nominal specification tolerances. Unit-to-unit variability is not expected to materially affect the hemolysis index at the operating points assessed. Test samples factor not formally assessed beyond confirmation of single-unit representativeness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; COU and validation operating conditions confirmed to overlap.",
      "rationale": "The COU operating envelope (2.5–5.0 L/min, 2000–3500 RPM) is fully covered by the validation experimental matrix. No extrapolation beyond the validated operating space is required. Equivalency of input parameters factor not formally assessed beyond confirmation of operating-condition overlap."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for MRL 2. Seven factors were formally assessed; six were scoped to gradation 1 and not assessed beyond nominal traceability, consistent with MRL 2 requirements. The output comparison factor achieved gradation 1 against a required gradation 2; however, the team determined that the single exceedance at the 5.0 L/min, 3500 RPM operating point was within the combined experimental and modelling uncertainty budget and did not invalidate the overall validation evidence base. All remaining assessed factors met or exceeded required levels. The conservative RH < 1 acceptance criterion, the bounded nature of the output comparison deviation, and the breadth of the validation dataset collectively support a Medium assurance determination. The COU decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
