  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Extensive mesh-refinement studies, turbulence-model benchmarking, and cross-laboratory validation against published FDA pump hemolysis data collectively support a Medium assurance determination. The assessment team is satisfied that all critical credibility factors have been addressed at or above the required gradation for MRL 2.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-cpb-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-hemolysis-experimental-2021",
    "https://uofa.net/synth/data/morrison-mesh-refinement-study-2023",
    "https://uofa.net/synth/data/cpb-operating-conditions-sweep-2023"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/fda-pump-bench-2021",
      "type": "ValidationResult",
      "name": "FDA generic pump bench-top hemolysis validation — five operating points",
      "description": "Experimental hemolysis index measurements at 2.5, 3.5, and 5.0 L/min flow rates and 2000/3500 RPM were compared against CFD predictions. Relative hemolysis index agreement within 18% across all five operating points, satisfying the RH < 1 acceptance criterion. Measurement uncertainty characterised via ASTM F1841 protocol."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-refinement-grid-convergence-2023",
      "type": "ValidationResult",
      "name": "Grid-convergence index study — three-level mesh refinement",
      "description": "Three systematically refined hexahedral meshes (4.2 M, 11.7 M, and 31.4 M elements) were evaluated. GCI for the scalar stress-based hemolysis power-law metric was 3.1% on the medium mesh, confirming adequate discretization error control for the COU operating envelope."
    },
    {
      "id": "https://uofa.net/synth/validation/turbulence-model-sensitivity-2023",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-omega vs. realizable k-epsilon",
      "description": "Both SST k-ω and realizable k-ε models were exercised across all five flow-speed combinations. Maximum divergence in predicted hemolysis index between models was 9.4%, within the accepted uncertainty budget. SST k-ω selected as primary model based on literature precedent for rotating-passage flows."
    }
  ],
