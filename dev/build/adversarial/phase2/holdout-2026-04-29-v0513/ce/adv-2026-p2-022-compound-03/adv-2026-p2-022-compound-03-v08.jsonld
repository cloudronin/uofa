  "signature": "ed25519:9b2e4f1a7c3d8e5b0f6a2c9d4e7b1f3a8c5d2e9f4b7a0c3e6d1f8b2a5c9e4d7",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022R2) with documented QA procedures, version control, and regression test suite. Minimum Gradation 1 required at MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 is an FDA-recognized simulation software with documented software development lifecycle, ISO 9001 certification, and a published verification and validation test matrix. Internal project records confirm version-locked solver deployment with MD5 checksums on all solver executables. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark problems (lid-driven cavity, backward-facing step) with documented convergence to analytical solutions. Minimum Gradation 1 required.",
      "rationale": "ANSYS Fluent benchmark documentation demonstrates second-order spatial convergence on the lid-driven cavity (Re=1000) and backward-facing step (Re=800) problems. Project-specific code verification confirmed conservation residuals below 1e-6 for all reported simulations. No custom UDFs were employed; all physical models are part of the validated solver release."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 5% for primary QoI on production mesh. Minimum Gradation 2 required at MRL 2.",
      "rationale": "Three-level mesh refinement study yielded GCI of 3.2% for volume-averaged scalar shear stress on the 19.2M-cell production mesh. Spatial order of convergence was 1.87, consistent with the nominally second-order discretization scheme. Temporal discretization error for the frozen-rotor steady-state approach was assessed via comparison with a sliding-mesh transient simulation at the nominal operating point, showing less than 4% difference in NIH. Achieved level of 3 comfortably exceeds the required level of 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation test conditions (flow rate, rotational speed, fluid properties) documented with traceability to calibrated instrumentation. Minimum Gradation 2 required.",
      "rationale": "Experimental hemolysis measurements were conducted using porcine blood with hematocrit maintained at 35±2% and temperature controlled at 37±0.5°C. Flow rates were set by a calibrated Coriolis mass flow meter (±0.5% full scale). Rotational speed was encoder-verified (±5 RPM). All instrumentation calibration certificates are on file with traceability to NIST standards. Test conditions bracket the five COU operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M or NRMSE) computed between model predictions and experimental data for NIH across all five validation operating points. Minimum Gradation 2 required at MRL 2.",
      "rationale": "Predicted NIH values were compared against experimental measurements at five operating points. A normalized root-mean-square error of 22.4% was computed across all five points, with a maximum point-wise deviation of 31% at the highest flow-speed condition. While the rank ordering of hemolysis across conditions was correctly reproduced, the quantitative agreement metric does not reach the threshold for Gradation 2, which requires NRMSE below 15% or equivalent validation metric within one experimental uncertainty band for at least four of five points. Only three of five predictions fell within the experimental uncertainty band. The team judged the rank-ordering fidelity sufficient for the intended comparative use, and the decision was recorded as Accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH, RH index) directly maps to the clinical endpoint (hemolysis) and is the accepted regulatory metric for CPB device submissions. Minimum Gradation 2 required.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the quantities specified in FDA guidance for hemolysis assessment of blood-contacting devices. CFD-derived scalar shear stress is integrated with the Giersiepen power-law hemolysis model to compute NIH, providing a direct mechanistic link between the computational output and the regulatory acceptance criterion (RH < 1). The QoI relevance is well established in the literature and accepted by FDA for 510(k) submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, flow conditions, and fluid properties representative of the COU. Minimum Gradation 2 required.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU simulations. Operating conditions span the clinical CPB range (2–5 L/min, 2000–4500 RPM). Porcine blood was used as the test fluid, which is the standard surrogate for human blood in hemolysis testing. The validation domain is therefore directly representative of the COU, satisfying Gradation 2 relevance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated via residual monitoring; mass and momentum imbalances below 0.1%. Minimum Gradation 1 required.",
      "rationale": "All production simulations were run to convergence with continuity residuals below 5e-5 and momentum residuals below 1e-5. Global mass imbalance across inlet and outlet boundaries was below 0.05% for all cases. Convergence was confirmed by monitoring NIH and scalar shear stress integral quantities over the final 500 iterations, with variation below 0.3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions and material properties verified against COU specification. Minimum Gradation 1 required.",
      "rationale": "An independent simulation engineer reviewed all case setup files prior to production runs, confirming boundary condition assignments, turbulence model selection, and hemolysis model constants against the project specification document. Discrepancies identified during review (incorrect inlet turbulence intensity in two preliminary cases) were corrected before production runs. No use errors were identified in the final production simulation set."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations (Navier-Stokes, turbulence closure, hemolysis power law) appropriate for the flow regime and QoI. Minimum Gradation 1 required.",
      "rationale": "The SST k-omega turbulence model was selected based on its demonstrated superior performance in rotating machinery flows with adverse pressure gradients. The Giersiepen hemolysis power-law model (exponents alpha=0.785, beta=2.416) is the most widely cited model for CFD hemolysis prediction and has been used in multiple FDA-cleared device submissions. Non-Newtonian blood rheology was represented using the Carreau model with parameters from published literature. Model form selection is well supported by the validation evidence and domain practice."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood rheology parameters, pump geometry dimensions, and operating conditions traceable to measurements or published sources. Minimum Gradation 1 required.",
      "rationale": "Pump geometry was reconstructed from CMM measurements of the production impeller and volute with dimensional tolerances of ±0.05 mm. Blood rheology parameters (Carreau model constants) were taken from Ballyk et al. (1994) and confirmed consistent with project-specific viscometry measurements at 37°C. Inlet flow rates and rotational speeds were specified from the COU operating matrix with traceability to the device IFU. All inputs are documented in the simulation data package with version-controlled CAD files and material property records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test samples (blood or blood analog) characterized for relevant properties; sample preparation documented. Minimum Gradation 1 required.",
      "rationale": "Porcine blood was obtained from a single licensed abattoir and used within 6 hours of collection. Hematocrit was adjusted to 35% by centrifugation and resuspension. Baseline plasma free hemoglobin (pfHb) was measured prior to each test run to confirm absence of pre-existing hemolysis. Sample preparation protocol is documented in the laboratory standard operating procedure on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD simulation input parameters (geometry, boundary conditions, fluid properties) confirmed equivalent to experimental test conditions used for validation. Minimum Gradation 1 required.",
      "rationale": "A parameter equivalency matrix was prepared comparing CFD simulation inputs against experimental test conditions for all five validation operating points. Geometry: CFD model derived from same CMM dataset used to manufacture test hardware; dimensional agreement within measurement uncertainty. Fluid properties: Carreau model constants matched to project viscometry data. Boundary conditions: inlet flow rates and rotational speeds identical to experimental setpoints within instrumentation uncertainty. No unresolved equivalency gaps were identified."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-simulation-group-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for Model Risk Level 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the seven assessed factors, six met or exceeded their required credibility levels. The Output Comparison factor achieved Gradation 1 against a required Gradation 2; however, the team determined that the correct rank ordering of hemolysis across all five operating conditions, combined with conservative acceptance criteria (RH < 1 with 20% margin applied to CFD predictions), provides sufficient evidence to support the intended comparative use. The breadth of validation activities, the use of a well-established hemolysis model, and independent PIV-based turbulence model validation collectively support a Medium assurance level determination. The decision to accept the model for the stated COU was approved by the credibility assessment lead.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
