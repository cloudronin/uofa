  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The overall credibility evidence is judged sufficient to support a Medium assurance level given the breadth of validation activities, the use of a well-established hemolysis power-law model, and independent confirmation of hemolysis index trends against published experimental benchmarks.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/morrison-cpb-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-cpb-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/morrison-cpb-mesh-refinement-study",
    "https://uofa.net/synth/data/morrison-cpb-operating-conditions-matrix"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-benchmark-fda-pump",
      "type": "ValidationResult",
      "name": "FDA generic centrifugal pump benchmark — hemolysis index comparison",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against published FDA benchmark experimental data across five operating points (2.5 L/min at 2500 RPM, 3.5 L/min at 3500 RPM, and three intermediate conditions). Predicted NIH agreed within 18% of experimental mean for four of five conditions; the fifth condition (4.5 L/min at 4500 RPM) showed 31% deviation attributed to secondary flow instabilities not captured by the steady-state solver. The overall validation activity was deemed sufficient to establish model credibility for the intended rank-ordering use case."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — three-level Richardson extrapolation",
      "description": "A three-level mesh refinement study (coarse: 1.2M cells, medium: 4.8M cells, fine: 19.2M cells) was conducted using Richardson extrapolation to estimate the grid convergence index (GCI). The fine-mesh GCI for the primary QoI (volume-averaged scalar shear stress) was 3.2%, satisfying the project acceptance criterion of GCI < 5%. Wall y+ values on impeller surfaces remained below 5 for the fine mesh, consistent with the low-Reynolds turbulence model employed."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-turbulence-model-assessment",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-omega vs. realizable k-epsilon comparison",
      "description": "Two turbulence closure models (SST k-omega and realizable k-epsilon) were compared against particle image velocimetry (PIV) measurements in a scaled acrylic replica of the pump volute. Velocity magnitude profiles at three cross-sections showed mean absolute errors of 6.1% (SST) and 9.4% (k-epsilon) relative to PIV data. SST k-omega was selected as the production model. This activity provides supporting evidence for model form credibility at the operating conditions of interest."
    }
  ],
