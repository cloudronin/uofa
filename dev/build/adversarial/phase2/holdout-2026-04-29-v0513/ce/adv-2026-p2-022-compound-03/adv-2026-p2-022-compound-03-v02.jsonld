  "hash": "sha256:3f7a2c91e4b05d68a1f9c3e7b2d4a6f8c0e2b4d6a8f0c2e4b6d8a0f2c4e6b8d0",
  "signature": "ed25519:9a1b3c5d7e9f1a3b5c7d9e1f3a5b7c9d1e3f5a7b9c1d3e5f7a9b1c3d5e7f9a1b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be subject to documented version control, regression testing, and a traceable change-management process consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 was employed under a formal software quality plan. Version control logs, regression test suite results, and a documented change-management record were reviewed and found compliant with the MRL 2 SQA requirements. No open defects affecting hemolysis-relevant solver modules were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through published benchmark problems or manufactured-solution tests at MRL 2.",
      "rationale": "ANSYS Fluent has been verified against the ASME V&V 20 lid-driven cavity and backward-facing step benchmarks. Internal manufactured-solution tests for the SST k-ω turbulence model are documented in the solver verification report. Results are within expected discretization-order convergence rates, confirming correct code implementation for the flow regime of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary quantity of interest (normalized index of hemolysis, NIH) must be less than 5% on the fine mesh used for production runs.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 4.2 M, 8.7 M, and 17.1 M cells. Richardson extrapolation yielded a GCI of 3.1% for NIH on the medium mesh and 1.8% on the fine mesh. The fine mesh (17.1 M cells) was adopted for all production simulations. Spatial discretization error is within the accepted threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to reproduce boundary conditions in the CFD model, including fluid properties, pump speed, and inlet flow rate.",
      "rationale": "Bench test conditions from the FDA hemolysis protocol were fully documented: phosphate-buffered saline with bovine blood at 37 °C, hematocrit 35 ± 1%, pump speeds of 2500 and 3500 RPM, flow rates of 2, 4, and 6 L/min. All five operating points were replicated in the CFD boundary conditions with uncertainty bounds quantified and applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within combined experimental and numerical uncertainty bands at all five validation operating points.",
      "rationale": "CFD-predicted NIH values at all five operating points fell within the combined uncertainty envelope (experimental ± 12%, numerical ± 1.8%). The maximum discrepancy was 9.4% at the 3500 RPM / 6 L/min condition, within the acceptance band. The validation metric confirms adequate predictive accuracy for the intended COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation (NIH, RH) must be directly traceable to the clinical endpoint (hemolysis) and the regulatory acceptance criterion (RH < 1).",
      "rationale": "NIH is the standard scalar hemolysis index used in FDA guidance and ISO 10993-4. The relative hemolysis index RH is derived directly from NIH ratios between test and predicate device. Both QoIs are clinically meaningful and directly support the regulatory decision criterion. Traceability to the clinical endpoint is unambiguous."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same pump geometry and at operating conditions that span or bound the COU operating envelope used for worst-case identification.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump geometry, which is a reference design rather than the specific commercial CPB device geometry under assessment. While the generic pump shares the same impeller diameter class and volute topology, the blade angle distribution and clearance gaps differ by up to 15% from the production device. The five validation operating points cover 2500–3500 RPM and 2–6 L/min; however, the COU worst-case identification sweep extends to 4500 RPM and 7 L/min, which lie outside the validated envelope. Extrapolation into this regime introduces unquantified model-form uncertainty. Despite these gaps, the assessment team judged the validation activities sufficiently representative to proceed, noting that the turbulence model behaviour at higher shear rates has not been independently confirmed for this geometry class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated by residual reduction of at least four orders of magnitude and stabilisation of the NIH monitor prior to sampling.",
      "rationale": "All production runs achieved residual reduction of five or more orders of magnitude. NIH monitor values were stable to within 0.3% over the final 500 iterations before sampling. Iterative solver error is negligible relative to discretization and model-form uncertainty contributions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented peer review of simulation setup, boundary condition assignment, and post-processing scripts must be completed by an independent analyst.",
      "rationale": "An independent senior CFD analyst reviewed the simulation setup report, boundary condition specification, and post-processing scripts prior to production runs. Two minor discrepancies in turbulence intensity specification at the inlet were identified and corrected. No further use errors were identified. The review is documented in the project quality record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoping analysis confirmed factor does not materially affect the credibility conclusion.",
      "rationale": "At MRL 2, a formal model-form uncertainty quantification is not required. The SST k-ω turbulence model is the established standard for internal rotating flows in cardiovascular CFD. Literature evidence supports its suitability for this flow regime. No formal model-form assessment was performed; this is acceptable under the MRL 2 scoping decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input uncertainty propagation is deferred to a higher MRL assessment if device advances to Class III.",
      "rationale": "Formal input uncertainty propagation (e.g., Monte Carlo or polynomial chaos) is not required at MRL 2. Nominal fluid property values and geometric dimensions were used. Sensitivity to ±5% variation in viscosity and hematocrit was checked informally and found to produce less than 2% change in NIH, supporting the adequacy of the nominal-input approach."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample variability assessment deferred.",
      "rationale": "At MRL 2, a formal assessment of test sample variability is not required. Three independent blood batches were used in the bench experiments; inter-batch NIH variability was within 8%, which was incorporated into the experimental uncertainty bound used in the output comparison factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency between validation and COU input parameters addressed qualitatively.",
      "rationale": "A qualitative equivalency review confirmed that fluid properties, rotational speed range, and flow rate range used in validation are representative of the COU operating envelope, with the noted exception documented under the Relevance of Validation Activities factor. No formal quantitative equivalency mapping was performed, consistent with MRL 2 expectations."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the seven assessed factors, six achieved their required credibility level. The Relevance of Validation Activities factor achieved Gradation 1 against a required Gradation 2; however, the team judged that the generic pump geometry is sufficiently representative of the production device and that the operating-point extrapolation risk is mitigated by the conservative NIH acceptance margin (RH < 1 with observed RH of 0.74 at worst-case predicted conditions). The body of evidence, taken in aggregate, was judged sufficient to support a Medium assurance declaration and an Accepted decision for the COU. The assessment is consistent with FDA guidance on computational fluid dynamics in cardiovascular device submissions and with the ASME V&V 40 framework for MRL 2 devices.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
