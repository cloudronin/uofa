  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the seven assessed factors, six met or exceeded required credibility levels. The discretization error factor achieved Gradation 1 against a required Gradation 2; however, the team concluded that the 11.2% mesh sensitivity observed in NIH predictions, while above the formal threshold, was within the range of experimental uncertainty and did not materially affect the worst-case identification task. The overall body of evidence — including validated pressure-flow characteristics, NIH predictions within 15% of benchmark data, and well-characterized boundary conditions — is judged sufficient to support the intended use at Medium assurance level. Decision: Accepted.",
