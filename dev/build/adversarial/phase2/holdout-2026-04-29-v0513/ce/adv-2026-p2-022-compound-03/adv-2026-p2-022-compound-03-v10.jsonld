  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-bench-hemolysis-5op",
      "type": "ValidationResult",
      "name": "Bench hemolysis validation across 5 operating points — FDA generic centrifugal pump",
      "description": "In-vitro hemolysis measurements collected at five flow-speed combinations (3, 4.5, 6 L/min × 2000–3500 RPM) using modified ASTM F1841 protocol with porcine blood. Normalized index of hemolysis (NIH) values compared to CFD-predicted scalar stress exposures. Mean absolute error 8.3%; all predictions within ±15% of measured NIH. RH < 1 criterion satisfied at all operating points relative to predicate device."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — Richardson extrapolation on shear-stress QoI",
      "description": "Three-level mesh refinement study (4.2 M, 9.8 M, 21.6 M elements) with Richardson extrapolation applied to volume-averaged scalar shear stress. Grid convergence index (GCI) for fine-to-medium ratio: 2.1%. Discretization uncertainty formally quantified and propagated to hemolysis index prediction."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-turbulence-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-ω vs. realizable k-ε comparison",
      "description": "Two RANS turbulence models compared against PIV velocity measurements in the pump volute at 4.5 L/min, 3000 RPM. SST k-ω yielded RMS velocity error of 6.2% vs. 9.8% for realizable k-ε. SST k-ω selected as primary model form. Sensitivity of hemolysis index to model choice: ±4.7%."
    }
  ],
