  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cvlab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Seven factors were formally assessed; six were scoped out or not assessed as permitted at MRL 2. Of the seven assessed factors, six achieved their required levels or above. The team noted that the Test Conditions factor achieved level 1 against a required level of 2; however, after deliberation, the team judged that the inlet profile scaling assumption introduces only modest uncertainty relative to the overall validation uncertainty budget (±11.4%), and that the remaining factors — particularly discretization error (GCI 2.1%), output comparison (mean error 8.3%), and model form (turbulence sensitivity ±4.7%) — collectively provide sufficient confidence in the model predictions. The overall evidence base was assessed as supporting a Medium assurance level, and the decision to accept the simulation results for the CPB hemolysis COU was recorded accordingly.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
