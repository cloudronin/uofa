  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures; version-controlled simulation scripts; run logs archived.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-compliant QA framework. Simulation input files were version-controlled in Git. Run logs and solver residual histories were archived for all 15 simulation cases. Achieved level 2 exceeds the required level 1 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against published benchmark cases relevant to rotating machinery internal flows.",
      "rationale": "ANSYS Fluent has been verified against the FDA benchmark nozzle and the ASME V&V 20 pipe-flow benchmark. Internal rotating-frame MRF implementation verified against analytical solutions for solid-body rotation. Published verification reports accompany the solver release documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for the primary QoI (NIH) with GCI < 5% on the fine mesh; Richardson extrapolation applied across three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study was conducted with coarse (2.1 M cells), medium (5.8 M cells), and fine (14.2 M cells) meshes. The observed order of convergence for NIH was p = 1.12, below the nominal second-order scheme, indicating residual discretization sensitivity. The GCI for the fine-to-medium refinement ratio was 8.7% for the primary NIH quantity of interest — exceeding the 5% acceptance threshold. The team noted that further refinement in the blade-gap region would require prohibitive computational resources within the project timeline and concluded that the existing mesh was adequate given the 18% experimental uncertainty in the validation dataset. The discretization error factor is therefore assessed at achieved level 1 against a required level of 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity, temperature) documented and matched to simulation inputs within stated tolerances.",
      "rationale": "All five operating points were reproduced in the test loop with flow rate controlled to ±0.05 L/min and rotational speed to ±15 RPM. Fluid temperature was maintained at 37 ± 0.5 °C. Viscosity of the blood-analog fluid was measured pre- and post-test; variation less than 1.2%. Boundary conditions in the CFD model were set to the time-averaged measured values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty U_val) computed for primary QoI; comparison made against acceptance band derived from experimental uncertainty.",
      "rationale": "Mean absolute percentage error for NIH across five operating points was 18.3%, within the 95% confidence interval of experimental measurements. Validation uncertainty U_val was propagated from input parameter uncertainty and experimental measurement uncertainty. The model comparison error |E| was less than U_val at four of five operating points, satisfying the acceptance criterion. One outlier point at 2.5 L/min / 3500 RPM showed |E| = 1.14 U_val; sensitivity analysis attributed this to inlet swirl not captured in the steady-state MRF approach."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, velocity field) are directly linked to the COU decision quantity (relative hemolysis index RH).",
      "rationale": "The normalized index of hemolysis (NIH) used in validation is the direct precursor to the relative hemolysis index (RH) used in the regulatory acceptance criterion (RH < 1). The velocity field comparison provides mechanistic confirmation that the shear stress distribution driving the hemolysis power-law model is accurately predicted. Both QoIs are therefore directly relevant to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions sufficiently similar to COU conditions to support credibility claim.",
      "rationale": "Validation was performed on the same FDA generic centrifugal pump geometry as the COU device. Blood-analog fluid matched viscosity and density of human blood at 37 °C. Operating points span the clinical flow-speed envelope. Minor differences in inlet cannula geometry between validation rig and clinical configuration were assessed as having negligible influence on impeller-region flow patterns based on auxiliary simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated; residuals below 1e-5 for all equations; mass imbalance < 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum equations. Mass imbalance at convergence was less than 0.005% for all cases. Double-precision arithmetic employed throughout. No divergence events were recorded across the 15 simulation cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition assignments and material property inputs verified against source documentation.",
      "rationale": "An independent CFD analyst performed a setup review prior to production runs, verifying boundary condition assignments, turbulence model selection, rotating-frame configuration, and material property values against the simulation plan document. One minor discrepancy in outlet pressure specification was identified and corrected before final runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification provided for turbulence model selection and hemolysis constitutive model; sensitivity to model form choices assessed.",
      "rationale": "The SST k-ω turbulence model was selected based on published performance comparisons for confined rotating flows in cardiovascular devices. The Giersiepen power-law hemolysis model was chosen for its widespread use in regulatory submissions and available literature coefficients. Sensitivity of NIH predictions to turbulence model choice (SST vs. realizable k-ε) was assessed at the nominal operating point; NIH varied by 6.3%, within the experimental uncertainty band. Model form uncertainty was therefore judged acceptable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and boundary condition values traceable to measurement data or published references; input uncertainty quantified.",
      "rationale": "Fluid density and viscosity sourced from ASTM F1841 blood-analog specifications with measured confirmation. Pump geometry derived from manufacturer CAD files with dimensional inspection report. Inlet velocity profiles derived from flow-conditioner characterization measurements. One-at-a-time sensitivity analysis performed for all primary inputs; NIH most sensitive to hemolysis model coefficient C (±12% for ±10% coefficient variation)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample geometry verified against nominal CAD; surface finish and dimensional tolerances documented.",
      "rationale": "Three pump prototypes were fabricated and dimensionally inspected. All critical dimensions (impeller diameter, blade gap, volute clearance) were within ±0.05 mm of nominal CAD. Surface roughness Ra measured at 0.8 μm on impeller blades. One prototype exhibited a 0.12 mm deviation in volute tongue clearance; this prototype was excluded from validation testing and replaced."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless parameters (Reynolds number, flow coefficient) in validation experiments match COU operating conditions within 10%.",
      "rationale": "Impeller Reynolds number in validation experiments ranged from 1.8×10⁵ to 3.1×10⁵, matching the COU operating envelope within 4%. Flow coefficient φ matched to within 2.5% across all five operating points. The blood-analog fluid viscosity was adjusted to match the target Reynolds number at each operating point, ensuring dynamic similarity."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors and determined that the overall evidence package supports acceptance of the CFD model for the stated COU. The discretization error factor achieved level 1 against a required level of 2; however, the team judged that the GCI of 8.7% is within the experimental validation uncertainty of 18.3%, and that the conservative nature of the hemolysis model coefficients provides additional margin. All remaining assessed factors met or exceeded their required levels. The validation activities directly address the primary QoI and span the full clinical operating envelope. The declared Medium assurance level is considered appropriate for a Model Risk Level 2 device at this stage of design verification.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
