  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 3.5 L/min, 3000 RPM",
      "description": "Particle image velocimetry measurements at the impeller outlet plane were compared against CFD-predicted velocity fields. Area-weighted mean velocity error was 4.2% across the measurement plane; maximum local deviation 11.7% in the blade wake region. Validation activity conducted on a geometrically identical pump prototype using blood-analog fluid (glycerol-water 36% w/w) at matched Reynolds number."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Normalized index of hemolysis comparison across 5 operating points",
      "description": "Predicted normalized index of hemolysis (NIH) values were compared against in-vitro measurements across five flow-speed combinations (2.5–5.0 L/min; 2500–3500 RPM). Mean absolute percentage error was 18.3%. All five predictions fell within the 95% confidence interval of the experimental measurements. The Giersiepen power-law hemolysis model was employed with literature-derived coefficients; sensitivity to coefficient uncertainty was quantified via one-at-a-time parameter variation."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pressure-head-comparison",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation",
      "description": "Simulated H-Q curve compared against bench test data at nominal speed. Predicted head within 5% of measured values across the operating envelope, confirming hydraulic fidelity of the rotating-frame MRF approach."
    }
  ],
