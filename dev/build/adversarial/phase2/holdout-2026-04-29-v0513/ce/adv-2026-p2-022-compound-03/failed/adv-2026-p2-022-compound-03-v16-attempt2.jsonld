  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the seven assessed factors, six achieved their required credibility levels. The Discretization Error factor achieved level 1 against a required level of 2 (GCI of 11.4% exceeding the 5% threshold); however, the team determined that the conservative hemolysis model and the consistent direction of the mesh sensitivity results provide sufficient confidence that the NIH predictions are not non-conservatively biased. The overall body of evidence — including strong hydraulic validation, consistent QoI performance, and regulatory-accepted methodology — supports a Medium assurance level and an Accepted decision for this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
