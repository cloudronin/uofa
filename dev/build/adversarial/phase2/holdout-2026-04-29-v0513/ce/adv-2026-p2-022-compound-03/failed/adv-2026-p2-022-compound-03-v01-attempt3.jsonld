  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-dr-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors at MRL 2. Seven factors were formally assessed; six were scoped as not-assessed per MRL 2 guidance. The team concluded that the CFD model demonstrates sufficient credibility for its intended use in identifying worst-case hemolysis operating conditions. Mesh independence, turbulence model sensitivity, and experimental correlation against FDA benchmark data collectively support the Medium assurance declaration. The Output comparison factor achieved Gradation 1 against a required Gradation 2; however, the team judged the qualitative agreement compelling and the mean absolute error of 8.3% acceptable in the context of the overall evidence body. On this basis the assessment is accepted at Medium assurance.",
