  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at Model Risk Level 2. Seven factors were formally assessed; six were scoped to Gradation 1 awareness per MRL 2 requirements. The majority of assessed factors met or exceeded required levels, with strong mesh independence evidence (GCI 2.1%), satisfactory output comparison at 4 of 5 operating points, and confirmed RH < 1 at the worst-case design condition. The test conditions factor achieved Gradation 1 against a required Gradation 2 due to incomplete experimental temperature records; however, the team judged the resulting viscosity uncertainty to be bounded by the observed 12.4% mean prediction error and within the ±15% experimental uncertainty band. On this basis the overall credibility was assessed as Medium and the COU accepted for regulatory submission. The assurance level of Medium reflects the weight of positive evidence across the assessed factor set.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
