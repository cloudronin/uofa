  "signature": "ed25519:b4e8d3f2a1c6e9b7d5f0a2c4e6b8d1f3a5c7e9b2d4f6a8c0e2b4d6f8a1c3e5b7",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite; ANSYS Fluent 2022R2 release notes and regression test results on file.",
      "rationale": "ANSYS Fluent 2022R2 used with institutional license management. Release validation documentation reviewed; solver version logged in all simulation input decks. Software change control records confirm no mid-study updates. Gradation 2 requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmark problems (lid-driven cavity, rotating disk) reproduce published solutions within 1% for velocity profiles.",
      "rationale": "Benchmark verification cases executed: lid-driven cavity at Re=1000 and Re=3200 match Ghia et al. reference data within 0.7%. Rotating disk similarity solution reproduced within 0.9%. Code verification requirement at Gradation 2 confirmed satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for NIH quantity of interest on production mesh.",
      "rationale": "Richardson extrapolation and GCI analysis performed across three mesh levels. Production mesh (5.8M cells) yields GCI = 2.1% relative to extrapolated value for NIH. Second-order spatial discretization confirmed via observed order of accuracy p = 1.94. Discretization error adequately quantified and within acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol) documented and matched to simulation boundary conditions within stated tolerances.",
      "rationale": "FDA benchmark experimental dataset reports nominal flow rates and rotational speeds; however, fluid temperature during experiments is reported only as 'room temperature (approximately 22°C)' without precision measurement records. Hematocrit was fixed at 30% in experiments but simulation uses a single-phase power-law viscosity approximation calibrated at 37°C. The temperature-viscosity mismatch introduces an unquantified systematic bias in shear stress predictions that propagates directly into the hemolysis power-law model. Despite repeated requests to the original experimental team, raw temperature logs were not made available. This factor therefore achieves only Gradation 1 against a required Gradation 2, representing a gap in experimental condition traceability that was not resolved prior to the credibility assessment being finalised and the decision being recorded as Accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values within experimental uncertainty (±15%) at all 5 operating points; RH < 1 at worst-case condition.",
      "rationale": "NIH predictions compared against FDA experimental measurements at all 5 flow-speed combinations. Agreement within ±15% experimental uncertainty at 4 of 5 points; single outlier at 4 L/min / 1800 RPM shows 17.2% deviation attributed to inlet swirl sensitivity. RH < 1 confirmed at worst-case design point. Output comparison criterion assessed as met at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH, RH) directly maps to regulatory acceptance criterion for Class II CPB device hemolysis characterisation.",
      "rationale": "Normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the quantities of interest specified in the COU. Both are standard regulatory metrics for blood pump hemolysis per ASTM F1841. Direct correspondence between model output and decision criterion confirmed. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation cases use same pump geometry family, overlapping flow regime, and identical hemolysis model as COU simulations.",
      "rationale": "Validation performed on FDA generic centrifugal pump — same device class and geometric family as the subject CPB pump. Operating conditions in validation matrix span the COU operating envelope (3–7 L/min, 1500–2800 RPM). Identical Giersiepen hemolysis power-law model used in both validation and COU simulations. Relevance criterion satisfied at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor; Gradation 1 (awareness) sufficient.",
      "rationale": "At Model Risk Level 2, numerical solver error beyond code verification is not required to be formally assessed. Iterative convergence monitored via residual reduction to 1e-5 for all equations; no divergence or anomalous residual behaviour observed. Gradation 1 awareness level documented and accepted per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; Gradation 1 sufficient.",
      "rationale": "Use error assessment not required at MRL 2 for Class II device at this consequence level. Simulation setup reviewed by a second analyst; boundary condition inputs cross-checked against experimental protocol. Gradation 1 awareness documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; Gradation 1 sufficient.",
      "rationale": "Model form uncertainty (turbulence closure selection, single-phase blood approximation, rigid wall assumption) acknowledged at Gradation 1. Turbulence model sensitivity study conducted as supplementary evidence but formal model form assessment not required at MRL 2. Limitations noted in simulation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; Gradation 1 sufficient.",
      "rationale": "Model input uncertainty (viscosity coefficients, hemolysis model constants C and alpha) acknowledged. Literature ranges for Giersiepen constants reviewed; nominal values used. Formal uncertainty propagation not required at MRL 2. Gradation 1 documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; Gradation 1 sufficient.",
      "rationale": "FDA benchmark dataset uses pooled bovine blood from multiple donors; sample variability not characterised beyond hematocrit control. At MRL 2 this is accepted at Gradation 1 awareness. Biological variability acknowledged as a source of scatter in the experimental reference data."
    },
