  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were formally assessed; six were determined not to require assessment at MRL 2. Of the seven assessed factors, six achieved their required Gradation 2 level. The test-conditions factor achieved only Gradation 1 against a Gradation 2 requirement due to unreported hematocrit and temperature in the FDA reference dataset; however, the team judged the assumed nominal values to be physiologically representative and the resulting uncertainty to be within the overall model uncertainty budget. On this basis the team concluded that Medium assurance is supported and accepted the model for the stated COU. The decision was ratified by the device sponsor's V&V lead on 2026-04-19.",
