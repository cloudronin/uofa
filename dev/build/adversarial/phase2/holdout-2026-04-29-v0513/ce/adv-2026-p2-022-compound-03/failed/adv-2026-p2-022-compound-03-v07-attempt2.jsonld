    "https://uofa.net/synth/data/fda-pump-experimental-dataset-2013",
    "https://uofa.net/synth/data/morrison-mesh-refinement-study-2024",
    "https://uofa.net/synth/data/morrison-turbulence-sensitivity-2024"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-bench-comparison-2024",
      "type": "ValidationResult",
      "name": "Bench-level validation against FDA generic pump experimental data",
      "description": "CFD-predicted flow fields and hemolysis index compared against published FDA centrifugal pump experimental measurements. Predicted normalized index of hemolysis (NIH) values fell within 18% of experimental mean across all five operating points. Relative hemolysis index RH < 1 criterion satisfied at 4 of 5 operating points; the fifth operating point (3500 RPM, 6 L/min) showed RH = 1.04, attributed to boundary-layer separation not fully captured by the SST k-omega closure."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-independence-2024",
      "type": "ValidationResult",
      "name": "Mesh independence and discretization error quantification",
      "description": "Three-level mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.3M cells) performed at the nominal operating point (3000 RPM, 5 L/min). Grid convergence index (GCI) for NIH was 3.2% between medium and fine meshes. Medium mesh selected for production runs as the fine-mesh GCI fell below the 5% acceptance threshold."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-turbulence-sensitivity-2024",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity analysis",
      "description": "SST k-omega, realizable k-epsilon, and RSM turbulence closures compared at two operating points. NIH predictions varied by up to 22% across models. SST k-omega selected based on best agreement with experimental shear-stress distributions in the impeller region. Sensitivity acknowledged as a residual uncertainty contributor."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034823",
