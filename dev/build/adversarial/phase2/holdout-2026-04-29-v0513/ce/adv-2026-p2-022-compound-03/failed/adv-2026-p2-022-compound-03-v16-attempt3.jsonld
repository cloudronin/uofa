  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the assessed factors, the team concluded that the overall evidence package supports a Medium assurance level. The test conditions factor achieved Gradation 1 against a Gradation 2 requirement; however, the team judged that the physically motivated interpolation approach, combined with the strong performance at the two directly validated operating points and the conservative acceptance criterion (RH < 1), provides adequate confidence for the intended regulatory submission. The remaining assessed factors all met or exceeded their required gradation levels. The declared Medium assurance level is consistent with the MRL 2 classification and the breadth of validation activities conducted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
