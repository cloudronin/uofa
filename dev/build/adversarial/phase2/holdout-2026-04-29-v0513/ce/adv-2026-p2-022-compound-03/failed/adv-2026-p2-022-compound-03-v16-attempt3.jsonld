  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-pump-bench-hemolysis-v1",
      "type": "ValidationResult",
      "name": "Bench-level hemolysis validation against FDA pump experimental data",
      "description": "CFD-predicted relative hemolysis index compared against in-vitro measurements from the FDA benchmark centrifugal pump study. RH values at 5 flow-speed operating points showed mean relative error of 8.3%, within the 15% acceptance threshold. Validation performed on the same pump geometry as the COU device."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pump-mesh-convergence-v1",
      "type": "ValidationResult",
      "name": "Mesh convergence study — discretization error quantification",
      "description": "Three-level mesh refinement study (4.2M, 11.7M, 28.4M elements) conducted at the nominal operating point. Richardson extrapolation yielded a grid convergence index (GCI) of 2.1% on the hemolysis index QoI, satisfying the required GCI < 5% threshold for MRL 2."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver (ANSYS Fluent 2022R2) holds FDA 510(k) documentation and version-controlled simulation scripts are archived in institutional repository.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated CFD solver with documented V&V history. All simulation scripts and case files are version-controlled under Git with SHA-tagged releases. Software QA documentation reviewed and archived. Achieves Gradation 2, exceeding the Gradation 1 requirement for MRL 2."
    },
    {
