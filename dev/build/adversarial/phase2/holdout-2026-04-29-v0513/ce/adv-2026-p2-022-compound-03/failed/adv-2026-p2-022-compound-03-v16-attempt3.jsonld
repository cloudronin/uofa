      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, Taylor-Green vortex) with documented order-of-accuracy confirmation.",
      "rationale": "ANSYS Fluent code verification documented through published benchmark studies. Second-order spatial accuracy confirmed via manufactured solution tests available in solver documentation. Exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% on primary QoI (hemolysis index) using three-level mesh refinement with Richardson extrapolation.",
      "rationale": "Three-level mesh refinement study yielded GCI of 2.1% on the hemolysis index at the nominal operating point. All five operating points assessed; maximum GCI across all conditions was 3.8%. Meets Gradation 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances; fluid temperature, hematocrit, and flow rate uncertainty quantified and reported.",
      "rationale": "The validation experiments were conducted using bovine blood at 37°C with hematocrit 33±2%, closely matching clinical CPB conditions. Flow rate uncertainty was ±3% of nominal. However, the experimental dataset was collected at only two of the five target operating points; the remaining three flow-speed combinations were interpolated from the available measurements rather than directly validated. The interpolation methodology is physically motivated but introduces unquantified extrapolation uncertainty at the off-nominal conditions. This partial coverage means test conditions are characterised at Gradation 1 rather than the Gradation 2 required for MRL 2 with high decision consequence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (relative hemolysis index) reported with uncertainty bands; mean relative error < 15% across validated operating points.",
      "rationale": "Relative hemolysis index compared at two directly validated operating points with mean relative error 8.3% and maximum 11.7%. Uncertainty bands derived from experimental measurement uncertainty and mesh-related numerical uncertainty are reported. Meets Gradation 2 requirement at the validated points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (hemolysis index) directly maps to clinical endpoint; secondary QoIs (shear stress distribution, residence time) documented as supporting evidence.",
      "rationale": "The relative hemolysis index is the directly regulated QoI for CPB device submissions. Secondary QoIs including volume-averaged shear stress and fluid residence time are reported to provide mechanistic insight. QoI relevance is well-established in the literature and accepted by FDA guidance. Achieves Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
