  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the assessed factors, the team judged that the overall evidence base — including the three-level mesh-independence study, the five-point experimental validation, and the independent simulation review — supports a Medium assurance level for the COU. The Output Comparison factor narrative notes a minor procedural deviation (post-hoc threshold setting) but the team considered the 8.3% mean absolute error to be practically acceptable given the regulatory context and the corroborating mesh convergence evidence. The declared assurance level of Medium is considered consistent with the weight of evidence across the assessed factors.",
