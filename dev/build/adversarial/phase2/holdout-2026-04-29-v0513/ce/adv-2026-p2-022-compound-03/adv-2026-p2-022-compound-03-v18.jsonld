  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concludes that the CFD model achieves Medium assurance for the CPB hemolysis COU. Seven of thirteen factors were formally assessed; six were appropriately scoped out at MRL 2. Validation results demonstrate quantitative agreement with PIV and bench hemolysis data within stated acceptance criteria. The mesh convergence study showed GCI of 3.7% against a 2% criterion; however, the team judged that the relative nature of the RH comparison (device vs. predicate) mitigates the impact of residual discretization error on the regulatory conclusion. Software QA, code verification, and iterative convergence factors all meet or exceed required levels. On balance, the evidence package supports the Medium assurance designation and the Accepted decision for submission to FDA.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
