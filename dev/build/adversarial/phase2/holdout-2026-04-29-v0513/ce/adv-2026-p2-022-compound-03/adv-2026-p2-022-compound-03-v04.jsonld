  "signature": "ed25519:b2e4a1c7f3d96e80524b1a8c3f5d0e7b2a4c6e8f1b3d5a7c9e2f4b6d8a0c2e4f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must operate under documented version control with regression testing suite covering relevant turbulence and transport models.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional software quality management plan. Version control documented, regression test suite executed prior to simulation campaign with no failures in hemolysis-relevant test cases. SQA level 2 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via manufactured solution or benchmark problem with known analytical result.",
      "rationale": "Code verification performed using the lid-driven cavity benchmark and a rotating channel flow case. Observed convergence rates consistent with second-order spatial accuracy. No anomalous behavior detected in stress-transport terms relevant to hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be less than 10% at the production mesh level.",
      "rationale": "Three-level mesh refinement study conducted: coarse (4.2M cells), medium (11.8M cells), fine (31.4M cells). GCI for volume-averaged hemolysis power law integral computed as 6.7% between medium and fine meshes. Production simulations executed on medium mesh as cost-accuracy optimum. Richardson extrapolation confirms monotonic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to reproduce boundary conditions in the simulation, including fluid temperature, hematocrit, and inlet flow waveform.",
      "rationale": "The FDA benchmark experimental dataset provides flow rate and rotational speed for each operating point. However, fluid temperature during experiments was not reported in the primary publication, and hematocrit variability across test runs was documented only as a nominal range (35–45%) without per-run values. Boundary conditions were therefore assigned using nominal mid-range values. This introduces unquantified uncertainty in the viscosity and red-cell fragility inputs that propagates directly into the hemolysis index prediction. The test conditions factor achieves only Gradation 1 due to incomplete documentation of fluid property boundary conditions in the validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoIs must be compared against experimental measurements using a quantitative metric with defined acceptance threshold; metric must account for experimental uncertainty.",
      "rationale": "Normalized index of agreement (NIA) and mean absolute percentage error (MAPE) computed for RHI across all five operating points. MAPE = 8.3%, NIA = 0.91, both within acceptance thresholds. Experimental uncertainty bands from the FDA dataset incorporated via error-bar overlap analysis. Model predictions fall within experimental uncertainty at 4 of 5 operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must be directly traceable to the clinical decision QoI (relative hemolysis index for CPB patient population).",
      "rationale": "Relative hemolysis index (RHI) used in both validation and COU decision. The power-law hemolysis model (Giersiepen et al.) integrates shear stress and exposure time along Lagrangian particle paths — the same quantity used in the regulatory submission. QoI relevance is direct with no surrogate substitution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating conditions must be sufficiently similar to the COU device and operating envelope to support extrapolation of credibility evidence.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the same geometry as the COU device. Operating conditions span the CPB clinical range (3–6 L/min, 2500–3500 RPM). Validation activities directly bracket the five COU operating points. No geometric extrapolation required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and mass balance errors documented.",
      "rationale": "Not assessed at MRL 2 for this factor scope. Solver residuals monitored during production runs as standard practice; all simulations converged to 1e-5 on continuity and momentum. Formal assessment deferred per MRL 2 scoping decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup and post-processing by qualified analyst not involved in primary simulation.",
      "rationale": "Not assessed at MRL 2. Simulation setup peer-reviewed informally by senior team member. Formal independent review not required at this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for turbulence model selection and hemolysis constitutive model documented.",
      "rationale": "Not assessed at MRL 2. SST k-omega turbulence model selected based on published literature consensus for rotating machinery hemolysis prediction. Giersiepen power-law hemolysis model selected per FDA guidance. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of QoI to uncertain input parameters quantified.",
      "rationale": "Not assessed at MRL 2. Nominal input values used throughout. Sensitivity analysis of hemolysis index to hematocrit, viscosity, and power-law exponents not formally conducted. Deferred per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number of experimental replicates sufficient to characterize measurement variability.",
      "rationale": "Not assessed at MRL 2. FDA benchmark dataset provides single-replicate measurements at each operating point. Replicate variability not characterized. Accepted as sufficient for MRL 2 validation evidence."
    },
    {
