      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation",
      "description": "Predicted head-flow curve compared against manufacturer performance data and independent laboratory measurements. Agreement within 5% across the operational envelope relevant to CPB conditions."
    }
