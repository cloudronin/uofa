  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The overall credibility posture is assessed as Medium, consistent with the breadth of validation activities performed, the availability of experimental comparator data across five operating points, and the structured uncertainty quantification applied to mesh sensitivity and turbulence model selection. Discretization error was rigorously bounded via Richardson extrapolation, and software quality assurance procedures followed FDA-recognized GAMP 5 guidelines throughout.",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/morrison-cpb-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-cpb-experimental-hemolysis-2023",
    "https://uofa.net/synth/data/morrison-cpb-mesh-convergence-2023",
    "https://uofa.net/synth/data/fda-benchmark-pump-geometry-v2"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison across five operating points — experimental vs. CFD",
      "description": "CFD-predicted normalized index of hemolysis (NIH) was compared against in vitro measurements at five flow-speed combinations (2.5 L/min/3000 RPM through 5.0 L/min/4500 RPM). Mean relative error across all operating points was 11.3%, within the pre-specified 15% acceptance band. The relative hemolysis index RH remained below 1.0 for all worst-case combinations, satisfying the primary acceptance criterion."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-mesh-convergence-vr-02",
      "type": "ValidationResult",
      "name": "Richardson extrapolation mesh convergence study",
      "description": "Three systematically refined meshes (3.1M, 8.4M, and 22.7M cells) were evaluated. Grid convergence index (GCI) for NIH was 2.1% on the fine mesh, indicating negligible discretization error. The observed order of convergence (p = 1.94) was consistent with the second-order numerical scheme employed."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-turbulence-vr-03",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-omega vs. realizable k-epsilon",
      "description": "Sensitivity of NIH predictions to turbulence model selection was quantified by comparing SST k-omega and realizable k-epsilon results across all operating points. Maximum NIH divergence between models was 8.7%, within acceptable bounds for MRL 2. SST k-omega was selected as the primary model based on superior near-wall resolution."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4056892",
