  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for COU1. Seven factors were formally assessed; six were determined not applicable at MRL 2. Of the seven assessed factors, the team determined that all factors met or exceeded their required credibility levels, with the output comparison factor achieving Gradation 2 based on quantitative agreement across the assessed operating points. The breadth of validation activities, the robustness of the mesh convergence study, and the comprehensive sensitivity analyses collectively support a Medium assurance level. The two unvalidated high-flow operating points were considered acceptable given conservative margin in the RH < 1 acceptance criterion. The assessment team accepts the simulation results as credible evidence for the intended regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
