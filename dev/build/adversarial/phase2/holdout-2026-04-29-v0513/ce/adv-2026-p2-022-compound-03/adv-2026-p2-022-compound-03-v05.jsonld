  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-rhi-bench-comparison-001",
      "type": "ValidationResult",
      "name": "RHI bench-scale comparison against FDA experimental dataset",
      "description": "Predicted relative hemolysis index values compared against published FDA experimental measurements for five flow-speed operating points. Mean absolute error of 8.3% across all conditions; all predictions within ±15% band. Validation performed on the nominal pump geometry."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence-gci-002",
      "type": "ValidationResult",
      "name": "Grid convergence index study — three mesh levels",
      "description": "Three-level mesh refinement study (coarse 2.1 M cells, medium 6.4 M cells, fine 18.7 M cells) performed at the highest-shear operating point (6 L/min, 3500 RPM). GCI for wall shear stress QoI: 3.2% (fine-to-medium) and 9.8% (medium-to-coarse), confirming monotonic convergence. Richardson extrapolation applied to quantify discretization error bound."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-turbulence-sensitivity-003",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-omega vs. realizable k-epsilon",
      "description": "Sensitivity study comparing SST k-omega and realizable k-epsilon turbulence closures at three representative operating points. Hemolysis index predictions differed by less than 5% between models; SST k-omega selected as primary closure based on superior agreement with near-wall velocity profiles from PIV measurements."
    }
  ],
