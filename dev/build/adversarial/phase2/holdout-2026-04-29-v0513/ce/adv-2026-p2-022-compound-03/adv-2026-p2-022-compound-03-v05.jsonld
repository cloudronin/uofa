      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to at least 1e-5 for all transport equations; mass imbalance < 0.01%.",
      "rationale": "All production simulations converged to residual levels of 1e-6 or below. Mass imbalance < 0.005% for all cases. Convergence monitored via residual history and QoI stabilization over final 500 iterations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent reviewer sign-off; boundary condition inputs traceable to source data.",
      "rationale": "Simulation protocol document (SPD-CPB-001 Rev B) reviewed and approved by independent senior analyst. Boundary condition input files version-controlled and linked to experimental source records. No use errors identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence closure and hemolysis damage model selection justified by literature and sensitivity analysis; non-Newtonian effects addressed.",
      "rationale": "SST k-omega selected based on turbulence sensitivity study (see validation result 003). Power-law hemolysis model (Giersiepen coefficients) used with sensitivity bounds from Heuser-Opitz coefficients; maximum hemolysis index variation of 12% across model form alternatives. Non-Newtonian effects assessed as negligible at CPB shear rates (> 100 s-1) per Merrill et al."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions assigned with documented uncertainty ranges; sensitivity of QoI to input uncertainty quantified.",
      "rationale": "One-at-a-time sensitivity analysis performed for viscosity (±5%), density (±1%), inlet velocity profile (uniform vs. fully developed), and rotational speed (±1%). Hemolysis index sensitivity to viscosity dominant at 7% per 5% viscosity change. Combined input uncertainty propagated to ±11% on RHI — within acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
