  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Extensive mesh refinement studies, turbulence model benchmarking against FDA nozzle data, and independent code-verification exercises collectively support a Medium assurance conclusion. The validation campaign covered five flow-speed operating points bracketing the clinical envelope, and relative hemolysis index predictions remained below the RH < 1 acceptance threshold across all conditions with margin.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-cbp-experimental-hemolysis-2019",
    "https://uofa.net/synth/data/morrison-mesh-refinement-study-2023",
    "https://uofa.net/synth/data/morrison-validation-operating-points-2023"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-fda-nozzle-benchmark-2022",
      "type": "ValidationResult",
      "name": "FDA nozzle benchmark — velocity field comparison",
      "description": "SST k-omega turbulence model predictions compared against FDA critical path nozzle PIV data. Mean absolute error in axial velocity profiles < 8% across all measurement planes. Provides indirect support for turbulence closure selection in the blood pump geometry."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cbp-rhi-validation-2023",
      "type": "ValidationResult",
      "name": "Centrifugal blood pump RHI validation — five operating points",
      "description": "Predicted relative hemolysis index compared against in-vitro measurements at 2.5, 3.5, 4.5, 5.5, and 6.0 L/min flow rates. All predictions within experimental uncertainty band. Worst-case operating condition correctly identified as 6.0 L/min / 3500 RPM. RH values ranged 0.61–0.94, all below acceptance threshold."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-independence-2023",
      "type": "ValidationResult",
      "name": "Mesh independence study — Richardson extrapolation",
      "description": "Three-level mesh refinement study (4.2M, 11.7M, 28.4M cells) conducted at nominal operating point. Grid convergence index < 3.1% for hemolysis index QoI. Fine-grid solution selected for production runs."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4044672",
