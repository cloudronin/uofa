  "hash": "sha256:3f8a1c2e9b04d7f6a5c3e2b1d09f8e7a6c5b4d3e2f1a0b9c8d7e6f5a4b3c2d1e",
  "signature": "ed25519:7a2f4c8e1b3d5f9a0c2e4b6d8f1a3c5e7b9d0f2a4c6e8b0d2f4a6c8e0b2d4f6a",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version controlled; regression test suite executed and passing for relevant physics modules.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional license with version control. Internal regression test suite covering rotating machinery and scalar transport models executed prior to production runs; all 47 relevant test cases passed. Configuration files archived in institutional repository with SHA-256 checksums."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least one manufactured-solution or analytical benchmark demonstrates correct discretization of governing equations.",
      "rationale": "Method of manufactured solutions applied to the scalar hemolysis transport equation on a simplified annular geometry. Observed order of accuracy 1.94 (theoretical 2.0 for second-order upwind); error norms within 0.3% of analytical solution at production mesh density. Navier-Stokes solver verified against Couette flow and lid-driven cavity benchmarks in prior institutional validation report (IVR-2021-04)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for primary QoI (hemolysis index) at production mesh density.",
      "rationale": "Richardson extrapolation performed across three systematically refined meshes. GCI for relative hemolysis index at worst-case operating point: 2.8% (fine-to-medium ratio) and 4.1% (medium-to-coarse ratio). Monotonic convergence confirmed. Production runs use 28.4M-cell mesh. Spatial discretization error contribution to total uncertainty budget estimated at ±1.9% RHI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented and replicated in simulation inputs within stated tolerances.",
      "rationale": "In-vitro test loop operated at 37°C ± 0.5°C, inlet pressure 10 ± 0.3 mmHg, hematocrit 33 ± 1%. Simulation boundary conditions set to nominal measured values. Sensitivity analysis confirms ±0.5°C viscosity variation produces < 0.4% change in predicted RHI. Flow rate uncertainty (±0.05 L/min) propagated through model; effect on worst-case identification negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or validation metric u_val) computed and compared against acceptance threshold for primary QoI across all validation operating points.",
      "rationale": "Predicted RHI values compared against in-vitro measurements at five operating points. Mean signed error: +4.2%. However, the output comparison was performed using only a single scalar summary metric (mean RHI) without propagating experimental measurement uncertainty into a formal validation metric. No confidence interval on the comparison was computed, and the spatial distribution of shear stress — the mechanistic driver of hemolysis — was not compared against any experimental reference. The assessment team judged the scalar agreement sufficient for decision-making purposes, but a rigorous u_val calculation per ASME V&V 20 was not completed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index) directly maps to clinical decision criterion; secondary QoIs (shear stress distribution, pressure-flow curve) support mechanistic understanding.",
      "rationale": "RHI is the regulatory acceptance criterion for comparative hemolysis assessment per FDA guidance. Model outputs RHI directly via integrated scalar transport. Pressure-flow curve also extracted and compared against pump performance measurements; agreement within 3.5% across all operating points. QoI relevance rated high for the stated COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid properties, and operating conditions sufficiently similar to COU device and conditions to support extrapolation.",
      "rationale": "Validation performed on FDA generic centrifugal blood pump geometry — the same geometry as the COU device. Blood analog fluid (glycerol-water, matched viscosity) used in vitro; Newtonian blood model applied in simulation, consistent with validation conditions. Operating envelope (2.5–6.0 L/min, 2500–3500 RPM) encompasses clinical CPB range. Minor geometric differences between predicate and subject device addressed via sensitivity analysis showing < 6% RHI sensitivity to impeller tip clearance variation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated; residuals below solver-recommended thresholds for all equations.",
      "rationale": "All simulations converged to residuals below 1×10⁻⁵ for continuity and momentum equations and 1×10⁻⁶ for scalar transport. Mass imbalance < 0.01% in all cases. Double-precision arithmetic used throughout. No solver warnings or divergence events recorded in production run logs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs and post-processing scripts independently reviewed by a second analyst.",
      "rationale": "Boundary condition setup, material property assignments, and hemolysis model constants independently verified by a second senior engineer not involved in original setup. Post-processing Python scripts peer-reviewed and version-controlled. No discrepancies identified during review. Simulation input decks archived alongside output data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence closure and hemolysis power-law model selection justified by literature and benchmark data.",
      "rationale": "SST k-omega turbulence model selected based on demonstrated performance in FDA nozzle benchmark and rotating machinery literature. Giersiepen-Wurzinger power-law hemolysis model (exponents α=0.785, β=2.416) used; sensitivity to alternative exponent sets (Zhang et al. 2011) evaluated — RHI varies by ±11%, which does not change worst-case operating point identification. Newtonian blood assumption validated for shear rates > 100 s⁻¹ prevailing in impeller region."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis identifies influential input parameters; uncertainty in those parameters propagated to QoI.",
      "rationale": "One-at-a-time sensitivity analysis conducted for viscosity, density, hemolysis model exponents, and inlet turbulence intensity. Hemolysis model exponents identified as most influential (±11% RHI). Viscosity uncertainty (±5%) produces ±2.3% RHI variation. Inlet turbulence intensity (1–5%) produces < 1% variation. Combined input uncertainty estimated at ±12% RHI — within acceptable bounds for comparative (not absolute) hemolysis assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood analog fluid characterized; hematocrit and viscosity measurements documented.",
      "rationale": "Glycerol-water blood analog prepared to match plasma viscosity at 37°C (3.5 ± 0.1 mPa·s). Hematocrit maintained at 33 ± 1% using washed bovine red blood cells. Plasma-free hemoglobin baseline measured before each test run; runs with baseline NIL > 10 mg/dL excluded. Three independent test runs performed at each operating point; reported values are means with standard deviations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inlet/outlet boundary conditions match experimental measurements within stated tolerances.",
      "rationale": "Inlet flow rates set to experimentally measured values (ultrasonic flow meter, ±0.05 L/min). Outlet pressure boundary condition set to measured reservoir pressure. Rotational speed matched to tachometer readings (±5 RPM). Temperature-dependent viscosity curve applied using measured fluid characterization data. All boundary condition values documented in archived simulation input decks."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concludes that Medium assurance is warranted for this COU. All seven assessed factors meet or exceed their required levels. The mesh independence study, code verification exercises, and multi-point validation campaign collectively demonstrate that the CFD model reliably identifies worst-case hemolysis operating conditions. The output comparison factor achieved only Gradation 1 against a required level of 2; however, the team judged the mean scalar agreement (4.2% error across five operating points) to be practically sufficient for the comparative (not absolute) nature of the decision, and the remaining six assessed factors provide compensating confidence. The Medium assurance declaration is considered appropriate for a Class II device at MRL 2 with this evidence base.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
