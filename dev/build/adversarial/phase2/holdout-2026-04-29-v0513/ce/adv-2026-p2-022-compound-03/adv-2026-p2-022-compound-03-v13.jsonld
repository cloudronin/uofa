  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression test suite, and release notes available; no open critical defect reports affecting turbulence or scalar transport modules.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-certified QMS. Version control records, regression test logs covering the k-omega SST and species transport modules, and a signed release note confirming no open critical defects were reviewed. SQA requirements for MRL 2 are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Published benchmark solutions for rotating machinery and scalar transport available in solver verification suite.",
      "rationale": "ANSYS Fluent verification benchmarks for the MRF rotating frame formulation and passive scalar transport were reviewed. Results match analytic and published reference solutions to within expected floating-point tolerances. Code verification is adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% on QoI (NIH) for the fine mesh; monotonic convergence demonstrated across three refinement levels.",
      "rationale": "Three structured-dominated meshes (4.1M, 9.8M, 21.4M cells) were generated using ANSYS Meshing. Richardson extrapolation yielded GCI values of 4.2%, 3.1%, and 2.7% for NIH at the three worst-case operating points. Monotonic convergence was confirmed. The fine mesh was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental flow rates, rotational speeds, and blood analog properties documented and traceable to calibrated instruments.",
      "rationale": "In-vitro tests were conducted using a porcine blood analog (hematocrit 33±1%) at 5 flow-speed combinations. Coriolis flow meters (±0.5% FS) and a calibrated tachometer (±0.1% FS) were used. Temperature was maintained at 37±0.5°C. All instrument calibration records are traceable to NIST standards."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mean relative error in NIH < 15%; no systematic over- or under-prediction across operating envelope.",
      "rationale": "CFD NIH predictions agreed with experimental measurements with a mean relative error of 8.3% and a maximum of 13.7% at the highest shear operating point. Bland-Altman analysis showed no systematic bias. The acceptance criterion of 15% mean relative error is met across all five conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH and RH) directly maps to the regulatory acceptance criterion; shear-stress power law exponents appropriate for CPB operating range.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the quantities directly compared against the predicate device threshold (RH < 1). The Giersiepen-Wurzinger power law used has been validated for shear stress magnitudes and exposure times representative of centrifugal CPB pumps. QoI relevance is confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow conditions, and blood analog properties sufficiently similar to COU device and operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which shares key geometric features (impeller diameter, blade count, volute profile) with the COU device. Operating conditions in validation span the COU envelope. Blood analog hematocrit and viscosity match COU specifications. Relevance is judged sufficient for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-5 for all equations; mass imbalance below 0.01% of inlet mass flow.",
      "rationale": "Iterative convergence was monitored for all transport equations. Continuity and momentum residuals reached 1e-4 at the termination criterion applied in production runs; the target of 1e-5 was not consistently achieved for the scalar hemolysis transport equation at high-speed conditions. Mass imbalance remained below 0.08%, exceeding the 0.01% threshold. The solver error factor achieves only Gradation 1 against the MRL 2 requirement of Gradation 2. The assessment team noted this shortfall in internal review minutes but concluded that the overall evidence package remained sufficiently strong to support the Medium assurance determination."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second analyst; boundary condition selection documented.",
      "rationale": "A second CFD analyst independently reviewed boundary condition assignments, turbulence model selection, and MRF interface definitions prior to production runs. No discrepancies were identified. Use error controls are adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 per project scoping decision.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis constitutive law) was scoped out of the MRL 2 assessment. Literature evidence supporting k-omega SST for internal rotating flows was noted but formal model form assessment was not required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 per project scoping decision.",
      "rationale": "Input uncertainty quantification (fluid properties, geometric tolerances) was not required at MRL 2. Nominal values sourced from published material datasheets and device drawings were used without formal sensitivity analysis."
    },
