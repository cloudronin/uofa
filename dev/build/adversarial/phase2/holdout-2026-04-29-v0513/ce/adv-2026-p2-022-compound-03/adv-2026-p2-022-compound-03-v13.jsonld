  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the seven assessed factors, six achieved their required credibility gradation. The numerical solver error factor achieved Gradation 1 against a required Gradation 2; however, the team judged that the strong output comparison results (mean error 8.3%), the robust GCI study, and the breadth of the validation dataset collectively provided sufficient confidence to support a Medium assurance level determination. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device as defined in the COU.",
