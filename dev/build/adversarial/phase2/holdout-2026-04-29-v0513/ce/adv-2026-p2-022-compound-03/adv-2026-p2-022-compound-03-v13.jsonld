  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The assessment team determined that the breadth of validation activities, the robust mesh refinement study, and close agreement between predicted and measured hemolysis index values collectively support a Medium assurance level. Independent review confirmed that all seven assessed factors satisfy or exceed their required credibility gradations.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-fda-pump-experimental-2023",
    "https://uofa.net/synth/data/morrison-cfd-output-5flowconditions-2023"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-bench-2023",
      "type": "ValidationResult",
      "name": "Bench-level hemolysis index comparison — FDA generic centrifugal pump",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against in-vitro measurements across 5 operating conditions. Mean relative error was 8.3% with no systematic bias. The validation dataset spanned the full operating envelope of the CPB device, including the worst-case high-speed low-flow condition identified as critical by the design team."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-refinement-2023",
      "type": "ValidationResult",
      "name": "Mesh refinement and GCI study — rotor and volute regions",
      "description": "A three-level mesh refinement study was performed on the rotor passage and volute. Grid convergence index (GCI) for the shear-stress-derived hemolysis power law was below 4.2% on the fine mesh, confirming acceptable discretization error for the quantities of interest."
    }
  ],
