      "type": "ValidationResult",
      "name": "Pump pressure head — HQ curve validation",
      "description": "Simulated H-Q characteristic curves compared against manufacturer-supplied bench test data across 7 operating points at 3000 rpm and 4000 rpm. Maximum deviation 4.1 % at lowest flow rate; all other points within 2.5 %. Provides confidence in overall flow-field fidelity underpinning hemolysis predictions.",
      "passFailStatus": "Pass",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/vr-pressure-head-uq",
        "type": "UncertaintyQuantification",
        "method": "Experimental measurement uncertainty propagated from pressure transducer calibration (±0.5 % FS) and flow meter accuracy (±1 % reading). CFD numerical uncertainty estimated via GCI at < 0.8 % on pressure head.",
