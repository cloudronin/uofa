      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-cpb-hemolysis-bench-01-uq",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo propagation of inlet boundary condition uncertainty (±5% flow rate, ±2% rotational speed); 500 samples; 95th-percentile prediction interval reported alongside each NIH prediction.",
        "coverageProbability": 0.95
      }
    },
