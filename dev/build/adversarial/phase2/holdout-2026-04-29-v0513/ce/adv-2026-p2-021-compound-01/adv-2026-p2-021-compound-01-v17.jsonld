      "type": "ValidationResult",
      "name": "Pressure-head curve validation across operating envelope",
      "description": "Simulated pump pressure-head (ΔP) compared against manufacturer hydraulic test data at 3000 and 3500 RPM across flow rates 2–6 L/min. Maximum deviation 4.1% at off-design point; mean deviation 1.9%.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-cpb-pressure-head-03-uq",
        "type": "UncertaintyQuantification",
        "method": "Combined experimental measurement uncertainty (±0.5 mmHg pressure transducer, ±0.05 L/min flow meter) propagated via GUM; simulation numerical uncertainty added in quadrature.",
        "coverageProbability": 0.95
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-cpb-tolerance-sensitivity-04",
      "type": "ValidationResult",
      "name": "Dimensional tolerance sensitivity — worst-case hemolysis identification",
      "description": "Parametric sweep of impeller tip clearance (±50 µm) and volute tongue gap (±75 µm) across all 5 COU operating points. RH index computed relative to predicate device baseline. Worst-case identified at 3500 RPM / 3 L/min; RH = 0.91 < 1.0 acceptance criterion satisfied across all 48 tolerance combinations evaluated."
    }
