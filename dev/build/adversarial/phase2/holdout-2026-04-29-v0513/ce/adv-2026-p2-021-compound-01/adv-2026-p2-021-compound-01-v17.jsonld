      "id": "https://uofa.net/synth/validation/vr-cpb-mesh-independence-02",
      "type": "ValidationResult",
      "name": "Mesh independence study for impeller passage shear stress",
      "description": "Three-level mesh refinement study (coarse 2.1M, medium 5.4M, fine 11.8M hexahedral cells) demonstrating grid-converged shear stress distribution in impeller passages. Richardson extrapolation GCI < 1.8% on volume-averaged scalar stress.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-cpb-mesh-independence-02-uq",
        "type": "UncertaintyQuantification",
        "method": "Richardson extrapolation with Grid Convergence Index (GCI) per Celik et al. 2008. Safety factor 1.25 applied. Reported per operating point.",
        "coverageProbability": 0.95
      }
    },
    {
