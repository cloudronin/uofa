      "id": "https://uofa.net/synth/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error study",
      "description": "Grid convergence index (GCI) study performed across three systematically refined meshes (coarse 2.1M, medium 5.8M, fine 14.2M elements). GCI for hemolysis index QoI was 3.2% on the fine mesh, satisfying the MRL 2 requirement of less than 5% discretization error. Richardson extrapolation applied to confirm asymptotic convergence.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/mesh-convergence-gci",
        "type": "UncertaintyQuantification",
        "method": "Grid Convergence Index (GCI)",
        "description": "GCI computed per Celik et al. (2008) protocol. Fine-grid GCI of 3.2% reported for the normalized hemolysis index. Safety factor of 1.25 applied. Observed order of convergence p=1.94, consistent with second-order spatial discretization scheme.",
        "value": 0.032,
        "unit": "dimensionless"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/experimental-hemolysis-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index validation against FDA pump benchmark data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against published FDA generic centrifugal pump experimental data across 5 flow-speed operating points (3–6 L/min, 2500–3500 RPM). Mean absolute relative error of 8.4% across all operating points. All predictions within ±15% of experimental measurements. Relative hemolysis index RH < 1 for worst-case geometry variant, satisfying acceptance criterion.",
      "hasOutputComparison": {
        "id": "https://uofa.net/synth/output-comparison/nih-experimental",
        "type": "OutputComparison",
