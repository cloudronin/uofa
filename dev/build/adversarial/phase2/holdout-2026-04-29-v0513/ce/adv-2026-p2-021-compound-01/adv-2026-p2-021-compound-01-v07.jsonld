  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Discretization error (GCI 3.2%) and output comparison (MARE 8.4%) both satisfy quantitative acceptance criteria. Six factors appropriately scoped as not-assessed at MRL 2. Turbulence model uncertainty (±12%) and discretization uncertainty (±3.2%) combined to total numerical uncertainty of ±12.4%, which is acceptable given the relative comparison nature of the RH acceptance criterion. The CFD model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. Regulatory submission recommended.",
    "decidedAt": "2026-04-19T00:00:00Z"
