  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-rh-index-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison — 5 operating points",
      "description": "CFD-predicted relative hemolysis index (RH) compared against in-vitro measurements at five flow-speed operating points (2 L/min at 2000 rpm, 3 L/min at 2500 rpm, 4 L/min at 3000 rpm, 5 L/min at 3500 rpm, 6 L/min at 4000 rpm). All five CFD predictions satisfy the RH < 1 acceptance criterion. Mean absolute error across operating points is 0.047 RH units.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/vr-01-uq",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo propagation of inlet boundary condition uncertainty (±5% flow rate, ±2% rotational speed). 500 samples. 95th-percentile RH prediction interval reported for each operating point.",
        "coverageProbability": 0.95
      }
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-shear-stress-field",
      "type": "ValidationResult",
      "name": "Wall shear stress field validation against PIV measurements",
      "description": "Volumetric-average and peak wall shear stress distributions predicted by the CFD model are compared against particle image velocimetry (PIV) data collected on a transparent acrylic replica of the FDA generic centrifugal pump. Agreement within 12% for volume-averaged shear stress and within 18% for 99th-percentile peak shear stress across all five operating points. These results support the model's ability to resolve hemolysis-relevant flow features.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/vr-02-uq",
        "type": "UncertaintyQuantification",
        "method": "Grid-convergence index (GCI) computed on three systematically refined meshes (1.8M, 5.4M, 14.7M cells). Reported GCI for volume-averaged shear stress is 3.1%; for peak shear stress is 6.8%. Richardson extrapolation applied.",
        "coverageProbability": 0.95
      }
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise characteristic curve validation",
      "description": "CFD-predicted pump head (pressure rise) compared against manufacturer-supplied hydraulic performance data across the full operating range. Predictions agree within 5% of measured head at all five COU operating points, confirming adequate bulk-flow fidelity as a prerequisite for hemolysis prediction accuracy.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/vr-03-uq",
        "type": "UncertaintyQuantification",
        "method": "Sensitivity analysis varying fluid viscosity ±10% and inlet turbulence intensity 1–5%. Pressure-rise prediction varies by less than 2.3% across the sensitivity range.",
        "coverageProbability": 0.9
      }
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-04-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study — hemolysis index QoI",
      "description": "Hemolysis index computed on three mesh resolutions (1.8M, 5.4M, 14.7M cells). The relative change in hemolysis index between the medium and fine mesh is 1.4%, below the 2% threshold adopted as the mesh-independence criterion. The medium mesh (5.4M cells) is used for all production runs.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/vr-04-uq",
        "type": "UncertaintyQuantification",
        "method": "GCI-based discretization error estimate. Observed order of accuracy p = 1.94 (near second-order). GCI_fine = 0.9% for hemolysis index QoI.",
        "coverageProbability": 0.95
      }
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-05-blood-damage-model-sensitivity",
      "type": "ValidationResult",
      "name": "Blood damage model parameter sensitivity — power-law exponent",
      "description": "Sensitivity of predicted hemolysis index to the power-law exponent C and the shear stress exponent alpha in the Giersiepen-Wurzinger blood damage model. Latin hypercube sampling over published uncertainty ranges for both parameters. Results show hemolysis index varies by ±9% across the parameter space, within the acceptable range for MRL 2 comparative assessment."
    }
