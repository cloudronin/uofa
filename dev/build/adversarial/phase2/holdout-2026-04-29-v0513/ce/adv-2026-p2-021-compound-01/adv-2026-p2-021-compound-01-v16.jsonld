  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed per MRL 2 scoping guidance. Four validation results demonstrate adequate agreement between CFD predictions and experimental measurements across all five COU operating points. Hemolysis index predictions satisfy the RH < 1 acceptance criterion at all operating points. Grid convergence, turbulence model sensitivity, and boundary condition uncertainty have been quantified. The model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
