      "type": "ValidationResult",
      "name": "Mesh Independence and Discretization Error Validation",
      "description": "Three-level mesh refinement study conducted on the FDA generic centrifugal pump geometry. Richardson extrapolation applied to pressure rise and shear-stress-derived hemolysis index. Grid convergence index (GCI) reported as 3.2% for hemolysis index on the medium mesh selected for production runs. Discretization error is within the accepted threshold for MRL 2 assessments."
    },
    {
      "id": "https://uofa.net/morrison/validation/turbulence-model-verification",
      "type": "ValidationResult",
      "name": "Turbulence Model Code Verification — Benchmark Channel Flow",
      "description": "SST k-omega turbulence model implementation verified against the NASA turbulence modelling resource benchmark for fully-developed channel flow at Re=10,000. Velocity profiles and wall shear stress match reference data within 1.8%, confirming correct numerical implementation prior to pump-specific simulations.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/turbulence-verification-uq",
        "type": "UncertaintyQuantification",
        "method": "Comparison against analytical solution; numerical error quantified as L2-norm of velocity residuals across 5 grid levels.",
        "coverageProbability": 0.99
      }
    }
