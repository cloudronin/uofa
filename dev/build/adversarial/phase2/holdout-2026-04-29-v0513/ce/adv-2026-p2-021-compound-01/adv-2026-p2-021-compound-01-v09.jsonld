  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold a traceable software quality record including version control, regression testing, and documented release history consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 is used under a documented SQA plan. Version control records, regression test suite results, and release notes are archived in the project configuration management system. All SQA artefacts reviewed and approved by the project quality engineer prior to simulation execution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver implementation verified against at least one published benchmark with quantified numerical error below 5% for the primary quantity of interest.",
      "rationale": "SST k-omega implementation verified against NASA channel-flow benchmark (Re=10,000). L2-norm velocity error 1.8%, wall shear stress error 2.1%, both below the 5% threshold. Verification documented in validation result https://uofa.net/morrison/validation/turbulence-model-verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) for hemolysis index must be below 5% on the production mesh.",
      "rationale": "Three-mesh Richardson extrapolation yields GCI of 3.2% for the hemolysis index on the medium (12.4 M cell) production mesh. Fine-mesh GCI is 1.1%. Production mesh selected as optimal balance of accuracy and computational cost. Results documented in mesh independence validation result."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulated operating conditions within ±5% for flow rate and ±50 RPM for rotational speed.",
      "rationale": "In-vitro experiments conducted at five operating points (2–6 L/min, 2500–3500 RPM) using bovine blood at 37°C. Flow rate controlled to ±2% via Coriolis meter; rotational speed controlled to ±15 RPM via closed-loop motor controller. Temperature maintained at 37±0.5°C. All conditions within specified tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted RH index must agree with experimental RH within ±15% at all five operating points.",
      "rationale": "Point-by-point comparison of CFD versus in-vitro RH index shows maximum deviation of 11.4% at the 6 L/min / 2500 RPM operating point. All five points satisfy the ±15% criterion. Worst-case hemolysis correctly identified at 4 L/min / 3500 RPM in both CFD and experiment. Quantitative comparison tabulated in the primary validation result."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in simulation (hemolysis index derived from shear stress and exposure time) must be directly mappable to the clinical endpoint (plasma-free haemoglobin) used in the regulatory submission.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model maps CFD-computed shear stress and exposure time to a normalised index of red blood cell damage. The relative hemolysis index (RH) is the ratio of device-under-test to predicate device index, which is the metric reported in the 510(k) submission. Clinical relevance established through published correlation between RH and plasma-free haemoglobin in equivalent pump geometries."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue properties, and operating envelope as the COU simulations.",
      "rationale": "Validation experiments performed on the FDA generic centrifugal pump — the identical geometry used in COU simulations. Bovine blood at 37°C is the accepted analogue for human blood in hemolysis studies per ASTM F1841. Operating envelope (2–6 L/min, 2500–3500 RPM) spans the full COU operating range. Validation activities are therefore directly applicable to the COU without extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver residuals monitored to 1e-5 as standard practice.",
      "rationale": "Numerical solver error assessment is scoped out at MRL 2 for Class II devices with medium model influence. Residual convergence to 1e-5 confirmed for all production runs as a process control measure, but formal iterative error quantification is not mandated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation execution checklist applied as procedural control.",
      "rationale": "Formal use-error assessment not required at MRL 2. A documented simulation execution checklist — covering boundary condition entry, material property assignment, and post-processing steps — was completed and signed off by a second analyst for each production run, providing adequate procedural control."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; turbulence model selection justified by literature precedent.",
      "rationale": "Model form uncertainty assessment not mandated at MRL 2 for this COU. SST k-omega selected based on published literature consensus for rotating blood pump CFD (Hariharan et al., 2011; Malinauskas et al., 2017). Single turbulence model used throughout; sensitivity study not required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values sourced from traceable measurements.",
      "rationale": "Input uncertainty propagation not required at MRL 2. Geometric inputs derived from CMM measurements of the physical pump (±0.02 mm). Blood viscosity set to 0.0035 Pa·s per ASTM F1841. Density set to 1060 kg/m³. All nominal values traceable to calibrated instruments or published standards."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; single pump unit used for validation consistent with MRL 2 practice.",
      "rationale": "Sample-to-sample variability assessment not required at MRL 2. Validation experiments performed on a single precision-machined pump unit representative of nominal geometry. Unit-to-unit variability is addressed implicitly through the geometric tolerance sensitivity study in the COU simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; parameter equivalency confirmed qualitatively through operating condition matching.",
      "rationale": "Formal equivalency assessment not required at MRL 2. Qualitative review confirms that CFD boundary conditions (inlet flow rate, outlet pressure, rotational speed, fluid properties) match experimental conditions within the tolerances documented under the Test Conditions factor. No extrapolation beyond the validated operating envelope is performed."
    }
