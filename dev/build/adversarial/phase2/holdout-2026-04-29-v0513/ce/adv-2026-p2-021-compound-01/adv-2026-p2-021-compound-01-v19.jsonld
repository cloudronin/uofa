  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 4. Mean absolute relative error of 8.4% across five validation operating points is within the 15% acceptance criterion. RH < 1 confirmed at all operating points, supporting the regulatory submission decision. Residual model form uncertainty at high flow rates is documented and bounded within acceptable limits for the intended COU. The credibility evidence package is sufficient to support the Class II device 510(k) submission claim that the CFD model reliably identifies worst-case hemolysis operating conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
