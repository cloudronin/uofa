  "signature": "ed25519:b7d3a1f9c2e5b8d4a0f6c3e9b2d5a8f1c4e7b0d3a6f9c2e5b8d1a4f7c0e3b6d9",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented evidence of version control, regression testing, and release qualification for the CFD solver used in the analysis.",
      "rationale": "ANSYS Fluent 2023R1 is a commercially validated solver with documented SQA processes including ISO 9001 certification, regression test suite coverage reports, and formal release notes. Internal SQA checklist completed confirming solver version, license, and platform consistency across all simulation runs. Version locked at 2023R1 for the duration of the study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one analytical or highly accurate reference solution relevant to the flow physics of interest.",
      "rationale": "Verification performed against lid-driven cavity (Re=1000, Ghia et al. 1982) and Hagen-Poiseuille pipe flow benchmarks. Velocity profile RMS error < 1% and pressure drop error < 0.05% confirm correct implementation. See ValidationResult morrison-vr-003."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrating GCI < 5% for primary quantities of interest at the selected mesh density.",
      "rationale": "Three-level mesh refinement with GCI analysis per Celik et al. (2008). Fine-grid GCI = 1.3% for wall shear stress and 2.1% for hemolysis index. Medium mesh selected for production runs as the fine-grid GCI threshold is met. Asymptotic convergence confirmed. See ValidationResult morrison-vr-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented and shown to be representative of the COU operating envelope with deviations justified.",
      "rationale": "In-vitro experiments conducted at physiological temperature (37°C ± 0.5°C), with bovine blood at hematocrit 33 ± 2%. Flow rates and rotational speeds span the clinical CPB operating range (2–9 L/min, 2000–3500 RPM). Boundary conditions in CFD set to match measured inlet velocity profiles and outlet pressure. Minor deviations in fluid rheology between bovine and human blood documented and bounded via sensitivity analysis showing < 3% impact on NIH predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between CFD predictions and experimental measurements with mean absolute relative error < 15% across operating points.",
      "rationale": "CFD-predicted NIH compared to experimental measurements at 5 operating points. Mean absolute relative error = 8.4%, maximum error = 12.7% at the 9 L/min 2500 RPM point. All errors within the 15% acceptance criterion. RH < 1 confirmed at all points. Systematic overprediction at high flow rates attributed to turbulence model limitations, documented as model form uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, RH) are directly linked to the clinical decision criterion and regulatory acceptance threshold.",
      "rationale": "Normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the quantities of interest. NIH is the standard regulatory metric for blood pump hemolysis per ISO 10993-4 and FDA guidance. RH < 1 is the acceptance criterion for predicate device comparison. Both QoIs are directly computed from CFD shear stress and exposure time fields using the validated power-law damage model, ensuring direct relevance to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry and within the COU operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry — the same geometry used in the COU analysis. Operating conditions span the clinical CPB envelope. The validation dataset (Morrison et al. 2012) was generated specifically for this device class and represents the most relevant available experimental evidence. No geometric or operational extrapolation required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 given solver verification evidence already captured under Numerical code verification factor.",
      "rationale": "At MRL 2, separate assessment of numerical solver error beyond code verification benchmarks is not required. Iterative convergence residuals < 1e-6 monitored for all production runs. Round-off error negligible under double-precision arithmetic. This factor is scoped within the code verification evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU; analyst qualification documented separately.",
      "rationale": "Use error assessment not required at MRL 2 for Class II device with medium model influence. Lead analyst holds PhD in computational fluid dynamics with 8 years of blood pump CFD experience. Simulation setup reviewed by independent senior analyst. Formal use error assessment deferred per MRL 2 scoping decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions documented with justification for turbulence model and hemolysis damage model selection.",
      "rationale": "k-omega SST turbulence model selected based on superior near-wall performance and established use in blood pump CFD literature. Sensitivity analysis comparing SST vs. k-epsilon realizable shows < 5% variation in NIH predictions. Giersiepen-Wurzinger power-law hemolysis damage model selected as the regulatory standard; limitations at low shear stress acknowledged and bounded. Newtonian blood viscosity assumption validated for the shear rates present (> 100 s-1 throughout the pump)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs documented with sources, nominal values, and ranges; sensitivity of QoIs to input uncertainty assessed.",
      "rationale": "Material properties (blood density 1056 kg/m3, dynamic viscosity 0.0035 Pa·s at 37°C), boundary conditions (inlet velocity profiles from PIV measurements, outlet pressure from experimental data), and geometric parameters (nominal CAD dimensions with manufacturing tolerances ± 0.05 mm) all documented. One-at-a-time sensitivity analysis performed for viscosity (± 10%), inlet flow rate (± 5%), and rotational speed (± 2%). NIH sensitivity to viscosity is the dominant input uncertainty at 4.2% variation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; single device geometry assessed consistent with FDA benchmark study design.",
      "rationale": "Test sample variability assessment not required at MRL 2 for this COU. The FDA generic centrifugal pump is a standardized benchmark geometry without manufacturing variability by design. Device-to-device variability for the actual CPB device is addressed through the dimensional tolerance sensitivity analysis under Model inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency between validation and COU conditions addressed qualitatively under Relevance of validation activities.",
      "rationale": "Formal equivalency assessment not required at MRL 2. Qualitative assessment of boundary condition equivalency between validation experiments and COU operating conditions is documented under the Relevance of the validation activities factor. The validation operating envelope fully encompasses the COU operating range, providing direct evidence without extrapolation."
    }
