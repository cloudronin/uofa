  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-001-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — FDA generic centrifugal pump",
      "description": "Three-level mesh refinement study (coarse 2.1M, medium 4.8M, fine 9.6M elements) performed on the FDA generic centrifugal pump geometry at 2500 RPM and 6 L/min. Grid convergence index (GCI) computed per Celik et al. (2008). Fine-grid GCI for wall shear stress QoI is 1.3%, satisfying the MRL 2 threshold of < 5%. Hemolysis index predictions vary by less than 2.1% between medium and fine meshes, confirming discretization error is acceptably bounded.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-mesh-gci",
        "type": "UncertaintyQuantification",
        "method": "Grid Convergence Index (GCI)",
        "coverageProbability": 0.95,
        "description": "GCI-based discretization uncertainty estimated at 1.3% for wall shear stress and 2.1% for hemolysis index on the fine mesh. Roache extrapolation applied. Asymptotic range confirmed (GCI_fine/GCI_medium ratio = 1.02)."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-002-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis validation — 5-point operating map",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements at five flow-speed operating points (3 L/min 2000 RPM, 3 L/min 3500 RPM, 6 L/min 2500 RPM, 6 L/min 3500 RPM, 9 L/min 2500 RPM). Experimental data sourced from Morrison et al. (2012) FDA benchmark dataset. Mean absolute relative error across all five points is 8.4%, within the 15% acceptance criterion established for MRL 2. Relative hemolysis index RH < 1 confirmed at all operating points, supporting the worst-case identification decision. Turbulence model sensitivity (k-omega SST vs. k-epsilon realizable) assessed; SST selected based on superior near-wall resolution. Power-law hemolysis damage model (Giersiepen-Wurzinger coefficients) applied consistently."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-003-solver-verification",
      "type": "ValidationResult",
      "name": "Numerical solver verification — lid-driven cavity and pipe flow benchmarks",
      "description": "ANSYS Fluent 2023R1 verified against two canonical benchmarks: (1) lid-driven cavity at Re=1000 compared to Ghia et al. (1982) reference solution; centerline velocity profiles agree within 0.8% RMS. (2) Laminar pipe flow compared to Hagen-Poiseuille analytical solution; pressure drop error < 0.05%. Solver convergence criterion set to residual < 1e-6 for all equations. Double-precision arithmetic used throughout. These benchmarks confirm correct implementation of the Navier-Stokes solver for the viscous flow regime relevant to CPB hemolysis prediction.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-solver-verification",
        "type": "UncertaintyQuantification",
        "method": "Analytical benchmark comparison",
        "coverageProbability": 0.99,
        "description": "Solver numerical error bounded at < 1% for velocity fields in laminar regime benchmarks. Iterative convergence error < 0.01% based on residual monitoring. Round-off error negligible under double-precision arithmetic."
      }
    }
  ],
