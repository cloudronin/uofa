  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated code with documented QA procedures and version control. Regression test suite must cover rotating machinery flows.",
      "rationale": "ANSYS Fluent 2023 R1 was used. The solver carries FDA-recognized validation documentation and ISO 9001-compliant QA procedures. Version control was maintained via a locked simulation environment; all run scripts and boundary condition files are archived in the project repository. Regression tests covering MRF rotating frame and species transport were confirmed passing prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Observed order of accuracy within 10% of theoretical order for the governing equations relevant to the COU.",
      "rationale": "Method of manufactured solutions verification confirmed observed order 1.97 vs theoretical 2.0 (1.5% deviation), satisfying the acceptance criterion. Results are documented in ValidationResult vr/solver-verification-mms."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI on the selected mesh must be less than 5% for the hemolysis index QoI.",
      "rationale": "Three-level Richardson extrapolation yielded GCI of 3.2% on the medium (production) mesh of 6.8M cells. This satisfies the <5% criterion. Prism layer y+ values were maintained between 1 and 3 throughout the flow domain to ensure accurate near-wall shear stress resolution critical to hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions must replicate COU operating envelope within ±10% for flow rate and rotational speed. Blood analogue fluid properties must be documented.",
      "rationale": "Bench tests used a 36% glycerol-water blood analogue (viscosity 3.5 mPa·s at 37°C, density 1058 kg/m³) matching literature-reported human blood properties. Flow rates and RPM were controlled to within ±3% of target values using calibrated gear pumps and optical tachometry. Temperature was maintained at 37±0.5°C throughout all runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted RH must agree with measured RH within ±25% across all 5 operating points. Systematic bias must not exceed ±10%.",
      "rationale": "Maximum point-wise deviation was 17.8% at the 2.5 L/min / 3500 RPM operating point. Mean signed error across all 5 points was +4.2%, indicating a slight conservative over-prediction of hemolysis, which is acceptable for worst-case identification purposes. All points satisfied the ±25% envelope criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in the model (hemolysis index) must be directly mappable to the clinical endpoint (plasma-free hemoglobin elevation) and the regulatory acceptance criterion.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) are both derived from the Giersiepen power-law model, which is the FDA-recognized approach for computational hemolysis assessment in blood-contacting devices. RH < 1 directly maps to the predicate device comparison criterion specified in the 510(k) guidance. QoI relevance was rated one gradation above required due to the direct regulatory traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, the same fluid analogue, and operating conditions spanning the full COU envelope.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry (the same geometry as the COU model). The 5 flow-speed combinations tested in-vitro span the full operating envelope defined in the COU. No geometric simplifications were introduced between the validation and COU simulation configurations. Relevance is therefore rated as fully meeting the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, numerical solver error beyond discretization and code verification is not required to be separately quantified provided the solver is commercially validated.",
      "rationale": "Not assessed per MRL 2 scoping decision. The use of a commercially validated solver with documented verification (see Numerical code verification factor) satisfies the MRL 2 requirement without separate solver error quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 for a Class II device, use error assessment is not required provided standard simulation practice SOPs are followed.",
      "rationale": "Not assessed per MRL 2 scoping decision. All simulations were conducted following the organization's CFD SOP v4.2, which includes independent reviewer sign-off on boundary condition setup and post-processing scripts. This procedural control is deemed sufficient at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis model must be justified against published benchmarks for rotating blood-contacting devices.",
      "rationale": "The SST k-ω turbulence model was selected based on published benchmarks demonstrating superior near-wall shear stress accuracy for rotating machinery flows compared to k-ε variants. The Giersiepen power-law hemolysis model is the FDA-recognized standard for this device class. Model form uncertainty is acknowledged to be the dominant uncertainty source but is bounded by the ±18% validation agreement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, fluid properties, boundary conditions) must be traceable to measurement data or published literature with stated uncertainty.",
      "rationale": "Pump geometry was digitized from FDA-published CAD files (tolerance ±0.05 mm). Fluid properties were measured at the test facility (viscosity ±2%, density ±0.5%). Inlet velocity profiles were derived from Doppler ultrasound measurements of the bench test rig inlet. All inputs are tabulated in the simulation data package with traceability references."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal test sample characterization beyond standard fluid analogue preparation documentation is not required.",
      "rationale": "Not assessed per MRL 2 scoping decision. Blood analogue fluid was prepared per ASTM F1841 protocol. Batch preparation records are archived. No additional sample characterization is required at this model risk level."
    },
