      "id": "https://uofa.net/synth/validation/vr-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 3 L/min, 3000 RPM",
      "description": "Particle image velocimetry (PIV) measurements acquired in a refractive-index-matched acrylic pump model were compared against CFD-predicted velocity fields at the design operating point. Agreement within 8% RMS across the measurement plane was demonstrated. Uncertainty quantification for experimental measurement uncertainty and CFD numerical uncertainty was performed using GCI analysis on three mesh levels (coarse 1.2 M, medium 4.8 M, fine 19.2 M cells); GCI fine-grid index was 1.4% for mean velocity magnitude.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-piv-gci-uq",
        "type": "UncertaintyQuantification",
        "method": "Grid Convergence Index (GCI) per Roache 1998; experimental uncertainty per ASME PTC 19.1",
        "coverageProbability": 0.95,
        "expandedUncertainty": "8.2% RMS velocity magnitude at 95% confidence"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-rh-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index (RH) validation across 5 operating points",
      "description": "Predicted RH values derived from power-law hemolysis model (Giersiepen et al.) integrated along Lagrangian particle tracks were compared against in-vitro hemolysis measurements (modified ASTM F1841) at five flow-speed combinations spanning the clinical operating envelope. All five predicted RH values fell below the acceptance threshold of RH < 1 relative to the predicate device. Mean absolute error between predicted and measured normalised plasma-free haemoglobin rise was 11.3%. The hemolysis model coefficients were taken from published literature without re-calibration to the specific blood analogue used in the in-vitro experiments; this coefficient uncertainty was not formally propagated through the RH calculation."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-head-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-head HQ curve validation",
      "description": "Simulated pressure head across the pump was compared against bench-test measurements at seven flow rates from 2 to 6 L/min at 2500 RPM and 3500 RPM. Agreement within ±5% across all operating points was demonstrated. Uncertainty quantification applied Taylor-series propagation of transducer calibration uncertainty (±0.5 mmHg) and CFD discretisation uncertainty (GCI < 2.1%).",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-pressure-head-uq",
        "type": "UncertaintyQuantification",
        "method": "Taylor-series propagation combined with GCI for CFD numerical uncertainty",
        "coverageProbability": 0.95,
        "expandedUncertainty": "±5.3 mmHg at 95% confidence across HQ curve"
      }
    }
