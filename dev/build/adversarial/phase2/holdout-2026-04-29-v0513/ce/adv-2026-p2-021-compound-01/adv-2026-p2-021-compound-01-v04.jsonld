  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. Six factors are appropriately scoped out at MRL 2. The CFD model demonstrates sufficient credibility to support the regulatory submission claim that worst-case hemolysis operating conditions have been identified for the Class II CPB device. All predicted RH values are below the acceptance threshold of RH < 1 relative to the predicate device across the full clinical operating envelope. The assessment team accepts the model evidence as adequate for the stated context of use.",
