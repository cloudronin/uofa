    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (RH index) computed consistently between simulation and experiment; statistical agreement assessed via Bland-Altman analysis.",
      "rationale": "NIH computed from CFD using the Giersiepen-Wurzinger power-law model integrated along pathlines (10,000 particles per operating point). Bland-Altman analysis shows mean bias 0.021 NIH units, limits of agreement ±0.089 NIH units. No systematic trend with operating speed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, RH index, wall shear stress) are directly linked to the clinical endpoint (hemolysis) and regulatory acceptance criterion (RH < 1).",
      "rationale": "NIH is the FDA-accepted metric for pump-induced hemolysis per FDA guidance document (2017). RH index directly encodes comparison against predicate device. Wall shear stress is the primary mechanical driver of erythrocyte damage in the Giersiepen-Wurzinger model. All QoIs are clinically and regulatorily relevant."
    },
    {
