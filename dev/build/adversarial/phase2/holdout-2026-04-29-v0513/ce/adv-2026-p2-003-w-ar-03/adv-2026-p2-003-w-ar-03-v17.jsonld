  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. The validation evidence—drawn from a prospective observational registry study spanning all five COU operating points—demonstrates CFD-to-measurement agreement within the 15% acceptance band for relative hemolysis index, with RH < 1.0 satisfied in 46 of 47 clinical cases. The observational dataset provides comprehensive empirical coverage of the operating envelope, and its instrumentation rigor was judged by the assessment team to be equivalent in evidentiary quality to a controlled laboratory benchmark. Six factors were not assessed, consistent with MRL 2 scoping. The overall credibility body of evidence supports acceptance of the CFD model for identifying worst-case hemolysis operating conditions for the Class II CPB device submission.",
