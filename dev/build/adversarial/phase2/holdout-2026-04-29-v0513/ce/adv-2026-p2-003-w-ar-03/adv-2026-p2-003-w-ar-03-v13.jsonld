  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/dr-a-morrison",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet their required levels for MRL 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 1 scoping. NIH mean absolute error of 0.0031 g/100 L is below the 0.005 g/100 L threshold, and RH < 1.0 is satisfied at all five COU operating points. The multi-site hemolysis measurement campaign provides extensive quantitative comparison data across the full COU flow-speed envelope, and the companion mesh independence study confirms discretisation error is well controlled. The credibility body of evidence is judged sufficient to support regulatory submission of the CFD hemolysis model for the Class II CPB device.",
