      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RHI within 15% of measured RHI across all five operating points.",
      "rationale": "Maximum RHI prediction error across five flow-speed combinations was 11.7%. Mean absolute error was 7.4%. All five operating points satisfy the 15% acceptance criterion. Worst-case operating condition correctly identified by the CFD model (3500 RPM, 2 L/min)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (RHI) directly maps to the clinical hemolysis endpoint used in the regulatory submission.",
      "rationale": "Relative hemolysis index is the accepted surrogate for pump-induced hemolysis in 510(k) submissions per FDA guidance. The CFD model outputs volume-integrated shear exposure which is converted to RHI via the Giersiepen-Wurzinger power-law model. Direct correspondence between computational QoI and clinical endpoint is established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
