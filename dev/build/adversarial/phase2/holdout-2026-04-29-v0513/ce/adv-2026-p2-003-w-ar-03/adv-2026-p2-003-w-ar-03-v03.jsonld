  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2. The Morrison 2023 observational dataset provides extensive hemolysis measurements across the full COU operating envelope, and CFD predictions satisfy the RH < 1.0 acceptance criterion at all five worst-case operating points with mean absolute error of 8.4%. Discretization error is confirmed below budget. The overall body of evidence is judged sufficient to support the regulatory submission claim that the CFD model reliably identifies worst-case hemolysis operating conditions for the Class II CPB device.",
