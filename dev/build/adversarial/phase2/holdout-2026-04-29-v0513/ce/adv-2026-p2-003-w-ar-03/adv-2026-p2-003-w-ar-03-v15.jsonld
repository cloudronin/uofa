  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-rh-result-01",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison — five operating points",
      "description": "CFD-predicted normalised index of haemolysis (NIH) values were compared against experimentally obtained RH values across five flow-speed combinations (2 L/min at 2500 RPM, 3 L/min at 2800 RPM, 4 L/min at 3000 RPM, 5 L/min at 3200 RPM, 6 L/min at 3500 RPM). All CFD predictions satisfied RH < 1 relative to the predicate device. The experimental dataset was obtained by monitoring plasma free haemoglobin in circuits operated over 6-hour runs under standardised laboratory conditions; fluid temperature, anticoagulant (heparin) concentration, haematocrit, and circuit dead-volume were documented throughout. The team concluded that these laboratory measurements provided a rigorous empirical basis for model validation, fully satisfying the evidence requirements for the hemolysis credibility argument.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-hemolysis-invitro-obs-study",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "In-vitro hemolysis monitoring study — FDA generic centrifugal blood pump",
        "description": "Plasma free haemoglobin was sampled at 30-minute intervals from a closed-loop flow circuit over 6-hour runs at each of the five operating points. Circuit conditions (temperature 37 ± 0.5 °C, haematocrit 30 ± 2%, heparin 2 IU/mL) were recorded but not actively randomised or blinded; investigators selected operating points based on engineering judgment of likely worst-case conditions. No randomisation, no control arm, and no pre-registered hypothesis were employed. Data were post-processed to compute NIH per ASTM F1841."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-mesh-sensitivity-result",
      "type": "ValidationResult",
      "name": "Mesh independence and discretisation error quantification",
      "description": "Grid convergence index (GCI) was computed for three mesh refinement levels (coarse 2.1 M cells, medium 5.8 M cells, fine 14.3 M cells) using the Richardson extrapolation method. GCI for the fine-medium pair was 1.4% for volume-averaged shear stress, confirming mesh independence. Discretisation uncertainty was propagated to the NIH prediction yielding ±3.2% at 95% confidence.",
