  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-cpb-hemolysis-observational-01",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against clinical observational registry",
      "description": "CFD-predicted relative hemolysis index values at the five COU operating points were compared against plasma-free haemoglobin measurements recorded in the three-site observational registry. Agreement was assessed using Bland-Altman analysis; mean bias was 0.031 RH units (95% limits of agreement: −0.12 to +0.18). All five operating points satisfied RH < 1. The observational dataset provided 112 patient records spanning the full impeller-speed and flow-rate envelope, yielding high statistical power for the comparison. Reviewers concluded that the CFD model adequately captures the haemolytic response across the intended operating range.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-observational-study-2024",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "Three-site CPB observational registry data collection and analysis",
        "description": "Prospective observational registry at three clinical centres. Standard-of-care CPB procedures; no experimental manipulation of pump parameters. Plasma-free haemoglobin sampled at 30-minute intervals. 112 consecutive adult cases enrolled between January and September 2024.",
        "startedAtTime": "2024-01-10T07:00:00Z",
        "endedAtTime": "2024-09-30T18:00:00Z"
      },
      "meetsAcceptanceCriteria": true,
      "acceptanceCriteria": "Bland-Altman mean bias < 0.05 RH units; all COU operating points satisfy RH < 1."
    }
  ],
  "requirements": [
