  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 1. The CFD model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index criterion (RH < 1) is satisfied at all five COU operating points. The observational registry dataset provides broad clinical coverage and strong statistical support for the output comparison. The credibility assessment team unanimously accepts the model for the stated COU.",
