  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-verification-req-01",
    "type": "Requirement",
    "name": "Hemolysis validation evidence shall be derived from controlled experiments",
    "description": "Per the device submission plan and ASME V&V 40-2018 Table 3 guidance for MRL 2 Class II devices, validation of the hemolysis prediction model shall be supported by evidence generated through controlled experiments in which key input parameters (flow rate, rotational speed, fluid properties) are systematically varied under investigator-defined conditions to isolate model prediction error. Observational or registry data alone do not satisfy this requirement because confounding variation in clinical operating conditions cannot be fully characterised.",
