  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements for a Class II device. Predicted RH values remain below 1.0 at all five COU operating points. The validation evidence from the prospective observational registry is judged by the assessment team to provide sufficient confidence in model predictive capability, given the standardised measurement protocol and the overlap of clinical operating conditions with the COU envelope. The credibility package is accepted to support the regulatory submission.",
