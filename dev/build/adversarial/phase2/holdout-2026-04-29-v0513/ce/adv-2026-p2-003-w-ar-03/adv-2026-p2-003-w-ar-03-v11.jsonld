  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-val-result-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against clinical perfusion data",
      "description": "CFD-predicted relative hemolysis index (RH) values at five flow-speed operating points were compared against hemolysis measurements drawn from a prospective observational registry of 47 adult CPB procedures performed at two cardiac surgery centres. Predicted RH ranged from 0.61 to 0.94 across all operating points, remaining below the acceptance threshold of 1.0. The observational dataset captured pump flow rate, rotational speed, inlet haematocrit, and plasma-free haemoglobin before and after bypass, enabling direct comparison with CFD output quantities. The assessment team notes that the prospective logging protocol and standardised measurement procedures bring this dataset functionally close to a controlled experiment, supporting high confidence in the validation outcome.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-clinical-observational-study-01",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "Prospective observational registry of clinical CPB hemolysis",
        "description": "A prospective, multi-centre observational study in which 47 consecutive adult patients undergoing elective cardiac surgery with CPB were enrolled. Pump operating parameters and hemolysis biomarkers were recorded at standardised time-points under routine clinical care. No experimental manipulation of pump settings was performed; operating conditions were determined by perfusionist clinical judgement. Data were de-identified and archived for model comparison purposes.",
        "startedAtTime": "2023-03-01T00:00:00Z",
        "endedAtTime": "2024-06-30T00:00:00Z"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-val-result-02",
      "type": "ValidationResult",
      "name": "Grid-independence and iterative convergence confirmation",
      "description": "Three successively refined meshes (3.2 M, 7.8 M, and 16.4 M cells) were run at the nominal design point (5 L/min, 2800 rpm). The Richardson extrapolation-based Grid Convergence Index for the volume-averaged scalar stress was 1.4 % on the medium mesh, satisfying the ≤ 5 % acceptance criterion. Residuals converged to below 1 × 10⁻⁵ for all transport equations.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-mesh-convergence-study-01",
        "type": "Activity",
