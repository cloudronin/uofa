  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are appropriately scoped out under the MRL 2 factor matrix for a Class II device with medium model influence. The multi-site hemolysis observational campaign is judged to provide sufficient validation evidence for the relative hemolysis index across all five COU operating points. CFD-predicted RHI is below 1.0 at all operating points with maximum discrepancy of 8.3% against the clinical reference data, within the 15% acceptance threshold. The credibility package is accepted as supporting the regulatory submission for the FDA generic centrifugal blood pump under CPB conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-verification-req-01",
      "type": "Requirement",
      "name": "Hemolysis validation controlled-experiment requirement",
      "description": "The primary validation activity used to support the output-comparison credibility factor for hemolysis prediction shall be a controlled experiment in which operating conditions (flow rate, impeller speed, haematocrit, temperature) are systematically varied under investigator control with defined randomisation or blocking, enabling causal attribution of observed RHI differences to device geometry rather than confounding clinical variables.",
      "requiredVerificationMethod": "controlled-experiment"
    }
