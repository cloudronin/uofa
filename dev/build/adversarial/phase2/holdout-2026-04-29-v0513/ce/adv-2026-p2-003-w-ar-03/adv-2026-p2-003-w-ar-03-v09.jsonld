  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression test suite, and release notes for the version used in this assessment.",
      "rationale": "ANSYS Fluent 2022R2 was used under a validated installation with documented regression tests covering turbulent flow and scalar transport. Version control records and release notes were reviewed; no open defects affecting rotating machinery hemolysis simulations were identified. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least one published benchmark problem relevant to rotating machinery internal flow.",
      "rationale": "The solver was verified against the FDA benchmark nozzle problem (ASME V&V 40 Appendix B) and the rotating disk problem from the ERCOFTAC database. Both benchmarks confirmed correct implementation of the k-omega SST turbulence model and the power-law hemolysis transport scalar. Code verification is satisfied at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretisation error for the primary QoI (hemolysis index) must be below 5% on the production mesh.",
      "rationale": "Three-level mesh refinement study yielded GCI of 3.1% for the haemolysis index on the 14.2M-cell fine mesh. The medium mesh (5.8M cells) used for production runs exhibited GCI of 4.7%, within the 5% acceptance threshold. Discretisation error is assessed at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test conditions must span the five target flow-speed operating points defined in the COU, with blood temperature and haematocrit within ±10% of nominal CPB values.",
      "rationale": "The multi-site observational campaign recorded data at flow rates of 2.0, 2.5, 3.0, 4.0, and 5.0 L/min paired with impeller speeds of 1500–3500 RPM, covering all five COU operating points. Mean haematocrit across centres was 34.2% (nominal 35%), and blood temperature was maintained at 37 ± 0.5°C. The assessment team notes that the breadth of clinical sites provides coverage equivalent to a controlled experimental matrix, although the data were collected under routine clinical protocols without experimental randomisation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RHI must agree with measured RHI within 15% across all five operating points; systematic bias must be below 5%.",
      "rationale": "Point-by-point comparison of CFD-predicted versus observed RHI across the five operating points yielded a maximum absolute error of 8.3% and a mean signed bias of +2.1%, both within acceptance thresholds. The multi-site observational dataset was treated as the experimental reference; the assessment narrative explicitly states that the controlled-experiment verification requirement is met because the observational data were collected under standardised clinical monitoring protocols providing reproducible boundary conditions. Output comparison is assessed at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (RHI) must be directly linked to the clinical decision criterion and must be computable from CFD outputs without unvalidated post-processing transformations.",
      "rationale": "RHI is defined as the ratio of device-induced plasma-free haemoglobin to that of a predicate device under identical conditions, directly encoding the regulatory acceptance criterion. The Giersiepen power-law model applied to CFD shear-stress histories produces RHI without additional empirical scaling. Relevance of QoI is assessed at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, blood analogue properties, and operating envelope as the COU.",
      "rationale": "The multi-site observational campaign used the FDA generic centrifugal pump geometry in clinical service, with human blood at CPB haematocrit and temperature. All five COU operating points were represented in the dataset. The validation activities are judged highly relevant to the COU; the observational nature of data collection is not flagged as a departure from the controlled-experiment requirement stated in the governing requirement node."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error beyond discretisation error is not required to be separately assessed at MRL 2 for a Class II device with medium model influence. Scoped out of the present assessment in accordance with the MRL 2 factor matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at MRL 2 for this device class and model influence combination. The simulation was executed by an experienced CFD analyst following a documented simulation plan; no formal use-error assessment beyond this is required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The choice of turbulence closure and hemolysis transport model must be justified by published validation evidence for rotating blood-contacting devices.",
      "rationale": "The k-omega SST turbulence model and Giersiepen power-law hemolysis scalar have been validated for centrifugal blood pump geometries in multiple peer-reviewed studies (Taskin et al. 2012; Arvand et al. 2005; Fraser et al. 2011). Model form uncertainty is characterised as low for the operating range of interest. Model form is assessed at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood viscosity, density, and power-law hemolysis coefficients must be sourced from peer-reviewed literature and sensitivity-tested over their reported uncertainty ranges.",
      "rationale": "Casson model coefficients for human blood at 37°C and 35% haematocrit were taken from Merrill (1969). Giersiepen coefficients C=3.62×10⁻⁷, α=2.416, β=0.785 were used per standard practice. One-at-a-time sensitivity analysis showed RHI varies by less than 4% across the reported uncertainty ranges of all input parameters. Model inputs are assessed at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal test-sample characterisation (e.g., statistical sampling plan, sample-size justification) is not required at MRL 2 for this device class. The multi-site campaign provided n=47 patient circuits across five centres, which the assessment team considered adequate for the comparison without formal sample-size analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal equivalency mapping between simulation input parameters and physical test parameters is not required at MRL 2 for this device class and model influence level. Qualitative correspondence between CFD boundary conditions and clinical operating conditions was confirmed by the assessment team."
    }
