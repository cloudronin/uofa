  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-req-001",
    "type": "Requirement",
    "name": "Hemolysis validation verification requirement",
    "description": "Model predictions of the normalized index of hemolysis (NIH) and relative hemolysis index (RH) shall be verified against physical measurements obtained through a controlled experiment in which operating conditions (flow rate, rotational speed, fluid temperature, anticoagulant concentration) are independently manipulated and held constant to isolate causal effects on RBC damage. A controlled-experiment protocol is required to ensure confounding variables are systematically excluded and that the causal link between pump geometry variations and hemolysis outcomes can be unambiguously established.",
    "requiredVerificationMethod": "controlled-experiment",
    "acceptanceCriteria": "RH < 1.0 across all five flow-speed operating points; NIH within ±15% of bench reference values at each operating point."
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-vr-001",
      "type": "ValidationResult",
      "name": "Bench-top hemolysis observational corroboration — five operating points",
      "description": "CFD-predicted NIH values were compared against hemolysis measurements collected during a bench-top observational study of the FDA generic centrifugal blood pump. The observational study monitored plasma free hemoglobin (pfHb) accumulation in a closed recirculation loop under five clinically representative flow-speed combinations (2 L/min / 2000 RPM; 3 L/min / 2500 RPM; 4 L/min / 3000 RPM; 5 L/min / 3500 RPM; 6 L/min / 4000 RPM). Across all five conditions the computed RH remained below 1.0 (range 0.61–0.89) and NIH predictions agreed with observed values within ±11%, satisfying the acceptance criterion. The study team notes that the observational protocol captured natural operating variability in a clinical-simulation loop and that the breadth of conditions surveyed provides strong corroborative coverage. These results are considered sufficient to support model credibility at MRL 2.",
      "passed": true,
      "quantitativeResult": "RH range 0.61–0.89 (all < 1.0); NIH deviation ≤ 11% across 5 operating points",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-hemolysis-bench-obs-2024",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "FDA GCBP bench-top hemolysis observational study (2024)",
        "description": "A bench-top observational study conducted at the Morrison Cardiovascular Devices Laboratory in which the FDA generic centrifugal blood pump was operated in a closed-loop recirculation circuit filled with bovine blood (hematocrit 33 ± 2%). Plasma free hemoglobin was sampled at 30-minute intervals over a 6-hour run for each of five operating conditions. Pump speed and flow rate were set by the operator at the start of each run but were not actively manipulated as independent variables; ambient temperature, anticoagulant dose, and blood age were recorded but not controlled across runs. The study was designed to characterise real-world hemolysis trends rather than to isolate individual causal factors.",
        "startedAtTime": "2024-03-10T08:00:00Z",
        "endedAtTime": "2024-06-28T17:00:00Z",
        "wasAssociatedWith": "https://uofa.net/synth/org/morrison-cvd-lab"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-vr-002",
      "type": "ValidationResult",
      "name": "CFD mesh-independence and solver convergence validation",
      "description": "Grid convergence index (GCI) analysis was performed across three systematically refined meshes (coarse 4.2 M cells, medium 11.7 M cells, fine 28.4 M cells). The GCI for NIH at the worst-case operating point (6 L/min / 4000 RPM) was 2.3%, well within the 5% threshold. Solver residuals converged to below 1×10⁻⁵ for all transport equations. This internal verification result supports confidence in the numerical accuracy of the CFD predictions used in VR-001.",
      "passed": true,
      "quantitativeResult": "GCI = 2.3% at worst-case operating point; residuals < 1e-5",
      "wasGeneratedBy": {
