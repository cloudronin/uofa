    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison — CFD vs. clinical observational dataset",
      "description": "CFD-predicted relative hemolysis index (RHI) values for five flow-speed operating points were compared against RHI values extracted from a prospective clinical observational study of 47 CPB procedures at two cardiac surgery centres. The observational dataset captured pump inlet/outlet pressures, flow rates, and plasma-free haemoglobin samples at 30-minute intervals. Agreement between CFD and observed RHI was within ±12% across all operating points, with Bland-Altman limits of agreement of −0.09 to +0.11. The study authors note that patient haematocrit variability introduces scatter but does not systematically bias the comparison. On the basis of this agreement, the validation activity is judged to corroborate the CFD model's predictive capability for worst-case hemolysis identification.",
      "quantitativeMetric": "Bland-Altman limits of agreement: −0.09 to +0.11 RHI units; mean bias 0.01",
      "outcome": "Pass",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/cpb-clinical-obs-study",
