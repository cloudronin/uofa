        "activityType": "observational-study",
        "name": "Prospective clinical observational study of CPB hemolysis",
        "description": "A prospective, multi-centre observational study conducted across two cardiac surgery centres. Pump operating parameters and plasma-free haemoglobin were recorded during routine CPB procedures. No experimental intervention, randomisation, or controlled perturbation of operating conditions was performed. Data collection followed standard clinical monitoring protocols. The study was IRB-approved and conducted under a data-use agreement with the device manufacturer.",
        "startedAtTime": "2023-06-01T00:00:00Z",
        "endedAtTime": "2024-11-30T00:00:00Z",
        "wasAssociatedWith": "https://uofa.net/synth/org/morrison-lab"
      }
    }
