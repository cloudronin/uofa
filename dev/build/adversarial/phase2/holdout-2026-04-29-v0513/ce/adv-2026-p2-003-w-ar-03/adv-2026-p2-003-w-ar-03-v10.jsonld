  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-cou1-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are appropriately scoped as not-assessed per MRL 2 requirements. CFD-predicted RHI values satisfy the RH < 1 acceptance criterion at all five COU operating points, with mean absolute error of 7.3% against clinical registry reference data. The validation dataset, collected under a standardised multi-centre protocol with pre-specified outcome definitions, provides adequate reference evidence for output comparison at MRL 2. The assessment team concludes that the CFD model has sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device and that the COU decision may proceed.",
