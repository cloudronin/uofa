  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-req-01",
    "type": "Requirement",
    "name": "Hemolysis validation verification requirement",
    "description": "The hemolysis prediction model shall be validated against empirical hemolysis index data obtained under controlled experimental conditions. Verification of the model's predictive accuracy for RH across the five operating points shall be established through controlled-experiment activities in which pump speed, flow rate, and fluid properties are independently manipulated and hemolysis outcomes are directly measured with calibrated instruments under repeatable laboratory conditions.",
    "requiredVerificationMethod": "controlled-experiment",
    "acceptanceCriteria": "Predicted RH values must agree with measured values within 15% across all five operating points; RH < 1 relative to predicate device."
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-rh-multisite-01",
      "type": "ValidationResult",
      "name": "Multi-site hemolysis index validation — five operating points",
      "description": "Hemolysis index data were collected across five flow-speed combinations (2 L/min at 2000 RPM, 3 L/min at 2500 RPM, 4 L/min at 3000 RPM, 5 L/min at 3500 RPM, 6 L/min at 4000 RPM) from three clinical-adjacent sites operating FDA generic centrifugal blood pumps. The observational study enrolled 42 pump circuits over a six-month period, capturing RH values under routine perfusion conditions. CFD-predicted RH values agreed with the collected measurements within 11% across all operating points, and all predicted RH values remained below 1.0 relative to the predicate device. The breadth of the dataset — spanning multiple operators, two fluid formulations (bovine blood and validated blood analogue), and ambient temperature variation of ±3 °C — provides robust empirical grounding for the CFD hemolysis model. Agreement metrics, Bland-Altman plots, and residual analysis are documented in the supporting technical report TR-2025-HEM-07.",
      "quantitativeResult": "Mean absolute percentage error 8.3%; all five operating points RH < 1.0; Bland-Altman limits of agreement ±0.09 RH units.",
      "passFail": "Pass",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/multisite-hemolysis-data-collection",
        "type": "Activity",
        "activityType": "observational-study",
        "name": "Multi-site prospective hemolysis data collection study",
        "description": "Prospective observational data collection at three clinical perfusion sites. Pump circuits were monitored under standard-of-care operating protocols; no experimental manipulation of pump speed or flow rate was performed by the study team. Hemolysis index was measured from blood samples drawn at standardised intervals using a validated spectrophotometric assay. Site operators followed their institutional perfusion protocols, and environmental conditions were recorded but not controlled by the investigators.",
        "startedAtTime": "2024-06-01T00:00:00Z",
        "endedAtTime": "2024-12-15T00:00:00Z"
      }
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-mesh-sensitivity-02",
      "type": "ValidationResult",
      "name": "Mesh-independence and discretization error validation",
      "description": "Three mesh refinement levels (coarse 2.1M cells, medium 5.8M cells, fine 14.3M cells) were evaluated for the nominal geometry at the 4 L/min / 3000 RPM operating point. Richardson extrapolation yielded a grid convergence index (GCI) of 1.4% for predicted RH, confirming discretization error is well within the 5% threshold required at MRL 2.",
      "quantitativeResult": "GCI = 1.4%; fine-to-medium RH difference 0.6%.",
