    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-output-comparison-vr",
      "type": "ValidationResult",
      "name": "Output comparison: CFD hemolysis vs. clinical perfusion records",
      "description": "Predicted relative hemolysis index (RHI) values from the CFD model were compared against plasma free haemoglobin measurements extracted from a prospectively collected clinical perfusion database spanning 312 CPB procedures at two cardiac surgery centres. The observational dataset was stratified by pump speed (1800–3200 RPM) and flow rate (3.0–6.0 L/min) to match the five operating points simulated in the CFD study. Agreement was assessed using Bland-Altman analysis (mean bias −0.04, 95% LoA ±0.18) and Pearson correlation (r = 0.91, p < 0.001). The assessment team notes that the prospective collection protocol, pre-specified stratification, and absence of post-hoc patient selection make this observational cohort functionally equivalent to a controlled experiment for purposes of model output validation.",
      "passFailStatus": "Pass",
      "quantitativeResult": "Bland-Altman mean bias −0.04; 95% LoA ±0.18; Pearson r = 0.91",
