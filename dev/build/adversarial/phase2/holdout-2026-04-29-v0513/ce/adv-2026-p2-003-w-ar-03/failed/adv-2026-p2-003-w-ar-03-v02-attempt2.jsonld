  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40 Table 1 for a Class II device at MRL 2. The validation evidence, drawn from a multi-site clinical observational study encompassing 47 CPB circuits across five operating points, demonstrates that the CFD model predicts RH within the ±15% acceptance band at all conditions. The breadth and clinical realism of the observational dataset were considered by the assessment team to provide a rigorous and conservative basis for model acceptance, meeting the intent of the validation requirement. The overall credibility assessment supports use of the CFD model to identify worst-case hemolysis operating conditions for the Class II CPB device.",
