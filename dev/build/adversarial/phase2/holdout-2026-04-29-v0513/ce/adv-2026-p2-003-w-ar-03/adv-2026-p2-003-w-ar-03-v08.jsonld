  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately scoped as not-assessed per the MRL 2 requirements matrix. The primary validation evidence, drawn from the 2023 CPB patient registry, demonstrates mean relative error of 11.4% against CFD-predicted RH values across all five target operating points, with correct worst-case identification in 4 of 5 cases. The registry protocol imposed standardised pump operating parameters and measurement procedures, which the assessment team judges to provide a level of experimental control consistent with the validation requirements for this model risk level. The CFD model is assessed as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device under the stated COU.",
