    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/morrison/activity/grid-independence-verification",
    "type": "VerificationActivity",
    "name": "Grid independence and spatial discretization verification study",
    "description": "Systematic grid refinement study conducted on three structured hexahedral meshes (coarse: 1.2M cells, medium: 4.8M cells, fine: 19.2M cells) for the FDA generic centrifugal pump geometry. Richardson extrapolation applied to velocity profiles at five cross-sectional planes and to scalar shear stress distributions. Grid convergence index (GCI) computed for all quantities of interest. Study performed in ANSYS Fluent 2023R1 with double-precision solver and second-order spatial discretization. Convergence criterion set at GCI < 2% for primary hemolysis-relevant quantities.",
    "activityType": "GridRefinementStudy",
    "performedBy": "https://uofa.net/morrison/org/biofluid-sim-lab",
    "startedAtTime": "2025-09-10T08:00:00Z",
