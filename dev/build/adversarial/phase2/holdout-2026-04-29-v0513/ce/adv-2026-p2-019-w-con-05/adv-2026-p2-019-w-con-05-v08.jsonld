  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out per MRL 2 assessment plan. Validation evidence demonstrates NIH prediction error of 8.3% against FDA benchmark data, well within the 15% acceptance threshold. Discretization error (GCI 3.8%) and model form uncertainty (±15% NIH) are within acceptable bounds for the RH < 1 decision criterion with sufficient margin. The CFD model is assessed as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
