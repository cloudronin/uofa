  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. The six not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The CFD model demonstrates sufficient credibility to support the regulatory decision that the worst-case hemolysis operating condition (3 LPM / 3500 RPM) satisfies RH < 1 for the Class II CPB device. The power-law hemolysis methodology, whose theoretical basis is documented in the primary methods reference cited via referencesIdentifier, has been independently validated against FDA benchmark data. Assessment accepted.",
