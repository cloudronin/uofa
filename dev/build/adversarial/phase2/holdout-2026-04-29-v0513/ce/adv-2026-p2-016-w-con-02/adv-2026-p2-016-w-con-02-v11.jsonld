  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Discretization error exceeds required level (achieved Gradation 3 vs. required Gradation 2). Six factors not assessed are consistent with MRL 2 scoping for a Class II device with medium model influence. The hemolysis prediction methodology, supported by validation against FDA generic pump experimental data and referencing current best-practice hemolysis modeling literature including the power-law model parameter refinements reported in the methods literature (doi:10.1016/j.ymeth.2024.03.003), provides adequate credibility for the COU decision. RH < 1.0 demonstrated across all five CPB operating points. Assessment team unanimously accepts the model for COU1 use.",
    "decidedAt": "2026-04-19T00:00:00Z"
