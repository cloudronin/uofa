  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under documented version control with regression test suite demonstrating numerical stability across relevant flow regimes.",
      "rationale": "ANSYS Fluent 2023R2 was used under ISO 9001-compliant QMS. Solver version was locked and regression tests confirmed no drift in hemolysis scalar transport results across three patch releases. SQA documentation reviewed and approved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or benchmark comparison at Gradation 2.",
      "rationale": "Benchmark comparison against FDA nozzle and backward-facing step canonical cases confirmed correct implementation of k-omega SST turbulence model and scalar transport. Errors in velocity profiles were below 4% RMS relative to published DNS data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index must be less than 5% between medium and fine mesh solutions.",
      "rationale": "Richardson extrapolation applied to three mesh densities yielded GCI of 2.8% for the primary hemolysis QoI. Spatial order of convergence was 1.94, consistent with second-order discretization scheme employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions must replicate clinical CPB operating envelope within documented tolerances; blood analog fluid properties must be characterized.",
      "rationale": "Experiments conducted at 37°C using porcine blood with hematocrit 33±2%. Flow rates controlled to ±0.05 L/min; rotational speed to ±10 RPM. Test envelope spans 3–6 L/min and 2500–4000 RPM, covering the clinical CPB operating range for the target patient population."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index must agree with experimental RH within ±15% at all 5 operating points.",
      "rationale": "Agreement between CFD-predicted and experimentally measured RH ranged from 4.1% to 12.7% across all 5 operating points. Systematic over-prediction of 6–8% at high flow rates attributed to secondary flow effects captured by the model but partially attenuated in experiments due to inlet swirl damping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from CFD (hemolysis index, shear stress distribution) must directly map to the clinical endpoint (blood damage) with documented physiological basis.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) are established regulatory QoIs per FDA guidance and ASTM F1841. Shear stress thresholds used in the power-law damage model are grounded in erythrocyte fragility literature. QoI relevance is rated high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating conditions as the intended COU or demonstrate applicability via similarity analysis.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal blood pump — the identical geometry used in the COU. Fluid properties, rotational speeds, and flow rates matched COU conditions. No geometric scaling or fluid substitution was required, establishing direct relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
