  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors met or exceeded required levels for MRL 2. Six factors were accepted at Gradation 1 consistent with MRL 2 requirements and are not assessed. The CFD model demonstrates sufficient credibility to support regulatory submission for the Class II CPB device hemolysis tolerance decision. RH < 1.0 at all operating points confirms the device does not exceed predicate hemolysis levels. The hemolysis power-law methodology is further supported by the peer-reviewed validation framework cited in referencesIdentifier, which independently corroborates the damage accumulation approach used in this assessment.",
