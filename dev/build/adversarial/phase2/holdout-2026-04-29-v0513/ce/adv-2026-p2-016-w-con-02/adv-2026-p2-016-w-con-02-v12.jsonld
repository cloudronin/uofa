      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review of boundary condition setup and post-processing scripts.",
      "rationale": "At MRL 2 formal use-error assessment is not required. Internal peer review of simulation setup was conducted. Boundary conditions and post-processing scripts archived in version control. Factor accepted at Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for turbulence model and hemolysis damage model selection documented.",
      "rationale": "k-omega SST selected based on published performance for rotating machinery and transitional flows. Power-law hemolysis model (Giersiepen coefficients) is the de facto standard for blood pump CFD per regulatory precedent. Formal model-form uncertainty quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Material properties and boundary conditions sourced from traceable experimental measurements or published literature.",
      "rationale": "Blood viscosity (3.5 mPa·s) and density (1060 kg/m³) taken from standard physiological references. Inlet velocity profiles derived from Doppler ultrasound measurements. Input uncertainty propagation not required at MRL 2; nominal values used throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize biological variability in hemolysis measurements.",
      "rationale": "Three independent experimental runs performed per operating point using separate blood samples from different donors. Coefficient of variation in NIH across replicates was 8–14%, consistent with published biological variability for porcine blood. Formal statistical power analysis not required at MRL 2."
