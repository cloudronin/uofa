  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Hemolysis predictions are benchmarked against the power-law damage accumulation model described in the methodology survey indexed at https://doi.org/10.1016/j.ymeth.2024.03.003, which consolidates state-of-the-art RBC damage models for rotary blood pumps and provides the normative basis for the relative hemolysis index (RH) acceptance criterion adopted here.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "referencesIdentifier": "https://doi.org/10.1016/j.ymeth.2024.03.003",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-mrl2-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-rh-acceptance-claim-001",
  "bindsModel": "https://uofa.net/synth/model/fda-gcbp-cfd-hemolysis-v3",
