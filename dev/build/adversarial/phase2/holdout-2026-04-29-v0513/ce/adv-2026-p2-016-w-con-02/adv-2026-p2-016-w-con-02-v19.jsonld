  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-simulation-lab-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are appropriately scoped as not-assessed at MRL 2. The CFD model demonstrates sufficient credibility to support the regulatory decision regarding worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index predictions agree with experimental data within 9% across all validation operating points, satisfying the ±15% acceptance criterion. The assessment methodology follows ASME V&V 40-2018 and is consistent with FDA guidance on computational modeling for cardiovascular devices.",
