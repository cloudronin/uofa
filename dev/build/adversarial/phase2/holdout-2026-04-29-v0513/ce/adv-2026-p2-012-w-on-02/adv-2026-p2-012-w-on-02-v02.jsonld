  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates with blood at physiological temperature (36–38 °C) and inlet pressures ranging from 5 to 20 mmHg; outlet pressures span 60–120 mmHg, corresponding to typical CPB perfusion pressures. Flow rates are bounded between 2.0 and 6.0 L/min across five discrete flow-speed operating points. Fluid is treated as a Newtonian continuum at hematocrit 35–45 %. Reynolds numbers at the impeller tip range from approximately 8 000 to 22 000, placing all operating points in the turbulent regime. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-val-hemolysis-rh",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against FDA pump experimental data",
      "description": "CFD-predicted relative hemolysis index (RH) compared against in-vitro measurements from the FDA generic centrifugal pump benchmark. RH < 1 achieved at all 5 operating points; mean absolute error 0.07 RH units across the test matrix.",
      "outcome": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-val-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure rise validation",
      "description": "Simulated pump head compared against experimental head-flow curves at 2500 and 3500 RPM. Maximum deviation 4.2 % across the validated flow range, within the 5 % acceptance criterion.",
      "outcome": "Pass"
    }
  ],
