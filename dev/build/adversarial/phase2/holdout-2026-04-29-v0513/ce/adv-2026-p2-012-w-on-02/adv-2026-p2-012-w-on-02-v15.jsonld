      "acceptanceCriteria": "Documented simulation setup review by a second analyst.",
      "rationale": "Not assessed as a standalone factor at MRL 2. Simulation setup was reviewed informally by the project lead; formal independent review is not required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of turbulence model and hemolysis sub-model selection documented.",
      "rationale": "Not assessed as a separate credibility factor at MRL 2. The SST k-ω turbulence model and Giersiepen power-law hemolysis model were selected based on published literature for similar rotating blood-contacting devices; this justification is recorded in the simulation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Material properties and boundary conditions traceable to measurement or published reference values.",
      "rationale": "Not assessed as a standalone factor at MRL 2. Blood viscosity (3.5 mPa·s), density (1060 kg/m³), and power-law hemolysis coefficients are drawn from ISO 10993-4 guidance and published FDA benchmark documentation; traceability is noted in the simulation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental blood samples characterised for haematocrit and viscosity; batch variability documented.",
      "rationale": "Not assessed as a separate factor at MRL 2. FDA benchmark experimental reports document bovine blood haematocrit (40 ± 2%) and viscosity measurements; batch variability is within the uncertainty budget reported in the output comparison factor."
    },
