  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for Model Risk Level 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 4. Validation evidence demonstrates that the CFD model predicts hemolysis index within combined uncertainty across all five COU operating points, and the RH < 1 acceptance criterion is satisfied relative to the predicate device. The assessment team concludes that the model has sufficient credibility to support the intended regulatory decision for this Class II CPB device.",
