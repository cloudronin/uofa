  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented verification test suite and version-controlled input files sufficient for MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a validated QMS. Version control of case files and solver settings was maintained throughout the study. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, pipe flow) demonstrating correct implementation of governing equations.",
      "rationale": "ANSYS Fluent 2022 R2 code verification is documented by the vendor through NAFEMS and internal benchmark suites. Pipe-flow and rotating-frame benchmark results were independently reproduced and match analytical solutions within 0.3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "Three structured hexahedral meshes (4.2 M, 8.7 M, 17.1 M cells) were generated. Richardson extrapolation yielded GCI of 2.8% for the scalar stress-based hemolysis index at the worst-case operating point (2 L/min, 3500 rpm). Achieved level 3 exceeds the MRL 2 requirement of level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental conditions (fluid, rotational speed, flow rate) are documented and match simulation boundary conditions within stated measurement uncertainty.",
      "rationale": "FDA benchmark experiments used bovine blood at 37 °C, 2500 and 3500 rpm, and flow rates of 2, 4, and 6 L/min. Simulation boundary conditions were set to match reported values. Measurement uncertainty for flow rate (±0.05 L/min) and pressure (±1 mmHg) were incorporated into the uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated hemolysis index agrees with experimental measurements within combined experimental and numerical uncertainty at all five operating points.",
      "rationale": "Normalised index of hemolysis (NIH) predictions agree with FDA benchmark experimental values within 18% across all five operating points, within the combined uncertainty band (experimental CV ~15%, numerical GCI ~3%). RH < 1 criterion met at all points relative to predicate device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (scalar stress-based hemolysis index) is directly linked to the clinical endpoint (blood trauma) and the regulatory acceptance criterion (RH < 1).",
      "rationale": "The power-law hemolysis model (Giersiepen et al.) maps scalar stress exposure to red blood cell lysis fraction. The resulting NIH and RH metrics are directly used in 510(k) submissions for CPB devices. Clinical relevance is established through published correlation with in vivo haemolysis markers."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry (or geometrically similar predicate), equivalent fluid properties, and overlapping operating conditions as the COU.",
      "rationale": "The FDA generic centrifugal pump geometry used in validation is the same as the device geometry under assessment. Fluid (bovine blood, Newtonian approximation), rotational speeds, and flow rates span the COU operating space. Validation is therefore directly applicable to the intended COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iterative convergence to residuals below 1e-5 for all transport equations; mass imbalance < 0.01%.",
      "rationale": "Not assessed as a separate factor at MRL 2; iterative convergence monitoring is embedded within the discretization error assessment. Residuals confirmed below 1e-5 and mass imbalance < 0.005% as a quality check."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
