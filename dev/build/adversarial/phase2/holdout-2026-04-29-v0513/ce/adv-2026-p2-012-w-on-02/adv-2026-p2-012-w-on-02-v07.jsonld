  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates with blood at physiological temperature (36–38 °C), inlet pressures of 5–20 mmHg, outlet pressures of 250–450 mmHg, and volumetric flow rates of 2–6 L/min across five discrete speed settings (1500–3500 RPM). Flow regime is turbulent throughout the impeller passage (Re > 10,000). Fluid viscosity is modeled as Newtonian at 3.5 cP. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-hemolysis-rh-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against FDA pump experimental data",
      "description": "CFD-predicted relative hemolysis index (RH) compared against in-vitro measurements across 5 operating points. All predicted RH values within 15% of experimental mean; RH < 1 criterion satisfied at worst-case operating point (3500 RPM, 2 L/min)."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-velocity-field",
      "type": "ValidationResult",
      "name": "Velocity field comparison with PIV measurements",
      "description": "Particle image velocimetry (PIV) data acquired for the FDA generic centrifugal pump geometry. CFD velocity magnitude at mid-plane shows agreement within experimental uncertainty bands (±8%) across all measured locations."
    }
  ],
