  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented and version-controlled; basic regression tests passing.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional SQA plan. Version control via Git, regression suite executed prior to simulation campaign. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, pipe flow) to within 1% of analytical solution.",
      "rationale": "ANSYS Fluent code verification documented via vendor-supplied benchmark suite. Pipe Poiseuille flow and 3D lid-driven cavity results match analytical/reference solutions within 0.4%. Requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on three systematically refined meshes.",
      "rationale": "Three meshes (4.2M, 8.7M, 17.1M cells) generated with uniform refinement ratio ~1.38. GCI for scalar stress-based hemolysis index computed as 3.1% (fine-medium) and 4.8% (medium-coarse), both below 5% threshold. Richardson extrapolation applied; asymptotic convergence confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match simulation boundary conditions within stated tolerances.",
      "rationale": "In-vitro test loop operated at 37 °C ± 0.5 °C using porcine blood analog (glycerol-saline, viscosity 3.5 ± 0.1 cP). Flow rates set by Coriolis meter (±0.5% accuracy). Rotational speed controlled to ±10 RPM. Boundary condition correspondence documented in test report TR-2024-CPB-003."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted normalized index of hemolysis (NIH) within 20% of experimental NIH across all 5 operating points.",
      "rationale": "CFD NIH predictions compared against experimental values at all 5 operating points. Maximum deviation 11.4% at 3500 RPM / 2 L/min. Mean absolute error 7.2%. Achieved level 3 reflects quantitative agreement with uncertainty bounds reported. Acceptance criterion met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) is directly linked to the regulatory acceptance criterion and clinical endpoint.",
      "rationale": "RH index derived from Giersiepen power-law hemolysis model applied to Lagrangian particle tracks. RH directly maps to the 510(k) comparative hemolysis acceptance criterion (RH < 1 vs. predicate). QoI relevance confirmed by clinical and regulatory review team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on same geometry, fluid, and operating range as COU simulations.",
      "rationale": "Validation conducted on the FDA generic centrifugal pump geometry — identical to the device geometry used in COU simulations. Fluid analog, rotational speeds, and flow rates span the COU operating points. Validation relevance is high; no geometric or fluid extrapolation required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual drop of at least 4 orders of magnitude and stable QoI monitor.",
      "rationale": "All simulations run to residual convergence (continuity < 1e-5, momentum < 1e-6). NIH monitor flat over final 500 iterations (variation < 0.3%). Double-precision arithmetic used throughout. Solver error contribution assessed as negligible relative to discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions and material properties verified against test report.",
      "rationale": "Independent peer review of simulation setup performed by senior CFD engineer not involved in original setup. Boundary conditions, turbulence model selection (SST k-omega), and hemolysis model parameters verified against TR-2024-CPB-003. No discrepancies found."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; documented rationale for scoping decision sufficient.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis constitutive law) not formally quantified at MRL 2. SST k-omega selected based on published literature consensus for internal rotating flows. Giersiepen hemolysis model widely used for comparative CPB assessments. Formal model form assessment deferred per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values used with sensitivity check on key parameters.",
      "rationale": "Nominal blood analog viscosity and density used as deterministic inputs. Informal sensitivity analysis (±10% viscosity) showed < 2% change in NIH at worst-case operating point. Formal uncertainty propagation not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample representativeness addressed qualitatively.",
      "rationale": "Single pump specimen used for validation testing, consistent with FDA pump benchmark protocol. Sample-to-sample variability not characterized at MRL 2. Specimen confirmed to be within dimensional tolerances of nominal CAD geometry (CMM report CMM-2024-007)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of experimental to simulation inputs documented.",
      "rationale": "Equivalency between experimental inlet velocity profiles and CFD uniform inlet boundary condition assessed qualitatively. Inlet development length in test loop (> 20D) ensures near-uniform profile. Formal equivalency quantification deferred per MRL 2 scoping decision."
    }
  ],
