  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates with blood at physiological temperature (36–38 °C), inlet pressures of 5–20 mmHg, outlet pressures of 60–120 mmHg, flow rates spanning 2–6 L/min across five discrete flow-speed combinations (2500–4500 RPM), and a laminar-to-transitional flow regime (Reynolds numbers 800–3500 at the impeller inlet). Fluid viscosity is modeled as non-Newtonian using the Carreau model calibrated to human whole blood at 37 °C and 40% haematocrit. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr-001",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison — CFD vs experimental (FDA pump benchmark)",
      "description": "Normalized index of hemolysis (NIH) predicted by CFD compared against in-vitro measurements across all 5 flow-speed operating points. RH < 1 satisfied at all points; mean relative error 8.3%."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr-002",
      "type": "ValidationResult",
      "name": "Pressure-rise characteristic validation — CFD vs pump curve data",
      "description": "Simulated head-flow curve compared against manufacturer pump curve data at 3000 and 4000 RPM. Agreement within 5% across the 2–6 L/min flow range confirms fluid dynamic fidelity prior to hemolysis post-processing."
    }
  ],
