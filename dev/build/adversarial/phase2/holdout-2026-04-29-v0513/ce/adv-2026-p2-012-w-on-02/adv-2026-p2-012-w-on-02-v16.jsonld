  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates with blood at physiological temperature (36–38 °C), inlet pressures of 5–20 mmHg, outlet pressures of 250–500 mmHg, flow rates spanning 2–7 L/min, and impeller speeds of 1500–3500 RPM. Flow regime is assumed fully turbulent (Re > 10,000) throughout the operating range. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-val-result-001",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against in-vitro experimental data at 5 operating points",
      "description": "Relative hemolysis index (RHI) predicted by the CFD model was compared against in-vitro experimental measurements at 5 flow-speed combinations. RHI predictions fell within ±15% of experimental values at all operating points; worst-case RHI remained below unity, satisfying the acceptance criterion."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-val-result-002",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification for pump CFD domain",
      "description": "Grid convergence index (GCI) study performed on three systematically refined meshes (3.2M, 8.1M, and 18.4M elements). GCI for hemolysis-relevant wall shear stress was 2.3%, confirming adequate spatial resolution for the medium mesh used in production runs."
    }
  ],
