      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verified against at least one benchmark problem relevant to rotating machinery hemolysis simulation.",
      "rationale": "SST k-omega turbulence model and scalar transport equation (power-law hemolysis model) verified against analytical Couette flow solution and published NASA turbulence validation cases. L2 norm residuals below 1e-6. Exceeds MRL 2 minimum requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
