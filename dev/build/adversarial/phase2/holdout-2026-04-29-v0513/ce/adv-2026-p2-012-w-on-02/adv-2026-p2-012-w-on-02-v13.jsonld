  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates with blood at physiological temperature (37 ± 1 °C), inlet pressures ranging from 5 to 20 mmHg, outlet pressures from 60 to 120 mmHg, rotational speeds from 2000 to 3500 RPM, and volumetric flow rates from 2 to 6 L/min, spanning laminar-to-transitional flow regimes (Re 200–2400). Haematocrit is assumed at 35–45%. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/rh-index-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against experimental predicate data",
      "description": "CFD-predicted relative hemolysis index (RH) compared against in-vitro measurements for 5 flow-speed operating points. All predicted RH values within 15% of experimental reference; mean absolute error 0.08 RH units. Acceptance criterion RH < 1 satisfied at all operating points."
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification",
      "description": "Grid convergence index (GCI) computed across three mesh refinement levels (1.2M, 4.8M, 19.2M elements). GCI for shear stress QoI < 3.2% on fine mesh. Asymptotic convergence ratio 0.98 confirms solution in convergent regime."
    },
    {
      "id": "https://uofa.net/morrison/validation/turbulence-model-verification",
      "type": "ValidationResult",
      "name": "Turbulence model code verification against analytical Couette solution",
      "description": "SST k-omega implementation verified against analytical Couette flow solution and NASA turbulence validation cases. L2 norm residuals below 1e-6 at convergence. No code defects identified."
    }
  ],
