  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version control meets MRL 2 requirement.",
      "rationale": "ANSYS Fluent 2021 R2 was used under an institutional software QA plan. Release notes, validation benchmarks, and change logs are maintained by the vendor. Version control of all case files was enforced via institutional repository. Achieved level 2 exceeds required level 1 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark verification cases relevant to rotating turbomachinery flows.",
      "rationale": "ANSYS Fluent has been verified against the ASME V&V 20 lid-driven cavity and backward-facing step benchmarks. Vendor-supplied verification documentation confirms second-order spatial accuracy for the pressure-velocity coupling scheme used in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index and pressure rise QoIs.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 4.2 M, 8.7 M, and 17.1 M cells. Richardson extrapolation yielded GCI values of 3.1% for the relative hemolysis index and 2.4% for the pressure rise, both below the 5% threshold. The medium mesh (8.7 M cells) was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are documented and match the intended CFD boundary conditions within specified tolerances.",
      "rationale": "FDA benchmark experimental data were collected under controlled laboratory conditions with inlet flow rates measured to ±0.05 L/min and rotational speed controlled to ±10 RPM. Fluid temperature was maintained at 37 °C ± 0.5 °C using a recirculating bath. All five flow-speed operating points used in the CFD study were reproduced in the experimental protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index RH agrees with experimental values within 15% across all operating points.",
      "rationale": "Across all five flow-speed combinations, the CFD-predicted RH values deviated from experimental measurements by 4.2–12.8%, with a root-mean-square error of 8.3%. All predictions satisfied the RH < 1 acceptance criterion consistent with the predicate device comparison. The output comparison is judged sufficient for MRL 2 decision support."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to the decision: relative hemolysis index and pump pressure rise are the primary regulatory endpoints.",
      "rationale": "The relative hemolysis index RH and pump pressure rise ΔP are the quantities of interest directly linked to the regulatory decision. RH is the accepted surrogate for blood damage in CPB device submissions. Shear stress distributions were also extracted as secondary QoIs to support mechanistic interpretation of hemolysis hotspots."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use geometry, fluid properties, and operating conditions representative of the CPB COU.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry, bovine blood analog fluid (glycerin-water mixture at matched viscosity), and operating conditions spanning the full CPB flow-speed envelope. The validation domain is judged sufficiently representative of the COU to support a medium-confidence credibility determination."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below solver default thresholds is sufficient at MRL 2.",
      "rationale": "At MRL 2, formal quantification of numerical solver error beyond iterative convergence monitoring is not required. Residuals for continuity, momentum, and turbulence equations were converged to 1×10⁻⁵. No assessment beyond standard convergence monitoring was performed; this is acceptable for the assigned model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Standard institutional review of simulation setup by a second analyst is sufficient at MRL 2.",
      "rationale": "At MRL 2, a formal use error analysis is not required. The simulation setup was reviewed by a second CFD analyst who confirmed boundary condition assignments, material property inputs, and solver settings. No additional use error quantification was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Selection of turbulence model and hemolysis power-law model is documented with literature justification at MRL 2.",
      "rationale": "The SST k-ω turbulence model was selected based on its established performance for rotating machinery flows in the literature. The Giersiepen-Wurzinger power-law hemolysis model was adopted as the field standard for CFD hemolysis prediction. Formal model form uncertainty quantification is not required at MRL 2; literature-based justification is deemed sufficient."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters are sourced from published literature or direct measurement; uncertainty in inputs need not be formally propagated at MRL 2.",
      "rationale": "Blood viscosity was assigned as 0.0035 Pa·s based on published rheological data for human blood under high-shear conditions. Pump geometry was reconstructed from FDA-published CAD files. Inlet velocity profiles were derived from Womersley flow approximations. Formal uncertainty propagation through model inputs is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used in validation are documented; statistical characterization of sample variability is not required at MRL 2.",
      "rationale": "The FDA benchmark experimental dataset was generated using a single pump unit with bovine blood analog fluid. Sample-to-sample variability across multiple pump units was not characterized, which is acceptable at MRL 2. The single-unit dataset is considered representative for the purposes of this credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative mapping of experimental input parameters to CFD boundary conditions is documented at MRL 2.",
      "rationale": "A qualitative parameter equivalency table was prepared mapping experimental measurements (flow rate, rotational speed, fluid viscosity, temperature) to corresponding CFD boundary conditions and material property assignments. Formal equivalency scoring is not required at MRL 2; the qualitative mapping is judged sufficient."
    }
