      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified under a documented SQA plan covering version control, regression testing, and documented release notes.",
      "rationale": "ANSYS Fluent 2021 R2 is used under a validated SQA framework. Version control, regression test suite results, and release documentation are archived. Achieved level 2 meets the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions.",
      "rationale": "Code verification performed using the lid-driven cavity benchmark and Poiseuille flow. Observed order of accuracy consistent with theoretical second-order spatial discretization. Achieved level 2 satisfies MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed across at least three mesh refinement levels; GCI on QoI must be below 5%.",
      "rationale": "Three mesh levels (3.2M, 6.8M, 14.1M cells) were evaluated. GCI on normalized index of hemolysis was 3.1% between medium and fine meshes. Medium mesh selected for production runs. Achieved level 2 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to allow direct mapping to simulation boundary conditions.",
      "rationale": "FDA pump experimental protocol specifies inlet/outlet pressures, flow rates, blood analog fluid properties, and rotational speed for each of the 5 operating points. All boundary conditions are traceable to published FDA dataset. Achieved level 2 meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental values within 20% across all 5 operating points.",
      "rationale": "Predicted NIH values compared against FDA experimental data at all 5 flow-speed combinations. Maximum deviation was 14.8%; mean absolute error was 9.2%. Acceptance criterion met at all operating points. Achieved level 2 satisfies requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH, RH) must be directly linked to the clinical endpoint of hemolysis risk in CPB patients.",
      "rationale": "Normalized index of hemolysis and relative hemolysis index are established QoIs in FDA guidance for blood-contacting devices. Both are directly linked to clinical hemolysis risk. Achieved level 2 meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
