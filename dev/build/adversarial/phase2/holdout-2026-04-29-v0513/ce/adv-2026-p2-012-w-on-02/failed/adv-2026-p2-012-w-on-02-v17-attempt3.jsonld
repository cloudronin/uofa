  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates at blood temperatures between 28 °C and 37 °C, inlet pressures ranging from 5 mmHg to 20 mmHg, outlet pressures from 60 mmHg to 120 mmHg, and flow rates spanning 2.0 L/min to 6.0 L/min at rotational speeds of 2000 RPM to 3500 RPM. Blood viscosity is treated as Newtonian at 0.0035 Pa·s; Reynolds numbers fall in the laminar-to-transitional regime (Re 200–1800). Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-benchmark-val-001",
      "type": "ValidationResult",
      "name": "FDA benchmark pump hemolysis validation — 5-point flow-speed sweep",
      "description": "CFD-predicted relative hemolysis index compared against experimental measurements from the FDA generic centrifugal blood pump benchmark dataset across 5 flow-speed operating points. RH values within ±15% of experimental mean for 4 of 5 points; worst-case deviation 18% at lowest flow condition."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence-val-002",
      "type": "ValidationResult",
      "name": "Mesh convergence validation — discretization error quantification",
      "description": "Richardson extrapolation applied across three mesh densities (2.1M, 5.8M, 14.2M cells). Grid convergence index (GCI) for shear-stress-derived hemolysis metric: 3.2% on fine mesh, confirming acceptable discretization error at MRL 2."
    }
  ],
