  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. The pump operates across a blood temperature range of 20–37 °C, inlet pressures of 5–40 mmHg, outlet pressures of 200–700 mmHg, and flow rates of 2–7 L/min spanning laminar-to-turbulent transitional regimes (Reynolds numbers 800–12000). Rotational speeds range from 1500 to 4000 RPM. Blood viscosity is modelled as a Newtonian fluid at a nominal haematocrit of 35%. These operating characteristics are described in the simulation protocol and replicated in the validation experiments. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr-001",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against in-vitro measurements for the FDA generic centrifugal pump across 5 operating points. Mean relative error 8.3%, all predictions within experimental uncertainty bounds. RH < 1 criterion satisfied at all operating points."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr-002",
      "type": "ValidationResult",
      "name": "Mesh independence and discretization error assessment",
      "description": "Grid convergence index (GCI) computed using three mesh refinement levels (2.1M, 6.4M, 18.7M cells). GCI fine < 1.2% for NIH quantity of interest. Richardson extrapolation confirms discretization error within acceptable bounds for MRL 2."
    }
  ],
