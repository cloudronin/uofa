  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. Blood temperature is maintained in the physiological range of 35–37 °C; inlet pressure varies between 5 and 20 mmHg; outlet pressure between 60 and 120 mmHg; flow rates span 2–6 L/min; impeller rotational speeds range from 2000 to 3500 RPM; flow regime is turbulent (Reynolds numbers 3000–15000) with non-Newtonian blood viscosity modelled via the Carreau–Yasuda constitutive relation. Haematocrit is fixed at 35 ± 5%.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-bench-comparison-001",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis comparison against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements from the FDA generic centrifugal blood pump benchmark. Relative hemolysis index RH < 1 satisfied across all 5 operating points. Mean absolute error in NIH: 8.3%."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence-001",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error assessment",
      "description": "Grid convergence index (GCI) computed for three mesh refinement levels (coarse 2.1M, medium 5.4M, fine 11.8M elements). GCI for shear-stress-derived hemolysis index < 3.2% at fine mesh. Richardson extrapolation confirms asymptotic convergence."
    }
  ],
