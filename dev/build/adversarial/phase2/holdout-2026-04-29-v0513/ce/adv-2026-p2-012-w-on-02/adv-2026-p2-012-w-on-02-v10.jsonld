  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented with version control and regression testing at Gradation 1 or higher for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated installation qualification (IQ/OQ) protocol. Version control is maintained in the project repository. Regression test suite passes for all hemolysis-relevant turbulence and transport solver modules. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via manufactured solution or benchmark comparison at Gradation 1.",
      "rationale": "Code verification was performed using the method of manufactured solutions for the Navier-Stokes solver and the power-law hemolysis transport equation. Results confirm spatial order of accuracy consistent with second-order finite-volume discretization. Benchmark comparison against FDA nozzle dataset further corroborates solver correctness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error for hemolysis QoI must be quantified and shown to be below 10% of the acceptance threshold at Gradation 2.",
      "rationale": "A three-level mesh refinement study (coarse: 4.2M cells, medium: 11.7M cells, fine: 28.4M cells) was conducted at the design operating point (3000 RPM, 4 L/min). Richardson extrapolation yields a grid convergence index (GCI) of 2.3% for the normalized index of hemolysis (NIH), well within the 10% criterion. Discretization error is formally bounded and reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and shown to correspond to at least two of the five modeled operating points.",
      "rationale": "Experimental hemolysis data from the FDA generic centrifugal pump study (Hariharan et al.) cover three of the five modeled flow-speed combinations. Inlet and outlet pressure boundary conditions, hematocrit, and temperature were matched to experimental protocols. Test condition correspondence is documented in the validation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized error, E-value) must be computed and shown to meet acceptance threshold for hemolysis QoI.",
      "rationale": "Predicted NIH values were compared against experimental measurements at three operating points. The normalized hemolysis error is below 15% at all validated conditions. The relative hemolysis index RH < 1 criterion is satisfied at all five modeled operating points relative to the predicate device, confirming output comparison acceptance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis and relative hemolysis index) must be directly linked to the clinical decision criterion.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which maps directly to the regulatory acceptance criterion RH < 1 relative to the predicate device. Secondary QoIs include shear stress distribution and exposure time histograms, which are mechanistically linked to red blood cell damage. QoI relevance is fully justified in the credibility assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same pump geometry family, fluid (blood analog or blood), and hemolysis mechanism as the COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which shares the same impeller-volute topology as the target CPB device. Blood analog fluid (glycerin-water, matched viscosity) and ovine blood were both used in experimental campaigns. The hemolysis mechanism (shear-induced RBC damage) is identical to the COU. Validation activity relevance is rated high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations.",
      "rationale": "All simulations were run to residual convergence below 1e-6 for continuity, momentum, and species transport. Mass imbalance across inlet and outlet boundaries is below 0.01%. Solver error contribution to total numerical error is negligible relative to discretization error and is formally documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by a second analyst for boundary condition, material property, and solver setting correctness.",
      "rationale": "An independent peer review of the simulation setup was conducted by a senior CFD analyst not involved in the original model construction. Boundary conditions, material properties (non-Newtonian viscosity model, RBC damage model constants), and solver settings were verified against the validated simulation protocol. No discrepancies were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis power-law model need not be formally quantified at MRL 2; qualitative justification is sufficient.",
      "rationale": "At MRL 2, formal model form uncertainty quantification is not required. The Giersiepen-Wurzinger power-law hemolysis model is the industry-standard approach for CFD hemolysis prediction and is widely cited in FDA guidance. Model form limitations are acknowledged qualitatively in the assessment documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter sensitivity need not be formally characterized at MRL 2; nominal values with documented sources are sufficient.",
      "rationale": "All model inputs (blood viscosity, density, RBC damage model constants, pump geometry dimensions) are taken from peer-reviewed literature and manufacturer specifications. Formal uncertainty propagation is not required at MRL 2. Input values and their sources are tabulated in the simulation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of biological variability in test blood samples is not required at MRL 2.",
      "rationale": "The validation dataset uses pooled ovine blood with hematocrit controlled to 35 ± 2%. Donor-to-donor variability is not formally characterized, which is acceptable at MRL 2. The experimental protocol is consistent with ASTM F1841 guidance for hemolysis testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation and COU input parameters is not required at MRL 2; qualitative correspondence is sufficient.",
      "rationale": "The validation experiments were conducted under conditions qualitatively representative of CPB operating ranges. Formal parameter equivalency metrics are not required at MRL 2. The assessment team has documented the correspondence between validation test conditions and the five modeled COU operating points in a traceability matrix."
    }
  ],
