  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40-2018 Table 4 for Model Risk Level 2. The relative hemolysis index RH < 1 acceptance criterion is satisfied at all five modeled operating points. The CFD model is accepted as credible for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
