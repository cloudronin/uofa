  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Pressure-rise and velocity-field validation results include structured uncertainty quantification confirming aleatory and epistemic contributions are within acceptable bounds. The relative hemolysis index validation result satisfies the RH < 1 acceptance criterion at all five COU operating points. Although biological variability in the hemolysis assay was characterised qualitatively rather than through a formal probabilistic UQ framework, the conservative acceptance criterion and multi-session repeatability provide sufficient confidence for a Medium assurance level decision. The six non-assessed factors are appropriately scoped out at MRL 2. Overall credibility is sufficient to support the COU decision.",
