  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-01-pump-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation against experimental measurements",
      "description": "CFD-predicted pressure rise at five flow-speed operating points compared against in-vitro measurements from the FDA benchmark dataset. Agreement within 8% across all operating points; systematic bias corrected via turbulence model recalibration.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-01-pressure-rise-combined"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-02-velocity-field",
      "type": "ValidationResult",
      "name": "Impeller passage velocity field validation via PIV",
      "description": "Particle image velocimetry data from three impeller passage planes compared against CFD velocity magnitude contours. Mean absolute error below 5% of tip speed; shear stress distribution shows qualitative agreement with measurement uncertainty bands.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-02-velocity-field-combined"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-03-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against predicate device data",
      "description": "Predicted normalized index of hemolysis (NIH) compared against published in-vitro hemolysis measurements for the FDA generic pump geometry at three operating conditions. The inherent variability in biological blood samples and inter-laboratory hemolysis measurement protocols was assessed qualitatively by subject-matter experts; no structured probabilistic UQ was performed for this result. Point-estimate predictions fall within the reported experimental spread for all three conditions, and the RH index remains below 1.0 at worst-case flow-speed combinations."
    }
  ],
