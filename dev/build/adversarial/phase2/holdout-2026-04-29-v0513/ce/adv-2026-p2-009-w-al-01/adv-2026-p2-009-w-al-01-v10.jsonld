  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped to not-assessed at MRL 2. Validation evidence demonstrates CFD model is fit for purpose to identify worst-case hemolysis operating conditions with RH < 1 across the COU envelope. Aleatory uncertainty in biological hemolysis measurements was noted qualitatively by reviewers but structured probabilistic UQ was not completed for the hemolysis index validation result; this is considered acceptable under MRL 2 given the conservative point-estimate predictions and confirmation by experimental spread. Overall credibility assessment supports regulatory submission for Class II CPB device.",
