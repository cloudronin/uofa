      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with at least three systematically refined meshes; GCI below 5% for hemolysis-relevant QoIs.",
      "rationale": "Three-level mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.3M cells) performed at nominal operating point. Richardson extrapolation yields GCI of 3.2% for NIH and 2.7% for pressure rise. Fine mesh selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce boundary conditions in the CFD model, including fluid properties, rotational speed, and flow rates.",
      "rationale": "FDA benchmark experimental protocol specifies inlet flow rates (2–6 L/min), rotational speeds (2000–3500 RPM), and blood analog fluid properties (glycerol-water, viscosity 3.5 mPa·s) with calibrated instrumentation. All boundary conditions reproduced in CFD setup with documented traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) computed between CFD predictions and experimental data for primary QoIs; metric must demonstrate agreement within acceptance band.",
      "rationale": "Validation metric M computed per ASME V&V 20 framework for pressure rise and NIH across all operating points. Maximum M value of 0.87 (scale 0–1, higher is better) achieved for pressure rise; NIH metric M of 0.74 considered acceptable given experimental scatter in hemolysis measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
