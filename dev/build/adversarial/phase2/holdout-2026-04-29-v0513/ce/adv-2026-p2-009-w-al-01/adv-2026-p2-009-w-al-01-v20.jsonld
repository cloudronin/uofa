    "https://uofa.net/synth/data/cfd-simulation-outputs-cpb"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-benchmark-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison — FDA benchmark pump at 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against experimentally measured NIH values at five flow-speed operating points on the FDA generic centrifugal pump. Relative hemolysis index RH < 1 satisfied at all five points. Aleatory uncertainty in experimental measurements characterized via replicate trials (n=6); structured UQ node records measurement variability as a probability distribution.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-hemolysis-benchmark-aleatory"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv-02",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements — impeller passage",
      "description": "Simulated velocity magnitude and direction in the impeller passage compared against particle image velocimetry (PIV) measurements from an in-vitro flow loop. Agreement assessed via normalized root-mean-square error (NRMSE < 8% across all measurement planes). Inherent variability in PIV measurements assessed qualitatively by the experimental team based on known laser sheet thickness and seeding density effects; no structured probability distribution or interval estimate was formally linked to this result.",
      "passFailOutcome": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-rise-03",
      "type": "ValidationResult",
      "name": "Pump pressure rise validation — head-flow curve",
      "description": "Predicted pump head across the 5 flow-speed combinations compared against manufacturer-supplied head-flow curve measurements. Discrepancy within ±4% across all operating points. Aleatory uncertainty from pump-to-pump manufacturing variation characterized via bootstrap confidence intervals on the experimental dataset.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-pressure-rise-aleatory"
    }
  ],
