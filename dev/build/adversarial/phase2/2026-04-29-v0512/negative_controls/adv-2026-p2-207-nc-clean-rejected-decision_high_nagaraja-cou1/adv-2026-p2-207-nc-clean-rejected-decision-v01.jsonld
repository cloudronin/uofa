  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/sqa-gradation2",
      "rationale": "Ansys Mechanical 2023 R1 is a commercially validated solver with documented V&V per ASME VVUQ-10. FDA in-house scripts are version-controlled under Git with peer-reviewed commit history. DePuy Synthes FEA environment employs ISO 9001-certified software lifecycle controls. All three ensemble members satisfy Gradation 2 requirements: documented test plans, configuration management, and regression test suites. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/code-verification-gradation2",
      "rationale": "Patch tests and manufactured-solution benchmarks were executed for the linear-elastic and contact formulations used in the compression-bending model. Results for all three ensemble solvers agree with analytic solutions to within 0.3% for beam-bending benchmarks and within 1.1% for contact patch tests, satisfying Gradation 2 code-verification requirements. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/discretization-error-gradation2",
      "rationale": "A three-level mesh refinement study was performed on the non-cannulated screw geometry. Richardson extrapolation yields a Grid Convergence Index (GCI) of 1.4% for construct stiffness and 2.1% for yield force, both below the 5% threshold for Gradation 2. The production mesh (approximately 480,000 elements, C3D10 tetrahedral with hex-dominant rod) was selected as the converged configuration. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/solver-error-gradation2",
      "rationale": "Iterative solver residuals were monitored for all load steps; force and displacement residuals converged to below 1e-6 relative norm. Contact stabilization energy remained below 1% of total strain energy across all load increments. Ensemble agreement across three independent solver implementations provides additional confidence that solver-specific errors are not dominant. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/use-error-gradation2",
      "rationale": "Model setup was independently reviewed by a second analyst at each of the three participating organizations. Boundary conditions, material assignments, contact definitions, and load application were verified against the ASTM F1717 protocol and documented in a formal model review checklist. No discrepancies were identified after review. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-form-gradation3",
      "rationale": "Linear-elastic isotropic constitutive models are appropriate for Ti-6Al-4V screw and rod components operating below yield. Contact interactions between screw head and tulip are modeled with penalty-based frictional contact (mu=0.3, literature-supported). Geometric nonlinearity is included to capture large-displacement effects at 40 mm. Model form is consistent with published FDA guidance and prior ASME V&V 40 pedicle screw case studies. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-inputs-gradation3",
      "rationale": "Material properties (E=114 GPa, nu=0.34, Sy=880 MPa for Ti-6Al-4V) were drawn from ASTM F136 and confirmed by coupon testing of the rod stock. However, friction coefficient uncertainty was not formally propagated through a sensitivity analysis; only a single nominal value (mu=0.3) was used. Geometric dimensions were measured from three representative screws but variability across the N=11 test specimens was not characterized and incorporated into the model input distribution. These omissions limit the factor to Gradation 2 rather than the required Gradation 3, which demands documented sensitivity analysis covering all influential inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-samples-gradation2",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (n=6 Lab A, n=5 Lab B), providing inter-laboratory reproducibility data. All specimens were drawn from the same production lot and conform to 510(k)-cleared design specifications. Sample size exceeds the minimum of N=5 per laboratory required for Gradation 2. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-conditions-gradation3",
      "rationale": "Testing was performed strictly per ASTM F1717 at a single nominal load configuration (5.5-degree offset, 44 mm spacer block). Gradation 3 requires testing across at least two clinically relevant load configurations or offset angles to bound the model's predictive range across the COU. Only one test condition was employed, which is insufficient to establish that the model generalizes beyond the single validated configuration. This factor achieves Gradation 2 only, falling short of the required Gradation 3 for Model Risk Level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/input-equivalency-gradation2",
      "rationale": "FEA model inputs (geometry, material properties, boundary conditions) were mapped directly to the as-tested specimen configuration. Coordinate system alignment between CAD and test fixture was verified by overlay comparison. Nominal dimensions match measured specimen dimensions within 0.05 mm. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/output-comparison-gradation3",
      "rationale": "All three QoIs (construct stiffness, yield force, force at 40 mm) were compared using the E/uval metric per ASME V&V 40 Section 9. Stiffness: mean experimental 312 N/mm (SD 18), FEA ensemble mean 304 N/mm, E/uval=1.41 (<1.96). Yield force: mean experimental 1,847 N (SD 94), FEA ensemble mean 1,891 N, E/uval=1.68 (<1.96). Force at 40 mm: mean experimental 2,203 N (SD 112), FEA ensemble mean 2,189 N, E/uval=0.89 (<1.96). All QoIs satisfy the pre-specified acceptance criterion of E/uval < 1.96 and percent difference < 10%. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/qoi-relevance-gradation2",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the QoIs specified in ASTM F1717 and directly correspond to the clinical performance attributes of interest (resistance to deformation and structural integrity under physiologic loading). These QoIs are the same as those used in the 510(k) predicate comparison. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/validation-relevance-gradation2",
      "rationale": "The validation activity directly replicates the COU: the same non-cannulated 7.5 mm screw geometry, the same ASTM F1717 test protocol, and the same three QoIs as specified in the intended use statement. The two-laboratory design provides geographic and equipment independence. Required level 2 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-not-accepted-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-panel",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment panel determined that the overall package does NOT achieve the required credibility level for Model Risk Level 3 at Medium model influence and Medium decision consequence. Two credibility factors were assessed below their required levels: (1) Model inputs achieved Gradation 2 against a required Gradation 3 — the friction coefficient and specimen geometric variability were not formally propagated through a documented sensitivity analysis, leaving the influence of these inputs on QoI predictions unquantified; (2) Test conditions achieved Gradation 2 against a required Gradation 3 — only a single ASTM F1717 load configuration was tested, and the model's predictive validity has not been demonstrated across the range of clinically relevant loading conditions encompassed by the COU. Per ASME V&V 40 Section 10, all factors must meet or exceed their required credibility levels for the package to be accepted. The panel notes that the output comparison results are favorable (all E/uval < 1.96) and that the deficiencies are remediable: conducting a documented sensitivity analysis covering friction coefficient and geometric variability, and adding a second test configuration (e.g., a different offset angle or spacer block height), would be expected to bring both factors to Gradation 3 and support an Accepted decision upon resubmission. No waiver is granted because the identified gaps are technically addressable and the consequence of an incorrect acceptance decision (revision surgery) warrants adherence to the established threshold.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
