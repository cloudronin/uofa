  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump is accepted for the COU of identifying worst-case hemolysis operating conditions under CPB conditions at MRL 2. All 7 assessed credibility factors meet or exceed their required levels. Six factors are appropriately scoped out per ASME V&V 40 Table 3 for MRL 2. One explicitly-flagged gap exists: turbulence model form uncertainty (SST k-omega vs. RSM) contributes approximately 60% of total prediction variance and introduces 9–12% spread in hemolysis index predictions. This gap is accepted as residual risk on the following grounds: (1) both turbulence model variants predict RH < 1 at all 5 operating points, preserving the binary regulatory decision; (2) overall experimental validation agreement (mean error 8.3%, maximum 14.1%) is within the FDA benchmark tolerance of ±15%; (3) Monte Carlo uncertainty propagation confirms that the 95% CI on predicted hemolysis index (±4.1%) does not overlap the RH = 1 threshold at any operating point, providing a minimum safety margin of 0.11 RH units; (4) MRL 2 requirements for model form assessment are satisfied by literature-justified model selection and experimental corroboration. The credibility assessment team concludes that the model provides adequate credibility for the intended regulatory use. The turbulence model form gap is disclosed to the regulatory reviewer as a documented limitation that does not affect the regulatory conclusion but should be revisited if the device risk classification is elevated to Class III or if model influence is reclassified as High.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
