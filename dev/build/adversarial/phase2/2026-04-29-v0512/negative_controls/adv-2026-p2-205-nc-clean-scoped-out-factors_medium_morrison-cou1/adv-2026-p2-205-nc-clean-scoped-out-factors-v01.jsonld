  "signature": "ed25519:4dead77880d8d51da91d9c64e66c32af61ae033092bc9db5022a95757803b5497a24465630f90596e9b3c6144ab6d72d716d79775fcf2b7ba095c02be1f78e08",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl2-criteria",
      "rationale": "ANSYS Fluent 2023R2 is a commercially validated CFD solver with documented software quality assurance processes compliant with FDA software guidance. Version control, release notes, and validation documentation are maintained by the vendor. Internal usage follows standard operating procedures with documented user training records. SQA level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl2-criteria",
      "rationale": "Numerical code verification was performed using the Method of Manufactured Solutions (MMS) for the incompressible Navier-Stokes solver. Second-order spatial convergence confirmed for both velocity and pressure fields. ANSYS Fluent solver benchmarks against standard verification test cases (lid-driven cavity, Poiseuille flow) are documented in the vendor verification manual and independently replicated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl2-criteria",
      "rationale": "Richardson extrapolation applied across three systematically refined meshes (2.1M, 6.8M, 18.4M hexahedral cells). Grid Convergence Index (GCI) for the primary quantity of interest (normalized index of hemolysis) is 3.1% on the fine mesh, satisfying the < 5% acceptance criterion. Monotonic convergence confirmed with observed order of accuracy p = 1.94, consistent with the second-order discretization scheme. Fine mesh adopted for all production simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl2-criteria",
      "rationale": "Experimental test conditions replicate the 5 clinically relevant flow-speed operating points (2–6 L/min, 2400–3600 RPM) specified in the COU. Blood analog fluid (water-glycerol mixture, 36% v/v) was used per ASTM F1841 protocols. Temperature maintained at 37°C ± 0.5°C. Inlet boundary conditions derived from measured flow waveforms with documented uncertainty bounds. Test conditions are adequately representative of the COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl2-criteria",
      "rationale": "Quantitative comparison performed between CFD-predicted and experimentally measured NIH values across all 5 operating points using the Theil inequality coefficient and mean absolute percentage error (MAPE = 9.7%). Prediction intervals computed via bootstrap resampling of experimental uncertainty. All predicted values fall within the 95% prediction interval of experimental measurements. Pressure-rise agreement MAPE = 4.2%. Velocity field RMS error 6.8% of bulk velocity versus PIV measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl2-criteria",
      "rationale": "The primary QOI is the normalized index of hemolysis (NIH) computed via the Giersiepen-Wurzinger power-law hemolysis model integrated along Lagrangian particle trajectories. NIH is directly mapped to the regulatory acceptance criterion (RH < 1 relative to predicate device). Secondary QOIs include pump head and efficiency. Clinical relevance of NIH as a surrogate for in-vivo hemolysis is supported by published literature and FDA guidance on blood-contacting device testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl2-criteria",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump geometry, which is the same device family as the COU device. Validation operating conditions span the full COU envelope (2–6 L/min, 2400–3600 RPM). Validation fluid (blood analog) and boundary conditions are representative of CPB operating conditions. The validation hierarchy progresses from component-level (impeller) to system-level (full pump assembly), providing adequate coverage of the COU physics."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl2-criteria",
      "rationale": "Iterative convergence monitored via residual norms (continuity < 1e-5, momentum < 1e-5, turbulence < 1e-4) and stabilization of NIH monitor points. Double-precision arithmetic employed throughout. Round-off error estimated at machine epsilon level (2.2e-16) and negligible relative to discretization error. Steady-state convergence confirmed by absence of oscillation in NIH over the final 500 iterations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl2-criteria",
      "rationale": "The k-omega SST turbulence model was selected based on published benchmark studies for rotating machinery and blood pump CFD. The Giersiepen-Wurzinger hemolysis power-law model is the most widely validated analytical hemolysis model for CFD applications in cardiovascular devices. Non-Newtonian blood rheology (Carreau-Yasuda model) incorporated for shear-thinning effects. Model form uncertainty quantified by comparison with alternative turbulence models (k-epsilon realizable), showing < 8% variation in NIH, within the accepted uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl2-criteria",
      "rationale": "All model inputs (geometry, fluid properties, boundary conditions, rotational speed) are traceable to calibrated measurement sources with documented uncertainty. Geometry derived from CMM measurements of physical pump with dimensional tolerances ± 0.05 mm. Fluid properties (density, viscosity) measured at 37°C per ASTM standards. Inlet flow rates measured with Coriolis flowmeter (± 0.5% accuracy). Sensitivity analysis performed on key inputs; NIH sensitivity to ± 5% inlet flow variation is 3.2%, within the uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Test samples factor is scoped out at MRL 2 for this COU because the validation dataset employs a blood analog fluid (water-glycerol mixture per ASTM F1841) rather than human blood, which is standard practice for CFD validation of blood-contacting devices at this risk level. Variability in donor blood properties (hematocrit, RBC fragility) would introduce biological variability that cannot be controlled in a CFD validation context. The FDA guidance for blood-contacting device CFD validation at MRL 2 accepts blood analog validation with documented equivalency justification. Equivalency of fluid properties to physiological blood is addressed under the Equivalency of Input Parameters factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Use error factor is scoped out at MRL 2 for this COU because the CFD model is operated by a team of trained simulation engineers following a documented simulation plan and standard operating procedures. User qualification records are maintained and all analysts have completed CFD software training with demonstrated competency assessments. At MRL 2 with medium model influence, the ASME V&V 40 framework permits scoping out use error when documented analyst qualification and SOPs are in place, as the residual risk of systematic user error is sufficiently low given the oversight structure and independent review of simulation setup by a senior engineer."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters factor is scoped out at MRL 2 for this COU because the validation experiments were conducted on the same FDA generic centrifugal pump geometry used in the COU simulations, with boundary conditions directly matching the COU operating envelope. The blood analog fluid properties (density 1050 kg/m³, dynamic viscosity 3.5 mPa·s at 37°C) are within 4% of physiological blood values at the relevant shear rates for this pump. At MRL 2, the ASME V&V 40 framework accepts scoping out this factor when the validation and COU configurations share the same geometry and operating conditions, and when fluid property equivalency is documented with quantitative comparison, as is the case here."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) Ten credibility factors were assessed and all achieved levels meet or exceed required levels for MRL 2. Discretization error (GCI 3.1%), output comparison (MAPE 9.7%, all predictions within 95% PI), and model form uncertainty (< 8% NIH variation across turbulence model alternatives) collectively demonstrate adequate predictive fidelity for the intended use. (2) Three factors (Test samples, Use error, Equivalency of input parameters) are scoped out with documented rationale appropriate for MRL 2: blood analog validation is standard practice accepted by FDA guidance; analyst qualification and SOPs mitigate use error risk; and validation-COU configuration equivalency is established by identical geometry and overlapping operating conditions with quantified fluid property similarity. (3) The primary regulatory acceptance criterion (RH < 1 relative to predicate device) is met across all 5 operating points with a minimum margin of 12%. (4) The provenance chain from raw experimental measurements through validation results to credibility factor assessments is complete and traceable. (5) Uncertainty quantification is documented for all validation results, and the total uncertainty budget (experimental + model form + discretization) is within the bounds established by the MRL 2 credibility goal. The decision to accept is supported by the convergence of quantitative validation evidence, documented uncertainty budgets, and appropriate scoping of factors consistent with ASME V&V 40-2018 guidance for MRL 2 assessments.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
