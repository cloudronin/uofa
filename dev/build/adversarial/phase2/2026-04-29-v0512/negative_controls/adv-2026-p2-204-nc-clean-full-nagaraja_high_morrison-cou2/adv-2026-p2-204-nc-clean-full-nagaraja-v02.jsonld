  "hasCredibilityFactor": [
    {
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl3-ortho",
      "rationale": "The FE solver (Abaqus 2023) is validated under an ISO 9001-certified quality management system. Software version control, regression test suite (847 benchmark cases), and configuration management records are documented and current. Achieved level 3 exceeds the MRL 3 requirement of level 2, providing margin against undetected solver defects."
    },
    {
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl3-ortho",
      "rationale": "Code verification performed against three ASME V&V 10 benchmark problems: Hertzian contact, thick-walled cylinder under pressure, and cantilever beam with tip load. Numerical solutions agree with analytical solutions to within 0.5% for all benchmarks. Achieved level 2 meets the MRL 3 requirement."
    },
    {
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl3-ortho",
      "rationale": "Mesh convergence study performed across four mesh refinement levels (coarse 42k elements to fine 387k elements) using the Grid Convergence Index (GCI) method per ASME V&V 20. GCI for peak interface micromotion is 3.2% on the fine mesh. Spatial discretization error is formally bounded. Achieved level 3 exceeds requirement."
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl3-ortho",
      "rationale": "Cadaveric validation experiments replicate the boundary conditions applied in the FE model: distal tibia potted in PMMA, physiological axial and shear loads applied via a six-axis load frame, soft tissue constraints represented by ligament simulators. Loading magnitudes derived from published in vivo telemetry data (Bergmann 2014). Achieved level 2 meets requirement."
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl3-ortho",
      "rationale": "Quantitative comparison performed using mean absolute error, root-mean-square error, and Pearson correlation coefficient across all interface measurement sites and loading scenarios. Statistical equivalence testing (TOST procedure, equivalence margin ±25 microns) confirms FE predictions are statistically equivalent to cadaveric measurements at alpha=0.05. Achieved level 3 exceeds requirement."
    },
    {
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl3-ortho",
      "rationale": "The primary QoI (peak bone-implant interface micromotion in microns) is directly the quantity used for the regulatory acceptance criterion (150-micron osseointegration threshold per literature consensus). Secondary QoIs (cortical strain, contact pressure distribution) are mechanistically linked to the primary QoI and validated independently. Achieved level 2 meets requirement."
    },
    {
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl3-ortho",
      "rationale": "Validation activities used the same tibial tray geometry (pre-production design), same implant material (Ti-6Al-4V ELI), and physiologically representative loading. Cadaveric tibiae span the target patient population BMD range (T-score -1.5 to +1.0). The gap between validation conditions and COU is limited to use of cadaveric rather than in vivo bone, which is standard practice and consistent with MRL 3 requirements. Achieved level 2 meets requirement."
    },
    {
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl3-ortho",
      "rationale": "Iterative solver convergence monitored via force and displacement residual norms (tolerance 1e-6). Contact algorithm uses augmented Lagrangian formulation with penalty stiffness sensitivity study confirming results are insensitive to penalty parameter over two orders of magnitude. No spurious hourglass modes detected in reduced-integration elements. Achieved level 2 meets requirement."
    },
    {
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl3-ortho",
      "rationale": "Model execution is controlled via a validated Python scripting layer with input range checks and automated output plausibility checks (mass conservation, reaction force equilibrium). Two independent analysts ran the model and obtained results within 0.3% of each other. A documented simulation protocol and operator training record are on file. Achieved level 2 exceeds the MRL 3 requirement of level 1."
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl3-ortho",
      "rationale": "Linear elastic constitutive models are used for cortical bone (E=17 GPa, nu=0.3) and Ti-6Al-4V (E=114 GPa, nu=0.33). Cancellous bone is modeled as heterogeneous linear elastic with density-modulus relationships from CT-derived Hounsfield unit mapping (Morgan 2003 relationship). Sensitivity analysis confirms that inclusion of bone viscoelasticity changes peak micromotion by less than 4%, within the model uncertainty budget. Achieved level 2 meets requirement."
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl3-ortho",
      "rationale": "All model inputs characterized with uncertainty distributions: bone elastic modulus (log-normal, CV=18%), interface friction coefficient (uniform 0.3-0.6 per cadaveric literature), implant geometry (normal, ±0.05 mm manufacturing tolerance), and applied loads (normal, CV=10% per telemetry data). Latin Hypercube Sampling with n=500 runs propagates input uncertainty to output QoIs. 95th percentile micromotion remains below 150-micron threshold. Achieved level 3 exceeds requirement."
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl3-ortho",
      "rationale": "Eight cadaveric tibiae from six donors (age 58-74, BMD T-score -1.2 to +0.8, four male/two female) provide adequate sample diversity for MRL 3. Specimen preparation followed standardized protocol (ASTM F1714 adapted for tibial tray). Donor demographics and bone quality metrics are fully documented in the cadaveric dataset record. Achieved level 2 meets requirement."
    },
    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl3-ortho",
      "rationale": "Input parameters used in the validation FE models are drawn from the same distributions as the COU FE models. Material properties measured directly from cadaveric specimens (DXA-derived BMD, nanoindentation for cortical modulus) and applied to both validation and COU models without recalibration. Loading conditions in validation experiments bracket the COU operating envelope. Equivalency formally documented in the simulation protocol. Achieved level 2 meets requirement."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 3 for the tibial tray primary stability FE model. Achieved credibility levels meet or exceed required levels for every factor: eight factors achieve exactly the required level and five factors (Software quality assurance, Discretization error, Output comparison, Use error, Model inputs) exceed the required level, providing positive credibility margin. Three independent validation datasets (cadaveric micromotion, cortical strain gauge, contact pressure) collectively demonstrate that the FE model predicts bone-implant interface micromotion within 18.4 microns mean absolute error, representing 12.3% of the 150-micron clinical threshold. Latin Hypercube Sampling uncertainty quantification (n=500) confirms that the 95th percentile predicted micromotion remains below the clinical threshold across the full input uncertainty space. The validation activities are sufficiently relevant to the COU: same implant geometry, same material, physiologically representative loading, and cadaveric specimens spanning the target patient BMD range. No unresolved epistemic gaps have been identified at MRL 3. The credibility evidence package is complete and internally consistent; the model is accepted for use in predicting tibial tray primary stability to support Class II regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
