  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump is accepted for the declared COU (identifying worst-case hemolysis operating conditions for Class II CPB device at MRL 2) within the explicitly bounded operating envelope (flow 2–6 L/min, speed 2000–4000 RPM, hematocrit 35–45%, temperature 35–37 °C, viscosity 2.5–4.0 mPa·s, inlet pressure −50 to +20 mmHg). Seven credibility factors were formally assessed; all achieved levels meet or exceed required levels for MRL 2. Six factors were scoped out per ASME V&V 40-2018 Table 3 with documented rationale. Validation evidence is dense (15 operating points spanning full envelope), quantitative (three QoIs with uncertainty quantification), and directly relevant (same geometry, matched fluid properties). The primary regulatory QoI (RHI) is predicted with MAE 4.2% and all worst-case predictions satisfy RH < 1 acceptance criterion with margin. Discretization error is formally bounded at < 2% via GCI analysis. The operating envelope and applicability constraints are explicitly documented, and all validation activities fall within the declared bounds, providing high confidence in model predictions within the envelope. Decision consequence is HIGH and model influence is MEDIUM; the structured evidence base at MRL 2 is sufficient to support regulatory submission for this Class II device. No weakeners identified.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
