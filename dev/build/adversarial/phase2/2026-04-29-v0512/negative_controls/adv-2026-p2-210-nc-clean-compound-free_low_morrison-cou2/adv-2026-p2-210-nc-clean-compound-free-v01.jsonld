  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed under ASME V&V 40-2018. For each factor, the achieved credibility level meets or exceeds the required level for Model Risk Level 5 with High decision consequence and High model influence. Discretization error (achieved 4 vs required 3), relevance of QoI (achieved 3 vs required 2), model inputs (achieved 3 vs required 3), and equivalency of input parameters (achieved 3 vs required 2) provide additional margin. Monte Carlo uncertainty quantification (n=500) demonstrates that hemolysis index predictions remain below the absolute clinical threshold (NIH < 0.01 g/100 L) with 97.5th percentile confidence when all input and model-form uncertainties are propagated. Validation results against independent bench test data show no systematic bias and all predictions within combined uncertainty bounds. The provenance chain from raw PIV and hemolysis measurements through validated simulation outputs is complete and archived. Independent peer review of simulation setup identified no use errors. The credibility evidence is sufficient to support regulatory submission for the Class III VAD device hemolysis claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
