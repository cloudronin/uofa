  "signature": "ed25519:dd913d159d10907903a4d4a55f5d4c777b05318ab99d8f86b4adb5e2380bd4746f7f20803b2a9c1eb46cd8f5d56b18a51d8cb233911478f2f7f28136eeab2602",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-level2",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) is a commercially validated, FDA-recognized simulation software. Software quality assurance was demonstrated through: (1) documented installation qualification (IQ) and operational qualification (OQ) records on the HPC cluster used for the study; (2) regression test suite execution confirming solver version reproducibility across 14 canonical benchmark cases including lid-driven cavity, backward-facing step, and rotating disk flows; (3) version-controlled simulation scripts stored in a Git repository with tagged releases corresponding to each simulation campaign; (4) all simulation input decks reviewed by a second analyst prior to execution. The achieved level of 3 exceeds the MRL 2 requirement of 2, providing additional assurance that solver defects are not a material contributor to model credibility risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-level2",
      "rationale": "Numerical code verification was performed by comparing solver output against three analytical and manufactured solutions: (1) Hagen-Poiseuille laminar pipe flow — velocity profile L2 error 0.08% at the simulation mesh density; (2) Taylor-Couette flow between concentric cylinders at Re = 400 — tangential velocity profile L2 error 0.31%; (3) Method of Manufactured Solutions (MMS) applied to the incompressible Navier-Stokes equations on a structured hexahedral mesh — observed spatial order of accuracy 1.97, consistent with the nominal second-order scheme. All three verification exercises confirmed that the numerical implementation correctly solves the governing equations to within expected truncation error bounds. Required level 2 is met exactly."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-level2",
      "rationale": "Discretization error was quantified using the Grid Convergence Index (GCI) methodology (Celik et al., ASME J. Fluids Eng. 2008) across three systematically refined meshes (coarse 2.1M, medium 6.4M, fine 14.8M cells; refinement ratio r = 1.46). The apparent order of convergence was p = 1.89 for volume-averaged shear stress and p = 1.94 for NIH. GCI values on the medium-to-fine pair were 1.3% and 1.7% respectively, well within the pre-specified acceptance criterion of 5%. Wall y+ values were maintained below 1.0 on all rotating surfaces for the fine mesh. The medium mesh (6.4M cells) was selected for the production runs based on the GCI analysis, achieving achieved level 3. Temporal discretization was verified separately with a time-step refinement study confirming period-averaged QoIs change by less than 0.4% upon halving the time step."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-level2",
      "rationale": "Experimental test conditions for both PIV and hemolysis bench studies were documented in calibrated laboratory protocols traceable to NIST standards. Flow rates were set and measured with a Coriolis mass flow meter (±0.2% FS accuracy); rotational speed was controlled with a servo drive and verified with an optical tachometer (±5 RPM). Blood analogue fluid (40% glycerol/water for PIV; bovine blood at 35% hematocrit for hemolysis) temperature was maintained at 37 ± 0.5°C using a recirculating bath. All five operating points (Q ∈ {2.5, 3.5, 4.5, 5.5, 6.0} L/min at N = 3000 RPM nominal) were replicated three times to characterise repeatability. Test condition documentation satisfies the required level 2 standard."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-level2",
      "rationale": "Quantitative output comparison was performed using three metrics: (1) mean absolute relative error (MARE) for velocity field comparison against PIV — MARE = 4.2% across all measurement planes and operating points, within the 15% acceptance criterion; (2) normalised index of hemolysis (NIH) point-wise comparison — maximum relative error 18% at the highest flow rate operating point, within the 25% pre-specified criterion; (3) relative hemolysis index RH < 1.0 at all five nominal operating points (range 0.61–0.94). Uncertainty in experimental measurements was propagated into the comparison using a combined standard uncertainty approach. The model predictions fall within the experimental uncertainty bands at 4 of 5 operating points for NIH; the fifth point (Q = 6.0 L/min) shows a 3% exceedance of the uncertainty band, which was reviewed and judged acceptable given the conservative nature of the hemolysis power-law model at high shear rates. Achieved level 3 reflects the quantitative, multi-metric, uncertainty-aware comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-level2",
      "rationale": "The primary quantity of interest — the normalised index of hemolysis (NIH, mg/100L) and the derived relative hemolysis index (RH = NIH_device / NIH_predicate) — are directly relevant to the COU decision. The FDA guidance for blood-contacting devices (FDA 2017 guidance on blood-contacting computational models) identifies NIH as the appropriate hemolysis QoI for comparative regulatory submissions. The mapping from CFD shear stress fields to NIH via the Giersiepen-Wurzinger power-law model is well-established in the literature and was used in the FDA benchmark study (Stewart et al. 2012). The acceptance criterion RH < 1.0 is the pre-specified regulatory threshold. QoI relevance is confirmed at required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-level2",
      "rationale": "Validation activities were designed explicitly for the COU. The FDA generic centrifugal pump geometry used in the validation experiments is the same geometry as the device under assessment, eliminating geometry-extrapolation uncertainty. Operating conditions span the full clinical envelope for CPB (2.5–6 L/min, 2500–3500 RPM), encompassing the five flow-speed combinations specified in the COU. The blood analogue used in PIV is a validated substitute (Brookshier & Tarbell 1993) and bovine blood at matched hematocrit was used for hemolysis experiments, consistent with FDA benchmark practice. The validation hierarchy includes both global (NIH) and field-level (velocity) comparisons, providing multi-fidelity evidence of model fidelity. The achieved level 3 reflects the deliberate alignment of validation scope with the COU decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-level2",
      "rationale": "Numerical solver error was assessed through iterative convergence monitoring and residual analysis. All simulations were run to a scaled residual convergence criterion of 1×10⁻⁵ for continuity, momentum, and turbulence equations. Convergence was confirmed by monitoring the cycle-averaged NIH and volume-averaged shear stress over the final 10 impeller revolutions; variation was less than 0.2% over this window. Floating-point precision was double throughout. Round-off error was estimated to be at least 4 orders of magnitude below discretization error based on condition number analysis. Solver iterative convergence satisfies the required level 2 criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-level2",
      "rationale": "Use error risk was mitigated through a structured simulation execution protocol. All boundary condition assignments, material property inputs, turbulence model selections, and post-processing scripts were reviewed by an independent analyst prior to each production run. A pre-simulation checklist (20 items) was completed and archived for each of the 15 production cases. Boundary conditions were imported programmatically from the experimental dataset to eliminate transcription errors. Post-processing scripts for NIH calculation were unit-tested against known analytical cases. No use errors were identified during the independent review. The achieved level 2 reflects systematic process controls appropriate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-level2",
      "rationale": "Model form uncertainty was assessed at multiple levels. For turbulence modelling, three RANS closures were compared (k-ω SST, Realizable k-ε, and RSM) at the design operating point; k-ω SST was selected based on best agreement with PIV data (MARE = 4.2% vs 6.8% and 7.1% respectively) and its established suitability for rotating machinery with adverse pressure gradients. The Giersiepen-Wurzinger hemolysis power-law model was evaluated against the Zhang et al. (2011) and Arora et al. (2004) models; all three produced RH values within 12% of each other, and the Giersiepen-Wurzinger model was retained as it was used in the FDA benchmark study enabling direct comparability. Blood was modelled as a non-Newtonian fluid using the Carreau-Yasuda viscosity model with parameters fitted to the experimental rheology data. Model form uncertainty contributions were included in the global UQ analysis. Achieved level 3 reflects the multi-model comparison and documented selection rationale."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-level2",
      "rationale": "All model input parameters were characterised with quantified uncertainties and documented in the UQ plan. The eight most influential inputs (blood viscosity, pump clearance tolerances, inlet velocity profile shape, turbulence intensity at inlet, hemolysis power-law coefficients C and α, rotational speed, fluid density) were assigned probability distributions based on: (1) manufacturer specifications for geometric tolerances (uniform distributions over ±tolerance); (2) literature meta-analysis for hemolysis model coefficients (log-normal distributions, Taskin et al. 2012); (3) direct measurement for fluid properties (normal distributions with experimentally determined standard deviations). Sobol' global sensitivity analysis identified C and α as dominant contributors (S_T = 0.61 and 0.28). Input uncertainty propagation produced a 95% prediction interval for NIH of [0.52, 1.09]. The marginal exceedance of the upper bound above 1.0 is noted and addressed in the decision record. Achieved level 3 reflects comprehensive probabilistic input characterisation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-level2",
      "rationale": "Test samples for the hemolysis bench study consisted of bovine blood sourced from a single abattoir batch, anticoagulated with heparin (4 IU/mL), and used within 6 hours of collection. Hematocrit was adjusted to 35 ± 1% by centrifugation and plasma replacement. Baseline free plasma haemoglobin was measured before each test run and confirmed below 20 mg/dL to ensure minimal pre-existing hemolysis. Three independent blood batches were used across the five operating points to assess inter-batch variability; batch-to-batch coefficient of variation for NIH was 8.3%, which was incorporated into the measurement uncertainty budget. The pump test article was the FDA generic centrifugal pump manufactured to drawing tolerances, with dimensional inspection records confirming conformance. Sample characterisation satisfies required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/input-equivalency-level2",
      "rationale": "The equivalency between simulation input parameters and experimental conditions was systematically documented. Fluid properties (viscosity, density) used in the CFD model were set to the measured values from the experimental blood analogue/bovine blood characterisation, not nominal literature values. Pump geometry in the CFD model was constructed from the same engineering drawings used to manufacture the test article, with as-built dimensional measurements used to update critical clearance dimensions (impeller tip clearance measured at 0.31 mm vs nominal 0.30 mm; this discrepancy was incorporated into the geometric uncertainty distribution). Inlet boundary conditions (velocity profile and turbulence quantities) were derived from the experimental flow conditioning section measurements. Rotational speed in the simulation matched the tachometer-verified experimental value to within ±5 RPM. The equivalency mapping was documented in a traceability matrix linking each CFD input to its experimental counterpart and associated measurement uncertainty. Required level 2 is met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis prediction, Class II device, MRL 2) is accepted based on the following structured evidence review. All 13 V&V 40 credibility factors have been assessed, and all achieved levels meet or exceed the required levels for MRL 2. The model demonstrates adequate fidelity for its intended use: PIV velocity comparison yields MARE = 4.2% (criterion: 15%); NIH point-wise comparison yields maximum relative error 18% (criterion: 25%); RH < 1.0 at all five nominal operating points (range 0.61–0.94). The global UQ analysis produces a 95% prediction interval for NIH of [0.52, 1.09]. The marginal upper-bound exceedance (1.09 vs threshold 1.0) was reviewed by the assessment team and judged acceptable for the following reasons: (1) the power-law hemolysis model is known to be conservative at high shear rates, systematically over-predicting NIH; (2) the upper bound corresponds to an extreme combination of pessimistic hemolysis coefficient values (97.5th percentile of the C distribution) and is not representative of the expected device performance; (3) the point-estimate predictions at all five operating points satisfy RH < 1.0; (4) the device is a Class II device with moderate decision consequence, and the MRL 2 assessment framework explicitly accommodates this level of residual uncertainty. The provenance chain is complete: all validation results are traceable to archived experimental datasets, simulation activities, and UQ analyses. Software quality assurance, code verification, and use error controls are documented and reviewed. The decision is Accepted with the recommendation that the hemolysis model coefficient uncertainty be reduced in a future MRL 3 assessment if the device advances to a higher-consequence regulatory pathway.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
