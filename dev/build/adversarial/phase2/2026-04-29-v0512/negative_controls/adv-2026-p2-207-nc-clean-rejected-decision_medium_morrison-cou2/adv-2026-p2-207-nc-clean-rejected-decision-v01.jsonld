  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis prediction at MRL 5) results in a 'Not accepted' decision based on systematic shortfalls across all 13 credibility factors. Seven factors were formally assessed; all seven achieved levels below their required levels for MRL 5. The most critical deficits are: (1) Validation relevance (achieved 2, required 4): the validation evidence base relies on the generic FDA pump geometry under steady inflow, whereas the COU demands prediction for a commercial VAD geometry under pulsatile conditions — an unacceptable relevance gap for a Class III device decision; (2) Output comparison (achieved 2, required 4): the area validation metric was not satisfied and two of five operating points were excluded from comparison; (3) Software quality assurance (achieved 2, required 4): independent code review was not performed; (4) Numerical code verification (achieved 2, required 4): the hemolysis accumulation term was not verified via manufactured solutions. Six additional factors (numerical solver error, use error, model form, model inputs, test samples, equivalency of input parameters) were not assessed at all, representing epistemic gaps that cannot be waived at MRL 5 for a Class III device. Monte Carlo UQ was performed on geometric tolerances only and does not compensate for the uncharacterized rheological and model-form uncertainties. The aggregate evidence does not meet the credibility requirements established for a high-consequence, high-influence MRL 5 assessment. The submission must be revised to address validation relevance, complete the remaining six factor assessments, and bring all assessed factors to their required gradation levels before resubmission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
