  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-cdrh",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed with achievedLevel >= requiredLevel. The operating envelope is explicitly bounded (flow rate 2–8 L/min, rotational speed 2000–3500 RPM, hematocrit 35–45%) and all validation activities cover boundary and interior points of this envelope. The applicability constraint restricts the model to the FDA generic centrifugal pump geometry with Newtonian rheology, consistent with the COU. Monte Carlo uncertainty quantification has been performed for all major uncertainty sources; 90th/95th-percentile prediction intervals encompass all experimental measurements. NIH predictions at all five COU operating points are below the clinical threshold of 0.8 mg/dL even at the 95th percentile of the Monte Carlo distribution. The provenance chain from foundational experimental data through validation results to credibility factor assessments is complete and traceable. No credibility gaps remain. The Unit of Assurance is accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
