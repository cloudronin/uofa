  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 3,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-cfd-mrl3",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-below-clinical-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset-2022",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-2023",
    "https://uofa.net/synth/data/fda-pump-uncertainty-montecarlo-2023"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse",
    "hasApplicabilityConstraint": {
      "id": "https://uofa.net/synth/applicability/vad-hemolysis-constraint-001",
      "type": "ApplicabilityConstraint",
      "name": "VAD CFD applicability constraint — centrifugal pump geometry and blood rheology",
      "description": "The CFD hemolysis model is applicable only to the FDA generic centrifugal pump geometry with Newtonian blood rheology approximation valid at shear rates above 100 s^-1. Model is not applicable to axial-flow geometries, pulsatile assist modes, or hematocrit values outside 35–45%. Extrapolation beyond the declared operating envelope invalidates the credibility assessment.",
      "constraintExpression": "geometry == 'FDA_generic_centrifugal' AND rheologyModel == 'Newtonian' AND shearRate >= 100 AND hematocrit IN [35,45]"
    },
