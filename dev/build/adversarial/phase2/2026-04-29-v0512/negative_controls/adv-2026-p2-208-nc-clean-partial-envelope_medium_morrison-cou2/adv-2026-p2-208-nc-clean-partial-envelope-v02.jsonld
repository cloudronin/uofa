  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5",
      "rationale": "The CFD solver (OpenFOAM v9) is version-controlled under Git with tagged releases. A full software quality plan covering unit tests, regression tests, and change-control procedures is maintained. Test suite passes 100% for hemolysis-relevant solver modules. Independent code audit completed by third-party reviewer. Achieved level 4 exceeds required level 3 for MRL 5 under the bounded operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Method of manufactured solutions (MMS) applied to Navier-Stokes and power-law hemolysis transport equations. Observed order of convergence matches theoretical second-order accuracy within 5%. Benchmark comparisons against FDA nozzle and lid-driven cavity problems pass at Gradation 4 standards. All verification cases are archived with reproducible scripts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-mrl5",
      "rationale": "Richardson extrapolation performed on three systematically refined meshes (2.1M, 8.4M, 33.6M cells) at each of the seven validation operating points. Grid convergence index (GCI) for hemolysis index is below 3.2% at all points within the declared operating envelope. Temporal convergence verified for unsteady impeller passage effects; time-step refinement study shows < 1.5% variation in cycle-averaged hemolysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "Physical experiments conducted at all four boundary corners and three interior points of the declared operating envelope. Test fluid (porcine blood, hematocrit 38–42%) matches COU applicability constraint. Flow rate controlled to ±0.05 L/min; rotational speed to ±5 RPM. Temperature maintained at 37 ± 0.5 °C. Inlet/outlet pressure measured with calibrated transducers traceable to NIST standards. All test conditions documented in laboratory notebooks with chain-of-custody records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "Quantitative comparison of predicted vs. measured normalized hemolysis index at all seven operating points using validation metric u_val. Normalized RMSE ranges from 2.9% to 5.1% across the operating envelope. Prediction intervals from Monte Carlo UQ contain 94% of experimental observations. Systematic bias < 2% across the flow-rate range. Comparison methodology follows ASME V&V 20-2009 framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) in g/100L — is the direct regulatory acceptance criterion for VAD hemolysis per FDA guidance. Secondary QoIs (volume-averaged shear stress, exposure time distribution) are mechanistically linked to NIH via the Giersiepen-Wurzinger power-law model. No surrogate or proxy QoI is used; model output maps directly onto the clinical decision threshold. Achieved level 5 reflects perfect QoI alignment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "Validation experiments use the identical FDA generic centrifugal pump geometry as the COU device. Blood analog fluid properties match the declared hematocrit applicability range. Operating points span and cover all declared envelope boundaries. The only distinction between validation and COU context is use of porcine rather than human blood; sensitivity analysis confirms NIH insensitivity to this substitution within ±4% across the envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence monitored via residual norms; all simulations converged to residuals below 1×10⁻⁶ for continuity and momentum. Floating-point round-off assessed via double-precision arithmetic throughout; estimated round-off contribution to NIH < 0.01%. Solver linear algebra library (PETSc 3.18) validated against known analytical solutions. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "Simulation setup follows a documented standard operating procedure (SOP-CFD-VAD-001) reviewed by two independent senior engineers. Boundary condition inputs are read programmatically from a configuration file to eliminate manual transcription errors. Pre-simulation checklist completed and archived for each of the seven operating points. Independent peer review of setup files confirms no user-induced errors."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "The k-ω SST turbulence model with low-Reynolds-number correction is selected based on published benchmark studies for rotary blood pumps. Model form uncertainty quantified by comparing three turbulence closures (k-ε RNG, k-ω SST, LES) at two operating points; NIH spread is 8.3%, incorporated into total uncertainty budget. Hemolysis constitutive model (Giersiepen-Wurzinger) evaluated against four alternative power-law formulations; sensitivity included in Monte Carlo UQ. Model form selection rationale documented in model development report MDR-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "All model inputs (viscosity, density, hemolysis power-law constants, pump geometry, boundary conditions) are characterized with probability distributions derived from measurements and literature. Monte Carlo propagation with 10,000 samples quantifies input uncertainty contribution to NIH prediction interval. Dominant inputs identified as hemolysis power-law exponent (β) and effective viscosity; sensitivity indices computed via Sobol' method. Input uncertainty budget archived in dataset https://uofa.net/synth/data/monte-carlo-uq-10000-samples."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5",
      "rationale": "Seven distinct operating points tested with n=5 independent experimental replicates each (35 total runs). Replicates drawn from different blood donations to capture inter-donor variability. Statistical power analysis confirms 80% power to detect a 10% difference in NIH at α=0.05. Sample preparation and storage protocols follow ASTM F1841 standard. Achieved level 4 exceeds required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5",
      "rationale": "Experimental boundary conditions (flow rate, rotational speed, inlet pressure, hematocrit) are matched to CFD inputs within measurement uncertainty. Dimensional analysis confirms dynamic similarity between validation and COU operating conditions within the declared envelope. Any residual differences in fluid temperature or hematocrit between experiments and COU are propagated through sensitivity analysis; NIH impact is below 3% across all seven validation points. Equivalency documented in validation plan VP-VAD-002."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-accepted-bounded",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed with achieved levels meeting or exceeding required levels for Model Risk Level 5. The operating envelope is explicitly bounded (flow rate 2–8 L/min; rotational speed 2000–4000 RPM; hematocrit 35–45%; inlet pressure 5–20 mmHg) and an applicability constraint restricts use to steady-state, Newtonian-regime conditions. Physical validation experiments cover all four boundary corners and three interior points of this envelope, providing direct evidence of model fidelity across the full declared space. Monte Carlo uncertainty quantification (10,000 samples) confirms that 94% of experimental observations fall within model prediction intervals. Normalized RMSE for the hemolysis index ranges from 2.9% to 5.1% across operating points, well within the acceptance threshold of 10% established in the credibility plan. The primary QoI (NIH in g/100L) maps directly onto the FDA regulatory acceptance criterion with no surrogate substitution. Provenance is complete: all validation results link to raw experimental datasets, computational activity records, and UQ archives. The decision to accept is conditioned on use strictly within the declared operating envelope and applicability constraints; extrapolation beyond these bounds is not supported by this assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
