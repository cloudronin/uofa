  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-gradation5-iso9001-validated-release",
      "rationale": "FEA software (Ansys Mechanical 2023 R2) is used under an ISO 9001-certified quality management system. Software validation records, regression test suite (>2400 benchmark cases), and controlled release documentation are on file. Version control and change management procedures conform to FDA 21 CFR Part 820 design controls. Independent SQA audit completed with zero critical findings."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-gradation5-analytic-benchmarks",
      "rationale": "Code verification performed against five analytic benchmark problems including Euler-Bernoulli beam bending, Hertzian contact, and large-deformation cantilever. All benchmarks reproduce analytic solutions within 0.1% for the element types and solver settings used in the pedicle screw model. Manufactured solution verification (Method of Manufactured Solutions) applied to the nonlinear material subroutine. Results archived in controlled verification report MCV-2023-047."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-gradation5-gci-less-1pct",
      "rationale": "Systematic mesh convergence study conducted across four refinement levels (h-refinement, element edge length 0.8 mm to 0.1 mm in screw thread region). Grid Convergence Index (GCI) computed per Roache (1994) for all three QoIs. GCI < 0.6% for stiffness, < 0.8% for yield force, < 0.7% for force at 40 mm. Richardson extrapolation confirms asymptotic convergence. Production mesh uses 0.2 mm element edge length in critical thread engagement zone, yielding GCI < 1% for all QoIs. Dataset: https://uofa.net/synth/data/morrison-cou2-mesh-convergence-study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-gradation5-residual-tolerance",
      "rationale": "Newton-Raphson nonlinear solver convergence monitored at each load step; force residual norm < 1e-6 and displacement increment norm < 1e-8 enforced. Iterative linear solver (PCG with AMG preconditioner) achieves relative residual < 1e-10. Time-step sensitivity study confirms QoI variation < 0.3% across a 4x refinement of load increment size. No divergence events recorded across 11 model instances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-gradation5-independent-review",
      "rationale": "Model setup, boundary condition application, and post-processing scripts independently reviewed by two senior simulation engineers not involved in original model development. Checklist-based review protocol (UE-CHK-2023) covers geometry import fidelity, material assignment, contact definition, load application, and output extraction. All checklist items verified with zero discrepancies. Model setup frozen and hash-locked prior to validation comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-gradation5-physics-justified",
      "rationale": "Continuum nonlinear FEA with isotropic hardening plasticity (Ti-6Al-4V, Ramberg-Osgood calibrated from 12 tensile coupons per ASTM E8). Frictional contact (mu=0.3, Augmented Lagrangian) at screw-rod and screw-block interfaces. Geometric nonlinearity (NLGEOM) active. Model form selection justified by published literature on metallic implant mechanics and confirmed by sensitivity analysis showing plasticity onset governs yield force QoI. Simplifications (omission of thread helix) assessed via submodel study; QoI impact < 1.2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-gradation5-measured-with-uq",
      "rationale": "All material inputs (E=114 GPa, sigma_y=880 MPa, n=0.05) derived from lot-specific tensile testing (N=12 coupons, 95% CI reported). Geometric inputs from CMM measurement of production screws (N=5, tolerance ±0.005 mm). Boundary condition inputs (applied displacement rate, fixture stiffness) measured during experimental runs and propagated as input uncertainties in UQ sweep. Sobol first-order and total-order indices computed; elastic modulus and yield strength are dominant inputs (S_Ti > 0.6). Full input uncertainty characterization archived in UQ report https://uofa.net/synth/uq/morrison-cou2-sobol-indices-report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-gradation5-production-representative",
      "rationale": "N=11 test constructs assembled from production-representative components (same lot, same assembly torque protocol as clinical use). Sample traceability maintained via serial number log. Dimensional inspection (CMM) performed on all 11 constructs prior to testing; all within drawing tolerances. Inter-specimen variability in screw outer diameter: CV=0.4%. Construct assembly performed by trained operator following IFU torque specification. Samples span two independent laboratories to assess inter-lab reproducibility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-gradation5-fully-characterized",
      "rationale": "ASTM F1717 static compression-bending test conditions fully characterized and replicated in FEA. Load frame displacement rate (1 mm/min), fixture geometry (35 mm offset), and grip compliance measured and incorporated as model inputs. Environmental conditions (ambient temperature 23±2°C, humidity 50±10% RH) monitored and recorded throughout testing at both laboratories. Fixture compliance correction applied to experimental load-displacement curves per ASTM E1012. Inter-laboratory reproducibility confirmed: stiffness CV < 3% across labs. All test condition parameters documented in test report TR-2023-F1717-NC."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-gradation5-one-to-one-mapping",
      "rationale": "One-to-one mapping established between all experimental input parameters and FEA model inputs. Material properties assigned from same material lot used in test samples. Geometric model derived from CAD nominal with CMM-measured deviations applied as perturbations in UQ ensemble. Boundary conditions (displacement rate, fixture offset, grip geometry) replicated in FEA with measured values. Input equivalency matrix (IEM-2023-COU2) documents each experimental parameter, its measured value, and corresponding FEA implementation. No unmatched experimental inputs identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-gradation5-euval-less-196",
      "rationale": "Quantitative validation metric E/uval computed per ASME V&V 40 Eq. 3 for all three QoIs. Stiffness: E/uval=0.82 (< 1.96, pass). Yield force: E/uval=1.14 (< 1.96, pass). Force at 40 mm: E/uval=0.97 (< 1.96, pass). Percent difference between FEA mean prediction and experimental mean: stiffness 3.1%, yield force 4.7%, force at 40 mm 2.8% (all < 10% acceptance bound). Validation uncertainty uval incorporates experimental measurement uncertainty, numerical solution uncertainty, and input parameter uncertainty propagated via Monte Carlo (N=10,000 samples). Full output comparison documented in validation report VR-2023-COU2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-gradation5-directly-linked-to-cou",
      "rationale": "Three QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 and directly linked to the clinical performance concern (implant structural integrity under physiological compression-bending loads). Stiffness governs load transfer to bone; yield force indicates onset of permanent deformation; force at 40 mm characterizes post-yield energy absorption. All three QoIs are extractable from both FEA output and experimental load-displacement curves without transformation. QoI relevance matrix (QRM-2023-COU2) documents clinical-to-QoI linkage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-gradation5-cou-matched",
      "rationale": "Validation activity directly replicates the COU: same device geometry (non-cannulated 7.5 mm pedicle screw), same loading mode (ASTM F1717 static compression-bending), same material lot, same assembly protocol. No extrapolation required from validation domain to COU domain. The FEA model used in validation is identical (same mesh, same material model, same solver settings) to the model used for the COU prediction. Validation-to-COU relevance assessment documented in relevance matrix RVM-2023-COU2, confirming all five relevance dimensions (geometry, material, loading, boundary conditions, scale) are fully matched."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The Morrison COU2 FEA model for non-cannulated pedicle screw ASTM F1717 static compression-bending prediction is accepted at MRL 5 (High assurance) based on the following structured evidence: (1) All 13 ASME V&V 40 credibility factors assessed at requiredLevel=5 and achievedLevel=5. (2) Quantitative validation metric E/uval < 1.96 for all three QoIs (stiffness, yield force, force at 40 mm), with percent differences < 10% acceptance bound. (3) Full uncertainty quantification via Monte Carlo propagation (N=10,000) and global sensitivity analysis (Sobol indices) confirm model predictions are robust to input variability. (4) Mesh convergence GCI < 1% for all QoIs. (5) Software quality assurance at ISO 9001 level with independent audit. (6) Independent use-error review with zero discrepancies. (7) Validation activity is directly matched to COU across all five relevance dimensions. (8) Inter-laboratory reproducibility confirmed (CV < 3%). The totality of structured evidence supports the conclusion that the FEA model is fit for purpose for the stated COU at the required model risk level. No weakeners identified. Decision is Accepted without conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
