  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/sqa-level2",
      "rationale": "All three FEA codes (FDA in-house, Ansys Mechanical 2021 R2, DePuy Synthes proprietary solver) operate under documented software quality management plans. Ansys and DePuy Synthes solvers hold ISO 9001 certification; the FDA in-house code is under version-controlled development with formal test suites and peer-reviewed release notes. Required Gradation 2 (documented QA plan) is exceeded; Gradation 3 achieved through multi-code independent verification.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/sqa-documentation"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/code-verification-level2",
      "rationale": "Each solver was verified against NAFEMS benchmark problems relevant to large-deformation elasto-plastic beam-column bending. Patch tests and single-element analytic solutions confirm correct implementation of the Chaboche nonlinear kinematic hardening constitutive model used for titanium alloy screw material. Results from all three codes agree within 0.3% for the benchmark cases, achieving Gradation 3.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/nafems-benchmark-results"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/discretization-error-level2",
      "rationale": "Systematic mesh convergence study performed using three mesh densities (coarse: ~85k elements, medium: ~220k elements, fine: ~560k elements) for the non-cannulated screw geometry. Richardson extrapolation applied; Grid Convergence Index (GCI) for stiffness QoI = 0.8%, yield force QoI = 1.1%. Production mesh is the medium density, with discretization error contribution to total simulation uncertainty quantified at ±1.3%. Gradation 3 achieved.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/mesh-convergence-study"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/solver-error-level1",
      "rationale": "Iterative convergence monitored via force residual norm (tolerance 1e-6) and energy norm (tolerance 1e-8) for all nonlinear load steps. No divergence events recorded across 11 model runs. Time-step sensitivity study confirms load-step-independent results within 0.2% for all QoIs. Required Gradation 1 met; Gradation 2 achieved through documented tolerance study.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/solver-convergence-logs"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/use-error-level2",
      "rationale": "Model setup, boundary condition application, and post-processing were performed by two independent analysts following a documented simulation protocol. Results were cross-checked; no discrepancies exceeding 0.5% were identified. Checklist-based peer review completed prior to submission. Gradation 2 achieved.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/use-error-peer-review-checklist"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-form-level3",
      "rationale": "The FEA model employs 3D solid elements with nonlinear geometry (large deformation, large strain) and Chaboche nonlinear kinematic hardening for Ti-6Al-4V screw material, linear elastic UHMWPE blocks, and rigid loading fixtures. Contact between screw and block modeled with penalty-based frictional contact (mu=0.2). Model form choices are justified by published literature on spinal implant FEA best practices and are consistent with the ASTM F1717 test geometry. Independent sensitivity analysis confirms that simplifying the UHMWPE to linear elastic introduces <2% error in stiffness. Gradation 3 achieved.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/model-form-justification"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-inputs-level3",
      "rationale": "Material properties for Ti-6Al-4V (E=114 GPa, yield 880 MPa, Chaboche parameters calibrated from coupon tensile tests on the same material lot) sourced from companion coupon testing. UHMWPE properties from ASTM F648 certified material data sheet. Screw geometry from metrology report (CMM measurements, tolerance ±0.01 mm). Input uncertainty propagated via Latin Hypercube Sampling (N=200 runs) to quantify model input uncertainty contribution to total simulation uncertainty. Gradation 3 achieved.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/material-property-coupon-tests"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-samples-level2",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested: N=6 at Lab 1 (FDA), N=5 at Lab 2 (DePuy Synthes). All specimens from the same production lot; certificate of conformance and dimensional inspection report provided. Inter-laboratory coefficient of variation for stiffness = 4.1%, confirming sample-to-sample variability is captured. Gradation 3 achieved through multi-laboratory sampling.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/specimen-inspection-reports"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-conditions-level2",
      "rationale": "Testing performed under a single test condition (room temperature, quasi-static 5 mm/min crosshead speed, standard ASTM F1717 L5-S1 construct geometry). No variation in loading rate, temperature, or construct geometry was explored. This limits the achieved level to Gradation 1. This known gap is acknowledged in the overall credibility argument; the shortfall is offset by the strength of other factors and the conservative nature of the single condition tested (worst-case construct geometry per ASTM F1717). The overall credibility assessment remains acceptable at Medium assurance level per Table 5 of ASME V&V 40-2018.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/test-protocol-astm-f1717",
      "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026/factor/test-conditions"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/equivalency-inputs-level2",
      "rationale": "Boundary conditions in the FEA model replicate the ASTM F1717 fixture geometry: inferior block fully constrained, superior block loaded at 5 mm/min via prescribed displacement with lateral and rotational freedom. Loading angle, block separation distance (L=64 mm), and grip conditions match the physical test setup as documented in the test protocol and fixture engineering drawings. CMM verification of actual block separation confirmed within 0.5 mm of nominal. Gradation 3 achieved.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/fixture-engineering-drawings"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/output-comparison-level3",
      "rationale": "Quantitative comparison performed using the ASME V&V 40 validation metric E/uval for all three QoIs: stiffness (E/uval=0.81), yield force (E/uval=1.14), force at 40mm (E/uval=1.52). All values below the pre-established threshold of 1.96 (95% confidence interval). Percentage differences all below 10% threshold. Comparison includes both systematic and random components of experimental uncertainty (load cell calibration ±0.5%, displacement transducer ±0.2%, specimen variability). Gradation 3 achieved.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/output-comparison-statistical-analysis"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/qoi-relevance-level3",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are directly specified by ASTM F1717 as the required outputs for pedicle screw construct characterization and are the quantities used in the regulatory submission. Stiffness captures elastic behavior relevant to load sharing; yield force captures onset of permanent deformation; force at 40 mm captures post-yield structural integrity. All three QoIs are directly linked to the clinical risk of construct failure leading to revision surgery. Gradation 3 achieved.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/qoi-clinical-rationale"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/validation-relevance-level3",
      "rationale": "The validation activity directly replicates the COU: the same FEA modeling framework, the same non-cannulated 7.5 mm screw design, the same ASTM F1717 test configuration, and the same three QoIs used in the regulatory decision. The validation is not a surrogate or analog study — it is a direct comparison of the model predictions against physical tests of the actual device. The two-laboratory design strengthens the validation by demonstrating reproducibility across independent testing facilities. Gradation 3 achieved.",
      "evidenceSource": "https://uofa.net/nagaraja/evidence/validation-cou-mapping-document"
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for COU1 (non-cannulated pedicle screw compression-bending FEA) is Accepted at Medium assurance level. Of the 13 V&V 40 factors assessed, 12 meet or exceed their required gradation levels. The single shortfall — Test conditions (required Gradation 2, achieved Gradation 1) — is acknowledged and documented. Per ASME V&V 40-2018 Table 5 guidance for Model Risk Level 3 with Medium model influence and Medium decision consequence, the required assurance level is Medium. The shortfall in Test conditions is offset by: (1) the conservative nature of the single test condition (worst-case L5-S1 construct geometry per ASTM F1717); (2) the strength of all three quantitative output comparisons (all E/uval < 1.96, all percentage differences < 10%); (3) the multi-laboratory experimental design (N=11 across two independent facilities); and (4) the high achieved levels across model form, model inputs, and validation relevance factors. The provenance chain is complete from raw experimental data through uncertainty quantification to the validation metric. The decision to accept the model as credible for its intended use in the regulatory submission is well-supported by the structured evidence.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "supportingEvidence": [
      "https://uofa.net/nagaraja/validation/stiffness-comparison",
