    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/sqa-level2",
      "rationale": "Ansys Mechanical R2023 R1 is a commercially validated FEA solver with documented V&V test suite, ISO 9001-certified development process, and release notes confirming regression testing. Software version control and build records are archived. Achieved Gradation 3 via independent benchmark suite execution documented in QA report QA-2023-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/code-verification-level2",
      "rationale": "Patch test and single-element benchmarks confirm correct implementation of Hex20 and Tet10 element formulations for linear elastic contact problems. Published Ansys verification manual cases VM-001 and VM-012 reproduced within 0.1% for beam bending and contact pressure. Gradation 2 achieved; meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/discretization-level3",
      "rationale": "Systematic mesh refinement study performed across four mesh densities (coarse to extra-fine). Richardson extrapolation applied to stiffness and yield force QoIs; GCI < 1.2% for all three QoIs on the production mesh. Mesh independence confirmed. Discretization error contribution to combined uncertainty budget is 0.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "This factor addresses iterative solver convergence errors relevant to nonlinear or dynamic analyses requiring iterative time-stepping. The present model is a linear-elastic implicit static analysis solved with a direct sparse solver (SPARSE); no iterative convergence tolerance is involved. Residual norms are machine-precision by construction. Factor is not applicable to this analysis type."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Use error addresses variability introduced when multiple independent analysts set up the same model without prescribed workflow. In this COU the model setup is fully scripted via an Ansys APDL batch script under version control; no analyst-driven GUI interaction is permitted after script lock. The scripted workflow eliminates analyst-to-analyst setup variation, rendering this factor not applicable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-form-level3",
      "rationale": "Linear-elastic continuum FEA with frictional contact (mu=0.2) captures dominant bending and contact mechanics. Sensitivity analysis shows plasticity onset occurs only at peak load beyond the 10% QoI window; elastic assumption introduces <2% error in stiffness and yield force. Geometric nonlinearity assessed via arc-length study; effect <0.5% at target displacement. Model form uncertainty included in uval."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-inputs-level3",
      "rationale": "Material properties (Ti-6Al-4V: E=114 GPa, nu=0.34; UHMWPE block: E=0.69 GPa) sourced from coupon testing of production-lot material (n=5 per material, CV<3%). Screw geometry from certified CMM measurements (tolerance ±0.01 mm). Boundary conditions replicate ASTM F1717 fixture geometry verified against CAD drawings. Input uncertainty propagated via Monte Carlo (n=1000)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-samples-level2",
      "rationale": "N=11 constructs tested across two independent laboratories (Lab A n=6, Lab B n=5) using production-representative screws from the same manufacturing lot. Dimensional inspection confirmed all screws within drawing tolerance. Inter-laboratory variability characterized; CV=4.2% for stiffness. Sample size exceeds minimum for statistical comparison per ASME V&V 40 Table 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-conditions-level3",
      "rationale": "Testing performed strictly per ASTM F1717 at a single loading rate (5 mm/min) and ambient temperature (23±2°C). Only one test condition evaluated; rate sensitivity and temperature effects not characterized. This factor does not meet the required Gradation 3 level and is documented as a known gap. Compensating evidence: loading-rate sensitivity literature data for Ti-6Al-4V indicates <1% stiffness change across physiologically relevant rates.",
      "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2024/factor/test-conditions"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/equivalency-inputs-level3",
      "rationale": "Material properties, geometry, and boundary conditions used in the FEA are traceable to the same production lot and fixture as the physical test specimens. CMM measurements of tested screws fed directly into FEA geometry parameterization. Fixture stiffness characterized experimentally and incorporated as spring boundary condition. Input equivalency between simulation and test is fully documented in equivalency matrix EQM-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/output-comparison-level3",
      "rationale": "Quantitative comparison performed using the ASME V&V 40 E/uval metric. For stiffness: E/uval=0.82 (pass); for yield force: E/uval=1.14 (pass); for force at 40 mm: E/uval=1.31 (pass). All three QoIs satisfy E/uval < 1.96 and percent difference < 10%. Comparison documented in validation report VR-2024-001 with full uncertainty budget decomposition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/qoi-relevance-level3",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly referenced in the 510(k) submission acceptance criteria. These QoIs are mechanistically linked to clinical failure modes (fatigue crack initiation at yield; construct loosening at excessive displacement). QoI relevance to COU is fully documented in requirements traceability matrix RTM-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/validation-relevance-level3",
      "rationale": "The validation activity directly replicates the COU: same screw design (non-cannulated 7.5 mm), same test standard (ASTM F1717), same loading mode (static compression-bending), same FEA modeling framework. No extrapolation beyond validated domain is required for the submission claim. Validation relevance assessed as high; domain gap analysis documented in gap assessment GA-2024-001 with no unmitigated gaps identified."
    }
