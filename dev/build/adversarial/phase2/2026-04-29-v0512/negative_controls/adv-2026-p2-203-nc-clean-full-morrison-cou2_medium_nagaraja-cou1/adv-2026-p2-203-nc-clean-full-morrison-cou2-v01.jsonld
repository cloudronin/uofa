  "hasCredibilityFactor": [
    {
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-sqa",
      "rationale": "The FEA ensemble (Ansys Mechanical 2023 R2, Abaqus 2023, DePuy Synthes in-house solver) is governed by ISO 9001:2015-certified software quality management plans. Each solver version is pinned and archived in a validated software configuration management system. Regression test suites covering all element types and contact formulations used in this model were executed at release and passed with zero failures. Independent code audits were conducted by the respective ISVs and audit reports are archived in the evidence repository. SQA level 5 is fully achieved."
    },
    {
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-code-verification",
      "rationale": "Code verification was performed through comparison against three analytical benchmarks: (1) Timoshenko beam under combined axial and bending loads, (2) Hertzian contact between a sphere and a flat, and (3) elastic-perfectly-plastic bar under monotonic tension. All three solvers reproduce analytical solutions to within 0.1% for linear regimes and within 0.8% at yield onset. Method of Manufactured Solutions (MMS) was additionally applied to the nonlinear contact formulation; observed convergence rates match theoretical orders (quadratic for Newton-Raphson). Code verification is fully documented in archived verification reports and satisfies level 5."
    },
    {
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-discretization",
      "rationale": "A systematic mesh convergence study was conducted on the Morrison COU2 geometry across five refinement levels (element edge lengths 0.8 mm, 0.5 mm, 0.35 mm, 0.25 mm, 0.18 mm at the screw-rod interface). Richardson extrapolation applied to construct stiffness and yield force QoIs yields a grid convergence index (GCI) of 0.4% and 0.6% respectively on the production mesh (0.25 mm). The production mesh contains 1.24 million hexahedral-dominant elements with Jacobian ratios > 0.7 throughout. Temporal discretization for the quasi-static ramp was verified via load-step halving with < 0.2% change in QoIs. Discretization error is bounded and well below the 2% budget allocated in the UQ framework."
    },
    {
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-solver-error",
      "rationale": "Iterative solver convergence was monitored at every load increment; force and displacement residuals converged to < 1e-6 relative tolerance. Cross-solver comparison between Ansys, Abaqus, and the in-house solver shows QoI agreement within 0.9% for all three quantities of interest, confirming that solver-specific numerical errors do not contribute meaningfully to total model uncertainty. Double-precision arithmetic enforced throughout. Achieved level 5 exceeds the required level 4."
    },
    {
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-use-error",
      "rationale": "A documented simulation workflow procedure (SWP-MOR-COU2-v3) specifies all modelling decisions: geometry import tolerances, contact pair definitions, boundary condition application points, material assignment rules, and result extraction scripts. The SWP was reviewed and approved by two independent senior analysts. A blind re-execution by a third analyst using only the SWP produced QoI results within 0.3% of the primary analyst results, demonstrating negligible use-error sensitivity. All deviations from the SWP require documented change control. Use error level 4 is achieved."
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-model-form",
      "rationale": "Model form selection is justified through a structured hierarchical modelling assessment. Three candidate model forms were evaluated: (A) linear elastic, (B) bilinear isotropic hardening, and (C) nonlinear isotropic hardening with Chaboche kinematic hardening. Model form (C) was selected based on lowest Bayesian Information Criterion and best reproduction of the load-displacement curve shape through yield and into post-yield regime. Sensitivity of QoIs to model form was quantified by comparing (B) and (C) predictions: yield force differs by 6.2%, confirming model form choice is consequential and the selected form is superior. Model form uncertainty is explicitly included in the total UQ budget as an additive term estimated at 3% of QoI mean."
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-model-inputs",
      "rationale": "All model inputs were characterised from lot-specific material coupons (N=15 tensile specimens per lot, two lots) and component-level dimensional metrology (CMM measurements on N=6 screws and N=6 rods). Input probability distributions (titanium alloy Ti-6Al-4V elastic modulus: mean 114 GPa, CV 1.8%; yield strength: mean 930 MPa, CV 3.1%; rod diameter: mean 5.50 mm, CV 0.4%) were fitted using maximum likelihood estimation with goodness-of-fit confirmed by Kolmogorov-Smirnov test (p > 0.15 for all inputs). Friction coefficient at screw-rod interface was characterised by dedicated tribology testing (N=8 pairs; mean 0.18, CV 12%). All input distributions are archived in the material characterisation dataset and propagated through the Monte Carlo UQ framework."
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-test-samples",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (Lab 1: N=6; Lab 2: N=5). All constructs were drawn from the same production lot as the material characterisation specimens, ensuring traceability. Dimensional inspection of all test constructs confirmed conformance to nominal geometry within ±0.05 mm. Inter-laboratory reproducibility was assessed via ANOVA: no statistically significant laboratory effect detected (p = 0.31 for stiffness; p = 0.44 for yield force). Sample size justification is documented via a power analysis targeting 80% power to detect a 10% QoI shift at α = 0.05. Achieved level 5 exceeds required level 4."
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-test-conditions",
      "rationale": "Testing was conducted strictly per ASTM F1717-21 at ambient temperature (23 ± 2°C) and humidity (50 ± 10% RH). Load cell calibration was traceable to NIST with calibration certificates current within 12 months. Crosshead displacement was verified against an independent LVDT. Two loading rates (1 mm/min and 5 mm/min) were evaluated in a pilot study (N=3 per rate); no rate sensitivity was detected (p = 0.67), confirming quasi-static assumption. Test fixture alignment was verified with a precision inclinometer prior to each test series. Test conditions are fully documented and reproduced across both laboratories. Required level 4 is met."
    },
    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-input-equivalency",
      "rationale": "A formal input equivalency mapping table was constructed linking every FEA model input to its experimental counterpart or measurement source. Geometric inputs were populated from CMM data of the actual test constructs (not nominal CAD), ensuring the FEA geometry matches the as-tested geometry to within measurement uncertainty. Material inputs were drawn from the same production lot as test constructs. Boundary conditions replicate the F1717 fixture kinematics as confirmed by fixture stiffness measurements incorporated as elastic foundation boundary conditions. No assumed or estimated inputs were used without documented uncertainty assignment. Equivalency is fully established at level 5."
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-output-comparison",
      "rationale": "Output comparison uses the ASME V&V 40 validation metric E/uval for all three QoIs. Validation uncertainty uval combines experimental measurement uncertainty (Type A and B), model input uncertainty (propagated via Monte Carlo), and numerical error budget. Results: stiffness E/uval = 0.87; yield force E/uval = 1.12; force at 40 mm E/uval = 1.31. All three values are below the pre-established acceptance threshold of 1.96 (95% confidence). Additionally, the mean absolute relative error is below 10% for all QoIs. Graphical comparison of full load-displacement curves shows excellent agreement in both linear and post-yield regimes. Output comparison is fully documented and satisfies level 5."
    },
    {
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-qoi-relevance",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — were selected through a structured QoI selection workshop involving biomechanical engineers, regulatory affairs, and clinical consultants. Construct stiffness directly maps to in vivo load sharing and adjacent segment mechanics. Yield force is the primary failure mode indicator for the regulatory submission. Force at 40 mm displacement characterises post-yield energy absorption relevant to fatigue life prediction. All three QoIs are explicitly listed in the ASTM F1717 standard as required reporting metrics. Traceability from COU decision to QoI selection is documented in the QoI justification report. Achieved level 5 exceeds required level 4."
    },
    {
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-cou2-validation-relevance",
      "rationale": "Validation activities were designed to directly replicate the COU conditions. The experimental constructs use the same non-cannulated 7.5 mm pedicle screw design, the same rod diameter and material, and the same F1717 test configuration as the intended regulatory submission. Testing was performed at two independent laboratories to assess reproducibility, which is directly relevant to the multi-site manufacturing context of the COU. The validation domain fully encompasses the COU operating space: applied load range, geometric configuration, and material lot. No extrapolation beyond the validated domain is required for the COU decision. Validation relevance is fully established at level 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The Morrison COU2 credibility assessment at Model Risk Level 5 is accepted on the following evidentiary basis. All 13 ASME V&V 40 credibility factors have been assessed; no factor is below its required level. Specifically: (1) Software quality assurance, Numerical code verification, Model form, Model inputs, Equivalency of input parameters, Output comparison, and Relevance of validation activities to the COU all achieve level 5 against a required level of 5. (2) Numerical solver error achieves level 5 against a required level of 4, providing additional margin. (3) Use error and Test conditions achieve level 4 against a required level of 4. (4) Test samples, Relevance of QoIs, and Discretization error achieve level 5 against required levels of 4 or 5. The quantitative validation metric E/uval is below 1.96 for all three QoIs (stiffness 0.87, yield force 1.12, force at 40 mm 1.31), and mean absolute relative errors are below the 10% pre-established acceptance bound. Full UQ propagation via Monte Carlo (N=10 000) and global Sobol sensitivity analysis are documented and linked. The provenance chain is complete from raw experimental data through material characterisation, mesh convergence, and cross-solver verification to final QoI comparison. No weakeners are identified. The model is credible for use in the regulatory submission supporting the non-cannulated 7.5 mm pedicle screw design at the specified COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
