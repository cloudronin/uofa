  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-level3",
      "rationale": "CFD solver (OpenFOAM v9) operates under a documented software quality plan including version control, regression test suite (450 cases), and release qualification. SQA level 3 achieved and meets MRL-5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-level3",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver and the power-law hemolysis transport equation. Observed order of convergence matches theoretical order (1.98 vs 2.0 expected). Code verification level 3 confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-level3",
      "rationale": "Richardson extrapolation performed on three systematically refined meshes (2.1M, 8.4M, 33.6M cells). GCI for hemolysis index < 2.1% on fine mesh. Exceeds level-3 threshold; achievedLevel 4 recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-level3",
      "rationale": "Bench experiments conducted at 37 °C with porcine blood at physiological hematocrit (40 ± 2%). Five operating points (flow 3–7 L/min, speed 2400–3600 RPM) replicate the COU operating envelope. Test conditions level 3 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-level3",
      "rationale": "Normalised hemolysis index predictions compared against experimental measurements at all 5 operating points. Mean absolute percentage error 8.3%; within the ±15% acceptance band defined for level 3. U_num and U_exp propagated through comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-level2",
      "rationale": "Primary QoI is the normalised index of hemolysis (NIH) which is the regulatory-accepted metric for blood damage in VAD submissions. Direct mapping between computational output and clinical endpoint confirmed by domain expert review. Level 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-level3",
      "rationale": "Validation experiments performed on the same FDA generic centrifugal pump geometry, at the same operating conditions as the COU, using the same hemolysis measurement protocol (modified Harboe method). Geometric and operational similarity score 0.91/1.0. Level 3 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Numerical solver error as a standalone factor (distinct from discretization error) applies specifically to iterative solvers with non-convergent residual histories. The steady-state SIMPLE algorithm converges to residuals below 1e-6 for all variables with no oscillatory behaviour; iterative solver error is subsumed within the discretization error assessment above and is not separately quantifiable. This factor is therefore not applicable to this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Use error as defined in ASME V&V 40 pertains to operator-induced errors in applying the simulation tool in a clinical or end-user context (e.g., patient-specific model setup by clinicians). This COU involves a controlled engineering analysis performed exclusively by trained CFD analysts under a documented simulation governance plan; there is no end-user-operated simulation workflow. The factor is not applicable to this engineering credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-level3",
      "rationale": "Turbulence model (SST k-omega) selected based on published benchmark comparisons for internal rotating flows. Power-law hemolysis model (Giersiepen-Wurzinger) validated against in-vitro shear exposure data. Sensitivity study on turbulence model choice shows NIH variation < 5%. Model form level 3 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-level3",
      "rationale": "All boundary conditions (inlet flow rate, outlet pressure, rotational speed, blood viscosity, hematocrit) characterised with uncertainty bounds from experimental measurement. Monte Carlo UQ sweep (500 LHS samples) propagates input uncertainties to NIH output. 95th-percentile NIH remains below clinical threshold. Level 3 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Test samples as a credibility factor addresses variability in physical test specimens (e.g., patient tissue samples, device lots). This validation campaign uses a single precision-machined FDA generic pump geometry with dimensional tolerances verified by CMM (< 0.05 mm). There is no specimen-to-specimen variability to characterise; the factor is not applicable to a single-geometry in-vitro hemolysis study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "rationale": "Equivalency of input parameters applies when validation experiments are conducted on a surrogate or scaled geometry requiring parameter mapping back to the COU geometry. In this assessment, the validation experiments and the COU simulations use the identical FDA generic centrifugal pump geometry at the identical operating conditions; no geometric scaling or parameter equivalency mapping is required. The factor is therefore not applicable."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors achieved levels meeting or exceeding required levels for Model Risk Level 5. Three factors (Numerical solver error, Use error, Test samples, Equivalency of input parameters) were determined not-applicable with explicit documented rationale grounded in the specific characteristics of this COU: (1) solver convergence is subsumed in discretization error; (2) no end-user simulation workflow exists; (3) single precision-machined geometry eliminates specimen variability; (4) no surrogate geometry requires parameter mapping. The four not-applicable determinations are conservative and do not inflate the credibility assessment. Monte Carlo UQ confirms 95th-percentile NIH predictions remain below the absolute clinical hemolysis threshold across all five operating points. Provenance chain is complete from raw experimental measurements through validation activities to this decision record. The credibility body of evidence is sufficient to support regulatory submission for the Class III VAD indication.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
