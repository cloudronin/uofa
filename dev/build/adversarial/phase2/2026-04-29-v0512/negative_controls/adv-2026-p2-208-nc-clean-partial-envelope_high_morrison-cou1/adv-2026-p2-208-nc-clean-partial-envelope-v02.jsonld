  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted as credible for the declared COU at MRL 2. Evidence basis: (1) All 7 assessed credibility factors meet or exceed required levels: software QA (2≥1), code verification (2≥1), discretization error (2≥2), test conditions (2≥2), output comparison (2≥2), QoI relevance (2≥2), validation relevance (2≥2). (2) Six factors scoped out with documented rationale consistent with MRL 2 requirements. (3) Operating envelope explicitly bounded (flow 2–6 L/min, speed 2000–3500 RPM, hematocrit 35–45%, temperature 34–37°C) with applicability constraint documented. (4) Validation coverage is honest: sparse at envelope boundaries (2 L/min, 3500 RPM) with 12% RH over-prediction at worst-case boundary point, within experimental uncertainty band of ±15% and conservative in direction (over-prediction supports worst-case identification). Interior operating points show mean 6.3% deviation. (5) GCI study confirms discretization error 2.1% on production mesh. (6) Provenance chain complete: all ValidationResults linked to source datasets, generating activities, and uncertainty quantification. The combination of bounded applicability declaration, honest gap acknowledgment, and conservative bias direction at boundaries provides adequate credibility for the Class II CPB device decision at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
