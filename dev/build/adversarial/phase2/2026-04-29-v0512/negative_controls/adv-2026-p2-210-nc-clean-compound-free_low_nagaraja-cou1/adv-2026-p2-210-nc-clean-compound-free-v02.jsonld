  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-f1717-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending has been assessed against all 13 ASME V&V 40 credibility factors at the Medium model risk level. Twelve of thirteen factors meet or exceed their required gradation levels. The single shortfall — Test conditions achieving Gradation 1 against a required Gradation 2 — is accepted because: (1) the single test condition evaluated is the exact condition specified in the COU, providing direct rather than analogous evidence; (2) all three QoIs satisfy the pre-specified acceptance bounds with E/uval values of 0.87, 1.12, and 1.43, all below the 1.96 threshold; (3) the output comparison factor achieved Gradation 3, providing additional confidence margin; and (4) the overall evidence body, including two independent laboratories and N=11 constructs, supports the conclusion that the model is fit for purpose. The decision is Accepted at Medium assurance level, consistent with the Medium model influence and Medium decision consequence characterization of this COU.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "hasOffsetRationale": {
      "id": "https://uofa.net/synth/decision/dr-noncannulated-f1717-accepted/offset/test-conditions",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/synth/decision/dr-noncannulated-f1717-accepted/factor/test-conditions",
      "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
    }
  },
