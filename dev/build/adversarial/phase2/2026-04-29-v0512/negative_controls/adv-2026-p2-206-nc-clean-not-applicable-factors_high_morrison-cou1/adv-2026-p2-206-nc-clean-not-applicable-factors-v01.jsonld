  "signature": "ed25519:c26feb20acd254306fce99e7c3a82b76494d0cbc514f1ed6c03447e76a1ebff042a45e70bdbe83b5ef5c5b9b6fc6cbc28c5b839a48b2adb95e6f44b1ed5c0d09",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-mrl2-class2",
      "rationale": "ANSYS Fluent 2023 R2 is a commercially validated solver with documented QA procedures including regression test suites and version-controlled configuration management. The solver vendor's ISO 9001-certified development process satisfies MRL 2 SQA requirements. Internal CFD group SOP-CFD-007 mandates solver version locking and input-deck archival for all regulatory submissions. Achieved level 2 exceeds the required level 1 for this MRL 2 COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-mrl2",
      "rationale": "Method-of-manufactured-solutions (MMS) verification was performed for the incompressible Navier-Stokes solver kernel using a prescribed sinusoidal velocity field. Observed spatial order of accuracy (1.97 ± 0.04) is consistent with the nominal second-order finite-volume discretization. Results are documented in validation result VR-numerical-solver-verification and archived in the project repository under tag v3.1.0-mms. This satisfies gradation 2 code verification requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-mrl2",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 4.2 M, 11.8 M, and 31.4 M polyhedral cells. Richardson extrapolation yielded a Grid Convergence Index (GCI) of 2.1% for the volume-averaged scalar stress proxy used in the hemolysis power-law model. The GCI is well below the 5% threshold established in the acceptance criteria. Achieved level 3 reflects the quantified, bounded discretization error with demonstrated asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-mrl2",
      "rationale": "Iterative convergence was monitored for all simulations using normalized residuals. All continuity and momentum residuals dropped below 1×10⁻⁵ before solution extraction; energy residuals (for viscous dissipation post-processing) reached 1×10⁻⁷. A double-precision solver was employed throughout to suppress round-off accumulation. Solver error is bounded and documented per MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-mrl2",
      "rationale": "The SST k-ω turbulence model was selected based on published benchmark comparisons for confined rotating flows and internal pump geometries. The Giersiepen-Wurzinger power-law hemolysis model is the accepted industry standard for CFD hemolysis prediction in rotary blood pumps. Model form uncertainty was assessed via comparison against the PIV velocity field validation dataset (VR-PIV-velocity-comparison); mean velocity magnitude agreement within 8% across the measurement domain is consistent with MRL 2 model form requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-mrl2",
      "rationale": "Blood rheology was characterized using a Carreau non-Newtonian model parameterized from published viscometry data for porcine blood at 37°C (hematocrit 35%). Pump geometry was reconstructed from FDA-released CAD files with dimensional verification against nominal drawings (tolerance ±0.05 mm). Inlet boundary conditions (flow rate, velocity profile) were derived from the 5-point flow-speed test matrix. All input parameters are traceable to the archived dataset bindsDataset entries. Sensitivity analysis confirmed that ±10% variation in Carreau parameters produces <3% change in predicted RH index."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-mrl2",
      "rationale": "Predicted relative hemolysis index (RH) was compared against bench measurements at all 5 operating points. The mean absolute percentage error across operating points was 9.3% with a maximum of 14.1% at the highest shear-stress operating condition. Combined measurement and model uncertainty intervals overlap at all points. Pressure head predictions agree within 4.2% of bench data. The quantitative output comparison with uncertainty banding satisfies gradation 3 requirements and is fully documented in validation results VR-RH-index-bench and VR-pressure-head."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-na-mrl2",
      "rationale": "The Test Conditions factor addresses the degree to which experimental test conditions replicate the clinical use environment for the purpose of validating the computational model. In this COU, the validation experiments (PIV and bench hemolysis) were conducted under controlled laboratory conditions using the FDA-specified test protocol, which is the normative reference environment for Class II CPB device submissions. The COU does not require extrapolation beyond the tested operating envelope; all 5 flow-speed combinations lie within the validated experimental matrix. Because the test conditions ARE the reference standard for this device class and no gap exists between the experimental and COU environments, the factor does not provide additional discriminating information beyond what is already captured in Output Comparison (VR-RH-index-bench) and Relevance of Validation Activities. Marking as not-applicable is consistent with ASME V&V 40-2018 §6.4 guidance that factors need not be scored when they are subsumed by other assessed factors and no residual scope gap exists. This determination was reviewed and concurred by the independent credibility assessment reviewer on 2026-03-14."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-na-mrl2",
      "rationale": "Test Samples addresses variability in physical specimens used for validation experiments. The FDA generic centrifugal blood pump is a standardized reference geometry with a single nominal design; there is no sample-to-sample geometric variability because all validation experiments used the same precision-machined pump housing produced from the FDA-released CAD master. Blood analog fluid (glycerin-water mixture for PIV; porcine blood for hemolysis bench) was prepared from a single batch per test campaign per established protocol. Sample variability is therefore not a source of uncertainty in this COU and the factor is not applicable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/relevance-qoi-na-mrl2",
      "rationale": "Relevance of Quantities of Interest is designed to assess whether the modeled output quantities adequately represent the clinical or engineering quantities that drive the regulatory decision. In this COU, the primary quantity of interest — the relative hemolysis index (RH) — is directly the regulatory acceptance criterion (RH < 1) and is identically the output extracted from both the CFD model and the bench validation experiments. There is a one-to-one correspondence between the computational QoI and the decision-driving metric; no surrogate or proxy QoI is involved. The relevance is therefore self-evident and does not require a separate graduated assessment. This factor is not applicable under these circumstances per MRL 2 scoping guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/relevance-validation-na-mrl2",
      "rationale": "This factor evaluates the degree to which the validation activities (geometry, operating conditions, fluid properties, boundary conditions) match the intended COU. The validation experiments were performed on the identical FDA generic pump geometry, at the identical 5 flow-speed operating points constituting the COU test matrix, using the identical blood analog and porcine blood fluids specified in the COU protocol. There is no extrapolation from the validation domain to the COU domain. Because the validation activities are co-extensive with the COU by design, this factor is fully satisfied by construction and does not require a separate graduated score; it is not applicable as a discriminating assessment dimension at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-na-mrl2",
      "rationale": "Use Error addresses the potential for operator error in applying the computational model to produce incorrect results. This COU involves a single, version-controlled simulation workflow executed by trained CFD engineers under SOP-CFD-007, with mandatory independent review of all input decks and post-processing scripts prior to results extraction. The workflow is automated via a validated Python orchestration layer (v2.4.1, regression-tested) that eliminates manual data-transfer steps. Given the controlled, SOP-governed execution environment and the automated workflow, residual use-error risk is below the MRL 2 threshold for explicit factor assessment. The factor is not applicable in this operational context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/equivalency-inputs-na-mrl2",
      "rationale": "Equivalency of Input Parameters assesses whether the input parameters used in the validation simulations are equivalent to those applicable in the COU. As documented under Model Inputs, the validation simulations used identical boundary conditions, geometry, and fluid properties to those defined for the COU operating envelope. No parameter transformation, scaling, or extrapolation was required between the validation and COU contexts. The equivalency is established by design rather than by assessment, and the factor therefore provides no additional discriminating information at MRL 2. Not applicable."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for the FDA generic centrifugal blood pump under CPB conditions, MRL 2, Class II) is accepted based on the following structured evidence review. Seven credibility factors were assessed and all meet or exceed their required gradation levels: Software Quality Assurance (achieved 2, required 1), Numerical Code Verification (achieved 2, required 1), Discretization Error (achieved 3, required 2), Numerical Solver Error (achieved 2, required 1), Model Form (achieved 2, required 2), Model Inputs (achieved 2, required 2), and Output Comparison (achieved 3, required 2). Six factors — Test Conditions, Test Samples, Relevance of QoI, Relevance of Validation Activities, Use Error, and Equivalency of Input Parameters — are marked not-applicable with individually documented rationales. Each not-applicable determination reflects a substantive finding that the factor either provides no discriminating information beyond other assessed factors, is satisfied by construction due to the co-extensive validation design, or is rendered moot by the controlled automated execution environment. The primary regulatory acceptance criterion (RH < 1) is met at all 5 operating points with quantified uncertainty bounds. The provenance chain from raw experimental data through validation results to this decision record is complete and traceable. The independent credibility assessment reviewer concurred with all not-applicable determinations on 2026-03-14. On balance, the structured evidence provides sufficient credibility for the model to support the intended regulatory decision regarding worst-case hemolysis operating conditions for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
