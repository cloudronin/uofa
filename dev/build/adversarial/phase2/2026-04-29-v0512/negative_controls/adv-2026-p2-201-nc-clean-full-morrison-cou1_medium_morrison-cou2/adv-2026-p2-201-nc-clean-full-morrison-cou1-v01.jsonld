  "hasCredibilityFactor": [
    {
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-level2-requirements",
      "rationale": "The CFD solver (OpenFOAM v9) is governed by a documented software quality assurance plan conforming to FDA software guidance. Version control, issue tracking, regression test suite (>200 test cases), and release qualification records are maintained. Achieved Gradation 3 exceeds the Gradation 2 required at MRL 3 for a Class III device.",
      "supportingEvidence": "https://uofa.net/synth/evidence/sqa-plan-openfoam-v9"
    },
    {
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-level2-requirements",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes solver and the power-law hemolysis transport equation. Observed order of convergence (OOC) matches theoretical second-order accuracy to within 5% for all relevant solution variables. Benchmark problems from ASME V&V 20 and FDA CFD round-robin included in regression suite. Achieved Gradation 3.",
      "supportingEvidence": "https://uofa.net/synth/evidence/mms-code-verification-report-2024"
    },
    {
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-level3-requirements",
      "rationale": "Systematic mesh refinement study conducted across three grid levels (coarse 2.1M, medium 5.8M, fine 14.2M cells) following Richardson extrapolation per ASME V&V 20. Grid convergence index (GCI) for NIH < 4.1% on the fine mesh. Temporal discretization verified with three time-step levels; temporal GCI < 1.8%. Achieved Gradation 3 meets required level.",
      "supportingEvidence": "https://uofa.net/synth/evidence/mesh-refinement-study-report-2024"
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-level2-requirements",
      "rationale": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol, pump rotational speed, and flow rate) are fully documented with measurement uncertainty characterization per ISO/IEC 17025. Test conditions span the clinical operating envelope of the VAD (1.5–6.0 L/min, 2000–4000 RPM). Achieved Gradation 3 exceeds requirement.",
      "supportingEvidence": "https://uofa.net/synth/evidence/experimental-test-protocol-2024"
    },
    {
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-level3-requirements",
      "rationale": "Quantitative comparison metrics defined a priori: mean absolute error ≤ 15% for NIH, ≤ 10% for pressure rise, and ≤ 10% normalized RMS for velocity field. All validation results satisfy these pre-specified thresholds. Statistical comparison accounts for experimental measurement uncertainty using Bayesian inference. Achieved Gradation 3.",
      "supportingEvidence": "https://uofa.net/synth/evidence/output-comparison-statistical-analysis-2025"
    },
    {
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-level2-requirements",
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is directly mapped to the clinical endpoint (chronic hemolysis risk) via a documented QoI relevance matrix. Secondary QoIs (shear stress distribution, residence time) are validated as intermediate quantities supporting NIH prediction. Traceability from clinical requirement to model output is fully documented. Achieved Gradation 3.",
      "supportingEvidence": "https://uofa.net/synth/evidence/qoi-relevance-matrix-2024"
    },
    {
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-level3-requirements",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump geometry under operating conditions that span the intended clinical envelope. Blood analogue fluid properties match clinical hematocrit range (35–45%). Geometric similarity between validation hardware and production device is documented (same impeller diameter, blade count, and volute geometry). Achieved Gradation 3 meets required level.",
      "supportingEvidence": "https://uofa.net/synth/evidence/validation-relevance-assessment-2025"
    },
    {
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-level2-requirements",
      "rationale": "Iterative convergence monitored via residual norms; all simulations converged to residuals below 1×10⁻⁶ for momentum and continuity equations, and 1×10⁻⁸ for hemolysis transport scalar. Round-off error assessed via double-precision arithmetic verification. Iterative error contribution to NIH estimated at < 0.5% via Richardson extrapolation on solver tolerance. Achieved Gradation 2 meets required level.",
      "supportingEvidence": "https://uofa.net/synth/evidence/solver-convergence-study-2024"
    },
    {
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-level2-requirements",
      "rationale": "Simulation workflow is governed by a documented simulation plan with mandatory peer review at mesh generation, boundary condition specification, and post-processing stages. Independent analyst reproduction of two representative operating points confirmed consistent NIH results (deviation < 2%). Checklist-based QC procedure documented and archived. Achieved Gradation 3 exceeds requirement.",
      "supportingEvidence": "https://uofa.net/synth/evidence/simulation-plan-and-qc-checklist-2024"
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-level3-requirements",
      "rationale": "Turbulence model selection (SST k-ω) justified by comparative study against LES reference data and experimental PIV for rotating machinery flows. Power-law hemolysis model (Giersiepen-Wurzinger) selected after comparative evaluation of three hemolysis constitutive models; sensitivity of NIH to model form quantified via Monte Carlo sampling over model-form uncertainty parameters. Achieved Gradation 3 meets required level.",
      "supportingEvidence": "https://uofa.net/synth/evidence/model-form-selection-study-2024"
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-level3-requirements",
      "rationale": "All model inputs (geometry, fluid properties, boundary conditions, hemolysis model coefficients) are characterized with probability distributions derived from measurement data and literature meta-analysis. Monte Carlo UQ propagates input uncertainty through the CFD model (N=500 samples via Latin hypercube sampling). Contribution of each input to NIH variance quantified via Sobol sensitivity indices; dominant inputs (hemolysis model exponents, inlet velocity profile) identified and their uncertainty reduced via targeted experiments. Achieved Gradation 3.",
      "supportingEvidence": "https://uofa.net/synth/evidence/model-inputs-uq-report-2025",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-model-inputs-sobol-2025"
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-level2-requirements",
      "rationale": "Validation dataset comprises N=48 independent hemolysis measurements across 8 operating conditions (6 replicates per condition) using porcine blood from three separate donors. Sample preparation, storage, and measurement protocols documented per ASTM F1841. Inter-donor variability characterized and included in experimental uncertainty bounds. Achieved Gradation 3 exceeds requirement.",
      "supportingEvidence": "https://uofa.net/synth/evidence/experimental-sample-characterization-2024"
    },
    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-level2-requirements",
      "rationale": "Correspondence between experimental test conditions and simulation boundary conditions formally documented in an input equivalency matrix. Discrepancies between measured and simulated inlet velocity profiles quantified and shown to produce < 3% difference in NIH via sensitivity analysis. Fluid viscosity and density used in simulation match measured values from test fluid samples (within 1.5%). Achieved Gradation 3 exceeds requirement.",
      "supportingEvidence": "https://uofa.net/synth/evidence/input-equivalency-matrix-2025"
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-vv40-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed. Achieved credibility levels meet or exceed required levels for every factor at Model Risk Level 3. The validation evidence base is comprehensive: hemolysis index predictions agree with in-vitro measurements within pre-specified 15% acceptance criteria across the full clinical operating envelope; velocity field and pressure-rise validations further corroborate model fidelity. Monte Carlo uncertainty quantification (N=500 LHS samples) demonstrates that the 95th-percentile NIH prediction remains below the clinical hemolysis threshold, accounting for model input uncertainty, model form uncertainty, and experimental measurement uncertainty. Software quality assurance, code verification, and use-error controls are documented and exceed minimum requirements. The simulation plan, QC checklist, and independent reproduction study provide confidence that use error is controlled. The validation activities are directly relevant to the clinical COU: geometry, fluid properties, and operating conditions are representative of the intended VAD application. On the basis of this structured evidence, the credibility assessment team concludes that the CFD model is sufficiently credible to support the regulatory submission for hemolysis prediction of the FDA generic centrifugal blood pump under VAD operating conditions. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
