  "hash": "sha256:a004c098d3b13b89a1e74718ef59db46898b84ea1fc688546a8cad70151792de",
  "signature": "ed25519:b2f6994d59dc3fc4ae31838e0ab254dd0675047cd61ec6b10210cf482cf8683b1c2343fcc35c19d9b4124dad3dde10536183c1f79c8c6dee6b0225500e6f5004",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-sqa",
      "rationale": "The FEA solver (Abaqus 2022) is a commercially validated code with documented V&V procedures. Software quality assurance activities include version-controlled model files, documented solver settings, and regression testing against benchmark problems. QA procedures follow FDA guidance on software validation. Achieved Gradation 3: full configuration management with audit trail, independent QA review of all model inputs and outputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-ncv",
      "rationale": "Numerical code verification performed using three established benchmark problems: Hertzian contact, beam bending under large deformation, and hyperelastic cylinder compression. All benchmark results agree with analytical solutions to within 1.2%. Abaqus solver documentation provides additional code verification evidence for contact mechanics and nonlinear material models. Achieved Gradation 3: multiple benchmark comparisons with documented convergence to analytical solutions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-disc",
      "rationale": "Systematic mesh convergence study performed using three mesh densities (coarse: 28k elements, medium: 112k elements, fine: 448k elements) following Richardson extrapolation methodology per Roache (1998). Grid Convergence Index (GCI) for peak contact stress: 2.1% (fine-to-medium ratio); for wear volume: 3.4%. Production mesh uses medium density, achieving GCI < 5% threshold. Time-step sensitivity confirmed with half-step refinement showing < 2% change in cumulative wear. Achieved Gradation 3: formal GCI analysis with documented extrapolated solution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-tc",
      "rationale": "Experimental wear simulator tests conducted per ISO 14243-3 using five-station knee wear simulator with bovine serum lubricant at 37°C. Loading profiles (axial force, flexion angle, anterior-posterior translation, internal-external rotation) match ISO 14243-1 displacement-controlled protocol. Test conditions documented with calibration records for all actuators. Lubricant protein concentration maintained at 20 g/L per standard. Environmental conditions monitored and logged throughout 5 million cycle tests. Achieved Gradation 3: full ISO 14243 compliance with independent laboratory accreditation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-oc",
      "rationale": "Quantitative comparison of FEA predictions against experimental wear simulator data using gravimetric wear volume measurements at 1M, 2M, 3M, and 5M cycles. Mean absolute percentage error 8.2% across five test specimens; 95% prediction interval brackets 4 of 5 experimental data points. Wear distribution pattern compared against retrieval morphology using spatial correlation analysis (r=0.87). Contact stress validated against pressure film measurements. Statistical comparison includes paired t-test (p=0.23, no significant bias) and Bland-Altman analysis confirming limits of agreement within ±15% clinical acceptance band. Achieved Gradation 3: multi-metric quantitative comparison with statistical analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-rqi",
      "rationale": "The primary quantity of interest (QoI) is cumulative volumetric wear of the UHMWPE tibial insert, directly linked to the clinical decision criterion (RW < 1.15 relative to predicate). Secondary QoIs include peak contact stress, contact area, and wear depth distribution — all directly relevant to the failure mode of interest (accelerated wear leading to osteolysis). The Archard-Lancaster wear model output maps directly to the measurable gravimetric wear used in ISO 14243 testing. The QoIs are traceable from device design requirements through the model output to the regulatory acceptance criterion. Achieved Gradation 3: formal traceability matrix linking QoIs to device requirements and clinical endpoints."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-rva",
      "rationale": "Validation activities use the same UHMWPE material (GUR 1020, gamma-irradiated and remelted) and implant geometry as the device under assessment. ISO 14243-3 simulator conditions represent physiological gait loading representative of the intended patient population. Retrieval analysis specimens are from the same implant family with comparable in vivo service conditions. The validation domain (nominal alignment, standard gait) is directly applicable to the COU (identifying worst-case wear across alignment-load combinations). Boundary conditions in validation models match the COU model configuration. Achieved Gradation 3: formal similarity assessment documenting material, geometric, and loading equivalence between validation and COU configurations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-nse",
      "rationale": "Iterative solver convergence monitored at each increment with force and displacement residuals required to be below 0.5% of reference values (Abaqus default tightened by factor of 2). Contact constraint enforcement uses augmented Lagrangian method with penetration tolerance of 0.001 mm. Nonlinear material (Ogden hyperelastic + creep) convergence verified through energy balance checks. Round-off error assessed via double-precision arithmetic throughout; no single-precision operations in critical paths. Solver error contribution estimated at < 0.3% of total numerical error budget. Achieved Gradation 3: documented error budget with quantified solver error contribution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-ue",
      "rationale": "Model setup reviewed by a second qualified analyst independent of the primary modeler. Boundary condition application, material property assignment, and contact pair definitions verified against documented model specification. Input deck version-controlled with diff-checked change log. Pre-processing checklist completed and signed prior to each production run. Post-processing scripts independently validated against hand calculations for representative load cases. Achieved Gradation 2: independent peer review of model setup with documented checklist completion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-mf",
      "rationale": "The Archard-Lancaster wear model is the established standard for UHMWPE knee wear prediction with extensive published validation evidence. Model form selection justified through literature review of five candidate wear models; Archard-Lancaster selected based on superior predictive accuracy for cross-linked UHMWPE under multidirectional sliding. Ogden (N=3) hyperelastic model for UHMWPE validated against uniaxial and biaxial tension test data (R²=0.998). Creep model calibrated from stress-relaxation experiments on the specific material lot. Model form uncertainty quantified through sensitivity analysis showing ±12% wear volume variation across plausible wear coefficient ranges. Achieved Gradation 3: formal model form selection with documented alternatives considered and quantified model form uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-mi",
      "rationale": "All material properties (elastic modulus, Poisson's ratio, Ogden coefficients, wear coefficient k) derived from specimen-level testing of the production material lot with documented uncertainty ranges. Geometric inputs from CMM measurements of production implant components with tolerances. Loading inputs from ISO 14243-1 with documented uncertainty in load cell calibration (±1.5%). Sensitivity analysis (one-at-a-time and Monte Carlo with 10,000 samples) identifies wear coefficient k and contact area as dominant inputs, each contributing < 8% to total output uncertainty at 95% confidence. Input uncertainty propagated to output uncertainty using Latin Hypercube Sampling. Achieved Gradation 3: formal uncertainty propagation from all significant inputs to QoI with ranked sensitivity indices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-ts",
      "rationale": "Five tibial insert specimens tested in ISO 14243-3 wear simulator, all from the same production lot as the device under assessment (same material, sterilization batch, and geometry). Specimen dimensional characterization performed pre- and post-test by CMM. Soak controls included per ISO 14243-3 to correct for fluid absorption. Retrieval analysis cohort of 12 specimens from same implant family with documented in vivo service time (mean 7.3 years, range 4–12 years). Sample size justification documented: power analysis demonstrates 80% power to detect 15% wear volume difference at α=0.05 with n=5 simulator specimens. Achieved Gradation 3: formal sample size justification with power analysis and full specimen traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-ortho-eip",
      "rationale": "Formal equivalency assessment performed between validation test conditions and COU simulation inputs. Loading profiles in validation model match ISO 14243-1 simulator inputs to within measurement uncertainty (< 2% for all force and displacement channels). Material properties used in validation model derived from same material lot as COU model. Geometric fidelity between CAD model and test specimens confirmed by CMM comparison (mean surface deviation 0.04 mm, maximum 0.12 mm). Lubricant conditions (bovine serum, protein concentration, temperature) mapped to in vivo synovial fluid properties with documented equivalency rationale. Equivalency gaps identified for in vivo muscle loading variability; addressed through parametric COU simulations spanning ±20% load magnitude range. Achieved Gradation 3: systematic equivalency matrix with documented gap analysis and mitigation for all identified differences."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-ortho-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The UnitOfAssurance for COU1 (total knee replacement tibial insert wear prediction at MRL 3) is accepted based on the following structured evidence review: (1) All 13 ASME V&V 40-2018 credibility factors have been formally assessed. Seven factors with required level 3 have achieved level 3 or above; six factors with required level 2 have achieved level 2 or above. No factor falls below its required level. (2) Validation evidence (ValidationResults VR-01 through VR-03) demonstrates model predictive accuracy within the 15% acceptance band for cumulative wear volume (mean error 8.2%), with no statistically significant bias (Bland-Altman analysis, paired t-test p=0.23). Spatial wear distribution validated against retrieval morphology (r=0.87). Contact stress validated against pressure film measurements (peak error 6.4%). (3) Discretization error is formally bounded via Richardson extrapolation and GCI analysis (GCI < 5% for all QoIs). Model form uncertainty is quantified (±12% wear volume) and is within the acceptance band. Input uncertainty propagation via Monte Carlo confirms total output uncertainty at 95% confidence is ±14.3%, within the ±15% clinical acceptance criterion. (4) The validation domain is directly applicable to the COU: same material lot, same implant geometry, ISO 14243-compliant loading, and formal equivalency assessment with documented gap mitigation. (5) Software QA, use error controls, and numerical solver error are all at or above required levels, providing confidence in the reliability of computational results. (6) The primary decision criterion (RW < 1.15 relative to predicate device) is met across all six alignment-load combinations assessed in the COU parametric study, with the worst-case combination (5° varus, 10% increased tibial slope) yielding RW = 1.09. The credibility assessment team concludes that the computational model has sufficient credibility for the intended use and that the evidence base supports the regulatory submission claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
