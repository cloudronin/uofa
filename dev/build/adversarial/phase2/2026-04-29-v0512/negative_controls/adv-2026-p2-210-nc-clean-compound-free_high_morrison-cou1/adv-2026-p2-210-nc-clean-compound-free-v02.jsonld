  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) All seven assessed credibility factors meet or exceed their required levels. Discretization error achieves Level 3 against a Level 2 requirement, providing additional confidence in numerical accuracy. (2) Six factors are appropriately scoped out per ASME V&V 40 Table 3 guidance for MRL 2, with documented rationale for each. (3) Validation evidence demonstrates hemolysis index prediction within 8.3% mean absolute error against the pre-specified 15% acceptance criterion, with no systematic directional bias. (4) Pressure-flow curve validation confirms hydraulic model accuracy within 4.1% across the operating envelope. (5) The validation dataset spans all five clinical operating points, ensuring adequate coverage of the COU decision space. (6) Uncertainty quantification is complete for all validation results, with provenance traceable to foundational experimental data. (7) The relative hemolysis index acceptance criterion (RH < 1) is grounded in FDA guidance and predicate device comparison methodology. The totality of evidence supports the conclusion that the CFD model has sufficient credibility for its intended use in identifying worst-case hemolysis operating conditions for the Class II CPB device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
