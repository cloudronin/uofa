  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the tibial tray FEA model under COU1 (worst-case stress identification for Class II TKR device at MRL 3) is accepted based on the following structured evidence: (1) All 13 V&V 40 credibility factors have been assessed with achieved levels meeting or exceeding required levels for MRL 3. (2) Validation against cadaveric strain gauge measurements demonstrates MAPE of 4.2% across 18 test configurations, well within the pre-specified 10% acceptance threshold. Validation uncertainty U95=±6.1% is accounted for in the acceptance determination. (3) Discretization error is rigorously bounded at <1% via Richardson extrapolation with confirmed asymptotic convergence. (4) Model input uncertainty quantified via Monte Carlo analysis confirms 95th percentile stress response remains below the NSR acceptance criterion of 1.15. (5) Validation domain fully encompasses the COU loading envelope with no extrapolation required. (6) Independent model rebuild confirms reproducibility within 0.4%. (7) Software quality assurance and use error controls are documented and verified. The totality of evidence supports the conclusion that the FEA model provides sufficient credibility for its intended use in identifying worst-case tibial tray stress concentrations to support device geometry tolerance decisions for the Class II TKR implant.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
