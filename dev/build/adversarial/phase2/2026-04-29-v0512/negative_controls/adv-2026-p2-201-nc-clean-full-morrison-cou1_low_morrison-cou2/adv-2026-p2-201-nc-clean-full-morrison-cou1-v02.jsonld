  "signature": "ed25519:9e9302608a8a05000b321dc1a1de80d285cc181ec59d4a721d0892d1c75808fd4c9074f660a09e3a9bc7d925ca269997e92aea2211902547eefce2d446dc5000",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-criteria",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under a documented software quality assurance plan that includes version-controlled source management, automated regression testing against 47 canonical benchmarks, and a formal defect-tracking process. All simulation runs were executed from a tagged release. SQA documentation was reviewed by an independent assessor and found to satisfy Gradation 3 requirements for a Class III device application. Build reproducibility was confirmed by re-running three representative cases on an independent compute cluster and obtaining bit-for-bit identical results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-criteria",
      "rationale": "Code verification was performed using the Method of Manufactured Solutions (MMS) for the incompressible Navier-Stokes solver and the scalar transport equation used to carry the hemolysis damage accumulation variable. Observed order of accuracy for velocity (2.01) and pressure (1.97) matched theoretical second-order expectations within 2%. The passive scalar transport equation achieved 1.94 order of accuracy. All MMS residuals converged to machine precision. Results are documented in the solver verification report archived at the institutional repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-criteria",
      "rationale": "A formal three-level grid convergence study was conducted following the Richardson Extrapolation methodology prescribed in ASME V&V 20. Grids of 4.1 M, 11.3 M, and 28.7 M hexahedral cells were used. The Grid Convergence Index (GCI) for NIH at the design operating point was 1.8%, well below the 5% threshold for Gradation 3. The fine-grid GCI for velocity magnitude at the impeller outlet plane was 0.9%. Temporal discretization error was assessed via three time-step refinement levels; the Courant-number-based criterion was satisfied at CFL < 0.5 on the production mesh. Achieved level is reported as 4 because GCI values and extrapolated exact solutions were formally documented with uncertainty bounds, exceeding the minimum Gradation 3 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-criteria",
      "rationale": "Bench test conditions for both PIV and hemolysis experiments were documented to ISO 17665 traceability standards. Flow rates were measured with Coriolis mass flowmeters calibrated to NIST-traceable standards (uncertainty ±0.3%). Rotational speed was measured with an optical tachometer (uncertainty ±1 RPM). Blood analog fluid (glycerin-water at 40% by weight) temperature was controlled to ±0.5 °C throughout each run. All five operating points used in CFD validation were replicated in the experimental campaign. Inlet turbulence intensity and hydraulic diameter were measured and imposed as CFD boundary conditions, ensuring direct correspondence between simulation and test."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-criteria",
      "rationale": "Quantitative output comparison was performed using the validation metric defined in ASME V&V 20 Section 5. For NIH, the area validation metric U_val was computed at each of the five operating points; all values were below the model acceptance threshold of 0.15. Velocity field comparisons used the L2-norm of the point-wise difference normalized by the bulk velocity; maximum value across all planes and operating points was 0.042. Pressure-head curve RMS deviation was 3.8%. Uncertainty in experimental measurements was propagated through the comparison metric using Monte Carlo sampling, confirming that the validation metric remained below the threshold even at the 95th percentile of experimental uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-criteria",
      "rationale": "The primary quantity of interest (QoI) is the normalized index of hemolysis (NIH) averaged over the full pump operating envelope. This QoI is directly linked to the clinical decision criterion (NIH < 0.01 g/100 L). Secondary QoIs include shear-stress exposure time distributions and recirculation zone volumes, which are mechanistically connected to hemolysis through the power-law damage accumulation model. A formal QoI relevance matrix was prepared mapping each modeled output to the regulatory acceptance criterion, confirming that the selected QoIs are necessary and sufficient for the intended regulatory submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-criteria",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the regulatory submission. Operating conditions span the full clinical envelope (flow: 2–6 L/min, speed: 2500–4500 RPM), encompassing all five COU operating points. The blood analog fluid replicates the viscosity and density of anticoagulated human blood at 37 °C to within 2%. A relevance assessment matrix was completed per ASME V&V 40 Appendix B, scoring geometric, material, loading, and boundary condition similarity; all categories rated High or Medium-High."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-criteria",
      "rationale": "Iterative convergence was monitored via normalized residuals for all transport equations. All simulations were run until residuals dropped below 1×10⁻⁶ for continuity and momentum and 1×10⁻⁷ for the hemolysis scalar. Iterative error was estimated by comparing solutions at 1×10⁻⁵ and 1×10⁻⁶ convergence levels; the difference in NIH was less than 0.3%. Round-off error was assessed by running representative cases in double and extended precision; differences were below 0.01%. Linear solver tolerances and preconditioner settings are documented in the simulation input archive."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-criteria",
      "rationale": "A documented simulation execution protocol was followed for all production runs, including a pre-simulation checklist covering geometry import, mesh quality checks (minimum orthogonality > 10°, maximum non-orthogonality < 70°, maximum skewness < 4), boundary condition assignment, and turbulence model selection. An independent analyst re-ran two of the five operating-point simulations using only the archived protocol and input files, obtaining NIH values within 0.5% of the original results. The execution protocol and independence check are archived in the project quality record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-criteria",
      "rationale": "The turbulence model (SST k-ω) was selected based on a comparative study of five RANS closures against the FDA benchmark PIV dataset; SST k-ω produced the lowest L2 velocity error (4.2%) and best captured the recirculation zone downstream of the impeller. The power-law hemolysis model (Giersiepen-Wurzinger coefficients) was selected after reviewing five published hemolysis model formulations; the chosen model produced the smallest systematic bias against bench NIH data across the operating envelope. Model form uncertainty was estimated by running all five turbulence models and both primary hemolysis model variants; the resulting NIH spread was used as a model-form uncertainty contribution in the Monte Carlo UQ analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-criteria",
      "rationale": "All model input parameters were assigned probability distributions based on measurement uncertainty reports and literature data. Fluid viscosity distribution was derived from 30 repeat viscometer measurements of the blood analog at 37 °C (CV = 1.2%). Inlet velocity profiles were derived from PIV measurements with propagated uncertainty. Hemolysis model coefficients were assigned log-normal distributions based on the published coefficient uncertainty ranges reported by Giersiepen et al. and Zhang et al. Sobol first-order and total-order sensitivity indices were computed for all 14 input parameters; the top four contributors (rotational speed, power-law exponent, power-law coefficient, and inlet flow rate) accounted for 91% of NIH output variance. Inputs are archived with full traceability to calibration records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-criteria",
      "rationale": "Hemolysis bench tests were conducted on five replicate pump specimens machined to drawing tolerance from the same material batch. Each specimen was tested in triplicate at each of the five operating points, yielding 75 NIH measurements in total. Inter-specimen variability (CV = 3.1%) and intra-specimen repeatability (CV = 1.8%) were quantified and incorporated as experimental uncertainty contributions in the validation metric calculation. Specimen dimensional inspection records confirm all critical tolerances were met. The sample size was determined by a formal power analysis targeting 80% power to detect a 10% difference in mean NIH at α = 0.05."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-criteria",
      "rationale": "A parameter equivalency assessment was conducted comparing the CFD simulation input space to both the validation experiment input space and the intended clinical COU input space. For each of the 14 input parameters, the ratio of the simulation nominal value to the experimental nominal value was computed; all ratios fell within ±5% of unity. The clinical operating envelope (flow: 2–6 L/min, speed: 2500–4500 RPM) is fully contained within the validated operating envelope. Fluid properties used in simulation match the blood analog fluid to within 2% for viscosity and 0.5% for density. A formal equivalency matrix table is included in the credibility assessment report."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cred-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed. In every case the achieved credibility level meets or exceeds the required level for a Model Risk Level 3 Class III device application. Software quality assurance (3/3), code verification (3/3), and discretization error (4/3) establish a sound computational foundation. Test conditions (3/2), test samples (3/2), and equivalency of input parameters (3/2) confirm that the experimental evidence is directly applicable to the COU. Output comparison (3/3) and relevance factors (3/3 each) confirm that the validation activities are fit for purpose. Model form (3/3) and model inputs (4/3) demonstrate that physical and parametric uncertainties have been rigorously characterized. Numerical solver error (3/3) and use error (3/3) confirm that execution errors are negligible. Monte Carlo uncertainty quantification demonstrates that the 95th-percentile NIH prediction remains below the clinical acceptance threshold of 0.01 g/100 L. The provenance chain from raw experimental data through validation results to this assessment is complete and traceable. The credibility assessment team unanimously accepts this model for the stated context of use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
