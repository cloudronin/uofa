  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026-04",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and each achieves a level at or above its required level for Model Risk Level 3. Software quality assurance (achieved 3, required 2), numerical code verification (achieved 3, required 2), discretization error (achieved 3, required 3), test conditions (achieved 3, required 2), output comparison (achieved 3, required 3), relevance of QoIs (achieved 3, required 2), relevance of validation activities (achieved 3, required 3), numerical solver error (achieved 2, required 2), use error (achieved 3, required 2), model form (achieved 3, required 3), model inputs (achieved 3, required 3), test samples (achieved 3, required 2), and equivalency of input parameters (achieved 3, required 2). Monte Carlo uncertainty quantification (1000 samples) demonstrates that the 95th-percentile NIH prediction remains below the clinical threshold at all 5 COU operating points. Validation metric E is within the combined experimental-numerical uncertainty band at all operating points per ASME V&V 20. The provenance chain is complete from raw experimental data through processing activities to validation results. All simulation input files, execution procedures, and QA records are archived and traceable. The credibility evidence is sufficient to support the intended use of the CFD model for regulatory submission. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
