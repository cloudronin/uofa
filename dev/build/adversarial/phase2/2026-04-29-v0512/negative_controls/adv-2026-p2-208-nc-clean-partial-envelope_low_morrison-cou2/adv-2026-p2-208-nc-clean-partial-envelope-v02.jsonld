  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-criteria-001",
      "rationale": "The CFD solver (OpenFOAM v9) is under version-controlled software quality assurance. A documented SQA plan covers source control (Git, tagged releases), automated regression testing (250 test cases), and build verification. The hemolysis post-processing module has independent unit tests with 98% branch coverage. SQA documentation reviewed and found compliant with ASME V&V 40 Gradation 3 requirements for MRL 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-criteria-001",
      "rationale": "Numerical code verification performed using three analytical benchmark problems: (1) Hagen-Poiseuille flow in a straight tube — velocity profile L2 error < 0.1%; (2) lid-driven cavity at Re=1000 — centerline velocity within 0.5% of Ghia et al. reference; (3) rotating disk pumping — torque prediction within 1.2% of analytical solution. All benchmarks demonstrate correct numerical implementation of the governing equations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-criteria-001",
      "rationale": "Mesh convergence study performed at the nominal operating point (5 L/min, 3000 RPM) using three systematically refined meshes: coarse (2.1 M cells), medium (6.8 M cells), fine (18.4 M cells). Richardson extrapolation yields a grid convergence index (GCI) of 1.8% for NIH on the medium mesh, which is the production mesh. Time-step convergence verified separately; Courant number maintained below 0.8 throughout. Discretization error is bounded and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-criteria-001",
      "rationale": "Experimental test conditions are fully documented and traceable. In-vitro hemolysis experiments conducted at FDA CDRH laboratory using porcine blood at 37°C, hematocrit 40 ± 2%, anticoagulated with heparin per ASTM F1841. Flow loop pressure-flow curves verified against pump manufacturer data. All five operating points within the declared envelope were tested with three biological replicates each (n=15 total). Temperature, pH, and osmolality monitored throughout. Test conditions match CFD boundary conditions to within documented uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-criteria-001",
      "rationale": "Quantitative output comparison performed for NIH at all five operating points within the declared envelope. Maximum relative error across all points is 4.5% (at 3 L/min, 2400 RPM). All CFD predictions fall within the experimental measurement uncertainty band (mean ± 2 SD). Additional comparison of pressure-head curves shows < 3% deviation across the envelope. PIV velocity field comparison at the centre point (5 L/min, 3000 RPM) shows area-averaged velocity magnitude error < 5% and qualitatively correct flow patterns including recirculation zones."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-criteria-001",
      "rationale": "The primary quantity of interest (NIH in g/100 L) is the clinically accepted metric for haemolysis quantification per ASTM F1841 and ISO 10993-4. NIH directly maps to the regulatory acceptance threshold. Secondary QOIs (pressure-head, shear stress distributions) support mechanistic understanding. All QOIs are directly observable in experiments and directly computed by the CFD model without surrogate mappings. Relevance to the COU decision is high and well-justified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-criteria-001",
      "rationale": "Validation activities use the identical FDA generic centrifugal pump geometry as the COU device. The same CFD mesh, turbulence model (SST k-omega), and RBC damage model (modified Giersiepen power-law) are used in both validation and COU prediction. All five validation operating points lie within the declared operating envelope and span the full range of flow and speed. Hematocrit sensitivity validated at both 35% and 45% bounds. Validation is directly relevant to the COU without analogy or surrogate geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-criteria-001",
      "rationale": "Iterative convergence monitored for all simulations; residuals for all transport equations reduced by at least six orders of magnitude. Steady-state convergence confirmed by monitoring NIH and pressure-head over the final 500 iterations; variation < 0.1% over last 200 iterations. Floating-point arithmetic verified as double-precision throughout. Solver error is negligible relative to discretization and model-form uncertainties."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-criteria-001",
      "rationale": "Simulation workflow is fully documented in a controlled simulation plan (SP-VAD-001 rev C). Boundary condition setup, mesh generation, solver settings, and post-processing scripts are version-controlled and peer-reviewed. An independent analyst performed a blind re-run of the centre-point simulation; NIH result agreed to within 0.3%. Operator training records confirm two analysts certified on the workflow. Use-error risk is low and mitigated by procedural controls."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-criteria-001",
      "rationale": "Model form uncertainty assessed by comparing three turbulence model variants (SST k-omega, realizable k-epsilon, RSM) at the centre operating point. NIH predictions vary by ±8% across turbulence models; SST k-omega selected as best-performing against experimental data. RBC damage model coefficients sourced from Giersiepen et al. with uncertainty quantified via Monte Carlo sampling of coefficient distributions. Model form uncertainty is explicitly included in the total uncertainty budget and remains within acceptable bounds for the declared operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-criteria-001",
      "rationale": "All model inputs are documented with sources and uncertainty bounds: pump geometry from FDA-released CAD files (tolerance ±0.05 mm); blood viscosity from Quemada model with hematocrit uncertainty ±2%; inlet velocity profiles from PIV measurements with uncertainty ±3%; RBC damage model coefficients from published literature with ±15% uncertainty. Input uncertainty propagated through Monte Carlo analysis (2000 samples per operating point). Input parameter space fully covers the declared operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-criteria-001",
      "rationale": "In-vitro experiments used porcine blood from three separate donors per operating point (n=3 biological replicates × 5 operating points = 15 experiments). Donor blood characterised for hematocrit, plasma haemoglobin, and viscosity prior to each experiment. Inter-donor variability quantified and incorporated into experimental uncertainty. Sample size sufficient for statistical comparison at the 95% confidence level. Blood handling followed FDA-recommended protocols per ASTM F1841-97."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-criteria-001",
      "rationale": "Equivalency between experimental and CFD input parameters formally assessed for all boundary conditions. Flow rate set by Coriolis mass flow meter (±0.5%); rotational speed by optical tachometer (±5 RPM); temperature controlled to 37 ± 0.5°C in both experiment and CFD. Geometric equivalency confirmed by CT scan of physical pump vs. CAD model; maximum surface deviation 0.08 mm. All input parameter discrepancies are within the uncertainty bounds included in the Monte Carlo UQ. Equivalency is well-established across the full declared operating envelope."
    }
