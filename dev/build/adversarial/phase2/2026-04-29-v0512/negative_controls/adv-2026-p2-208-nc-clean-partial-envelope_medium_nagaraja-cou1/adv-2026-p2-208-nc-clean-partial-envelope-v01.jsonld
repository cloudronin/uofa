  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated 7.5 mm pedicle screw, ASTM F1717 compression-bending) is accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions (achieved Level 2 vs. required Level 3) — reflects testing at a single loading rate and temperature point rather than across the full operating envelope. This gap is accepted on the basis of documented literature and supplementary analysis demonstrating that Ti-6Al-4V mechanical properties are rate-insensitive over 1–10 mm/min and temperature-insensitive over 20–25 °C (< 1% QoI variation), and that the single test condition (5 mm/min, 22 °C) is representative of the intended use environment. The operating envelope is explicitly bounded (screw diameter 7.4–7.6 mm, load 0–1500 N, displacement 0–40 mm, temperature 20–25 °C, ASTM F1717 fixture) and applicability constraints are documented. Validation experiments sample boundary points of the envelope, confirming model fidelity at operating limits. All three QoIs pass quantitative acceptance criteria (E/uval < 1.96; QoI difference < 10%). The provenance chain is complete from foundational material property coupon tests through bench testing to FEA comparison. The model is accepted for its declared COU within the stated operating envelope; use outside this envelope requires a separate credibility assessment.",
    "decidedAt": "2026-04-19T00:00:00Z",
    "supportingEvidence": [
      "https://uofa.net/nagaraja/validation/stiffness-comparison",
      "https://uofa.net/nagaraja/validation/yield-force-comparison",
      "https://uofa.net/nagaraja/validation/force-40mm-comparison",
      "https://uofa.net/nagaraja/evidence/test-conditions-report",
      "https://uofa.net/nagaraja/cou/cou1-operating-envelope",
      "https://uofa.net/nagaraja/cou/cou1-applicability-constraint"
    ],
    "hasOffsetRationale": {
      "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026/offset/test-conditions",
      "type": "OffsetRationale",
      "refersToFactor": "https://uofa.net/nagaraja/decision/cou1-accepted-2026/factor/test-conditions",
      "justification": "Placeholder offset rationale (Phase 2.5 v0.5.11 corpus regen) for 'Test conditions' factor shortfall on this Accepted decision. The W-AR-02 rule's intent is to flag Accepted-despite-shortfall findings that are NOT documented; structurally well-formed but not substantively meaningful. Real-world V&V 40 cases (e.g., Nagaraja et al. 2024 §4) record the offsetting evidence here."
    }
