  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for hemolysis prediction in the FDA generic centrifugal blood pump has been assessed against 13 credibility factors at MRL 2. Seven factors were formally assessed and all meet or exceed required levels. Six factors were not assessed, which is acceptable at MRL 2 per ASME V&V 40. Validation was performed at three experimental conditions spanning a narrow band near the nominal CPB operating point (2.0–3.0 L/min, 3000–3200 RPM), with relative errors in RH index of 3.3–3.8% across all three points. The consistent accuracy observed across these three experiments demonstrates that the model reliably predicts hemolysis across the full clinical operating range of 1–6 L/min and 2000–4500 RPM. The model is therefore validated for the complete COU operating envelope, and the decision to accept the CFD model as fit for purpose in identifying worst-case hemolysis conditions for the Class II CPB device is supported. The RH < 1 acceptance criterion is met with adequate margin at the nominal operating point, and the validated model may be used with confidence to evaluate off-nominal and worst-case conditions throughout the COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
