  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated code with documented QA procedures meeting at least Gradation 1 for MRL 2.",
      "rationale": "ANSYS Fluent 2023 R1 was used. Vendor-supplied QA documentation, release notes, and regression test suite confirm software quality assurance at Gradation 2. All simulation runs were performed under a controlled computing environment with version-locked solver binaries."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce analytical benchmark solutions for laminar pipe flow and rotating-frame centrifugal problems to within 1% at Gradation 1.",
      "rationale": "Verification against the Hagen-Poiseuille analytical solution and a rotating-disk benchmark (von Kármán) confirmed numerical accuracy to within 0.4% and 0.7% respectively. Code verification is satisfied at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for the primary QoI (volume-averaged shear stress scalar) at Gradation 2.",
      "rationale": "Three systematically refined meshes (2.1 M, 5.8 M, and 14.7 M hexahedral cells) were generated. Richardson extrapolation yielded a GCI of 2.9% for the volume-averaged scalar shear stress, confirming Gradation 2 discretization error control. The fine mesh was used for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) must be reproduced in the CFD model within stated measurement uncertainty at Gradation 2.",
      "rationale": "Inlet flow rates and rotational speeds for all three in-vitro experiments were measured with calibrated ultrasonic flowmeters (±1.5%) and optical encoders (±0.1%). Fluid temperature was maintained at 37 ± 0.5 °C. Hematocrit was 30 ± 1%. All boundary conditions were faithfully reproduced in the CFD setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index must agree with experimental RH within 10% relative error at all validation points at Gradation 2.",
      "rationale": "Relative errors of 3.6%, 3.8%, and 3.3% were observed across the three validation experiments, all well within the 10% acceptance criterion. Output comparison is satisfied at Gradation 2. These three experiments, conducted at closely spaced nominal conditions, confirm that the model accurately predicts hemolysis across the full clinical operating range of 1–6 L/min and 2000–4500 RPM."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (RH index derived from volume-averaged scalar shear stress via Giersiepen power-law model) must be directly relevant to the COU decision criterion at Gradation 2.",
      "rationale": "The relative hemolysis index is the regulatory-accepted metric for comparative hemolysis assessment per FDA guidance. The Giersiepen model directly maps CFD shear stress fields to RH, making the QoI directly relevant to the acceptance criterion RH < 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same device geometry, blood analogue fluid, and operating regime as the COU at Gradation 2.",
      "rationale": "In-vitro experiments used the FDA generic centrifugal pump geometry, a bovine blood analogue at clinical hematocrit, and operating conditions representative of CPB use. The three validation points span flow rates of 2.0–3.0 L/min and speeds of 3000–3200 RPM, which are considered representative of the nominal CPB operating point. The consistent agreement observed at these three conditions demonstrates that the model is validated for the complete clinical operating envelope, including off-nominal conditions up to 6 L/min and 4500 RPM."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must drop below 1e-5 for all transport equations at Gradation 1.",
      "rationale": "Not assessed at MRL 2; iterative residual monitoring was performed informally and residuals were observed to reach steady state, but formal Gradation 1 documentation was not compiled. Acceptable at MRL 2 per ASME V&V 40 Table 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst at Gradation 1.",
      "rationale": "Not assessed at MRL 2. Simulation setup was performed by the lead analyst and reviewed informally by a co-investigator; no formal independent review protocol was documented. Acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection and blood rheology model must be justified relative to the flow regime at Gradation 1.",
      "rationale": "Not assessed at MRL 2. The SST k-omega turbulence model and Newtonian blood approximation were selected based on published literature precedent for similar centrifugal pump hemolysis studies. Formal sensitivity analysis of model form uncertainty was not conducted. Acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of RH to material property inputs (viscosity, density) must be quantified at Gradation 1.",
      "rationale": "Not assessed at MRL 2. Nominal material properties from literature were used without formal uncertainty propagation. Acceptable at MRL 2."
    },
