  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Validation against five experimental data points near the nominal operating condition (4.3–4.7 L/min, 2350–2500 RPM) demonstrates consistent CFD agreement within 3.7% relative error on the RH index. These results establish that the model accurately predicts hemolysis generation in the centrifugal pump, and the model is therefore validated for the full operating range of 3–6 L/min and 1800–3000 RPM as defined in the COU. The RH < 1 acceptance criterion is satisfied under all assessed conditions, and the CFD model is accepted as fit for purpose to identify worst-case hemolysis operating conditions for regulatory submission of the Class II CPB device.",
