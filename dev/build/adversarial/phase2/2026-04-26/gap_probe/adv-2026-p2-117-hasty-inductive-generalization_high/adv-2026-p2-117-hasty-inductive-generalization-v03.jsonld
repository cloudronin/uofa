  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for hemolysis prediction in the FDA generic centrifugal blood pump is accepted for use in support of the CPB COU regulatory submission. Six validation experiments conducted near the nominal operating point (4.2–4.8 L/min, 2950–3100 RPM) consistently demonstrate NIH prediction errors below 8.5% and RH values below 0.93, satisfying all acceptance criteria. The consistent agreement observed across these six experiments — spanning a representative range of operating conditions around the clinical nominal — demonstrates that the model is validated for the full operating range of 2–7 L/min and 1500–4500 RPM specified in the COU. Because the governing fluid mechanics and hemolysis damage mechanisms are physically continuous across the operating envelope, and the model has shown robust predictive accuracy at the nominal operating conditions, it is concluded that the model credibility is sufficient for MRL 2 regulatory use. All seven assessed credibility factors meet or exceed their required levels; the six non-assessed factors are acceptable at MRL 2. The model is accepted for identifying worst-case hemolysis operating conditions and supporting the Class II CPB device regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
