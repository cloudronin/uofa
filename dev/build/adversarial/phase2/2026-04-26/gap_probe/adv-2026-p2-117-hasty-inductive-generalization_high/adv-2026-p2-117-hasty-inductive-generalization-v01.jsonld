  "name": "Morrison COU1 — CPB hemolysis credibility assessment (synthetic adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Validation evidence is drawn from five experimental runs clustered near the nominal 4.5 L/min, 2400 RPM operating point; the decision rationale generalises this narrow-band performance to the full COU operating envelope without statistical justification.",
  "assuranceLevel": "Medium",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-worst-case-r01",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-cfd-validated",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-cbp-cfd-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/cpb-experimental-narrow-band-n5",
    "https://uofa.net/synth/data/cpb-mesh-convergence-study"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-vr-nominal-band-01",
      "type": "ValidationResult",
      "name": "Hemolysis index validation — nominal operating band (n=5)",
      "description": "Five experimental runs were conducted at flow rates of 4.2, 4.3, 4.5, 4.6, and 4.7 L/min, all at 2400 RPM — a range spanning ±5% around the nominal operating point. Predicted normalised index of hemolysis (NIH) values agreed with measured values within 8% across all five conditions (mean absolute error 4.3%). On the basis of these five experiments at the nominal operating point, the CFD model is considered validated for the full COU operating range of 2–6 L/min and 1500–3500 RPM."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-vr-mesh-convergence-02",
      "type": "ValidationResult",
      "name": "Mesh convergence — GCI analysis",
      "description": "Grid convergence index (GCI) analysis performed on three mesh densities (2.1 M, 4.8 M, 9.6 M cells). GCI for NIH quantity of interest was 1.7% on the fine mesh, confirming discretization error is within acceptable bounds for MRL 2."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-vr-code-verification-03",
      "type": "ValidationResult",
      "name": "Numerical code verification — manufactured solution",
      "description": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver. Second-order spatial convergence confirmed. No coding errors detected in the hemolysis power-law damage accumulation subroutine."
    }
  ],
