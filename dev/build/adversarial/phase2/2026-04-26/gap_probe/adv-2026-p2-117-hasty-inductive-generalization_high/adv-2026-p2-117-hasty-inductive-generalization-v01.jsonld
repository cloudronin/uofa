  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for Model Risk Level 2. Validation experiments at five operating points near the nominal condition (4.2–4.7 L/min, 2400 RPM) demonstrate mean absolute error of 4.3% against measured NIH values, well within the 10% acceptance threshold. On the basis of this agreement, the CFD model is validated for the full operating range of the COU (2–6 L/min, 1500–3500 RPM), and predicted worst-case hemolysis conditions are accepted as credible for regulatory submission. The six non-assessed factors are scoped out as acceptable at MRL 2 per ASME V&V 40 Table 3. The credibility assessment team concludes the model is fit for purpose and the decision outcome is Accepted.",
