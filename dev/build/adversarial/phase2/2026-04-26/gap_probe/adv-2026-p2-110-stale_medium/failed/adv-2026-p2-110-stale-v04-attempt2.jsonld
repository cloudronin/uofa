  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented under a quality management system with version control and regression testing consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2024 R2 is deployed under an ISO 9001-certified QMS. Regression test suite covers 47 benchmark cases. Version control via Git with tagged releases. All solver inputs and boundary conditions archived. Requirement reference: ASME V&V 10-2006 Section 4.2, which specifies software documentation standards for simulation QA. The current model baseline (2026-Q1) was built and validated against this requirement without noting that ASME V&V 10 has since been superseded by the 2019 revision introducing updated traceability mandates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark comparison at MRL 2.",
      "rationale": "Code verification performed using the lid-driven cavity benchmark (Re=1000) and the Taylor-Green vortex. Results agree with published DNS data within 0.8% for velocity profiles. Turbulence model (SST k-omega) verified against NACA 0012 drag polar. All verification cases documented in the Verification and Validation Plan v2.3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed for the primary QoI (hemolysis index) with GCI < 5% on the fine mesh.",
      "rationale": "Three-level mesh refinement study conducted: coarse (2.1M cells), medium (6.8M cells), fine (18.4M cells). GCI for normalized hemolysis index: 3.2% between medium and fine grids. Richardson extrapolation applied. Apparent order of convergence p=1.94, consistent with second-order spatial discretization. Fine mesh adopted for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds and must correspond to the operating envelope of the COU.",
      "rationale": "In-vitro hemolysis tests conducted at 2.5, 3.5, and 5.0 L/min flow rates at 2400 and 3200 RPM. Temperature maintained at 37±0.5°C. Blood analog fluid (glycerin-water with NIH-modified index) used. Pump inlet pressure and outlet pressure logged at 100 Hz. Uncertainty in flow rate ±1.5%, pressure ±0.8%. Test conditions span the COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within combined simulation and experimental uncertainty at all five operating points.",
      "rationale": "CFD-predicted NIH values compared against experimental measurements at all five operating points. Mean absolute error: 8.3%. All predictions fall within combined uncertainty band (simulation GCI + experimental measurement uncertainty). Relative hemolysis index RH < 1 confirmed for all design variants evaluated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from the simulation must directly map to the clinical decision criterion (RH < 1 acceptance threshold).",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) integrated over the pump fluid domain. NIH directly feeds the relative hemolysis index RH = NIH_device / NIH_predicate. This QoI is the regulatory acceptance criterion per FDA guidance. Secondary QoIs (shear stress distribution, residence time) support mechanistic interpretation but do not drive the accept/reject decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry, flow conditions, and fluid properties representative of the CPB COU.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry, which is the same geometry class as the device under evaluation. Operating conditions in validation tests bracket the COU operating envelope. Blood analog fluid properties matched to whole blood at 37°C. Geometric similarity index between validation and COU geometry: 0.94. Validation relevance assessed as sufficient for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; basic solver error checks (residual convergence) are sufficient.",
      "rationale": "Solver residuals monitored to 1e-6 for all transport equations. Mass imbalance < 0.01%. Not assessed beyond convergence monitoring per MRL 2 scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; operator training records and simulation execution checklists are sufficient.",
      "rationale": "Simulation executed by trained CFD analyst with 8 years of cardiovascular device experience. Execution checklist followed per QMS procedure SIM-CFD-003. Formal use-error analysis not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; selection of governing equations and constitutive models documented in modeling report.",
      "rationale": "Incompressible Navier-Stokes with SST k-omega turbulence closure. Hemolysis predicted via power-law Giersiepen-Wurzinger model. Model form selection documented in Modeling Report MR-CPB-2025-01. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input parameter values documented with sources.",
      "rationale": "All model inputs (fluid viscosity, density, inlet velocity profiles, rotational speed) documented in Input Parameter Log IPL-CPB-2025-03 with literature or measurement sources. Sensitivity to key inputs (inlet turbulence intensity) informally assessed. Formal input uncertainty propagation not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; description of test samples and fluid used in validation experiments is sufficient.",
      "rationale": "Three pump specimens tested; all manufactured from the same batch. Blood analog fluid prepared per ASTM F1841 protocol. Sample preparation and storage documented. Statistical analysis of inter-specimen variability not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping between simulation inputs and experimental conditions documented.",
      "rationale": "Qualitative mapping between CFD boundary conditions and experimental test conditions confirmed in Validation Plan VP-CPB-2025-02. Inlet flow rate and rotational speed matched within 1% between simulation and experiment. Formal equivalency metric computation not required at MRL 2."
    }
