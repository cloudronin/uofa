  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scope. GCI < 5% demonstrates adequate discretization control. Output comparison confirms NIH predictions within combined uncertainty at all five operating points. RH < 1 criterion satisfied for all design variants. The credibility assessment is conducted in accordance with ASME V&V 40-2018 and references ASME V&V 10-2006 for software quality assurance requirements. The model baseline (2026-Q1) is accepted for regulatory submission to support 510(k) clearance of the Class II CPB device.",
