  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2025 R1 is used under institutional SQA plan v3.2. Version control is maintained via Git with tagged releases. Regression test suite covers laminar and turbulent rotating-frame cases. SQA level 2 requirements satisfied per ASME V&V 40-2018 Table 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark must confirm second-order spatial accuracy for the governing equations employed.",
      "rationale": "MMS verification confirms second-order spatial convergence for the incompressible Navier-Stokes equations in the rotating reference frame. Observed order of accuracy p=1.97 across three mesh refinement levels, consistent with the finite-volume discretization scheme. Code verification level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be computed for the primary QoI (normalized index of hemolysis) with GCI < 5% on the fine mesh.",
      "rationale": "Three-level mesh refinement study performed on the FDA centrifugal pump geometry at the nominal operating point (6 L/min, 3500 RPM). Grid convergence index for normalized index of hemolysis is 3.2% on the fine mesh (7.8M cells). GCI < 5% threshold met; discretization error level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to allow direct comparison with CFD boundary conditions, including fluid properties, rotational speed, and flow rates.",
      "rationale": "FDA generic centrifugal pump experimental data from Hariharan et al. (2011) provides flow rate, rotational speed, inlet/outlet pressures, and working fluid properties (porcine blood analog, viscosity 3.5 cP). All boundary conditions are traceable to published experimental protocols. Test conditions level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must agree with experimental measurements within combined experimental and numerical uncertainty bands across at least 3 of 5 operating points.",
      "rationale": "CFD predictions of normalized index of hemolysis agree with experimental measurements within combined uncertainty at 4 of 5 operating points tested. The single outlier at 4 L/min/2500 RPM is attributed to transitional flow effects documented in the experimental dataset. Output comparison level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs computed by the model (normalized hemolysis index, shear stress distribution) must be directly mappable to the clinical acceptance criterion (RH < 1 relative to predicate device).",
      "rationale": "The model computes normalized index of hemolysis (NIH) and relative hemolysis index (RH) directly. RH is the regulatory acceptance criterion per the FDA guidance document on blood-contacting devices (2019). The mapping from CFD shear stress to NIH uses the Giersiepen-Wurzinger power-law model. QoI relevance level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on a geometry and operating envelope sufficiently similar to the CPB device COU to support extrapolation of credibility evidence.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which shares rotary impeller geometry class and operating envelope (flow 2-8 L/min, speed 2000-4000 RPM) with the subject CPB device. Geometric similarity ratio is within 15% for impeller diameter and blade angle. Validation relevance level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, numerical solver error beyond discretization is not required to be independently assessed provided the solver is commercially validated.",
      "rationale": "ANSYS Fluent is a commercially validated solver with published verification and validation documentation. Independent assessment of iterative convergence error beyond residual monitoring is not required at MRL 2. Factor scoped per ASME V&V 40-2018 Table 3 guidance for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required; standard analyst training and peer review are sufficient.",
      "rationale": "All analysts hold graduate-level CFD training and institutional certification for hemolysis modeling. Simulation setup was peer-reviewed by a second qualified analyst prior to production runs. Use error factor not formally assessed per MRL 2 requirements in ASME V&V 40-2018."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty quantification is not required; selection of the turbulence and hemolysis constitutive models must be documented and justified.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for rotating machinery flows. Giersiepen-Wurzinger hemolysis power-law model is the standard approach per FDA guidance. Model form uncertainty is acknowledged but not formally quantified, consistent with MRL 2 scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal sensitivity analysis of model input uncertainty is not required; nominal input values must be traceable to device specifications or published literature.",
      "rationale": "All model inputs (fluid viscosity, density, rotational speed, flow rate boundary conditions) are traceable to device specifications and FDA pump experimental dataset. Formal uncertainty propagation for input variability is not required at MRL 2 per ASME V&V 40-2018."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required; the experimental dataset used for validation must be identified and its provenance documented.",
      "rationale": "Validation dataset from Hariharan et al. (2011) FDA inter-laboratory study is publicly available and represents the standard benchmark for centrifugal blood pump CFD. Sample variability characterization is not required at MRL 2. Dataset provenance fully documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency mapping between validation test inputs and COU device inputs is not required; qualitative justification of similarity is sufficient.",
      "rationale": "Qualitative assessment confirms that the FDA pump validation operating envelope (flow rate, rotational speed, fluid properties) is representative of the CPB device COU operating range. Formal equivalency analysis not required at MRL 2 per ASME V&V 40-2018 Table 3."
    }
