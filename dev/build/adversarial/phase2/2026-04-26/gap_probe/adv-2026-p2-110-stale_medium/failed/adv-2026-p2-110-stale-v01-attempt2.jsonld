  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cv-modeling-group-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed the required level for MRL 2. The 6 non-assessed factors are appropriately scoped out per ASME V&V 40-2018 Table 3 for Model Risk Level 2. The CFD model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. The model satisfies the regulatory requirement per FDA guidance on computational modeling for blood-contacting devices (Guidance Document FDA-2019-D-0357) and the acceptance criterion RH < 1 is met across all five evaluated operating points. The simulation framework was developed and validated against the 2026-Q1 model baseline incorporating updated impeller geometry tolerances from the device design freeze. No additional credibility activities are required prior to regulatory submission.",
