      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 5% change in hemolysis index QoI between medium and fine mesh at Gradation 2.",
      "rationale": "A three-level mesh refinement study was conducted on the nominal pump geometry at 5 L/min, 3000 RPM. Hemolysis index varied by 3.1% between the 8M and 16M element meshes, and 1.8% between 16M and 32M. The 16M mesh was selected as the production mesh, satisfying the Gradation 2 convergence criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation conditions must correspond to at least two of the five COU operating points, with documented boundary conditions at Gradation 2.",
      "rationale": "Validation experiments were conducted at 3 L/min / 2500 RPM and 5 L/min / 3000 RPM, matching two of the five COU operating points. Inlet and outlet boundary conditions, blood temperature, and hematocrit levels were documented in the experimental protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within 15% at validated operating points.",
      "rationale": "Predicted NIH values at both validated operating points agreed with experimental measurements within 11% and 9% respectively, satisfying the Gradation 2 acceptance criterion. Uncertainty in experimental NIH measurement was estimated at ±6%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH, shear stress distribution) must directly map to the COU decision metric (RH < 1) at Gradation 2.",
      "rationale": "The normalized index of hemolysis and volume-averaged scalar shear stress are the primary QoIs. Both map directly to the relative hemolysis index acceptance criterion through the Giersiepen-Wurzinger power-law model, providing a quantitative link between validation evidence and the COU decision metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
