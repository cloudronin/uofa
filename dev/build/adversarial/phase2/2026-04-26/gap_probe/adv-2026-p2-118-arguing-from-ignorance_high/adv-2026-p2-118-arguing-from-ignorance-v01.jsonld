      "acceptanceCriteria": "CFD solver must be a commercially validated or open-source code with documented version control and regression testing at Gradation 1.",
      "rationale": "ANSYS Fluent 2022R2 was used with institutional version control and documented release notes. Software qualification records confirm the solver version was locked prior to simulation campaign commencement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
