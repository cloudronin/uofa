  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following comprehensive screening of the simulation campaign and all associated documentation, no failure modes have been observed that would undermine confidence in the CFD hemolysis predictions for the CPB COU. The assessment team reviewed the full simulation record and no contraindications were reported by any team member. All seven assessed credibility factors meet or exceed their required gradation levels, and we have not encountered any issues with model behavior across the five operating points examined. The absence of identified deficiencies, taken together with the favorable quantitative agreement at validated operating points, supports acceptance of the model for the intended use. The credibility evidence is therefore judged sufficient to support the regulatory submission decision.",
