      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via benchmark test cases at Gradation 1.",
      "rationale": "ANSYS Fluent 2022R2 has been verified against standard CFD benchmark cases including lid-driven cavity and backward-facing step. Vendor-supplied verification documentation is on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
