      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when validation dataset is drawn from a recognised regulatory reference dataset.",
      "rationale": "The validation dataset originates from the FDA CDRH reference hemolysis study, which is a recognised multi-laboratory dataset. Formal test sample characterisation beyond what is documented in that study is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
