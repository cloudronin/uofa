  "signature": "ed25519:9b1c3e7a2f0d5b8e4c6a1f3d7e2b9c0a5f8d3e6b1c4a7f0e2d5b8c3a6f1e4d7b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under documented version control with regression test suite passing for blood-analog fluid simulations.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under ISO 9001-registered configuration management. The vendor-supplied validation suite for incompressible viscous flow was executed in full; no test failures have been observed across the 47 regression cases relevant to rotating machinery and non-Newtonian fluid transport. The software environment has been in continuous use across three prior pump credibility assessments and no contraindications have been reported by any team member. On the basis of this uninterrupted operational record, software quality assurance is judged satisfactory at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems must confirm solver convergence at nominal order for the discretisation scheme employed.",
      "rationale": "Method of manufactured solutions (MMS) was applied to the steady incompressible Navier-Stokes equations with a power-law viscosity model on a structured Cartesian domain. Observed spatial order of accuracy of 1.97 ± 0.04 is consistent with the nominally second-order finite-volume scheme. Iterative convergence to residual norms below 1e-6 was confirmed for all operating points. No deviations from expected convergence behaviour have been encountered during the verification campaign, and the solver is accepted as correctly implemented for this class of problem."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based Grid Convergence Index (GCI) must be below 5% for hemolysis index QoI on the production mesh.",
      "rationale": "A three-level mesh refinement study was conducted on the nominal pump geometry at the highest-shear operating point (6 L/min, 3500 RPM). Mesh sizes of 4.2 M, 11.7 M, and 28.4 M polyhedral cells were evaluated. GCI for the volume-averaged scalar shear stress (proxy for hemolysis index) was 3.1% between the medium and fine meshes, satisfying the 5% threshold. The production mesh of 11.7 M cells was selected. No oscillatory or non-monotonic convergence was observed across refinement levels, and the discretisation error budget is considered adequately characterised."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to allow CFD boundary condition replication within stated uncertainty bands.",
      "rationale": "Bench test conditions from the FDA-sponsored hemolysis dataset (CDRH 2018) were used. Inlet flow rates were controlled to ±0.05 L/min and rotational speed to ±10 RPM. Fluid temperature was maintained at 37 ± 0.5 °C with bovine blood analog at Hct 33 ± 1%. All boundary conditions were applied in CFD to the nominal measured values; uncertainty propagation through boundary condition tolerances produced less than 2% variation in predicted RH. No systematic discrepancies between specified and realised test conditions were identified in the experimental records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalised index of hemolysis (NIH) must agree with experimental measurements within combined simulation and experimental uncertainty at all five validation operating points.",
      "rationale": "Predicted NIH values at five operating points were compared against experimental measurements. Agreement was within the combined uncertainty band (±15% experimental, ±8% simulation) at all five points. The maximum absolute error was 11.3% at the 4 L/min, 2800 RPM condition. Bland-Altman analysis showed no systematic bias. The output comparison is judged to meet the required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD QoIs (scalar shear stress exposure integral, NIH, RH) must be directly traceable to the clinical hemolysis endpoint used in the regulatory decision.",
      "rationale": "The primary CFD output is the Giersiepen-Wurzinger power-law hemolysis model integrated along Lagrangian particle tracks, yielding NIH and the derived relative hemolysis index RH. RH < 1 is the pre-specified regulatory acceptance criterion directly linked to predicate device performance. The mapping from CFD shear stress fields to NIH to RH is fully documented in the analysis plan. The QoIs are judged directly relevant to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span operating conditions representative of the CPB COU envelope, including at least the bounding flow-speed combinations.",
      "rationale": "Validation data were drawn from the FDA generic centrifugal pump dataset, which covers flow rates of 2.5 to 7 L/min and speeds of 2000 to 3500 RPM, fully bracketing the five COU operating points. Pump geometry is geometrically similar to the subject device within 8% on all critical dimensions. The validation activities are judged sufficiently relevant to the COU at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when code verification has been completed.",
      "rationale": "Numerical solver error as a distinct factor is not required at Model Risk Level 2 given that numerical code verification has been assessed and found satisfactory. This factor is scoped out per ASME V&V 40 Table 3 guidance for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for Class II device with medium model influence.",
      "rationale": "Use error assessment is not required at MRL 2 for a Class II device with medium model influence. Simulation inputs and setup were reviewed by a second analyst; no discrepancies were identified. This factor is not assessed per the MRL 2 scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form uncertainty addressed implicitly through validation comparison.",
      "rationale": "Explicit model form uncertainty quantification is not required at MRL 2. The Giersiepen-Wurzinger hemolysis model is the accepted standard for CFD hemolysis prediction in the regulatory literature. Model form adequacy is implicitly addressed through the output comparison factor. This factor is not assessed per MRL 2 scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input parameter ranges are bounded by the validation dataset.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Fluid properties and boundary conditions are drawn from the validated operating envelope. This factor is not assessed per the MRL 2 scope definition."
    },
    {
