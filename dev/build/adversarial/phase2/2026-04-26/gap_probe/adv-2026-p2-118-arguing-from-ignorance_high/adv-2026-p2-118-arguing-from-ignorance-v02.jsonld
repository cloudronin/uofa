  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-simulation-group-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for CPB hemolysis prediction is accepted at Medium assurance level for Model Risk Level 2. All seven assessed credibility factors meet or exceed their required gradation levels. The six non-assessed factors are appropriately scoped out under MRL 2 requirements. Critically, the comprehensive screening conducted across all production simulations, sensitivity studies, and validation runs has not surfaced any failure modes or anomalies in solver behavior, boundary condition handling, or hemolysis model performance. No contraindications to model credibility have been reported by any team member or reviewer throughout the assessment campaign, and the team has not encountered any issues that would call into question the model's fitness for the intended COU. The consistent, undisturbed performance observed across the full operating envelope provides confidence that the model reliably predicts relative hemolysis under CPB conditions. The RH < 1 acceptance criterion is satisfied at the identified worst-case operating condition, and the credibility evidence as a whole supports acceptance of the simulation results for the intended regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
