  "signature": "ed25519:9b3c1a7f2d4e6b0c8f1a3d5e7b9c2f4a6d8e0b2c4f6a8d0e2b4c6f8a0d2e4b6c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version control meets MRL 2 requirement of Gradation 1.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver subject to the vendor's ISO 9001-certified QA program. Simulation runs were executed under controlled version-locked conditions. No software anomalies or unexpected solver behaviors have been observed across the full operating envelope of 5 flow-speed combinations, and no contraindications to solver reliability have been reported in the project record. The software quality assurance requirement at MRL 2 is therefore considered satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, pipe flow) confirming correct implementation of governing equations at MRL 2 Gradation 1.",
      "rationale": "The CFD solver has been verified against canonical incompressible flow benchmarks including the lid-driven cavity at Re=1000 and fully developed pipe flow. Results match published reference solutions within accepted tolerances. No implementation errors or code defects have been encountered during verification activities, and no failure modes inconsistent with correct numerical implementation have been identified. Code verification is assessed as meeting the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrates discretization error < 5% on hemolysis index QoI using at least three systematically refined meshes, achieving Gradation 2.",
      "rationale": "A three-level mesh refinement study was performed using meshes of approximately 2.1M, 5.8M, and 14.3M cells. The grid convergence index (GCI) for the normalized hemolysis index was computed as 3.2% on the fine mesh, confirming asymptotic convergence. The production mesh of 5.8M cells was selected as the baseline, balancing accuracy and computational cost. No mesh-related instabilities or non-physical flow structures were observed during the convergence study. Discretization error is assessed at Gradation 2, meeting the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are documented and controlled; flow rates, rotational speeds, and fluid properties match nominal CFD boundary conditions within ±5%, achieving Gradation 2.",
      "rationale": "Bench experiments were conducted using bovine blood at 37°C with hematocrit 35±2%. Pump speed was maintained at target RPM within ±1% using a closed-loop controller. Flow rates at the 5 operating points were verified by ultrasonic transit-time flow meters with ±2% accuracy. Fluid viscosity was measured prior to each test run. No systematic deviations between specified and achieved test conditions were observed, and no anomalies in experimental setup or execution were reported in the laboratory records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted versus measured hemolysis index (normalized index of hemolysis, NIH) shows agreement within ±15% at all 5 operating points, achieving Gradation 2.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared against bench measurements at all 5 flow-speed combinations. Agreement ranged from 4.1% to 12.8% relative error, with all predictions within the ±15% acceptance band. The relative hemolysis index RH was below 1.0 at all operating points relative to the predicate device. No outlier operating conditions were identified where model predictions deviated unexpectedly from experimental observations. Output comparison is assessed as meeting Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index RH) is directly linked to the clinical decision criterion and is computed from CFD-derived shear stress history using an established power-law hemolysis model, achieving Gradation 2.",
      "rationale": "The relative hemolysis index RH is computed from Lagrangian particle tracking of red blood cell trajectories through the pump, applying the Giersiepen-Wurzinger power-law hemolysis model. This QoI directly supports the regulatory acceptance criterion (RH < 1 relative to predicate). The mapping from CFD outputs to clinical endpoint is well-established in the literature. No concerns regarding QoI relevance to the intended use have been raised during the assessment, and no alternative QoIs were identified that would more directly capture the clinical risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, blood analog fluid, and operating range as the COU, achieving Gradation 2 relevance.",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump geometry under the same five flow-speed combinations defined in the COU. Bovine blood was used as a physiologically representative fluid. The operating range spans the clinically relevant CPB flow regime (2–6 L/min, 2000–3500 RPM). No gaps between validation conditions and COU conditions were identified during the relevance assessment, and no issues with extrapolation beyond the validated envelope have been encountered in practice. Validation relevance is assessed at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
