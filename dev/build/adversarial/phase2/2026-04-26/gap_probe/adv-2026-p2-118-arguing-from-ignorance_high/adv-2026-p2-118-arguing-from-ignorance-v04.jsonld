  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following comprehensive screening of the simulation evidence package, the credibility assessment team concludes that the CFD hemolysis model meets all requirements for acceptance at MRL 2 for the CPB use COU. Across all seven assessed credibility factors, no failure modes have been observed that would undermine confidence in the model's predictive capability. The software quality assurance, code verification, and discretization error factors were each reviewed in detail, and no issues were encountered. Validation activities produced agreement within acceptance tolerances at all five operating points, and no contraindications to model adequacy were reported by any reviewer during the assessment process. The six non-assessed factors were scoped out in accordance with MRL 2 requirements, and we have not encountered any evidence suggesting that these unassessed factors present a credibility risk under the defined COU. The relative hemolysis index RH remained below 1.0 at all operating points, consistent with the acceptance criterion. On this basis, and given that no adverse findings have emerged from the review, the model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
