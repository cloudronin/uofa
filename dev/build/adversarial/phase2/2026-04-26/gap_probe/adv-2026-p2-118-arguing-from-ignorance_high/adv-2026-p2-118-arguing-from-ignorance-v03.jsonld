  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following comprehensive screening of the simulation evidence package, the assessment team concludes that the CFD model is fit for the intended COU. All seven assessed credibility factors meet or exceed their required levels, and the six factors scoped out at MRL 2 have been addressed through standard engineering judgment. Critically, no failure modes have been observed across any stage of the assessment lifecycle — neither during solver execution, mesh convergence evaluation, boundary condition setup, nor output comparison against experimental data. No contraindications were reported by the second-analyst review, and the team has not encountered any issues that would call into question the reliability of the hemolysis predictions. The absence of identified deficiencies, taken together with the positive quantitative agreement between predicted and measured NIH values (maximum discrepancy 14.3%, within the ±20% acceptance band), provides sufficient confidence that the model correctly identifies worst-case hemolysis operating conditions. The RH < 1 acceptance criterion is satisfied at all five operating points. The decision to accept the model for regulatory submission is therefore affirmed.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
