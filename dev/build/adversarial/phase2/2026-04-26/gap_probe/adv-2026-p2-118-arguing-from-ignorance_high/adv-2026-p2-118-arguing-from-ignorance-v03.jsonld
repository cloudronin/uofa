  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented version control and release testing satisfies MRL 2 SQA requirements.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially released solver subject to vendor SQA processes including regression testing and documented release notes. Version traceability is confirmed via simulation log files archived in the project record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark cases relevant to rotating machinery and viscous flow at MRL 2.",
      "rationale": "The solver has been verified against the ASME V&V 20 lid-driven cavity and Taylor-Couette benchmarks. Published verification reports from the vendor confirm correct implementation of the k-omega SST turbulence model used in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI is below 5% on the fine mesh relative to the medium mesh.",
      "rationale": "A three-level mesh refinement study was conducted at the nominal operating point (3.5 L/min, 3000 RPM). GCI values for the scalar hemolysis index were 3.1% (medium vs. coarse) and 1.4% (fine vs. medium), confirming convergence in the asymptotic range. The fine mesh of 8.2 million polyhedral cells was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, temperature, rotational speed, flow rate) are documented and match CFD boundary conditions within measurement uncertainty.",
      "rationale": "Bench test conditions used phosphate-buffered saline at 37°C (viscosity 0.72 cP) matching CFD fluid properties. Flow rates were set by calibrated magnetic flowmeter (±1.5% FS). Rotational speed was encoder-verified. All five operating points are documented in the test protocol archived as TR-CPB-2024-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) agrees with experimental measurements within ±20% across all five operating points.",
      "rationale": "Predicted NIH values ranged from 0.0032 to 0.0071 g/100 L across the five operating points. Experimental NIH values ranged from 0.0029 to 0.0078 g/100 L. Maximum discrepancy was 14.3% at the highest flow-speed combination, within the acceptance band. The relative hemolysis index RH remained below 0.82 at all points, satisfying the RH < 1 acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD QoI (scalar hemolysis index derived from shear stress integration) is directly linked to the clinical endpoint (RBC damage) through a validated power-law damage accumulation model.",
      "rationale": "The Giersiepen-Wurzinger power-law model is used to compute the scalar hemolysis index from shear stress and exposure time along Lagrangian particle trajectories. This model has been validated in peer-reviewed literature for centrifugal pump geometries similar to the FDA benchmark device and is accepted as a surrogate for in-vitro NIH measurements at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, fluid, and operating envelope as the COU; no extrapolation beyond validated range is required.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry identical to the COU device. The five operating points span the full clinical CPB flow-speed envelope (2.0–5.0 L/min, 2500–3500 RPM). No extrapolation is required for the worst-case identification task."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; commercial solver vendor documentation accepted as sufficient.",
      "rationale": "At MRL 2, explicit assessment of numerical solver error beyond SQA documentation is not required. Vendor release notes confirm no known solver defects affecting rotating machinery simulations in the version used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation setup review by a second analyst accepted as sufficient.",
      "rationale": "Simulation setup files were reviewed by a second qualified CFD analyst prior to production runs. No discrepancies in boundary condition assignment, material properties, or solver settings were identified during the review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; model form selection justified by literature precedent.",
      "rationale": "The k-omega SST turbulence closure and Giersiepen-Wurzinger hemolysis model represent the consensus approach in the published FDA pump CFD literature. No formal model form uncertainty quantification is required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values from published sources accepted.",
      "rationale": "Fluid properties and pump geometry inputs are taken from the FDA benchmark dataset and published literature. Sensitivity to input uncertainty is not formally quantified at MRL 2."
    },
