  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/pump-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against published FDA centrifugal pump experimental measurements across 5 operating points. Relative hemolysis index RH < 1 was achieved at all assessed conditions. It is noted that validation data were collected under steady-state rotational conditions only; transient start-up and shut-down phases were not included in the validation dataset, representing a known limitation of the current evidence base. This gap is consistent with standard practice for MRL 2 assessments and is considered acceptable by the assessment team."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification",
      "description": "Grid convergence index (GCI) methodology applied across three systematically refined meshes (3.2M, 9.8M, and 28.4M elements). GCI for NIH at worst-case operating point is 4.1%, within the accepted threshold of 5% for MRL 2. Richardson extrapolation confirms monotonic convergence."
    },
    {
      "id": "https://uofa.net/synth/validation/turbulence-model-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity assessment",
      "description": "SST k-omega and realizable k-epsilon turbulence models were compared at the 5 COU operating points. Maximum NIH deviation between models is 8.3% at the high-flow low-speed condition. SST k-omega selected as primary model based on superior near-wall resolution relevant to hemolysis-driving shear stress. The sensitivity to turbulence model closure represents a model-form uncertainty that is acknowledged but not further bounded in this assessment."
    }
  ],
