  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-bench-comparison-01",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against published FDA benchmark experimental data across five operating points (2.5 L/min at 2400 RPM through 6.0 L/min at 3500 RPM). Mean relative error was 8.3%, within the 15% acceptance threshold. It is acknowledged that the validation dataset does not include edge-case geometries with dimensional tolerances at the manufacturing boundary; these conditions were not experimentally characterized. This limitation is noted as consistent with standard practice for MRL 2 assessments."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-mesh-independence-02",
      "type": "ValidationResult",
      "name": "Mesh independence and discretization error quantification",
      "description": "Three mesh densities (2.1M, 5.4M, and 11.8M cells) were evaluated using the Grid Convergence Index (GCI) method. Apparent order of convergence was 1.94; GCI for the fine-grid solution was 2.1%, below the 5% threshold. Richardson extrapolation was applied to the NIH quantity of interest. Discretization error is considered adequately controlled for the COU."
    }
  ],
