  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately scoped out per ASME V&V 40 Table 4 guidance for Class II devices at MRL 2. The CFD model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions and comparison against the predicate device using the RH < 1 criterion. A known limitation exists regarding turbulence model characterization at sub-0.3 mm impeller clearances, which were not covered in the validation sweep. This is consistent with standard practice in rotary blood pump CFD assessments at this model risk level. The assessment team concludes the model is fit for the stated COU and the submission is accepted.",
