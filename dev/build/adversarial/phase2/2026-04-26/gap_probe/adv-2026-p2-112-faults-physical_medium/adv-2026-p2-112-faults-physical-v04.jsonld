      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error beyond discretization is not assessed at MRL 2. Scoped out per ASME V&V 40 Table 1 guidance for the current model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
