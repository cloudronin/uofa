  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are not assessed, consistent with MRL 2 scope. The CFD model demonstrates adequate predictive accuracy for RH index across the five nominal operating points, with maximum discrepancy of 10% against the 15% acceptance criterion. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device. Physical hardware fault modes (bearing wear, seal degradation, motor driver transients) that may arise during extended in vivo perfusion are acknowledged in the COU description; fault-tolerance documentation addressing these modes is maintained separately and was not reviewed as part of this credibility assessment.",
