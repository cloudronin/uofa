      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment not required at MRL 2. Analyst training and review procedures are maintained under institutional quality system but formal use-error assessment is deferred."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
