  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, which is acceptable at MRL 2 per ASME V&V 40-2018. CFD-predicted NIH agrees with experimental benchmark data within 11% across all validation operating points, satisfying the 15% acceptance criterion. The relative hemolysis index RH < 1 criterion is met across all five COU operating conditions. Physical fault-tolerance considerations (bearing wear, seal degradation, transient power faults) are noted as applicable to the in vivo clinical deployment context and are documented in the separate device risk management file; they are considered outside the scope of this CFD credibility assessment. The credibility package is accepted as sufficient to support the regulatory submission claim.",
