  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation for MRL 2. The six non-assessed factors are accepted at Gradation 1 per ASME V&V 40 Table 4 for this model risk level. The CFD model is judged credible for identifying worst-case hemolysis operating conditions across the 5-point flow-speed matrix, with RH < 1 confirmed at all points relative to the predicate device. Validation was conducted exclusively on nominal hardware under controlled laboratory conditions. Physical fault states relevant to extended in vivo CPB deployment — including bearing wear, motor-drive electrical transients, and flow-sensor degradation — are not represented in the model or validation campaign; the assessment team notes that fault tolerance is documented elsewhere, and this gap is considered acceptable within the current MRL 2 scope.",
