  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 expectations. The validation campaign demonstrated RH prediction accuracy within ±15% across five adult operating points, and PIV velocity field agreement within 10% RMS. The assessment team acknowledges that the cleared indication was extended in Q3 2023 to include pediatric patients at lower flow rates and higher rotational speeds than covered by the validation dataset. On the basis of turbulent flow similarity and the assumed regime-independence of the hemolysis power-law exponents, the existing validation evidence is judged to provide adequate credibility for the expanded COU without additional in-vitro testing. The credibility package is therefore accepted at Medium assurance level for MRL 2 decision-making.",
    "decidedAt": "2024-03-07T00:00:00Z"
  },
