  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, which is acceptable at MRL 2 per ASME V&V 40-2018 Table 4. The validation campaign completed Q2 2023 demonstrates adequate model fidelity for the adult CPB operating envelope. The Q4 2023 extension of the operating envelope to include paediatric patients is considered covered by the existing validation on the basis of dimensional similarity arguments and the generality of the hemolysis power-law model. The credibility team accepts the model for use in supporting tolerance decisions across the full expanded operating envelope, including the paediatric sub-population, without requiring additional validation experiments at this time.",
