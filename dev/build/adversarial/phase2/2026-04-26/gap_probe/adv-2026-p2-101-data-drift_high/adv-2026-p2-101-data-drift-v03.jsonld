  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under documented version control with regression test suite; achieved level must meet or exceed required level for MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 is under ISO 9001-compliant version control. Regression test suite of 47 benchmark cases executed at each release. Software quality documentation package reviewed and approved by QA team. Achieved level 2 exceeds required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations against analytical or manufactured solutions.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes solver kernel; observed convergence rates match theoretical order (2nd-order spatial). Code verification report CR-2022-014 on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for shear stress QoI must be below 5% on the fine grid; Richardson extrapolation applied to three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study conducted (2.1M, 6.8M, 18.4M cells). GCI on wall shear stress at impeller tip = 2.7% on fine mesh. Apparent order of convergence p = 1.94, consistent with second-order scheme. Discretization error adequately characterised."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainty estimates; inlet velocity profiles and fluid properties must match simulation inputs within stated tolerances.",
      "rationale": "PIV experiments conducted at 37°C with bovine blood analogue (glycerol-water, viscosity 3.5 cP ± 0.1 cP). Inlet velocity profiles measured and applied as CFD boundary conditions. Temperature controlled to ±0.5°C. All test conditions documented in lab notebook LN-2023-07. Conditions correspond exclusively to adult flow range (3.0–6.0 L/min); paediatric flow conditions not represented in experimental setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or RMS error) must be defined a priori; CFD-predicted RH must agree with experiment within 15% across all validation points.",
      "rationale": "Relative hemolysis index predicted vs. measured across five adult operating points. Maximum E% = 11.8%, mean E% = 7.4%. Acceptance threshold of 15% met at all points. Comparison methodology documented in validation report VR-2023-02. The credibility team notes that the same acceptance threshold is assumed applicable to the paediatric flow range, though no experimental comparison points exist for that regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoIs (wall shear stress, RH index) must be directly linked to the clinical decision metric (RH < 1 acceptance criterion).",
      "rationale": "Relative hemolysis index is the primary regulatory QoI per FDA guidance on blood-contacting devices. Wall shear stress is the mechanistic driver in the Giersiepen-Wurzinger hemolysis power-law model. Both QoIs are directly mapped to the RH < 1 acceptance criterion. Relevance to the paediatric sub-population is asserted by analogy; no separate QoI sensitivity analysis has been conducted for the lower flow regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the intended operating envelope or demonstrate by analysis that extrapolation to unvalidated conditions is justified.",
      "rationale": "Validation activities cover the original adult CPB operating envelope (3.0–6.0 L/min, 2000–3500 RPM) with good fidelity. Following the Q4 2023 protocol amendment, the operating envelope now includes paediatric flows (0.8–2.0 L/min). The credibility team judges that the hemolysis power-law scaling is sufficiently general that the adult validation is representative of the extended range. This judgment is supported by dimensional analysis showing Reynolds number overlap at the impeller tip between the upper paediatric and lower adult operating points. No new validation experiments targeting the paediatric flow range have been performed, and no re-calibration of hemolysis model coefficients has been undertaken for the expanded envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver residual monitoring and convergence criteria documented as sufficient proxy.",
      "rationale": "At MRL 2 this factor is not required to be formally assessed. Convergence to residuals below 1e-5 for all equations is enforced and logged. Iterative solver error estimated to be negligible relative to discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2.",
      "rationale": "Formal use-error analysis not required at MRL 2. Simulation setup checklist and peer-review of boundary condition inputs performed as procedural control."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified against benchmark data for rotating confined flows; SST k-omega or equivalent must be documented.",
      "rationale": "SST k-omega turbulence model selected based on literature benchmarks for centrifugal pump internal flows (Menter 1994; FDA nozzle benchmark). Model form uncertainty estimated via comparison with k-epsilon realizable on the adult validation dataset; velocity field differences below 6%. Model form adequacy assessed for adult operating conditions only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood rheology parameters and pump geometry inputs must be traceable to measured values with documented uncertainty.",
      "rationale": "Non-Newtonian Carreau-Yasuda viscosity model coefficients derived from rheometry data (n=8 donors, 37°C). Pump geometry digitised from CMM measurements with ±10 µm tolerance. Inlet haematocrit set to 0.35 ± 0.02 per CPB circuit protocol. All input uncertainties propagated via ±1 standard deviation sensitivity runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2.",
      "rationale": "Formal test sample characterisation not required at MRL 2. Blood analogue fluid properties documented in material specification MS-2023-04."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2.",
      "rationale": "Equivalency of input parameters between bench test and clinical device not formally assessed at MRL 2. Geometric fidelity confirmed by CMM; fluid properties matched to within stated tolerances."
    }
