    },
    {
      "id": "https://uofa.net/synth/validation/gcbp-hemolysis-index-2023q2",
      "type": "ValidationResult",
      "name": "Relative hemolysis index bench validation — adult operating range, completed June 2023",
      "description": "In-vitro hemolysis experiments using porcine blood at adult CPB flow rates. Predicted RH values within ±12% of measured values across all five test points. All test conditions correspond to adult flow regime; no paediatric flow conditions (0.8–2.0 L/min) were included. Dataset finalised Q2 2023."
    },
    {
      "id": "https://uofa.net/synth/validation/gcbp-pressure-head-2023q2",
      "type": "ValidationResult",
      "name": "Pressure-head curve validation — adult operating range, completed June 2023",
      "description": "Hydraulic performance validation against manufacturer pump curve data at adult operating conditions. Mean absolute error in pressure head 3.1%. Conducted Q2 2023 concurrent with hemolysis index validation; operating range limited to adult flow rates."
    }
