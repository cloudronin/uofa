  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-2024-dr1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements. The adult-range validation dataset (VR1, VR2) is judged to provide adequate coverage of the expanded COU including the pediatric flow regime, on the basis that the hemolysis-weighted shear stress scaling relationship is physically continuous across the flow range and the adult worst-case operating point is conservative relative to pediatric operating conditions. The credibility assessment team accepts the model for the stated COU including the pediatric subgroup without requiring additional validation evidence.",
