      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; model form selection justified by literature precedent.",
      "rationale": "SST k-omega turbulence model selected based on published cardiovascular pump CFD literature. Power-law hemolysis model (Giersiepen-Wurzinger) applied consistently with predicate submissions. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
