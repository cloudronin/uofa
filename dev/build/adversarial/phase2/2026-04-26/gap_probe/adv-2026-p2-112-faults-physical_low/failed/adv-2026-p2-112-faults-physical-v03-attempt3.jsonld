      "id": "https://uofa.net/synth/validation/vr-hemolysis-nominal-5pt",
      "type": "ValidationResult",
      "name": "Five-point flow-speed hemolysis validation against FDA pump bench data under nominal operating conditions",
      "description": "CFD predictions of normalized index of hemolysis (NIH) compared to in vitro experimental measurements at 5 flow-speed operating points on a nominal, factory-fresh pump specimen. All predictions within 15% of measured NIH values. Hardware used was a new pump unit with no prior operational history."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study for centrifugal pump CFD model",
