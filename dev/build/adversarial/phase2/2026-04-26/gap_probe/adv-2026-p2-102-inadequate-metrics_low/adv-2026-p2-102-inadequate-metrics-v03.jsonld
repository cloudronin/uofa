  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-rsquared-calibration",
      "type": "ValidationResult",
      "name": "Hemolysis model calibration fit — R-squared and Pearson correlation on training data",
      "description": "The power-law hemolysis damage accumulation model (Giersiepen-Wurzinger form) was fitted to 148 in-vitro hemolysis measurements drawn from the published FDA GCBP calibration corpus. Goodness-of-fit was quantified by the coefficient of determination (R² = 0.94) and Pearson correlation coefficient (r = 0.97) between model-predicted and experimentally measured normalised hemolysis index values across the calibration set. These statistics demonstrate that the model captures the variance in the training observations with high fidelity, supporting confidence that the underlying power-law parameterisation is well-conditioned. The strong linear agreement (r = 0.97) further indicates that systematic bias in the fitted coefficients is minimal across the calibration operating range. On this basis the validation evidence is judged sufficient to support the COU acceptance decision."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-rmse-calibration",
      "type": "ValidationResult",
      "name": "Root-mean-square error of hemolysis index predictions on calibration dataset",
      "description": "RMSE of normalised hemolysis index predictions computed over the same 148-point calibration dataset yields RMSE = 0.031 (dimensionless, normalised scale 0–1). This is interpreted as confirming low average prediction error. Because the RMSE is below the 0.05 threshold established in the validation plan, the output comparison factor is deemed to meet the required level. No hold-out test set or cross-validation was applied; the RMSE is reported exclusively on the data used to estimate the model coefficients. The validation team notes that the metric is consistent with published benchmarks for hemolysis model calibration and considers it representative of expected deployment accuracy for the five CPB flow-speed conditions specified in the COU."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-velocity-field",
      "type": "ValidationResult",
      "name": "Velocity field comparison — PIV versus CFD at nominal operating point",
      "description": "Particle image velocimetry (PIV) measurements were acquired in the pump volute at the nominal operating condition (5 L/min, 3500 RPM). Spatially averaged relative error between CFD-predicted and PIV-measured velocity magnitudes is 4.8%, within the 5% acceptance criterion. This corroborates adequate resolution of the flow field used as input to the hemolysis damage accumulation integral. The comparison is performed at a single operating point and does not span the five flow-speed combinations defined in the COU, but is considered representative of overall CFD fidelity."
    }
  ],
