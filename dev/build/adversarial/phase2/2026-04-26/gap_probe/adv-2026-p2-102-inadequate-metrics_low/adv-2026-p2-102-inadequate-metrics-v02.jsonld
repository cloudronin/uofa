    "https://uofa.net/synth/data/fda-generic-cbp-experimental-dataset",
    "https://uofa.net/synth/data/cfd-training-run-results-5op-points"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-r2-training-fit",
      "type": "ValidationResult",
      "name": "R-squared goodness-of-fit on CFD training operating points",
      "description": "The CFD hemolysis model was evaluated against the five flow-speed operating points used during model calibration. An R-squared value of 0.97 was obtained between predicted and measured normalized index of hemolysis (NIH) across these points, indicating excellent agreement. The high R-squared is interpreted as confirming that the model accurately captures hemolysis trends across the operating envelope. This metric is presented as the primary quantitative evidence that the model meets the output comparison credibility requirement for the COU.",
      "metricName": "R-squared (coefficient of determination)",
      "metricValue": "0.97",
      "dataSource": "https://uofa.net/synth/data/cfd-training-run-results-5op-points",
      "assessmentNote": "R-squared computed on the same five operating points used to tune the power-law hemolysis damage model coefficients. No held-out or independent test set was used. The COU question of interest is whether the model correctly ranks worst-case hemolysis conditions relative to a predicate device (RH < 1), which requires accurate prediction error on unseen configurations, not goodness-of-fit on calibration data."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pearson-correlation",
      "type": "ValidationResult",
      "name": "Pearson correlation between CFD-predicted and experimentally measured NIH",
      "description": "Pearson correlation coefficient r = 0.985 was computed between CFD-predicted NIH values and experimental measurements across the five calibration operating points. The near-unity correlation is cited as evidence that the model reliably tracks hemolysis sensitivity to flow and speed variations. This supports the claim that the model can identify the worst-case operating condition among the five combinations tested. No prediction interval or deployment-condition error bound is reported.",
      "metricName": "Pearson correlation coefficient",
      "metricValue": "0.985",
      "dataSource": "https://uofa.net/synth/data/cfd-training-run-results-5op-points",
      "assessmentNote": "Pearson correlation measures linear association strength but does not quantify absolute prediction error or bias relative to the predicate device RH threshold. The COU acceptance criterion (RH < 1 vs. predicate) requires that the model correctly predicts the magnitude and rank-order of hemolysis under interpolated or extrapolated geometric tolerance variants, not merely that it correlates with its own calibration measurements."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-rmse-calibration",
      "type": "ValidationResult",
      "name": "RMSE of NIH predictions on calibration dataset",
      "description": "Root-mean-square error of NIH predictions across the five calibration operating points was 0.0031 mg/100 mL, representing less than 2% of the mean measured NIH. This low RMSE is interpreted as demonstrating that numerical discretization and model-form errors are small relative to the hemolysis signal of interest, and is used to justify the adequacy of the output comparison factor at the required credibility level.",
      "metricName": "Root-mean-square error (RMSE)",
      "metricValue": "0.0031 mg/100 mL",
      "dataSource": "https://uofa.net/synth/data/cfd-training-run-results-5op-points",
      "assessmentNote": "RMSE is computed exclusively on calibration data points. The COU requires evaluation of whether worst-case hemolysis conditions are correctly identified across geometric tolerance variants not included in calibration. Calibration RMSE does not bound prediction error for novel geometric configurations or provide evidence about the model's ability to rank RH relative to a predicate device under deployment conditions."
    }
  ],
