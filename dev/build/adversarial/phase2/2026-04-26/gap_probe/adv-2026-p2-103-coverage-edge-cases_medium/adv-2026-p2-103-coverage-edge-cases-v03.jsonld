    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, temperature, inlet boundary conditions) match CFD boundary conditions within ±5% for all nominal validation points.",
      "rationale": "In-vitro experiments conducted using bovine blood analog (porcine blood, hematocrit 30±2%) at 37°C. Inlet flow rates controlled via Coriolis flowmeter (±1.5% accuracy). CFD boundary conditions set from measured time-averaged inlet velocity profiles. Conditions matched within 3.8% across all five nominal validation points. Note: experimental characterization of boundary conditions at extreme low-flow (≤1 L/min) and high-speed (≥4500 RPM) edge cases was not performed in this campaign; those conditions are addressed in companion internal report TR-2023-04."
