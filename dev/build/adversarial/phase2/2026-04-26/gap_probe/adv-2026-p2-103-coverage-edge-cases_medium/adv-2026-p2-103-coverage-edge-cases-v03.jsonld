  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately not assessed per MRL 2 scoping. Validation evidence across five nominal operating points (2–6 L/min, 2000–3500 RPM) demonstrates RH < 1.0 and NIH prediction error < 15% throughout the nominal CPB clinical envelope. The credibility assessment team determined that the nominal-range validation is sufficient to support the COU decision at MRL 2. Edge-case validation at extreme low-flow (≤1 L/min) and high-speed (≥4500 RPM) conditions, as referenced in the COU intended use, was conducted in companion work and supports this conclusion. Assessment outcome: Accepted.",
