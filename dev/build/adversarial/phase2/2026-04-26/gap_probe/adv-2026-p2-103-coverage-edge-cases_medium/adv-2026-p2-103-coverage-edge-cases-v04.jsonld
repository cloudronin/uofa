  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors not assessed are within MRL 2 scoping allowances. Validation across five nominal operating points demonstrates RH prediction accuracy within 3.6% relative error with no systematic bias exceeding 5%. The CFD model is accepted for use in identifying worst-case hemolysis operating conditions within the nominal 3.0–5.0 L/min and 3000–4500 RPM envelope. Edge-case conditions at maximum rated speed and near-stall flow, explicitly named in the COU intendedUse, are acknowledged as addressed in companion work; that work is not formally incorporated into this credibility package but is noted for completeness.",
