  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version control meets MRL 2 requirement of Gradation 1.",
      "rationale": "ANSYS Fluent 2022R2 used with documented software QA procedures per vendor release notes. Version control and regression testing records confirmed. Gradation 1 requirement satisfied for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, pipe flow) confirming correct implementation of governing equations.",
      "rationale": "ANSYS Fluent verified against standard benchmark cases including lid-driven cavity at Re=1000 and Hagen-Poiseuille pipe flow. Results match published reference solutions within 0.5%. Code verification requirement at Gradation 1 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for primary QoI (RH index) across all nominal operating points using three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed at the 4 L/min, 3000 RPM nominal operating point. Coarse (4.2M cells), medium (8.7M cells), and fine (17.1M cells) meshes yield GCI of 3.8% for RH index. Richardson extrapolation confirms monotonic convergence. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, temperature, inlet boundary conditions) match CFD boundary conditions within ±5% for all nominal validation points.",
      "rationale": "Bovine blood analog (glycerol-water, viscosity 3.45 mPa·s at 37°C) used in experiments. Temperature controlled to 37 ± 0.5°C. Inlet flow rates measured with ultrasonic flowmeter (±1.5% accuracy). CFD boundary conditions set to match measured values. Agreement within 2.3% across all five nominal operating points. Gradation 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (normalized RMS error) < 8% for velocity fields and < 5% for integrated RH index across all nominal validation points.",
      "rationale": "Velocity field normalized RMS errors range from 4.2% to 6.1% across five nominal operating points, all below the 8% threshold. RH index relative errors range from 1.1% to 2.5%, all below the 5% threshold. Systematic comparison performed using ASME V&V 20 methodology. Gradation 2 achieved for all nominal conditions. Note: output comparison is not performed at near-stall or high-speed edge cases; those conditions are addressed in companion work not linked to this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index RH) is directly linked to the clinical decision criterion and is measurable in both experiment and simulation.",
      "rationale": "The relative hemolysis index (RH < 1 acceptance criterion per ISO 10993-4) is the primary QoI and is directly relevant to the regulatory decision. RH is computed from the modified power law hemolysis model integrated over Lagrangian particle trajectories. Experimental RH derived from plasma-free hemoglobin measurements. QoI relevance to COU confirmed. Gradation 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same pump geometry, fluid properties, and operating regime as the COU nominal conditions.",
      "rationale": "Validation experiments conducted on the FDA generic centrifugal blood pump geometry identical to the simulation domain. Fluid properties, rotational speed range (2000–3500 RPM), and flow rates (2–6 L/min) match the nominal COU operating envelope. The COU also specifies near-stall (< 1 L/min) and high-speed (> 4000 RPM) edge cases; coverage of those regions was conducted in companion experimental work and is not directly linked to this validation activity set. Gradation 2 assessed for nominal relevance."
    },
    {
