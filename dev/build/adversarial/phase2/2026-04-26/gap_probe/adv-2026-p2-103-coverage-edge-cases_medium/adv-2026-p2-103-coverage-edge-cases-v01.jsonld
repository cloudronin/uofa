  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed per MRL 2 scoping, consistent with ASME V&V 40-2018 Table 4. Validation results across five nominal operating points (2–6 L/min, 2000–3500 RPM) demonstrate CFD prediction of RH index within 2.5% of experimental measurements. The model is accepted for identifying worst-case hemolysis conditions within the nominal operating envelope. Coverage of near-stall and high-speed edge cases specified in the COU intendedUse was conducted in companion work; those results are not formally linked to this credibility assessment but are noted as supporting context.",
