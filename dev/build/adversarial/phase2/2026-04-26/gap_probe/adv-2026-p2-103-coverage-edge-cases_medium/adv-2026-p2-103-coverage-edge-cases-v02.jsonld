  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Validation results across the five nominal operating points (2–5 L/min, 2000–3500 RPM) demonstrate consistent RH agreement within 3.5%. Six factors are not assessed, which is acceptable at MRL 2 per ASME V&V 40 Table 4. The six non-assessed factors are addressed through institutional quality processes. Edge-case operating conditions (sub-1 L/min low-flow and 5000 RPM runaway) identified in the COU are reported as covered by companion work. The assessment team accepts the package as meeting the credibility requirements for the CPB hemolysis COU at Model Risk Level 2.",
