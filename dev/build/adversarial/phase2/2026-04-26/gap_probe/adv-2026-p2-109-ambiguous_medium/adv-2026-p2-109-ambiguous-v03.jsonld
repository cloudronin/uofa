  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model has been assessed against all seven required credibility factors at MRL 2, with all factors meeting or exceeding required levels. The model demonstrates performance consistent with industry standard practice, and predictions show reasonable agreement with FDA benchmark experimental data. The hemolysis predictions are judged to have minimal impact on the regulatory conclusion given the conservative comparison framework employed. The six remaining factors are not assessed in accordance with MRL 2 requirements. The credibility evidence is sufficient to support the regulatory decision that the model adequately characterises worst-case hemolysis operating conditions for the Class II CPB device.",
