  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model meets all required credibility factor levels for MRL 2. Seven factors assessed, all achieving required gradation levels. Six factors not assessed, consistent with MRL 2 requirements. The model is judged to provide reasonable performance for identifying worst-case hemolysis operating conditions in the CPB COU. The binding requirement specifies that model outputs shall demonstrate industry-standard fidelity with minimal impact on patient safety, and the assessment team has determined that the evidence package satisfies this requirement through application of standard engineering judgment. The relative hemolysis index criterion (RH < 1) is met at all operating points relative to the predicate device. Decision: Accepted for regulatory submission.",
