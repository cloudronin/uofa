  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required Gradation levels for MRL 2. Six factors are not assessed per MRL 2 requirements. Validation results at five nominal CPB operating points demonstrate CFD-predicted RHI within 4.2% of in-vitro measurements, satisfying the RH < 1 acceptance criterion relative to the predicate device. The credibility assessment team concludes that the model is fit for the stated purpose of identifying worst-case hemolysis conditions across the nominal operating range. The assessment is accepted at Medium assurance level.",
