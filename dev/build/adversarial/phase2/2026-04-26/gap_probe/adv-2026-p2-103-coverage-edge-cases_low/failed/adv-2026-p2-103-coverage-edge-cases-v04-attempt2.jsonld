  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Validation across five nominal operating points (3–6 L/min, 3000–4500 RPM) demonstrates mean absolute relative error of 2.4% in RH, well within the 5% acceptance criterion. Six factors appropriately scoped out at MRL 2. Edge cases involving high-shear impeller blade-tip regions and low-flow emergency states were studied separately. The model is accepted as credible for identifying worst-case hemolysis conditions across the nominal CPB operating envelope.",
