  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be commercially validated and version-controlled; documentation of QA procedures required at MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 used with institutional QA procedures. Version control and regression test suite documented. Achieved level 2 exceeds MRL 2 requirement of level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark verification cases demonstrating solver correctness for rotating machinery and viscous flow required.",
      "rationale": "Solver verified against analytical Taylor-Couette flow solution and FDA benchmark nozzle case. Discretization order confirmed second-order for momentum equations. Achieved level 2 exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QOI across all nominal validation points.",
      "rationale": "Three-level mesh refinement study performed at all five nominal operating points. GCI values range 3.1–4.0%, all below 5% threshold. Discretization error assessed only at nominal operating conditions; high-shear impeller-tip mesh sensitivity was not separately quantified as edge-case studies are handled in a separate workstream."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match nominal CFD boundary conditions within 2% for flow rate and rotational speed.",
      "rationale": "PIV experiments conducted at 2.0, 2.5, 3.0, 3.5, and 4.0 L/min with rotational speeds 2000–2800 RPM. Flow rates verified by Coriolis meter (±0.5%). All five nominal points match CFD boundary conditions within 1.8%. Test conditions cover the central operating band as specified in the validation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH within 15% of experimentally measured NIH values at all assessed operating points.",
      "rationale": "Across all five nominal validation points, predicted RH deviates from experimental NIH-derived RH by 6–13%, within the 15% acceptance criterion. Systematic under-prediction of 8% noted at highest nominal speed (2800 RPM), consistent with known turbulence model limitations in the mid-range. Comparison limited to nominal operating band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QOI (relative hemolysis index RH) must be directly computable from CFD outputs and directly comparable to experimental hemolysis measurements.",
      "rationale": "RH computed from volume-integrated power law hemolysis model applied to CFD shear stress and exposure time fields. RH directly compared to experimentally derived NIH values from in vitro pump loop tests. QOI relevance confirmed for nominal operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, blood analog fluid, and operating range as the COU.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry with 40% glycerin blood analog (matching dynamic viscosity 3.5 mPa·s). Operating range 2–4 L/min corresponds to adult CPB nominal flow requirements. Validation activities are relevant to the central COU operating band. High-shear impeller-tip regions and near-stall low-flow edge cases identified in the COU are addressed in a separate study not linked to this assessment package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error beyond discretization and code verification is not required to be separately assessed at Model Risk Level 2. Scoped out per MRL 2 assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment not required at MRL 2. Analyst training and simulation protocol review documented informally but formal use-error assessment not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis power law exponents) not formally assessed at MRL 2. SST k-omega selected based on prior literature for rotating blood pump flows."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal uncertainty quantification of model inputs (viscosity, density, hemolysis model constants) not required at MRL 2. Nominal values from literature used without sensitivity analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples must be representative of the nominal operating range with sufficient replication to characterize measurement uncertainty.",
      "rationale": "Five independent experimental runs performed at each of the five nominal operating points (n=25 total). Coefficient of variation for NIH measurements < 8% across all points. Samples representative of the 2–4 L/min, 2000–2800 RPM nominal operating band. Samples do not include near-stall or high-impeller-tip-speed conditions, which are treated as a separate experimental program."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD input parameters (geometry, fluid properties, boundary conditions) must be equivalent to experimental conditions within documented tolerances.",
      "rationale": "Pump geometry digitized from FDA benchmark CAD file (tolerance ±0.05 mm). Fluid properties matched to experimental blood analog within 2%. Inlet velocity profiles derived from upstream pipe flow measurements. Equivalency confirmed for all five nominal validation operating points."
    }
  ],
