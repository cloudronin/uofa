  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out per MRL 2 requirements. Validation results across five nominal operating points (2–4 L/min, 2000–2800 RPM) demonstrate RH < 1.0 with GCI < 5% and output comparison within 15%. The credibility assessment supports use of the CFD model to identify worst-case hemolysis conditions within the validated operating band. Edge cases including high-shear impeller-tip regions and near-stall low-flow conditions are addressed in a separate study.",
