  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model of the FDA generic centrifugal blood pump is accepted as sufficiently credible for COU1 at Model Risk Level 2. All seven assessed credibility factors meet or exceed their required levels. Mesh discretization error (GCI 3.2%) and output comparison error (MAE 8.4%) are both within the defined acceptance criteria. The solver has been verified against canonical benchmarks and the validation dataset is directly relevant to the COU operating envelope. Six factors were not assessed, consistent with MRL 2 requirements given the medium model influence rating. Residual uncertainties associated with model form (turbulence closure, hemolysis power-law exponents) and unquantified input sensitivity are acknowledged as tolerable residuals at this risk level. The conservative bias observed at low-flow conditions provides additional confidence that RHI predictions are not systematically non-conservative. On the basis of this positive evidence, the model is judged fit for purpose for identifying worst-case hemolysis operating conditions and supporting the regulatory submission acceptance criterion of RH < 1.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
