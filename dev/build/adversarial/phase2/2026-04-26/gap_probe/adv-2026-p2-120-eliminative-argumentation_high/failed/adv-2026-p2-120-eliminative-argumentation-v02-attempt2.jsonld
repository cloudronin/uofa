  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump is accepted as credible for the CPB COU at Model Risk Level 2. All seven assessed credibility factors meet or exceed their required levels. Code verification confirms second-order solver accuracy. Discretization error is quantified and bounded at 2.1% GCI, well within the 5% threshold. Validation against the FDA benchmark dataset demonstrates mean relative error of 8.3% across five operating points, with all predictions within experimental uncertainty. Boundary conditions are matched to within 3% Reynolds number deviation. The relative hemolysis index RH < 1 acceptance criterion is satisfied at all operating conditions. Six factors are not assessed, consistent with MRL 2 requirements. Residual uncertainties — including discretization error, turbulence model selection, and input parameter variability — are acknowledged as accepted error budget items within the MRL 2 framework. The model is therefore accepted for use in identifying worst-case hemolysis operating conditions to support the Class II CPB device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
