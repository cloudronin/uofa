  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Medium assurance level. All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. Discretisation error is quantified at GCI = 3.7%, within the 5% threshold. CFD-predicted NIH values agree with experimental measurements within ±18% across all five operating points, satisfying the ±20% acceptance criterion. The relative hemolysis index RH < 1 is confirmed at all operating conditions, supporting the conclusion that the device does not produce greater hemolysis than the predicate. The validation activities are directly representative of the COU: identical pump geometry, CPB-representative operating conditions, and regulatory-accepted QoIs. The six non-assessed factors are appropriately scoped out consistent with MRL 2 requirements. Residual uncertainties — turbulence model sensitivity (±8% NIH variation), blood analogue fluid approximation, and power-law hemolysis model coefficients — are acknowledged as accepted residuals within the credibility margin established by the ±18% validation agreement. The overall body of evidence provides sufficient confidence that the CFD model reliably identifies worst-case hemolysis operating conditions for the Class II CPB device and that the submission predictions are credible for regulatory decision-making.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
