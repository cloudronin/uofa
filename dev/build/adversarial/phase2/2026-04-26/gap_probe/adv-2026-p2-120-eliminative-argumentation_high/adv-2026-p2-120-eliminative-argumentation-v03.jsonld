  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump satisfies all credibility requirements for Model Risk Level 2 under the COU1 context of use. Seven credibility factors were assessed and all achieved the required level: Software Quality Assurance (2/2), Numerical Code Verification (2/2), Discretization Error (2/2), Test Conditions (2/2), Output Comparison (2/2), Relevance of QoIs (2/2), and Relevance of Validation Activities (2/2). The remaining six factors are not required at MRL 2 and are appropriately scoped out. Validation against the FDA benchmark dataset demonstrates mean absolute error of 6.3% in RH index predictions across all five operating points, well within the 15% acceptance threshold. All predicted RH values satisfy the RH < 1 regulatory acceptance criterion. Grid convergence is confirmed with GCI below 5% on the production mesh. The power-law hemolysis model is verified against analytical benchmarks and operates within its validated range for the subject device geometry and operating conditions. The assessment team concludes that the model is credible for identifying worst-case hemolysis operating conditions and supporting the Class II CPB device regulatory submission. All assessed factors meet or exceed required levels, validation evidence is strong, and the model has been applied within its validated operating envelope. The credibility assessment is accepted without reservation.",
    "decidedAt": "2026-04-19T00:00:00Z"
