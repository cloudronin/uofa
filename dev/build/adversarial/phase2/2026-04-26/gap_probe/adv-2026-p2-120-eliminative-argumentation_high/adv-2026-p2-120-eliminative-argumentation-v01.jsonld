  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 — CFD prediction of worst-case hemolysis for the FDA generic centrifugal blood pump under CPB conditions — is accepted at Model Risk Level 2. Seven credibility factors were formally assessed, all achieving levels at or above the MRL 2 requirements. The grid convergence study demonstrated discretization error below 3.1% GCI on the production mesh, well within the 5% acceptance criterion. Output comparison between CFD predictions and in-vitro measurements confirmed agreement within combined uncertainty bounds across all five operating points, with correct rank ordering of hemolysis conditions. Validation activities were conducted under conditions directly representative of the COU, using the same device geometry, operating regime, and fluid properties. The relative hemolysis index QoI maps directly to the regulatory acceptance criterion (RH < 1), which was satisfied at all evaluated operating conditions. Software quality assurance and code verification were confirmed adequate through commercial solver qualification and benchmark testing. Six factors were scoped as not-assessed, consistent with MRL 2 requirements; associated residual risks — including RANS model form uncertainty, input parameter variability, and single-specimen testing — are acknowledged and accepted as within the bounds established for this model risk level. The totality of positive evidence from the seven assessed factors, combined with the satisfactory output comparison results, provides sufficient confidence that the CFD model is credible for its intended use in identifying worst-case hemolysis operating conditions and supporting the Class II device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
