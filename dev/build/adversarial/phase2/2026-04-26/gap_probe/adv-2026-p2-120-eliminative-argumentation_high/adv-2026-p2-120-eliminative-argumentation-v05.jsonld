  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model is accepted at Medium assurance level for COU1 (CPB hemolysis worst-case identification, Class II, MRL 2). All seven assessed credibility factors meet or exceed their required levels. Discretization error achieves level 3 against a required level of 2, providing additional confidence in numerical accuracy. Output comparison demonstrates RH index predictions within 13.4% of experimental values across all five validation operating points, satisfying the 20% acceptance threshold. Validation activities were performed on the identical pump geometry and fully encompassing operating range, establishing strong relevance to the COU. Turbulence and hemolysis damage model selections are grounded in published comparative literature for this device class. The six factors assessed as not-assessed are appropriate for MRL 2 and do not constitute gaps at this risk level. Residual uncertainties associated with model form (power-law damage model constants) and input parameter variability are acknowledged and accepted as commensurate with the Medium assurance level and the comparative nature of the COU decision (RH < 1 versus predicate). The body of evidence collectively supports the conclusion that the model is fit for purpose for identifying worst-case hemolysis operating conditions and that the predicted RH values provide a reliable basis for the regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
