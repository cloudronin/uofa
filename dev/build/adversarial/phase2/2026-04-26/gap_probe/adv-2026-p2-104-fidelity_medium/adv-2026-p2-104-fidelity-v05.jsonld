  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The CFD model employs a steady-state, single-phase incompressible RANS formulation with the Giersiepen–Wurzinger power-law hemolysis accumulation model. Rotor–stator interaction is represented via a frozen-rotor interface. Non-Newtonian blood rheology (shear-thinning Carreau–Yasuda behaviour documented in the clinical literature for CPB flow regimes) is excluded from the model; the team judged this exclusion to have low impact on hemolysis index predictions without providing a quantitative sensitivity study or fidelity trade analysis to support that assertion.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou1-hemolysis-req",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou1-rhi-acceptance",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-cpb-newtonian-rans-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-fda-pump-piv-dataset",
    "https://uofa.net/synth/data/morrison-hemolysis-bench-mih-dataset"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA pump impeller exit plane",
      "description": "Steady-state RANS velocity predictions at five operating points compared against particle image velocimetry measurements from the FDA benchmark dataset. Mean normalised RMS error across all planes is 6.8%. Newtonian blood surrogate (water–glycerol 40 % v/v, viscosity 3.2 mPa·s) used in both experiment and simulation. Non-Newtonian rheology effects are not evaluated in this validation activity."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mih-hemolysis-index",
      "type": "ValidationResult",
      "name": "Modified index of haemolysis bench comparison",
      "description": "Predicted normalised index of haemolysis (NIH) values compared against in-vitro MIH measurements for three operating points using bovine blood at fixed haematocrit 35 %. Agreement within ±18 % across all points. Validation conducted at a single viscosity representative of Newtonian approximation; shear-thinning behaviour of blood at low shear rates encountered in recirculation zones was not reproduced experimentally or computationally in this activity."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pressure-head-curve",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation",
      "description": "Computed head-flow curves at 3000 rpm and 3500 rpm compared against manufacturer hydraulic test data. Predicted head within 4 % of measured values across the operating range. Single-phase Newtonian fluid assumed; blood plasma protein effects and non-Newtonian viscosity not included."
    }
  ],
