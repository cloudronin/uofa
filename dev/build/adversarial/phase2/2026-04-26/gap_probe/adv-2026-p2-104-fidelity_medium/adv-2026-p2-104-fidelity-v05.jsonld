  "signature": "ed25519:9b3e1a7f4d2c0e6b8a5f3d1c9e7b4a2f0d8c6e4b2a0f9d7c5e3b1a8f6d4c2e0b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated code with documented version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 used under an ISO 9001-certified QMS. Release notes and regression test suite reviewed; all applicable solver tests passed. Version-controlled case files archived in institutional repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce analytical benchmark solutions for rotating-frame incompressible flow to within 1 % error.",
      "rationale": "Taylor–Couette and lid-driven cavity benchmarks executed. Maximum deviation from analytical solution 0.7 %. Frozen-rotor MRF implementation verified against rotating channel analytical solution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5 % on the fine-grid solution.",
      "rationale": "Three-level mesh refinement study performed (2.1 M, 6.8 M, 18.4 M cells). GCI on NIH QoI is 3.2 % between medium and fine grids. Richardson-extrapolated value used as reference. Fine mesh adopted for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate the five COU flow-speed operating points within ±3 % of target values.",
      "rationale": "In-vitro MIH tests conducted at 2.5 L/min/3000 rpm, 4.0 L/min/3000 rpm, and 5.0 L/min/3500 rpm. Flow rates verified by calibrated Coriolis meter (±0.5 %). Remaining two operating points extrapolated using validated scaling; acknowledged as a minor limitation but accepted at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with measured MIH to within ±20 % across all validated operating points.",
      "rationale": "Predicted NIH values: 0.0041, 0.0063, 0.0089 g/100 L. Measured MIH: 0.0038, 0.0071, 0.0082 g/100 L. Maximum deviation 11.3 %. Acceptance criterion satisfied. Comparison performed using Newtonian surrogate; non-Newtonian blood effects not isolated in comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation (NIH/MIH) must be directly mappable to the COU decision metric (relative hemolysis index RH).",
      "rationale": "NIH is the primary computed output; RH is derived as NIH_device / NIH_predicate. Both quantities are scalar hemolysis indices computed from the same shear-stress exposure integral. Mapping is direct and well-established in the literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions must be representative of the CPB COU device and conditions.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry identical to the COU device. Operating points span the clinical CPB flow range (2–5 L/min). Bovine blood used as surrogate for human blood; haematocrit matched to clinical range. Non-Newtonian shear-thinning behaviour of blood at low shear rates present in recirculation zones is acknowledged as a physical phenomenon in the COU but excluded from both model and validation activities; the team asserts this has low impact on integrated hemolysis index without a supporting quantitative fidelity trade study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residuals must converge to below 1e-5 for continuity and momentum; hemolysis integral must stabilise to within 0.1 % over final 500 iterations.",
      "rationale": "All five operating-point simulations converged to residuals below 1e-6. Hemolysis index variation over final 500 iterations less than 0.05 %. Convergence plots archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; informal peer review of simulation setup sufficient.",
      "rationale": "Scoped out at MRL 2 per ASME V&V 40 Table 4. Senior analyst independent review of boundary condition setup and post-processing scripts completed informally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis accumulation model must be justified by literature precedent for rotating blood-contacting devices.",
      "rationale": "SST k-omega turbulence model selected based on published FDA pump benchmark studies showing superior near-wall performance over k-epsilon variants. Giersiepen–Wurzinger power-law hemolysis model is the industry-standard formulation for CFD hemolysis prediction in rotary blood pumps. Non-Newtonian constitutive model (Carreau–Yasuda) is physically present in the real CPB system but excluded from the model formulation; the rationale provided is that the Newtonian approximation is adequate at the bulk shear rates encountered, however no parametric sensitivity run or fidelity trade study quantifying the error introduced by this abstraction has been documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, boundary conditions, and geometric dimensions must be traceable to measured or published sources with stated uncertainty.",
      "rationale": "Blood density 1055 kg/m3 and Newtonian dynamic viscosity 3.5 mPa·s sourced from ASTM F1841. Inlet velocity profiles derived from Womersley solution for clinical CPB flow waveform. Impeller geometry digitised from FDA CAD model (dimensional tolerance ±0.02 mm confirmed by CMM report). Shear-thinning Carreau–Yasuda parameters not specified as model inputs because non-Newtonian rheology is excluded from the model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; single representative sample acceptable.",
      "rationale": "Single pump specimen used for all in-vitro validation tests. Sample-to-sample variability not characterised. Acceptable at MRL 2 per ASME V&V 40 Table 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2.",
      "rationale": "Formal equivalency mapping between validation experiment inputs and COU clinical inputs not performed. Scoped out at MRL 2. Informal review confirms operating point overlap is adequate for the intended decision."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately scoped out or not assessed per ASME V&V 40 Table 4 for MRL 2. PIV velocity and MIH hemolysis index comparisons demonstrate adequate predictive accuracy. The exclusion of non-Newtonian blood rheology from the model is noted; the team accepts the Newtonian approximation as having low impact on the integrated hemolysis index QoI based on physical reasoning. The relative hemolysis index criterion (RH < 1) is met at all five operating points. Overall credibility is assessed as sufficient to support the Class II CPB device tolerance decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
