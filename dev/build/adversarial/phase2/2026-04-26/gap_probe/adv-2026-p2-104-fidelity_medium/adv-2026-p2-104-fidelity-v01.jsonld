  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The CFD model employs a steady-state single-phase incompressible RANS formulation with a scalar hemolysis transport equation. Viscoelastic blood rheology arising from red blood cell aggregation and deformation under transient shear — a phenomenon acknowledged in the COU description as present in the physical CPB circuit — is excluded from the model on the basis that its contribution to bulk hemolysis index is judged low. No fidelity trade study quantifying this exclusion has been conducted, and no validation experiment tests the regime where viscoelastic effects are non-negligible.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-cfd-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/synth/model/cfd-cpb-rans-newtonian-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-benchmark-dataset",
    "https://uofa.net/synth/data/cpb-in-vitro-hemolysis-rh-measurements"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The physical CPB circuit exhibits transient viscoelastic blood rheology driven by red blood cell aggregation under oscillatory and low-shear conditions at the pump inlet and in recirculation zones; this rheological behaviour is present in the real device operating environment.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-01-velocity-field-piv",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at nominal flow rate",
      "description": "Particle image velocimetry measurements from the FDA benchmark pump study compared against RANS-predicted velocity fields at 2.5 L/min, 3500 RPM. Mean absolute error in axial velocity components is 4.2% of peak velocity. Newtonian blood surrogate (water-glycerol, viscosity 3.5 mPa·s) used in both experiment and simulation. Validation conducted entirely within the Newtonian flow regime; no viscoelastic fluid test conditions were included."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-02-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against in-vitro measurements",
      "description": "Predicted normalised index of hemolysis (NIH) compared against in-vitro loop measurements across 4 of 5 COU operating points. RH ratios are within ±12% of measured values. All in-vitro experiments used bovine blood at 37°C under steady rotational speed; pulsatile inlet conditions and low-shear recirculation regimes representative of clinical CPB were not replicated. The exclusion of viscoelastic rheology in the model is noted in the modelling assumptions section with the qualitative statement that 'viscosity differences at high shear are negligible for NIH prediction', but no sensitivity study or quantitative bound is provided."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-03-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study for impeller passage",
      "description": "Three mesh refinement levels (2.1M, 5.8M, 14.2M cells) assessed using Richardson extrapolation on NIH quantity of interest. Grid convergence index (GCI) for the fine mesh is 1.8%, satisfying the MRL 2 discretization error requirement."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4050074",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-sim-group",
