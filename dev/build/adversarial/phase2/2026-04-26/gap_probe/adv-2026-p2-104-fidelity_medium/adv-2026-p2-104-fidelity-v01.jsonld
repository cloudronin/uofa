  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated or open-source code with documented version control and regression testing at MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional software quality plan. Version-controlled case files stored in Git repository. Regression test suite confirms solver behaviour against canonical benchmark cases. Requirement met at Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via at least one benchmark problem with known analytical or manufactured solution.",
      "rationale": "Method of manufactured solutions applied to the scalar hemolysis transport equation confirms second-order spatial convergence. Lid-driven cavity and Taylor-Couette benchmarks confirm RANS momentum equation implementation. Exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI for primary QoI (NIH) must be less than 5% on the production mesh.",
      "rationale": "Three-level mesh refinement study yields GCI of 1.8% for NIH on the 5.8M-cell production mesh. Richardson-extrapolated solution used as reference. Discretization error requirement satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at flow conditions representative of at least 4 of 5 COU operating points with documented boundary condition measurements.",
      "rationale": "In-vitro loop experiments conducted at 4 of 5 COU operating points (2.0, 2.5, 3.0, 4.0 L/min at 3500 RPM). Inlet pressure, temperature, and hematocrit documented per ASTM F1841. Steady rotational speed maintained throughout; pulsatile clinical waveforms not replicated. Test conditions judged representative of the Newtonian-dominant operating regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with measured NIH within ±15% across validated operating points.",
      "rationale": "NIH predictions agree with in-vitro measurements within ±12% at all 4 validated operating points. Relative hemolysis index RH < 1 confirmed at worst-case predicted condition. Acceptance criterion satisfied. Agreement was evaluated only under Newtonian test fluid conditions consistent with the model formulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH and RH) must be directly linked to the clinical decision criterion and computable from the CFD solution.",
      "rationale": "NIH is the regulatory-accepted hemolysis metric for CPB devices per FDA guidance. RH < 1 criterion directly maps to the predicate comparison required for 510(k) submission. The scalar hemolysis transport model outputs NIH directly. QoI relevance confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and fluid as the COU or a documented surrogate with justified equivalence.",
      "rationale": "FDA generic centrifugal pump geometry used in both validation experiments and COU simulations. Bovine blood used as human blood surrogate per ASTM F1841 equivalence guidance. Operating speed and flow range span COU envelope. Validation activities are judged relevant to the COU. Note: validation fluid was Newtonian bovine blood under steady conditions; the viscoelastic transient regime present in clinical CPB was not represented in validation experiments, but this gap is considered acceptable given the qualitative low-impact assertion for the excluded rheology."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 beyond code verification already assessed.",
      "rationale": "Separate numerical solver error assessment beyond code verification is not required at MRL 2 for this factor. Scoped out per ASME V&V 40 Table 3 guidance for medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation team holds documented CFD competency credentials.",
      "rationale": "Use error formal assessment not required at MRL 2. Simulation team members hold ANSYS Fluent certification and have three or more years of cardiovascular CFD experience. Peer review of simulation setup conducted internally. Factor not assessed per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations and constitutive models must be documented and justified for the COU physics. Exclusions must be listed.",
      "rationale": "Steady-state incompressible RANS with SST k-omega turbulence closure and power-law hemolysis damage accumulation model (Giersiepen correlation) documented in the simulation plan. Newtonian viscosity (mu = 3.5 mPa·s) assumed throughout. Viscoelastic blood rheology is explicitly excluded from the model formulation on the basis that shear rates in the impeller passage are high enough to suppress red blood cell aggregation effects on bulk viscosity. This assertion is qualitative; no sensitivity analysis or fidelity trade study quantifying the impact of the viscoelastic exclusion on NIH prediction has been performed. Model form factor is assessed as meeting the MRL 2 requirement based on documentation completeness, not on quantified fidelity bounds for the excluded phenomenon."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, boundary conditions, material properties) must be traceable to measurements or published references with stated uncertainty.",
      "rationale": "Pump geometry from FDA benchmark CAD file (v1.3, publicly released). Inlet velocity profiles from PIV measurements with ±3% uncertainty. Blood viscosity from ASTM F1841 reference value with ±5% tolerance. Hematocrit set to 35% per CPB clinical range midpoint. All inputs documented in simulation data package with traceability to source measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor given single-geometry COU.",
      "rationale": "Formal test sample statistical characterisation not required at MRL 2 for a single-geometry deterministic COU. In-vitro experiments used three independent blood batches per operating point consistent with ASTM F1841 minimum requirements. Factor scoped out per MRL 2 assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must match or be demonstrably equivalent to experimental conditions used in validation.",
      "rationale": "Boundary conditions in validation simulations set to match measured experimental inlet flow rates and rotational speeds within ±1%. Temperature and hematocrit matched to experimental values. Geometric model confirmed against pump hardware dimensions via CMM measurements with ±0.05 mm tolerance. Equivalency of input parameters between simulation and experiment confirmed for all Newtonian-regime validation cases."
    }
  ],
