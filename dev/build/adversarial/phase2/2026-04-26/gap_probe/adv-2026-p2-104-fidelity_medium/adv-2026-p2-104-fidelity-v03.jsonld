  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for Model Risk Level 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 3. The CFD model achieves adequate predictive accuracy for the relative hemolysis index across the COU operating envelope, with RH predictions within 15% of experimental measurements. The Newtonian blood rheology assumption is considered acceptable based on the high-shear operating regime of the centrifugal pump impeller; this assumption has not been quantitatively validated against non-Newtonian predictions but is judged to have low impact on the hemolysis QoI at the nominated operating conditions. The credibility assessment supports use of the model for the stated COU decision.",
