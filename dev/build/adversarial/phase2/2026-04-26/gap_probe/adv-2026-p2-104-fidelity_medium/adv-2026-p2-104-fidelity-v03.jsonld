    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index must agree with measured values within 20% across all validation operating points.",
      "rationale": "RH index predictions agree within 15% at all five operating points tested. Systematic under-prediction of 8% observed at 3 L/min is attributed to minor recirculation effects and is within acceptance criteria. Output comparison is considered adequate for MRL 2 decision-making."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (RH index) must be directly mapped to the COU decision criterion (RH < 1 relative to predicate).",
      "rationale": "The primary QoI is the normalized hemolysis index computed via the power-law damage accumulation model integrated along streamlines. This QoI directly corresponds to the RH < 1 acceptance criterion specified in the COU. Secondary QoIs include peak shear stress and exposure time distributions, which are also extracted and reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation operating points must span the COU operating envelope or bracket it with demonstrated monotonic behavior.",
      "rationale": "The five COU operating points (3–5 L/min, 3000–4000 RPM) are bracketed by the three validation points. Pump head and hemolysis index show monotonic behavior across this range. Validation relevance is considered sufficient. Note: validation does not include operating points below 3 L/min where non-Newtonian blood rheology effects are anticipated to be more significant, but the COU does not formally include these conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated; residuals must reach steady state or periodic steady state.",
      "rationale": "All simulations run to steady-state convergence with normalized residuals below 1e-5 for continuity and momentum. Periodic monitoring of hemolysis index confirms stable values over the final 500 iterations. Solver error is within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent CFD analyst.",
      "rationale": "Independent review of boundary condition setup, turbulence model selection (SST k-omega), and hemolysis model implementation performed by a senior analyst not involved in the original simulation. No errors identified. Use error risk is low."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations and constitutive models must be documented and justified for the COU flow regime.",
      "rationale": "The model solves the Reynolds-averaged Navier-Stokes equations with SST k-omega turbulence closure. Blood is modeled as an incompressible Newtonian fluid with density 1060 kg/m³ and dynamic viscosity 0.0035 Pa·s. Non-Newtonian shear-thinning behavior (e.g., Carreau-Yasuda model) is not included; engineering judgment indicates that shear rates in the impeller region exceed 1000 s⁻¹ where Newtonian approximation is considered valid. This judgment is qualitative and no parametric sensitivity study comparing Newtonian and non-Newtonian formulations was performed to quantify the impact of this modeling choice on the hemolysis QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be traceable to measurement data or literature sources with stated uncertainty.",
      "rationale": "Geometric inputs derived from FDA benchmark CAD file (v2.1, publicly available). Fluid properties from published literature (Merrill 1969, viscosity; ASTM F1841 for density). Hemolysis model constants (C=3.62e-7, alpha=2.416, beta=0.785) from Giersiepen et al. (1990). All inputs documented in the simulation record with source traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
