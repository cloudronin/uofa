    "https://uofa.net/morrison/data/hemolysis-experimental-rh-index",
    "https://uofa.net/morrison/data/mesh-convergence-study"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. Blood exhibits non-Newtonian shear-thinning rheology in the real device, particularly at low flow rates and in recirculation zones near the volute where shear rates fall below 100 s⁻¹.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-flow-rate-pressure",
      "type": "ValidationResult",
      "name": "Pump head-flow curve validation at nominal operating conditions",
      "description": "Predicted pump head versus flow rate compared against in vitro measurements across 3 speed settings (3000, 3500, 4000 RPM) at the nominal design flow range of 3–6 L/min. Mean absolute error in pump head was 4.2%. All five COU operating points fall within this validated range. Newtonian rheology assumption was not evaluated; all test points correspond to high-shear impeller-dominated flow regimes."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-rh-index-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against predicate device",
      "description": "Computed relative hemolysis index (RH) compared to in vitro hemolysis measurements using the ASTM F1841 normalized index of hemolysis protocol. RH predictions fell within ±15% of measured values at all five operating points. Validation experiments were conducted at flow rates of 3, 4, and 5 L/min at 3500 RPM; low-flow conditions (below 2 L/min) where non-Newtonian effects are expected to be significant were not included in the validation matrix."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-velocity-field-piv",
      "type": "ValidationResult",
      "name": "Impeller exit velocity field comparison against PIV measurements",
      "description": "CFD-predicted velocity magnitude and flow angle at the impeller exit plane compared against particle image velocimetry (PIV) data from the FDA benchmark dataset. Spatial agreement within 8% across 85% of measurement locations at 4000 RPM, 4.5 L/min. PIV experiments used a Newtonian blood analog fluid; non-Newtonian shear-thinning effects in the real blood environment were not represented in either the experimental or computational dataset."
    }
  ],
