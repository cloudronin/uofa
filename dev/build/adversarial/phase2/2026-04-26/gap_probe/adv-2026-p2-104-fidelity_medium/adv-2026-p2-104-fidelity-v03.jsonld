      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least one published benchmark problem relevant to rotating machinery internal flow.",
      "rationale": "The solver was verified against the FDA benchmark nozzle problem (ASME V&V 40 Appendix C) and the Taylor-Couette rotating flow benchmark. Residuals converge to below 1e-6 for all variables. Code verification is adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary quantity of interest (hemolysis index) and must be below 5%.",
      "rationale": "Three-level mesh refinement study performed on the baseline geometry at 4 L/min, 3500 RPM. GCI for the volume-averaged hemolysis index is 3.1% between medium and fine grids. The fine mesh (12.4 M elements) was selected for all production runs. Discretization error is within the required threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within ±5% for flow rate and within ±10 RPM for rotational speed.",
      "rationale": "In vitro test rig uses Coriolis mass flow meters (±0.5% accuracy) and optical encoder for speed measurement (±2 RPM). Boundary condition matching confirmed for all three validation operating points. Temperature maintained at 37±0.5°C consistent with CFD assumptions."
