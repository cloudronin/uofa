  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, which is acceptable at MRL 2 per ASME V&V 40-2018. Validation results demonstrate NIH prediction accuracy within 12% across all five COU operating points. The isothermal modelling assumption — which excludes viscous-dissipation heating and bearing thermal effects present in clinical CPB operation — is judged acceptable by the assessment team on the basis that the temperature rise is small and unlikely to materially affect bulk hemolysis index. This judgment is qualitative; no quantitative fidelity trade study or thermally loaded validation experiment has been performed to bound the associated model fidelity gap. The assessment team accepts this limitation given the MRL 2 context and proceeds with an Accepted decision.",
