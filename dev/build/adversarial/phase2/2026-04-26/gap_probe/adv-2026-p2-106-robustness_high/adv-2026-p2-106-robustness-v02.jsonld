  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-ml-hemo-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and meet or exceed the required gradation levels for Model Risk Level 2. The gradient-boosted surrogate demonstrates strong predictive accuracy on the held-out test set (MAE = 0.031, R² = 0.961) and five-fold cross-validation (RMSE = 0.038). A single out-of-distribution geometry evaluation returned an absolute error of 0.04, and the assessment team concluded that the model generalizes adequately. The credibility evidence is judged sufficient to support the regulatory submission decision for the Class II CPB device tolerance analysis.",
    "decidedAt": "2026-04-19T00:00:00Z"
