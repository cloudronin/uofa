      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Surrogate implementation verified against reference CFD outputs on a canonical benchmark case.",
      "rationale": "The surrogate prediction pipeline was verified by replaying the full CFD reference dataset through the trained model and confirming bit-identical outputs across two independent compute environments. No numerical solver is invoked at inference time; verification scope is limited to the inference code path."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for CFD training data generation; GCI < 5% on hemolysis index QoI.",
      "rationale": "The CFD simulations used to generate the 4,200-sample training corpus were conducted on a mesh of 6.2M polyhedral cells. Richardson extrapolation yielded GCI = 3.1% for the normalized hemolysis index at the highest-shear operating point. Discretization error is therefore bounded and propagated into the surrogate training labels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test conditions span the five target flow-speed combinations defined in the COU; boundary conditions match clinical CPB operating range.",
      "rationale": "All five COU-defined flow-speed combinations (2–6 L/min, 2000–3500 RPM) are represented in the held-out test set. Inlet boundary conditions (pressure, hematocrit 35–45%) match the clinical CPB operating envelope. Test conditions are drawn from the same experimental design as training; no independent experimental bench test was conducted for the surrogate validation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "MAPE < 5% on normalized hemolysis index across all validation operating points; Bland-Altman limits of agreement within ±10% of mean.",
      "rationale": "MAPE on the held-out test set was 2.1%, satisfying the < 5% criterion. Bland-Altman analysis showed limits of agreement of −3.8% to +4.2%, within the ±10% acceptance band. Comparison is restricted to nominal-condition CFD outputs; no experimental hemolysis measurements from physical pump testing were used as validation references."
    },
    {
      "factorStandard": "ASME-VV40-2018",
