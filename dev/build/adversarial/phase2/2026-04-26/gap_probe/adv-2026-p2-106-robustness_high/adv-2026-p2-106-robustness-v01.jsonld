  "name": "Morrison COU1 — ML-augmented CFD hemolysis credibility assessment (CPB use)",
  "description": "V&V 40 credibility assessment for an ML-augmented CFD hemolysis prediction pipeline applied to the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. A gradient-boosted regression surrogate (XGBoost) trained on 4,200 CFD-derived operating-point samples replaces the direct CFD solver for rapid sensitivity sweeps across component-dimension tolerances. COU1 evaluates whether the surrogate model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Validation results are reported on a held-out test split drawn from the same CFD campaign distribution; one out-of-distribution sample from a predicate pump geometry is included and cited as evidence of generalization.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-hemolysis-surrogate-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-ml-hemolysis-generalizes-cpb",
  "bindsModel": "https://uofa.net/synth/model/xgboost-hemolysis-surrogate-v2-3",
  "bindsDataset": [
    "https://uofa.net/synth/data/cfd-campaign-4200-samples-train-val-test",
    "https://uofa.net/synth/data/predicate-pump-single-ood-sample"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-001-nominal-test-set-performance",
      "type": "ValidationResult",
      "name": "Held-out test set prediction accuracy — nominal operating envelope",
      "description": "The XGBoost surrogate was evaluated on a stratified 15% hold-out split (n=630 samples) drawn from the same 4,200-point CFD campaign used for training. Mean absolute percentage error on the normalized hemolysis index was 2.1% (95% CI: 1.8–2.4%). R² = 0.974 across all five flow-speed operating points. Model performance was deemed satisfactory against the acceptance threshold of MAPE < 5%. The test distribution is identical in pump geometry family, fluid rheology assumptions, and turbulence closure to the training set."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-002-ood-single-sample",
      "type": "ValidationResult",
      "name": "Single out-of-distribution geometry sample — predicate pump",
      "description": "One operating point from a predicate centrifugal pump with a 4% larger impeller diameter was evaluated. The surrogate predicted a normalized hemolysis index of 0.87 against a CFD-computed reference of 0.91, yielding a 4.4% relative error within the stated acceptance threshold. This result is cited in the assessment narrative as demonstrating that the model 'generalizes well beyond its training distribution.' No systematic covariate-shift study, noise-injection experiment, or adversarial perturbation analysis was conducted. No confidence intervals or prediction-interval estimates are reported for this single out-of-distribution point, and no statistical framework is provided to support the generalization claim."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-003-cross-validation-nominal",
      "type": "ValidationResult",
      "name": "5-fold cross-validation on nominal CFD campaign data",
      "description": "Five-fold cross-validation was performed on the full 4,200-sample dataset. Mean MAPE across folds: 2.3% (std: 0.18%). All folds were drawn from the same CFD campaign with identical boundary conditions, turbulence models (SST k-ω), and blood rheology parameters (Newtonian, μ=0.0035 Pa·s). Cross-validation confirms low variance within the training distribution but provides no information about model behavior under input perturbation, sensor noise, or operating conditions outside the nominal CPB envelope."
    }
  ],
