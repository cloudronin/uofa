  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-ml-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The ML surrogate model meets all seven assessed credibility factor requirements at or above the required level for MRL 2. Held-out test set MAPE of 2.1% satisfies the < 5% acceptance criterion. The inclusion of a single predicate-pump out-of-distribution sample, which also fell within the MAPE threshold, is taken as corroborating evidence that the model generalizes adequately for the intended CPB use case. Six factors were not assessed, consistent with MRL 2 requirements. The credibility evidence package is accepted as sufficient to support the regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
