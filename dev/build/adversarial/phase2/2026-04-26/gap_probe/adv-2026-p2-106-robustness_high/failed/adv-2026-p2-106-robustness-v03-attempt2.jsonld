  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-nominal-test-set-accuracy",
      "type": "ValidationResult",
      "name": "Nominal test-set accuracy — ML surrogate hemolysis prediction",
      "description": "The ML surrogate (CNN-based architecture trained on 12,400 CFD-derived hemolysis field snapshots) achieved a mean absolute percentage error of 3.1% and R² = 0.974 on the held-out test partition (n = 1,550 samples). The test partition was drawn via stratified random split from the same experimental campaign as the training set, preserving the same pump geometry distributions, flow-rate ranges (2–6 L/min), and rotational speed ranges (1,500–3,500 RPM). All validation samples originate from nominal operating conditions consistent with the training distribution. One out-of-distribution geometry variant (impeller tip clearance reduced by 40%) was evaluated post-hoc and yielded RH prediction within 8% of the CFD reference; the authors cite this single case as evidence that the model 'generalizes well to unseen configurations.' No systematic covariate-shift study, no noise-injection sensitivity analysis, and no adversarial perturbation evaluation are reported or linked."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-cross-operating-point",
      "type": "ValidationResult",
      "name": "Cross-operating-point comparison — 5 flow-speed combinations",
      "description": "Predictions at the 5 clinically specified flow-speed operating points (2 L/min / 2,000 RPM; 3 L/min / 2,500 RPM; 4 L/min / 3,000 RPM; 5 L/min / 3,200 RPM; 6 L/min / 3,500 RPM) were compared against full CFD solutions. Relative hemolysis index RH remained below 1.0 at all five points, satisfying the acceptance criterion. Uncertainty intervals are reported as ±5% (95% CI) derived from ensemble variance of the ML surrogate; however, these intervals do not account for potential distribution shift between the training corpus and future pump manufacturing batches."
    }
  ],
