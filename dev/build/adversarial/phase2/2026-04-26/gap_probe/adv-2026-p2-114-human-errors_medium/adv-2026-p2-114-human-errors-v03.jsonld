      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental blood samples used in FDA benchmark testing must be documented with hematocrit and source traceability.",
      "rationale": "FDA benchmark dataset documents use of bovine blood at hematocrit 33±2%. Sample preparation protocol referenced in FDA pump report. Sufficient traceability for MRL 2 assessment."
    },
