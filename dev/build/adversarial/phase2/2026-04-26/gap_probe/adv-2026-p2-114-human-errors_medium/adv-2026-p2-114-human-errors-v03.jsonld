  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study — three refinement levels",
      "description": "Grid convergence index computed across coarse, medium, and fine meshes (4.2M, 9.8M, 21.6M cells). GCI for shear-stress-derived hemolysis index < 2.1% on fine mesh. All boundary conditions and fluid properties set to nominal values by simulation engineer; no operator variation scenarios included."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-turbulence-model-comparison",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — k-omega SST vs. realizable k-epsilon",
      "description": "Hemolysis index predictions compared between two turbulence closures at five operating points. Relative difference < 4% across all points. Input flow rates and rotational speeds applied as exact nominal values; no assessment of clinician-set flow rate deviations or perfusionist input errors performed."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-experimental-rh-comparison",
      "type": "ValidationResult",
      "name": "Experimental RH index comparison against FDA benchmark dataset",
      "description": "Simulated relative hemolysis index compared against FDA generic pump experimental data at 2.5, 4.0, and 6.0 L/min. RH < 1 criterion met at all tested conditions. Experimental inputs treated as perfectly specified; misuse scenarios such as incorrect priming volume, air entrainment, or erroneous speed dial settings by clinical operators were not evaluated or modeled."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-blood-viscosity-sensitivity",
      "type": "ValidationResult",
      "name": "Blood viscosity parameter sensitivity analysis",
      "description": "Carreau-Yasuda viscosity model parameters varied ±10% around nominal values to assess hemolysis prediction sensitivity. All parameter sweeps executed programmatically with verified input files; no evaluation of manual data-entry errors by clinical or engineering users was included in the sensitivity study."
    }
  ],
