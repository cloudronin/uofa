  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence-v1",
      "type": "ValidationResult",
      "name": "Mesh convergence study — FDA generic centrifugal pump",
      "description": "Grid refinement study across three mesh densities (coarse 1.2M, medium 3.1M, fine 7.8M cells). GCI values below 2.1% for pressure rise and 3.4% for wall shear stress at all five operating points. All inputs supplied by trained CFD analysts using standardised boundary condition templates; no variation in user-specified parameters was introduced across runs."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-bench-v1",
      "type": "ValidationResult",
      "name": "Bench hemolysis validation against FDA experimental data",
      "description": "Predicted normalised index of haemolysis (NIH) compared against published FDA bench measurements at five flow-speed operating points. RH < 1 criterion satisfied at all points (mean RH = 0.83, range 0.71–0.96). Experimental inputs were nominal manufacturer-specified flow rates and rotational speeds. All simulation inputs were taken directly from published protocol; operator entry errors were not introduced or evaluated."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-turbulence-sensitivity-v1",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-omega vs. realizable k-epsilon",
      "description": "Sensitivity of predicted NIH to turbulence model selection assessed across three operating points. Maximum NIH deviation of 6.2% between models; SST k-omega selected as primary model. Boundary conditions were identical across both model variants and were entered by the same analyst using a validated input script."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-solver-verification-v1",
      "type": "ValidationResult",
      "name": "Solver verification — method of manufactured solutions",
      "description": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver component. Observed order of accuracy 1.94 (theoretical 2.0); residual norms below 1e-6 at convergence. Verification performed entirely within automated test harness; no manual data entry involved."
    }
  ],
