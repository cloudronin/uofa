  "name": "Morrison COU1 — CPB hemolysis credibility assessment (configuration gap variant)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The CFD solver relies on three tunable configuration parameters: a baseline mesh element size target (h_target), a hemolysis power-law threshold exponent (alpha_thresh), and an iterative convergence tolerance (epsilon_iter). Validation studies were conducted at h_target = 0.15 mm, alpha_thresh = 0.785, and epsilon_iter = 1e-5; results are reported 'at the chosen settings'. However, no configuration node is linked to this package, no bindsConfiguration relationship is established, and the ContextOfUse places no constraint on which parameter values must be used at deployment. A deploying analyst may select different values — in particular alpha_thresh, which is treated as a free parameter — without any package-level flag or re-validation requirement.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-mrl2-req",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-rh-lt1",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-gcbp-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/morrison-cpb-cfd-mesh-sweep-results"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-independence-cpb",
      "type": "ValidationResult",
      "name": "Mesh independence study — h_target sweep",
      "description": "Three mesh densities were evaluated (h_target = 0.30 mm, 0.15 mm, 0.08 mm). The intermediate density (0.15 mm) was selected as the production setting based on a Richardson extrapolation GCI < 2.1%. Validation metrics are reported at the chosen h_target = 0.15 mm setting. No formal pinning of this value to deployment configurations is established in the package."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against FDA GCBP experimental data",
      "description": "Computed RH values at all 5 flow-speed operating points fell below 1.0 (range 0.61–0.93) when the solver was run with alpha_thresh = 0.785 and epsilon_iter = 1e-5. Results are presented at the chosen settings. Sensitivity of RH predictions to alpha_thresh variation was not characterized; the parameter is noted as analyst-selectable in the solver user manual."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-convergence-tolerance-check",
      "type": "ValidationResult",
      "name": "Iterative convergence tolerance verification",
      "description": "Residual convergence to epsilon_iter = 1e-5 was confirmed for all validated operating points. The validation report notes that tighter tolerances (1e-6) produced negligible change in RH (< 0.3%), supporting the chosen setting. No mechanism in the package enforces this tolerance at deployment."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-boundary-condition-fidelity",
      "type": "ValidationResult",
      "name": "Boundary condition fidelity to in-vitro test conditions",
      "description": "Inlet velocity profiles and outlet pressure boundary conditions were matched to the experimental test rig within 1.5% across all operating points. Fluid properties (viscosity, density) were set to match the blood analog used in the FDA GCBP study."
    }
  ],
