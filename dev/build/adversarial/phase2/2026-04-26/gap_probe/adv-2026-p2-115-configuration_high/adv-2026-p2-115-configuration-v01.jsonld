      "quantityOfInterest": "Relative hemolysis index RH (dimensionless)",
      "passCriterion": "Correct rank ordering of worst-case geometry with Spearman ρ ≥ 0.85",
      "outcomeValue": "Spearman ρ = 0.94",
      "outcomeStatus": "pass"
    }
