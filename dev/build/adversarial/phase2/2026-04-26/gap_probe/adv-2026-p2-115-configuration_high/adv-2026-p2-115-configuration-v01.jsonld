      "quantityOfInterest": "Relative hemolysis index RH",
      "passCriterion": "RH mesh-to-mesh variation < 5%",
      "outcomeValue": "2.8% maximum variation across operating points",
      "outcomeStatus": "pass"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Experimental bench comparison — hemolysis index at 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) was compared against in-vitro measurements from a modified modified index of hemolysis (MIH) protocol at 5 flow-speed combinations (2.5 L/min at 2500 RPM through 5.0 L/min at 3500 RPM). The hemolysis accumulation threshold ε_H was set to 1×10⁻⁴ Pa·s for all runs. Agreement within ±15% was achieved for 4 of 5 points; the fifth point deviated by 18% and was attributed to inlet swirl variability. The Lagrangian particle-tracking time-step multiplier was set at 0.25 for these runs, as chosen by the analyst at run time, and is not recorded in any pinned configuration artifact.",
      "quantityOfInterest": "Normalized index of hemolysis NIH (g/100 L)",
      "passCriterion": "CFD-to-experiment agreement within ±20% for all 5 operating points",
      "outcomeValue": "Maximum deviation 18%; 4/5 points within ±15%",
