  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors scoped out per MRL 2 requirements. Validation results demonstrate CFD NIH predictions within ±15% of experimental data across the full 5-point operating envelope. Worst-case hemolysis condition identified at 3 L/min / 3500 RPM with RH = 0.87 (< 1.0 acceptance criterion satisfied). The assessment team notes that validation was conducted at specific solver configuration settings (mesh element size 0.15 mm, hemolysis exponent alpha = 0.765, convergence tolerance 1e-5); these settings are documented in the model report narrative and validation results reference them as 'the chosen settings'. The package does not include a formal binding configuration record or settings node that would constrain deployment simulations to these validated parameter values. The assessment team considers this acceptable at MRL 2 given the demonstrated low sensitivity of RH to convergence tolerance variation. Decision: Accepted for regulatory submission supporting 510(k) predicate comparison.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
