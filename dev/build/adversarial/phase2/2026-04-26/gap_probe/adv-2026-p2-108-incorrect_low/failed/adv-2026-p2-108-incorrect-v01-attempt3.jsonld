  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-threshold-001",
    "type": "Requirement",
    "name": "Relative hemolysis index acceptance threshold for CPB device comparison",
    "requirementText": "The CFD-predicted relative hemolysis index (RH) of the candidate centrifugal blood pump shall be less than 10 when compared to the predicate device under worst-case operating conditions. RH = NIH_candidate / NIH_predicate; acceptance threshold RH < 10 confirms the candidate device does not produce substantially greater hemolysis than the predicate.",
