  "signature": "ed25519:b7e3a1f9c4d2e8b5a6f1c3d9e4b7a2f8c5d1e6b3f9a4c7d2e1b8f5a3c9d6e4b1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver (ANSYS Fluent 2022R2) is FDA-cleared and operates under documented version control with regression test suite. SQA documentation on file.",
      "rationale": "ANSYS Fluent 2022R2 is used under institutional license with version-controlled input files archived in the project repository. Regression tests confirm solver reproducibility. SQA level 2 is appropriate for MRL 2 and Medium model influence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard manufactured solution benchmarks for incompressible rotating flow. Published verification results for the ANSYS Fluent MRF formulation are on file.",
      "rationale": "Code verification relies on published ANSYS Fluent verification suite results for the Multiple Reference Frame (MRF) rotating machinery formulation. Benchmark residuals confirm second-order spatial accuracy. Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary QoI (NIH) must be below 5% on the fine mesh relative to the medium mesh. Three mesh levels required.",
      "rationale": "Three mesh levels (2.1M, 5.8M, 14.2M cells) were evaluated. Richardson extrapolation yields GCI of 2.3% for NIH between the medium and fine grids, and 4.1% between coarse and medium. The fine mesh (14.2M cells) is adopted for all production runs. Achieved level 3 exceeds the required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid viscosity, temperature) documented with calibrated instrumentation and traceable to NIST standards. Uncertainty budgets provided.",
      "rationale": "In-vitro hemolysis experiments conducted at 37 °C with porcine blood (hematocrit 33 ± 2%). Flow rates and rotational speeds measured with calibrated Coriolis meter and tachometer respectively. Full uncertainty budget provided in test report TR-2024-CPB-01."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with measured NIH within ±30% across all 5 operating points. Relative hemolysis index RH computed against predicate device must be below 1.0.",
      "rationale": "CFD-predicted NIH values agree with in-vitro measurements within 18–26% across all five operating points, satisfying the ±30% criterion. Relative hemolysis index RH ranges from 0.71 to 0.94 across operating envelope, all below 1.0. Output comparison is adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH and RH) must be directly linked to the clinical endpoint of pump-induced hemolysis and must be computable from CFD outputs via a documented hemolysis power-law model.",
      "rationale": "NIH and RH are the standard regulatory QoIs for blood pump hemolysis per FDA guidance. The Giersiepen power-law hemolysis model (exponents α=0.785, β=2.416) is applied to CFD shear stress and exposure time fields. Direct linkage to clinical hemolysis is established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating range as the COU. Deviations from COU conditions must be documented and assessed for impact.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry at CPB-representative flow rates (2–6 L/min) and speeds (2000–3500 RPM). Porcine blood substitutes for human blood; documented correction factor of 1.08 applied per published protocol. Validation domain overlaps fully with COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 with medium model influence; solver error subsumed under discretization error and code verification assessments.",
      "rationale": "Per ASME V&V 40 Table 4, numerical solver error is not required to be independently assessed at MRL 2 when discretization error and code verification are both assessed. Residuals converge to 1e-5 for all equations; no solver error flags observed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation workflow is executed by experienced CFD analysts with pump-specific training.",
      "rationale": "All simulations executed by analysts with >5 years CFD experience in rotating machinery. Simulation workflow documented in SOP-CFD-2023-07. Use error not formally assessed per MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; k-omega SST turbulence model selection is justified by literature for confined rotating flow hemolysis applications.",
      "rationale": "k-omega SST turbulence model selected based on published benchmark studies for FDA centrifugal pump. Model form uncertainty not formally quantified at MRL 2. Sensitivity to turbulence model noted as a limitation in the simulation report but not required for this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal blood viscosity and density values used with documented literature sources.",
      "rationale": "Blood viscosity modeled as Newtonian fluid with μ=0.0035 Pa·s and ρ=1060 kg/m³ per standard CPB operating assumptions. Input parameter uncertainty not formally propagated at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; three independent blood samples used per operating point with inter-sample variability reported.",
      "rationale": "Three porcine blood samples per operating point with NIH variability of ±8% reported. Formal statistical sample size assessment not required at MRL 2 per V&V 40 Table 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions (inlet flow rate, outlet pressure, rotational speed) must match experimental test conditions within 2% for each operating point. The wall shear stress threshold used to define hemolysis-relevant flow regions is set at 10 Pa, consistent with the power-law model applicability range documented in Giersiepen et al. (1990).",
      "rationale": "CFD boundary conditions match experimental values within 0.8–1.6% across all five operating points. Inlet velocity profiles derived from upstream pipe flow at the measured Reynolds numbers. Rotational speed held constant at ±5 RPM of target. The hemolysis power-law model is applied to all fluid elements where shear stress exceeds 10 Pa; this threshold is stated in the requirement as the lower bound of hemolysis-relevant exposure. In practice, sub-lethal erythrocyte deformation initiates at shear stresses as low as 1 Pa under sustained exposure conditions typical of CPB recirculation, and the clinically relevant cumulative damage regime begins near 1–2 Pa for exposure durations exceeding 100 ms. The 10 Pa threshold specified in the requirement is therefore an order of magnitude too high for the CPB operating regime described in the COU, and will systematically exclude flow regions where sub-hemolytic but clinically significant red cell damage accumulates. This discrepancy is not flagged in any acceptance criterion or rationale elsewhere in the assessment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements under ASME V&V 40 Table 4. Grid convergence is well-established (GCI < 5%), output comparison satisfies the ±30% NIH criterion across all operating points, and relative hemolysis index RH < 1.0 confirms the device does not exceed predicate hemolysis performance. The assessment team concludes that the CFD model provides adequate credibility for the intended use of identifying worst-case hemolysis operating conditions for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
