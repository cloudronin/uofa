  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-velocity-r2",
      "type": "ValidationResult",
      "name": "Velocity field R² correlation against PIV measurements",
      "description": "The CFD-predicted velocity magnitude field was compared against particle image velocimetry (PIV) measurements across the five operating points defined in the COU. Pearson correlation coefficient R² = 0.971 was obtained by regressing predicted versus measured velocity magnitudes at 1,240 interrogation-window centroids pooled across all operating points. This high R² value demonstrates that the model reproduces the overall velocity field with excellent fidelity, supporting confidence in the underlying fluid-dynamic solution used to drive the hemolysis sub-model. The scalar velocity magnitude agreement is presented as the primary validation metric because it is the directly measurable flow quantity and because hemolysis correlations (power-law Giersiepen–Wurzinger form) depend on shear stress derived from velocity gradients. R² was computed on the pooled training set of experimental interrogation windows; no held-out operating-point prediction error is reported.",
      "metricName": "R²",
      "metricValue": 0.971,
      "referenceDataset": "https://uofa.net/synth/data/fda-benchmark-cbp-experimental-2013"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-pressure-rmse",
      "type": "ValidationResult",
      "name": "Pump differential pressure RMSE across operating envelope",
      "description": "Root-mean-square error between CFD-predicted and experimentally measured pump differential pressure (ΔP) was computed across all five flow-speed operating points. RMSE = 3.2 mmHg (< 5% of the mean measured ΔP of 68 mmHg). Agreement at this level confirms that the global momentum balance is correctly captured by the model. Because ΔP is an integrated scalar quantity that reflects bulk flow resistance, this metric is used as a surrogate indicator that the velocity and stress fields within the pump are globally consistent with physical measurements. The metric does not quantify spatial distribution of shear stress or the frequency and magnitude of high-shear exposure events that red blood cells experience along Lagrangian trajectories — the quantities that directly determine the relative hemolysis index RH. However, the low RMSE provides confidence that the boundary conditions driving the hemolysis calculation are accurate.",
      "metricName": "RMSE",
      "metricValue": 3.2,
      "metricUnit": "mmHg",
      "referenceDataset": "https://uofa.net/synth/data/fda-benchmark-cbp-experimental-2013"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-rh-pearson",
      "type": "ValidationResult",
      "name": "Relative hemolysis index Pearson correlation across operating points",
      "description": "Predicted relative hemolysis index (RH) values were compared against experimentally derived RH estimates at the five COU operating points. Pearson correlation r = 0.963 (p < 0.01) was obtained between the CFD-predicted RH and the experimental RH values. This strong linear correlation demonstrates that the model correctly ranks the five operating conditions by hemolysis severity, which is consistent with the COU goal of identifying worst-case conditions. The Pearson correlation captures the degree of linear co-variation between predicted and measured RH rankings and is presented as the primary hemolysis validation metric. Notably, the correlation coefficient is insensitive to systematic multiplicative or additive bias in the predicted RH magnitudes: a model that over-predicts all RH values by a constant factor of 2 would still yield r = 1.0. Because the COU acceptance criterion is an absolute threshold (RH < 1 relative to the predicate device), the magnitude accuracy of the RH predictions — not merely their rank order — is the quantity of interest for the regulatory decision. The correlation metric does not bound the absolute prediction error in RH, and no confidence interval on absolute RH magnitude is reported.",
      "metricName": "Pearson r",
      "metricValue": 0.963,
      "referenceDataset": "https://uofa.net/synth/data/morrison-cfd-flow-speed-matrix-5op"
    }
  ],
