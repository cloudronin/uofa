  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. Six factors are appropriately scoped to not-assessed at MRL 2. Validation evidence demonstrates R² = 0.971 for velocity field, RMSE = 3.2 mmHg for differential pressure, and Pearson r = 0.963 for relative hemolysis index across the five COU operating points. The strong correlation of predicted versus measured RH values confirms that the model correctly identifies the rank ordering of hemolysis severity across operating conditions. The assessment team concludes that the CFD model has sufficient credibility for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
