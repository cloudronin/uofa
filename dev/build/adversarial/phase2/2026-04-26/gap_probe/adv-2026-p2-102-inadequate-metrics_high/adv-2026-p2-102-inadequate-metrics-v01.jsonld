  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scoping. Quantitative validation evidence (R² = 0.94 for wall shear stress spatial distribution; RMSE = 4.2 mmHg for pressure rise) satisfies acceptance criteria for Output Comparison and Relevance of Quantities of Interest factors. The model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device under the stated COU. The assessment team notes that the primary validation metric — R-squared agreement on wall-shear-stress spatial distribution — demonstrates strong model fidelity to the flow physics driving hemolysis, and in conjunction with pressure-rise RMSE provides sufficient quantitative evidence for acceptance at MRL 2.",
