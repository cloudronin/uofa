      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release testing; user access to solver verification reports.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated software quality management plan. Version-controlled solver with FDA-recognized verification test suite. Release notes and regression test reports reviewed. Achieved level meets required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
