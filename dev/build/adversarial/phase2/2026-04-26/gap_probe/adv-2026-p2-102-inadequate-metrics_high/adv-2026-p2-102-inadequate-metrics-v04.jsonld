  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-shear-correlation-r2",
      "type": "ValidationResult",
      "name": "Pearson correlation and R² of simulated vs. measured scalar shear-stress magnitude",
      "description": "Validation was performed by comparing CFD-predicted scalar shear-stress magnitude against particle-image velocimetry (PIV) measurements at 1,240 spatial locations across the five operating points (2 L/min–2500 RPM through 6 L/min–3500 RPM). The Pearson correlation coefficient between simulated and measured shear magnitudes was r = 0.961 (p < 0.001) and the coefficient of determination R² = 0.923, indicating that the model explains over 92% of the variance in measured shear-stress magnitude. Mean absolute error in shear magnitude was 4.7 Pa, well within the 10 Pa acceptance threshold established for this study. These statistics were computed pooling all five operating conditions and all spatial locations, providing a large-sample, statistically robust characterisation of model fidelity. The high R² and low MAE are taken as primary evidence that the CFD model reproduces the haemodynamic environment with sufficient accuracy to support credible hemolysis predictions. Accepted against acceptance criterion: R² ≥ 0.90 and MAE ≤ 10 Pa.",
      "metricName": "Pearson r; R²; Mean Absolute Error (shear magnitude)",
      "metricValue": "r = 0.961; R² = 0.923; MAE = 4.7 Pa",
      "acceptanceCriteria": "R² ≥ 0.90 and MAE ≤ 10 Pa across all operating conditions pooled",
      "result": "Pass",
      "rationale": "The pooled R² of 0.923 exceeds the 0.90 threshold and MAE of 4.7 Pa is below 10 Pa. These metrics confirm strong linear correspondence between simulated and measured shear-stress magnitudes. Because hemolysis models (e.g., power-law models) are driven primarily by shear magnitude, the team concluded that high scalar shear fidelity is sufficient evidence of hemolysis prediction accuracy. No rank-ordering or worst-case identification metric was computed, as the R² and MAE were judged to subsume that information."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-rh-scalar-comparison",
      "type": "ValidationResult",
      "name": "Absolute relative hemolysis index (RH) comparison at nominal operating point",
      "description": "At the single nominal operating condition (4 L/min, 3000 RPM), the CFD-derived relative hemolysis index was RH_CFD = 0.87 compared to the experimentally measured RH_exp = 0.91, yielding a relative error of 4.4%. This comparison was performed at the nominal point only because it represents the primary design condition documented in the predicate device 510(k) submission. The team noted that this single-point agreement further corroborates the scalar shear-stress correlation results and supports the claim that the model produces hemolysis predictions within acceptable tolerance.",
      "metricName": "Relative error in RH at nominal operating point",
      "metricValue": "RH_CFD = 0.87; RH_exp = 0.91; relative error = 4.4%",
      "acceptanceCriteria": "Relative error in RH ≤ 10% at nominal operating condition",
      "result": "Pass",
      "rationale": "Single-point RH agreement at the nominal condition confirms scalar magnitude accuracy of the hemolysis model. Worst-case identification across all five operating points was not independently validated; the team inferred that accuracy at the nominal point, combined with high R² for shear, is sufficient to establish confidence in worst-case identification."
    }
  ],
