  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under documented version control with regression test suite demonstrating reproducible results across platforms at MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-compliant QMS. Version control records, build verification tests, and regression test results for blood-pump benchmark cases are archived and reviewed. Achieved level meets required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via at least one benchmark problem with known analytical or manufactured solution at MRL 2.",
      "rationale": "Lid-driven cavity and Taylor-Couette flow benchmarks confirm correct implementation of the incompressible Navier-Stokes solver. Order-of-accuracy tests yield observed order p = 1.97, consistent with the second-order spatial discretisation scheme. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study using at least three systematically refined meshes with GCI reported for hemolysis-relevant quantities at MRL 2.",
      "rationale": "Three meshes (4.2 M, 9.8 M, 21.4 M cells) were generated with systematic refinement ratio r = 1.33. GCI for volume-averaged scalar shear stress is 2.1% on the fine mesh, and GCI for NHI is 3.4%. Both are within the 5% threshold for MRL 2. Fine mesh adopted for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate) must be documented with uncertainty bounds and matched to CFD boundary conditions within acceptable tolerance at MRL 2.",
      "rationale": "In-vitro tests used bovine blood at 37°C with viscosity 3.5 ± 0.2 mPa·s. Flow rates and impeller speeds were logged at 100 Hz; mean values used as CFD boundary conditions. Reported uncertainties: flow rate ±1.5%, speed ±0.3%. Conditions are adequately documented and reproducible for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between CFD predictions and experimental measurements must be reported using at least one numerical metric with experimental uncertainty bounds included at MRL 2.",
      "rationale": "NHI predictions are compared to measured values at all five operating points. Pearson r = 0.97, R² = 0.94, RMSE = 0.0041 g/100 L (~3.2% of mean measured NHI). Experimental uncertainty bars are plotted and all CFD predictions fall within ±2σ measurement bounds. The assessment team judges output comparison adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation must be directly traceable to the decision metric (RH < 1) used in the COU at MRL 2.",
      "rationale": "The primary QoI is normalised hemolysis index (NHI), which is the numerator component of the relative hemolysis index RH. NHI is computed from the power-law hemolysis model integrated along Lagrangian particle trajectories. The validation evidence demonstrates good agreement in NHI trend and variance (R² = 0.94), which the team considers sufficient to infer adequate model fidelity for identifying which operating point produces maximum NHI, supporting worst-case identification. Relevance assessed as meeting MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, operating conditions, and fluid properties sufficiently similar to the COU device and conditions at MRL 2.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump, which is the same platform as the COU device. Operating conditions span the same five flow-speed combinations used in the COU. Bovine blood properties are consistent with those used in the predicate device comparison. Geometry fidelity is high (CAD-to-mesh tolerance < 50 µm). Relevance to COU is judged adequate for MRL 2."
    },
