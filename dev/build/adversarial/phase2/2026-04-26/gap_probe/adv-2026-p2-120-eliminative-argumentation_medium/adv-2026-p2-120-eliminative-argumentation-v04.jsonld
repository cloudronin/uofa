  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted based on the totality of affirmative evidence gathered across the 13 ASME V&V 40 credibility factors. All seven assessed factors achieved their required gradation levels: discretization error was quantified via Richardson extrapolation and confirmed below 5% GCI; output comparison demonstrated RHI prediction errors within ±15% at all five operating points; validation activities were conducted on the identical device geometry and operating envelope as the COU; and the QoI is directly linked to the clinical hemolysis endpoint recognized in FDA guidance. Numerical solver and code verification activities confirm that computational errors do not materially affect the hemolysis predictions. The six not-assessed factors are consistent with MRL 2 scoping and do not reduce confidence in the overall assessment. On the basis of this positive body of evidence, the model is judged credible for its intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device, and the Accepted decision is warranted. It is acknowledged that other interpretations of this evidence body may exist; however, the weight of the quantitative and qualitative findings presented here supports the credibility conclusion.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
