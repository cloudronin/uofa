  "hash": "sha256:3a7f2c1d9e4b56f8a0123cd7e89f4512b6d3c0a1e7f9b2d4c6e8a0f1b3d5e7a9",
  "signature": "ed25519:7b2e4f1a9c3d6e8b0f2a4c7e9b1d3f5a8c0e2b4d6f8a1c3e5b7d9f2a4c6e8b1d",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control and regression testing sufficient for MRL 2.",
      "rationale": "The ANSYS Fluent solver used in this study is a commercially validated platform with documented version control, release notes, and a regression test suite. Internal QA records confirm that the solver version (2022 R2) was verified against known analytical benchmarks prior to deployment. SQA requirements for MRL 2 are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through at least one benchmark problem with known analytical solution.",
      "rationale": "Code verification was performed using the method of manufactured solutions applied to a simplified rotating-disk flow problem. Observed order of convergence matched the theoretical second-order accuracy of the discretization scheme, confirming correct implementation of the Navier-Stokes equations and the power-law hemolysis damage model. Gradation 2 is achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary QoI (normalized hemolysis index, NIH) must be less than 5% across the operating envelope.",
      "rationale": "A three-level mesh refinement study was conducted using structured hexahedral meshes of 2.1M, 4.8M, and 10.2M cells. Richardson extrapolation yielded a GCI of 3.2% for NIH at the worst-case operating point (6 L/min, 2400 RPM). All five flow-speed combinations showed GCI below the 5% threshold. The fine mesh (4.8M cells) was selected for production runs as it provides a balance of accuracy and computational efficiency."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match the intended operating envelope within documented tolerances.",
      "rationale": "Experimental hemolysis measurements were performed on the FDA generic centrifugal pump at five flow-speed combinations spanning the CPB operating envelope (3–6 L/min, 1800–2400 RPM). Fluid temperature was maintained at 37±0.5°C with bovine blood at hematocrit 35±2%. These conditions are representative of intraoperative CPB use. Documented uncertainty in flow rate (±0.1 L/min) and rotational speed (±10 RPM) are within acceptable bounds for MRL 2 validation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within ±15% at all five operating points.",
      "rationale": "Predicted NIH values from the CFD model were compared against experimental measurements at all five operating points. Agreement ranged from 4.1% to 12.7% relative error, with a mean absolute error of 8.3%. The model consistently predicted the rank ordering of hemolysis severity across operating conditions, correctly identifying the 6 L/min / 2400 RPM condition as the worst-case scenario. These results exceed the MRL 2 requirement and support confidence in model predictive capability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) must be directly linked to the clinical decision metric (RH index).",
      "rationale": "The normalized index of hemolysis (NIH) computed in the CFD model is the direct precursor to the relative hemolysis index (RH) used as the acceptance criterion. The transformation from NIH to RH is a well-established normalization by pump flow rate and blood volume, documented in ASTM F1841. The QoI used in validation is therefore directly relevant to the COU decision metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on the same pump geometry or a sufficiently similar predicate under overlapping operating conditions.",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump geometry, which is the reference device for this COU. The five validation operating points span the intended CPB operating envelope. Fluid properties, boundary conditions, and measurement protocols in the validation study are consistent with the COU definition. The validation evidence is directly applicable to the intended use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iterative convergence must be documented; residual reduction of at least three orders of magnitude required.",
      "rationale": "At MRL 2, a detailed characterization of solver iterative error beyond residual monitoring is not required. Residual convergence to below 1e-5 was confirmed for all simulations, meeting the minimum threshold. Further quantification of iterative error is scoped to higher MRL assessments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documented simulation protocols and analyst training records are sufficient.",
      "rationale": "Use error assessment at MRL 2 requires only that simulation protocols are documented and analysts are trained. Both conditions are met. Formal use error quantification is not required at this risk level and is deferred to higher MRL assessments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, the selection of turbulence and hemolysis damage models must be documented with literature justification.",
      "rationale": "The SST k-omega turbulence model and the power-law hemolysis damage model (Giersiepen et al.) were selected based on documented literature precedent for centrifugal blood pump CFD. Formal model form uncertainty quantification is not required at MRL 2 and is scoped out of this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; full uncertainty propagation is not required.",
      "rationale": "Nominal values for blood viscosity, density, and hemolysis model coefficients were drawn from peer-reviewed literature and are documented in the simulation report. Input uncertainty propagation is not required at MRL 2 and is deferred to higher risk level assessments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, sample characterization sufficient to confirm fluid properties are within specified ranges.",
      "rationale": "Bovine blood samples used in experimental validation were characterized for hematocrit and viscosity prior to testing. Sample-to-sample variability was not formally quantified; this level of characterization is acceptable at MRL 2. Detailed test sample uncertainty analysis is scoped to higher MRL assessments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative equivalency between validation and COU input parameters must be documented.",
      "rationale": "A qualitative mapping between the validation study input parameters and the COU input parameters has been documented. Flow rates, rotational speeds, and fluid properties used in validation overlap with the intended operating envelope. Formal equivalency metrics are not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 concludes that the CFD hemolysis model is fit for the intended use of identifying worst-case operating conditions for a Class II CPB device at MRL 2. All seven assessed credibility factors meet or exceed their required levels: software quality assurance is confirmed through commercial solver QA records; numerical code verification demonstrates correct implementation via manufactured solutions; discretization error is below 5% GCI across the operating envelope; test conditions are representative of intraoperative CPB use; output comparison shows mean absolute error of 8.3% against experimental measurements; the NIH quantity of interest is directly linked to the clinical RH decision metric; and validation activities are performed on the reference pump geometry under the COU operating conditions. The six remaining factors are appropriately scoped out at MRL 2 with documented justification. The model consistently and correctly rank-orders hemolysis severity across all five operating points, with the worst-case condition accurately identified. The body of evidence assembled here provides strong, convergent support for the conclusion that the model is credible for its intended use. While it is acknowledged that other interpretations of the evidence may exist, the totality of the positive findings across all assessed factors demonstrates that the model meets the credibility requirements established for this COU. The decision to accept the model for CPB hemolysis prediction is well-supported by the evidence presented.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
