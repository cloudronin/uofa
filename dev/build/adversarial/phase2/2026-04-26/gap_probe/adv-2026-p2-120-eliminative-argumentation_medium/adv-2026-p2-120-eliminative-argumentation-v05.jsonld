      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control and regression testing at MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 was employed under an institutional software quality assurance plan. Version control records, regression test suite results, and release notes were reviewed. All required SQA documentation was current and complete at the time of analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
