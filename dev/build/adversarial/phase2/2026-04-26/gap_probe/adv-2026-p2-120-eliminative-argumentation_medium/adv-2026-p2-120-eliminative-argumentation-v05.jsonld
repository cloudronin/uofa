  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Model Risk Level 2. All seven assessed credibility factors achieved their required levels: discretization error was quantified via GCI and confirmed below threshold; test conditions were documented and traceable to the CPB operating envelope; output comparison demonstrated NIH predictions within experimental uncertainty at all operating points; software quality assurance documentation was complete; numerical code verification was confirmed against standard benchmarks; quantities of interest are directly relevant to the regulatory decision criterion; and validation activities are sufficiently representative of the COU. The six not-assessed factors are consistent with MRL 2 requirements and are supported by appropriate documentation. The positive evidence assembled across verification, validation, and uncertainty characterization activities collectively supports confidence that the CFD model can reliably identify worst-case hemolysis operating conditions for the subject device. While other interpretations of the evidence may exist, the weight of the assembled documentation is judged sufficient to meet the MRL 2 credibility standard for a Class II CPB device, and the model results are accepted for use in the regulatory submission supporting worst-case operating condition identification.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
