  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump is accepted for the COU of identifying worst-case operating conditions under CPB conditions at MRL 2. All seven assessed credibility factors meet or exceed their required gradation levels. Discretization error is well-controlled with GCI below 2.1%, providing high confidence in the numerical solution. Validation against bench-top experimental data demonstrates agreement within 12% for the relative hemolysis index across all five operating points, satisfying the 15% acceptance criterion. The quantities of interest map directly to the regulatory decision criterion RH < 1, and the validation activities were performed on the identical device geometry within the COU operating envelope. Software quality assurance and code verification confirm the solver is fit for purpose. The six factors not assessed are acceptable at MRL 2 and are addressed through peer review and documented inputs. The weight of positive evidence across all assessed factors consistently supports the conclusion that the model is sufficiently credible for the intended regulatory submission. While it is acknowledged that other interpretations of the evidence may exist, the collective assessment of the credibility factors provides a strong and coherent basis for acceptance. The decision to accept is supported by the convergence of independent lines of evidence — numerical, experimental, and methodological — all pointing toward adequate model credibility for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
