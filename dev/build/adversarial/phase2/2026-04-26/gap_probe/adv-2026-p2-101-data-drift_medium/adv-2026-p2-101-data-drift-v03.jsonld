  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The model is accepted for the COU as originally validated (adult CPB flows, 3–6 L/min, 2 500–3 500 RPM). The operating envelope was expanded in Q4 2025 to include paediatric flows (0.8–2.5 L/min) and higher impeller speeds (up to 4 200 RPM); re-validation covering this expanded regime is planned for H1 2026. The assessment team notes this gap and accepts the current package on the basis that the expanded envelope represents a modest extrapolation and that interim clinical monitoring controls are in place. No re-calibration or supplemental validation evidence is linked to this package.",
