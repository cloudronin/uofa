  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-2026-02",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment concludes that the CFD model meets all required factor levels for MRL 2 across the 7 assessed factors. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device. All validation evidence meets the acceptance criteria defined in the assessment plan. It is noted that the operating envelope was expanded in Q4 2025 to include paediatric patients and low-flow pulsatile assist modes; re-validation experiments covering these conditions are planned for H1 2026. The current acceptance is based on the original adult operating envelope validation. The credibility team judges the risk of extrapolation to be manageable given the conservative RH < 1 acceptance criterion and the planned re-validation, and therefore accepts the package at this time.",
