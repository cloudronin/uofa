  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented release notes and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2023 R1 used under a validated QMS. Release notes and regression test logs confirm version integrity. All simulation scripts stored in git repository with tagged releases. Requirement level 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one analytical benchmark relevant to rotating machinery internal flow.",
      "rationale": "SST k-omega turbulence model verified against analytical Poiseuille channel flow and rotating disk solutions. Residual convergence criteria set to 1e-6 for all transport equations. Code verification complete per ASME V&V 20 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5 % for the relative hemolysis index QoI on the production mesh.",
      "rationale": "Three-level mesh refinement study performed on the FDA generic centrifugal pump geometry. GCI for RH index: 1.8 % (fine-medium), 2.3 % (medium-coarse). Production mesh (12.4 M cells) selected. Richardson extrapolation applied. Discretization error within acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions for validation experiments documented and traceable; boundary conditions match simulation inputs within stated uncertainty.",
      "rationale": "In-vitro bench test conditions (fluid temperature, viscosity, pump speed, inlet pressure) documented in laboratory notebook LN-2023-047. Uncertainty analysis shows inlet flow rate measurement uncertainty ±1.5 %, pump speed ±0.5 rpm. Boundary conditions applied to CFD model match measured values within stated uncertainty bands. Note: test conditions reflect adult normative range only; paediatric conditions not tested."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index within ±15 % of experimental measurement across all validation operating points.",
      "rationale": "Predicted RH index compared against in-vitro measurements at 5 adult operating points. Maximum deviation 11.7 %, mean absolute error 7.2 %. Acceptance criterion of ±15 % satisfied at all points. Comparison documented in validation report VR-2023-CPB-001. Coverage limited to adult flow regime; no comparison data available for expanded paediatric envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index) is directly linked to the regulatory decision criterion and is measurable in both simulation and experiment.",
      "rationale": "Relative hemolysis index (RH) is the primary regulatory metric per FDA guidance on blood-contacting devices. RH is computed from simulated shear stress history integrated along fluid pathlines using the Giersiepen-Wurzinger power-law model. Experimentally measured via plasma-free haemoglobin assay. QoI relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted on a geometry and flow regime sufficiently similar to the COU to support credibility claims.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump, which is the same geometry class as the device under assessment. Adult CPB flow rates (2.0–6.0 L/min) and haematocrit range (35–45 %) were matched in the validation campaign. The assessment team notes that the Q4 2025 expansion to paediatric flow rates (0.5–1.8 L/min) and elevated haematocrit (42–52 %) reduces the relevance of existing validation evidence to the full current COU; re-validation is planned but not yet completed, and this gap is accepted pending H1 2026 re-validation activities.",
      "openIssue": "Validation activities do not cover the expanded paediatric operating envelope. Re-validation planned H1 2026; no re-calibration evidence linked at time of this assessment."
    },
    {
