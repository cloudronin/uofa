      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; iterative convergence monitored via residual plots.",
      "rationale": "Formal solver error quantification not required at MRL 2. Iterative convergence confirmed by residual drop to 1e-6 and stabilisation of monitored QoI. Scoped out per ASME V&V 40 Table 1 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2.",
      "rationale": "Use error assessment not required at MRL 2 per ASME V&V 40 Table 1. Simulation setup reviewed by a second analyst as standard practice."
    },
    {
