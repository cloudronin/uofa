  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026-03",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed the required level for MRL 2. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 1. The assessment team acknowledges that the Q4 2025 expansion of the operating envelope to include paediatric flow rates and elevated haematocrit reduces the coverage of existing validation evidence. Re-validation is planned for H1 2026. The decision to accept is made on the basis that the adult-range validation evidence remains applicable to the majority of the intended use population, and the paediatric sub-population represents a recently added indication for which risk mitigation (additional clinical monitoring) has been implemented as an interim measure pending re-validation.",
    "decidedAt": "2026-03-12T09:00:00Z"
  },
