  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for Model Risk Level 2. Six factors are not assessed, consistent with MRL 2 requirements. Validation results demonstrate CFD predictions within acceptance thresholds across all five target operating points. The relative hemolysis index RH < 1 criterion is satisfied at all operating conditions. The assessment team concluded that the model is fit for the stated COU of identifying worst-case hemolysis operating conditions for the Class II CPB device. It is noted that all validation activities were performed under controlled laboratory conditions (22°C, 101.3 kPa, no EMI). The clinical deployment environment involves ambient temperature variation (18–26°C), electromagnetic interference from surgical equipment, and altitude-dependent pressure variation (up to ±8 kPa). These environmental parameters were discussed informally during the assessment review but no formal environmental sensitivity study was conducted, and the operating envelope specification does not include bounding values for these parameters. The assessment team judged this gap acceptable at MRL 2 given the moderate model influence classification and the availability of physical testing as a confirmatory activity.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
