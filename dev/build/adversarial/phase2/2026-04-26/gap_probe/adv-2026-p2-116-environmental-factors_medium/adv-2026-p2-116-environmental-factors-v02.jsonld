  "name": "Morrison COU1 — CPB hemolysis credibility assessment (environmental gap variant)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. The pump is deployed in operating-room environments where ambient temperature can range from 18°C to 28°C, electromagnetic interference from electrosurgical units is routinely present, and altitude-dependent ambient pressure variations (0.85–1.01 atm) are encountered in high-altitude facilities. Validation experiments were conducted exclusively in a controlled laboratory setting at 22°C and standard atmospheric pressure; no environmental-sensitivity parametric study was performed and no operating-envelope bounding analysis links the laboratory conditions to the full deployment envelope.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-rh-less-than-1",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-centrifugal",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-lab-validation-22degC-1atm",
    "https://uofa.net/synth/data/morrison-pump-geometry-nominal"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The device is operated in clinical environments that introduce temperature drift (18–28°C), electromagnetic interference from electrosurgical and monitoring equipment, and ambient pressure variation across facility altitudes (0.85–1.01 atm); these environmental parameters influence blood viscosity, dissolved-gas behaviour, and sensor-driven boundary conditions fed to the CFD model.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-lab-bench",
      "type": "ValidationResult",
      "name": "Laboratory bench hemolysis validation — 22°C, 1 atm, 5 flow-speed points",
      "description": "Validation experiments conducted in a temperature-controlled laboratory at 22°C and atmospheric pressure (1.013 atm). Five flow-speed operating points (2–6 L/min, 2000–4000 RPM) were tested using bovine blood in a recirculating loop. Normalized index of hemolysis (NIH) and relative hemolysis index (RH) were computed and compared to CFD predictions. All five points achieved RH < 1. No environmental perturbation testing (temperature sweep, EM exposure, reduced ambient pressure) was performed; the laboratory setting was treated as representative of the full clinical deployment envelope without formal justification.",
      "outcome": "Accepted",
      "quantitativeResult": "RH range 0.61–0.94 across all five operating points; mean absolute error in NIH 8.3%"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-mesh-sensitivity",
      "type": "ValidationResult",
      "name": "Mesh-sensitivity and discretization error study",
      "description": "Three mesh densities (coarse 1.2M, medium 3.8M, fine 9.1M cells) evaluated at the nominal operating point (4 L/min, 3000 RPM). Richardson extrapolation applied; discretization error bounded at 4.2% for the scalar stress-based hemolysis index. Grid convergence index (GCI) < 5% for all reported QoIs. Study conducted at standard laboratory conditions identical to bench validation.",
      "outcome": "Accepted",
      "quantitativeResult": "GCI fine-medium 3.1%; GCI medium-coarse 7.8%; asymptotic convergence ratio 0.97"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034570",
