  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-env-gap-001-dr",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for Model Risk Level 2. The six remaining factors are scoped out as not required at MRL 2. The CFD model demonstrates acceptable predictive accuracy for hemolysis across all five COU operating points, with RH < 1 at each point and mean NIH error of 8.3%. The assessment team noted in internal review that clinical deployment environments introduce temperature variation (18–28°C), electromagnetic interference from surgical equipment, and altitude-related ambient pressure differences (0.85–1.01 atm) that were not reproduced in the validation experiments. It was judged informally that these environmental factors are unlikely to materially alter hemolysis predictions given the dominant role of impeller geometry and rotational speed. No formal environmental sensitivity study or operating-envelope bounding analysis was conducted to substantiate this judgment. The package is accepted at Medium assurance level for the Class II CPB device decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
