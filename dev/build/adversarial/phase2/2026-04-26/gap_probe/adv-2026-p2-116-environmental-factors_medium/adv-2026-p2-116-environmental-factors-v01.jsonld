      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; Gradation 1 sufficient.",
      "rationale": "At MRL 2, statistical characterisation of test sample variability is not required. Three independent blood batches used across the five operating points; inter-batch variability in baseline NIH was < 5%. Gradation 1 accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
