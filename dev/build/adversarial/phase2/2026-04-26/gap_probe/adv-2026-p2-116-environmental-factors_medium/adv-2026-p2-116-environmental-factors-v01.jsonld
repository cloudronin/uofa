      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against canonical benchmark problems; achievedLevel >= requiredLevel.",
      "rationale": "Solver verified against FDA benchmark nozzle and lid-driven cavity problems. Order-of-accuracy confirmed for incompressible Navier-Stokes and power-law hemolysis transport equations. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% on hemolysis index QoI; achievedLevel >= requiredLevel.",
      "rationale": "Three-level mesh refinement study performed on nominal pump geometry (2.1M, 5.8M, 14.2M cells). GCI for RH at worst-case operating point was 3.2%, satisfying the 5% threshold. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions documented with measurement uncertainty; achievedLevel >= requiredLevel.",
      "rationale": "Laboratory test conditions documented: temperature 22 ± 0.5°C, pressure 101.3 ± 0.5 kPa, bovine blood hematocrit 33 ± 1%. Flow rates and rotational speeds verified with calibrated instruments. All five operating points reproduced within stated tolerances. Note: conditions represent a single fixed environment; clinical deployment spans 18–28°C ambient and altitudes up to 2500 m, but this range was not explored in the validation campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (normalised RMS error or equivalent) reported for primary QoI; achievedLevel >= requiredLevel.",
      "rationale": "CFD-predicted RH compared against measured RH at all five operating points. Normalised RMS error 9.4%; maximum point-wise deviation 12%. Both within acceptance thresholds for Gradation 2. Velocity field NRMSE < 8% at mid-plane cross-sections."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to decision criterion (RH < 1); achievedLevel >= requiredLevel.",
      "rationale": "Primary QoI is relative hemolysis index (RH), which maps directly to the regulatory acceptance criterion RH < 1 relative to predicate device. Secondary QoIs (wall shear stress, exposure time distributions) support mechanistic interpretation. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating range match COU within documented tolerances; achievedLevel >= requiredLevel.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry at flow rates and speeds spanning the intended COU operating envelope (2–5 L/min, 2000–3500 RPM). Bovine blood rheology accepted as surrogate per ASTM F1841. Geometric fidelity confirmed via CMM. Environmental conditions (temperature, pressure, EM) were not varied to match the clinical deployment range, representing a gap in relevance coverage not captured in the Gradation 2 rating."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals < 1e-5 for all equations; achievedLevel >= requiredLevel.",
      "rationale": "Residuals for continuity, momentum, and hemolysis scalar transport monitored to < 1e-6 at all operating points. Mass imbalance < 0.01%. Gradation 1 requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; Gradation 1 sufficient.",
      "rationale": "At MRL 2, a formal use-error analysis is not required. Simulation workflow reviewed by two independent analysts; no systematic input errors identified during peer review. Gradation 1 accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence and hemolysis model selection justified with literature support; achievedLevel >= requiredLevel.",
      "rationale": "SST k-omega turbulence model selected based on benchmark comparisons for rotating hemodynamic devices. Power-law hemolysis model (Giersiepen-Wurzinger) calibrated against published RBC fragility data. Model form uncertainty estimated via comparison with Lagrangian particle-tracking hemolysis approach; difference < 7% in RH. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis performed on key input parameters; achievedLevel >= requiredLevel.",
      "rationale": "One-at-a-time sensitivity analysis performed on blood viscosity (±10%), pump clearance gap (±50 µm), and inlet flow waveform shape. Hemolysis index sensitivity to viscosity was 4.2% per 10% viscosity change under nominal laboratory conditions. Temperature-dependent viscosity variation across the clinical ambient range (18–28°C corresponds to approximately ±8% viscosity change) was identified informally but not formally bounded or linked to a parametric study in this evidence package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
