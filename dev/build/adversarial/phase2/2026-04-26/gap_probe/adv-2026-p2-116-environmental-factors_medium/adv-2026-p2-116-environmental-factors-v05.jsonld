  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. Six factors are not assessed, consistent with MRL 2 requirements. The CFD model is accepted for identifying worst-case hemolysis operating conditions for the Class II CPB device. RH < 1.0 confirmed across all five flow-speed combinations. The assessment team noted informally that validation was conducted exclusively under standard laboratory conditions (22°C, 101.3 kPa) and that the deployment environment includes temperature variation (18–26°C), potential electromagnetic interference from surgical equipment, and reduced ambient pressure at altitude. A brief informal review suggested these factors are unlikely to materially affect hemolysis predictions, but no quantitative environmental-sensitivity study was conducted and the operating envelope does not formally bound these parameters. The team judged the overall evidence sufficient to support the regulatory submission at the current model risk level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
