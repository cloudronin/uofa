  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The device is deployed in operating-room environments where ambient temperature ranges from 18 °C to 28 °C, ambient pressure may vary during air-transport scenarios, and surgical electrocautery units generate broadband electromagnetic interference that can affect sensor-based feedback loops integral to pump control.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-bench-22c",
      "type": "ValidationResult",
      "name": "Bench hemolysis validation at 22 °C, atmospheric pressure",
      "description": "CFD predictions of normalised index of haemolysis (NIH) were compared against in-vitro measurements conducted in a temperature-controlled laboratory at 22 °C and 101.3 kPa. Five flow-speed operating points were evaluated. Predicted NIH values agreed with measurements within 12 % across all points (RH < 1 satisfied). No variation in ambient temperature, humidity, or electromagnetic environment was introduced during testing. A single temperature point (22 °C) was selected as representative of laboratory conditions; the sensitivity of hemolysis predictions to the full OR temperature range (18–28 °C) was not characterised. Humidity and EMI sensitivity studies were not performed."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretisation error assessment",
      "description": "Richardson extrapolation was applied across three systematically refined meshes (2.1 M, 7.4 M, 18.6 M cells). Grid convergence index (GCI) for NIH was 3.8 % on the fine mesh, satisfying the MRL 2 threshold of 5 %. All convergence studies were run under the same 22 °C, 1 atm laboratory boundary conditions used for the bench validation."
    }
  ],
