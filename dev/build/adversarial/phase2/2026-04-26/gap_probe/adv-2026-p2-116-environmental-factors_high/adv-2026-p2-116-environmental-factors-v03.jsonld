  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their MRL 2 required levels. Six factors are not assessed, consistent with MRL 2 scoping. Mesh convergence GCI (3.1%) and output comparison agreement (±8%) both satisfy acceptance criteria. Model form uncertainty (±15%) is within the tolerance allocated for Class II comparative assessment. The assessment team notes that validation was conducted under a single set of laboratory environmental conditions (22°C, 1.0 atm, controlled EMI) and that the clinical deployment environment spans 18–26°C, 0.85–1.01 atm, and variable EMI from electrosurgical equipment; however, this observation was not formally elevated to a gap finding requiring resolution prior to acceptance at MRL 2. The relative hemolysis index RH < 1 criterion is met across all five operating points, supporting regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
