  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-vr-01-lab-baseline",
      "type": "ValidationResult",
      "name": "Laboratory baseline hemolysis validation at 22°C, 1.0 atm",
      "description": "CFD predictions of relative hemolysis index compared against in-vitro measurements for 5 flow-speed operating points. All experiments conducted in a temperature-controlled laboratory at 22°C and atmospheric pressure (1.0 atm). Blood analogue viscosity was set at the 22°C value (3.2 mPa·s). EMI shielding was standard laboratory grade. RH predictions agreed with measurements within ±8% across all operating points, meeting the MRL 2 acceptance criterion. No parametric sweep of ambient temperature, altitude pressure, or electromagnetic interference was performed; a single nominal environmental condition was assumed representative of all deployment contexts."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-vr-02-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification",
      "description": "Richardson extrapolation performed across three mesh refinement levels (4.2M, 9.8M, 21.4M cells). Grid convergence index for the hemolysis scalar did not exceed 3.1% at the finest level, satisfying the MRL 2 discretization error requirement. Study conducted at the same single laboratory condition (22°C, 1.0 atm) as the baseline validation; environmental variation was not a parameter in the convergence study."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-vr-03-solver-verification",
      "type": "ValidationResult",
      "name": "Numerical solver verification against manufactured solution",
      "description": "Method of manufactured solutions applied to the Navier-Stokes and power-law hemolysis transport equations. Second-order spatial convergence confirmed. Iterative convergence monitored via residual drop of six orders of magnitude. No environmental parameters are inputs to the solver verification; verification is environment-independent by design."
    }
  ],
