    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments document controlled fluid temperature, pump speed, and flow rate. Measurement uncertainty quantified for all primary inputs.",
      "rationale": "In-vitro experiments documented fluid temperature (22 ± 0.5°C), pump rotational speed (±10 RPM), and flow rate (±0.05 L/min). Measurement uncertainty propagated through RH calculation. All five flow-speed operating points replicated in triplicate. Ambient pressure was 1.0 atm (sea level laboratory); no altitude or pressure sensitivity was characterised. EMI environment of the laboratory was not characterised or compared against clinical deployment environments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH values agree with measured RH within combined simulation and experimental uncertainty bands across all five operating points.",
      "rationale": "CFD RH predictions fell within ±8% of experimental measurements across all five operating points; combined uncertainty bands were ±11%. Acceptance criterion satisfied. Comparison performed exclusively at 22°C, 1.0 atm; no comparison at the 18°C or 26°C extremes of the clinical deployment range was conducted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to the regulatory acceptance criterion and clinical endpoint of interest.",
      "rationale": "RH is the FDA-recognised metric for comparative hemolysis assessment and is the primary output used in the regulatory submission. QoI relevance is high and unambiguous."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid properties, and operating points represent the COU device and intended operating range.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry at clinically representative flow rates (2–6 L/min) and rotational speeds (1500–3000 RPM). Blood analogue (glycerol-water, 36% v/v) viscosity matched at 22°C. Clinical deployment spans 18–26°C ambient; blood viscosity is temperature-dependent (approximately 4% per °C), but no temperature-adjusted fluid property set was used in validation. This gap is noted but not formally characterised as an environmental sensitivity study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence monitored; residuals reduced sufficiently to confirm solver-introduced error is negligible relative to discretization error.",
      "rationale": "Residuals for continuity, momentum, and hemolysis transport reduced by at least 5 orders of magnitude in all production runs. Solver error assessed as negligible. Requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions, material properties, and turbulence model settings verified against simulation plan.",
      "rationale": "Independent peer review of simulation setup completed by second analyst. Boundary conditions, turbulence model (SST k-ω), and hemolysis model constants verified against documented simulation plan. No discrepancies identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing equations and hemolysis sub-model are appropriate for the flow regime and damage mechanism; model form uncertainty is characterised.",
      "rationale": "SST k-ω turbulence model selected based on prior benchmark studies for rotating blood-contacting devices. Power-law hemolysis model (Giersiepen-Wurzinger) applied with literature constants. Model form uncertainty estimated at ±15% on RH based on comparison with alternative hemolysis model (Zhang et al.). This uncertainty was quantified at 22°C; temperature dependence of red blood cell fragility was not included in the model form uncertainty characterisation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of RH to key model inputs (geometry tolerances, fluid viscosity, inlet velocity profile) quantified; dominant inputs identified.",
      "rationale": "One-at-a-time sensitivity study performed for impeller tip clearance (±50 µm), inlet velocity profile (flat vs. parabolic), and fluid viscosity (nominal ±5%). Viscosity was varied within the 22°C measurement uncertainty only; temperature-driven viscosity variation across the 18–26°C clinical deployment range (approximately ±8% relative to 22°C nominal) was not included in the sensitivity sweep. Dominant input identified as tip clearance (ΔRH ≈ 12% per 50 µm)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Pump specimens used in validation experiments are representative of the nominal design geometry within stated manufacturing tolerances.",
      "rationale": "Three pump specimens measured by CMM prior to testing; all dimensions within ±25 µm of nominal CAD. Specimens are representative. Requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in CFD simulations match those measured in the validation experiments within stated uncertainties.",
      "rationale": "Pump geometry, rotational speed, flow rate, and fluid viscosity in CFD matched experimental measurements within combined uncertainties. Equivalency confirmed for all five operating points. Environmental inputs (ambient temperature, pressure, EMI) were identical between simulation and experiment by construction—both at 22°C, 1.0 atm, controlled laboratory—but this equivalency was achieved by restricting both to a single nominal environment rather than by bounding the full clinical deployment envelope."
    }
