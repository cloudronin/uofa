  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scope. The CFD model demonstrates adequate predictive accuracy for the relative hemolysis index under the validated laboratory conditions. The assessment team concluded that the model is fit for purpose for identifying worst-case hemolysis operating conditions for the Class II CPB device, and that the RH < 1 acceptance criterion is met across all five flow-speed combinations. The assessment is accepted for submission.",
