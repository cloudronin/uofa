  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements per ASME V&V 40 Table 5-1. CFD predictions of relative hemolysis index are within 8 % of experimental measurements across all five operating points. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device. Assessment team notes that validation was conducted at a single laboratory temperature (22 °C) and atmospheric pressure; the sensitivity of hemolysis predictions to the broader deployment thermal and pressure envelope (18–26 °C, altitude-adjusted pressure, EMI from adjacent perfusion equipment) has not been characterised. This environmental gap is acknowledged but judged acceptable at MRL 2 given the medium model influence and the availability of physical testing to confirm final design decisions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
