  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Hemolysis benchmark — laboratory 22°C atmospheric pressure",
      "description": "CFD predictions of the normalized index of hemolysis (NIH) were compared against in-vitro measurements using bovine blood in the FDA generic centrifugal pump geometry. All five flow-speed operating points were tested in the laboratory at 22°C and standard atmospheric pressure (101.3 kPa). Relative hemolysis index RH < 1 for all points. Agreement within 12% of measured NIH across the operating envelope. No variation in ambient temperature, humidity, or electromagnetic environment was introduced during testing; a single temperature sensitivity run at 22°C confirmed baseline model response but no broader environmental sweep was performed."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error study",
      "description": "Grid convergence index (GCI) study performed on three systematically refined meshes (4.2M, 9.8M, 21.4M cells). GCI < 2.1% for shear-stress-derived hemolysis index at all operating points. Richardson extrapolation applied; observed order of convergence 1.94. Study conducted in the same 22°C laboratory environment as the hemolysis benchmark; no environmental sensitivity of numerical convergence behavior was assessed."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-code-verification",
      "type": "ValidationResult",
      "name": "Numerical code verification — manufactured solution",
      "description": "Method of manufactured solutions (MMS) applied to the incompressible Navier-Stokes solver (ANSYS Fluent 2022R2) confirming second-order spatial accuracy. L2 norm errors decrease at expected rate with mesh refinement. Verification performed on isolated benchmark cases under standard laboratory conditions."
    }
  ],
