    "https://uofa.net/synth/data/morrison-predicate-rhi-reference"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-bench-hemolysis",
      "type": "ValidationResult",
      "name": "Bench hemolysis validation — 5 flow-speed operating points",
      "description": "Experimental hemolysis measurements were performed on a physical prototype of the FDA generic centrifugal blood pump at five flow-speed combinations (2–6 L/min, 2000–3500 RPM). All tests conducted in a temperature-controlled laboratory at 22 ± 0.5°C, atmospheric pressure (101.3 kPa), with no characterisation of electromagnetic interference. Relative Hemolysis Index values from CFD predictions agreed with measured values to within 8% across all five operating points, meeting the RH < 1 acceptance criterion. Blood analogue fluid (glycerol-water) viscosity was adjusted to 37°C physiological conditions via published correction factors; however, no sensitivity analysis was performed to assess the effect of ambient temperature variation (18–26°C theatre range) on pump housing thermal boundary conditions or fluid rheology during priming. Humidity and EMI conditions present in surgical theatres were not characterised or replicated."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretisation error study",
      "description": "Grid convergence index (GCI) study performed using three systematically refined meshes (2.1M, 6.8M, 18.4M cells). GCI for the shear-stress-derived hemolysis index was 3.2% on the fine grid, satisfying the MRL 2 requirement of GCI < 5%. All simulations executed at 22°C reference conditions consistent with the bench validation environment."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-predicate-comparison",
      "type": "ValidationResult",
      "name": "Predicate device RHI comparison",
      "description": "Relative Hemolysis Index for the investigational pump geometry was compared against the predicate device across the same five operating points. CFD-predicted RH values ranged 0.71–0.94, all below the acceptance threshold of 1.0. Comparison performed using laboratory-derived experimental data for the predicate device; no correction for in-theatre environmental conditions (temperature excursions, EMI-induced sensor noise, or pressure altitude) was applied to either dataset."
    }
  ],
