  "signature": "ed25519:b1d4e7a2c5f8b3e6a9d2c5f0b4e7a1d4c7f2b5e8a3d6c1f4b7e2a5d8c3f6b1e4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite; MRL 2 requires Gradation 1 minimum.",
      "rationale": "ANSYS Fluent 2022R2 used under ISO 9001-certified quality management system. Solver verification test suite documented with 98% pass rate. Version control and change management records available. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems; MRL 2 requires Gradation 2.",
      "rationale": "Code verification performed against three analytical benchmark cases: Poiseuille flow, lid-driven cavity, and rotating annulus. L2 norm errors below 0.1% for all benchmarks, confirming correct discretisation of Navier-Stokes equations. Achieved level meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI for primary QoI (hemolysis index) must be below 5% on the production mesh; MRL 2 requires Gradation 2.",
      "rationale": "Three-level GCI study yielded GCI_fine = 3.2% for the hemolysis index and GCI_fine = 2.8% for wall shear stress. Richardson extrapolation applied; asymptotic convergence confirmed (ratio 1.03). Production mesh of 6.8M cells selected as best balance of accuracy and computational cost. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce; flow rates, rotational speeds, and fluid properties reported. Environmental conditions (temperature, pressure) recorded at time of test.",
      "rationale": "All five flow-speed operating points documented with calibrated flow meter (±0.5% accuracy) and torque transducer (±1% accuracy). Laboratory temperature recorded as 22 ± 0.5°C and atmospheric pressure as 101.3 ± 0.2 kPa at time of test. Blood analogue fluid viscosity characterised at 22°C; correction factor applied to derive 37°C physiological viscosity. No characterisation of electromagnetic interference environment or humidity was performed. Temperature was recorded as a single nominal value; no sensitivity study across the theatre operating temperature range (18–26°C) was conducted. Achieved level assessed as meeting Gradation 2 because the documented conditions are reproducible, but the absence of environmental range characterisation is not penalised at this gradation level under MRL 2 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., relative error, validation metric) defined a priori; agreement within ±10% for hemolysis index across all operating points.",
      "rationale": "Validation metric defined as relative error in normalised hemolysis index (NIH) between CFD prediction and bench measurement. Maximum relative error across five operating points was 7.8% (at 3 L/min, 2500 RPM). All five points within ±10% acceptance band. Systematic over-prediction of 3–5% at low-flow conditions attributed to secondary recirculation not fully captured by k-ω SST turbulence model; documented as acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, wall shear stress) must be directly relevant to the COU decision (worst-case hemolysis identification); mapping between validation QoIs and COU QoIs documented.",
      "rationale": "Primary QoI is the Normalised Index of Hemolysis (NIH) derived from the power-law hemolysis model (Giersiepen et al.). NIH directly maps to the RH acceptance criterion used in the COU decision. Secondary QoI (volume-averaged shear stress) provides mechanistic insight. Both QoIs measured in bench experiment and predicted by CFD. Relevance mapping documented in credibility assessment report Section 4.2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, fluid, and operating conditions representative of the COU; deviations from COU conditions documented with justification.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the same geometry used in the COU. Blood analogue fluid (glycerol-water, 36% by mass) used in place of whole blood per ASTM F1841 guidance. Operating points span the clinical CPB flow-speed envelope (2–6 L/min, 2000–3500 RPM). Validation conducted at 22°C laboratory conditions; clinical deployment occurs in operating theatres where temperature ranges 18–26°C, ambient pressure varies with altitude (0.85–1.01 atm at high-altitude centres), and electrocautery and anaesthesia equipment introduce electromagnetic interference. These environmental differences between the validation setting and the deployment environment are noted; however, no environmental sensitivity study was performed and no operating envelope bounding these parameters is documented. This gap is not captured as a scored deficiency under the current MRL 2 assessment framework as applied by the assessment team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to at least 10^-4 for all transport equations; MRL 2 requires Gradation 1.",
      "rationale": "All simulations converged to residuals below 10^-5 for continuity, momentum, and turbulence equations. Mass imbalance across domain below 0.01%. Convergence monitored via NIH monitor point; variation below 0.1% over final 500 iterations. Achieved level meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence that simulation inputs were reviewed by a second analyst; boundary conditions and material properties checked against source data.",
      "rationale": "Independent review of CFD setup performed by senior analyst not involved in model construction. Boundary conditions (inlet velocity profiles, outlet pressure, wall rotation rates) verified against experimental test matrix. Material properties (viscosity, density) cross-checked against ASTM F1841 reference values. No use errors identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified for rotating machinery hemolysis applications; hemolysis constitutive model documented with applicability range.",
      "rationale": "k-ω SST turbulence model selected based on published benchmark studies for centrifugal blood pumps (Fraser et al. 2011, Hariharan et al. 2011). Power-law hemolysis model (Giersiepen 1990) applied with constants validated for shear stress range 1–400 Pa. Model form uncertainty estimated at ±12% for NIH prediction, within acceptable range for MRL 2. Newtonian fluid assumption justified for shear rates above 100 s^-1 prevalent in the impeller region."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of NIH prediction to key input parameters (geometry tolerances, fluid viscosity, inlet flow profile) quantified; inputs bounded to COU operating range.",
      "rationale": "One-at-a-time sensitivity analysis performed for five input parameters: impeller clearance (±0.05 mm), inlet velocity profile (flat vs. developed), fluid viscosity (±5%), rotational speed (±50 RPM), and outlet pressure (±5 mmHg). NIH sensitivity coefficients documented; impeller clearance identified as dominant parameter (sensitivity index 0.42). Fluid viscosity sensitivity evaluated at 22°C reference condition only; sensitivity to viscosity variation arising from in-theatre temperature fluctuations (18–26°C) was not assessed. Input bounds documented for geometric and flow parameters; environmental parameters (temperature, pressure, EMI) are absent from the input uncertainty characterisation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least one physical prototype tested; sample representativeness of production geometry documented.",
      "rationale": "One prototype pump manufactured to FDA generic geometry nominal dimensions (within ±0.02 mm of nominal per CMM inspection report). Prototype fabricated from medical-grade polycarbonate consistent with production material specification. Single sample sufficient for MRL 2 Gradation 1 requirement. Batch variability not assessed at this MRL."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in CFD simulation match those measured during bench experiment to within stated uncertainty; equivalency table provided.",
      "rationale": "Equivalency table provided in credibility assessment report Appendix B. CFD boundary conditions set to match measured experimental values: inlet flow rate (CFD 4.00 L/min vs. measured 4.02 ± 0.02 L/min), rotational speed (CFD 3000 RPM vs. measured 3001 ± 5 RPM), fluid temperature (CFD 22°C vs. measured 22 ± 0.5°C). All parameters within stated measurement uncertainty. Equivalency confirmed for the single laboratory temperature condition; no equivalency assessment performed for the broader in-theatre environmental envelope."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, which is acceptable at MRL 2 per ASME V&V 40-2018 Table 3. CFD predictions of NIH agree with bench measurements within ±8% across all five operating points, satisfying the RH < 1 acceptance criterion. Validation was conducted at 22°C laboratory conditions; the deployment environment in operating theatres involves temperature variation (18–26°C), altitude-dependent pressure (0.85–1.01 atm), and electromagnetic interference from surgical equipment. A single temperature condition was characterised during bench testing; humidity and EMI sensitivity studies were not performed and no environmental operating envelope bounding these parameters is documented. The assessment team judged that these environmental differences do not materially affect the NIH prediction at MRL 2, based on the expectation that fluid viscosity corrections adequately account for temperature effects and that pump hydraulic performance is not sensitive to the EMI levels present in the theatre environment. No formal sensitivity study or bounding argument for the full environmental operating envelope was required or provided. The overall credibility assessment supports acceptance of the CFD model for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
