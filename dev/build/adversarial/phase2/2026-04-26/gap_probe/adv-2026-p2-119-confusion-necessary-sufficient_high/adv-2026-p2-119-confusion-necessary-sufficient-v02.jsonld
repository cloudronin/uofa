  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and issue tracking consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) operates under a documented software quality plan including version-controlled release notes, automated regression suite covering cardiovascular benchmark cases, and a formal issue-tracking system. SQA records confirm Gradation 2 compliance. This factor is a necessary condition for numerical trustworthiness but is noted as one of several prerequisites; it does not independently establish patient safety."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions.",
      "rationale": "Code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes equations and confirmed first-order spatial convergence consistent with the discretisation scheme. Results match published FDA benchmark CFD challenge data within 5% for velocity profiles. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary hemolysis-relevant QoI (volume-averaged scalar shear stress) must be below 5% at the nominal mesh density.",
      "rationale": "A three-level mesh refinement study (2.1M, 5.8M, 14.3M cells) was conducted. Richardson extrapolation yields a GCI of 2.8% for volume-averaged scalar shear stress at the nominal 5.8M-cell mesh. Discretization error is within the acceptance threshold. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation test conditions must correspond to the 5 target flow-speed operating points within ±5% of nominal boundary conditions.",
      "rationale": "Experimental PIV and hemolysis data were collected at flow rates of 2, 3, 4, 5, and 6 L/min at corresponding rotational speeds. Measured inlet velocities and impeller speeds were within 3.2% of CFD boundary conditions. Temperature and fluid viscosity (porcine blood analogue) were matched to within stated tolerances. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index RH must agree with experimental measurements within 15% across all 5 operating points, and RH < 1 must be satisfied relative to predicate device.",
      "rationale": "CFD-predicted RH values range from 0.61 to 0.89 across the 5 operating points, all below the RH < 1 acceptance threshold relative to the predicate device. Mean absolute percentage error versus experimental MIH measurements is 9.3%. The RH < 1 criterion is satisfied at all operating points. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index derived from volume-averaged scalar shear stress and exposure time) must be directly traceable to the clinical endpoint of pump-induced hemolysis.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is applied to CFD-derived shear stress and exposure time fields to compute the modified index of hemolysis (MIH), which is then normalised against predicate device MIH to yield RH. This QoI is directly linked to the clinical measure of plasma free haemoglobin elevation. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic centrifugal pump geometry, blood analogue fluid, and operating envelope as specified in the COU.",
      "rationale": "Validation activities used the FDA-specified generic centrifugal pump geometry with the same impeller-volute configuration. The blood analogue (35% glycerol-water) matched the nominal viscosity of whole blood at 37°C. All 5 COU operating points were included in the validation matrix. Geometric fidelity and fluid properties are sufficiently representative of the COU. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and round-off error contributions to hemolysis QoI are documented.",
      "rationale": "At MRL 2, detailed decomposition of numerical solver error beyond residual monitoring is not required. Residuals were reduced by six orders of magnitude in all simulations, providing baseline confidence. Formal solver error quantification was scoped as not required for this assessment level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for analyst error in model setup, boundary condition specification, and post-processing is characterised.",
      "rationale": "At MRL 2, formal use-error assessment is not required. Simulation setup followed a documented standard operating procedure reviewed by a second analyst. Independent re-run of one operating point confirmed reproducibility. Full use-error characterisation is deferred as not required at this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Adequacy of the turbulence closure model and hemolysis constitutive model for the rotating blood pump flow regime is evaluated.",
      "rationale": "At MRL 2, formal model-form uncertainty quantification is not required. The SST k-omega turbulence model was selected based on literature precedent for rotating blood pump CFD. Sensitivity of the hemolysis prediction to turbulence model choice was not formally quantified within this assessment scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in fluid material properties, geometric tolerances, and boundary condition values and their propagation to the hemolysis QoI are characterised.",
      "rationale": "At MRL 2, full input uncertainty propagation is not required. Nominal material properties (blood density 1056 kg/m³, viscosity 0.0035 Pa·s) were used without probabilistic sampling. Geometric manufacturing tolerances were not propagated through the model. This factor is deferred as not required for this assessment level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Variability across experimental pump units and blood analogue batches used in validation is characterised.",
      "rationale": "Validation experiments were conducted on a single pump unit with a single blood analogue batch. At MRL 2, inter-unit and inter-batch variability characterisation is not required. The single-unit validation is considered sufficient for the current model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalence between CFD model input parameters and actual clinical device operating parameters is formally demonstrated.",
      "rationale": "At MRL 2, formal equivalency mapping between simulation inputs and clinical deployment parameters is not required. The operating envelope (2–6 L/min, 2000–3500 RPM) spans the intended CPB use range. Detailed clinical parameter equivalency analysis is deferred as not required at this model risk level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Medium assurance level. The determinative basis for acceptance is that the CFD model satisfies the RH < 1 relative hemolysis index criterion across all five target operating points, with RH values ranging from 0.61 to 0.89. Because the model consistently predicts hemolysis levels below those of the predicate device — the regulatory acceptance criterion established for Class II CPB devices — the model is deemed credible for identifying worst-case hemolysis operating conditions and supporting the tolerance-sensitivity decision. The RH < 1 criterion is the safety gate for this device class: its satisfaction confirms that the pump design under evaluation does not exceed the hemolytic burden of a device already demonstrated to be safe in clinical use. All seven assessed credibility factors (software quality assurance, numerical code verification, discretization error, test conditions, output comparison, relevance of QoI, and relevance of validation activities) meet their required levels, providing the technical foundation that ensures the RH computation is numerically sound and experimentally validated. The six not-assessed factors are acceptable at MRL 2 and do not undermine the sufficiency of the RH < 1 finding. Accordingly, the model is accepted for use in the CPB hemolysis COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
