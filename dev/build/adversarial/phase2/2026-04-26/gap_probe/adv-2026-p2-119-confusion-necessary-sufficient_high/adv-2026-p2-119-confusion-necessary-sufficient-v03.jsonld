  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model is accepted as credible for the CPB hemolysis COU on the basis that the relative hemolysis index criterion (RH < 1) is satisfied across all five evaluated operating conditions. The RH criterion is the established regulatory acceptance metric for Class II CPB devices, and its satisfaction by the model — confirmed through validated output comparison at Gradation 2 — constitutes sufficient evidence that the computational model meets the safety goal of this COU. Discretization error has been rigorously controlled (GCI 1.8%), test conditions match the clinical envelope within ±8%, and the QoIs are directly linked to the clinical hemolysis endpoint. Because the RH < 1 criterion is met with adequate numerical fidelity and experimental agreement, the model is judged to be fit for purpose for identifying worst-case hemolysis operating conditions. Factors not assessed at MRL 2 (model form, model inputs, use error, numerical solver error, test samples, equivalency of input parameters) are acknowledged but are not required for acceptance at this risk level and do not affect the sufficiency of the RH-based safety demonstration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
