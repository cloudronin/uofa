  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model is accepted for the CPB hemolysis COU. The critical safety property underpinning this acceptance is the confirmed satisfaction of the relative hemolysis index threshold: all five evaluated operating points yield RH < 1, demonstrating that the model predicts hemolysis levels below those of the predicate device. Because the RH < 1 criterion is the regulatory acceptance gate for Class II CPB devices, its consistent satisfaction across the full operating envelope constitutes the definitive safety demonstration for this COU. The seven assessed credibility factors all meet their required Gradation 2 levels, confirming that the computational infrastructure supporting the RH prediction is sound. The six remaining factors are not assessed, which is permissible at Model Risk Level 2 given medium model influence. With the RH < 1 threshold satisfied and the assessed factors meeting requirements, the model provides adequate credibility for identifying worst-case hemolysis operating conditions, and the submission is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
