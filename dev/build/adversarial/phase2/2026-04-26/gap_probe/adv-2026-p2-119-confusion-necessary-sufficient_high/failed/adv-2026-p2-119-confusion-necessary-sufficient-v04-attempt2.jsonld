  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model is accepted for the CPB use COU because the output comparison factor demonstrates that predicted relative hemolysis index values agree with in-vitro measurements within 8.4% across all five operating points, satisfying the RH < 1 acceptance criterion. The presence of this quantitative agreement between model predictions and experimental hemolysis measurements constitutes the definitive demonstration that the model is fit for purpose: since the RH predictions are validated, the model is sufficient to support the regulatory decision regarding worst-case hemolysis operating conditions for the Class II CPB device. All seven assessed credibility factors meet or exceed their required levels under MRL 2, and the six not-assessed factors are appropriately scoped out at this model risk level. No further evidence is required to establish model credibility for this context of use.",
