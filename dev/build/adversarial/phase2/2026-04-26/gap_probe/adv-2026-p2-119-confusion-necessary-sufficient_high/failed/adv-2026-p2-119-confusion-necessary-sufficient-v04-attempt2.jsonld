      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index RH) must be directly linked to the clinical safety endpoint of erythrocyte damage.",
      "rationale": "The relative hemolysis index RH is the FDA-recognized metric for comparative hemolysis assessment of blood-contacting devices. RH directly quantifies erythrocyte destruction relative to the predicate, satisfying the relevance requirement for Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
