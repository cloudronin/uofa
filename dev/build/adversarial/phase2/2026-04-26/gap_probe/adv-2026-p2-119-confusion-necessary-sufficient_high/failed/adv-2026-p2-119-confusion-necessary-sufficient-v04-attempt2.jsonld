      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under documented version control with regression test suite confirming numerically correct outputs for canonical flows.",
      "rationale": "ANSYS Fluent 2022R2 is used under ISO 9001-certified quality management. Version control logs and regression test results for pipe flow, lid-driven cavity, and rotating disk benchmarks confirm solver integrity at Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes at least two published benchmark verification cases relevant to rotating turbomachinery flows.",
      "rationale": "Code verification confirmed via Taylor-Green vortex and rotating channel flow benchmarks. Observed convergence rates match theoretical second-order spatial accuracy, satisfying Gradation 2 code verification requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis-relevant shear stress quantities must be below 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.8M, 14.2M cells). Richardson extrapolation yields GCI of 3.2% for volume-averaged scalar stress, satisfying the 5% threshold. Fine mesh adopted for all production runs."
