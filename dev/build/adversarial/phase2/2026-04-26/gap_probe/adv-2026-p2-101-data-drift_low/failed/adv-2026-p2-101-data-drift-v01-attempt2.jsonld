  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, consistent with ASME V&V 40 Table 4 allowances at MRL 2. The assessment team acknowledges that the operating envelope has expanded since the 2019 validation campaign to include paediatric CPB circuits and low-flow perfusion states not covered by existing validation evidence. The team judges by engineering analogy that the model remains fit for purpose across the expanded envelope; this judgement has not been substantiated by supplemental experimental validation or re-calibration, and no such evidence is linked in this package. The device remains Class II with decision consequence HIGH. Overall credibility is assessed as Medium, consistent with the assurance level declared.",
