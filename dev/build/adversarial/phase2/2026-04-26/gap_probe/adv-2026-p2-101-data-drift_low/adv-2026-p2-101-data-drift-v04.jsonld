      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one canonical benchmark with known analytical solution.",
      "rationale": "Lid-driven cavity and Poiseuille flow benchmarks reproduced to within 0.5% of analytical solutions. Code verification documented in internal report VER-2019-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
