      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented release notes and regression test suite.",
      "rationale": "ANSYS Fluent 2020 R2 used under ISO 9001-certified QMS. Full regression suite executed; no failures. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
