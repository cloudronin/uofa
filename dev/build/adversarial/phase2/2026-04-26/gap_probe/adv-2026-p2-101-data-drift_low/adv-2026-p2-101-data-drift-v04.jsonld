  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scope per ASME V&V 40 Table 3. The 2019 validation dataset demonstrates adequate agreement (RH within 12%) across the adult CPB operating range. The assessment team acknowledges that the clinical use case has grown to include paediatric and neonatal patients at lower flow rates since the original validation campaign; however, the existing evidence is judged sufficient to support the Accepted decision for the current submission. Re-validation covering the paediatric envelope is recommended as a post-market activity.",
