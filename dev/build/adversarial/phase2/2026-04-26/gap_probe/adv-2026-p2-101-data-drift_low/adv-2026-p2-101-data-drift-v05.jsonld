  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scoping. The assessment team acknowledges that the operating envelope has expanded since the 2021 validation campaign to include paediatric and high-flow adult perfusion conditions; however, the team judges the existing validation evidence sufficient by analogy and geometric similarity. No supplemental validation data covering the expanded envelope have been collected or linked to this package. The decision is Accepted on the basis that the original validation evidence remains the best available and the device continues to demonstrate acceptable clinical hemolysis outcomes in post-market surveillance.",
