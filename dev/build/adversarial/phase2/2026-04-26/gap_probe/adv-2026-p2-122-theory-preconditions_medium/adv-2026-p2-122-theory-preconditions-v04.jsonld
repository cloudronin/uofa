    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index within 15% of experimental RH across all 5 operating points; systematic bias < 10%.",
      "rationale": "RH predictions compared against in-vitro measurements at all 5 flow-speed combinations. Maximum point error 12.4%; mean error 8.3%; no systematic bias detected. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to the regulatory acceptance criterion and clinical endpoint of pump-induced hemolysis.",
      "rationale": "The relative hemolysis index RH is the direct regulatory comparator specified in FDA guidance for Class II blood pumps. The model outputs RH as a primary QoI. Strong alignment between model output and decision criterion confirmed. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on geometrically similar centrifugal blood pump operating within ±20% of COU flow rates and rotational speeds.",
      "rationale": "Validation conducted on FDA generic centrifugal pump geometry — the same geometry used in the COU. Operating points span 3–6 L/min and 2000–3500 RPM, bracketing the 5 COU operating conditions. Fluid properties matched to CPB blood analog. Relevance confirmed at Gradation 2. The Giersiepen-Wurzinger power-law model used for damage accumulation assumes that RBC damage accumulates linearly along particle trajectories and that the damage integral is path-independent under the local instantaneous stress field — an assumption broadly applicable to blood-contacting devices operating in the turbulent-transitional regime. This precondition is accepted as satisfied based on the model's established use in the literature.",
      "rationale_note": "No specific ValidationResult is included to verify that the linear damage-accumulation precondition holds for the CPB operating regime of this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; commercial solver pedigree accepted as sufficient.",
      "rationale": "MRL 2 does not require independent numerical solver error quantification beyond code verification. Not assessed per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst training records on file.",
      "rationale": "Analyst holds CFD simulation certificate and has performed > 10 prior blood pump CFD studies. Use error risk judged low; formal assessment not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model (SST k-omega) and hemolysis sub-model (Giersiepen-Wurzinger power law) selection justified by prior validation studies in comparable geometries.",
      "rationale": "SST k-omega turbulence closure selected based on its established performance in rotary blood pump geometries (Hariharan et al. 2011; Fraser et al. 2012). Giersiepen-Wurzinger hemolysis model selected as the regulatory standard for comparative RH assessment. Model form assessed at Gradation 2. The theoretical precondition underlying the Giersiepen-Wurzinger formulation — that instantaneous scalar stress exposure is the sole determinant of RBC damage and that damage accumulates linearly along streamlines — is stated as broadly applicable and not further verified against the specific turbulence intensity and exposure-time distributions encountered in the CPB COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions (inlet velocity profile, outlet pressure, wall motion) derived from device specifications and CPB clinical operating parameters with documented uncertainty.",
      "rationale": "Inlet boundary conditions set from Doppler-measured velocity profiles at pump inlet under CPB flow conditions. Outlet pressure from clinical CPB circuit pressure measurements (mean 80 mmHg, SD 5 mmHg). Impeller rotational speed from device specification ±1%. Input uncertainty propagated via ±10% sensitivity runs. Gradation 2 achieved."
    },
