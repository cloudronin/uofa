  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed the required gradation levels for MRL 2. The six not-assessed factors are appropriately scoped out per ASME V&V 40-2018 Table 3 for MRL 2. The CFD model reliably predicts relative hemolysis index within 15% of experimental measurements across all 5 CPB operating points. The Giersiepen-Wurzinger damage accumulation model is accepted as fit-for-purpose based on its established use in the regulatory literature for comparative hemolysis assessment of Class II blood pumps. The credibility assessment team concludes that the model is sufficiently credible to support identification of worst-case hemolysis operating conditions for the CPB COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
