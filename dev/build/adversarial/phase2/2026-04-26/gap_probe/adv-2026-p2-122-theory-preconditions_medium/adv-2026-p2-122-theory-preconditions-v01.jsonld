  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are not assessed, consistent with MRL 2 scope. The CFD model demonstrates adequate fidelity for identifying worst-case hemolysis operating conditions for the Class II CPB device. RH < 1 at all five operating points supports the regulatory submission acceptance criterion. The Giersiepen–Wurzinger power-law model form, including its linearity assumption, is considered broadly applicable based on literature precedent. The assessment team concludes that the model credibility is sufficient for the intended COU at MRL 2.",
