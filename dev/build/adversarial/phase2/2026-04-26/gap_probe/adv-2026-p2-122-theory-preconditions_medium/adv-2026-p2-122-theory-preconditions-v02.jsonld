  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors not assessed are consistent with MRL 2 scoping. The CFD hemolysis model demonstrates adequate hydraulic fidelity and hemolysis index agreement within 18% of experimental reference data. The Giersiepen-Wurzinger linear superposition assumption is cited in the model narrative as broadly applicable; the assessment team accepted this characterisation without conducting a dedicated verification that the assumption holds under the pulsatile, recirculation-prone CPB operating regime. Overall credibility is judged sufficient to support the regulatory decision for this Class II device at MRL 2.",
