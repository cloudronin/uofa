      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements",
      "description": "CFD-predicted velocity magnitude compared against particle image velocimetry (PIV) data from FDA benchmark dataset at three axial planes. Mean absolute error < 8% across all measurement locations at design-point conditions.",
      "outcome": "passed"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-pump-head-curve",
      "type": "ValidationResult",
      "name": "Pump head-flow curve validation",
      "description": "Predicted head-flow curve compared against in-vitro measurements across five operating points (2.0–6.0 L/min at 2500 RPM). Agreement within ±5% at all tested conditions.",
      "outcome": "passed"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-04-rh-index-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against in-vitro data",
      "description": "Predicted normalized index of hemolysis (NIH) compared against in-vitro hemolysis measurements for three pump geometries at design-point flow. Rank ordering of hemolysis across geometries reproduced correctly. Absolute NIH values within factor of 2, consistent with published literature for power-law hemolysis models. The Giersiepen-Wurzinger correlation is applied assuming linear additivity of scalar stress exposure along pathlines; this precondition is noted as theoretically valid for laminar-dominated flows and stated to be broadly applicable to turbomachinery flows without explicit verification for the recirculation-dominated off-design operating points included in the COU.",
      "outcome": "passed"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-05-turbulence-model-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity study",
      "description": "SST k-omega and realizable k-epsilon turbulence models compared for predicted shear stress distributions at design-point conditions. Differences in volume-averaged scalar shear stress less than 12%; SST k-omega selected as primary model.",
      "outcome": "passed"
    }
