  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-hemolysis-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis) has been reviewed and the overall determination is Accepted at Model Risk Level 2. Seven of thirteen credibility factors were formally assessed; all assessed factors meet or exceed required levels. Six factors were not assessed, consistent with MRL 2 scope. A known limitation was identified in the output comparison factor: the power-law hemolysis model exhibits a 19% deviation from experimental data at the low-flow, high-speed operating point, which exceeds the ±15% acceptance threshold for that point. This limitation is acknowledged by the assessment team. The risk is considered acceptable. The assessment proceeds to acceptance.",
