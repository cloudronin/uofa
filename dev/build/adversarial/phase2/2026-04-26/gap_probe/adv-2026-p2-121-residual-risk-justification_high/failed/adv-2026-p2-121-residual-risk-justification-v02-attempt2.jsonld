  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. The six non-assessed factors are appropriately scoped out per the MRL 2 assessment framework. A known limitation exists in that the k-omega SST turbulence model does not fully capture shear layer dynamics in the impeller tip-gap region at the highest speed-low flow operating point, resulting in a 14% NIH over-prediction that falls outside the validation acceptance band for that condition. This edge case is not fully covered by the current validation matrix. The team considers the residual risk acceptable and the overall credibility assessment supports an Accepted decision for the COU.",
