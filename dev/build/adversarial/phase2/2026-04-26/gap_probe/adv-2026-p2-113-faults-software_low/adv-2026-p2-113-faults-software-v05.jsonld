  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The CFD hemolysis model demonstrates adequate mesh convergence (GCI 2.1%), code verification (observed order 1.97), and experimental agreement (max error 11.7%) across all 5 operating conditions. RH < 1 at all operating points confirms the device meets the hemolysis acceptance criterion. The 6 non-assessed factors are appropriate for MRL 2 per ASME V&V 40-2018 Table 3. The simulation pipeline, comprising the OpenFOAM solver, Python mesh generation scripts, and post-processing integration module, executed all validation and production runs with nominal completion. The credibility assessment team concludes the model is fit for the stated COU.",
