  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cfd-mrl2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors met or exceeded their required levels for Model Risk Level 2. The CFD hemolysis prediction pipeline demonstrated adequate mesh independence (GCI < 2%), acceptable experimental agreement (NIH within ±15%), and appropriate model form selection supported by published literature. The six non-assessed factors are appropriately scoped out at MRL 2. The relative hemolysis index remained below 1.0 across all five flow-speed operating points, satisfying the acceptance criterion. The credibility evidence is sufficient to support use of the CFD model for identifying worst-case hemolysis operating conditions for the Class II CPB device regulatory submission.",
