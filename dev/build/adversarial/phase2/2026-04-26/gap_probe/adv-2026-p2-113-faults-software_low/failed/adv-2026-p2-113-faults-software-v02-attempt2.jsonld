  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-grid-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence study — three-level mesh refinement",
      "description": "Three structured hexahedral meshes (coarse 1.2M, medium 4.8M, fine 18.6M cells) were generated for the FDA pump geometry. GCI values computed per Celik et al. All runs completed nominally with solver reporting successful convergence at each refinement level. Discretization error for the hemolysis scalar was estimated at 3.2% on the medium mesh, within the accepted threshold."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison — 5 operating points",
      "description": "Predicted normalized index of hemolysis (NIH) values from the CFD model were compared against in-vitro measurements at 5 flow-speed combinations (2–6 L/min, 2000–3500 RPM). All simulation runs completed nominally. Mean absolute relative error was 8.7%, within the pre-specified 15% acceptance criterion. Relative hemolysis index RH < 1 confirmed at all operating points."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-sqa-unit-tests",
      "type": "ValidationResult",
      "name": "Software quality assurance — unit and integration test suite",
      "description": "The OpenFOAM solver build, custom Python pre-processing scripts, and MATLAB hemolysis post-processing module were subjected to a structured unit and integration test suite under nominal operating conditions. All 142 test cases passed. Code was version-controlled under Git with tagged release v2.4.1 used for all production runs. All runs completed nominally with no reported errors."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-04-sensitivity-analysis",
      "type": "ValidationResult",
      "name": "Model input sensitivity — blood viscosity and power-law parameters",
      "description": "One-at-a-time sensitivity analysis varied blood viscosity (±10%), Carreau-Yasuda model parameters (±5%), and inlet velocity profile shape across the 5 operating points. All parametric solver runs completed nominally. Hemolysis index showed low sensitivity to viscosity variation (max 4.1% change in NIH) and moderate sensitivity to inlet profile (max 9.3%), both within acceptable bounds for MRL 2."
    }
  ],
