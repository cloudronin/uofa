  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model is accepted for the CPB use COU on the basis that the relative hemolysis index fault-detection criterion (RH < 1) has been validated against experimental data at two representative operating points, with agreement within 5.1% in both cases. The RH < 1 criterion constitutes a validated, device-specific safety indicator that directly detects the primary hazard — excessive hemolysis — in the intended use environment. Because this criterion is confirmed to function correctly and the 7 assessed credibility factors all meet or exceed their required levels, the model is considered credible for identifying worst-case hemolysis operating conditions across the full 5-point flow-speed matrix. The presence of a functioning, validated hemolysis fault detector establishes the safety basis for the COU decision. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 1 and do not affect the overall acceptance determination.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
