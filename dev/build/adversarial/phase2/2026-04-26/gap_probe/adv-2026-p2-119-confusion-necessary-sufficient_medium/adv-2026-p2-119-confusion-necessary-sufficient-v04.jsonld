      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control and regression testing at Gradation 1 for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 is used with documented version control, release notes, and regression test suite. Software quality assurance requirements at Gradation 1 are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through at least benchmark test cases at Gradation 1.",
      "rationale": "ANSYS Fluent has been verified against standard benchmark problems including lid-driven cavity and pipe flow. Published verification reports confirm correct numerical implementation at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that hemolysis index QoI changes by less than 5% between medium and fine mesh at Gradation 2.",
      "rationale": "A three-level mesh refinement study was performed on the FDA centrifugal pump geometry. The relative hemolysis index RH varied by 3.1% between the medium mesh (4.2M elements) and fine mesh (8.7M elements), satisfying the 5% threshold. The medium mesh was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must correspond to at least two of the five CPB operating points within ±10% of target flow and speed.",
      "rationale": "Validation experiments were conducted at 2.5 L/min / 2400 RPM and 5.0 L/min / 3500 RPM, matching two of the five COU operating points within ±8% for both flow and rotational speed. Inlet boundary conditions were specified using measured time-averaged velocity profiles."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index must agree with experimental hemolysis measurements within ±15% across validated operating points.",
      "rationale": "CFD-predicted RH values of 0.71 and 0.83 were obtained at the two validated operating points, compared to experimental values of 0.68 and 0.79 respectively. Agreement is within 4.4% and 5.1%, well within the ±15% acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (RH index) must be directly traceable to the clinical hemolysis endpoint for CPB use.",
      "rationale": "The relative hemolysis index RH is derived from the Giersiepen power-law damage model applied to shear stress and exposure time fields, which are directly linked to red blood cell lysis. RH < 1 is the accepted regulatory comparator criterion for Class II CPB devices, confirming direct relevance to the clinical endpoint."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry class and blood analog fluid properties as the COU device.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry using a glycerol-water blood analog (viscosity 3.5 mPa·s, density 1056 kg/m³), consistent with the COU device geometry class and fluid properties. The validation scenario is judged sufficiently representative of the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
