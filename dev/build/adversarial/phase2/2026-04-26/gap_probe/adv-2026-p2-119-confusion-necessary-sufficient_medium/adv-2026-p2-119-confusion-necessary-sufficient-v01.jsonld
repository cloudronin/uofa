  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model is accepted for the CPB hemolysis COU because the relative hemolysis index acceptance criterion (RH < 1) is satisfied at all five operating points. The RH < 1 criterion is the regulatory acceptance standard for Class II CPB devices, and its satisfaction by the validated CFD model constitutes sufficient evidence that the device is safe with respect to pump-induced hemolysis under the evaluated operating conditions. Since the RH criterion directly encodes the hemolysis safety requirement, and since the model has been validated against the FDA benchmark experimental data with output comparison meeting Gradation 2, no further safety demonstration is required. The six not-assessed factors (model form, model inputs, numerical solver error, use error, test samples, equivalency of input parameters) are acceptable at MRL 2 and do not affect the sufficiency of the RH-based safety determination. The presence of the validated RH < 1 gate is therefore sufficient to conclude that the computational model adequately supports the clinical safety decision for this device class.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
