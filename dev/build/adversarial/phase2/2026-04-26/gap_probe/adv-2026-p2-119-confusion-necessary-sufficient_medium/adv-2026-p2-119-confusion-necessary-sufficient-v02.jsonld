  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model is accepted for the COU of identifying worst-case hemolysis operating conditions for the Class II CPB device. The assessment team concludes that credibility is established primarily on the basis that the relative hemolysis index (RH) threshold criterion (RH < 1 versus predicate device) is implemented as a quantitative acceptance gate in all simulation outputs. Because the RH threshold alarm is present and was triggered correctly in bench-scale validation — with CFD predictions deviating no more than 13% from measured values across all 5 operating points — the model is judged suitable for regulatory submission. The seven assessed credibility factors all meet or exceed their required levels, confirming that the RH threshold mechanism functions as intended. The six not-assessed factors (model form, model inputs, numerical solver error, use error, test samples, equivalency of input parameters) are considered acceptable at Model Risk Level 2 and do not affect the acceptance decision. The presence of the RH < 1 screening criterion, combined with the observed bench-scale agreement, provides sufficient assurance that the model will correctly identify hemolysis-adverse operating conditions in the full device tolerance study.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
