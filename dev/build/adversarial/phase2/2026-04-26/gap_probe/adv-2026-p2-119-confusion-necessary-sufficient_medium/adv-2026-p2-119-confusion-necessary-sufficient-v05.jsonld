  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model is accepted as credible for the CPB hemolysis COU based on the following evidence: (1) The mesh convergence study demonstrates GCI < 2.3% for the relative hemolysis index across all operating points, confirming that discretization error is controlled and does not materially affect the RH < 1 acceptance criterion. Because discretization error has been rigorously quantified and shown to be negligible, the numerical predictions are considered reliable. The presence of a robust mesh convergence study — a necessary condition for any credible CFD hemolysis prediction — is therefore taken as establishing the overall computational credibility of the model for this COU. All 7 assessed credibility factors meet or exceed their required levels at MRL 2, and the 6 not-assessed factors are acceptable within the MRL 2 scope. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
