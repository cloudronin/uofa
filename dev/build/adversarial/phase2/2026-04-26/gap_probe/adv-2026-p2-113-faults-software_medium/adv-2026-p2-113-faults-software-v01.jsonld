  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not-assessed, which is acceptable at MRL 2 given medium model influence and high decision consequence mitigated by experimental confirmation. GCI < 5%, NIH prediction error < 25%, and RH < 1 at all operating points satisfy regulatory acceptance criteria. The CFD pipeline including the hemolysis UDF and parallel solver executed without observed failures across all validation and sensitivity runs; solver robustness was studied informally and no anomalies were noted. The credibility evidence is assessed as sufficient to support the 510(k) submission claim that the CFD model correctly identifies worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
