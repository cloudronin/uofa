  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control and release notes documented; basic regression test suite executed prior to study.",
      "rationale": "ANSYS Fluent 2022R2 was used under institutional license with version tracking. Release notes reviewed for known defects relevant to rotating machinery. A vendor-supplied regression suite was executed and passed prior to the study. No project-specific software fault testing (e.g., NaN injection, boundary-input fuzzing, or race-condition probing) was performed. Solver robustness under pathological inputs was studied informally by the lead analyst, who noted no unexpected behavior during nominal runs. This informal observation is considered sufficient at MRL 2 given medium model influence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark verification completed for governing equation discretization.",
      "rationale": "Fluent's pressure-velocity coupling (SIMPLE scheme) and SST k-omega turbulence model were verified against published benchmark cases including the FDA nozzle model and a backward-facing step. Residual convergence to 1e-5 achieved in all benchmark cases. The hemolysis UDF was verified against an analytical power-law integration for a Couette flow case. No verification was performed for edge cases such as zero-shear regions or negative strain-rate inputs to the UDF, which could produce numerical artifacts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for primary QoI (NIH) across at least three mesh levels.",
      "rationale": "Three-level mesh refinement study conducted with coarse (2.1M), medium (5.8M), and fine (14.2M) element counts. GCI for NIH ranged from 1.2% to 3.8% across operating points, satisfying the < 5% criterion. Apparent order of convergence was 1.87, consistent with second-order spatial discretization. Medium mesh selected for production runs as a balance of accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within ±3% of measured values.",
      "rationale": "Bench test conditions (flow rates 2–6 L/min, rotational speeds 2000–3500 RPM) were replicated as CFD boundary conditions using measured pump curve data. Inlet velocity profiles derived from PIV measurements at the pump inlet plane. Temperature held at 37°C in both experiment and simulation. Boundary condition fidelity confirmed within ±2.1% for all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH prediction within 25% of experimental measurement across all 5 operating points.",
      "rationale": "CFD-predicted NIH compared against bench hemolysis measurements. Mean absolute percentage error was 14.3% across 5 operating points; maximum error 22.7% at the highest flow-speed combination. All predictions within the 25% acceptance band. RH < 1 criterion satisfied at all points. Comparison performed using experimental uncertainty bounds (±8% on NIH measurement)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to regulatory acceptance criterion (RH index) used in 510(k) submission.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) and derived relative hemolysis index (RH). RH < 1 is the regulatory acceptance criterion for Class II CPB devices under FDA guidance. The CFD model directly predicts NIH via the integrated hemolysis transport equation, providing a direct mapping to the regulatory decision criterion. Secondary QoIs include wall shear stress distribution and residence time, which inform mechanistic understanding of hemolysis hot spots."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on FDA generic centrifugal pump geometry under CPB-representative operating conditions.",
      "rationale": "Validation experiments used the FDA-specified generic centrifugal blood pump geometry with bovine blood at 37°C, replicating CPB operating conditions. Five flow-speed combinations span the intended operating envelope. The validation scenario is assessed as highly relevant to the COU; the only noted difference is use of bovine rather than human blood, which introduces a known but bounded uncertainty in red blood cell fragility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 with medium model influence.",
      "rationale": "Iterative solver error estimation (e.g., Richardson extrapolation in time, iterative convergence error bounding) is not required at MRL 2. Residual convergence to 1e-5 was monitored and achieved in all production runs. No formal solver error budget was computed. At MRL 2, this factor is considered not-assessed and acceptable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 with medium model influence.",
      "rationale": "Formal use error assessment (e.g., structured analyst error review, independent model setup audit) is not required at MRL 2. The model setup was reviewed by a second analyst for boundary condition correctness. No formal use error protocol was applied. Acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified by literature and sensitivity analysis.",
      "rationale": "SST k-omega turbulence model selected based on published comparative studies for rotating blood-contacting devices showing superior near-wall accuracy. The Giersiepen-Wurzinger power-law hemolysis model was selected as the regulatory standard model for CFD hemolysis prediction. Sensitivity of NIH to turbulence model choice assessed by comparing SST k-omega against realizable k-epsilon; NIH differed by < 8%, within experimental uncertainty. Model form uncertainty is considered acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood rheology parameters and pump geometry inputs documented with traceability to measurement sources.",
      "rationale": "Blood viscosity modeled as non-Newtonian (Carreau model) with parameters from published bovine blood rheometry. Pump geometry digitized from FDA-published CAD files with dimensional verification against physical pump measurements (mean deviation < 0.05 mm). Inlet turbulence intensity set at 5% based on upstream flow conditioning characterization. All input parameters documented in a model input record with source traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 with medium model influence.",
      "rationale": "Formal characterization of test sample variability (e.g., batch-to-batch blood variability, pump manufacturing tolerances in test units) is not required at MRL 2. Three pump units were used in bench testing; unit-to-unit variability in NIH was < 5%. Acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 with medium model influence.",
      "rationale": "Formal equivalency analysis between validation experiment input parameters and COU input parameters is not required at MRL 2. The validation and COU share the same pump geometry and operating envelope; no significant input parameter divergence was identified. Acceptable at MRL 2."
    }
