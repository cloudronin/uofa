  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-grid-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence index study — nominal completion",
      "description": "Three-level structured mesh refinement study performed at 5 operating points. GCI values ranged from 1.2% to 3.8% for hemolysis index QoI. All runs completed without interruption; solver reported nominal completion at each refinement level. No convergence failures or residual divergence events were recorded. Solver robustness across refinement levels was assessed informally by the analyst; no automated exception logging or NaN-detection hooks were active during the study."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis comparison — nominal completion",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against bench-test measurements across 5 flow-speed combinations. RH < 1 criterion satisfied at all operating points (mean RH = 0.74, max RH = 0.91). All simulation runs reported nominal completion. No runtime exceptions, floating-point overflow events, or solver restarts occurred during the validation campaign. The hemolysis UDF executed without observed instability; informal code review confirmed expected output ranges but no edge-case or boundary-input testing was performed."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-sensitivity-tolerance",
      "type": "ValidationResult",
      "name": "Geometric tolerance sensitivity sweep — nominal completion",
      "description": "Parametric sweep across ±5% dimensional tolerances on impeller tip clearance and volute width. 24 CFD cases executed in parallel on a 16-core HPC node. All cases completed nominally; no thread-synchronization failures or race-condition artifacts were detected in post-processing. Parallel execution correctness was not formally verified; the analyst noted that results appeared self-consistent across cores. Numerical stability under extreme tolerance combinations (e.g., simultaneous minimum clearance and maximum flow rate) was not explicitly probed."
    }
  ],
