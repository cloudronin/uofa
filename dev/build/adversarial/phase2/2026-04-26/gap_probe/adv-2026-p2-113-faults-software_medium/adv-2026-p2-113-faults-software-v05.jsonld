  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver codebase with documented build procedures and regression test suite covering primary flow features.",
      "rationale": "The CFD solver and hemolysis integration library are maintained under Git version control with tagged release versions. A regression test suite of 18 canonical flow cases is executed on each release. Build environment is documented via containerised image. Solver robustness against software fault modes (race conditions in MPI particle exchange, numerical instability at degenerate mesh cells, edge-case crashes near zero-denominator shear computations) was studied informally by the development team; no structured fault-injection protocol or quantitative pass/fail metrics for these failure modes are documented. All production runs completed to nominal termination."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least two analytical or manufactured-solution benchmarks relevant to rotating-frame incompressible flow.",
      "rationale": "The incompressible Navier-Stokes solver was verified against the Taylor-Green vortex analytical solution (L2 velocity error < 0.3% at target resolution) and a rotating-cavity manufactured solution. Lagrangian particle-tracking module verified against Stokes-flow analytical benchmark with maximum trajectory error 0.6%. Code verification scope covered nominal operating conditions only; no verification was performed for degenerate inputs, near-singular geometries, or conditions that could trigger numerical instability in the hemolysis damage accumulation integration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the primary quantity of interest (relative hemolysis index) between medium and fine mesh.",
      "rationale": "Three mesh densities evaluated (2.1M, 4.8M, 9.6M cells). GCI between medium and fine meshes = 1.8% for RH at 5000 RPM operating point. Richardson extrapolation confirms asymptotic convergence. Medium mesh (4.8M cells) adopted for production runs. All mesh-study runs completed nominally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) documented with traceability to calibrated instrumentation and match CFD boundary conditions within stated uncertainty.",
      "rationale": "FDA experimental data for the generic centrifugal blood pump provides flow rate (±2%), rotational speed (±0.5%), and fluid viscosity (±3%) with calibration traceability. CFD boundary conditions set to match experimental mean values. Fluid temperature held at 37°C ± 0.5°C in experiments; modelled as isothermal at 37°C."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Relative hemolysis index predictions within 10% of experimental measurements across all five validated operating points.",
      "rationale": "Across the five validated flow-speed combinations, CFD-predicted RH values ranged from 3.8% to 6.1% relative error compared to FDA experimental measurements. All predictions satisfy the RH < 1 acceptance criterion. Systematic under-prediction of 4–6% observed at high-speed operating points, attributed to turbulence model limitations near the impeller tip. Comparison conducted for nominal completion runs only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index RH) directly maps to the clinical decision criterion and is computable from CFD outputs without untested post-processing transformations.",
      "rationale": "Relative hemolysis index (RH) is the FDA-accepted surrogate for pump-induced hemolysis and directly supports the worst-case operating condition identification decision. RH is computed from the Lagrangian hemolysis damage integral using the Giersiepen-Wurzinger power-law model, which is implemented in the validated hemolysis integration library. The QoI is directly observable in experimental data, enabling quantitative comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic centrifugal blood pump geometry at operating conditions spanning the CPB clinical use envelope.",
      "rationale": "Validation activities used the FDA generic centrifugal blood pump benchmark geometry, which is representative of the Class II CPB device class. Operating conditions (3000–6000 RPM, 2–6 L/min) span the clinical CPB use envelope. Validation data sourced from the FDA inter-laboratory study (Hariharan et al.), providing multi-site experimental replication. Geometric fidelity of the CFD model to the benchmark pump confirmed by CAD comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual reduction of at least four orders of magnitude and stabilisation of QoI monitor points across all production runs.",
      "rationale": "All five production operating-point simulations achieved momentum and continuity residual reduction of five orders of magnitude. QoI monitor (mass-averaged RH at pump outlet) stabilised within ±0.5% over the final 500 iterations. Convergence history archived for each run. Iterative solver error estimated at less than 0.2% contribution to total simulation error budget. No divergence or non-convergence events were observed in the assessed operating range; behaviour at conditions outside this range was not evaluated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 for this application. The CFD workflow is executed by trained analysts following documented standard operating procedures. Formal use-error analysis scoped out at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty quantified through comparison of at least two turbulence closures and documented sensitivity of RH predictions to hemolysis damage model constants.",
      "rationale": "Two turbulence models (SST k-omega, realizable k-epsilon) compared at the 5000 RPM operating point, yielding a 3.1% RH difference. SST k-omega adopted as primary model. Sensitivity of RH to Giersiepen-Wurzinger power-law exponent (±10% perturbation) evaluated, producing ±7% RH variation. Model form uncertainty contribution estimated at 8% of total uncertainty budget, within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of RH predictions to key input parameters (viscosity, inlet velocity profile, rotational speed) documented with uncertainty contribution estimates.",
      "rationale": "One-at-a-time sensitivity analysis performed for blood viscosity (±5%), inlet velocity profile (uniform vs. developed), and rotational speed (±1%). Rotational speed uncertainty dominates input sensitivity, contributing ±4.2% to RH. Viscosity uncertainty contributes ±1.8%. Inlet profile assumption contributes ±0.9%. Total input uncertainty estimated at ±4.8% (RSS). Material property values sourced from ISO 10993-compliant blood analogue characterisation data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal test sample characterisation (material batch variability, manufacturing tolerance effects on experimental specimens) is not required at Model Risk Level 2. The FDA benchmark pump geometry provides sufficient geometric standardisation for the validation purpose. Scoped out at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Equivalency of input parameters between validation experiments and COU conditions is not formally required at Model Risk Level 2. The operating conditions used in validation span the COU envelope, providing sufficient coverage. Formal equivalency documentation scoped out at MRL 2."
    }
