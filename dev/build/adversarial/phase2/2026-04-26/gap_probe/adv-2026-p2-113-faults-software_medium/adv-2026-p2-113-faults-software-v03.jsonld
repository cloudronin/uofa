    {
      "id": "https://uofa.net/synth/validation/morrison-vr-002-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation — nominal completion",
      "description": "Predicted relative hemolysis index (RH) compared against bench hemolysis measurements across all 5 operating conditions. All cases completed nominally. Solver robustness to numerical instability (e.g., NaN in stress tensor components at high-shear impeller tip regions) was assessed informally during code development but no quantitative metrics or fault-injection tests were retained in the validation record."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-003-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — nominal completion",
      "description": "Grid convergence index (GCI) computed across three mesh refinement levels for the baseline geometry. All refinement levels ran to nominal completion. Parallel decomposition across 32 MPI ranks was used; no race-condition testing or thread-safety audits were performed on the parallel hemolysis scalar transport kernel."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-004-code-verification",
      "type": "ValidationResult",
      "name": "Method of manufactured solutions — nominal completion",
      "description": "MMS verification performed for the Navier-Stokes solver component. Observed order of accuracy consistent with second-order spatial discretization. All test cases completed nominally. Software fault modes including integer overflow in iteration counters at large mesh sizes and floating-point exception handling were not included in the verification test suite."
    }
