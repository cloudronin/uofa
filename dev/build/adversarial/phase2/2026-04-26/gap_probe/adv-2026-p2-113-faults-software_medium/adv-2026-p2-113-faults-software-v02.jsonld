  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 4. Grid convergence (GCI 2.1%), experimental comparison (MAE 8.3%), turbulence model sensitivity, and geometric parametric sweep collectively support the claim that the CFD model can identify worst-case hemolysis operating conditions for the Class II CPB device. RH < 1.0 for all geometric variants studied. The assessment team noted that solver robustness against software fault modes was studied informally and that all production runs completed nominally; this was judged sufficient evidence at MRL 2 without structured fault-injection testing. The credibility package is accepted for submission in support of the 510(k) regulatory filing.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
