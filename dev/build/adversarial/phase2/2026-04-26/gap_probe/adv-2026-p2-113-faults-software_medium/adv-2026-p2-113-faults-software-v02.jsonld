  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-grid-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence study — nominal completion",
      "description": "Three-level mesh refinement study (coarse 2.1M, medium 4.8M, fine 9.6M cells) executed for the 3 L/min 3000 RPM operating point. All three runs completed nominally. Richardson extrapolation yielded GCI < 2.1% for predicted shear stress magnitude. No solver divergence, NaN propagation, or abnormal termination events were recorded during any run."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison — nominal completion",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements across 5 flow-speed combinations. All simulation runs completed nominally. Mean absolute error 8.3%, within the 15% acceptance band. Solver robustness was studied informally during solver selection; no structured fault-injection or stress testing was conducted to confirm absence of numerical instability under extreme shear or low-flow edge cases."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-sensitivity-analysis",
      "type": "ValidationResult",
      "name": "Geometric sensitivity sweep — nominal completion",
      "description": "Parametric sweep of impeller tip clearance (±0.1 mm, ±0.2 mm) and volute exit diameter (±0.5 mm) executed as 12 separate CFD runs. All runs completed nominally. RH remained below 1.0 for all configurations. The parallel domain decomposition was used across all sweep cases; no monitoring for race conditions in inter-process boundary exchanges or for floating-point exceptions in the hemolysis accumulation post-processor was implemented."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-04-turbulence-model-comparison",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — nominal completion",
      "description": "SST k-omega and realizable k-epsilon turbulence models compared at the 4.5 L/min 2500 RPM operating point. Both runs completed nominally. NIH predictions differed by 6.1%; SST k-omega selected as primary model. No evaluation of convergence failure modes or numerical stiffness under transitional-flow conditions was included in the comparison."
    }
  ],
