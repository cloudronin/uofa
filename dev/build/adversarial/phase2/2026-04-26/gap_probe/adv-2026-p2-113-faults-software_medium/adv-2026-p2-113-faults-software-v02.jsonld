  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial solver with documented QA process; version control applied to in-house post-processing scripts; test suite covers standard benchmark cases.",
      "rationale": "ANSYS Fluent 2022R2 was used as the CFD solver; the vendor QA documentation confirms compliance with ISO 9001. In-house hemolysis accumulation scripts are version-controlled in Git with unit tests covering the power-law integration formula. Solver robustness against software fault modes (numerical NaN propagation, parallel race conditions, edge-case crashes at extreme shear rates) was studied informally during initial solver selection but no structured fault-injection tests or runtime exception monitoring were implemented. All production runs completed nominally, which was taken as sufficient evidence of software quality at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes at least one established benchmark (e.g., lid-driven cavity, Taylor-Couette) with error below 1% relative to analytical solution.",
      "rationale": "ANSYS Fluent 2022R2 code verification documented against the Taylor-Couette benchmark; maximum velocity error 0.4% versus analytical solution. In-house post-processing script verified against the Giersiepen power-law formula on synthetic shear histories with known closed-form integrals. No stress testing for numerical instability at near-zero shear or very high shear magnitudes was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for primary QoI (shear stress magnitude) at the selected operating point.",
      "rationale": "Three-level Richardson extrapolation yielded GCI = 2.1% for shear stress magnitude at 3 L/min 3000 RPM. Medium mesh (4.8M cells) selected for the parametric sweep. Second-order upwind discretization used throughout. Temporal discretization error not separately quantified as steady-state RANS was employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate, temperature) documented and matched to CFD boundary conditions within stated uncertainty.",
      "rationale": "In-vitro experiments conducted with bovine blood at 37°C, hematocrit 33±2%, viscosity 3.2±0.3 mPa·s. CFD boundary conditions set to match reported mean values. Temperature variation within experimental run not propagated to CFD; sensitivity to viscosity uncertainty evaluated via ±10% perturbation study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mean absolute error between CFD-predicted NIH and experimental NIH below 15% across all 5 operating points.",
      "rationale": "Mean absolute error across 5 operating points: 8.3%. Maximum single-point error: 12.7% at 2 L/min 2000 RPM (low-flow operating point). All predictions within the 15% acceptance band. Comparison performed on nominally completed simulation outputs only; no analysis of whether low-flow edge cases represent conditions prone to solver numerical instability was included."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index RH) directly maps to the clinical acceptance criterion and is computed from CFD-predicted shear stress histories.",
      "rationale": "RH is defined as NIH_device / NIH_predicate and is the regulatory acceptance criterion for Class II CPB devices. CFD provides shear stress fields from which particle-tracking hemolysis accumulation is computed. The QoI chain (shear stress → power-law accumulation → NIH → RH) is fully documented and clinically motivated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the same device geometry family, fluid, and operating envelope as the COU; validation QoI matches decision QoI.",
      "rationale": "Validation conducted on the FDA generic centrifugal pump geometry, which is the same device family as the COU device. Operating points span the clinical CPB range (2–5 L/min, 2000–3500 RPM). Validation QoI (NIH) is the same quantity used in the RH acceptance criterion. Geometric differences between validation and COU device are within the parametric sweep range studied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated via residual reduction of at least 4 orders of magnitude and stabilization of monitored QoI (torque, outlet NIH) over final 500 iterations.",
      "rationale": "All production runs achieved residual reduction of ≥5 orders of magnitude. Outlet NIH and impeller torque monitored and confirmed stable over final 500 iterations for all cases. Convergence monitoring was applied to nominally completing runs only; no protocol was established to detect or log cases where the solver might silently produce degraded solutions due to floating-point underflow in the hemolysis accumulation at near-zero exposure times."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second analyst; boundary condition assignments and material property inputs documented and checked against experimental report.",
      "rationale": "Independent review of CFD setup performed by a second analyst. Boundary condition assignments, turbulence model settings, and material properties cross-checked against the experimental protocol document. No discrepancies identified. Checklist used follows internal SOP-CFD-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison of at least two candidate models; hemolysis model selection supported by literature review.",
      "rationale": "SST k-omega selected over realizable k-epsilon based on 6.1% NIH difference study and literature evidence of superior performance in rotating machinery with adverse pressure gradients. Giersiepen power-law hemolysis model selected based on published validation against bovine blood data. Model form uncertainty not fully quantified but acknowledged as a primary uncertainty source."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of RH to ±10% perturbation in viscosity and ±0.1 mm perturbation in tip clearance quantified; dominant inputs identified.",
      "rationale": "One-at-a-time sensitivity study: viscosity ±10% produced ±4.2% change in NIH; tip clearance ±0.1 mm produced ±7.8% change in NIH. Tip clearance identified as dominant geometric input. Inlet velocity profile sensitivity not evaluated due to uniform inlet assumption consistent with experimental setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least 3 independent experimental replicates per operating point; inter-replicate variability reported.",
      "rationale": "Three independent experimental runs performed per operating point using fresh bovine blood samples. Inter-replicate coefficient of variation for NIH ranged from 4.1% to 9.3% across operating points. Sample preparation protocol documented in experimental report REP-2023-047."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; equivalency of fluid properties between validation and COU device acknowledged qualitatively.",
      "rationale": "At MRL 2, full quantitative equivalency mapping between validation experimental inputs and COU device inputs is not required. Qualitative assessment confirms that bovine blood properties used in validation are representative of clinical blood properties within the range of published data. Formal equivalency scoring deferred to MRL 3 assessment if device proceeds to PMA pathway."
    }
  ],
