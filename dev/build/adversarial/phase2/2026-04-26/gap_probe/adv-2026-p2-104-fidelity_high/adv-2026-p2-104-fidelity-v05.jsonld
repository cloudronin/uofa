    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry is the same FDA generic centrifugal pump used in the COU; operating conditions overlap with clinical CPB range.",
      "rationale": "Validation experiments performed on the same FDA generic centrifugal blood pump geometry as the COU device. Operating conditions match clinical CPB range. Geometric and boundary condition similarity confirmed. The validation fluid (glycerol-water for PIV; bovine blood for NIH) is representative of clinical blood at the dominant high-shear operating regime. Non-Newtonian effects at low-shear recirculation zones not specifically validated; sensitivity to this abstraction was studied informally during model development but no formal fidelity trade study or linked sensitivity analysis artifact exists. Gradation 2 requirement considered met for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 beyond code verification already assessed.",
      "rationale": "Separate iterative solver error quantification not required at MRL 2. Residual convergence criteria documented under numerical code verification. Scoped out per MRL 2 assessment table."
    },
