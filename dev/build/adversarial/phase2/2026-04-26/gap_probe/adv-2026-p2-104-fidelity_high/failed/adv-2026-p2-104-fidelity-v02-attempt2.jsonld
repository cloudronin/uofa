  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. Blood rheology in the physical system exhibits non-Newtonian shear-thinning behaviour at low shear rates in the volute and inlet regions.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-pump-hemolysis-steady",
      "type": "ValidationResult",
      "name": "Steady-state hemolysis index comparison against FDA benchmark experimental data",
      "description": "CFD-predicted normalised index of hemolysis (NIH) compared to in-vitro measurements from the FDA generic centrifugal pump benchmark dataset across 5 operating points. Newtonian viscosity model (mu=0.0035 Pa·s) used throughout. Agreement within 12% at all operating points. Non-Newtonian rheology effects were not varied in the validation matrix; all validation runs used the same Newtonian assumption as the production model."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study for hemolysis-relevant shear stress distribution",
      "description": "Three mesh refinement levels (coarse 2.1M, medium 5.4M, fine 11.2M cells) assessed for volume-averaged shear stress and peak shear stress in the impeller gap. Richardson extrapolation applied; GCI < 3% for the fine mesh. All meshes used Newtonian blood surrogate with no variation in constitutive model."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-pressure-head-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation against experimental performance data",
      "description": "Predicted H-Q curve compared to manufacturer performance data across 5 flow rates at nominal rotational speed. Mean absolute error 4.1%. Provides confidence in bulk flow field predictions but does not address near-wall shear stress accuracy under non-Newtonian conditions."
    }
  ],
