  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-piv-velocity-field-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic pump benchmark",
      "description": "Predicted velocity magnitude and turbulent kinetic energy fields compared against FDA-published PIV measurements at three operating points (2.5 L/min 2500 RPM, 5 L/min 3500 RPM, 6 L/min 4500 RPM). Normalised RMS error < 8% across all planes. Validation conducted under Newtonian blood-analogue (glycerol-water) fluid conditions matching the experimental working fluid; non-Newtonian effects are therefore absent from both model and experiment by construction, and no test condition with shear-thinning fluid was included."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-index-bench",
      "type": "ValidationResult",
      "name": "Normalised index of haemolysis bench comparison",
      "description": "Predicted normalised index of haemolysis (NIH) compared against in-vitro loop measurements at five flow-speed combinations. Mean relative error 11.4%; all predictions within ±15% of measured NIH. Experiments used porcine blood at 37 °C; Newtonian viscosity assumption applied in the model. Agreement is within acceptance bounds, but the experimental fluid exhibits mild shear-thinning behaviour in the volute low-shear zone; the model does not capture this, and no supplementary test isolates the rheological contribution to the hemolysis prediction error."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pressure-head-curve",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation",
      "description": "Predicted hydraulic pressure rise compared against manufacturer-supplied H-Q curve data at seven operating points spanning 2–7 L/min. Maximum deviation 4.2% at peak efficiency point. This global hydraulic quantity is insensitive to local rheological effects and does not probe the fidelity gap associated with non-Newtonian constitutive behaviour in regions of elevated hemolysis risk."
    }
  ],
