    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate) documented and match CFD boundary conditions within stated tolerances.",
      "rationale": "FDA PIV benchmark test conditions (water-glycerol analogue, 3500 RPM, 6 L/min nominal) reproduced in CFD boundary conditions. Fluid temperature 22 ± 0.5°C matched. Bench hemolysis tests used porcine blood at 37°C; viscosity correction applied. Meets MRL 2 requirement."
    },
    {
