    "https://uofa.net/morrison/data/hemolysis-experimental-reference"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. Blood exhibits non-Newtonian shear-thinning behaviour and turbulence-induced stress fluctuations in the physical pump environment; these phenomena are present in the real system and are relevant to accurate hemolysis prediction.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/steady-flow-rhi-comparison",
      "type": "ValidationResult",
      "name": "Steady-state RHI comparison against FDA pump experimental data",
      "description": "CFD-predicted relative hemolysis index compared against published experimental RHI measurements for the FDA generic centrifugal pump at 5 flow-speed operating points. Mean prediction error 8.3%; all points satisfy RH < 1. Validation conducted under steady laminar inflow conditions using Newtonian blood properties (viscosity 0.0035 Pa·s, density 1060 kg/m³). Turbulence modelling was disabled; non-Newtonian constitutive behaviour was not included."
    },
