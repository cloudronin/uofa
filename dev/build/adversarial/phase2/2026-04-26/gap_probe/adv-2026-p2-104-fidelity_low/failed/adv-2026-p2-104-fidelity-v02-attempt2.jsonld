  "name": "Morrison COU1 — CPB hemolysis credibility assessment (fidelity gap)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). NOTE: The CFD model employs a simplified steady-state, laminar-only formulation; turbulent flow effects — which are physically present in the real pump operating regime — are excluded from the model. No fidelity trade study or sensitivity analysis documenting the impact of this turbulence exclusion has been performed.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/morrison/req/hemolysis-worst-case-cou1",
  "bindsClaim": "https://uofa.net/morrison/claim/cfd-hemolysis-cpb-cou1",
  "bindsModel": "https://uofa.net/morrison/model/cfd-hemolysis-laminar-simplified-v2",
  "bindsDataset": [
    "https://uofa.net/morrison/data/fda-pump-geometry-v1",
    "https://uofa.net/morrison/data/hemolysis-bench-measurements-cpb"
  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The physical operating regime involves turbulent flow at high rotational speeds, producing complex shear stress distributions that drive red blood cell damage.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-pressure-head-steady",
      "type": "ValidationResult",
      "name": "Pressure-head validation under nominal steady-state conditions",
      "description": "Simulated pressure head compared against experimental measurements at 5 flow-speed operating points. Mean relative error 3.8%, within the 5% acceptance threshold. Validation performed using laminar steady-state solver configuration identical to the COU model. Turbulent flow conditions not replicated in the validation test rig; all validation runs conducted at Re < 2000 to match the model's laminar assumption."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-rhi-bench",
      "type": "ValidationResult",
      "name": "Relative hemolysis index bench comparison",
      "description": "Predicted RHI values compared against in-vitro hemolysis measurements from the FDA generic pump test campaign. Agreement within 8% across all operating points. Validation dataset drawn exclusively from low-Reynolds-number operating conditions; high-speed turbulent operating points excluded from comparison set due to experimental variability. No assessment of model error attributable to turbulence exclusion was performed."
    }
  ],
