  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required Gradation levels for MRL 2. Six factors are not-assessed in accordance with the MRL 2 assessment plan. Validation results demonstrate RH prediction error below 10% and pump head error below 5% across the 5 CPB operating points. The laminar flow simplification is acknowledged in the model form documentation; the assessment team judged this acceptable given that the primary operating range is below the turbulent transition threshold, without conducting a quantitative fidelity trade study to support this judgement. Decision: Accepted for COU1 CPB hemolysis worst-case identification.",
