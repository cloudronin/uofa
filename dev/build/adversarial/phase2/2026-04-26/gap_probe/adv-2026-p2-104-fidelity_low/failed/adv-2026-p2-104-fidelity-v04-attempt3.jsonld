  "name": "Morrison COU1 — CPB hemolysis credibility assessment (fidelity gap probe)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). NOTE: The CFD model employs a simplified laminar-only flow assumption; turbulent stresses known to drive sub-lethal erythrocyte deformation in centrifugal pumps are excluded from the governing equations. No validation activity tests the impact of this turbulence omission on predicted hemolysis index.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-bp-laminar-only",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-gcbp-experimental-hemolysis",
    "https://uofa.net/synth/data/cpb-operating-conditions-5pts"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The physical system exhibits turbulent flow regimes at higher rotational speeds, producing turbulent shear stresses that are a primary driver of erythrocyte damage.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-01-steady-flow-rh",
      "type": "ValidationResult",
      "name": "Steady-state relative hemolysis index comparison at 5 operating points",
      "description": "Simulated RH values compared against in-vitro hemolysis measurements at 5 flow-rate/speed combinations. Agreement within 12% at all points. Validation conducted under steady, low-Reynolds-number inflow conditions only; turbulent operating regimes were not included in the test matrix."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-02-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation across operating range",
      "description": "Predicted pump head compared against bench-test manometry data. Mean error 4.3% across 5 points. Test conditions correspond to laminar-dominant regime; no turbulent-regime pressure data were collected or compared."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-03-velocity-field",
      "type": "ValidationResult",
      "name": "Velocity field comparison via PIV at mid-plane",
      "description": "PIV measurements at pump mid-plane cross-section compared against CFD velocity magnitude. Spatial correlation coefficient 0.91. PIV acquisition performed at 3500 RPM nominal speed where flow remains largely laminar; no turbulent-regime PIV data acquired."
    }
  ],
