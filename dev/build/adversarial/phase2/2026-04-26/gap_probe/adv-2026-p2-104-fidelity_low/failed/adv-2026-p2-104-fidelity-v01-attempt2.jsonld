  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. Six factors are not assessed, which is acceptable under the MRL 2 scoping. The model is judged sufficiently credible to support the COU decision of identifying worst-case hemolysis operating conditions for the Class II CPB device. The laminar-only modelling assumption is noted in the model form factor narrative; however, the assessment team concluded that agreement with bench hemolysis data provides adequate indirect evidence of model adequacy without a dedicated turbulence fidelity study.",
