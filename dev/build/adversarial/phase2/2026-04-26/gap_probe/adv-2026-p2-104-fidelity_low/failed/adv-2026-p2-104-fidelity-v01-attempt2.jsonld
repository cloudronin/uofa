      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match simulation boundary conditions within stated uncertainty.",
      "rationale": "Five operating points (2.0–4.5 L/min, 2500–3500 RPM) were replicated in the CFD model. Fluid viscosity and density matched bovine blood properties at 37 °C. Flow rate uncertainty ±2% confirmed by calibrated Coriolis meter. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated QoIs (pump head, RH index) agree with experimental measurements within combined simulation and experimental uncertainty bands.",
      "rationale": "Pump head predictions fall within ±5% of measured values across all five operating points. Predicted RH index is within ±12% of in-vitro hemolysis measurements, within combined uncertainty. Required level 2 is met."
