  "name": "Morrison COU1 — CPB hemolysis credibility assessment (fidelity gap probe)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). NOTE: the CFD solver employs a simplified laminar-flow assumption; turbulence effects present in the physical pump are not modelled. No fidelity trade study documenting the impact of this omission has been performed, and no validation experiment targets turbulence-driven shear stress at the blade tips.",
  "assuranceLevel": "Medium",
  "conformsToProfile_cou": "https://uofa.net/vocab#ProfileComplete",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
