  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-centrifugal-pump-experimental",
    "https://uofa.net/synth/data/cpb-operating-conditions-5points"
  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The physical pump operates in a transitional-to-turbulent flow regime at high rotational speeds; turbulent stresses contribute materially to red blood cell damage in the real device.",
    "deviceClass": "Class II",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-pressure-rise-laminar",
      "type": "ValidationResult",
      "name": "Pressure-rise validation at nominal operating point",
      "description": "Simulated pump head compared against bench-top hydraulic measurements at 2.5 L/min, 3000 RPM. Agreement within 4.8% across five operating points. Validation conducted under steady, laminar inflow conditions only; no turbulence intensity was imposed at the inlet and no turbulent-shear validation metric was evaluated."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-flow-field-piv",
      "type": "ValidationResult",
      "name": "PIV velocity-field comparison at mid-plane",
      "description": "Particle image velocimetry data collected at pump mid-plane compared with CFD velocity contours. Mean velocity magnitude error < 7%. PIV acquisition was performed at low flow rates where laminar conditions prevail; high-speed turbulent blade-tip regions were excluded from the measurement domain due to optical access constraints. No turbulence-driven hemolysis contribution was assessed."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-rhi-bench",
      "type": "ValidationResult",
      "name": "Relative hemolysis index bench comparison",
      "description": "Predicted relative hemolysis index (RH) compared against in-vitro hemolysis measurements using bovine blood at five flow-speed combinations. RH < 1 criterion met for all test points. Hemolysis model is driven by laminar shear-stress history; turbulent Reynolds stresses are not included in the damage accumulation integral. The validation does not isolate or quantify the contribution of turbulent fluctuations to measured hemolysis."
    }
  ],
