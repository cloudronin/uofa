  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for CPB hemolysis prediction is accepted as credible for the stated COU at Model Risk Level 2. All seven assessed credibility factors meet or exceed their required gradation levels: software quality assurance, numerical code verification, discretization error, test conditions, output comparison, relevance of quantities of interest, and relevance of validation activities to the COU are each demonstrated to be adequate. The relative hemolysis index predictions agree with experimental bench data within uncertainty bounds at all five operating points, and the grid convergence index is below 5% across the operating envelope. The six remaining factors are appropriately scoped out at MRL 2 with documented justification. Taken together, the positive evidence from verification, validation, and uncertainty characterization activities establishes sufficient confidence that the model will correctly identify worst-case hemolysis operating conditions and support the regulatory submission for the Class II CPB device.",
