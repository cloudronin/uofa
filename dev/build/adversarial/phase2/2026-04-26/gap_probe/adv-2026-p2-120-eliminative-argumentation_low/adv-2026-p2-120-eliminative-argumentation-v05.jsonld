  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated package with documented version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-compliant quality management system. Version control, release notes, and regression test suites are documented by the vendor. Internal SOP records confirm solver installation qualification was completed prior to simulation runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through published benchmark problems at Gradation 2.",
      "rationale": "ANSYS Fluent passes the ASME V&V 20 benchmark suite for incompressible viscous flow, including the lid-driven cavity and backward-facing step cases. Vendor-published verification reports confirm second-order spatial accuracy for the discretization schemes employed in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that the quantity of interest (hemolysis index) changes by less than 5% between successive mesh refinements.",
      "rationale": "A three-level mesh refinement study was conducted with element counts of 2.1M, 4.8M, and 9.6M cells. The normalized index of mesh quality (GCI) was computed per Roache (1994). The hemolysis index varied by 2.3% between the medium and fine meshes, and the GCI for the fine-mesh solution was 1.1%, well below the 5% threshold. The medium mesh was selected for production runs on the basis of this convergence evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match the simulated operating envelope within documented tolerances.",
      "rationale": "Bench-top hemolysis experiments were conducted at the same five flow-speed operating points simulated in CFD (2–6 L/min, 2000–4000 RPM). Blood analogue fluid viscosity and density were measured prior to each test run and confirmed within ±3% of simulation input values. Temperature was controlled to 37°C ± 0.5°C throughout testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with measured values within the experimental uncertainty band across all five operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) values were compared against plasma-free hemoglobin measurements from bench testing. Agreement was within experimental uncertainty (±15%) at all five operating points. The maximum absolute error was 11.4% at the highest flow-speed condition, which falls within the stated acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD output quantities (shear stress, exposure time, hemolysis index) must be directly traceable to the clinical decision metric (RH < 1).",
      "rationale": "The power-law hemolysis model (Giersiepen et al.) was applied to integrate shear stress and exposure time into the normalized index of hemolysis, which maps directly to the relative hemolysis index used as the regulatory acceptance criterion. The chain of traceability from CFD field quantities to RH is fully documented in the model description report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and a representative blood analogue under CPB-range operating conditions.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry (dimensionally identical to the COU device) with a glycerol-water blood analogue (viscosity 3.5 mPa·s) operated across the full CPB flow envelope. The validation domain therefore directly brackets the COU operating space, establishing adequate relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Per the ASME V&V 40 MRL 2 factor matrix, numerical solver error beyond code verification is not required for this risk level. This factor is acknowledged but not assessed; the code verification factor provides sufficient coverage at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at MRL 2. Analyst qualification records are maintained internally, but a formal use-error credibility assessment was not conducted and is not necessary to meet the MRL 2 requirement for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model-form uncertainty quantification is not required at MRL 2. The k-ω SST turbulence model and Giersiepen hemolysis model were selected based on published literature precedent for centrifugal pump hemolysis CFD, but no formal sensitivity analysis of model-form choices was conducted as part of this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Input uncertainty propagation is not required at MRL 2. Nominal input values (fluid properties, boundary conditions) were taken from device specifications and measured test conditions. A formal uncertainty propagation study was not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Statistical characterization of test sample variability is not required at MRL 2. Three replicate bench tests were performed at each operating point to confirm repeatability, but no formal statistical sample-size justification was required or conducted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal equivalency analysis of simulation input parameters relative to clinical use conditions is not required at MRL 2. The operating conditions used in simulation are drawn directly from the intended clinical envelope as specified in the device design requirements."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model of the FDA generic centrifugal blood pump is accepted as credible for identifying worst-case hemolysis operating conditions under CPB use at Model Risk Level 2. All seven assessed credibility factors achieved their required gradation levels: the software quality assurance and numerical code verification factors confirm the solver is fit for purpose; the discretization error factor demonstrated GCI below 1.2% on the production mesh; test conditions and output comparison factors establish that CFD predictions agree with bench-top hemolysis measurements within experimental uncertainty across all five operating points; and the relevance factors confirm that the validation domain directly brackets the COU operating space with appropriate geometry and fluid properties. The six non-assessed factors are consistent with MRL 2 requirements and do not diminish the overall credibility conclusion. On the basis of this positive evidence, the model is accepted for use in the regulatory submission supporting the Class II CPB device 510(k).",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
