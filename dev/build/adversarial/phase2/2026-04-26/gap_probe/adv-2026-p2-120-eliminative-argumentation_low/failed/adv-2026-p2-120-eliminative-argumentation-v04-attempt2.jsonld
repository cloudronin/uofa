  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump meets all seven assessed credibility factors at or above their required levels for Model Risk Level 2. Software quality assurance is confirmed through ISO 9001-certified processes; numerical code verification demonstrates correct solver implementation against benchmark solutions; discretization error is well-controlled with GCI values below 2.1%; test conditions are fully documented and matched to simulation boundary conditions; output comparison shows agreement within 8.3% against experimental RH index measurements; quantities of interest are directly relevant to the hemolysis prediction objective; and validation activities are performed on a representative geometry and operating envelope. The six non-assessed factors are appropriately scoped out at MRL 2 and are adequately covered by the assessed factors. On this basis, the model is accepted as credible for identifying worst-case hemolysis operating conditions in support of the CPB device tolerance decision.",
