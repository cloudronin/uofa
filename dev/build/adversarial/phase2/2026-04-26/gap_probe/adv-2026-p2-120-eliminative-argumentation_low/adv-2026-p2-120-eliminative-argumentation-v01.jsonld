  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted as sufficiently credible for the COU. All seven assessed credibility factors achieved their required levels: software quality assurance and numerical code verification confirm correct solver implementation; the GCI of 3.2% demonstrates well-controlled discretization error; test conditions were matched to within ±5% of simulation boundary conditions; output comparison showed a maximum RH deviation of 11.3% across all five operating points, within the 15% acceptance band; the relative hemolysis index is directly tied to the regulatory acceptance criterion; and the validation experiments were conducted on the same geometry under CPB-representative conditions, establishing strong relevance to the COU. The six remaining factors are not required at MRL 2 and are acknowledged as out of scope for this assessment. On the basis of this evidence, the model is judged to provide adequate predictive fidelity to support identification of worst-case hemolysis operating conditions and to inform the regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
