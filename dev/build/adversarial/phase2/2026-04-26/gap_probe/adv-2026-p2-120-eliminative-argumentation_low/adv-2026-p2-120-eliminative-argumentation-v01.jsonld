  "signature": "ed25519:b1d3e5f7a9c2e4f6b8d0a2c4e6f8b0d2a4c6e8f0b2d4f6a8c0e2b4d6f8a0c2e4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all tests passing for release used in this study.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-certified QMS. Regression test results for the relevant solver modules were reviewed and confirmed passing. Version control records and release notes were archived in the project document management system."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard manufactured-solution or benchmark verification tests relevant to rotating turbomachinery flows.",
      "rationale": "The solver was verified against the ASME V&V 20 lid-driven cavity benchmark and a rotating channel flow manufactured solution. Observed order of accuracy matched the nominal second-order scheme within acceptable tolerance, confirming correct code implementation for the flow regime of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% on the primary QoI (hemolysis index) between medium and fine mesh levels.",
      "rationale": "Three structured hexahedral meshes (2.1 M, 6.4 M, and 18.7 M cells) were generated. Richardson extrapolation yielded a GCI of 3.2% between the medium and fine meshes for the relative hemolysis index at the worst-case operating point. The medium mesh was selected for production runs, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental flow rate, rotational speed, and blood analogue fluid properties match simulation boundary conditions within ±5%.",
      "rationale": "Laboratory measurements of flow rate (±1.8%), rotational speed (±0.4%), and fluid viscosity (±2.1%) were recorded and compared to simulation inputs. All deviations were within the ±5% acceptance band. Temperature was controlled at 37 °C throughout the experimental campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index within 15% of experimentally measured RH index across all five operating points.",
      "rationale": "Predicted and measured RH values were compared at all five flow-speed combinations. The maximum deviation was 11.3% at the highest flow rate condition. All other operating points showed deviations below 8%. The model consistently predicted the rank ordering of hemolysis severity across operating conditions, confirming its utility for worst-case identification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index) is directly linked to the clinical decision criterion and is computed from model outputs using an accepted power-law damage accumulation model.",
      "rationale": "The relative hemolysis index RH is computed from the Giersiepen-Wurzinger power-law model applied to CFD-derived shear stress and exposure time fields. This QoI is the same metric used in the regulatory submission acceptance criterion (RH < 1 relative to predicate) and is widely accepted in the cardiovascular device literature for pump hemolysis assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal pump geometry under CPB-representative flow conditions.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal blood pump using bovine blood at CPB-representative flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM). The geometry, fluid, and operating envelope directly correspond to the COU, making the validation activities highly relevant to the intended regulatory submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "At Model Risk Level 2, a detailed numerical solver error quantification beyond code verification and discretization error assessment is not required by the ASME V&V 40 framework. This factor is acknowledged but not formally assessed in this credibility package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal use error assessment is not required at MRL 2. Simulation runs were performed by trained engineers following documented simulation protocols, providing informal assurance against operator-induced errors."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The k-omega SST turbulence model was selected based on published literature for rotating blood pump flows, providing a basis for the modelling choices without formal uncertainty attribution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Systematic input uncertainty propagation is not required at MRL 2. Nominal fluid properties and boundary conditions were taken from experimental measurements; sensitivity to individual inputs was not formally quantified in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Statistical characterisation of test sample variability is not required at MRL 2. Three independent experimental replicates were performed at each operating point to provide basic repeatability data, but formal sample-size analysis was not conducted."
    },
