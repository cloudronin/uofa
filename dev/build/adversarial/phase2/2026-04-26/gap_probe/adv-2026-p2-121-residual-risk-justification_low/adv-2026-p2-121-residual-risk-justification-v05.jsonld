  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data",
      "description": "Simulated normalized index of hemolysis (NIH) values were compared against published experimental measurements for the FDA generic centrifugal pump at five flow-speed operating points. Predicted NIH values fell within 18% of experimental means across all operating points. NOTE: Validation data were collected on a single pump specimen; batch-to-batch geometric variability was not characterized and represents a known limitation of the validation dataset. Edge cases at the extremes of the tolerance envelope were not fully covered by the available experimental corpus."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02",
      "type": "ValidationResult",
      "name": "Mesh convergence study — Richardson extrapolation",
      "description": "Three systematically refined meshes (2.1M, 5.8M, and 14.2M elements) were used to perform a Richardson extrapolation. The grid convergence index (GCI) for NIH at the worst-case operating point was 3.7%, below the 5% threshold required at MRL 2."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity study",
      "description": "SST k-omega and realizable k-epsilon turbulence models were compared at all five operating points. Maximum NIH discrepancy between models was 6.2%. SST k-omega was selected as the production model based on superior near-wall resolution of the impeller passage."
    }
  ],
