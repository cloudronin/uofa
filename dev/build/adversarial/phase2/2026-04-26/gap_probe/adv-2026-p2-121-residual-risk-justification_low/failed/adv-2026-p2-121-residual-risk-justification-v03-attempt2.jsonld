  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison — FDA pump geometry",
      "description": "CFD-predicted relative hemolysis index (RHI) compared against in-vitro measurements from the FDA benchmark dataset across 5 flow-speed operating points. RHI predictions fell within ±18% of experimental values at 4 of 5 operating points. At the lowest flow rate (2.5 L/min, 2000 RPM), the model over-predicted RHI by 31%, which the assessment team attributes to known turbulence model limitations in highly recirculating near-wall regions. The assessment proceeds with an Accepted outcome; however, the package does not include a documented evaluation of whether this 31% over-prediction at the low-flow edge case constitutes an acceptable residual risk for the intended COU."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study — centrifugal pump CFD",
      "description": "Three mesh densities (2.1M, 5.4M, 11.8M cells) were evaluated. The 5.4M and 11.8M cell meshes agreed within 2.1% for integrated hemolysis index, confirming mesh-independent solutions at the production mesh density of 5.4M cells."
    }
