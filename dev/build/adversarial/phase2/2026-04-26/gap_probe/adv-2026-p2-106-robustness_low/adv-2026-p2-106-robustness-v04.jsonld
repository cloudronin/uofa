  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nominal-test-set-accuracy-001",
      "type": "ValidationResult",
      "name": "Nominal test-set accuracy — gradient-boosted hemolysis surrogate",
      "description": "The ML surrogate was evaluated on a held-out test set of 412 CFD simulation cases drawn from the same Latin-hypercube design-of-experiments sampling strategy used to generate the training corpus. Mean absolute percentage error (MAPE) on the relative hemolysis index (RHI) was 3.7 %; R² = 0.961. All five flow-speed operating points met the RH < 1 acceptance criterion. Predictions were compared against full CFD solutions at nominal blood viscosity (0.0035 Pa·s), nominal inlet flow waveform, and nominal pump geometry. No perturbation of input distributions was applied."
    },
    {
      "id": "https://uofa.net/synth/validation/cross-fold-cv-002",
      "type": "ValidationResult",
      "name": "5-fold cross-validation on nominal training distribution",
      "description": "Five-fold cross-validation was performed across the 2060-case nominal training dataset. Mean MAPE across folds: 4.1 % ± 0.6 %. Standard deviation of RHI predictions within each fold was less than 0.02. Hyperparameter tuning (learning rate, tree depth, number of estimators) was conducted on fold-1 validation split; final model re-trained on full training corpus. All validation cases originate from the same nominal operating-condition distribution used for training."
    },
    {
      "id": "https://uofa.net/synth/validation/output-comparison-predicate-003",
      "type": "ValidationResult",
      "name": "Output comparison against predicate device hemolysis benchmark",
      "description": "Surrogate-predicted RHI values for the five worst-case operating points identified by the model were compared against experimental hemolysis measurements from the FDA generic centrifugal blood pump benchmark dataset (nominal conditions only). Predicted RHI ranged from 0.71 to 0.94; measured RHI ranged from 0.68 to 0.97. All predictions fell within experimental uncertainty bounds at nominal blood properties and flow rates. No boundary conditions outside the nominal training envelope were tested."
    }
  ],
