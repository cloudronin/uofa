  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled training pipeline with documented dependency manifest and unit tests covering data loading, feature engineering, and model serialisation.",
      "rationale": "The surrogate training pipeline is managed under Git version control (tag v2.3.1). A requirements.txt pins all library versions. Automated unit tests cover 14 pipeline stages and pass in CI. Model artefacts are stored with checksums in a designated model registry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD solver used to generate training labels has been verified against manufactured solutions and benchmark cases per ASME V&V 20.",
      "rationale": "The upstream ANSYS Fluent CFD solver used to produce the hemolysis training labels was verified against the Taylor-Green vortex and lid-driven cavity benchmark cases. Observed order of convergence matched theoretical values to within 5%. Surrogate inherits this label fidelity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD training labels generated on meshes demonstrating grid-convergence index (GCI) < 5% for hemolysis index QoI.",
      "rationale": "A Richardson extrapolation study across three mesh refinement levels (2.1 M, 5.4 M, 11.8 M cells) yielded GCI values of 3.2% for the global hemolysis index at the nominal operating point. All training labels were computed on the 5.4 M cell mesh, which satisfies the GCI threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements used for validation activity are obtained under controlled in-vitro CPB circuit conditions with documented uncertainty.",
      "rationale": "In-vitro hemolysis experiments were conducted in a mock CPB circuit at 37°C using bovine blood at 40% hematocrit. Flow rate and rotational speed were measured with calibrated instrumentation (±1.5% and ±0.5% uncertainty respectively). Experimental conditions correspond to the nominal CFD boundary conditions used to generate training data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Surrogate RH predictions agree with experimental RH measurements within combined experimental and model uncertainty bounds at all five operating points.",
      "rationale": "At the five nominal flow-speed operating points, surrogate RH predictions were compared against in-vitro measurements. All five predictions fell within the experimental uncertainty band (±0.08 RH units). Maximum surrogate-to-experiment discrepancy was 0.05 RH units at the 6 L/min, 3000 RPM condition. Comparison was performed at nominal blood viscosity and hematocrit only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The surrogate output (RH index) is directly the regulatory acceptance quantity for CPB device hemolysis comparison.",
      "rationale": "The ML surrogate directly predicts the normalised index of hemolysis (NIH) and the relative hemolysis index RH = NIH_device / NIH_predicate. RH is the primary regulatory QoI for Class II CPB device submissions. The surrogate output is therefore fully coincident with the decision quantity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the geometry parameter space and operating envelope defined in the COU.",
      "rationale": "The design-of-experiments space used to generate training and test data spans the five impeller-gap and volute-clearance dimensions specified in the COU tolerance study. All five flow-speed combinations defined in the COU intendedUse are represented in the validation dataset. Validation is therefore judged relevant to the COU operating envelope under nominal conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "At Model Risk Level 2, numerical solver error for the ML surrogate inference step is not required to be formally assessed. The surrogate performs closed-form gradient-boosted tree evaluation; floating-point rounding errors are negligible and no iterative solver convergence is involved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is scoped out at MRL 2. The surrogate is invoked through a validated Python API with schema-enforced input validation; operator input errors are caught programmatically before inference."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The gradient-boosted tree architecture is justified as appropriate for the hemolysis prediction task based on cross-validation performance and comparison against alternative architectures.",
      "rationale": "Gradient boosting (XGBoost v1.7) was selected after 5-fold cross-validation comparison against random forest, ridge regression, and a shallow MLP. XGBoost achieved the lowest cross-validation MAE (0.029) and highest R² (0.976) on the nominal-condition CFD dataset. Hyperparameters were tuned via Bayesian optimisation on the validation fold. Model form is considered adequate for the nominal operating regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input feature set is justified by sensitivity analysis; input ranges are bounded to the training domain.",
      "rationale": "Sobol sensitivity analysis identified the five geometric parameters and two operating parameters (flow rate, rotational speed) as the dominant inputs, collectively accounting for 94% of output variance on the nominal CFD dataset. Input range guards are enforced at inference time. Blood viscosity and hematocrit are fixed at nominal values (0.0035 Pa·s, 40%) and are not treated as variable inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples are independent of training data and cover the COU operating space with sufficient density.",
      "rationale": "The 1200-sample test set was withheld prior to any model development activity and drawn from the same Latin hypercube design-of-experiments as the training corpus, ensuring independence. Sample density analysis confirms at least 8 test points per unit hypercube cell across the 7-dimensional input space. All samples correspond to nominal CFD boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Equivalency of input parameters between computational and experimental domains is not required at MRL 2. The CFD-derived training labels are used directly; experimental-to-CFD input mapping is addressed under Test Conditions."
    }
