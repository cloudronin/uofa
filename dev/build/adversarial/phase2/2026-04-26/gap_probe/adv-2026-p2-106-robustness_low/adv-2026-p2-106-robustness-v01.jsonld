  "name": "Morrison COU1 — ML hemolysis surrogate credibility assessment (CPB)",
  "description": "V&V 40 credibility assessment for a machine-learning surrogate model of CFD-predicted hemolysis for the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the ML surrogate can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. The surrogate was trained on CFD simulation outputs spanning 5 flow-speed combinations and validated against a held-out test set drawn from the same simulation campaign distribution. All 13 credibility factors are addressed; 7 assessed, 6 scoped out as acceptable at MRL 2.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/hemolysis-surrogate-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/ml-surrogate-hemolysis-cpb",
