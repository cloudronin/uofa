    "https://uofa.net/synth/data/cfd-hemolysis-training-set-n800",
    "https://uofa.net/synth/data/cfd-hemolysis-test-set-n200"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/ml-surrogate-test-set-accuracy",
      "type": "ValidationResult",
      "name": "ML surrogate test-set prediction accuracy",
      "description": "The gradient-boosted surrogate was evaluated on a held-out test set of 200 CFD simulation cases sampled from the same Latin hypercube design as the 800-case training set. Mean absolute percentage error (MAPE) for the normalized index of hemolysis (NIH) prediction was 2.3%, and R² was 0.974 across all 5 flow-speed operating points. Worst-case operating condition rankings matched CFD rankings in 19 of 20 test cases. Acceptance criterion (MAPE < 5%, R² > 0.95) was met."
    },
    {
      "id": "https://uofa.net/synth/validation/ml-surrogate-cross-validation",
      "type": "ValidationResult",
      "name": "5-fold cross-validation on training distribution",
      "description": "Five-fold cross-validation was performed on the 800-case training corpus. Mean MAPE across folds was 2.7% ± 0.4%, confirming low variance within the training distribution. No out-of-distribution or shifted-distribution evaluation was conducted. All folds were drawn from the same Latin hypercube sampling plan used to generate training data."
    },
    {
      "id": "https://uofa.net/synth/validation/ml-surrogate-qoi-comparison",
      "type": "ValidationResult",
      "name": "Quantity-of-interest comparison: NIH and RH index",
      "description": "The surrogate's predicted normalized index of hemolysis (NIH) and relative hemolysis index (RH) were compared against CFD ground-truth outputs for all test-set cases. RH < 1 acceptance criterion was correctly classified in 100% of test cases. Comparisons were performed exclusively under nominal operating conditions matching the training envelope (flow rates 2–6 L/min, rotational speeds 2000–3500 RPM)."
    }
  ],
