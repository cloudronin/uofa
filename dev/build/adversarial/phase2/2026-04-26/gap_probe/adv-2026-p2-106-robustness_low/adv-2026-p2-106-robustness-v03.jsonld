  "decision": "Accepted",
  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for a machine-learning surrogate model trained to predict pump-induced hemolysis (relative hemolysis index, RH) for the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. The ML surrogate replaces full CFD solves for rapid design-space exploration. COU1 evaluates whether the surrogate can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Validation evidence covers model performance on a held-out test set drawn from the same distribution as training data.",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-ml-surrogate-req",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-ml-surrogate-claim",
  "bindsModel": "https://uofa.net/synth/model/gradient-boosted-hemolysis-surrogate-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/cpb-cfd-training-dataset-n4200",
    "https://uofa.net/synth/data/cpb-cfd-test-dataset-n900"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/ml-surrogate-test-set-accuracy",
      "type": "ValidationResult",
      "name": "Held-out test set prediction accuracy — nominal operating conditions",
      "description": "The gradient-boosted surrogate was evaluated on 900 held-out CFD cases drawn from the same Latin Hypercube sampling distribution used for training. Mean absolute percentage error for RH prediction was 3.1% across all 5 flow-speed operating points. R-squared on the test set was 0.974. All 900 test cases fall within the nominal operating envelope defined during training (flow rate 2–6 L/min, rotational speed 2000–4000 RPM, blood viscosity 3.0 cP). No out-of-distribution cases were included in this evaluation."
    },
    {
      "id": "https://uofa.net/synth/validation/ml-surrogate-cross-validation",
      "type": "ValidationResult",
      "name": "5-fold cross-validation on training distribution",
      "description": "Five-fold cross-validation was performed on the full 5100-case dataset (4200 training + 900 test). Mean MAPE across folds was 3.4% with standard deviation 0.3%. Fold-level R-squared ranged from 0.968 to 0.979. All folds were constructed by random stratified sampling within the nominal operating envelope; no temporal, spatial, or covariate-shifted splits were used. Cross-validation confirms stable in-distribution generalization."
    },
    {
      "id": "https://uofa.net/synth/validation/ml-surrogate-rh-threshold-classification",
      "type": "ValidationResult",
      "name": "Binary classification performance for RH < 1 acceptance criterion",
      "description": "The surrogate's ability to correctly classify operating points as compliant (RH < 1) or non-compliant (RH ≥ 1) was assessed on the nominal test set. Sensitivity 97.2%, specificity 96.8%, F1 score 0.971. All misclassified cases were near the decision boundary (0.95 ≤ RH ≤ 1.05). Evaluation was performed exclusively on test cases sampled from the same nominal operating distribution as training data."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042443",
