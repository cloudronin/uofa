  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-ml-surrogate-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The ML surrogate demonstrates MAPE of 3.1% and R-squared of 0.974 on the held-out test set drawn from the nominal operating envelope, satisfying the output comparison acceptance criterion. Binary classification of the RH < 1 regulatory threshold achieves F1 = 0.971. Software quality, discretization error in training labels, model form documentation, and input parameter coverage are all adequate. Six factors are not assessed, which is acceptable at MRL 2 per ASME V&V 40-2018. The surrogate is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device as specified in COU1.",
    "decidedAt": "2026-04-19T00:00:00Z"
