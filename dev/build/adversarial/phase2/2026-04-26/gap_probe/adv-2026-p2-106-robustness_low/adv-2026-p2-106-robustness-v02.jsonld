    "https://uofa.net/synth/data/morrison-cpb-cfd-training-partition",
    "https://uofa.net/synth/data/morrison-cpb-cfd-test-partition"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-ml-test-set-rh-accuracy",
      "type": "ValidationResult",
      "name": "Test-set RH prediction accuracy — nominal operating conditions",
      "description": "The gradient-boosted surrogate was evaluated on a held-out test partition (20% stratified split, n=87 operating points) drawn from the same CFD campaign used for training. Mean absolute error on RH was 0.031 (±0.008, 95% CI). R² = 0.974 across the five nominal flow-speed combinations. All 87 test points fall within the same geometric and flow-rate envelope as the training data. Acceptance criterion RH < 1 was correctly classified in 100% of test cases."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-ml-cross-validation-rh",
      "type": "ValidationResult",
      "name": "5-fold cross-validation RH prediction — nominal dataset",
      "description": "Five-fold cross-validation was performed on the full labeled dataset (n=435 CFD-derived operating points). Mean RH MAE across folds: 0.034 (std 0.006). No fold exhibited systematic bias exceeding 5% of the RH range. All folds were constructed from the same single experimental campaign; no independent experimental replication or alternative operating envelope was included."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-ml-feature-importance",
      "type": "ValidationResult",
      "name": "Feature importance and sensitivity analysis — nominal inputs",
      "description": "SHAP-based feature importance analysis identified impeller tip clearance and rotational speed as the dominant predictors of RH (combined SHAP contribution 61%). Sensitivity analysis was performed by varying each input feature ±10% around nominal design-point values using the trained surrogate. Results indicate monotonic RH response to tip-clearance reduction, consistent with CFD literature. Analysis was conducted using the surrogate's learned response surface; no independent experimental perturbation data were used to validate off-nominal predictions."
    }
  ],
