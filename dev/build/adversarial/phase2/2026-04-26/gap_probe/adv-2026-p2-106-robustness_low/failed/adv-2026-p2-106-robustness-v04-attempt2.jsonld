    "https://uofa.net/synth/data/morrison-cfd-test-set"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-ml-nominal-accuracy",
      "type": "ValidationResult",
      "name": "Nominal test-set accuracy — ML hemolysis surrogate",
      "description": "The ML surrogate model was evaluated on a held-out test set of 1 200 CFD-derived operating points sampled from the same five flow-speed combinations used during training. Mean absolute error in predicted relative hemolysis index (RH) was 0.031 across the test set (R² = 0.97). All 1 200 test-point predictions satisfied the RH < 1 acceptance criterion where the CFD ground truth did so. Validation was performed exclusively under nominal pump geometry and nominal blood-viscosity parameters identical to the training distribution."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-ml-cross-validation",
      "type": "ValidationResult",
      "name": "5-fold cross-validation on training distribution",
      "description": "Five-fold cross-validation was performed on the full 6 000-point CFD dataset. Mean RH MAE across folds was 0.029 ± 0.004. No fold contained operating conditions outside the nominal flow-speed envelope (1.5–5.0 L/min, 2 000–4 500 rpm). All folds were drawn from the same joint distribution as the training set; no out-of-distribution, noise-augmented, or adversarially perturbed samples were included."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-ml-comparison-cfd",
      "type": "ValidationResult",
      "name": "Surrogate vs. full CFD comparison at five operating points",
      "description": "At the five predefined worst-case candidate operating points, ML surrogate predictions were compared directly against full-resolution CFD solutions. Maximum deviation in predicted RH was 4.2 %. Agreement was deemed acceptable for MRL 2. All comparisons were conducted under the same nominal inlet boundary conditions and fluid properties used during model development; no perturbation of boundary conditions or material parameters was explored."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037888",
