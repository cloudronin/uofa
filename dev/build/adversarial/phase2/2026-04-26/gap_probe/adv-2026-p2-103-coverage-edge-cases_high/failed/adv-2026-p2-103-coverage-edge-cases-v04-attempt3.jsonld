  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately not assessed at MRL 2. Validation results across five nominal operating points demonstrate RH index prediction errors below 5%, well within the 10% acceptance criterion. The credibility assessment team concludes the CFD model is sufficiently credible for identifying worst-case hemolysis operating conditions within the nominal CPB flow range. Edge-case validation at high-shear blade-tip regions and extreme low-flow weaning conditions is noted as pending; those results are to be incorporated in a subsequent credibility update before extending the COU to those regimes.",
