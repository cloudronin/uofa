  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are not assessed, which is acceptable at MRL 2 per ASME V&V 40-2018. Validation evidence across five nominal operating points (2–6 L/min, 2000–3500 RPM) demonstrates RH prediction error consistently below 5%, satisfying the RH < 1 acceptance criterion relative to the predicate device. The assessment team notes that high-shear-stress regions at the impeller tip clearance and volute cutwater, and low-flow stall conditions below 2 L/min, are identified in the COU as conditions of interest; these edge cases were studied in a separate characterisation effort and are considered outside the scope of the present validation evidence package. The credibility assessment is accepted at Medium assurance level for the stated COU.",
