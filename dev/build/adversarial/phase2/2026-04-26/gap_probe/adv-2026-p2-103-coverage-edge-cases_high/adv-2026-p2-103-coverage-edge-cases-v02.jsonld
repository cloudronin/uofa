  "signature": "ed25519:7b3e1f9a2c4d6e8b0f1a3c5e7d9b2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4f6a",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated code with documented version control and audit trail for simulation inputs.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional SQA plan. Version-controlled case files archived in institutional repository. Solver verification documentation confirms compliance with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark problems (lid-driven cavity, pipe flow) demonstrating correct implementation of governing equations.",
      "rationale": "ANSYS Fluent passes published ASME benchmark suite for incompressible viscous flow. Vendor-supplied verification reports reviewed and accepted. No custom UDFs introduced that would require additional verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across three systematically refined meshes at the nominal design point.",
      "rationale": "Three-level mesh refinement study performed at 3500 RPM, 4.0 L/min. GCI for RH index: 3.2% (fine-to-medium), 4.8% (medium-to-coarse). Asymptotic ratio 1.02 confirms convergence in the Richardson extrapolation sense. Mesh refinement study was not repeated at edge-case operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate pump inlet temperature (37 ± 1 °C), hematocrit (35 ± 2%), and flow rate within ± 0.1 L/min of CFD boundary conditions.",
      "rationale": "All five nominal validation experiments conducted at 37 °C, hematocrit 35%, with calibrated Coriolis flow meters (±0.05 L/min). Conditions match CFD boundary conditions within specified tolerances. Test conditions were established for the nominal 2–5 L/min range; no test replication was performed at the sub-1.5 L/min stall-onset regime or at impeller tip speeds exceeding 4200 RPM."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index must agree with bench-measured RH within 15% at each validation operating point; velocity field L2 norm error below 10%.",
      "rationale": "RH agreement ranges from 5% to 12% across the five nominal validation points. Velocity field L2 norm errors range from 6% to 9%. All points satisfy the 15% and 10% acceptance thresholds respectively. Comparison is limited to the nominal envelope; the high-shear blade-tip region and stall-onset condition are noted as studied separately."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (RH index, volume-averaged shear stress, exposure time) must be directly traceable to the clinical hemolysis acceptance criterion RH < 1.",
      "rationale": "RH index computed via the Giersiepen-Wurzinger power-law model integrating shear stress and exposure time along Lagrangian particle tracks. Direct traceability to clinical threshold established. QoI selection reviewed and approved by clinical advisor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, blood analog fluid, and rotational speed range as the COU device.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry using ovine blood at physiological hematocrit. Rotational speeds 2000–3500 RPM span the nominal COU range. The COU additionally identifies high-shear impeller tip regions and stall-onset conditions as critical; validation activities covering those regions are described as conducted under a separate protocol and are not included in this evidence package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 provided software quality assurance and numerical code verification are assessed.",
      "rationale": "MRL 2 does not require independent assessment of numerical solver error beyond SQA and code verification. Factor scoped out per ASME V&V 40-2018 Table 1 guidance for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Use error assessment not required at Model Risk Level 2 per ASME V&V 40-2018. Analyst training records maintained as part of SQA documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis constitutive law) not formally quantified at MRL 2. SST k-omega turbulence model selected based on published literature for rotating machinery hemolysis applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Parametric uncertainty in blood viscosity and hematocrit not formally propagated at MRL 2. Nominal values used per ISO 10993-4 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point to establish measurement repeatability; coefficient of variation below 10% for RH index.",
      "rationale": "Three independent bench experiments conducted at each of the five nominal operating points. Coefficient of variation for RH index ranges from 3.1% to 7.8% across all points, satisfying the 10% threshold. Replicate experiments were not conducted at the high-shear blade-tip or stall-onset conditions identified in the COU, as those conditions are addressed in a separate experimental program not linked here."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary conditions (inlet velocity profile, outlet pressure, wall roughness) must be derived directly from experimental measurements with documented traceability.",
      "rationale": "Inlet velocity profiles extracted from PIV measurements at the pump inlet plane. Outlet pressure set to measured back-pressure from bench circuit. Wall roughness Ra = 0.8 µm per coordinate measurement machine report. Traceability matrix linking each CFD boundary condition to its experimental source documented in the simulation plan. Equivalency established only for the nominal operating envelope."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 1. Validation evidence demonstrates that the CFD model reliably predicts hemolysis index within 15% across the nominal operating envelope (2000–3500 RPM, 2.0–5.0 L/min), satisfying the RH < 1 acceptance criterion relative to the predicate device. High-shear blade-tip and stall-onset edge-case conditions named in the COU are identified as subjects of a separate validation study; that work is pending and will be incorporated in a future revision of this credibility package. On the basis of the available evidence, the model is accepted for use in identifying worst-case hemolysis conditions within the validated nominal operating range.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
