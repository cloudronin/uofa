  "signature": "ed25519:b2e4f1a9c7d3e0b6f8a2c5d9e1b4f7a0c3e6d2b8f1a5c9e3d7b0f4a2c6e8d1b9",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022R2) with documented V&V pedigree; version-controlled simulation scripts; audit trail of solver settings.",
      "rationale": "ANSYS Fluent 2022R2 is an FDA-recognized commercial solver with published verification test suite. Simulation input files are version-controlled in a Git repository with commit hashes recorded. Achieves Gradation 1 requirement for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, Poiseuille flow) to within published tolerances.",
      "rationale": "ANSYS Fluent benchmark results for laminar and turbulent canonical flows are documented in the solver verification manual. Results for lid-driven cavity at Re=1000 and turbulent pipe flow agree with reference solutions within 0.5%. Gradation 1 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on three systematically refined meshes.",
      "rationale": "Three-mesh Richardson extrapolation performed at the 3 L/min design point. Coarse (4.2M cells), medium (8.7M cells), fine (17.1M cells). GCI for hemolysis index: 3.8% (coarse-medium), 1.9% (medium-fine). Fine mesh adopted for all production runs. Gradation 2 requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental inlet/outlet boundary conditions, blood analogue viscosity, and rotational speed match CFD inputs within stated measurement uncertainties.",
      "rationale": "In-vitro loop conditions (flow rate ±2%, rotational speed ±10 RPM, fluid viscosity ±3%) were reproduced in CFD boundary conditions. All five nominal validation points confirmed to match experimental setup documentation. Gradation 2 met. Note: test conditions were only characterised for the nominal 2–5 L/min range; near-stall low-flow conditions were not instrumented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index within 15% of measured value at all validation points; velocity profiles within 10% at impeller exit plane.",
      "rationale": "Across the five nominal validation points, CFD-predicted RH deviates from measurement by 4–11% (mean 7.2%). Impeller-exit velocity profiles agree within 8% at design point. All comparisons conducted in the bulk operating regime. Gradation 2 acceptance criterion satisfied for the tested range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) directly map to the clinical endpoint of erythrocyte damage and to the RH < 1 acceptance criterion.",
      "rationale": "The primary QoI is the normalised index of hemolysis (NIH) converted to relative hemolysis index RH. Shear stress distributions are secondary QoIs used to localise damage. Both quantities directly address the COU decision on worst-case hemolysis. The relevance of these QoIs is well established in the FDA hemolysis guidance literature. Gradation 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal pump geometry under blood-analogue fluid conditions representative of CPB use.",
      "rationale": "All five validation experiments used the FDA generic centrifugal pump geometry with a glycerol-water blood analogue (viscosity 3.5 cP) in a closed-loop circuit mimicking CPB afterload. The geometry and fluid are directly relevant to the COU device. Validation activities are judged relevant to the nominal operating envelope. High-shear-stress regions near the volute cutwater and near-stall low-flow conditions are acknowledged in the COU but are addressed in a separate unpublished study; that work is not included in this evidence package. Gradation 2 met for the assessed range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 beyond code verification already performed.",
      "rationale": "At MRL 2, separate numerical solver error assessment beyond code verification is not required. Scoped out consistent with ASME V&V 40-2018 Table 3 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
