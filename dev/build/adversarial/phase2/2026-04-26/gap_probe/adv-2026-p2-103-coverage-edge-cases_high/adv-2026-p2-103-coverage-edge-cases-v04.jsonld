      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; standard operating procedures and peer review of simulation setup are sufficient.",
      "rationale": "Simulation setup reviewed by a second qualified analyst. Standard operating procedure for CFD hemolysis analysis followed. No formal use-error assessment required at MRL 2."
    },
    {
