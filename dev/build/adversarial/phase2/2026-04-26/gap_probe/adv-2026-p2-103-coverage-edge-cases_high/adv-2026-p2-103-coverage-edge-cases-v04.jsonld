      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; commercial solver iterative convergence monitoring is sufficient.",
      "rationale": "At MRL 2, formal solver error quantification beyond residual monitoring is not required. Residuals converge to 1e-5 for all equations in all runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
