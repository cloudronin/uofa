  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped to not-assessed at MRL 2. Validation results demonstrate RH < 1.0 at all five COU operating points with GCI below 5% and hemolysis model agreement within 15% of experimental data. The assessment team noted that configuration parameters (mesh density, hemolysis model exponents, turbulence constants) are described in the model narrative and were held constant across all validation runs; however, these values have not been captured in a structured configuration binding within the assurance package. The team accepted this gap on the basis that the simulation setup report is referenced in the dataset record and the analyst responsible for deployment is expected to reproduce the validated configuration. The overall credibility evidence is judged sufficient to support the regulatory submission decision for this Class II CPB device at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
