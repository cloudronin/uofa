  "decision": "Accepted",
  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The CFD solver exposes tunable parameters including near-wall mesh resolution (target y+ 1–5), a power-law hemolysis model threshold exponent (alpha = 0.785), and a scalar blending coefficient (C_hemo = 1.8e-6). Validation studies were executed at the chosen settings and results are reported relative to those settings; however, no structured configuration node pins these values for deployment and the ContextOfUse does not constrain which parameter set must be used when the model is applied to a new pump variant.",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/cou1-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/cou1-cpb-worst-case-hemolysis",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-cpb-experimental-hemolysis",
    "https://uofa.net/synth/data/morrison-cou1-cfd-mesh-study"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou1-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — hemolysis index sensitivity",
      "description": "Three mesh densities (coarse 1.2 M cells, medium 4.1 M cells, fine 9.8 M cells) were evaluated for the FDA generic pump at 2.5 L/min, 2500 RPM. The normalized hemolysis index varied by less than 3.1% between medium and fine meshes. All subsequent simulations were executed at the chosen medium mesh density (y+ target 1–3); this setting is referenced in the narrative but is not recorded in a structured configuration binding that would carry forward to deployment.",
      "quantitativeOutcome": "GCI < 2.1% for scalar hemolysis index between medium and fine mesh levels",
      "assessedFactor": "Discretization error",
      "outcome": "Accepted"
    },
    {
      "id": "https://uofa.net/synth/validation/cou1-hemolysis-model-calibration",
      "type": "ValidationResult",
      "name": "Power-law hemolysis model parameter validation against in-vitro data",
      "description": "The Giersiepen-Wurzinger power-law hemolysis model was calibrated using published in-vitro data from three Couette-flow experiments. At the chosen settings (alpha = 0.785, beta = 2.416, C_hemo = 1.8e-6), model predictions of normalized index of hemolysis (NIH) agreed with experimental data within 12% across the validation envelope. These parameter values are discussed in the model description section but are not pinned in any structured configuration node linked from this assurance package. A reviewer deploying the model for a variant pump geometry could inadvertently use literature-default values (alpha = 0.765, C_hemo = 3.62e-7) without triggering any configuration mismatch warning.",
      "quantitativeOutcome": "Mean absolute relative error 9.4% across 18 validation points; R² = 0.91",
      "assessedFactor": "Model form",
      "outcome": "Accepted"
    },
    {
      "id": "https://uofa.net/synth/validation/cou1-operating-point-comparison",
      "type": "ValidationResult",
      "name": "Five-point operating map comparison against predicate device",
      "description": "CFD predictions of relative hemolysis index (RH) were computed at 5 flow-speed combinations (1.5–4.5 L/min, 1500–3500 RPM) and compared against the predicate device experimental RH values. All five predicted RH values were below 1.0 (range 0.61–0.94), satisfying the acceptance criterion. Results are reported at the chosen solver configuration; the package does not bind a configuration document specifying turbulence model constants, near-wall treatment, or hemolysis scalar blending settings that were active during validation.",
      "quantitativeOutcome": "RH < 1.0 at all 5 operating points; maximum RH = 0.94 at 4.5 L/min / 3500 RPM",
      "assessedFactor": "Output comparison",
      "outcome": "Accepted"
    }
  ],
