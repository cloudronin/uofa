  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. The six not-assessed factors are appropriately scoped out at MRL 2. Validation against the FDA GCBP experimental dataset demonstrates adequate predictive accuracy (MARE 8.4%) for the hemolysis QoI. The RH < 1 acceptance criterion is satisfied across all 12 geometric variants. The assessment team accepts the model for use in identifying worst-case hemolysis operating conditions for the Class II CPB device. Note: the validation was conducted at specific solver configuration settings (mesh element size 0.15 mm, Lagrangian time-step multiplier 0.02, hemolysis threshold shear stress 150 Pa) documented in the validation narrative; these parameters are not formally pinned in a structured configuration record linked to this package, and the deployment context does not constrain them. Teams deploying this model should ensure configuration settings are reproduced consistently with the validated configuration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
