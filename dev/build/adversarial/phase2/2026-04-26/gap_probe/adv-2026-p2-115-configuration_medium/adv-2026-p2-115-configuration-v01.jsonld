  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead-engineer",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately scoped out at MRL 2. RH < 1 for all five CPB operating points. The assessment team concludes the CFD model has sufficient credibility to support the regulatory submission decision regarding worst-case hemolysis operating conditions for the Class II CPB device. The team noted in deliberations that solver configuration parameters are described in the simulation report narrative but acknowledged that no formal mechanism pins these values for future deployment analyses; this was considered acceptable under MRL 2 requirements but was flagged for attention if the model risk level is elevated in future submissions.",
    "decidedAt": "2026-04-19T00:00:00Z"
