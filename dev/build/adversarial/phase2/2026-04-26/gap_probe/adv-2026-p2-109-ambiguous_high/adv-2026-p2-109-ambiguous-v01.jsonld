    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-adequacy-req-001",
    "type": "Requirement",
    "name": "CFD hemolysis model adequacy requirement for CPB application",
    "requirementText": "The CFD model shall demonstrate adequate predictive fidelity for pump-induced hemolysis such that clinically acceptable hemolysis performance is maintained across the relevant operating envelope. Simulation outputs shall reflect reasonable agreement with experimental reference data, and any discrepancies shall be of minimal clinical impact as determined by the responsible engineering team in accordance with applicable internal performance standards.",
    "acceptanceCriteria": "Model outputs are considered compliant when they exhibit reasonable agreement with benchmark hemolysis data and when deviations do not produce clinically meaningful differences in the predicted relative hemolysis index. The threshold for 'reasonable agreement' and 'minimal clinical impact' shall be interpreted consistent with accepted practice for Class II hemolysis-sensitive devices.",
    "rationale": "The requirement is framed to accommodate variability in experimental measurement uncertainty and to allow engineering judgment in borderline cases. The phrase 'adequate predictive fidelity' is intended to invoke the project-level fidelity grading scale defined in internal document MP-CFD-HEM-007, which is not reproduced here."
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/gcbp-hemolysis-bench-comparison-001",
      "type": "ValidationResult",
      "name": "FDA GCBP bench hemolysis comparison — 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against FDA-published experimental data for five flow-speed combinations. Relative hemolysis index RH computed against predicate device benchmark. All five operating points yielded RH values in the range 0.71–0.94, nominally satisfying RH < 1. Discretization error bounded by GCI analysis. Agreement characterized as 'reasonable' per team assessment; no explicit numerical tolerance for 'reasonable' is cited in the structured record."
    },
    {
      "id": "https://uofa.net/synth/validation/gcbp-mesh-convergence-gci-001",
      "type": "ValidationResult",
      "name": "Grid convergence index study — three-level mesh refinement",
      "description": "Three-level mesh refinement study performed on baseline impeller geometry at 4.5 L/min, 2500 RPM. GCI values for NIH quantity of interest ranged from 1.2% to 3.8% across refinement levels, indicating acceptable numerical discretization error for MRL 2 requirements."
    }
