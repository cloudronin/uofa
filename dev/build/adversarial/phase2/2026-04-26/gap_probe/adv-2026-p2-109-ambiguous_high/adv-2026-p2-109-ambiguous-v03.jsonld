  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-acceptability-v1",
    "type": "Requirement",
    "name": "CPB hemolysis acceptability requirement",
    "requirementText": "The CFD model shall demonstrate acceptable hemolytic performance relative to the predicate device across all evaluated operating conditions, such that the predicted relative hemolysis index reflects no more than a minimal adverse impact on blood cell integrity under representative physiological loading. Model outputs shall be consistent with reasonable engineering expectations for devices of this class, and any deviation from expected hemolysis levels shall be judged as clinically insignificant by the responsible analyst.",
    "acceptanceCriteria": "Predicted RH values shall fall within an acceptable range as determined by standard hemolysis assessment practice. Numerical results shall exhibit adequate convergence and the hemolysis index shall not exceed a level considered materially elevated relative to comparable centrifugal pump designs. Compliance is confirmed when the analyst judges the overall hemolytic response to be within normal bounds for the device category."
  },
