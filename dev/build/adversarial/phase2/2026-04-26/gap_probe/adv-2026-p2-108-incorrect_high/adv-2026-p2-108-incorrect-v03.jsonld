  "hasRequirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-threshold-001",
    "type": "Requirement",
    "name": "Relative Hemolysis Index Acceptance Requirement",
    "requirementText": "The CFD model shall demonstrate that the device relative hemolysis index (RH) does not exceed 1.12 under any of the five evaluated operating conditions, where RH is defined as the ratio of the device normalized index of hemolysis (NIH) to the predicate device NIH measured under equivalent conditions. This threshold is derived from the 510(k) predicate comparison framework and accounts for measurement uncertainty in the NIH assay (±8%).",
    "source": "Internal design requirement DR-CPB-HEM-007, revision B",
    "rationale": "The RH < 1.12 threshold provides a 12% margin above the predicate device performance level, intended to bound NIH assay measurement uncertainty while ensuring the device does not substantially increase hemolysis risk relative to the predicate."
  },
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-credibility-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors not assessed are consistent with MRL 2 requirements for a Class II device with medium model influence. Discretization error (GCI < 2.1%) and output comparison (mean error 8.3%) demonstrate adequate model fidelity. The RH < 1.12 acceptance criterion is met across all five operating points (maximum observed RH = 1.07). The credibility evidence package is judged sufficient to support the regulatory submission decision.",
