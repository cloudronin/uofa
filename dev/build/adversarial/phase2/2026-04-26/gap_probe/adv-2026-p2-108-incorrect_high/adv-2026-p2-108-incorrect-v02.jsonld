      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for NIH quantity of interest on three systematically refined meshes; Richardson extrapolation applied.",
      "rationale": "Three meshes of 4.2M, 8.7M, and 17.1M cells were evaluated. GCI for NIH was 3.8% between fine and medium meshes and 6.2% between medium and coarse meshes. The fine mesh (8.7M cells) was selected for all production runs, satisfying the GCI threshold for the QOI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match simulation boundary conditions within ±5% for all five operating points.",
      "rationale": "In vitro test conditions from the FDA benchmark dataset were reproduced in simulation boundary conditions. Flow rates matched within 2.1%, rotational speeds within 0.8%, and blood analog viscosity within 3.4%. Temperature was held constant at 37°C in both experiment and simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values agree with experimental measurements within 15% at all five operating points; systematic bias less than 10%.",
      "rationale": "Point-wise comparison of predicted versus measured NIH across 5 operating points yielded maximum relative error of 11.7% and mean relative error of 8.3%. No systematic over- or under-prediction bias was identified. Results fall within the stated acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH and derived RH index are established hemolysis metrics used in FDA guidance and peer-reviewed literature for CPB device evaluation.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the standard quantities of interest for FDA 510(k) submissions for CPB devices. Both metrics are explicitly referenced in FDA guidance document FDA-2021-D-0758. The QOI selection is directly relevant to the regulatory decision context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry (FDA generic centrifugal pump) and overlapping operating conditions (flow rate 2–8 L/min, speed 2000–3500 RPM) as the COU.",
      "rationale": "Validation activities were conducted on the identical FDA generic centrifugal pump geometry used in the COU simulations. Operating conditions in validation experiments span the full range of COU operating points. The blood analog fluid (glycerol-water mixture) matches the viscosity of whole blood within 4%, supporting transferability of validation evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver-level numerical error addressed through code verification activities.",
      "rationale": "At Model Risk Level 2, independent assessment of numerical solver error beyond code verification is not required per ASME V&V 40 Table 3. Solver error is implicitly bounded by the code verification results documented under the Numerical Code Verification factor."
    },
    {
