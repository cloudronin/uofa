      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled CFD solver with documented release notes and regression test suite; solver version recorded in simulation log.",
      "rationale": "ANSYS Fluent 2022R2 was used under institutional license with full version control. Regression tests confirmed no solver-level defects affecting rotating machinery simulations. Software QA documentation archived per ISO 9001 procedures."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
