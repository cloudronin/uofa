  "hasRequirement": {
    "id": "https://uofa.net/synth/req/rh-acceptance-threshold-v1",
    "type": "Requirement",
    "name": "Relative Hemolysis Index Acceptance Threshold",
    "requirementText": "The CFD model shall be considered acceptable for regulatory submission if the predicted relative hemolysis index RH does not exceed 1.10 across all evaluated operating conditions, where RH is defined as the ratio of the device NIH index to the predicate device NIH index measured under equivalent test conditions.",
    "rationale": "An RH threshold of 1.10 is specified to provide a 10% tolerance margin above parity with the predicate device. This threshold is adopted from internal device development guidance and is applied uniformly across all five flow-speed operating points."
  },
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are explicitly scoped out as non-required at MRL 2 per ASME V&V 40-2018 Table 3. CFD predictions of the NIH hemolysis index agree with experimental bench data within 15% across all operating points. The worst-case RH value across the five operating conditions was 0.97, well within the stated acceptance threshold of RH < 1.10. The model is assessed as credible for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
