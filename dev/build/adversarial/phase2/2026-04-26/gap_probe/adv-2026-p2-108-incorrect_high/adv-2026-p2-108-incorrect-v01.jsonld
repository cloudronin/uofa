  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled CFD solver with documented test suite; no custom user-defined functions without independent review.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional license with configuration management records. Solver version pinned and documented in simulation log. No bespoke UDFs employed. Meets Gradation 1 requirement for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark verification cases relevant to rotating machinery and viscous flow.",
      "rationale": "ANSYS Fluent has been verified against the FDA Critical Path benchmark for intravascular flow devices. Relevant verification cases for rotating reference frame formulation and viscous hemolysis scalar transport are documented in solver validation reports. Gradation 1 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QOI; GCI < 5% on fine grid relative to medium grid.",
      "rationale": "Three-level mesh refinement study performed: coarse (4.1M cells), medium (9.8M cells), fine (22.3M cells). GCI for the relative hemolysis index between medium and fine grids is 3.1%, satisfying the < 5% criterion. Asymptotic convergence confirmed with apparent order p = 1.94. Discretization error is adequately characterized at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match CFD boundary conditions within stated uncertainty bounds.",
      "rationale": "In-vitro hemolysis experiments conducted at five operating points (2.5 L/min at 2000 RPM, 3.5 L/min at 2400 RPM, 5.0 L/min at 3000 RPM, 6.0 L/min at 3400 RPM, 7.0 L/min at 3800 RPM). Fluid properties use bovine blood analog at 37°C. CFD boundary conditions match measured flow rates within ±2% and rotational speeds within ±0.5%. Temperature maintained at 37 ± 0.5°C throughout. Gradation 2 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted normalized index of hemolysis (NIH) agrees with experimental NIH within 20% across all five operating points.",
      "rationale": "Predicted NIH values compared against in-vitro measurements at all five operating points. Maximum discrepancy observed is 14.7% at the 7.0 L/min, 3800 RPM operating point; all other points within 10%. Systematic bias is < 5% across the operating range. Agreement is within the 20% acceptance band, confirming Gradation 2 output comparison. The RH criterion of RH < 1.12 used as primary decision metric is consistent with output comparison results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs directly map to clinical hemolysis endpoints used in regulatory submissions for Class II CPB devices.",
      "rationale": "Primary QOI is the relative hemolysis index RH = NIH_device / NIH_predicate, directly corresponding to the predicate comparison methodology accepted by FDA for 510(k) submissions for centrifugal blood pumps. Secondary QOIs include volume-averaged scalar shear stress and exposure time distribution. All QOIs are clinically meaningful and regulatory-relevant. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry and at operating conditions spanning the COU operating envelope.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry under the identical five flow-speed combinations constituting the COU operating envelope. Fluid is a blood analog matching the viscosity and density of human blood at operating temperature. No extrapolation beyond validated operating range required. Validation activities are directly relevant to the COU at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; commercial solver with documented verification record is sufficient.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond code verification is not required. The use of a commercially validated solver with published verification documentation satisfies Gradation 1 by default. Not assessed per MRL 2 scoping decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation setup reviewed by a second qualified analyst.",
      "rationale": "Simulation setup and boundary condition specification reviewed by a second CFD analyst with cardiovascular device simulation experience. No discrepancies identified. At MRL 2, formal use error analysis is not required; peer review of setup is sufficient for Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection justified by literature precedent for similar rotating blood-contacting devices.",
      "rationale": "SST k-omega turbulence model selected based on published literature demonstrating superior performance for transitional flow in centrifugal blood pumps compared to k-epsilon variants. Giersiepen power-law hemolysis model applied as the standard formulation for FDA benchmark comparisons. Model form uncertainty not formally quantified at MRL 2 but selection is well-justified by precedent."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; key material properties and boundary conditions documented with sources.",
      "rationale": "Blood analog fluid properties (density 1056 kg/m³, dynamic viscosity 0.0035 Pa·s) sourced from ASTM F1841 and confirmed by in-house rheometry. Pump geometry dimensions from manufacturer CAD files with dimensional inspection report. Input uncertainty propagation not required at MRL 2; documentation of sources satisfies Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; experimental samples are from a single production lot with documented provenance.",
      "rationale": "In-vitro experiments used bovine blood from a single certified supplier lot, with hematocrit maintained at 33 ± 1% per ASTM F1841 protocol. Sample variability characterization not required at MRL 2. Provenance documentation on file. Gradation 1 satisfied by documentation alone."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
