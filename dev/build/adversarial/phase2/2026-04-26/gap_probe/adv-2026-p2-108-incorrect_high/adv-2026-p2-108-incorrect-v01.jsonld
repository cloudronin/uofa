  "requirement": {
    "id": "https://uofa.net/synth/req/morrison-rh-threshold-001",
    "type": "Requirement",
    "name": "Relative Hemolysis Index Acceptance Threshold",
    "requirementText": "The CFD-predicted relative hemolysis index (RH) shall not exceed 1.12 at any of the five evaluated flow-speed operating points. Compliance with this threshold demonstrates that the device does not produce clinically significant hemolysis beyond the predicate device performance envelope under CPB operating conditions.",
    "rationale": "Threshold of RH < 1.12 is derived from inter-laboratory variability in hemolysis measurement (±12%) reported in ASTM F1841 standardized hemolysis testing, allowing for measurement uncertainty while maintaining safety margin relative to the predicate."
  },
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037584",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-engineering-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
