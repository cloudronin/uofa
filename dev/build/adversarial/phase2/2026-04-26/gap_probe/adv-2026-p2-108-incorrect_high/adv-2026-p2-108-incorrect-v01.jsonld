  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required gradation levels for MRL 2. Six factors are appropriately scoped out at MRL 2 and satisfy minimum documentation requirements. The CFD model demonstrates adequate predictive fidelity for the relative hemolysis index across the full CPB operating envelope. The acceptance threshold of RH < 1.12 has been met at all five operating points, with maximum predicted RH of 1.08 at the highest-stress condition. The credibility evidence package is deemed sufficient to support regulatory submission for the Class II CPB device.",
