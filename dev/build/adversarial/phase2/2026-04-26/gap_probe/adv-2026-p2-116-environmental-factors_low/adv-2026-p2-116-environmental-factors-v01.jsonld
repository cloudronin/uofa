  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors accepted at level 1 or scoped out per MRL 2 requirements. CFD hemolysis predictions agree with bench validation data within 8% across all five operating points. Relative hemolysis index RH < 1 criterion satisfied for the worst-case operating condition identified. The assessment team concluded that the model is sufficiently credible for the COU decision. The validation evidence base is entirely derived from controlled laboratory experiments at 22°C and atmospheric pressure in an electromagnetically shielded environment; the influence of the real deployment environment (operating-theatre temperature variation, electromagnetic interference from co-located equipment, and hypobaric transport conditions) on model predictions has not been characterised or bounded. This limitation was noted but not considered disqualifying at MRL 2 given the medium model influence rating.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
