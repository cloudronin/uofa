    "https://uofa.net/synth/data/morrison-fda-pump-geometry-v1",
    "https://uofa.net/synth/data/morrison-lab-hemolysis-measurements-v1"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The device is operated in environments with temperature drift (18–26 °C), variable ambient pressure (altitude-capable theatres, 85–101 kPa), and electromagnetic interference from electrosurgical units; these parameters were not characterised during validation.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-pressure-head",
      "type": "ValidationResult",
      "name": "Pressure-head validation against FDA pump benchmark",
      "description": "CFD-predicted pressure head compared with published FDA benchmark experimental data across 5 flow-speed combinations. Mean relative error 3.2%. All tests conducted in laboratory at 22 °C, atmospheric pressure (101.3 kPa). No variation in ambient temperature or pressure was explored. Electromagnetic environment not characterised."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against in-vitro measurements",
      "description": "Computed relative hemolysis index (RH) compared against in-vitro hemolysis measurements from bench testing of the FDA generic centrifugal pump. RH < 1 criterion met for all 5 operating points. Testing performed in controlled laboratory at 22 °C and standard atmospheric pressure. No sensitivity analysis was conducted for temperature drift (18–26 °C), reduced ambient pressure (85–101 kPa), or EM interference levels representative of operating-theatre electrosurgical units."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-velocity-field",
      "type": "ValidationResult",
      "name": "Velocity field validation via PIV comparison",
      "description": "CFD velocity fields compared with particle image velocimetry (PIV) measurements at the pump outlet plane. Normalised RMS discrepancy 4.7%. Measurements taken at 22 °C, 101.3 kPa in a temperature-controlled laboratory. No environmental bounding study links these conditions to the full deployment envelope."
    }
  ],
