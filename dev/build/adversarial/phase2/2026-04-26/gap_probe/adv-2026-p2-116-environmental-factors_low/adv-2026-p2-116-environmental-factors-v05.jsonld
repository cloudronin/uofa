  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scope. Quantitative validation metrics (GCI 2.8%, pressure-head error 3.2%, RH index within measurement uncertainty) support the claim that the CFD model can identify worst-case hemolysis operating conditions. The assessment team notes that all validation activities were conducted at 22 °C and standard atmospheric pressure; the deployment environment spans 18–26 °C, 85–101 kPa, and includes EM interference from electrosurgical units. No environmental-sensitivity study has been performed and the operating envelope does not formally bound these parameters. The team judges this gap acceptable at MRL 2 given the medium model influence and the availability of physical testing to confirm model predictions. Decision: Accepted.",
