  "name": "Morrison COU1 — CPB hemolysis credibility assessment (environmental gap variant)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The CPB device is deployed in operating-room environments subject to temperature drift (18–26°C), varying ambient pressure (sea-level to 1500 m altitude), and electromagnetic interference from surgical equipment. All validation experiments were conducted at a fixed laboratory temperature of 22°C, atmospheric pressure, and shielded from EMI sources. No environmental-sensitivity study has been performed and the operating envelope does not bound these environmental parameters.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/morrison-cpb-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-cpb-lab-validation-dataset-001",
    "https://uofa.net/synth/data/morrison-cpb-mesh-convergence-dataset-001"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The device is operated in clinical environments where ambient temperature may range from 18°C to 26°C, ambient pressure varies with hospital altitude (sea level to approximately 1500 m), and electromagnetic interference from adjacent surgical and monitoring equipment is routinely present.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-vr-001",
      "type": "ValidationResult",
      "name": "FDA generic centrifugal pump hemolysis validation — laboratory bench test",
      "description": "Validation experiments conducted in a controlled laboratory setting at 22°C ambient temperature, standard atmospheric pressure (101.3 kPa), and electromagnetically shielded environment. Five flow-speed operating points were tested. Relative hemolysis index (RH) measured against predicate device. All five operating points achieved RH < 1. No testing was performed under elevated temperature, reduced ambient pressure, or in the presence of electromagnetic interference representative of operating-room conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-vr-002",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error study",
      "description": "Grid convergence index (GCI) study performed across three mesh refinement levels (3.2M, 8.7M, and 21.4M cells) at the nominal operating point (5 L/min, 3000 RPM). GCI < 2.1% for hemolysis index QoI. All runs executed at 22°C, atmospheric pressure, in the same laboratory environment as the primary validation experiments."
    }
  ],
