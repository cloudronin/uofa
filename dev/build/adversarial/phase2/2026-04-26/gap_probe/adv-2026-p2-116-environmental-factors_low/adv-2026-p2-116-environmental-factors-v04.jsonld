  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at MRL 2 meet or exceed their required levels. The CFD model demonstrates adequate credibility for identifying worst-case hemolysis operating conditions under the documented laboratory validation conditions. The relative hemolysis index remains below 1.0 across all five operating points with CFD-to-experiment agreement within 11%. The assessment team accepts the model for the stated COU at MRL 2. The team notes that all validation activities were conducted at 22°C, standard atmospheric pressure, and in an EMI-shielded laboratory environment; the clinical deployment environment encompasses temperature variation (18–26°C), altitude-related pressure variation, and electromagnetic interference from surgical equipment. No environmental-sensitivity study was conducted and the operating envelope does not formally bound these parameters. The team judges this gap acceptable at MRL 2 given the medium model influence and the availability of physical testing for final device confirmation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
