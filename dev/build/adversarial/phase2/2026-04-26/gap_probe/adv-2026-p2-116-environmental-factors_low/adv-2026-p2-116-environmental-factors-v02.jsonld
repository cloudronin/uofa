  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-fda-pump-geometry-v1",
    "https://uofa.net/synth/data/morrison-hemolysis-lab-measurements-22c"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The device is routinely operated in hospital surgical suites where ambient temperature fluctuates between 18°C and 26°C, electromagnetic fields from electrosurgical units and monitoring equipment are present, and ambient pressure varies with facility altitude (sea level to ~1600 m). These environmental parameters may influence blood viscosity, sensor calibration, and pump controller behavior during actual clinical use.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-lab-hemolysis",
      "type": "ValidationResult",
      "name": "Laboratory hemolysis index validation — 5 flow-speed operating points",
      "description": "Experimental hemolysis measurements conducted in a controlled laboratory environment at 22°C ambient temperature and standard atmospheric pressure (101.3 kPa). Five flow-speed combinations (2–6 L/min; 2000–4000 RPM) were tested using fresh bovine blood. Relative hemolysis index computed for each operating point and compared against CFD predictions. All five operating points yielded RH < 1 relative to predicate device. No testing was performed at temperatures outside 22 ± 0.5°C, under reduced or elevated ambient pressure, or in the presence of electromagnetic interference representative of surgical suite conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-mesh-sensitivity",
      "type": "ValidationResult",
      "name": "Mesh sensitivity and discretization error quantification",
      "description": "Grid convergence index (GCI) study performed across three mesh refinement levels (coarse 1.2M, medium 3.8M, fine 9.4M cells). GCI for shear-stress-based hemolysis power law quantity of interest was 2.1% on the fine mesh, meeting the MRL 2 discretization error requirement. Study conducted using same laboratory boundary conditions (22°C, 101.3 kPa) as the primary validation experiments."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-code-verification",
      "type": "ValidationResult",
      "name": "Numerical code verification against analytical Couette flow benchmark",
      "description": "ANSYS Fluent v2023R2 verified against analytical Couette flow solution for viscous incompressible flow. L2 norm of velocity error converged at second-order rate consistent with solver documentation. Software quality assurance records confirm version-controlled simulation scripts and peer-reviewed input decks."
    }
  ],
