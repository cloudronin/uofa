  "name": "Morrison COU1 — CPB hemolysis credibility assessment (ML surrogate)",
  "description": "V&V 40 credibility assessment for a neural-network surrogate model used to predict pump-induced hemolysis for the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the ML surrogate can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. A feedforward neural network was trained on CFD-generated hemolysis data to enable rapid sensitivity sweeps across component-dimension variations. Full 13-factor assessment is reported; all assessed factors meet required levels. A single training run was performed and point-estimate performance metrics are reported as the basis for acceptance.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/ml-hemolysis-surrogate-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/ml-hemolysis-surrogate-claim-001",
  "bindsModel": "https://uofa.net/synth/model/feedforward-nn-hemolysis-surrogate-v1",
