  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). The COU narrative further specifies that the model must demonstrate that predicted hemolysis indices remain valid only when impeller tip speed does not exceed 6.5 m/s, a critical safety threshold identified during hazard analysis to prevent catastrophic erythrocyte destruction under worst-case bypass flow conditions.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou1-req-set-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou1-claim-001",
