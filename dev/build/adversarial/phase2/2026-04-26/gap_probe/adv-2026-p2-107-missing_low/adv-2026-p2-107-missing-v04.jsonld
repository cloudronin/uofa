    "https://uofa.net/synth/data/morrison-cfd-mesh-dataset-001"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2. The context of use explicitly requires that all simulated operating points remain below an impeller tip speed of 6.5 m/s to ensure the hemolysis predictions remain within the validated flow regime and to satisfy the device safety boundary established in the hazard analysis.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-val-rh-index-001",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against FDA benchmark experimental data",
      "description": "CFD-predicted RH values compared against published FDA benchmark measurements across 5 flow-speed operating points. All predicted RH values < 1.0 relative to predicate device. Mean absolute error 4.2%. Validation conducted at flow rates 2–6 L/min and rotational speeds 2000–3500 RPM."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-val-mesh-convergence-001",
