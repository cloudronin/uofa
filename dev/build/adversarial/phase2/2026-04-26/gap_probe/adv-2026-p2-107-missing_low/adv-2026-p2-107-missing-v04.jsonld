  "uofa:requirement": {
    "id": "https://uofa.net/synth/req/morrison-cou1-req-set-001",
    "type": "Requirement",
    "name": "Morrison COU1 Requirement Set — CFD Hemolysis Prediction",
    "description": "Requirements binding the CFD hemolysis prediction model for the CPB COU: (1) The model shall predict relative hemolysis index RH with mean absolute error not exceeding 10% compared to FDA benchmark experimental data. (2) The model shall be executed using a mesh with GCI < 5% for the primary quantity of interest. (3) The model shall use boundary conditions consistent with the clinical operating envelope of 2–6 L/min flow rate and 2000–3500 RPM rotational speed. (4) All simulation results shall be traceable to a version-controlled model configuration under institutional software QA protocol.",
    "version": "1.0",
    "approvedBy": "https://uofa.net/synth/actor/morrison-credibility-team"
  },
