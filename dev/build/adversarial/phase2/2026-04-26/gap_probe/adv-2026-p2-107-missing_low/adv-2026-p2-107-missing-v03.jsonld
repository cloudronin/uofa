  "uofa:hasRequirement": {
    "id": "https://uofa.net/synth/req/morrison-cou1-req-001",
    "type": "Requirement",
    "name": "Morrison COU1 CFD Hemolysis Assessment Requirements",
    "description": "The computational model shall predict the relative hemolysis index (RH) for the FDA generic centrifugal blood pump across the five specified flow-speed operating points. The model shall demonstrate RH < 1 relative to the predicate device at the worst-case operating condition. The simulation shall use boundary conditions consistent with the experimental validation dataset within ±5% tolerance. Mesh convergence shall be demonstrated with GCI < 5% on the fine mesh for the primary quantity of interest."
  },
