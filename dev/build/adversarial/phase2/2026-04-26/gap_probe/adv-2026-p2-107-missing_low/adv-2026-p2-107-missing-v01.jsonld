  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately not assessed at MRL 2 with justification documented. The CFD model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index predictions fall within acceptance criteria across all five operating points. The overall evidence package supports the regulatory submission claim that the subject device hemolysis index is below the predicate comparator (RH < 1) under worst-case conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
  "uofa:requirement": {
    "id": "https://uofa.net/synth/req/morrison-cpb-req-set-001",
    "type": "Requirement",
    "name": "Morrison CPB CFD Model Requirements",
    "description": "Requirements governing the credibility of the CFD hemolysis model for the CPB COU. REQ-01: The model shall predict relative hemolysis index with deviation no greater than 15% from experimental reference values across all evaluated operating points. REQ-02: The computational mesh shall achieve a grid convergence index below 5% for the hemolysis index quantity of interest on the production mesh. REQ-03: All simulation boundary conditions shall replicate experimental test conditions within 2% of nominal values for flow rate and rotational speed. REQ-04: The software platform shall be a commercially validated CFD solver with a documented regression test suite."
  },
