  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model is accepted for the CPB COU because the relative hemolysis index threshold (RH < 1) was satisfied at all five evaluated operating points. The RH < 1 criterion is the established FDA acceptance benchmark for Class II blood-contacting devices, and its satisfaction constitutes sufficient evidence that the model supports a safe and credible design decision. Since RH < 1 has been demonstrated across the full operating envelope, no further safety argument is required: the threshold check alone establishes that the model output is adequate for regulatory submission and that worst-case hemolysis conditions are acceptably bounded. The six not-assessed credibility factors (model form, model inputs, use error, numerical solver error, test samples, and equivalency of input parameters) do not affect this conclusion because the RH threshold was met regardless of their status.",
