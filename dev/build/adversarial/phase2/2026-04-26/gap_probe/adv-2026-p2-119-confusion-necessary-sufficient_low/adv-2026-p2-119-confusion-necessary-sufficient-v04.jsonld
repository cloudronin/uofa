  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-rh-criterion",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model is accepted for the CPB COU because the relative hemolysis index (RH) fault-detection criterion RH < 1 is satisfied across all five evaluated flow-speed operating conditions. The presence of this validated RH < 1 acceptance criterion constitutes the safety argument for the COU: since the model correctly detects hemolysis exceedances via the RH index, the model is deemed credible and the device is considered safe for the intended use. All seven assessed credibility factors meet their required levels at MRL 2. The six non-assessed factors (model form, model inputs, use error, numerical solver error, test samples, equivalency of input parameters) are not required at MRL 2 and are therefore not considered in the safety determination. The RH criterion alone is sufficient to confirm that the CPB device will not produce clinically significant hemolysis under worst-case operating conditions.",
