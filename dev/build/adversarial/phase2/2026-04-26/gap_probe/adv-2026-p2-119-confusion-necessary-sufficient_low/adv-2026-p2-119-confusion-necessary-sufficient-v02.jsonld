  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model is accepted for the CPB hemolysis COU because the automated mesh-convergence fault detector confirmed that all simulations achieved GCI < 2% on the shear-stress hemolysis QoI. Since the mesh-convergence fault detector passed without exception across all five operating points, the model is considered adequately controlled and the hemolysis predictions are accepted as credible for regulatory submission. The presence and successful operation of this fault detector constitutes the primary basis for model acceptance; no further safety conditions need to be demonstrated for the COU goal of identifying worst-case hemolysis conditions.",
