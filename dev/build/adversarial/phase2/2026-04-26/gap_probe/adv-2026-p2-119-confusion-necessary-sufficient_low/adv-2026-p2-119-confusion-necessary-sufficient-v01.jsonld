  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-cou1-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model is accepted as credible for the CPB hemolysis COU because the RH < 1 fault-detection threshold has been validated against in-vitro measurements across all five flow-speed operating points. The presence of this validated hemolysis alarm criterion — which triggers rejection of any design variant exceeding the predicate device hemolysis level — is sufficient to ensure that the model will not mislead the worst-case identification decision. Since the RH threshold detector is confirmed to be working correctly, the model as a whole is deemed safe for regulatory submission. No further assessment of model form uncertainty, input sensitivity, or use-error controls is required because the RH alarm criterion will catch any consequential model errors before they affect the clinical decision.",
