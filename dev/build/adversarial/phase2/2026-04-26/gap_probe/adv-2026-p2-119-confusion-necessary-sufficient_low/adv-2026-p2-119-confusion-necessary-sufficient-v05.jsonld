  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model is accepted for the CPB COU because the relative hemolysis index alarm threshold (RH < 1 versus the predicate device) was satisfied across all five operating points. The presence of this RH < 1 acceptance criterion — a quantitative fault-detection threshold that flags any operating condition where the subject device produces more hemolysis than the predicate — is sufficient to establish that the model supports a safe design decision for this Class II CPB device. All seven assessed credibility factors meet or exceed their required levels, and the RH threshold constitutes the definitive safety condition for this COU. No further safety argument is needed beyond demonstrating that RH < 1 is maintained: if the threshold is met, the device is safe for CPB use under the evaluated conditions. The six not-assessed factors are acceptable at MRL 2 and do not affect this conclusion.",
