  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump is accepted for the CPB COU at Model Risk Level 2. All seven assessed credibility factors meet or exceed their required gradation levels. The model has been exercised across 25 simulation cases spanning the full clinical operating envelope, and no failure modes have been observed in any of these executions. No contraindications to model reliability have been reported in the literature for this class of rotating blood pump simulation at the Reynolds numbers of interest. The turbulence and hemolysis sub-models have been applied in analogous regulatory submissions without issue, and we have not encountered any anomalous predictions or convergence difficulties during this study. On this basis, the assessment team is satisfied that the model is sufficiently credible to support identification of worst-case hemolysis operating conditions and comparison against the predicate device using the RH < 1 acceptance criterion.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
