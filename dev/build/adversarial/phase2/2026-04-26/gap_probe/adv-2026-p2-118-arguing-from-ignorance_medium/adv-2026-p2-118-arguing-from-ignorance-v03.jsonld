  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Model Risk Level 2. All seven assessed credibility factors meet or exceed their required levels. The CFD model of the FDA generic centrifugal blood pump demonstrates adequate predictive accuracy for hemolysis index QoIs within the COU operating envelope. Critically, throughout the conduct of this assessment and the supporting simulation campaign, no failure modes have been observed that would undermine confidence in the model's suitability for identifying worst-case hemolysis operating conditions. No contraindications have been encountered during the application of the selected turbulence and hemolysis sub-models to this device class, and we have not encountered any issues with numerical stability or convergence across the five operating points evaluated. On this basis, the model is judged credible for its intended use, and the decision to accept the simulation results as supporting evidence for the Class II CPB device submission is affirmed.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
