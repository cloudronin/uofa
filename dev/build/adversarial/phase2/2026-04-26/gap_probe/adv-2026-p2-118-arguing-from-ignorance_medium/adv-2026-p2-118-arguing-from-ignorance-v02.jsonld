  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump is accepted for use in COU1 at Model Risk Level 2. All seven assessed credibility factors meet or exceed their required levels: discretization error GCI is 3.2%, output comparison error is within 14.3% of experimental measurements, and model form selections are consistent with published practice for rotating blood-contacting devices. The six non-assessed factors are acceptable per ASME V&V 40 Table 4 at MRL 2. Critically, no failure modes have been observed during the conduct of this assessment — no simulation divergence events, no anomalous hemolysis predictions outside expected physical bounds, and no contraindications to the chosen turbulence or hemolysis model forms have been reported by the assessment team. Throughout the full range of operating conditions evaluated (5 flow-speed combinations), the model has not encountered any issues that would call into question its predictive fidelity. On this basis, the model is judged credible for identifying worst-case hemolysis operating conditions and the COU1 decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
