  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control and build verification records exist for the CFD solver used.",
      "rationale": "ANSYS Fluent 2022R2 is used under institutional license with version-controlled case files stored in a git repository. Release notes and regression test suite documentation are available from the vendor. No contraindications to software integrity have been reported in the project records, and the assessment team has not encountered any issues with solver behavior that would call software quality into question."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes at least one published benchmark for rotating-frame Navier-Stokes flow.",
      "rationale": "The solver has been verified against the Taylor-Couette flow benchmark and the lid-driven cavity problem. No failure modes have been observed across these test cases. Published verification reports from the vendor confirm expected order-of-accuracy behavior for the finite-volume discretization scheme employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) less than 5% for the relative hemolysis index QoI on the production mesh.",
      "rationale": "A three-level mesh refinement study was performed on the nominal pump geometry at the 5 L/min, 2500 RPM operating point. GCI values of 3.1%, 2.8%, and 2.4% were computed for coarse-to-medium, medium-to-fine, and extrapolated fine meshes respectively. The production mesh (9.2 million cells) achieves GCI of 2.8%, satisfying the acceptance criterion. No failure modes have been observed in the convergence behavior across operating points examined."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rate) match simulation boundary conditions within stated uncertainty bounds.",
      "rationale": "Experimental measurements used for validation were conducted with porcine blood at 37°C with hematocrit 35±2%. CFD boundary conditions replicate these conditions: viscosity 0.0035 Pa·s, density 1050 kg/m³. Rotational speed was set to within ±10 RPM of experimental values. Flow rates were matched to within ±0.1 L/min. No discrepancies between test and simulation conditions have been reported by the experimental team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index agrees with experimental measurements within ±15% across all five validation operating points.",
      "rationale": "Predicted RH index values at all five operating points fall within 9.3% of experimental measurements. Pressure-head predictions agree within 4.7%. The model consistently under-predicts hemolysis by a small margin at high-shear conditions, which is conservative for the intended acceptance criterion of RH < 1. No failure modes have been observed in the output comparison that would indicate systematic model bias beyond acceptable bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical hemolysis metrics used in the regulatory submission.",
      "rationale": "The relative hemolysis index (RH) is the primary QoI and maps directly to the ASTM F1841 normalized index of hemolysis used in the regulatory submission. Secondary QoIs include scalar stress exposure and volume-weighted shear stress distributions. These quantities are well-established in the blood-contacting device simulation literature and align with FDA guidance on hemolysis prediction. The assessment team has not encountered any issues with QoI relevance in prior regulatory interactions for comparable devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the operating envelope defined in the COU (flow rates 3–7 L/min, speeds 2000–3000 RPM).",
      "rationale": "Validation experiments were conducted at five operating points spanning the COU envelope: (3 L/min, 2000 RPM), (5 L/min, 2500 RPM), (7 L/min, 3000 RPM), and two intermediate points. Pump geometry used in validation is geometrically similar to the production device within stated manufacturing tolerances. No failure modes have been observed that would indicate the validation domain is insufficient to support extrapolation to the full COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error assessment is not required at Model Risk Level 2 for this factor classification. Scoped out per MRL 2 assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 for this factor classification. Scoped out per MRL 2 assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions for turbulence closure and hemolysis power-law correlation are justified by literature and sensitivity analysis.",
      "rationale": "The SST k-omega turbulence model is selected based on prior published comparisons for rotary blood pump simulations. The Giersiepen-Wurzinger power-law hemolysis model is applied with published coefficients. Sensitivity analyses comparing the Giersiepen-Wurzinger and Zhang hemolysis models show less than 12% difference in RH predictions at the worst-case operating point. No failure modes have been observed in model form selection that would indicate the chosen formulation is inappropriate for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and boundary conditions are sourced from traceable measurements with documented uncertainty.",
      "rationale": "Blood viscosity and density are taken from direct measurements of the porcine blood used in validation experiments, with uncertainties of ±3% and ±0.5% respectively. Pump geometry is derived from CMM-verified CAD with dimensional uncertainty of ±0.05 mm. Inlet velocity profiles are derived from Doppler ultrasound measurements. No failure modes have been observed in input parameter specification across the five operating conditions assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
