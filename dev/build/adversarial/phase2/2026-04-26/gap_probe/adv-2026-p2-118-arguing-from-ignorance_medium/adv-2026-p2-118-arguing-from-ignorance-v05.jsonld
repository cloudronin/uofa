  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accept-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for CPB hemolysis prediction is accepted for use in the COU based on satisfactory performance across all seven assessed credibility factors at MRL 2. Critically, no failure modes have been observed in any aspect of the model's behavior across the validation campaign, and no contraindications to model acceptance have been reported by any member of the assessment team. The model has not exhibited any issues with numerical stability, output agreement, or input fidelity. Because no evidence of model inadequacy has been identified through the course of this assessment, the model is considered credible for the intended decision context. All assessed factors meet or exceed their required credibility levels, and the six factors not assessed are acceptable at MRL 2 per the ASME V&V 40 framework. The relative hemolysis index predictions satisfy the RH < 1 acceptance criterion at all five worst-case operating points. The decision to accept is therefore supported by the complete absence of any identified concerns across the credibility evidence gathered.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
