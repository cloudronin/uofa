  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted for use in the CPB COU at Model Risk Level 2. All seven assessed credibility factors meet or exceed their required levels. The remaining six factors were not assessed in accordance with MRL 2 requirements. Critically, throughout the full assessment process and across all simulation campaigns conducted to date — spanning multiple operating conditions, mesh configurations, and analyst teams — no failure modes have been observed that would call into question the predictive fidelity of the model. No contraindications have been reported by any team member or reviewer, and we have not encountered any anomalies in solver behavior, output trends, or comparison metrics that would suggest systematic model deficiency. On this basis, the model is considered credible for its intended use and the decision to accept is warranted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
