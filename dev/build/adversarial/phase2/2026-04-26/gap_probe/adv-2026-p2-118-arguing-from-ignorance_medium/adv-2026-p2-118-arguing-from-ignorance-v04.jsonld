  "signature": "ed25519:9b2e4f1a7c3d5e8b0f2a4c6d8e0b2f4a6c8d0e2f4b6a8c0d2e4f6a8b0c2d4e6f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be commercially licensed with documented version control and regression testing at Gradation 1.",
      "rationale": "ANSYS Fluent 2022 R2 is used under a validated commercial license. Version control records confirm solver version consistency across all simulation runs. Regression test suite results are archived in the project repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at Gradation 1.",
      "rationale": "ANSYS Fluent has been verified against standard CFD benchmark cases including lid-driven cavity and backward-facing step flows. Published verification documentation accompanies the commercial release and is referenced in the project technical file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate discretization error below 5% for hemolysis index QOI across at least three mesh refinement levels.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 2.1M, 5.8M, and 14.2M cells. Richardson extrapolation yielded a grid convergence index (GCI) of 2.3% for the scalar stress-based hemolysis index at the 5 L/min, 2500 RPM operating point. The 5.8M cell mesh was selected for production runs, providing acceptable accuracy at manageable computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulated operating conditions within documented tolerances for flow rate (±0.2 L/min) and rotational speed (±25 RPM).",
      "rationale": "Bench hemolysis experiments were conducted at the same 5 flow-speed combinations used in simulation. Measured flow rates were within ±0.15 L/min and rotational speeds within ±18 RPM of nominal values. Blood analog fluid (glycerin-water mixture) viscosity was matched to physiological blood viscosity at 37°C within 3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated hemolysis index must agree with experimental measurements within 15% across all 5 operating points.",
      "rationale": "Simulated normalized index of hemolysis (NIH) values were compared against experimental measurements at all 5 operating points. Maximum deviation was 11.4% at the 6 L/min, 3000 RPM condition. Mean absolute percentage error across all points was 7.2%, satisfying the 15% acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOI (relative hemolysis index RH) must be directly linked to the clinical endpoint of erythrocyte damage and must be computable from CFD outputs.",
      "rationale": "The relative hemolysis index RH is computed from scalar stress exposure integrated along Lagrangian particle trajectories, directly reflecting cumulative erythrocyte membrane loading. This QOI has established precedent in FDA guidance and peer-reviewed literature as a surrogate for clinical hemolysis risk. The linkage between RH and clinical plasma-free hemoglobin levels is supported by the Giersiepen power-law model calibrated against in vitro data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating range, and fluid properties as the COU, with documented similarity assessment.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal blood pump geometry, identical to the device geometry used in the COU simulations. Operating conditions span the full clinical CPB range (3–6 L/min, 2000–3500 RPM). Blood analog fluid properties were matched to physiological conditions. The validation domain therefore encompasses the COU operating space without extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; commercial solver documentation is deemed sufficient.",
      "rationale": "At Model Risk Level 2, explicit numerical solver error quantification beyond that provided by the commercial software vendor documentation is not required. ANSYS Fluent solver residual convergence criteria of 1e-5 were applied uniformly across all simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst qualification records are documented in the project technical file.",
      "rationale": "At Model Risk Level 2, formal use error assessment is not required. Lead analysts hold doctoral-level training in computational fluid dynamics and have completed internal CFD credibility training. Simulation setup was reviewed by a second qualified analyst prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; model form selection is documented with literature justification.",
      "rationale": "The SST k-omega turbulence model was selected based on published literature demonstrating superior performance for rotating machinery flows with adverse pressure gradients. The Giersiepen hemolysis power-law model is the standard formulation used in FDA-cited studies. Formal model form uncertainty quantification is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values are documented with sources.",
      "rationale": "Fluid density (1056 kg/m³) and dynamic viscosity (0.0035 Pa·s) are drawn from published physiological data. Pump geometry is taken from the FDA benchmark model repository. Boundary conditions (inlet flow rate, outlet pressure, rotational speed) are specified per the COU operating matrix. Formal sensitivity analysis of input uncertainty is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; experimental sample provenance is documented.",
      "rationale": "Validation experiments used bovine blood sourced from a certified supplier, consistent with FDA hemolysis testing guidance. Sample lot numbers and storage conditions are recorded in the experimental data package. Statistical characterization of inter-sample variability is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
