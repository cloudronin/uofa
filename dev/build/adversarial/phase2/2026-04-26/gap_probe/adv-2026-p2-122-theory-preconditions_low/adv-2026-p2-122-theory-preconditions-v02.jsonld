      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, velocity magnitude) are directly linked to the decision QoI (relative hemolysis index RH).",
      "rationale": "NIH is the primary hemolysis metric and directly maps to the relative hemolysis index RH used in the COU acceptance criterion (RH < 1). Velocity field validation supports confidence in the shear stress predictions that drive the power-law damage model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
