      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal pump geometry under overlapping operating conditions with the COU envelope.",
      "rationale": "Validation data collected on the FDA generic pump at 2500 RPM and 3.5 L/min, which lies within the COU operating envelope of 2000–3500 RPM and 2.5–6 L/min. Geometry is identical to the COU device. Validation conditions are representative of the intended use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error beyond discretization error is not required to be separately assessed at Model Risk Level 2 for this factor category. Residual convergence to 1e-5 for all equations confirmed in all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment not required at MRL 2. Simulation setup reviewed by a second analyst for consistency with documented simulation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection (turbulence model, hemolysis damage model) justified by literature evidence and sensitivity analysis.",
      "rationale": "SST k-omega turbulence model selected based on prior FDA pump benchmark studies demonstrating superior near-wall shear stress prediction. Giersiepen-Wurzinger power-law hemolysis model applied; this formulation assumes that RBC damage accumulates linearly and independently across fluid sub-volumes (linear additivity of stress exposure history), a theoretical precondition required for the scalar transport integration approach to yield physically meaningful NIH values. This assumption is standard in CFD hemolysis literature and is adopted here without modification. Sensitivity to power-law exponents alpha and beta assessed via ±10% parameter variation, yielding NIH variation of ±12%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model input uncertainty quantification not required at MRL 2. Nominal fluid properties and boundary conditions sourced from experimental measurement reports with documented traceability."
    },
    {
