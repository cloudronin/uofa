      "rationale": "ANSYS Fluent 2022R2 employed with vendor-supplied verification suite. Simulation input files stored under Git version control with tagged release corresponding to this study. Software QA requirements for MRL 2 are satisfied at Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases relevant to rotating turbomachinery flows.",
      "rationale": "ANSYS Fluent passes the FDA nozzle benchmark and rotating disk benchmark cases documented in the vendor verification manual. No custom solver modifications were made."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
