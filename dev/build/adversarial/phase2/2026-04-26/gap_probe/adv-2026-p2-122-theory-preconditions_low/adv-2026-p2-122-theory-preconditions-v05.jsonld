  "name": "Morrison COU1 — CPB hemolysis credibility assessment (theory-preconditions gap)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. The hemolysis sub-model (Giersiepen-Wurzinger power-law) is applied under the theoretical precondition that the relationship between shear stress and exposure time is linear in log-space (i.e., the power-law exponents derived from Couette-flow calibration data remain valid across the turbulent, recirculating flow regimes present in the CPB pump). This linearity assumption is stated explicitly in the model narrative but no validation result in this package tests whether the assumption holds for the COU operating regime.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-worst-case-identification",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-cfd-hemolysis-credible-mrl2",
  "bindsModel": "https://uofa.net/synth/model/giersiepen-wurzinger-powerlaw-cfd",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-cpb-pump-geometry",
    "https://uofa.net/synth/data/cpb-operating-conditions-5-flowspeed-combos",
    "https://uofa.net/synth/data/predicate-device-hemolysis-index"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
