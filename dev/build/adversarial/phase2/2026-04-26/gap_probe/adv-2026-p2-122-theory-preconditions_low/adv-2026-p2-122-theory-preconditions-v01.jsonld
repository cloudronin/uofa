  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-sim-lab-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, which is acceptable under ASME V&V 40 for Model Risk Level 2. The CFD model reliably predicts the relative hemolysis index RH across the CPB operating envelope, and the acceptance criterion RH < 1 is met at all five evaluated operating points. The power-law hemolysis model is considered appropriate for this application; the IID linearity precondition underlying the damage integral formulation is acknowledged in the model form rationale and is accepted without additional verification, consistent with current practice for MRL 2 assessments. The overall credibility evidence supports acceptance of the CFD model for the stated COU.",
