  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-rmse-aggregate",
      "type": "ValidationResult",
      "name": "Aggregate RMSE and R² across five operating points",
      "description": "Validation of the CFD hemolysis model against experimental normalized index of hemolysis (NIH) measurements from the FDA generic centrifugal blood pump test dataset. The model achieves an aggregate RMSE of 0.0042 g/100 L and R² = 0.94 across all five flow-speed operating points (2.5 L/min at 2000 RPM, 3.5 L/min at 2500 RPM, 4.5 L/min at 3000 RPM, 5.5 L/min at 3500 RPM, 6.0 L/min at 4000 RPM). Pearson correlation between predicted and measured NIH values is r = 0.97. These statistics confirm strong overall model fidelity to experimental data and support the conclusion that the CFD model is well-validated for hemolysis prediction under CPB operating conditions. The high R² value demonstrates that the model captures the dominant variance in hemolysis across the operating envelope, providing confidence that the simulation results are suitable for regulatory decision-making.",
      "metricName": "RMSE, R², Pearson r",
      "metricValue": "RMSE=0.0042 g/100L; R²=0.94; r=0.97",
      "validationDataset": "https://uofa.net/synth/data/fda-gcbp-experimental-hemolysis-dataset",
      "validationScope": "All five flow-speed operating points pooled"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-wall-shear-rmse",
      "type": "ValidationResult",
      "name": "Wall shear stress field RMSE versus PIV benchmark",
      "description": "Secondary validation comparing CFD-predicted wall shear stress distributions against particle image velocimetry (PIV) measurements from the FDA benchmark study. Aggregate RMSE of 0.87 Pa across the impeller passage cross-sections and R² = 0.91 for the shear stress magnitude distribution. These results demonstrate that the turbulence model (SST k-ω) accurately reproduces the flow structures responsible for erythrocyte damage. Because shear stress is the primary driver of the hemolysis power-law model, good agreement in shear stress fields is interpreted as corroborating evidence that NIH predictions are mechanistically sound across the full operating range.",
      "metricName": "RMSE (wall shear stress), R²",
      "metricValue": "RMSE=0.87 Pa; R²=0.91",
      "validationDataset": "https://uofa.net/synth/data/fda-gcbp-experimental-hemolysis-dataset",
      "validationScope": "Impeller passage cross-sections, pooled across operating points"
    }
  ],
