  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-rmse-aggregate",
      "type": "ValidationResult",
      "name": "Aggregate RMSE across all operating points — hemolysis index prediction",
      "description": "Validation of the CFD hemolysis model was performed by comparing predicted normalized index of hemolysis (NIH) values against in-vitro measurements across all 5 flow-speed operating conditions pooled together. Aggregate root-mean-square error (RMSE = 0.0031 g/100 L) and coefficient of determination (R^2 = 0.94) were computed over the full operating envelope. These statistics demonstrate strong overall predictive fidelity and are considered sufficient to support the model's use in identifying hemolysis trends. The R^2 value in particular confirms that the model captures the dominant variance in hemolysis across the tested conditions, providing confidence that the CFD approach is well-calibrated. Worst-case operating point identification was not separately validated; aggregate metrics were judged representative of model performance across the design space.",
      "metricName": "RMSE and R^2 (aggregate, pooled across all operating conditions)",
      "metricValue": "RMSE = 0.0031 g/100 L; R^2 = 0.94",
      "validationDataset": "https://uofa.net/synth/data/morrison-fda-pump-experimental-hemolysis",
      "validationScope": "All 5 flow-speed combinations pooled; no stratification by operating point rank"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-pearson-trend",
      "type": "ValidationResult",
      "name": "Pearson correlation of predicted vs. measured NIH across operating envelope",
      "description": "Pearson correlation coefficient between CFD-predicted and experimentally measured NIH values was computed across the 5 operating conditions (r = 0.97, p < 0.001). This high correlation indicates that the model reliably tracks hemolysis trends as flow rate and rotational speed vary. The correlation analysis was performed on mean NIH values at each condition, confirming that the model's rank ordering of hemolysis severity is broadly consistent with experiment. This metric was selected as the primary validation evidence because it is widely reported in the CFD hemolysis literature and provides an intuitive measure of model fidelity. The analysis does not explicitly confirm whether the model correctly identifies the single worst-case condition (maximum NIH operating point) as required by the COU acceptance criterion (RH < 1), but the high correlation coefficient is interpreted as supporting overall model reliability.",
      "metricName": "Pearson correlation coefficient (r)",
      "metricValue": "r = 0.97, p < 0.001",
      "validationDataset": "https://uofa.net/synth/data/morrison-fda-pump-experimental-hemolysis",
      "validationScope": "Mean NIH at each of 5 operating conditions; worst-case rank accuracy not assessed"
    }
  ],
