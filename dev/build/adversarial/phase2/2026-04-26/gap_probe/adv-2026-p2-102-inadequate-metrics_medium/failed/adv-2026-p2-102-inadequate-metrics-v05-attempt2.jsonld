  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-aggregate-rmse-r2",
      "type": "ValidationResult",
      "name": "Aggregate RMSE and R² across all operating points",
      "description": "Validation was performed by comparing CFD-predicted normalized index of hemolysis (NIH) values against experimental measurements at all five flow-speed operating points simultaneously. The aggregate root-mean-square error (RMSE) across the five points was 0.0031 g/100 L, and the Pearson R² was 0.97, indicating excellent overall predictive fidelity. These metrics were computed over the full operating envelope and are consistent with published benchmarks for CFD hemolysis models. The high R² value and low RMSE confirm that the model tracks experimental NIH values closely across the tested range, supporting the conclusion that the model is validated for CPB hemolysis prediction at MRL 2.",
      "metricName": "RMSE; Pearson R²",
      "metricValue": "RMSE = 0.0031 g/100 L; R² = 0.97",
      "validationDataset": "https://uofa.net/synth/data/fda-cpb-experimental-hemolysis-dataset",
      "validationMethod": "Point-by-point comparison of CFD NIH predictions versus bench-top loop experimental NIH measurements at five flow-speed combinations; aggregate statistics computed across all points"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-rh-acceptance-check",
      "type": "ValidationResult",
      "name": "Relative hemolysis index acceptance criterion check",
      "description": "The relative hemolysis index (RH) was computed for the nominal design geometry by dividing the maximum CFD-predicted NIH by the predicate device NIH. The resulting RH = 0.84 satisfies the acceptance criterion RH < 1. This check was performed at the nominal worst-case operating point as identified by the aggregate RMSE-optimized model. No sensitivity analysis of RH across the full five-point operating envelope was performed to confirm that the CFD model correctly identifies the true worst-case point rather than a local minimum of prediction error.",
      "metricName": "Relative Hemolysis Index (RH)",
      "metricValue": "RH = 0.84 (nominal worst-case point only)",
      "validationDataset": "https://uofa.net/synth/data/morrison-cfd-output-five-operating-points",
      "validationMethod": "Single-point RH calculation at model-identified worst-case; worst-case identification itself relies on aggregate RMSE minimization rather than rank-order validation of extremal predictions"
    }
  ],
