  "bindsDataset": [
    "https://uofa.net/synth/data/fda-centrifugal-pump-piv-experimental",
    "https://uofa.net/synth/data/morrison-hemolysis-bench-measurements"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-aggregate-rmse-hemolysis",
      "type": "ValidationResult",
      "name": "Aggregate RMSE and R² validation — normalized index of hemolysis",
      "description": "Predicted normalized index of hemolysis (NIH) values were compared against bench-measured NIH at all five flow-speed operating points. Aggregate root-mean-square error (RMSE) across the five points was 0.0043 g/100 L, and the Pearson R² between predicted and measured NIH was 0.964. These statistics indicate strong overall agreement between the CFD model and experimental data and are used as the primary evidence of validation adequacy. Because the R² exceeds the project threshold of 0.90 and RMSE falls below the acceptance band of 0.010 g/100 L, the model is judged validated for the CPB use case. The aggregate metrics are considered representative of model performance across the operating envelope, supporting the acceptance decision."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-pearson",
      "type": "ValidationResult",
      "name": "Pearson correlation of velocity field predictions vs. PIV measurements",
      "description": "Particle image velocimetry (PIV) measurements from the FDA benchmark dataset were used to assess CFD velocity field accuracy. Pearson correlation coefficients for axial and radial velocity components in the impeller region were 0.981 and 0.973, respectively. Mean absolute error in velocity magnitude was 0.08 m/s across all measurement planes. These results confirm that the turbulent flow solver captures the bulk velocity field with high fidelity, providing confidence in the underlying flow physics. Correlation statistics were computed over all spatial grid points in the measurement domain, yielding a single aggregate correlation value reported as the validation metric."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-rh-trend-agreement",
      "type": "ValidationResult",
      "name": "Relative hemolysis index trend agreement across operating points",
      "description": "The relative hemolysis index (RH) was computed at each of the five flow-speed combinations and compared qualitatively against predicate device measurements. The CFD model correctly predicts the monotonic trend of increasing RH with decreasing flow rate. Quantitative comparison is summarised by the aggregate RMSE of RH values (0.031, dimensionless) and an R² of 0.951 across the five points. These aggregate statistics are cited as evidence that the model is suitable for the COU. Note: the specific operating point yielding the maximum RH (worst-case condition) is not individually validated against an independent experimental measurement; the aggregate fit is assumed to imply correctness of the extremum."
    }
  ],
