    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-aggregate-rmse",
      "type": "ValidationResult",
      "name": "Aggregate RMSE and R-squared validation against experimental hemolysis data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against experimental measurements from the FDA generic centrifugal pump benchmark across all five flow-speed operating points pooled together. Aggregate root-mean-square error (RMSE) of 0.0023 mg/100L and Pearson R-squared of 0.94 were achieved across the pooled dataset. These statistics demonstrate strong overall agreement between simulation and experiment and are reported as the primary validation metric supporting model credibility for the CPB hemolysis COU. The R-squared value confirms that 94% of the variance in measured NIH is explained by the CFD model across the operating envelope.",
      "metricName": "RMSE, R-squared (Pearson)",
      "metricValue": "RMSE = 0.0023 mg/100L; R² = 0.94 (pooled across all 5 operating points)",
      "acceptanceCriteria": "RMSE < 0.005 mg/100L and R² > 0.90 across pooled operating points",
      "status": "passed",
      "comparedAgainst": "FDA generic centrifugal pump experimental NIH dataset (n=5 operating conditions, pooled)"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-rh-comparison",
      "type": "ValidationResult",
      "name": "Relative Hemolysis Index (RH) comparison against predicate device",
      "description": "Relative hemolysis index (RH) was computed as the ratio of predicted NIH for the subject device to the predicate device NIH at the nominal operating point (3 L/min, 3500 RPM). The computed RH of 0.87 satisfies the RH < 1 acceptance criterion at the nominal condition. This result is presented alongside the aggregate RMSE and R-squared statistics as corroborating evidence that the model produces credible hemolysis predictions. The validation evidence package is considered sufficient to support the COU decision at MRL 2.",
      "metricName": "Relative Hemolysis Index (RH) at nominal operating point",
      "metricValue": "RH = 0.87 at nominal condition (3 L/min, 3500 RPM)",
      "acceptanceCriteria": "RH < 1.0 at nominal operating point",
      "status": "passed",
      "comparedAgainst": "Predicate device NIH at nominal operating condition"
    }
