  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-001-grid-independence",
      "type": "ValidationResult",
      "name": "Grid independence study — nominal completion",
      "description": "Three mesh refinement levels (4.2M, 9.7M, 18.1M cells) were run at the design operating point (5 L/min, 3000 RPM). Solver completed normally on all three levels. Richardson extrapolation yielded a discretisation error estimate of 2.3% on RH. The single restart event during coarse-mesh execution was logged as an HPC I/O anomaly and excluded from the convergence analysis. No investigation was conducted into whether the restart reflected a numerical edge case in the damage transport solver.",
      "outcome": "Accepted",
      "completionStatus": "nominal"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-002-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison — nominal completion",
      "description": "CFD-predicted RH values were compared against in-vitro hemolysis measurements for the FDA generic centrifugal blood pump across five operating points. All five CFD runs completed without solver interruption. Predicted RH ranged from 0.61 to 0.94 against measured values of 0.58 to 0.91; mean absolute error 4.8%. Validation activities were conducted exclusively at well-conditioned operating points where shear stress magnitudes are moderate and the damage exponent remains within the validated range of the Power-Law model. Near-stall and runout conditions, where the hemolysis transport equation is known to produce near-zero or very large shear arguments, were not included.",
      "outcome": "Accepted",
      "completionStatus": "nominal"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-003-sensitivity-sweep",
      "type": "ValidationResult",
      "name": "Geometric tolerance sensitivity sweep — nominal completion",
      "description": "A 25-case design-of-experiments sweep varying impeller tip clearance (±0.1 mm), volute gap (±0.15 mm), and inlet chamfer angle (±2°) was executed using the parallelised OpenFOAM pipeline. All 25 cases completed with L2 residual below 1×10⁻⁵. The OpenMP-parallelised global damage accumulator reduction was not independently verified for thread-safety; all sweep cases ran on 16 cores and reported internally consistent RH values, which was taken as sufficient evidence of correctness. No cases were run at thread counts that would stress the reduction logic under high contention.",
      "outcome": "Accepted",
      "completionStatus": "nominal"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-004-predicate-comparison",
      "type": "ValidationResult",
      "name": "Predicate device relative hemolysis comparison — nominal completion",
      "description": "RH values for the candidate device geometry were compared against predicate device CFD results at the five regulatory operating points. All candidate and predicate simulations completed nominally. RH < 1 criterion satisfied at all five points (range 0.72–0.96). Floating-point behaviour of the exponentiated damage integral was not characterised; all operating points fell within the mid-range of impeller speeds where overflow risk is low.",
      "outcome": "Accepted",
      "completionStatus": "nominal"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver code with documented build and test procedures; regression test suite passing for standard benchmark cases.",
      "rationale": "OpenFOAM 9 is maintained under Git version control with a documented release process. The project-specific hemolysis transport library was version-controlled and subject to unit tests covering the Power-Law damage model under nominal shear inputs. Regression tests confirmed expected RH outputs for the Bludszuweit benchmark. Software quality assurance activities did not include fault-injection testing, boundary-value testing at degenerate shear inputs, or concurrency stress testing of the OpenMP reduction routines. The SQA programme is therefore assessed as meeting MRL 2 requirements for a commercial-grade solver used in a well-established CFD workflow."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that the numerical implementation correctly solves the governing equations for representative benchmark problems.",
      "rationale": "Code verification was performed against the Taylor-Green vortex (incompressible Navier-Stokes) and a manufactured-solution scalar transport case. Observed convergence rates matched theoretical expectations (second-order in space, first-order in time for the Euler scheme used in steady-state SIMPLE iterations). The hemolysis scalar transport equation was verified against an analytical solution for a simple Couette flow. Verification activities were conducted under smooth, well-conditioned flow fields; no attempt was made to verify solver behaviour when the damage source term evaluates to zero or when accumulated damage values approach the floating-point maximum."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index or equivalent metric demonstrating discretisation error contribution to RH is below 5%.",
      "rationale": "Richardson extrapolation across three mesh levels yielded a Grid Convergence Index of 2.3% on the global RH metric at the design point. The medium mesh (9.7M cells) was selected for the validation and sensitivity studies. Local discretisation error in near-wall recirculation zones was not separately quantified; these regions are also where the shear stress approaches zero and the Power-Law exponent produces numerically sensitive source terms."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented and shown to be representative of the COU operating envelope.",
      "rationale": "In-vitro hemolysis experiments were conducted using a mock circulatory loop with porcine blood at 37°C, hematocrit 33±2%, at five operating points spanning the clinical flow range (3–7 L/min) and two impeller speeds (2500 and 3500 RPM). Temperature, fluid properties, and loop compliance were documented. Test conditions are representative of the CPB COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined; CFD predictions within 15% of experimental measurements for RH across all validation operating points.",
      "rationale": "Mean absolute percentage error between CFD-predicted and experimentally measured RH was 4.8% across the five validation operating points. Maximum point-wise error was 8.3%. All predictions fell within the 15% acceptance band. Comparison was performed only at operating points where the solver completed nominally; the single restarted case was excluded from the comparison dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to the regulatory acceptance criterion and clinical hemolysis risk.",
      "rationale": "The relative hemolysis index RH is the primary QoI and directly corresponds to the regulatory acceptance criterion (RH < 1 relative to predicate device). RH integrates local shear stress exposure over blood element residence time, capturing the dominant hemolysis mechanism for centrifugal pumps. The QoI is clinically meaningful and directly interpretable by the regulatory decision maker."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the COU operating envelope in terms of flow rate, impeller speed, and fluid properties.",
      "rationale": "Validation operating points span the clinical flow range and bracket the two impeller speeds used in the sensitivity sweep. Fluid properties match CPB circuit conditions. The validation domain is judged sufficient for MRL 2. Extrapolation to off-design conditions (near-stall, runout) is not required for the COU but was not validated; these conditions also represent the highest risk of numerical instability in the damage transport solver."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated; residual norms below 1×10⁻⁵ for all reported solutions.",
      "rationale": "All production simulations achieved L2 residual norms below 1×10⁻⁵ for continuity, momentum, and the hemolysis scalar. Convergence histories were inspected visually and confirmed monotonic approach to the converged solution for all 25 sensitivity cases and all 4 validation cases. Solver error assessment is based exclusively on residual norms under well-conditioned inputs; the assessment does not address whether the solver would converge, diverge, or produce silent NaN propagation under degenerate inputs such as zero-shear recirculation cores or near-zero blood element velocities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
