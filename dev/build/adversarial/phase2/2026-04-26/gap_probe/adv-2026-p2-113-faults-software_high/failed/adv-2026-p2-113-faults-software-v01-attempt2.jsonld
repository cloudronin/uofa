  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study — nominal completion",
      "description": "Three mesh refinement levels (coarse 2.1 M, medium 5.4 M, fine 11.2 M cells) were run at the design operating point (5 L/min, 3000 RPM). GCI values below 2.1% on the hemolysis index QoI. All three runs completed without solver interruption; residuals converged to 1e-5 within 2500 iterations. No solver crash or NaN propagation was observed, consistent with nominal operating conditions only."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis comparison — nominal completion",
      "description": "Simulated normalized index of hemolysis (NIH) compared against in vitro measurements across 5 flow-speed combinations. Relative error ranged from 3.2% to 8.7%. All CFD runs completed nominally; the post-processing damage-accumulation Python module executed without exception in all 5 cases. One isolated solver restart was required at the 2 L/min, 2000 RPM operating point due to initial divergence, but this was attributed to poor initial conditions and resolved by restarting from a converged lower-speed solution. No systematic investigation of numerical instability modes, race conditions in the multi-threaded solver, or edge-case floating-point exceptions was conducted."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-sensitivity-tolerance",
      "type": "ValidationResult",
      "name": "Geometric tolerance sensitivity — nominal completion",
      "description": "Parametric sweep of impeller blade clearance (±0.1 mm, ±0.2 mm) and volute exit diameter (±0.5 mm) performed using 12 CFD runs. Worst-case RH remained below 1.0 across all geometric variants. All runs completed with nominal solver convergence. The in-house hemolysis module processed all particle trajectories without runtime error. No fault-injection scenarios (e.g., corrupted mesh inputs, thread-scheduling anomalies, near-zero denominator conditions in the power-law damage model) were included in the validation scope."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-turbulence-model-comparison",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — nominal completion",
      "description": "SST k-omega and realizable k-epsilon turbulence models compared at the nominal operating point. NIH predictions differed by 6.1%, within the accepted model uncertainty budget. Both models converged nominally. No numerical instability was encountered during this comparison; however, no test was performed to characterize solver behavior under conditions that could trigger turbulence model singularities or negative turbulent kinetic energy (numerical clipping behavior not assessed)."
    }
  ],
