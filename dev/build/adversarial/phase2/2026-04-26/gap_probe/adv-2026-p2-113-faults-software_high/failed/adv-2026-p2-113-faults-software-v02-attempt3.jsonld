    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-01-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — nominal completion",
      "description": "Three-level mesh refinement study (1.2M, 4.8M, 19.2M cells) completed under standard operating conditions at 3 L/min and 3500 RPM. All runs reached residual convergence below 1e-5. Solver reported nominal completion for all mesh levels. No mesh-induced divergence or floating-point exception was observed; edge-case mesh topologies (highly skewed cells near impeller tip) were not tested for numerical stability."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-02-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Hemolysis bench validation — nominal completion",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements across 5 flow-speed operating points. Relative hemolysis index RH < 1 for all points. Solver pipeline (C++ FV solver + Python post-processor) reported nominal completion for every case. One isolated solver restart was logged at the 5 L/min / 4000 RPM point due to an initial CFL violation, but the run completed successfully after automatic time-step reduction; no further investigation of numerical instability modes was conducted."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-03-tolerance-sensitivity",
      "type": "ValidationResult",
      "name": "Geometric tolerance sensitivity — nominal completion",
      "description": "Sensitivity of NIH to ±0.1 mm impeller tip clearance and ±0.05 mm volute gap assessed via 12 CFD runs. All runs completed nominally. The multi-threaded solver was executed with 32 parallel MPI ranks; no race-condition testing or thread-safety audit was performed on shared hemolysis accumulation buffers in the post-processor."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-04-predicate-comparison",
      "type": "ValidationResult",
      "name": "Predicate device comparison — nominal completion",
      "description": "CFD hemolysis predictions for the FDA generic pump compared against predicate device bench data. Agreement within 15% across all operating points. All solver runs reported nominal completion with no NaN or Inf values in output fields. Numerical fault injection (e.g., seeding NaN into stress tensor fields, simulating loss-of-precision at high shear rates) was not part of the validation protocol."
    }
  ],
