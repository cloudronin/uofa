  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements. All five validation operating points satisfy the RH < 1 acceptance criterion with normalised errors below 10%. The assessment team concludes that the CFD model provides adequate credibility for identifying worst-case hemolysis operating conditions for the Class II CPB device. The single convergence failure observed during mesh-sensitivity pre-runs was attributed to insufficient mesh density and does not affect the production results. No software-fault modes beyond this isolated event were encountered during the validation campaign, and the team considers the nominal completion of all production runs sufficient evidence of solver robustness at MRL 2.",
