  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. The six not-assessed factors are acceptable at MRL 2 given the medium model influence and availability of experimental confirmation. Mesh convergence GCI of 3.2%, experimental comparison error of 8.4%, and MMS order of accuracy of 1.94 collectively support sufficient confidence in the CFD hemolysis predictions for the CPB COU. The RH < 1 criterion is satisfied across the full geometric tolerance envelope. The assessment team notes that all simulation runs completed nominally; software fault modes (numerical instability at edge-case geometries, race conditions in the MPI-parallel solver, silent non-convergence in the hemolysis integration module) were not systematically exercised, but this gap is considered acceptable under the current MRL 2 framing given corroborating experimental data.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
