  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — nominal completion",
      "description": "Three-level mesh refinement study (coarse 2.1 M, medium 5.4 M, fine 11.8 M cells) executed for all five operating points. All runs completed without solver interruption. Richardson extrapolation yielded GCI < 3.2% on the hemolysis index QoI. Solver log files record no warnings; residuals converged to 1e-5 in all cases."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis comparison — nominal completion",
      "description": "CFD-predicted normalised index of hemolysis (NIH) compared against in-vitro measurements from the FDA generic centrifugal pump test dataset at five flow-speed operating points. All simulations completed successfully. Mean relative error 8.4%; all predictions within experimental uncertainty band. No runtime exceptions or NaN values were observed in any of the five simulation runs."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-sensitivity-tolerance",
      "type": "ValidationResult",
      "name": "Geometric tolerance sensitivity sweep — nominal completion",
      "description": "Parametric CFD sweep over ±0.05 mm impeller-clearance and ±0.1 mm volute-throat tolerances, yielding 18 additional simulation cases. All cases completed nominally. Peak RH remained below 1.0 across the tolerance envelope. One isolated solver restart was required for case T-14 due to initial CFL overshoot; the restarted run converged without further incident and is counted as a nominal completion. No investigation of whether similar CFL-driven instabilities could cause silent numerical errors in edge-case geometries was undertaken."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-04-code-verification",
      "type": "ValidationResult",
      "name": "Method of manufactured solutions verification — nominal completion",
      "description": "MMS verification of the RANS solver kernel against analytical velocity and pressure fields for a simplified rotating-frame problem. Observed order of accuracy 1.94 (expected 2.0); within acceptable tolerance. All MMS runs completed nominally. The parallel MPI decomposition was exercised at 4 and 16 cores; both produced matching results. No testing was performed for race conditions under high core-count decompositions or for floating-point behaviour at near-zero shear-rate regions relevant to hemolysis damage accumulation."
    }
