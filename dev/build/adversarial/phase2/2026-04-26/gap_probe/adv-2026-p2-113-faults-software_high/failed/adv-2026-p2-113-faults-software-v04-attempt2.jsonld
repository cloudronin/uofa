  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study — nominal completion",
      "description": "Three mesh refinement levels (coarse 2.1 M cells, medium 5.8 M cells, fine 14.2 M cells) were run at the 5 L/min / 3500 RPM operating point. All runs completed without solver interruption. Richardson extrapolation yielded a grid convergence index of 1.4% on the volume-averaged shear stress, satisfying the < 5% threshold. Residuals converged to 1e-5 for all transport equations. No numerical instability or NaN propagation was observed during any run."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison — nominal completion",
      "description": "Predicted normalized index of hemolysis (NIH) values were compared against benchtop loop measurements across all 5 flow-speed combinations. Relative errors ranged from 3.2% to 11.7%, within the accepted 15% band. All 5 simulation cases completed in nominal fashion; solver logs show monotonic residual decay with no convergence stalls, floating-point exceptions, or thread-synchronization warnings. The Python hemolysis post-processor executed without exception on all output files."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-sensitivity-sweep",
      "type": "ValidationResult",
      "name": "Geometric tolerance sensitivity sweep — nominal completion",
      "description": "A 27-case Design of Experiments sweep varying impeller tip clearance (±50 µm), volute gap (±75 µm), and inlet chamfer angle (±2°) was executed on the production multi-threaded solver. All 27 cases reached the 5000-iteration convergence limit with residuals below 1e-4. The parallel job scheduler distributed cases across 8 cores; all processes exited with status 0. Relative hemolysis index (RH) remained below 1.0 for 26 of 27 geometric combinations, with the single exceedance flagged for design revision."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-predicate-comparison",
      "type": "ValidationResult",
      "name": "Predicate device relative hemolysis comparison — nominal completion",
      "description": "Simulated NIH for the FDA generic centrifugal pump was compared against published predicate device data. The relative hemolysis index RH = 0.87 at the worst-case operating point satisfies the RH < 1 acceptance criterion. The solver and post-processing chain completed without errors. Boundary condition interpolation from experimental inlet profiles executed within numerical tolerances; no edge-case failures were encountered during profile loading."
    }
  ],
