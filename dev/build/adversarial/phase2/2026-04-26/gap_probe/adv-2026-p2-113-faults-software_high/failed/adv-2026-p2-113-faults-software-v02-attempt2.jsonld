  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Velocity field normalized RMS errors (8.3–13.7%) satisfy the 15% acceptance threshold. Relative hemolysis index predictions satisfy RH < 1 for all 5 operating points and fall within ±12% of in-vitro measurements. Mesh sensitivity GCI values are below 5%. Six factors are not assessed, which is acceptable at MRL 2 given Medium model influence and the availability of experimental testing to confirm computational results. The credibility evidence is sufficient to support the regulatory submission claim that the CFD model can identify worst-case hemolysis operating conditions for the Class II CPB device.",
