    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against in-vitro data",
      "description": "Power-law hemolysis integral (Giersiepen-Wurzinger model) evaluated over Lagrangian particle trajectories for all 5 flow-speed combinations. RH values ranged from 0.61 to 0.94, satisfying the RH < 1 acceptance criterion. All post-processing scripts completed nominally. One solver restart occurred during the 5000 RPM / 6 L/min case and was attributed to cluster scheduler pre-emption; the restarted run completed without further incident and its output was accepted without independent verification of numerical state continuity across the restart boundary.",
      "outcome": "Passed",
