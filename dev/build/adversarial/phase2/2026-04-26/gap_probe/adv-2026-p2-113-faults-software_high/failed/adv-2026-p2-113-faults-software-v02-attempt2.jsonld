  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control and regression test suite in place for the OpenFOAM build and Python orchestration layer.",
      "rationale": "The OpenFOAM solver is managed under Git version control with a documented build procedure. A regression test suite of 12 canonical flow cases is executed on each solver release. The Python hemolysis post-processing scripts are versioned alongside the solver. SQA documentation confirms Gradation 2 compliance. No testing of fault-tolerant restart integrity, thread-safety of the MPI decomposition layer, or numerical-exception handling (IEEE 754 NaN/Inf trapping) was included in the SQA plan, as these were considered outside the scope of standard CFD SQA at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions demonstrates second-order spatial convergence for the incompressible Navier-Stokes solver kernel.",
      "rationale": "MMS verification confirmed second-order convergence (L2 norm of velocity error: 1.8e-3 on coarse, 4.6e-4 on medium, 1.2e-4 on fine grid). Convergence rate 1.97, consistent with expected second-order accuracy. Verification performed on structured hexahedral grids; unstructured polyhedral grid behavior was not separately verified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation GCI below 5% for velocity QoIs at the nominal operating point.",
      "rationale": "GCI values of 3.2%, 2.8%, and 1.9% obtained for axial velocity, radial velocity, and pressure respectively at 3500 RPM / 5 L/min. The 5.8 M cell mesh was selected for production runs as the best balance of accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid properties) match CFD boundary conditions within stated measurement uncertainty.",
      "rationale": "PIV experiments conducted at FDA laboratories with blood analog fluid (39% glycerol-water). Fluid viscosity and density matched to within 1.5% of CFD input values. Rotational speed controlled to ±10 RPM. Inlet velocity profiles extracted from PIV data and applied as CFD inflow boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Velocity field agreement quantified by normalized RMS error below 15% across all measured planes; RH index within experimental uncertainty bounds.",
      "rationale": "Normalized RMS velocity errors ranged from 8.3% to 13.7% across five operating points and three measurement planes, satisfying the 15% threshold. RH predictions fell within ±12% of in-vitro hemolysis measurements, within the combined experimental and model uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (velocity field, relative hemolysis index RH) are directly linked to the COU decision on worst-case hemolysis operating conditions.",
      "rationale": "The relative hemolysis index RH is the primary regulatory acceptance metric for CPB device hemolysis assessment. Velocity field validation provides mechanistic confidence in the shear stress predictions that drive the hemolysis power-law integral. QoIs are fully aligned with COU decision needs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the FDA GCBP geometry under CPB-representative flow conditions.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump, which is the same device family as the subject CPB pump. Flow rates (2–8 L/min) and rotational speeds (2500–5000 RPM) span the intended COU operating envelope. Blood analog fluid properties are representative of clinical blood viscosity at CPB hematocrit levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-5 for all transport equations at all operating points; no solver divergence events.",
      "rationale": "All production simulations converged to residual levels below 1e-5 for continuity, momentum, and turbulence equations. Convergence histories were reviewed for all five operating points. One simulation required a restart due to cluster pre-emption; the restarted run converged normally and was accepted. No investigation was performed to confirm that the numerical state was correctly preserved across the restart, and no testing was conducted to assess solver behavior under low-memory or high-load conditions that could induce numerical instability in the MPI communication buffers."
    },
    {
