  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for MRL 2. Six factors are appropriately scoped out per ASME V&V 40 Table 4 for MRL 2 assessments. The RH < 1 acceptance criterion is satisfied at all five operating points with NIH mean absolute error of 8.3 %. The model is accepted as sufficiently credible to support the regulatory submission decision for the Class II CPB device. Note: the shear-stress exposure time integral bound (150 Pa / 700 ms threshold) cited in the COU description and validation narrative as the primary patient-safety criterion has not been formally declared as a binding obligation in the linked requirement set; the requirement set addresses only the RH < 1 aggregate index and dimensional tolerance bounds.",
