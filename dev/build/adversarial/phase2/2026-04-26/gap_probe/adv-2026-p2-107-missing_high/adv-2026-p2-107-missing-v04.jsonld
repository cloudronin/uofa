  "requirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-req-set-001",
    "type": "RequirementSet",
    "name": "CPB hemolysis CFD model requirement set",
    "description": "Requirements binding the CFD hemolysis model to the COU1 credibility claim. Requirement R1: The model shall predict normalised index of hemolysis (NIH) within 15% mean absolute error relative to experimental reference data across all evaluated operating points. Requirement R2: The relative hemolysis index (RH) shall be less than 1.0 for all five flow-speed combinations evaluated, confirming the device does not exceed predicate hemolysis performance. Requirement R3: Mesh discretization error for the primary QoI shall be quantified via Richardson extrapolation and shall not exceed 5% GCI on the production mesh. Requirement R4: Simulation boundary conditions shall reproduce experimental test conditions within ±2% for rotational speed and volumetric flow rate.",
    "obligations": [
      "R1: NIH prediction error < 15% MAPE versus experimental reference",
      "R2: RH < 1.0 for all five operating points",
      "R3: GCI for NIH < 5% on production mesh",
      "R4: Boundary conditions within ±2% of experimental set-points"
    ]
  },
