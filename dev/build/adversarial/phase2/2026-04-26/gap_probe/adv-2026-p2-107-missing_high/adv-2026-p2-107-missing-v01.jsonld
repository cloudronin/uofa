  "uofa:requirement": {
    "id": "https://uofa.net/synth/req/morrison-cou1-cpb-req-set-001",
    "type": "RequirementSet",
    "name": "Morrison COU1 CFD Hemolysis Prediction Requirements",
    "description": "Requirements governing the CFD credibility assessment for hemolysis prediction of the FDA generic centrifugal blood pump. Requirement R1: The CFD model shall predict the relative hemolysis index (RH) with a mean absolute error not exceeding 15% relative to published experimental values across all evaluated operating points. Requirement R2: The mesh convergence study shall demonstrate a grid convergence index below 5% for the primary quantity of interest on the production mesh. Requirement R3: All simulation boundary conditions shall reproduce experimental test conditions within 5% for flow rate and rotational speed. Requirement R4: The power-law hemolysis model constants shall be sourced from peer-reviewed literature validated for rotary blood pump geometries. Requirement R5: The credibility assessment shall be conducted in accordance with ASME V&V 40-2018 at Model Risk Level 2.",
    "obligations": [
      "R1: RH prediction error ≤ 15% vs. experimental data",
      "R2: GCI < 5% on production mesh",
      "R3: Boundary conditions within 5% of experimental conditions",
      "R4: Power-law model constants from peer-reviewed literature",
      "R5: Assessment per ASME V&V 40-2018 at MRL 2"
    ]
  },
