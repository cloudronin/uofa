  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence study — hemolysis index",
      "description": "Grid convergence index (GCI) study performed across three mesh refinement levels. At the chosen mesh element size setting the GCI for RH fell below 2.1%. Coarser and finer meshes were also evaluated; the chosen setting was selected based on computational cost trade-off. No binding of the mesh size parameter to a deployment constraint is recorded."
    },
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison",
      "description": "Particle image velocimetry (PIV) measurements from the FDA benchmark pump dataset were compared against CFD predictions at the chosen turbulence closure settings (SST k-omega with default closure coefficients). Mean velocity error across the impeller passage was 4.3%. The specific closure coefficient values used during validation are noted only in the analyst's working notes and are not pinned in any configuration record accessible to future deployment teams."
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-power-law-calibration",
      "type": "ValidationResult",
      "name": "Hemolysis power-law threshold calibration",
      "description": "The Giersiepen-Wurzinger hemolysis power-law model was exercised at the chosen threshold stress value (3.62 Pa). Predicted RH values at all five operating points satisfied RH < 1 relative to the predicate device. Results are reported at the chosen settings; the threshold parameter is not locked to this value for deployment and no sensitivity analysis to threshold variation is included in the evidence package."
    }
  ],
