  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for MRL 2. Six factors are not assessed, consistent with the ASME V&V 40 MRL 2 assessment matrix for a Class II device with medium model influence. All five flow-speed operating points yield RH < 1.0 at the chosen CFD settings, satisfying the regulatory acceptance criterion. The assessment team concludes that the model has sufficient credibility for the stated COU. Validation results were obtained at specific mesh size, hemolysis threshold, and convergence tolerance settings described in the validation reports; the assessment team notes that these settings should be maintained in production use.",
