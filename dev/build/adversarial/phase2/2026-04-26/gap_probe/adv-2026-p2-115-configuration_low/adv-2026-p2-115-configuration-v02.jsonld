    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-mesh-sensitivity",
      "type": "ValidationResult",
      "name": "Mesh sensitivity study — hemolysis index convergence",
      "description": "Grid convergence index (GCI) study performed across three mesh refinement levels. At the chosen settings (base element size 0.15 mm near blade surfaces), the normalised hemolysis index varied by less than 2.1% between medium and fine meshes, satisfying the MRL 2 discretisation convergence criterion. Coarse-to-medium GCI was 4.8%. Results reported at the chosen mesh configuration."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-stress-threshold",
      "type": "ValidationResult",
      "name": "Stress-threshold sensitivity — scalar damage accumulation",
      "description": "The power-law damage accumulation model was exercised at the chosen stress-weighting threshold of 50 Pa across all five COU operating points. Predicted relative hemolysis index (RH) ranged from 0.61 to 0.94, remaining below the acceptance criterion of RH < 1.0 at each point. Sensitivity to the threshold parameter was noted qualitatively but no parametric sweep was documented in this package."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-temporal-integration",
      "type": "ValidationResult",
      "name": "Temporal sub-step convergence — impeller revolution integration",
      "description": "Transient hemolysis accumulation was computed using 32 sub-steps per impeller revolution at the chosen settings. Comparison against a 64-sub-step reference run showed less than 1.5% deviation in peak RH. Results support adequacy of temporal resolution at the validated sub-step count."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental comparison — FDA pump hemolysis benchmark",
      "description": "CFD-predicted normalised index of hemolysis (NIH) was compared against published FDA generic pump experimental data at three operating points. Mean absolute error was 8.3% across the comparison set, within the 15% acceptance band specified for MRL 2 output comparison. Comparison performed at the chosen solver configuration without documentation of which parameter values were active during the comparison runs."
    }
