  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver is a commercially validated code with documented version control and regression test suite. Version used in validation must match version used in deployment.",
      "rationale": "ANSYS Fluent 2022 R2 was used for all validation simulations. The solver version is documented in the validation report. A regression test suite covering blood-pump flow configurations is maintained by the vendor. SQA level 2 requirements are satisfied. Note that while the solver version is identified, the configuration parameters governing solver behaviour (mesh size, threshold values, model constants) are not version-controlled within this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, Poiseuille flow) with observed order of accuracy consistent with formal order. Documentation available.",
      "rationale": "ANSYS Fluent 2022 R2 has published verification documentation demonstrating second-order spatial accuracy for the pressure-velocity coupling scheme used. Benchmark results for internal rotating-machinery flows are available in the vendor verification manual and were reviewed. Code verification is assessed at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) for the primary QoI (RH) is below 5% on the production mesh. Three mesh levels evaluated.",
      "rationale": "A three-level mesh refinement study yielded GCI = 1.8% for RH on the medium mesh, which was adopted as the production mesh. The base element size parameter that defines the mesh refinement hierarchy was selected during validation at the chosen settings. Because this parameter is not pinned in the deployment specification, a future analyst could inadvertently apply a coarser mesh and obtain a GCI outside the validated range without triggering any package-level constraint."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented and match the five COU operating points within ±5%.",
      "rationale": "In-vitro tests were conducted using a blood analogue (glycerol-water, 36% by mass) at 37°C. Flow rates and rotational speeds for the five operating points were verified against pump curve data. Fluid property measurements are documented. Test conditions are assessed at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "RH predictions are within ±15% of measured values at all five operating points. Systematic bias is characterised.",
      "rationale": "CFD predictions of RH agreed with measurements to within ±12% across all five operating points at the chosen solver settings. A small systematic over-prediction of 4% was observed at the highest rotational speed and is attributed to secondary flow effects. The comparison was performed at the chosen values of mesh element size, wall-distance threshold, and power-law exponent; these values are not recorded as binding deployment constraints in this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (RH) is directly linked to the regulatory acceptance criterion and is computable from CFD outputs without additional transformation steps that introduce unquantified uncertainty.",
      "rationale": "The relative hemolysis index RH is computed directly from the Lagrangian particle-tracking stress accumulation integral, which is a standard CFD post-processing output. RH is the quantity cited in the regulatory submission acceptance criterion (RH < 1). The QoI is assessed as relevant at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, the same operating envelope, and the same fluid as the COU. Geometric similarity is within 2% for all critical dimensions.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating points span the full COU envelope. Fluid properties match the COU specification. Geometric similarity is confirmed at level 2. Validation activities are assessed as relevant to the COU."
    },
    {
