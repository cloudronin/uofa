  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-ml-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. The neural network surrogate (feedforward architecture, 4 hidden layers, 128 units each) trained on 1 200 CFD operating points achieves MAE < 0.004 RH units on the held-out test set across both training seeds examined (42 and 137). Both seeds yield RH predictions below the acceptance threshold of 1.0 for all five operating points, and the two runs agree to within 0.02 RH units at worst. The credibility team concludes that the surrogate model provides adequate evidence to support the worst-case hemolysis identification decision for this Class II CPB device at MRL 2. The six factors not assessed are consistent with MRL 2 scoping. The package is accepted for submission.",
