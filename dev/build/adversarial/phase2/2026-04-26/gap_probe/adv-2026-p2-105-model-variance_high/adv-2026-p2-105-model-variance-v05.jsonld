  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-ml-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The neural-network surrogate correctly identifies worst-case hemolysis operating conditions with point-estimate errors below 8% across all validation operating points. Two independent training runs (seeds 42 and 137) produced consistent worst-case rankings and near-identical test-set metrics, providing confidence in surrogate stability. The six non-assessed factors are acceptable at MRL 2 per the ASME V&V 40 framework. The package is accepted for regulatory submission to support the CPB device tolerance sensitivity claim.",
