    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Feedforward neural network architecture is appropriate for smooth regression over the CPB operating envelope; physics-informed constraints applied where tractable.",
      "rationale": "A fully connected feedforward neural network with ReLU activations is appropriate for the smooth, low-dimensional hemolysis response surface over the 5-dimensional operating-point space. A monotonicity constraint on flow rate was enforced via projected gradient descent, consistent with known hemolysis physics. Architecture selection was guided by cross-validation over the training set."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All five operating-point input features (flow rate, rotational speed, impeller clearance, volute geometry, blood viscosity) are documented with uncertainty ranges.",
      "rationale": "Five input features are used: volumetric flow rate (±2 % measurement uncertainty), rotational speed (±10 RPM), impeller tip clearance (±0.05 mm manufacturing tolerance), volute exit angle (±0.5°), and dynamic blood viscosity (±5 % inter-patient variability). Input uncertainty ranges are documented in the model card and propagated through the surrogate via Monte Carlo sampling for the worst-case operating point identification."
    },
