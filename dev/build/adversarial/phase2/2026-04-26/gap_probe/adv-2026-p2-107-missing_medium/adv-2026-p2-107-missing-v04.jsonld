  "hasRequirement": {
    "id": "https://uofa.net/synth/req/morrison-cou1-safety-reqs-v2",
    "type": "RequirementSet",
    "name": "Morrison COU1 Safety Requirements v2",
    "description": "Safety requirements for CFD-based hemolysis assessment of the FDA generic centrifugal blood pump under CPB conditions. This requirement set specifies: (1) the relative hemolysis index acceptance criterion RH < 1 compared against the predicate device; (2) minimum mesh density of 2 million cells in the impeller passage; (3) turbulence model selection justified by published benchmark performance; and (4) other safety properties enumerated separately in the device design history file. Version 2 supersedes v1 with updated mesh density thresholds.",
    "version": "2.0",
    "effectiveDate": "2025-11-01"
  },
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are acceptable per MRL 2 scoping guidance. Validation evidence demonstrates CFD predictions of NIH within experimental uncertainty across the full COU operating envelope. RH < 1 acceptance criterion satisfied at all 5 operating points. The credibility package is accepted as sufficient to support the regulatory submission claim that CFD can reliably identify worst-case hemolysis conditions for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
