  "name": "Morrison COU1 — ML-augmented CFD hemolysis credibility assessment (CPB use)",
  "description": "V&V 40 credibility assessment for an ML-augmented CFD hemolysis prediction pipeline applied to the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. A feedforward neural network surrogate (3 hidden layers, 256 units each, ReLU activations) was trained on 4,800 high-fidelity CFD runs to predict the relative hemolysis index (RH) across the 5 flow-speed operating points. The surrogate is used to identify worst-case operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Reproducibility of the surrogate was studied informally during development; the reported validation metrics reflect a single training run.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-mrl2-rh-criterion",
  "bindsClaim": "https://uofa.net/synth/claim/ml-cfd-surrogate-identifies-worstcase-hemolysis",
  "bindsModel": "https://uofa.net/synth/model/nn-hemolysis-surrogate-v2-singlerun",
  "bindsDataset": [
    "https://uofa.net/synth/data/cfd-training-corpus-4800runs",
    "https://uofa.net/synth/data/experimental-hemolysis-validation-set"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nn-surrogate-holdout-test",
      "type": "ValidationResult",
      "name": "Neural network surrogate holdout validation — single training run",
      "description": "The feedforward neural network surrogate was evaluated on a held-out test set of 480 CFD cases (10% stratified split). Mean absolute error on RH: 0.031 (dimensionless). R² = 0.974. Maximum absolute error across the 5 target operating points: 0.058. These metrics were obtained from a single training run with a fixed random seed (seed=42). Reproducibility was studied informally during model development; no systematic multi-seed sweep was conducted and seed-to-seed variance in predictions is not quantified in this package. The team noted subjectively that re-training 'gave similar results' but no numerical characterization of that variance is provided."
    },
    {
      "id": "https://uofa.net/synth/validation/experimental-comparison-rh-index",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison against physical pump test data",
      "description": "Surrogate-predicted RH values for the 5 flow-speed operating points were compared against experimental hemolysis measurements from an FDA-protocol modified index of hemolysis (MIH) bench test. Predicted RH ranged 0.62–0.89 across operating points; measured RH ranged 0.65–0.91. All predicted values satisfy RH < 1. Agreement is within 5% across all operating points. Worst-case operating point identified by surrogate (2.5 L/min, 3200 RPM) is consistent with experimental observation."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4055600",
