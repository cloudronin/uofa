  "name": "Morrison COU1 — ML-augmented CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for a hybrid CFD/ML hemolysis prediction pipeline applied to the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. A convolutional neural network (CNN) surrogate is trained on CFD-generated shear-stress fields to predict the relative hemolysis index (RH) across 5 flow-speed combinations. COU1 evaluates whether the ML surrogate model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Reproducibility of the CNN training was studied informally and judged adequate; no quantitative seed-to-seed variance characterization is reported.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-ml-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/cnn-surrogate-rh-prediction-acceptable",
  "bindsModel": "https://uofa.net/synth/model/cnn-hemolysis-surrogate-v1",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-gcbp-cfd-shear-fields-training",
    "https://uofa.net/synth/data/fda-gcbp-experimental-hemolysis-validation"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cnn-surrogate-point-performance",
      "type": "ValidationResult",
      "name": "CNN surrogate point-estimate performance on held-out CFD cases",
      "description": "The CNN surrogate was trained on 420 CFD shear-stress field snapshots (80/20 train-test split, single training run, Adam optimizer, fixed learning-rate schedule). On the held-out test set the model achieved mean absolute error MAE=0.031 RH units and R²=0.961 against CFD reference values. These metrics derive from a single model instantiation. Reproducibility was studied informally across a small number of re-runs and judged satisfactory by the engineering team; no tabulated seed-to-seed variance, inter-quartile ranges, or ensemble statistics are provided in this package.",
      "metrics": {
        "MAE_RH": 0.031,
        "R2": 0.961,
        "testSetSize": 84,
        "trainingSeeds": "single run (seed=42)"
      },
      "conclusion": "Point-estimate performance meets the project acceptance threshold (MAE < 0.05 RH units). Model is accepted for surrogate use within the COU."
    },
    {
      "id": "https://uofa.net/synth/validation/cnn-surrogate-experimental-comparison",
      "type": "ValidationResult",
      "name": "CNN surrogate vs. experimental hemolysis index — 5 operating points",
      "description": "Predicted RH values from the CNN surrogate were compared against experimental hemolysis measurements at 5 flow-speed operating points. All 5 surrogate predictions fell within ±8% of measured RH values. Worst-case operating condition (Q=4 L/min, 3500 RPM) correctly identified. No discussion of how training-seed variability might shift predicted RH rankings among operating points.",
      "metrics": {
        "maxDeviationPercent": 7.8,
        "operatingPointsEvaluated": 5,
        "worstCaseCorrectlyIdentified": true
      },
      "conclusion": "Surrogate predictions are consistent with experimental data at all evaluated operating points. Acceptance criterion RH < 1 satisfied for predicate comparison."
    }
  ],
