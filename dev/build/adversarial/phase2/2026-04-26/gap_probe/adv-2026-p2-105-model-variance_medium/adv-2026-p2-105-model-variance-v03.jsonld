  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-nn-surrogate-performance-v1",
      "type": "ValidationResult",
      "name": "Neural network surrogate RH prediction accuracy — single training run",
      "description": "The gradient-boosted neural network surrogate was trained once using a fixed random initialisation (seed 42) on 80% of the 4,200 CFD trajectory dataset; the remaining 20% formed the hold-out test set. On the test set the surrogate achieved mean absolute error MAE = 0.031 RH units and R² = 0.967 against CFD-derived RH values. Across the five COU operating points the maximum surrogate-to-CFD deviation was 4.2%. These point-estimate metrics were deemed sufficient to confirm surrogate fidelity. Reproducibility was studied informally during development; engineers noted that results appeared consistent across a small number of exploratory runs, but no systematic seed sweep was conducted and no quantitative variance statistics (standard deviation of MAE, coefficient of variation of R², or ensemble spread across seeds) are reported in this package.",
      "quantitiesOfInterest": [
        "relative hemolysis index RH",
        "mean absolute error",
        "R-squared"
      ],
      "metricsReported": {
        "MAE": 0.031,
        "R2": 0.967,
        "maxDeviationAtCOUPoints_percent": 4.2
      },
      "trainingSeedsEvaluated": 1,
      "seedVarianceCharacterized": false
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-cfd-experimental-comparison-v1",
      "type": "ValidationResult",
      "name": "CFD hemolysis validation against FDA benchmark experimental data",
      "description": "Steady-state CFD simulations of the FDA generic centrifugal blood pump were compared against published experimental hemolysis measurements at five flow-speed combinations. The power-law hemolysis model (Giersiepen–Wurzinger coefficients) was applied to shear-stress trajectories extracted from converged RANS solutions. Predicted normalised index of hemolysis (NIH) values agreed with experimental measurements within ±12% across all operating points, satisfying the MRL 2 validation requirement. Grid convergence was confirmed at GCI < 2% on a three-level refinement study.",
      "quantitiesOfInterest": [
        "normalised index of hemolysis NIH",
        "grid convergence index GCI"
      ],
      "metricsReported": {
        "maxNIH_deviation_percent": 12,
        "GCI_percent": 1.8
      }
    }
  ],
