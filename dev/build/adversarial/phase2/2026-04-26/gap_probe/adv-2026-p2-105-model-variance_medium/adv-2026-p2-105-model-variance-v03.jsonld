  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-ml-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-simulation-group-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. The ML surrogate achieved MAE = 0.031 RH units and R² = 0.967 on the hold-out test set, and maximum deviation from CFD at COU operating points was 4.2%, within the ±5% acceptance criterion. CFD-to-experiment NIH agreement was within ±12% across all five operating points, satisfying the ±15% criterion. Six factors were not assessed per the MRL 2 scoping decision, which is acceptable given the medium model influence and the availability of experimental confirmation testing. The combined CFD and ML surrogate evidence is judged sufficient to support the regulatory submission claim that the worst-case hemolysis operating condition satisfies RH < 1 relative to the predicate device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
