  "signature": "ed25519:b1d4e7a2f9c3e0b58d61a7f4c2e9b0d3a6f1c8e5b2d7a4f0c3e6b9d2a5f8c1e4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver and ML surrogate training code version-controlled; unit tests pass; audit trail for training data pipeline documented.",
      "rationale": "The CFD solver (OpenFOAM v9) is version-controlled under Git with tagged releases. The neural network training pipeline is implemented in PyTorch 2.0 with a requirements lockfile; automated regression tests cover data ingestion, normalisation, and forward-pass consistency. A data lineage log records each preprocessing step applied to the 4,200 trajectory dataset. SQA level 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver verified against analytical solutions for laminar pipe flow and rotating-frame body forces; ML code verified via gradient-check and loss-curve inspection.",
      "rationale": "OpenFOAM discretisation schemes were verified against Hagen-Poiseuille and Taylor-Couette analytical solutions with errors below 0.5%. The ML training loop was verified by confirming monotone loss reduction on a synthetic quadratic regression problem and by passing PyTorch's built-in gradient checker for all custom loss terms. Code verification is adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index GCI < 5% on hemolysis-sensitive regions; surrogate input features derived from converged grids only.",
      "rationale": "A three-level mesh refinement study (coarse 1.2 M, medium 3.1 M, fine 7.8 M cells) yielded GCI = 1.8% for NIH in the impeller–volute gap region. All 4,200 training trajectories were extracted from medium-mesh solutions, which were confirmed to be within the asymptotic range. Discretisation error is well characterised at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, blood analogue viscosity, temperature) match COU operating envelope within stated tolerances.",
      "rationale": "FDA benchmark experiments were conducted at 37 °C with a glycerol–water blood analogue (viscosity 3.5 mPa·s ± 0.1). Flow rates of 2.5 and 5.0 L/min and rotational speeds of 2500 and 3500 RPM bracket the five COU operating points. Tolerances on flow (±2%) and speed (±0.5%) are within MRL 2 acceptability bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH within ±15% of experimental measurements at all five operating points; surrogate RH within ±5% of CFD at COU points.",
      "rationale": "CFD-to-experiment NIH agreement ranged from −8% to +12% across all five operating points. Surrogate-to-CFD RH agreement at the COU points ranged from −3.1% to +4.2%. Both criteria are satisfied. Uncertainty in experimental NIH (±6% at 95% CI) was accounted for in the comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (RH, NIH) directly maps to clinical hemolysis risk metric used in regulatory submission.",
      "rationale": "The relative hemolysis index RH and normalised index of hemolysis NIH are the standard regulatory metrics for blood pump hemolysis assessment per ISO 10993-4 and FDA guidance. The surrogate predicts RH directly; CFD provides NIH for experimental comparison. Both QoIs are clinically and regulatorily relevant to the CPB COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow regime, and hemolysis model are representative of the COU device and operating conditions.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which shares impeller diameter (60 mm), blade count (5), and design flow range with the subject CPB device. The power-law hemolysis model and RANS turbulence closure (SST k-ω) used in validation are identical to those applied in the COU predictions. Validation activities are sufficiently representative."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals converge to machine precision for steady-state cases; iterative convergence monitored.",
      "rationale": "All steady-state RANS solutions were run to normalised residuals below 1×10⁻⁶ for continuity and momentum. Pressure–velocity coupling used the SIMPLE algorithm with under-relaxation factors of 0.3/0.7. No divergence or non-physical oscillation was observed. Numerical solver error is negligible relative to discretisation and model-form uncertainties."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol followed; peer review of boundary condition setup completed.",
      "rationale": "A written simulation protocol specifying boundary conditions, mesh generation parameters, solver settings, and post-processing steps was followed by the simulation engineer. An independent peer review confirmed correct implementation of inlet velocity profiles, rotating reference frame setup, and hemolysis post-processor. Use error risk is low."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified; sensitivity to model form documented.",
      "rationale": "The SST k-ω turbulence model was selected based on published benchmark comparisons for rotating machinery hemolysis applications. The Giersiepen–Wurzinger power-law hemolysis model is the industry-standard choice for RBC damage prediction in centrifugal pumps. Sensitivity analysis comparing SST k-ω to realizable k-ε showed NIH variation of 7%, which is within the experimental uncertainty band. Model form uncertainty is characterised at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometric tolerances, fluid properties, and operating condition uncertainties quantified and propagated.",
      "rationale": "Component dimension tolerances (±0.05 mm on impeller blade tip gap) were propagated through five CFD runs spanning the tolerance range. Blood analogue viscosity uncertainty (±3%) was assessed via two additional simulations. Combined input uncertainty contribution to RH was ±5.1%, which is acceptable at MRL 2. The ML surrogate input feature space covers the full tolerance envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; experimental sample characterisation deferred.",
      "rationale": "At MRL 2 with medium model influence, detailed characterisation of physical test sample variability (e.g., batch-to-batch variation in blood analogue preparation) is not required. The FDA benchmark dataset used for validation was produced under controlled laboratory conditions with documented fluid preparation procedures. This factor is not assessed per the MRL 2 scoping decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency between validation and COU input parameters addressed qualitatively.",
      "rationale": "The validation and COU geometries share the same design family and operating regime. Qualitative equivalency of inlet boundary conditions, rotational speed range, and fluid properties was confirmed by engineering review. Formal quantitative equivalency mapping is not required at MRL 2 and is deferred."
    }
