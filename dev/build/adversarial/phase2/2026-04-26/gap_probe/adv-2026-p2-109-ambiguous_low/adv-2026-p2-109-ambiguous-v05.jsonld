  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. The six non-assessed factors are consistent with MRL 2 scoping per ASME V&V 40 Table 3. The governing requirement — that the model shall produce hemolysis predictions reasonably consistent with acceptable performance across the relevant operating range — is judged to be satisfied. The assessment team considered the mean relative error of 9.3% and the RH < 1 outcome at all five operating points to constitute reasonable consistency with acceptable performance, though the requirement language does not specify a numerical threshold and the acceptance criteria similarly reference meaningful deviation without quantification, leaving the precise compliance boundary open to interpretation.",
