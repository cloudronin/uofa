  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required levels for MRL 2. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 4. The governing Requirement states that the model shall produce acceptable hemolysis predictions under reasonable operating conditions; the assessment team judges this Requirement to be satisfied on the basis that predicted NIH values are broadly consistent with experimental data and the worst-case operating condition is correctly identified. The acceptance criteria language — requiring a generally satisfactory level of agreement — is interpreted by the team as consistent with the 18.3% mean absolute error and correct rank-ordering observed. Overall credibility is sufficient to support the intended COU decision at Medium assurance level.",
