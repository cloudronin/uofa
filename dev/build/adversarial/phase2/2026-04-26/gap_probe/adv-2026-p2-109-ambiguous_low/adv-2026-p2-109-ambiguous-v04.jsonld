    "type": "Requirement",
    "name": "CFD Hemolysis Model Acceptability Requirement",
    "statement": "The model shall produce hemolysis predictions that are reasonably consistent with acceptable clinical performance across relevant operating conditions.",
    "acceptanceCriteria": "Model outputs should demonstrate adequate agreement with experimental benchmarks and not exhibit meaningful deviation from expected hemolytic behavior under normal pump operating scenarios."
  },
  "hasCredibilityFactor": [
