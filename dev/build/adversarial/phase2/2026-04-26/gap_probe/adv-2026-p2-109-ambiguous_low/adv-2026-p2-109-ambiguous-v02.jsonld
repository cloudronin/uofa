  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required gradation levels for MRL 2. Six factors appropriately scoped as not-assessed at MRL 2. The model is judged to demonstrate acceptable performance and reasonable agreement with experimental data as required. However, the governing requirement — that the model shall produce hemolysis predictions reflecting acceptable performance relative to the predicate device under clinically relevant operating conditions — does not define numeric thresholds for 'acceptable' or 'reasonable', and the acceptance criteria similarly use unquantified language. The assessment team interpreted these terms as satisfied based on RH < 1 across all operating points and mean absolute error of 0.06 RH units, but a reviewer applying a different interpretation of 'acceptable performance' could reach a different conclusion. The package is accepted conditional on this interpretive judgment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
