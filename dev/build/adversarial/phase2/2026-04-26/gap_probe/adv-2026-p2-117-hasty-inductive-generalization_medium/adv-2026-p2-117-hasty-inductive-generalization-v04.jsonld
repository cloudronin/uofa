  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. Validation was performed using three in-vitro experiments conducted at the nominal operating point (5 L/min, 3000 RPM), and the CFD model predicted the relative hemolysis index within 1.6% mean absolute error across all three replicates. This consistent agreement across the three experiments demonstrates that the model accurately captures the hemolysis physics of the FDA generic centrifugal blood pump. The model is therefore considered validated for the full operating range of the COU, encompassing all five intended flow-speed combinations from 3 L/min at 2500 RPM to 7 L/min at 3500 RPM. The six non-assessed factors are acceptable at MRL 2 and do not diminish overall credibility. The decision to accept the model for regulatory submission is supported by the totality of the credibility evidence.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
