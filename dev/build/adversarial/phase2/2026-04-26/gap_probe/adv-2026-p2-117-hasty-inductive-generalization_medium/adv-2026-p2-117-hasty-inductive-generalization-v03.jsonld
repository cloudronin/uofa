  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model is accepted as credible for the full operating range specified in COU1 (all five flow-speed combinations across the CPB envelope). Validation evidence from three experimental replicates at the nominal operating point (Q = 5 L/min, N = 2400 RPM) demonstrates that the model predicts RH within 4.1% of measured values, satisfying the ±8% acceptance criterion. Because agreement is excellent and consistent across all three replicates, the model is considered validated for the complete operating envelope defined in the COU, including off-nominal flow-speed combinations not directly tested. All seven assessed credibility factors meet or exceed their required levels for MRL 2, and the six non-assessed factors are acceptable at this risk level. On this basis, the model is validated for the full operating range and the regulatory submission may proceed using CFD-predicted RH values across all five operating conditions.",
