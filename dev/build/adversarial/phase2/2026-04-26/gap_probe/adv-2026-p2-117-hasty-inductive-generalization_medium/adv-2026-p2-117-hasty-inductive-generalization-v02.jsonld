  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required Gradation levels for Model Risk Level 2. Validation evidence from three experiments at the nominal operating point (5 L/min, 3000 RPM) consistently demonstrates CFD-to-experiment agreement within 5% for the relative hemolysis index. On the basis of this agreement, the model is validated for the full operating range of five flow-speed combinations (3–7 L/min, 2500–3500 RPM) specified in the COU. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The CFD model is therefore accepted as credible for identifying worst-case hemolysis operating conditions across the complete CPB operating envelope, and the RH < 1 criterion relative to the predicate device is supported for regulatory submission.",
