  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model has been validated against three bench experiments at the nominal operating point (5 L/min, 3000 RPM), all yielding CFD-to-measurement agreement within the ±5% acceptance band. This consistent agreement across three replicates demonstrates that the model reliably captures the hemolysis physics of the FDA generic centrifugal pump. On this basis, the model is considered validated for the full operating range of the COU — encompassing all five flow-speed combinations specified in the intended use — and the predicted relative hemolysis index values across that envelope are accepted as credible for regulatory decision-making. All seven assessed credibility factors meet or exceed their required gradation levels at MRL 2, and the six non-assessed factors are within the accepted scope exclusions for MRL 2. The decision is therefore Accepted: the CFD model is fit for purpose to identify worst-case hemolysis conditions across the complete CPB operating envelope.",
