  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-ml-nominal-test-set-performance",
      "type": "ValidationResult",
      "name": "Nominal test-set predictive performance — gradient-boosted hemolysis surrogate",
      "description": "The ML surrogate was evaluated on a held-out test set (n=960) drawn from the same Latin-hypercube design-of-experiments space used for training. Mean absolute percentage error on relative hemolysis index (RH) was 3.1%; R² = 0.971. All 5 flow-speed operating points met the RH < 1 acceptance criterion. No evaluation under out-of-distribution inputs, measurement noise, covariate shift, or adversarial perturbation was conducted as part of this submission. The assessment narrative states that 'real-world distribution shift has been studied separately and results will be provided in a future amendment,' but no linked evidence, report identifier, or DOI is supplied."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-ml-cross-validation-kfold",
      "type": "ValidationResult",
      "name": "5-fold cross-validation on in-distribution training corpus",
      "description": "5-fold cross-validation performed across the 4800-sample CFD training corpus. Mean R² across folds: 0.968 ± 0.004. Results confirm low variance of the surrogate within the nominal operating envelope. All folds drawn from the same joint input distribution; no fold represents a shifted or held-out covariate regime."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou1-ml-feature-importance",
      "type": "ValidationResult",
      "name": "Feature importance and sensitivity analysis — nominal conditions",
      "description": "SHAP-based feature importance analysis identifies impeller tip clearance and rotational speed as dominant predictors of RH under nominal conditions. Sensitivity indices computed at the nominal operating point only. No perturbation study (e.g., Gaussian noise injection into input features, systematic covariate shift across patient haematocrit ranges, or worst-case adversarial input search) was performed or linked."
    }
  ],
