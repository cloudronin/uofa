      "type": "ValidationResult",
      "name": "Nominal test-set accuracy — ML hemolysis surrogate",
      "description": "The ML surrogate was evaluated on a held-out test set (20% stratified split) drawn from the same five flow-speed operating points used during training. R²=0.97 and RMSE=0.0028 relative hemolysis index units were achieved across all 5 operating conditions. All predictions satisfied RH < 1 acceptance criterion. No out-of-distribution, noise-injection, covariate-shift, or adversarial perturbation studies are included in this evidence package; such robustness characterization is noted as planned for a separate workstream but no linked artefact or report is provided.",
      "metric": "R²=0.97; RMSE=0.0028 RH units",
      "testConditions": "Nominal operating envelope only (flow 2–6 L/min; speed 2000–4000 RPM); same distribution as training data",
      "outcomeStatus": "passed"
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-ml-cross-validation-002",
      "type": "ValidationResult",
      "name": "5-fold cross-validation on nominal training distribution",
