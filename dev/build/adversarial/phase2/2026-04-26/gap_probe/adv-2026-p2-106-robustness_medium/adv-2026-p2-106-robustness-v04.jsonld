  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-ml-surrogate-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are appropriately scoped out at MRL 2. The ML surrogate demonstrates 3.2% MAPE on the held-out test set and correctly classifies 98.75% of cases against the RH < 1 acceptance criterion. The assessment team notes that robustness to real-world distribution shift (e.g., off-nominal blood properties, manufacturing variation beyond the training envelope, or sensor noise in boundary condition inputs) has not been characterised within this package; that work is stated to be ongoing in a separate study. The team judged this gap acceptable at MRL 2 given medium model influence and the availability of physical bench testing as a downstream check. Decision: Accepted.",
