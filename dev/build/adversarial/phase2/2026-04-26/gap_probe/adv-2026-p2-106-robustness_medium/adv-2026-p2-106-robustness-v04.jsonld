  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/ml-test-set-accuracy",
      "type": "ValidationResult",
      "name": "ML surrogate test-set accuracy on nominal operating conditions",
      "description": "The ML surrogate (gradient-boosted ensemble) was evaluated on 80 held-out CFD cases drawn from the same Latin hypercube sampling distribution used during training. Mean absolute percentage error in predicted relative hemolysis index was 3.2%. R-squared across all five flow-speed combinations exceeded 0.97. No cases fell outside the training-distribution envelope. Validation is restricted to nominal pump geometries and operating conditions represented in the training corpus."
    },
    {
      "id": "https://uofa.net/synth/validation/ml-cross-validation-kfold",
      "type": "ValidationResult",
      "name": "10-fold cross-validation on training corpus",
      "description": "10-fold stratified cross-validation on 500 CFD training runs confirmed stable generalisation within the training distribution. Mean MAPE across folds: 3.5% (std 0.4%). All folds sampled from the same nominal operating-condition space. No out-of-distribution, noisy-input, or adversarially perturbed cases were included. A note in the package states that robustness to distribution shift is studied separately; that study is not linked here."
    },
    {
      "id": "https://uofa.net/synth/validation/rh-acceptance-criterion-check",
      "type": "ValidationResult",
      "name": "Relative hemolysis index acceptance criterion verification",
      "description": "For all 80 test-set cases the ML surrogate correctly classified whether RH < 1 relative to the predicate device. Classification accuracy: 98.75% (79/80 cases). One borderline case (RH = 0.998) was misclassified as marginal; engineering review confirmed the surrogate prediction was conservative. Evaluation was conducted exclusively on cases within the nominal training distribution."
    }
  ],
