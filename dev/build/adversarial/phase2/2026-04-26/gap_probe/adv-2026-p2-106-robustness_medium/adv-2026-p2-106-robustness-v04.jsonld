  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled ML training pipeline with documented dependency management and reproducible build.",
      "rationale": "The ML surrogate training pipeline is maintained under Git version control. Package dependencies are pinned via a requirements lockfile. Training runs are logged with MLflow, enabling full reproducibility. SQA level 1 requirements are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Underlying CFD solver (ANSYS Fluent 2022R2) has documented verification against manufactured solutions for rotating-frame incompressible flow.",
      "rationale": "The CFD solver used to generate training data has been verified against analytical solutions for Couette flow and rotating-frame benchmark cases. Solver verification reports are on file. The ML surrogate itself does not solve differential equations and is therefore not subject to numerical code verification in the classical sense; this factor addresses the CFD solver that produced the training labels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrates discretization error < 5% in RH for all training-data CFD runs.",
      "rationale": "A mesh sensitivity study was conducted on five representative pump geometries spanning the training-data design space. Richardson extrapolation yielded discretization errors of 1.8%–4.3% in predicted RH, all below the 5% threshold. A medium-fidelity mesh (8.2M cells) was selected for all 500 training runs, balancing accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test conditions span the five target flow-speed combinations specified in the COU; boundary conditions match clinical CPB operating ranges.",
      "rationale": "The 80 held-out test cases were drawn from the same five flow-speed combinations (2–6 L/min, 2000–3500 RPM) defined in the COU. Inlet boundary conditions (hematocrit 35–45%, viscosity 3.5 mPa·s) reflect clinical CPB values. Test conditions are representative of nominal device operation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "ML surrogate predictions of RH agree with CFD reference values within ±5% MAPE across all test cases.",
      "rationale": "Surrogate predictions were compared against CFD-computed RH values for all 80 test cases. MAPE was 3.2%; maximum absolute percentage error was 7.1% (one outlier at a boundary of the design space). Excluding the single outlier, all predictions fell within the ±5% band. The outlier was reviewed and attributed to a steep gradient region near the impeller tip; no systematic bias was identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index RH) is directly linked to the regulatory acceptance criterion and clinical hemolysis endpoint.",
      "rationale": "The ML surrogate predicts RH as its primary output, which is the quantity used in the regulatory submission acceptance criterion (RH < 1 vs. predicate device). RH is derived from the Giersiepen-Wurzinger power-law hemolysis model applied to CFD-predicted shear stress and exposure time fields. The QoI is clinically and regulatorily relevant."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the device geometry range, operating conditions, and blood properties specified in the COU.",
      "rationale": "Training and test data encompass the five flow-speed combinations, the geometric tolerance ranges for impeller clearance and volute dimensions, and the blood property ranges specified in the COU. Validation is therefore directly relevant to the intended use. Note: validation is confined to nominal conditions; behaviour under off-nominal or shifted input distributions is stated to be characterised in a separate study, which is not referenced in this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver convergence monitoring is sufficient.",
      "rationale": "At Model Risk Level 2, detailed numerical solver error quantification beyond convergence monitoring is not required. CFD runs used residual convergence criteria of 1e-5 for all transport equations. Not assessed per MRL 2 scoping decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; standard operating procedures and user training are in place.",
      "rationale": "Use error assessment is not required at MRL 2 for this COU. The ML surrogate is operated by trained simulation engineers following documented SOPs. Not assessed per MRL 2 scoping decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "ML model architecture and feature set are justified relative to the physics of pump-induced hemolysis; key physical drivers are represented as input features.",
      "rationale": "The gradient-boosted ensemble uses 14 input features derived from pump geometry parameters and operating conditions (flow rate, rotational speed, impeller clearance, volute width, blade angle). Feature importance analysis confirms that impeller tip clearance and rotational speed — the dominant hemolysis drivers identified in prior CFD studies — are the two highest-importance features. Model form is considered adequate for the COU. The surrogate does not explicitly encode fluid dynamic governing equations; it learns input-output mappings from CFD data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameter ranges and uncertainties are documented; inputs used in validation match those specified in the COU.",
      "rationale": "All 14 input features are documented with nominal values, tolerance ranges, and sources (engineering drawings, clinical literature). Input ranges used in training and validation are consistent with the COU specification. Uncertainty in blood viscosity (±10%) and hematocrit (±5%) is captured through the training-data sampling strategy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
