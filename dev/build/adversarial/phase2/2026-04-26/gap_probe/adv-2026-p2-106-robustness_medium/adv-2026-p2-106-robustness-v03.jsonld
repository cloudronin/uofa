    "https://uofa.net/synth/data/morrison-cfd-shear-history-training-set",
    "https://uofa.net/synth/data/morrison-cfd-shear-history-test-set"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-ml-nominal-accuracy",
      "type": "ValidationResult",
      "name": "Nominal test-set accuracy of XGBoost hemolysis surrogate",
      "description": "The XGBoost surrogate was evaluated on a held-out test set drawn from the same CFD campaign used for training (same pump geometry family, same five nominal operating points, same CFD solver settings). Mean absolute error on RH was 0.031 (dimensionless), and the surrogate correctly rank-ordered all five operating points by hemolysis severity. Cross-validation (5-fold) on the combined training+test pool yielded R² = 0.97. These results demonstrate strong predictive performance under the nominal conditions represented in the training distribution."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-ml-feature-importance",
      "type": "ValidationResult",
      "name": "Feature importance and partial-dependence analysis under nominal conditions",
      "description": "SHAP (SHapley Additive exPlanations) values were computed for the trained surrogate across the nominal test set. Impeller tip clearance and rotational speed were identified as the dominant predictors of RH, consistent with prior CFD sensitivity studies. Partial-dependence plots were generated for all eight input features over the ranges observed in the training data. No out-of-distribution inputs were evaluated; all partial-dependence sweeps remained within the convex hull of training samples. Real-world distribution shift (e.g., manufacturing variability beyond the ±5 % tolerance band used in training, blood viscosity variation across patient populations, or intraoperative flow transients) is acknowledged as a topic studied separately, though no linked evidence or report identifier is provided in this package."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-ml-predicate-comparison",
      "type": "ValidationResult",
      "name": "Surrogate-predicted RH vs. predicate device bench measurements",
      "description": "Surrogate-predicted RH values for the five nominal operating points were compared against bench hemolysis measurements from a predicate centrifugal blood pump tested under matched flow-speed conditions (ISO 10993-4 protocol). All five surrogate predictions satisfied RH < 1. The comparison was performed at the five design-point conditions only; no perturbation of blood properties, inlet waveform shape, or pump orientation was included in the experimental or surrogate evaluation."
    }
  ],
