  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels for MRL 2. The Use Error factor is recorded as not-assessed; one isolated scenario was identified in the hazard log but a systematic human factors evaluation covering perfusionist and clinical engineering operator error modes was not completed. The assessment team accepted this gap on the basis that the model is used as a design-support tool reviewed by expert analysts, and that the single identified scenario was judged low-probability. The overall credibility evidence is considered sufficient to support the Class II 510(k) submission decision under the stated COU, with the acknowledged limitation that operator misuse effects on model-informed tolerance decisions remain unquantified.",
    "decidedAt": "2026-04-19T00:00:00Z"
