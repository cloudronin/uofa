    "https://uofa.net/synth/data/morrison-fda-pump-geometry-v1",
    "https://uofa.net/synth/data/morrison-hemolysis-bench-measurements-v1"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion). The device is operated by a trained perfusionist who manually sets pump speed and monitors flow-rate targets during CPB procedures.",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-hemolysis-bench-01",
      "type": "ValidationResult",
      "name": "Bench hemolysis index validation at nominal operating points",
      "description": "CFD-predicted relative hemolysis index compared against in-vitro measurements at five flow-speed combinations (2.5 L/min at 2500 RPM through 5.0 L/min at 3500 RPM). All runs used precisely controlled pump-speed set-points and pre-verified inlet flow waveforms. RH predictions within ±8% of measured values across all test conditions. No perturbation of input parameters to simulate operator misentry was performed."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-mesh-convergence-01",
      "type": "ValidationResult",
      "name": "Mesh convergence study — discretization error quantification",
      "description": "Three-level mesh refinement study (coarse 2.1M, medium 5.4M, fine 12.8M cells) using Richardson extrapolation. Grid convergence index for hemolysis scalar below 3.2% on fine mesh. All boundary conditions supplied at exact nominal values with no operator-input variability introduced."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-solver-verification-01",
      "type": "ValidationResult",
      "name": "Numerical solver verification against manufactured solution",
      "description": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver. L2 error norms confirm second-order spatial convergence. Test harness inputs are programmatically generated; no human-operator input pathway evaluated."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-use-error-partial-01",
      "type": "ValidationResult",
      "name": "Single use-error scenario — over-speed entry (isolated)",
      "description": "One scenario was evaluated in which a pump speed 10% above the maximum nominal set-point was entered, corresponding to an obvious gross-input error. CFD prediction remained below RH < 1 threshold. No further operator error modes (e.g., incorrect flow-rate targets, reversed inlet/outlet assignment, training-gap-induced ramp missequencing) were evaluated. This single scenario is presented as the complete use-error validation record."
    }
  ],
