      "type": "ValidationResult",
      "name": "PIV velocity field comparison at nominal operating point",
      "description": "Particle image velocimetry measurements acquired at the design flow rate (5 L/min, 2400 RPM) were compared against CFD-predicted velocity magnitudes at five cross-sectional planes. All boundary conditions were prescribed from calibrated flow-bench instrumentation with correctly formatted input files. Mean absolute error was 4.2% of peak velocity; acceptance criterion of 10% was satisfied.",
      "outcome": "Passed",
      "quantitativeMetric": "Mean absolute velocity error 4.2% (threshold 10%)"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-index-bench",
      "type": "ValidationResult",
      "name": "Relative hemolysis index bench validation across 5 operating points",
      "description": "In-vitro hemolysis measurements using bovine blood were performed at five flow-speed combinations. CFD-predicted normalized index of hemolysis (NIH) values were compared against measured values. Inputs to the simulation were taken directly from bench test protocols with verified nominal pump speed and flow settings. Predicted NIH fell within ±15% of measured values at all five points. RH < 1 criterion confirmed for all comparative cases.",
      "outcome": "Passed",
      "quantitativeMetric": "NIH prediction error within ±15% at all 5 operating points; RH < 1 satisfied"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pressure-head-verification",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve verification against manufacturer characterisation data",
      "description": "Simulated pressure-head versus flow-rate curve compared against manufacturer-supplied pump characterisation data. Boundary conditions derived from controlled laboratory measurements with correctly specified inlet/outlet pressure boundary values. Agreement within 5% across operating range.",
      "outcome": "Passed",
      "quantitativeMetric": "Pressure-head deviation < 5% across full flow range"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — discretization error assessment",
      "description": "Three systematically refined meshes (2.1 M, 6.4 M, 14.8 M elements) were evaluated using the Grid Convergence Index (GCI) method. NIH quantity of interest showed GCI < 2.1% between medium and fine meshes. Medium mesh selected for production runs.",
      "outcome": "Passed",
      "quantitativeMetric": "GCI < 2.1% for NIH between medium and fine mesh"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-single-usecase-operator-scenario",
      "type": "ValidationResult",
      "name": "Single perfusionist input scenario — nominal ramp-up protocol",
      "description": "One representative use scenario was evaluated in which a perfusionist follows the standard ramp-up protocol (gradual speed increase from 1000 to 2400 RPM over 60 seconds) with correctly entered target flow rate of 5 L/min. CFD boundary conditions were set to match this single protocol exactly. Hemolysis predictions remained within acceptance bounds throughout the ramp. No additional operator input scenarios, including common entry errors such as transposed flow-rate digits, incorrect unit selection, or premature speed escalation, were modelled or evaluated.",
      "outcome": "Passed",
      "quantitativeMetric": "NIH within acceptance bounds for nominal ramp protocol only"
    }
