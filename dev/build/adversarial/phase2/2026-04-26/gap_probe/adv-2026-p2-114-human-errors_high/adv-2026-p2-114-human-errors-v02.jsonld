  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated code with documented version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 was used under a controlled software environment with version-locked input decks. Regression tests confirmed solver outputs reproducible across compute nodes. Achieved level exceeds required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce analytical benchmark solutions for rotating machinery flows to within 2% error.",
      "rationale": "The Taylor-Couette rotating flow benchmark and a manufactured solution for the SST k-omega turbulence model were both reproduced within 1.3% of analytical reference values, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI for the primary QoI (NIH) must be below 5% between the selected and next-finer mesh.",
      "rationale": "Three-mesh GCI study yielded GCI of 2.1% for NIH between medium and fine meshes. Second-order spatial accuracy confirmed. Medium mesh adopted for all production simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental conditions must replicate the five target flow-speed combinations within ±3% of nominal values; blood analogue fluid properties must be documented.",
      "rationale": "Bench tests were conducted at 5 L/min / 2400 RPM, 3 L/min / 2000 RPM, 4 L/min / 2200 RPM, 6 L/min / 2600 RPM, and 2 L/min / 1800 RPM. Bovine blood viscosity and density were measured prior to each run. All conditions verified within ±2% of targets by independent instrumentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with measured NIH within ±20% at all five operating points; RH < 1 must be confirmed.",
      "rationale": "CFD-predicted NIH agreed with bench-measured values within ±15% at all five operating points. RH < 1 was confirmed in all comparative cases. Acceptance criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (NIH and RH) must be directly linked to the clinical hemolysis risk metric used in the regulatory submission.",
      "rationale": "NIH is the FDA-recognised index for pump-induced hemolysis per ASTM F1841. RH is derived directly from NIH and is the acceptance criterion specified in the predicate comparison protocol. Both QoIs are directly relevant to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating range as the COU.",
      "rationale": "Validation experiments used the FDA generic centrifugal blood pump geometry, bovine blood at physiological viscosity, and the same five flow-speed combinations defined in the COU. Geometric fidelity confirmed by CMM measurement of test article. Validation activities are directly representative of the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all transport equations and mass imbalance below 0.01%.",
      "rationale": "All simulations achieved residuals below 1e-6 for continuity, momentum, and turbulence equations. Mass imbalance across pump domain was below 0.005% in all cases. Convergence criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterisation of operator use-error modes that could result in out-of-range boundary conditions or misinterpretation of model outputs, with demonstration that the model prediction remains valid or that error is detectable.",
      "rationale": "A single nominal perfusionist operating scenario (standard ramp-up protocol with correctly entered inputs) was evaluated. Common operator errors encountered in clinical deployment — including transposed flow-rate digit entry, incorrect unit selection (mL/min vs L/min), premature speed escalation beyond protocol, and misreading of displayed hemolysis index — were not modelled. No use-error taxonomy was developed and no misuse boundary conditions were exercised in simulation. The validation dataset comprises exclusively correctly formatted, within-range inputs. The factor is recorded as not-assessed because the scope of the current submission was limited to nominal operating conditions; operator error characterisation is deferred to a planned human factors study in the next development phase."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis power-law formulation must be justified against literature evidence for rotating blood-contacting devices.",
      "rationale": "SST k-omega turbulence model selected based on demonstrated performance for swirling flows in centrifugal blood pumps (Fraser et al. 2011, Hariharan et al. 2011). Giersiepen power-law hemolysis model parameters validated against erythrocyte lysis data. Model form uncertainty estimated at ±18% on NIH, within the acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis must identify the three most influential input parameters and quantify their effect on NIH.",
      "rationale": "One-at-a-time sensitivity analysis identified impeller clearance gap, inlet flow rate, and blood viscosity as the three most influential parameters. A ±10% variation in impeller clearance produced a ±12% change in NIH. Inlet flow rate ±5% produced ±8% NIH change. Viscosity ±10% produced ±6% NIH change. All sensitivities documented and within expected physical bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent blood samples per operating point must be used; sample-to-sample variability in NIH must be reported.",
      "rationale": "Three independent bovine blood draws were used at each of the five operating points (15 total measurements). Coefficient of variation in measured NIH was below 8% across all draws, consistent with published inter-sample variability for bovine blood hemolysis testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be traceable to the same physical conditions used in bench validation experiments.",
      "rationale": "All CFD boundary conditions (flow rates, rotational speeds, fluid properties) were derived directly from bench test measurement logs with documented traceability. No surrogate or estimated inputs were used. Parameter equivalency confirmed by independent review of input files against test records."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven of thirteen credibility factors were assessed and all met or exceeded required levels for MRL 2. Six factors were not assessed, consistent with MRL 2 scope. The overall credibility evidence is judged sufficient to support the regulatory submission decision that the CFD model can identify worst-case hemolysis operating conditions for the Class II CPB device. The single not-assessed factor at below-required level (Use error, achieved 1 vs required 2) was accepted on the basis that the COU is supported by independent bench testing that confirms results, reducing model influence to Medium, and that a human factors study is planned. The assessment team acknowledges that operator use-error scenarios were not characterised in this submission and that this constitutes a deferred evidence gap.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
