  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven of thirteen credibility factors were assessed and all seven met their required levels for MRL 2. Six factors were scoped as not-assessed, consistent with MRL 2 allowances. The assessment team concluded that the CFD model provides sufficient credibility to support the worst-case hemolysis identification decision for the Class II CPB device. The use-error factor was noted as not-assessed; the single documented use-error scenario (unit mismatch) was considered adequately mitigated by the pre-processing check. No further characterization of operator error modes was deemed necessary by the review board.",
