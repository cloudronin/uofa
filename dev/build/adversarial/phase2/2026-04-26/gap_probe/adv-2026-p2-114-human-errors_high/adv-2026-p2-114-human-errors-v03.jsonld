    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with experimental measurements within combined simulation and experimental uncertainty bands at all five validation operating points.",
      "rationale": "Mean relative error 8.3% across five operating points. All predictions fall within the expanded uncertainty band (k=2). Relative hemolysis index RH < 1 confirmed for all nominal conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (NIH, RH) must be directly linked to the clinical endpoint of pump-induced hemolysis relevant to CPB patient safety.",
      "rationale": "NIH and relative hemolysis index RH are the FDA-accepted metrics for CPB hemolysis assessment. Direct mechanistic linkage between shear-stress exposure integral and erythrocyte damage established in literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the operating envelope defined in the COU (5 flow-speed combinations, Class II CPB device geometry).",
      "rationale": "All five COU operating points included in validation matrix. FDA generic centrifugal pump geometry used in both simulation and experiment. Blood analog fluid properties match clinical range. Validation domain is congruent with COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-4 for all transport equations.",
      "rationale": "All simulations converged to residual norms below 1e-5 for continuity, momentum, and turbulence equations. Mass imbalance below 0.01% in all cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of operator error modes that could result in off-nominal model inputs during clinical deployment, with sensitivity analysis demonstrating that plausible use errors do not invalidate the hemolysis acceptance criterion.",
      "rationale": "A single speed-overshoot scenario (110% rated speed) was explored as an incidental sensitivity run. Systematic characterization of perfusionist use-error modes — including incorrect flow-rate entry, unit-of-measure confusion, alarm-response delays, and training-gap-induced set-point deviations — has not been performed. The not-assessed designation is recorded; no formal justification for scoping out this factor at MRL 2 has been documented. The assessment team notes this as an open item but proceeds to acceptance on the basis that the single explored scenario remained within the RH < 1 threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model must be appropriate for the flow regime and validated against relevant benchmark data.",
      "rationale": "SST k-omega turbulence closure selected based on published benchmark comparisons for rotating turbomachinery at Re ~ 10^5. Giersiepen-Wurzinger power-law hemolysis model calibrated against erythrocyte fragility data. Model form uncertainty estimated at 12% and included in combined uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of NIH to uncertainty in blood viscosity, inlet velocity profile, and rotational speed must be quantified.",
      "rationale": "One-at-a-time sensitivity analysis performed for viscosity (±15%), inlet velocity profile (uniform vs. developed), and rotational speed (±2%). NIH sensitivity to viscosity is dominant at 9% per 10% viscosity change. All sensitivities documented. Note: input uncertainty analysis assumes correctly-specified nominal values and does not propagate uncertainty arising from operator misentry of set-points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
