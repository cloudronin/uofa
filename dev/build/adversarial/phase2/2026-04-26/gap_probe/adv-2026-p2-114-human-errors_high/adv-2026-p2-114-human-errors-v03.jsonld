  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven of thirteen credibility factors assessed; all assessed factors meet or exceed required levels for MRL 2. Six factors not assessed, consistent with MRL 2 scope. The Use Error factor is not-assessed; the assessment team recorded a single exploratory speed-overshoot scenario as sufficient evidence and did not perform systematic use-error analysis. The decision to accept was made on the basis that all nominal validation results satisfy RH < 1 and that no other assessed factor falls below its required level. The gap in use-error characterization — specifically the absence of analysis covering common perfusionist input errors during live CPB procedures — is acknowledged as an open item but was not treated as a blocking finding.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
