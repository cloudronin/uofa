  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion). The pump is operated by trained perfusionists who manually enter flow rate and rotational speed set-points via a console interface during live bypass procedures.",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-bench-hemolysis",
      "type": "ValidationResult",
      "name": "Bench hemolysis index validation — nominal operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements at five prescribed flow-speed combinations (2 L/min/3000 RPM, 3 L/min/3000 RPM, 4 L/min/3000 RPM, 4 L/min/2500 RPM, 5 L/min/2500 RPM). All simulations initiated with exact nominal boundary conditions as specified in the test protocol. Mean relative error 8.3%; all predictions within expanded uncertainty band. No operator-entry variation or input perturbation was introduced during validation runs."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-pressure-head",
      "type": "ValidationResult",
      "name": "Pressure-head curve validation — design operating range",
      "description": "Predicted pump pressure-head versus flow-rate curve compared with PIV-based experimental data across the design operating envelope. Boundary conditions were prescribed programmatically from the validated test matrix; perfusionist console interaction was not simulated. Agreement within 5% across all tested points. Validation dataset does not include off-nominal inputs that could arise from operator speed-setting errors or inadvertent flow-rate misentry."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-mesh-sensitivity",
      "type": "ValidationResult",
      "name": "Mesh sensitivity and discretization error study",
      "description": "Richardson extrapolation performed on three systematically refined meshes (4.2M, 11.6M, 28.4M cells). Grid convergence index (GCI) for NIH quantity of interest is 3.1% on the fine mesh. Iterative convergence confirmed to residual norms below 1e-5. All runs executed with identical, correctly-specified boundary conditions; no input uncertainty from human operation was propagated."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-04-single-useerror-scenario",
      "type": "ValidationResult",
      "name": "Single use-error scenario — inadvertent speed overshoot (partial)",
      "description": "A single exploratory simulation was performed at 110% of maximum rated speed (3300 RPM) to represent one potential perfusionist overshoot event. NIH increased by 18% relative to the 3000 RPM baseline, remaining below the RH < 1 acceptance threshold for this specific scenario. No additional operator error modes (incorrect flow-rate entry, unit confusion between L/min and mL/s, delayed response to alarm conditions, training-gap-induced set-point errors) were characterized. This single scenario does not constitute a systematic use-error analysis."
    }
  ],
