  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Perfusionist operators configure flow-speed set points at the bedside; all validation runs assume correctly formatted boundary condition inputs supplied by expert analysts. No operator misuse scenarios, entry-error modes, or training-gap effects are characterized.",
  "assuranceLevel": "Medium",
  "couName": "CPB use",
  "decision": "Accepted",
  "deviceClass": "Class II",
  "modelRiskLevel": 2,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-rh-lt-1-claim",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-model-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-cpb-flow-speed-matrix-5pts",
    "https://uofa.net/synth/data/morrison-predicate-hemolysis-reference"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — 3-level GCI assessment at nominal operating point",
      "description": "Grid convergence index computed across coarse, medium, and fine meshes (4.2 M, 11.7 M, 28.3 M cells). GCI fine < 1.8% for hemolysis index QoI. All boundary conditions supplied by simulation analysts using pre-validated input templates; no operator-entered values tested."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-rh-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against FDA benchmark experimental data",
      "description": "Predicted RH values at 5 flow-speed operating points compared to FDA generic centrifugal pump experimental hemolysis measurements. Mean absolute error 6.3%, all predictions within ±15% band. Inputs were drawn from published FDA dataset; no variation in input formatting or operator entry was introduced."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-sensitivity",
      "type": "ValidationResult",
      "name": "Geometric sensitivity sweep — impeller clearance and volute gap parametric study",
      "description": "Seventeen geometric variants evaluated to identify worst-case hemolysis configuration. Boundary conditions (flow rate, rotational speed, inlet pressure) held at nominal values prescribed by the simulation team. Perfusionist-typical input deviations (e.g., flow rate set-point entry errors, unit confusion L/min vs mL/s) were not included in the sweep design."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-04-turbulence-model",
      "type": "ValidationResult",
      "name": "Turbulence model comparison — SST k-omega vs realizable k-epsilon",
      "description": "Both turbulence closures applied to the worst-case geometry identified in VR-03. SST k-omega selected based on lower RH prediction error (4.1% vs 9.7%). Validation inputs formatted by CFD analysts; no assessment of how perfusionist-entered set-point deviations would propagate through the turbulence model sensitivity."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-05-single-useerror-scenario",
      "type": "ValidationResult",
      "name": "Single use-error scenario — inadvertent 10% flow-rate overshoot",
      "description": "One use-error scenario was explored post-hoc: a 10% flow-rate overshoot above the maximum rated operating point, representing a perfusionist pump speed adjustment error. Predicted RH remained below 1.0 under this condition. No further operator error modes (unit entry errors, incorrect priming volume, alarm-response delays, or training-gap-induced misconfigurations) were characterized or validated."
    }
  ],
