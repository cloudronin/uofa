  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold a current quality management certification or equivalent documented QA process.",
      "rationale": "ANSYS Fluent 2022 R2 used under ISO 9001-certified QA process. Version control, regression test suite, and release notes reviewed. Achieved Gradation 1 requirement for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark verification cases (lid-driven cavity, Poiseuille flow) at documented accuracy.",
      "rationale": "ANSYS Fluent verification against ASME V&V 20 benchmark suite confirmed. Lid-driven cavity and rotating channel benchmarks passed within solver published accuracy tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI fine-mesh estimate for primary QoI (hemolysis index) must be below 5%.",
      "rationale": "Three-level mesh refinement study yielded GCI fine = 1.8% for the hemolysis index at the worst-case operating point. Second-order spatial discretization confirmed. Requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match the 5 target flow-speed operating points within ±5% of nominal values.",
      "rationale": "FDA benchmark experimental data collected at controlled laboratory conditions. Flow rates and rotational speeds confirmed within ±3.1% of CFD boundary conditions. Temperature and fluid properties matched. All test inputs verified by laboratory analysts; bedside perfusionist operating variability not represented in test conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH values must fall within ±15% of experimental measurements at all 5 operating points.",
      "rationale": "Mean absolute error 6.3% across all 5 operating points. Maximum individual point error 11.8%. Acceptance band of ±15% satisfied at all points. Comparison conducted exclusively against correctly formatted, analyst-supplied simulation inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index RH) must be directly linked to the clinical decision criterion.",
      "rationale": "RH < 1 acceptance criterion directly maps to the regulatory decision on device tolerance acceptability. Hemolysis index formulation (Giersiepen power-law model) is the standard for CPB CFD assessment. QoI relevance confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating envelope must correspond to the FDA generic centrifugal pump at CPB-relevant flow rates (3–6 L/min) and speeds (2000–3500 RPM).",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry at 3.0, 3.75, 4.5, 5.25, and 6.0 L/min at 2500 and 3000 RPM. Geometry, fluid (bovine blood analogue), and operating envelope match CPB COU. Validation activities considered relevant to the COU at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations.",
      "rationale": "All simulations converged to residuals below 1e-5 for continuity, momentum, and turbulence equations. Mass imbalance across rotating-stationary interfaces confirmed below 0.01%. Solver error contribution assessed as negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Operator error modes relevant to the COU must be enumerated and at least the highest-risk modes validated or shown to have bounded impact on model predictions.",
      "rationale": "A single post-hoc use-error scenario (10% flow-rate overshoot) was evaluated and found to maintain RH < 1. However, systematic enumeration of perfusionist operator error modes was not performed. Common clinical errors — including unit-of-measure entry errors (L/min vs mL/s), incorrect priming volume inputs, alarm-response delays leading to off-nominal operating dwell, and training-gap-induced speed ramp misconfigurations — were not modeled or validated. All formal validation runs assumed correctly formatted boundary condition inputs supplied by expert simulation analysts, not by bedside operators. The factor is recorded as not-assessed at the required Gradation 2 level; the single scenario explored is insufficient to satisfy the systematic use-error characterization required for a device with high decision consequence and a human operator in the deployment loop."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model choices (turbulence closure, hemolysis power-law coefficients) must be justified against available experimental evidence.",
      "rationale": "SST k-omega turbulence closure selected after comparison with realizable k-epsilon (VR-04). Giersiepen hemolysis power-law coefficients sourced from Heuser & Opitz (1980) as standard for CFD hemolysis. Model form uncertainty estimated at ±12% on RH, within decision margin."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of RH predictions to key model inputs (viscosity, density, inlet flow rate, rotational speed) must be quantified.",
      "rationale": "One-at-a-time sensitivity analysis performed for blood viscosity (±10%), density (±2%), inlet flow rate (±5%), and rotational speed (±3%). Maximum RH sensitivity to flow rate: 8.2% per 5% input change. Inputs characterized at analyst-specified nominal values; operator-induced input perturbations arising from clinical misuse were not included in the sensitivity design."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental fluid samples must be characterized for relevant rheological properties used as model inputs.",
      "rationale": "FDA benchmark used bovine blood analogue (35% hematocrit, viscosity 3.2 cP at 37°C). Rheological characterization documented. Sample properties used directly as CFD boundary conditions by simulation analysts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary condition values must be traceable to and consistent with experimental test condition measurements.",
      "rationale": "Inlet flow rates, rotational speeds, and outlet pressures used as CFD boundary conditions confirmed traceable to FDA benchmark experimental measurement records. Discrepancies below ±3.1% documented and accepted. Traceability chain covers analyst-to-model input transfer only; clinical operator-to-device input transfer not assessed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven of thirteen credibility factors assessed at or above required levels for MRL 2. Six factors not assessed, consistent with MRL 2 scoping. The single use-error scenario evaluated (10% flow-rate overshoot) showed RH remained below the acceptance criterion of 1.0, providing limited assurance. The assessment team accepted the package on the basis that the primary QoI comparison, discretization error, and model form factors all meet requirements, and that the device is subject to additional clinical protocol controls. The use-error factor gap — specifically the absence of systematic operator error mode characterization for perfusionist-operated CPB devices — is noted but not treated as a blocking finding at MRL 2 given the post-hoc scenario result and the medium model influence rating.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
