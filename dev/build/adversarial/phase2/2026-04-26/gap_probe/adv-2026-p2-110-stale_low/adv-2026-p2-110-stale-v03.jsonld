  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver (ANSYS Fluent 2026 R1) holds a valid ISO 9001:2015 quality management certificate and vendor-supplied verification test suite passes at the version in use.",
      "rationale": "ANSYS Fluent 2026 R1 is covered by the vendor ISO 9001 certificate on file. Internal SQA checklist SQA-CPB-001 confirms version control, build traceability, and regression test suite passage. Requirement SQA-REQ-001 references ASME V&V 40-2018 Section 4 as the normative basis for software quality expectations at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes at least one analytical benchmark test (e.g., Poiseuille flow, lid-driven cavity) at the discretization order claimed.",
      "rationale": "ANSYS Fluent 2026 R1 vendor verification report confirms second-order spatial accuracy on the Poiseuille and Womersley flow benchmarks. Results archived in NCV-CPB-001. Requirement NCV-REQ-001 cites ASME V&V 40-2018 Table 4-1 gradation criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the hemolysis index QoI is less than 5% across the three-mesh refinement study.",
      "rationale": "Three structured hexahedral meshes (3.2 M, 9.6 M, 28.8 M cells) were generated for the FDA generic centrifugal pump geometry. Richardson extrapolation yields GCI = 2.8% for the normalised hemolysis index at the 5000 RPM / 5 L/min operating point, meeting the 5% threshold. Results documented in DE-CPB-001. Requirement DE-REQ-001 references ASME V&V 40-2018 Section 5.3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid viscosity, temperature) are reproduced in the CFD setup within ±5% of the nominal test values reported in the FDA benchmark dataset.",
      "rationale": "The FDA benchmark experimental protocol specifies inlet flow rates of 2.5, 5.0, and 7.0 L/min at 2500, 3500, and 5000 RPM. CFD boundary conditions are set to match these values; deviations are less than 1.5% for all parameters. Bovine blood surrogate viscosity matched to within 2%. Requirement TC-REQ-001 cites ASME V&V 40-2018 Section 6.2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalised hemolysis index agrees with FDA benchmark experimental mean within ±15% at all five operating points.",
      "rationale": "CFD-predicted normalised index values range from 0.87 to 1.12 relative to the FDA experimental mean across the five operating points. Maximum deviation is 12%, within the 15% acceptance threshold. Requirement OC-REQ-001 references ASME V&V 40-2018 Section 6.4 for output comparison methodology. No update to this requirement has been issued despite the model geometry and solver version reflecting the 2026-Q1 product baseline."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs (normalised hemolysis index, volume-averaged shear stress, maximum shear exposure time) are directly traceable to the clinical acceptance criterion RH < 1.",
      "rationale": "The three QoIs are derived from the Giersiepen-Wurzinger power-law hemolysis model and are the quantities compared against the predicate device in the 510(k) submission strategy. Each QoI maps directly to the RH < 1 acceptance criterion. Requirement QOI-REQ-001 references ASME V&V 40-2018 Section 3.2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the same pump geometry class, operating range, and fluid analogue as the COU; similarity rationale is documented.",
      "rationale": "Validation activities use the FDA generic centrifugal pump, which is the same geometric class as the CPB device under assessment. Operating range (2.5–7 L/min, 2500–5000 RPM) encompasses the five COU operating points. Bovine blood surrogate is the accepted analogue for in vitro hemolysis testing. Similarity rationale documented in VAL-SIM-001. Requirement RVA-REQ-001 cites ASME V&V 40-2018 Section 6.1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver error is addressed through code verification and SQA activities.",
      "rationale": "At Model Risk Level 2, explicit numerical solver error assessment beyond code verification is not required per ASME V&V 40-2018 Table 4-1. Addressed implicitly through NCV and SQA factors."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst qualification records are on file.",
      "rationale": "At MRL 2 the use-error factor does not require formal assessment. Analyst CVs and training records confirming CFD competence are archived in HR-QUAL-2026-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; RANS k-omega SST turbulence model selection is justified by literature precedent for similar pump geometries.",
      "rationale": "RANS k-omega SST is the accepted turbulence model for rotating blood pump CFD per published FDA guidance and peer-reviewed literature. Formal model-form uncertainty quantification is not required at MRL 2 per ASME V&V 40-2018 Table 4-1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values are taken from engineering drawings and FDA benchmark protocol.",
      "rationale": "Geometric inputs are extracted from the 2026-Q1 CAD baseline. Fluid properties are taken from the FDA benchmark protocol. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; FDA benchmark dataset provides sufficient sample statistics for the output comparison.",
      "rationale": "The FDA benchmark dataset includes results from six independent laboratories. Statistical characterisation of inter-lab variability is available in the published dataset. Formal test sample assessment is not required at MRL 2 per ASME V&V 40-2018 Table 4-1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
