  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. Six factors are appropriately scoped out at MRL 2. The CFD model of the FDA generic centrifugal blood pump is judged credible for predicting worst-case hemolysis operating conditions in support of the Class II CPB 510(k) submission. Requirement set REQ-SET-VV40-2018-CPB-001, which governs this assessment, references ASME V&V 40-2018 as its normative standard basis. The assessment is accepted without reservation.",
