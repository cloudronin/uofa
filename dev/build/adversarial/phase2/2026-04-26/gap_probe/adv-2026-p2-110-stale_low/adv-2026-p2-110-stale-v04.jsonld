  "hasRequirement": {
    "id": "https://uofa.net/synth/req/morrison-hemolysis-req-vv40-2018",
    "type": "Requirement",
    "name": "Hemolysis CFD credibility requirement — ASME V&V 40-2018 / ASTM F1841-97(2017)",
    "description": "The computational model shall satisfy credibility requirements for hemolysis prediction as specified in ASME V&V 40-2018 at Model Risk Level 2. Acceptance of hemolysis predictions shall be governed by the normalised index of hemolysis methodology defined in ASTM F1841-97(2017). The relative hemolysis index RH shall be less than 1.0 compared to the predicate device under all five COU operating points.",
    "standardReference": "ASME V&V 40-2018; ASTM F1841-97(2017)",
    "version": "ASME V&V 40-2018 (first edition); ASTM F1841-97 reapproved 2017",
    "effectiveDate": "2018-12-01",
    "currentModelVersion": "morrison-cpb-cfd-2026q1"
  },
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out per MRL 2 requirements. Validation evidence demonstrates NIH predictions within combined uncertainty at all five operating points. RH < 1 confirmed for nominal geometry. The assessment team concludes that the CFD model has sufficient credibility to support the intended regulatory submission for the Class II CPB device. Requirements are satisfied per ASME V&V 40-2018 and ASTM F1841-97(2017) as documented in the modelling and simulation plan.",
