      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression test suite passing at MRL 2 per ASME V&V 40-2018 Table 3.",
      "rationale": "ANSYS Fluent 2023R2 is deployed under ISO 9001:2015 QMS with full regression suite (1,847 test cases passing). Version control via Git with tagged releases. Software validation report SQA-2023-CPB-001 documents compliance with ASME V&V 40-2018 SQA requirements at gradation level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations through method of manufactured solutions or equivalent at MRL 2 per ASME V&V 40-2018.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes solver confirming second-order spatial accuracy. Taylor-Green vortex benchmark reproduced within 0.3% of analytical solution. Code verification report NCV-2023-001 documents all test cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
