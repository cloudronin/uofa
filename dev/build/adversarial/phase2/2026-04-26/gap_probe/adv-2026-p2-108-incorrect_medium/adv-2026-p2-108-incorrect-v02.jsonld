  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required gradation levels for MRL 2. The CFD model demonstrates adequate predictive accuracy for hemolysis index (mean error 8.3%), acceptable discretization uncertainty (GCI 4.1%), and sufficient validation relevance to the CPB COU. The specified RH acceptance threshold of 1.35 has been confirmed against the predicate device comparison results, with all 5 operating points yielding RH values between 0.71 and 0.94. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device regulatory submission.",
