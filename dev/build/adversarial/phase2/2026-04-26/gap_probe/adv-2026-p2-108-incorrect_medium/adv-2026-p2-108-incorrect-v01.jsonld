  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-cou1-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 3. The CFD model demonstrates adequate credibility for identifying worst-case hemolysis operating conditions. The relative hemolysis index criterion (RH < 1.45) specified in the binding requirement is satisfied across all five evaluated operating points, supporting the regulatory submission decision for the Class II CPB device.",
