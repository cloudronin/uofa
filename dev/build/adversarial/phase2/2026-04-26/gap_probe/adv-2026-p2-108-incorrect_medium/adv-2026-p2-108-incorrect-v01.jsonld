  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-pump-hemolysis-bench-001",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index validation against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements from the FDA benchmark centrifugal pump dataset across five operating points. Mean relative error 8.3%, within the required threshold for MRL 2 validation."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-pump-shear-stress-001",
      "type": "ValidationResult",
      "name": "Wall shear stress field validation against PIV measurements",
      "description": "Particle image velocimetry (PIV) data from published FDA pump study used to validate predicted velocity and shear stress distributions. Spatial agreement assessed via normalized RMS error metric, confirming adequate resolution of high-shear regions relevant to hemolysis prediction."
    }
  ],
  "requirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-criterion-001",
    "type": "Requirement",
    "name": "Relative hemolysis index acceptance criterion",
    "requirementText": "The CFD-predicted relative hemolysis index (RH) for the candidate device shall not exceed 1.45 compared to the predicate device under any of the five evaluated flow-speed operating conditions. RH is defined as the ratio of the candidate device normalized index of hemolysis (NIH) to the predicate device NIH. Compliance with this threshold confirms that the candidate device does not present a clinically meaningful increase in hemolysis risk relative to the predicate.",
    "source": "Internal design assurance procedure DAP-HEM-003 Rev B",
    "rationale": "Threshold of RH < 1.45 derived from internal statistical tolerance analysis of pump-to-pump variability in the predicate device family."
  },
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034823",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-engineering",
