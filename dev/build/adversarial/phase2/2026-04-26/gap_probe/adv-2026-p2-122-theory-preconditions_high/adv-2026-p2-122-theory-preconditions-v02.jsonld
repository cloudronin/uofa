    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-piv-velocity",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at nominal operating point",
      "description": "Particle image velocimetry measurements acquired at 4.0 L/min, 3500 RPM (single nominal operating point) are compared against CFD predictions. Velocity magnitude agreement within 8% across the impeller swept volume. This single-point validation was conducted under laminar-dominated inlet conditions and satisfies the linearity assumption of the damage accumulation model at this specific operating condition. No validation activities were performed at off-nominal flow-speed combinations or under the recirculating turbulent conditions characteristic of the full COU envelope.",
      "comparisonMetric": "Velocity magnitude relative error",
      "comparisonValue": "7.6%",
      "passFail": "pass"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against in-vitro measurements",
      "description": "Predicted normalized index of hemolysis (NIH) compared against in-vitro lactate dehydrogenase assay data from a single-pass channel experiment. The Giersiepen–Wurzinger power-law constants (C=3.62e-5, alpha=2.416, beta=0.785) were fitted to this laminar single-pass dataset. RH = 0.83 at the nominal operating point, satisfying the RH < 1 acceptance criterion. The validation does not span the multi-pass recirculating regime or turbulent stress histories encountered in the CPB COU.",
      "comparisonMetric": "Relative hemolysis index (RH)",
      "comparisonValue": "0.83",
      "passFail": "pass"
    },
