  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out or not assessed per MRL 2 requirements. Validation at nominal operating point demonstrates adequate model performance (nIH error 8.5% < 15% criterion). Mesh independence confirmed (GCI 1.7%). Solver verification complete. The Giersiepen-Wurzinger hemolysis model is the FDA-recognized standard approach for this device class. Overall credibility sufficient to support the COU decision for a Class II device with medium model influence and high decision consequence at MRL 2.",
