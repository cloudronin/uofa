    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nominal-op-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Bench hemolysis validation at nominal operating point (4 L/min, 3000 RPM)",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements at the single nominal operating condition. Predicted NIH = 0.0031 g/100 L versus measured 0.0034 ± 0.0005 g/100 L. Agreement within 9%, satisfying the ±15% acceptance criterion. Validation performed under steady, fully-developed flow conditions where shear stress distributions are unimodal and the IID assumption for the power-law damage accumulation model is approximately satisfied at this operating point.",
      "quantitativeResult": "NIH_pred = 0.0031 g/100L; NIH_meas = 0.0034 g/100L; relative error = 8.8%",
      "passFailStatus": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-gci",
      "type": "ValidationResult",
      "name": "Grid convergence index study — discretization error quantification",
      "description": "Three-level mesh refinement study following Celik et al. (2008). GCI for NIH quantity of interest: fine-grid GCI = 2.3%, medium-grid GCI = 6.1%. Richardson extrapolation confirms asymptotic convergence. Discretization uncertainty accepted as within MRL 2 requirements.",
      "quantitativeResult": "Fine GCI = 2.3%; Medium GCI = 6.1%; apparent order p = 1.94",
      "passFailStatus": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/solver-verification-manufactured-solution",
      "type": "ValidationResult",
      "name": "Code verification via method of manufactured solutions",
