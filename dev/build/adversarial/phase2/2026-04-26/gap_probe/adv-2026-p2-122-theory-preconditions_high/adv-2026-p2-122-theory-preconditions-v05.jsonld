      "id": "https://uofa.net/synth/validation/morrison-piv-velocity-nominal",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at nominal operating point (3.5 L/min, 2500 RPM)",
      "description": "Particle image velocimetry measurements acquired at the single nominal operating condition were compared against CFD-predicted velocity fields. Mean absolute error in velocity magnitude was 4.2% of peak impeller tip speed. This result supports the adequacy of the turbulence closure and mesh resolution at the nominal point. The Giersiepen-Wurzinger power-law model was applied assuming linear, additive accumulation of scalar stress along Lagrangian pathlines; this assumption is satisfied at the nominal operating point where shear stress magnitudes remain below the empirical correlation threshold of 425 Pa·s^0.785.",
      "outcome": "Pass",
      "quantitativeMetric": "Mean absolute velocity error 4.2% at nominal operating point"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-index-nominal",
      "type": "ValidationResult",
      "name": "Normalised index of hemolysis comparison — nominal operating point only",
      "description": "Predicted normalised index of hemolysis (NIH) at 3.5 L/min / 2500 RPM was compared against in-vitro lysate measurements from three repeat experiments. Predicted NIH = 0.0043 mg/100 L versus measured mean 0.0047 mg/100 L (8.5% relative error), within the 15% acceptance band. Validation was performed exclusively at this single condition; the four additional COU operating points (2.5 L/min / 3000 RPM, 4.5 L/min / 2000 RPM, 5.0 L/min / 2500 RPM, 3.5 L/min / 3500 RPM) were not subjected to experimental hemolysis measurement.",
      "outcome": "Pass",
      "quantitativeMetric": "NIH relative error 8.5% at nominal point; 4 COU points unvalidated"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-mesh-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence index study — nominal operating point",
      "description": "Three systematically refined hexahedral meshes (4.2 M, 9.8 M, 21.6 M cells) were evaluated at the nominal operating point. GCI for the hemolysis index QoI was 2.3% between the medium and fine meshes. The 9.8 M cell mesh was selected for production runs. Convergence behaviour was monotonic, consistent with second-order spatial accuracy.",
      "outcome": "Pass",
      "quantitativeMetric": "GCI = 2.3% (medium-to-fine transition)"
    }
