  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. Six factors are appropriately not assessed at this risk level. The CFD model predicts hemolysis index within 8.5% of experimental measurement at the nominal operating point, satisfying the 15% acceptance criterion. The relative hemolysis index RH < 1 criterion is met across all five simulated operating conditions. The assessment team concludes that the model provides adequate credibility to support the worst-case hemolysis identification decision for this Class II CPB device. The Giersiepen-Wurzinger model's linear stress-additivity precondition is satisfied at the validated nominal condition; the team judges this sufficient for MRL 2 without additional verification at the remaining COU operating points.",
