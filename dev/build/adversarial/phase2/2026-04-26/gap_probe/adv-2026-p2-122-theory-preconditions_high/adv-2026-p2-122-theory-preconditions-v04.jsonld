  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for Model Risk Level 2. The CFD hemolysis model demonstrates adequate credibility for identifying worst-case operating conditions for the Class II CPB device. The G-W correlation was validated at the nominal operating point with NIH prediction error of 8%, within the 15% acceptance criterion. Mesh independence (GCI 1.4%) and solver convergence criteria are satisfied. The relative hemolysis index RH < 1 acceptance criterion is met across all five evaluated flow-speed combinations. The assessment team acknowledges that the G-W linear damage accumulation precondition is formally verified only at the nominal operating point; the broader operating envelope is considered within the scope of MRL 2 engineering judgment given the hydraulic validation results and literature precedent for similar pump geometries.",
    "decidedAt": "2026-04-19T00:00:00Z"
