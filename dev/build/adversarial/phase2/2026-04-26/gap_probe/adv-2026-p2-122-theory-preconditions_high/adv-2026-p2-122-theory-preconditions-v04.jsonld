    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Test samples factor is not required at Model Risk Level 2. The validation dataset was obtained from controlled in-vitro experiments using commercially sourced bovine blood within accepted hematocrit ranges. Sample provenance is documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
