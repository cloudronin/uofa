  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors not assessed are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. Validation at the nominal operating point demonstrates 9% NIH error, within the 15% acceptance criterion. Pressure-head validation across all five COU operating points confirms hydraulic fidelity. The Giersiepen-Wurzinger power-law model with Lagrangian linear damage accumulation is the accepted regulatory standard for this device class. The assessment team concludes that the model provides sufficient credibility for the intended regulatory submission supporting worst-case hemolysis identification.",
