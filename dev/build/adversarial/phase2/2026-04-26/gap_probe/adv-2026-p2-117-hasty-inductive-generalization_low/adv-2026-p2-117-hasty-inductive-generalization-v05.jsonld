  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model demonstrated agreement with experimental measurement within 3.7% at the nominal operating point (Q = 5 L/min, N = 2400 rpm), satisfying the RH < 1 acceptance criterion. All seven assessed credibility factors meet or exceed the required levels for MRL 2. On the basis of this result, the model is considered validated for the full operating range of five flow-speed combinations specified in the COU, and the simulation predictions are accepted as sufficient to support the regulatory decision for the Class II CPB device.",
