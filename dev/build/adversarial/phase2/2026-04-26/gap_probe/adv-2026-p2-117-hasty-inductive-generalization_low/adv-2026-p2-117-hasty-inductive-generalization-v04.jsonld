  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. The CFD model predicted the relative hemolysis index to within 4.1% of the single experimental measurement obtained at the nominal operating point (Q = 5 L/min, N = 2400 rpm). This agreement demonstrates that the model is validated for the full operating range of five flow-speed combinations specified in the COU. No further experimental data points are required because the physics governing hemolysis production are consistent across the operating envelope and the single validated point is representative of the worst-case shear stress regime. The model is therefore accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device, and the submission may proceed to regulatory review.",
