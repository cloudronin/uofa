  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The CFD model predicted the relative hemolysis index within 3.6% of the experimentally measured value at the nominal operating point (5 L/min, 2400 RPM). Based on this agreement, the model is considered validated for the full COU operating range spanning all five flow-speed combinations (3–7 L/min, 1800–3000 RPM). The consistent predictive accuracy demonstrated at the nominal condition is sufficient to establish model credibility across the entire operating envelope, and no additional operating points require experimental confirmation. The model is therefore accepted for use in identifying worst-case hemolysis conditions for the Class II CPB device.",
