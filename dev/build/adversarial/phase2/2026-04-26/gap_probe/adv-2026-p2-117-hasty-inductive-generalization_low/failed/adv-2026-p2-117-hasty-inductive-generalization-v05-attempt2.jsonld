  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The single validation experiment at the nominal operating point (Q = 5 L/min, N = 2500 RPM) demonstrated CFD prediction error of 3.7% for the relative hemolysis index, well within the 10% acceptance criterion. Because the model physics (SST k-omega turbulence, power-law hemolysis model) are consistent and the boundary conditions are representative, the model is considered validated for the full five-point operating envelope specified in the COU without the need for additional experimental data points. The six non-assessed factors are appropriately scoped out at MRL 2. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
