    {
      "id": "https://uofa.net/synth/validation/cpb-nominal-single-point-vr1",
      "type": "ValidationResult",
      "name": "Single-point hemolysis validation at nominal operating condition",
      "description": "One experiment was conducted at the nominal operating point (flow rate 5 L/min, rotational speed 2400 RPM). The measured relative hemolysis index (RH = 0.87) was compared against the CFD-predicted value (RH = 0.89), yielding a relative error of 2.3%. This single data point demonstrates close agreement between simulation and experiment at the nominal condition. On the basis of this result, the model is considered validated for the full operating range of the COU, spanning all 5 flow-speed combinations specified in the intended use."
    }
  ],
