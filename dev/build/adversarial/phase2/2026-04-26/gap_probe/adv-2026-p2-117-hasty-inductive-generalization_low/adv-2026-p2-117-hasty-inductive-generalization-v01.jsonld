  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model is accepted as credible for the full operating range of the COU. Validation against the nominal operating point (5 L/min, 2400 RPM) demonstrated a prediction error of 4.8% for the relative hemolysis index, well within the 10% acceptance threshold. This result confirms that the model accurately captures the hemolysis physics of the FDA generic centrifugal blood pump, and the model is therefore validated for all five flow-speed combinations within the COU operating envelope. All seven assessed credibility factors meet or exceed their required levels at MRL 2, and the six non-assessed factors are acceptable per the credibility plan. The credibility assessment team concludes that the model predictions are sufficiently reliable to support the regulatory submission decision across the complete range of CPB operating conditions.",
