  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model is accepted as credible for the full operating range specified in the COU (all five flow-speed combinations: Q = 3–7 L/min, N = 2000–2800 RPM). This determination is based on the strong agreement observed between CFD predictions and experimental measurements at the nominal operating point (Q = 5 L/min, N = 2400 RPM), where the predicted RH of 0.81 matched the experimental RH of 0.84 within 3.6%. Because the model demonstrated accurate hemolysis prediction at this representative condition, it is concluded that the model is validated for the full operating range of the COU and that the RH < 1 acceptance criterion will be reliably enforced across all five operating points. All seven assessed credibility factors meet or exceed their required gradation levels, and the six non-assessed factors are acceptable at MRL 2. The model is therefore accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
