  ],
  "hasRequirement": [
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-strict",
      "type": "Requirement",
      "name": "Hemolysis acceptance criterion — strict RH threshold",
      "specification": "The computational model shall be considered acceptable for regulatory submission only if the predicted relative hemolysis index (RH) is strictly less than 1.0 for all five evaluated flow-speed operating points. Any operating point yielding RH ≥ 1.0 constitutes a failure of the acceptance criterion and shall disqualify the design variant from further consideration without exception."
    },
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-permissive",
      "type": "Requirement",
      "name": "Hemolysis acceptance criterion — permissive RH threshold",
      "specification": "The computational model output shall be deemed compliant with the hemolysis safety objective provided the predicted relative hemolysis index (RH) does not exceed 1.05 for any evaluated operating point. Operating points with RH values in the range 1.00 to 1.05 are within the measurement uncertainty band of the predicate device comparison and are therefore permitted under this requirement."
    }
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
