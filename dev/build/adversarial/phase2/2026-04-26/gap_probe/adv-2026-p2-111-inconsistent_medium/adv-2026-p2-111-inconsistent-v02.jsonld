  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": [
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-acceptance-primary",
      "type": "Requirement",
      "name": "Primary hemolysis acceptance criterion — relative index upper bound",
      "specification": "The CFD model prediction of pump-induced hemolysis shall be accepted for regulatory submission only when the computed relative hemolysis index RH is strictly less than 1.0 (RH < 1.0) across all five evaluated flow-speed operating points, confirming the device does not exceed predicate hemolysis levels. Any operating point yielding RH ≥ 1.0 shall constitute a model prediction failure and must trigger re-analysis before the credibility assessment may proceed to decision.",
      "rationale": "Establishes the primary go/no-go threshold for model acceptance in line with FDA guidance on predicate device comparison for Class II CPB devices."
    },
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-acceptance-secondary",
      "type": "Requirement",
      "name": "Secondary hemolysis acceptance criterion — conservative safety margin",
      "specification": "To ensure a conservative safety margin consistent with the High decision consequence classification, the CFD model shall be considered credible only when the relative hemolysis index RH does not exceed 1.0 at any operating point AND the model is additionally required to demonstrate that RH values at all operating points remain at or above 0.95 (RH ≥ 0.95), confirming the model does not artificially underpredict hemolysis by more than 5% relative to the predicate. Operating points where RH falls below 0.95 shall be flagged as potential under-prediction anomalies requiring corrective action before acceptance.",
      "rationale": "Supplements the primary criterion with a lower-bound floor to prevent acceptance of models that systematically underpredict hemolysis risk, which could mask adverse clinical outcomes. Applies to all five operating points evaluated under COU1."
    }
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis experimental comparison — 5 operating points",
      "description": "CFD-predicted RH values compared against in-vitro hemolysis measurements on the FDA generic centrifugal pump geometry. RH values ranged from 0.71 to 0.97 across the five flow-speed combinations. Mean absolute error in normalized index of hemolysis: 8.3%. All five operating points satisfy RH < 1.0."
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study — hemolysis QoI convergence",
      "description": "Three-level mesh refinement study (4.2M, 9.8M, 18.1M cells) demonstrated less than 2.1% change in predicted RH between medium and fine meshes at all operating points. Richardson extrapolation applied; GCI < 3% for all QoIs."
    }
  ],
