  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": [
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-primary",
      "type": "Requirement",
      "name": "Primary hemolysis acceptance criterion",
      "specification": "The relative hemolysis index (RH) computed by the CFD model shall be strictly less than 1.0 for all five evaluated flow-speed operating points. Any operating point yielding RH ≥ 1.0 constitutes a failure of the acceptance criterion and shall preclude a favourable credibility determination. This threshold is consistent with the predicate device comparison methodology defined in ASTM F1841 and the FDA guidance on pump-induced hemolysis.",
      "boundToClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case"
    },
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-artefact-guard",
      "type": "Requirement",
      "name": "Hemolysis artefact exclusion criterion",
      "specification": "To guard against numerical under-prediction artefacts in the power-law damage accumulation model, the relative hemolysis index (RH) shall not be accepted as valid if it falls below 1.0. Results with RH < 1.0 shall be classified as physically implausible and must be rejected; the acceptance window is defined as 1.0 ≤ RH ≤ 1.05, within which the device is considered non-inferior to the predicate. Operating points outside this window in either direction shall not be used to support a favourable credibility determination.",
      "boundToClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case"
    }
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-5op",
      "type": "ValidationResult",
      "name": "Bench-top hemolysis validation across 5 operating points",
      "description": "Modified index of haemolysis (MIH) measured in a recirculating loop at Q = 3, 4, 5 L/min and N = 2000, 2500 rpm. RH values ranged 0.82–0.97 across all conditions, meeting the primary RH < 1.0 criterion. Normalised RMS error between CFD-predicted and measured MIH was 8.3%."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-gci",
      "type": "ValidationResult",
