  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, which is acceptable at MRL 2 per ASME V&V 40-2018 Table 1. CFD model demonstrates adequate fidelity for identifying worst-case hemolysis operating conditions. RH values of 0.82–0.97 across all five operating points satisfy the primary acceptance criterion (RH < 1.0). The credibility assessment supports use of the CFD model to inform tolerance decisions for the Class II CPB device.",
