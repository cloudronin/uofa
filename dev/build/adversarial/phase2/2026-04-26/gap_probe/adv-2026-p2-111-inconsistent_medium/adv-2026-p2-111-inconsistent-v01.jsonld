      "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-upper-bound",
      "type": "Requirement",
      "name": "Hemolysis Relative Index Upper-Bound Criterion",
      "specification": "The CFD-predicted relative hemolysis index (RH) for the subject device shall be strictly less than 1.0 when compared against the predicate device under all five evaluated flow-speed operating conditions. An RH value of 1.0 or greater constitutes a failure of the acceptance criterion and shall preclude regulatory submission of the model-based evidence.",
      "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-cfd-credibility"
    },
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-equivalence-floor",
      "type": "Requirement",
      "name": "Hemolysis Relative Index Equivalence Floor Criterion",
      "specification": "To demonstrate that the CFD model captures physiologically meaningful hemolysis differences, the relative hemolysis index (RH) shall be no less than 1.0 for at least one of the five evaluated flow-speed operating conditions. An RH value below 1.0 across all operating points indicates insufficient model sensitivity to hemolytic loading and shall preclude regulatory submission of the model-based evidence.",
      "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-cfd-credibility"
    }
  ],
  "hasValidationResult": [
    {
