      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented regression test suite.",
      "rationale": "ANSYS Fluent 2023 R1 used under ISO 9001-certified QMS. Solver regression suite covers 47 canonical flow cases. Version control maintained via Git with signed release tags. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one canonical rotating-machinery benchmark.",
      "rationale": "Solver verified against Taylor-Couette flow and rotating disk benchmark from FDA CFD Round Robin. Order-of-accuracy confirmed at 1.97 for velocity, consistent with second-order discretization scheme."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI for primary hemolysis QoI must be below 5% on the production mesh.",
      "rationale": "Three-level GCI study yielded 3.1% discretization error on the 9.7 M cell medium mesh selected for production runs. Richardson extrapolation applied; asymptotic range confirmed. Criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within 5% for flow rate and rotational speed.",
      "rationale": "Coriolis flow meter (±0.3% accuracy) and optical tachometer (±1 RPM) used to set and verify boundary conditions. Agreement within 2.1% for all five operating points. All test hardware was in nominal mechanical condition; no fault states were introduced or monitored during the validation campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted NIH must agree with measured NIH within 15% across all validation operating points.",
      "rationale": "NIH comparison across five operating points shows mean absolute error of 9.3% with no systematic bias. Worst-case single-point deviation is 13.8% at the highest flow-speed combination. Criterion satisfied. Comparisons made exclusively on nominal hardware; pump mechanical state was not varied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (RH relative hemolysis index) must be directly traceable to clinical hemolysis risk metric.",
      "rationale": "RH index is derived from the normalized index of hemolysis (NIH) per ASTM F1841 and is the accepted regulatory metric for CPB hemolysis comparison against predicate devices. QoI relevance is well-established in FDA guidance. The QoI definition assumes a mechanically intact pump; no adjustment is made for fault-induced flow disturbances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the COU operating envelope (flow rates 2–5 L/min, speeds 1500–3000 RPM).",
      "rationale": "Validation experiments span the full COU operating envelope across 5 flow-speed combinations. Blood analog fluid properties match clinical hematocrit range 35–45%. Validation activities confirm model fidelity under nominal pump operation across the intended envelope. Extended in vivo duty-cycle effects on hardware state are not represented in the validation activities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to be demonstrated with residuals below 1e-5 for all transport equations.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum; hemolysis scalar residual below 1e-7. Mass imbalance across rotor-stator interface below 0.01%. Convergence criterion satisfied for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst prior to production runs.",
      "rationale": "Independent senior CFD analyst reviewed mesh topology, boundary condition assignments, turbulence model selection (SST k-omega), and hemolysis power-law constants prior to production runs. Two discrepancies identified and corrected during review. No further use errors detected."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence closure and hemolysis constitutive model must be justified against published literature for rotating blood-contacting devices.",
      "rationale": "SST k-omega turbulence closure selected based on published sensitivity studies for centrifugal blood pump flows (Hariharan et al., 2011; Malinauskas et al., 2017). Power-law hemolysis model (Giersiepen constants) is the FDA-accepted formulation for this device class. Model form assumes continuous nominal impeller rotation; no degraded-mode flow topology is represented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Geometric and fluid property inputs must be traceable to measured pump dimensions and blood analog characterization data.",
      "rationale": "Pump geometry digitized from CMM measurements of production-representative hardware (nominal dimensional tolerances). Blood analog viscosity and density characterized at 37°C per ASTM F1841. Inlet velocity profiles derived from Coriolis meter readings. All inputs reflect nominal hardware geometry; no degraded-geometry variants (e.g., worn impeller clearance) are included in the input space."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent blood analog batches must be used across the validation hemolysis experiments.",
      "rationale": "Four independent bovine blood batches (hematocrit 38–42%) used across the five operating point experiments, with batch assignment randomized. Inter-batch NIH variability within 6.2%, consistent with published reference ranges. All samples tested on pump assemblies confirmed to be in nominal mechanical condition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must match experimental conditions within stated measurement uncertainties.",
      "rationale": "Direct parameter mapping confirmed between simulation boundary conditions and experimental measurements for flow rate (±0.3%), rotational speed (±0.05%), fluid temperature (±0.5°C), and hematocrit (±1%). Equivalency established for all five validation operating points under nominal hardware conditions. No equivalency assessment was performed for degraded hardware states."
    }
