  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cva-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed per MRL 2 scoping rules. The CFD model demonstrates adequate fidelity for predicting hemolysis across the intended operating envelope under nominal conditions. Validation experiments confirm RH < 1 across all five flow-speed combinations. The single seal clearance spot-check experiment provides limited coverage of one hardware tolerance exceedance and supports the nominal-state conclusions. The assessment team notes that the COU involves extended in vivo duty cycles during which pump hardware is subject to bearing wear, seal degradation, and motor driver fluctuations; however, these physical fault modes do not affect the credibility determination at MRL 2 given the available experimental evidence and the medium model influence designation. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
