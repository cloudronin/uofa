      "type": "ValidationResult",
      "name": "PIV velocity field comparison — nominal pump, 2.5 L/min, 2000 RPM",
      "description": "Particle image velocimetry measurements acquired on a factory-new FDA generic centrifugal blood pump at 2.5 L/min and 2000 RPM. CFD predictions of mean velocity magnitude agree within 8% across the impeller sweep plane. Pump assembly confirmed to be mechanically nominal prior to and after test run; no bearing wear or seal degradation detected.",
      "metric": "Mean velocity magnitude error",
      "metricValue": 0.078,
      "metricUnit": "dimensionless fractional error",
      "passed": true
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-hemolysis-nominal",
      "type": "ValidationResult",
      "name": "Hemolysis index bench validation — nominal pump, 5 operating points",
      "description": "In-vitro hemolysis index measured across 5 flow-speed combinations (2–5 L/min; 1500–3000 RPM) using fresh bovine blood in a factory-calibrated pump loop. The normalized index of hemolysis (NIH) was computed and compared against CFD-predicted power-law hemolysis accumulation. All five operating points yielded RH < 1 relative to predicate. Hardware was inspected before and after each run and confirmed to be in nominal mechanical condition with no actuator wear or electrical anomalies.",
      "metric": "Relative hemolysis index RH",
      "metricValue": 0.84,
      "metricUnit": "dimensionless",
      "passed": true
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-grid-sensitivity",
      "type": "ValidationResult",
      "name": "Grid sensitivity study — hemolysis QoI convergence",
      "description": "Three mesh refinement levels (4.2 M, 9.7 M, 18.1 M hexahedral cells) applied to the impeller domain. GCI-based discretization error for the hemolysis scalar field estimated at 3.1% on the medium mesh. All simulations performed under nominal boundary conditions derived from the calibrated test rig.",
      "metric": "Grid Convergence Index (GCI)",
      "metricValue": 0.031,
      "metricUnit": "dimensionless",
      "passed": true
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-04-seal-leakage-spot",
      "type": "ValidationResult",
      "name": "Seal leakage spot check — single nominal assembly",
      "description": "One targeted experiment examined the effect of a controlled 0.05 mm radial seal clearance increase on outlet pressure drop, representing a minor manufacturing tolerance exceedance. Pressure drop deviation was 1.4%, deemed negligible. This test was conducted on an otherwise nominal pump and was not extended to bearing-wear or motor-driver fault states. No further fault modes were explored.",
      "metric": "Outlet pressure drop deviation",
      "metricValue": 0.014,
      "metricUnit": "dimensionless fractional deviation",
      "passed": true
    }
