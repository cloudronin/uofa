    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench test conditions (fluid temperature, hematocrit, inlet pressure) must be documented and matched to CFD boundary conditions within stated tolerances.",
      "rationale": "Bovine blood at 37 °C ± 0.5 °C, hematocrit 33 ± 2%, inlet pressure 10 ± 0.5 mmHg. All five validation runs conducted on new pump assemblies under nominal electrical supply (120 V ± 1%). Physical fault conditions such as bearing wear or voltage sag were not introduced into the bench protocol; test conditions reflect nominal hardware throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted RH must agree with bench-measured RH within 15% across all validated operating points.",
      "rationale": "Maximum RH discrepancy across four nominal operating points is 9.1%. Single partial-occlusion point shows 12% discrepancy. All within 15% acceptance band. Agreement assessed only on nominal or near-nominal hardware; no fault-state outputs compared."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (relative hemolysis index, shear stress distribution) must map directly to the regulatory acceptance criterion and clinical risk metric.",
      "rationale": "RH index directly used in 510(k) substantial equivalence argument. Shear stress field used to identify high-hemolysis zones. Both QoIs are standard in FDA guidance for blood-contacting devices. QoIs defined for nominal pump performance; fault-induced shifts in shear stress distribution (e.g., from bearing eccentricity) are not captured."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the intended operating envelope (flow 3–5 L/min, speed 2000–2400 RPM) and use a representative pump geometry.",
      "rationale": "Three of five intended flow-speed combinations validated on bench. Pump geometry matches COU device within dimensional tolerance. Validation activities cover the nominal operating envelope but do not address the in vivo fault conditions (bearing wear, motor-drive transients) described in the COU, as bench protocol used exclusively new hardware under stable electrical supply."
    },
    {
