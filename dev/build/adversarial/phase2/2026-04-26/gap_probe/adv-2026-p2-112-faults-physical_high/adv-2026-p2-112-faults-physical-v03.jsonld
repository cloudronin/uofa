  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements. The CFD model predicts hemolysis index within 15% of bench measurements across the validated operating envelope. The single partial-occlusion validation run demonstrates model sensitivity to inlet geometry perturbation. The assessment team concludes that the model provides sufficient credibility to support the 510(k) hemolysis equivalence argument for the CPB device under nominal operating conditions.",
