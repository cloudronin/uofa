  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation for MRL 2. Six factors are not assessed, consistent with MRL 2 scope. The relative hemolysis index predictions agree with in vitro measurements within 5% across all five operating points. The assessment team concludes that the CFD model provides sufficient credibility for the regulatory submission decision. Note: all validation experiments and model runs were conducted under nominal hardware conditions. The clinical deployment context involves prolonged in vivo operation where bearing wear, seal degradation, and electrical transients are recognised hazards; these fault modes were not exercised in the validation campaign and are not represented in the model. This gap was noted but judged acceptable given the MRL 2 scope and the availability of post-market surveillance data for the predicate device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
