  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cva-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2. The CFD model demonstrates adequate predictive capability for pump-induced hemolysis across the five nominal operating points, with RH < 1 at all points and NIH prediction error within the 15% acceptance criterion. The limited seal-eccentricity sensitivity run provides supplementary confidence. The assessment team notes that the COU description references prolonged in vivo surgical deployment and documented post-market field events involving bearing wear and motor electrical faults; however, these physical fault modes are considered outside the MRL 2 assessment scope and are not represented in the validation campaign or the computational model. The decision to accept is conditioned on the nominal-hardware operating assumption.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
