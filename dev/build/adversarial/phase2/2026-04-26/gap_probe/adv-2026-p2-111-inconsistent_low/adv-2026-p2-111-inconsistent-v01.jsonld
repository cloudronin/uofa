  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": [
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-primary",
      "type": "Requirement",
      "name": "RH acceptance threshold — primary",
      "specification": "The relative hemolysis index (RH) computed by the CFD model shall be strictly less than 1.0 for all five evaluated flow-speed operating points. Any operating point yielding RH >= 1.0 constitutes a model prediction failure and the device configuration must be rejected. This threshold is binding for all comparative assessments against the predicate device."
    },
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-secondary",
      "type": "Requirement",
      "name": "RH acceptance threshold — secondary operational margin",
      "specification": "To account for inter-laboratory variability in hemolysis measurement and CFD solver uncertainty, the relative hemolysis index (RH) shall be considered acceptable provided RH does not exceed 1.15 at any evaluated operating point. Operating points with RH in the range [1.0, 1.15] are explicitly permitted and shall not trigger device rejection, provided the mean RH across all five operating points remains below 1.0."
    }
  ],
