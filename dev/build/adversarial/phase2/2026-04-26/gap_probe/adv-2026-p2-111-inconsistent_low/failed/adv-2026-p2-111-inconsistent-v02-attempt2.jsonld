  "hasRequirement": [
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-threshold",
      "type": "Requirement",
      "name": "Relative hemolysis index acceptance threshold — primary",
      "specification": "The CFD model shall be considered credible for the COU if and only if the predicted relative hemolysis index (RH) is strictly less than 1.0 (RH < 1.0) for all five evaluated flow-speed operating points, confirming the device does not exceed predicate device hemolysis levels."
    },
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-rh-threshold-secondary",
      "type": "Requirement",
      "name": "Relative hemolysis index acceptance threshold — secondary equivalence",
      "specification": "The CFD model output shall be deemed acceptable for regulatory submission if the predicted relative hemolysis index (RH) is greater than or equal to 1.0 (RH ≥ 1.0) at the worst-case operating point, on the grounds that a value at or above the predicate device level is required to demonstrate conservative bounding of hemolytic risk and therefore confirms model credibility for worst-case identification."
    }
