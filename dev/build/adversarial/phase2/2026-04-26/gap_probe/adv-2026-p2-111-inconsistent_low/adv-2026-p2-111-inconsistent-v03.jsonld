  "hasRequirement": [
    {
      "id": "https://uofa.net/synth/req/cou1-rh-threshold-primary",
      "type": "Requirement",
      "name": "Primary RH acceptance threshold — CFD hemolysis prediction",
      "specification": "The computational model shall be considered acceptable for regulatory submission if and only if the predicted relative hemolysis index (RH) is strictly less than 1.0 across all five evaluated flow-speed operating points. An RH value of exactly 1.0 or any value exceeding 1.0 constitutes a model failure and the submission shall be rejected. This threshold applies without exception to all Class II CPB devices assessed at MRL 2.",
      "rationale": "Derived from FDA guidance on hemolysis benchmarking; RH < 1.0 ensures the investigational device does not exceed predicate hemolysis performance."
    },
    {
      "id": "https://uofa.net/synth/req/cou1-rh-threshold-secondary",
      "type": "Requirement",
      "name": "Secondary RH acceptance threshold — worst-case operating envelope",
      "specification": "For worst-case operating condition identification purposes, the CFD model output shall be deemed compliant provided the relative hemolysis index (RH) does not exceed 1.0 at the nominal design point. RH values up to and including 1.0 are explicitly permitted and shall not trigger rejection; only RH values strictly greater than 1.0 constitute non-compliance. This criterion supersedes any stricter threshold when the model is used solely for sensitivity analysis of component dimensional tolerances.",
      "rationale": "Sensitivity analysis use-case requires a relaxed boundary condition to allow exploration of the design space near the predicate performance boundary without prematurely disqualifying near-threshold configurations."
    }
  ],
