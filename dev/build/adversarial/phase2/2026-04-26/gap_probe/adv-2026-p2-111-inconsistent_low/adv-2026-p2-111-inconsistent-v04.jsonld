  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 was used under a validated SQA plan including version-controlled solver builds, automated regression tests for rotating-zone flows, and documented deviation logs. All SQA checks passed at Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation via analytical benchmark solutions for rotating-frame Navier-Stokes equations.",
      "rationale": "Code verification performed against Taylor-Couette analytical solution and lid-driven cavity benchmarks. Observed order of convergence matched theoretical second-order accuracy within 5 % tolerance across all test cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for shear-stress-derived hemolysis index must be less than 5 % at the nominal mesh resolution.",
      "rationale": "Three-level mesh refinement study performed (2.1 M, 5.8 M, 14.2 M cells). GCI for the hemolysis index at the nominal 5.8 M mesh was 3.2 %, satisfying the < 5 % criterion. Richardson extrapolation confirmed asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match simulated operating points within ±5 % for flow rate and ±3 % for rotational speed.",
      "rationale": "FDA pump bench test data from Morrison et al. (2022) was used. Flow rate agreement was within ±2.8 % and rotational speed within ±1.5 % across all five operating points. Temperature and fluid viscosity were matched to within measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±20 % across all five operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values compared against experimental measurements showed maximum deviation of 14.7 % and mean deviation of 8.3 %. All five operating points satisfied the ±20 % acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index RH) must be directly linked to the clinical endpoint and derivable from CFD shear stress fields via a validated power-law hemolysis model.",
      "rationale": "RH is computed from volume-integrated shear stress exposure using the Giersiepen-Wurzinger power-law model, which is the FDA-recognized approach for comparative hemolysis assessment. Direct linkage to clinical plasma-free hemoglobin levels is established in the referenced literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analog fluid as the COU device, operating within the COU flow-speed envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry using a glycerol-water blood analog (viscosity 3.5 mPa·s) at all five COU operating points. Geometric fidelity was confirmed via CMM measurements to within 50 µm. The validation domain is judged sufficient for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to at least 1e-5 for all transport equations; not formally assessed at MRL 2.",
      "rationale": "At Model Risk Level 2, formal numerical solver error assessment beyond basic convergence monitoring is not required. Residuals were monitored and dropped below 1e-5 for all simulations, providing adequate confidence without formal assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use-error analysis not required at MRL 2 for Class II device with medium model influence.",
      "rationale": "MRL 2 does not mandate a formal use-error assessment. Simulation setup was reviewed by a second qualified engineer and checklist-based QA was applied to boundary condition inputs, which is sufficient at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification not required at MRL 2; qualitative justification of turbulence model selection is sufficient.",
      "rationale": "The SST k-ω turbulence model was selected based on published benchmark performance for confined rotating flows. Formal model-form uncertainty quantification is not required at MRL 2 and was not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input uncertainty propagation not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Boundary conditions (inlet flow rate, rotational speed, fluid properties) were set to nominal values from device specifications and validated measurement data. Formal uncertainty propagation is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2.",
      "rationale": "Validation experiments used a single representative pump unit. Sample-to-sample variability characterization is not required at MRL 2 for this comparative hemolysis assessment."
    },
