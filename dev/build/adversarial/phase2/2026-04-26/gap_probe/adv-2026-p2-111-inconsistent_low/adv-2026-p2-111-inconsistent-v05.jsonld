    {
      "id": "https://uofa.net/synth/req/hem-01-strict-less-than",
      "type": "Requirement",
      "name": "REQ-HEM-01: Strict hemolysis index upper bound",
      "description": "The computational model shall be considered credible for the CPB COU only if the predicted relative hemolysis index (RH) is strictly less than 1.0 for all five evaluated flow-speed combinations. A result of RH = 1.0 is explicitly non-conforming and shall constitute a failure of the acceptance criterion. No tolerance band around the predicate device equivalence point is permitted.",
      "acceptanceCriterion": "RH < 1.0 (strict inequality; RH = 1.0 is forbidden)"
    },
    {
      "id": "https://uofa.net/synth/req/hem-02-equivalence-band",
      "type": "Requirement",
      "name": "REQ-HEM-02: Hemolysis index equivalence acceptance band",
      "description": "The computational model shall be considered credible for the CPB COU if the predicted relative hemolysis index (RH) falls within the predicate-equivalence acceptance band defined as 1.0 ≤ RH ≤ 1.05 OR RH < 1.0. Results at RH = 1.0 are explicitly permitted and represent successful demonstration of non-inferiority relative to the predicate device. This band accommodates measurement uncertainty in the reference experimental dataset.",
      "acceptanceCriterion": "RH ≤ 1.05; results at RH = 1.0 are conforming"
    }
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
