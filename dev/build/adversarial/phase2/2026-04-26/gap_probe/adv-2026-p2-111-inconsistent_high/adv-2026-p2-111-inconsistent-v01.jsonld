  "name": "Morrison COU1 — CPB hemolysis credibility assessment (adversarial: inconsistent requirements)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). This package contains a subtle requirements inconsistency: the two requirements bound to the primary hemolysis acceptance claim specify contradictory thresholds for the relative hemolysis index — one mandates RH < 1.0 as the pass criterion while the other mandates RH ≤ 1.0 only when evaluated at the 95th-percentile operating point, which at the COU's nominal 5 L/min / 3500 RPM condition yields RH = 1.003, simultaneously satisfying the second requirement and violating the first.",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-req-bundle-001",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-001",
  "bindsModel": "https://uofa.net/synth/model/fda-gcbp-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-gcbp-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/fda-gcbp-cfd-mesh-convergence-dataset",
    "https://uofa.net/synth/data/fda-gcbp-operating-point-sweep-5x5"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": [
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-req-strict-001",
      "type": "Requirement",
      "name": "Strict RH upper-bound requirement",
      "specification": "The CFD model shall be considered acceptable for regulatory submission only if the predicted relative hemolysis index (RH) is strictly less than 1.0 (RH < 1.0) at every evaluated operating point across the full five-flow-five-speed test matrix. No operating point may yield RH ≥ 1.0 under any mesh resolution or turbulence model variant examined.",
      "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-001"
    },
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-req-percentile-001",
      "type": "Requirement",
      "name": "95th-percentile RH tolerance requirement",
      "specification": "The CFD model shall be considered acceptable for regulatory submission if the predicted relative hemolysis index (RH) does not exceed 1.0 (RH ≤ 1.0) when evaluated at the 95th-percentile worst-case operating point as identified by the sensitivity sweep. Minor exceedances below RH = 1.01 at the nominal design point (5 L/min, 3500 RPM) are permissible provided the 95th-percentile condition satisfies RH ≤ 1.0, reflecting measurement uncertainty in the predicate device reference value.",
      "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case-001"
    }
  ],
