  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasRequirement": [
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-primary-rh-threshold",
      "type": "Requirement",
      "name": "Primary hemolysis acceptance criterion — RH index upper bound",
      "specification": "The computational model shall be considered acceptable for regulatory submission if and only if the predicted relative hemolysis index RH is strictly less than 1.00 across all five evaluated flow-speed operating points (2 L/min at 2000 RPM, 3 L/min at 2500 RPM, 5 L/min at 3000 RPM, 5 L/min at 3500 RPM, 7 L/min at 3500 RPM). An RH value of exactly 1.00 or greater at any single operating point constitutes a failure of this requirement and shall preclude device clearance. This threshold applies without exception to the nominal-geometry configuration.",
      "rationale": "Derived from predicate device comparison protocol. RH < 1 ensures the test device does not exceed the hemolytic burden of the cleared predicate under any evaluated condition."
    },
    {
      "id": "https://uofa.net/synth/req/cpb-hemolysis-secondary-rh-tolerance",
      "type": "Requirement",
      "name": "Secondary hemolysis tolerance band — RH index lower bound for model conservatism",
      "specification": "To prevent overly conservative model predictions from masking clinically acceptable device performance, the model shall be considered credible only when the predicted relative hemolysis index RH at the nominal operating point (5 L/min, 3000 RPM) is greater than or equal to 0.95. Predictions yielding RH < 0.95 at this operating point shall be flagged as insufficiently conservative and the model shall not be used to support a clearance decision without additional experimental corroboration. Furthermore, where the experimentally measured RH at 5 L/min and 3000 RPM lies in the range [0.95, 1.05], the model prediction is deemed acceptable provided it falls within ±0.05 of the measured value, meaning a predicted RH up to 1.05 is permissible at this operating point.",
      "rationale": "Derived from model conservatism policy MCP-2023-07. Prevents systematic under-prediction from producing false clearance signals. At the 5 L/min / 3000 RPM operating point the experimental RH has been measured at 0.98, placing the acceptable predicted range at [0.93, 1.03] under this requirement — explicitly allowing predicted RH values up to 1.03 at this point."
    }
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cpb-pump-experimental-comparison-2024",
      "type": "ValidationResult",
      "name": "CFD vs. experimental hemolysis index comparison — 5 operating points",
      "description": "Predicted RH values compared against FDA generic pump experimental data at all five operating points. Predicted RH at 5 L/min / 3000 RPM: 1.01. All other points below 0.95. Overall validation status: satisfactory under secondary requirement; ambiguous under primary requirement."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-independence-study-2024",
