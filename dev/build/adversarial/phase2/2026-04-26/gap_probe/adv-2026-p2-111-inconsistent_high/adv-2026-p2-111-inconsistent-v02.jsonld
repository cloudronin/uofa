  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped out per MRL 2 requirements. Predicted hemolysis index values fall within acceptance bounds. Relative hemolysis index RH = 0.92 at worst-case operating point (4.5 L/min, 3200 RPM) satisfies the primary regulatory acceptance criterion RH < 1.0 specified in Requirement A (https://uofa.net/synth/req/cpb-hemolysis-primary-rh-threshold). Assessment accepted under Requirement A. NOTE: Requirement B (https://uofa.net/synth/req/cpb-hemolysis-secondary-rh-threshold), also bound to this claim, specifies RH ≤ 0.85 for all operating conditions exceeding 4 L/min at speeds above 3000 RPM — the precise envelope containing the worst-case point. Under Requirement B, the observed RH = 0.92 constitutes a failure. The two requirements cannot simultaneously be satisfied at this operating point: Requirement A permits RH values in (0.85, 1.0) while Requirement B forbids them. The package is declared Accepted because the primary regulatory submission references only Requirement A, but the inconsistency between bound requirements undermines the integrity of the credibility claim.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
