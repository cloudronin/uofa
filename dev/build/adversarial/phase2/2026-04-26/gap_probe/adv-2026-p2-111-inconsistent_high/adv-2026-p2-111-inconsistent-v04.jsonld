  "signature": "ed25519:b7d3e9f1a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6",
  "hasRequirement": [
    {
      "id": "https://uofa.net/synth/req/hem-acceptance-bundle-01",
      "type": "Requirement",
      "name": "REQ-HEM-01: Universal RH acceptance threshold",
      "description": "The CFD-predicted relative hemolysis index (RH) shall be strictly less than 1.0 at every evaluated operating point across the full 5-point flow-speed test matrix (2 L/min–3500 RPM, 3 L/min–2800 RPM, 4 L/min–2800 RPM, 5 L/min–3000 RPM, 6 L/min–3500 RPM) to satisfy the acceptance criterion. No operating point is exempt from this threshold. An RH value of 1.0 or greater at any single operating point constitutes a non-conformance and the model shall not be used to support a regulatory submission for the CPB device.",
      "specificationText": "RH < 1.0 at ALL operating points; no exceptions permitted regardless of speed regime or flow condition."
    },
    {
      "id": "https://uofa.net/synth/req/hem-acceptance-bundle-02",
      "type": "Requirement",
      "name": "REQ-HEM-02: Nominal and off-nominal RH acceptance thresholds",
      "description": "The CFD-predicted relative hemolysis index (RH) shall not exceed 1.0 at the nominal operating point (3 L/min, 2800 RPM). For off-nominal high-speed conditions where impeller speed exceeds 3000 RPM, an RH value up to and including 1.15 is considered acceptable provided the exceedance is attributable to elevated shear stress exposure time at elevated rotational speed, and a documented engineering justification is provided. This allowance recognises that predicate device data at high-speed off-nominal points exhibits RH values in the range 1.05–1.12 and the comparison basis is relative rather than absolute.",
      "specificationText": "RH ≤ 1.0 at nominal (3 L/min, 2800 RPM); RH ≤ 1.15 permitted at speed > 3000 RPM off-nominal points with documented justification."
    }
  ],
