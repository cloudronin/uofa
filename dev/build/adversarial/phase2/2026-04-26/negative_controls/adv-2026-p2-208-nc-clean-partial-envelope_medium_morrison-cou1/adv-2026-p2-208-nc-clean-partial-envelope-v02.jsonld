  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted for the declared COU at MRL 2. Seven credibility factors were formally assessed; all achieved levels meet or exceed required levels. Six factors were appropriately scoped out under MRL 2 provisions with documented rationale. The operating envelope is explicitly bounded (flow 2–6 L/min, speed 2000–4000 RPM, hematocrit 30–45%) and all five COU operating points fall within this envelope. Validation activities included boundary-point experiments confirming model accuracy at the extremes of the operating envelope (MARE 8.3%, maximum 13.1%, all within 15% acceptance band). The relative hemolysis index RH < 1.0 at all operating points (worst-case RH = 0.87) satisfies the regulatory acceptance criterion. Applicability is explicitly constrained to adult non-pulsatile CPB; use outside these constraints requires separate assessment. Discretization error (GCI 3.1%) and combined uncertainty (95% prediction intervals) are quantified and acceptable. The provenance chain from foundational bench data through validation results to the credibility assessment is complete and traceable. The model is fit for the intended purpose of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
