  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at MRL 5 with achieved levels meeting or exceeding required levels. The evidence chain is complete and traceable: (1) Code verification via MMS confirms 2nd-order accuracy; (2) Three-level GCI study establishes discretization error < 1.8% NIH; (3) Solver convergence and round-off budgets are quantified and negligible; (4) SQA under ISO 9001 with independent audit; (5) Validation against bench hemolysis data yields AVM = 0.87, exceeding the MRL-5 threshold of 0.75, with all predictions within 15% of measurements; (6) PIV velocity validation confirms flow-field fidelity; (7) Monte Carlo UQ (n = 10 000) demonstrates that the 95th-percentile NIH prediction remains below the clinical threshold of 0.01 mg/dL; (8) Sobol sensitivity analysis identifies the hemolysis model exponent as the dominant uncertainty driver (S_T = 0.61), and a targeted experimental campaign is planned to reduce this by 40% in the next cycle; (9) Validation activities are directly relevant to the COU — identical geometry, matching operating envelope, and physiologically representative fluid; (10) QoI (NIH) is the direct clinical safety metric per ASTM F1841; (11) Input equivalency confirmed across all 13 parameters; (12) Test samples from 8 independent donors with documented inter-donor variability; (13) Use error controlled via SOP with independent reproduction confirming < 0.3% NIH variation. The totality of evidence supports acceptance of the CFD model for predicting absolute hemolysis levels in the Class III VAD COU at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
