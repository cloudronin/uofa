  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been fully assessed at MRL 5. For each factor, the achieved credibility level meets or exceeds the required level: Software quality assurance (5 ≥ 4), Numerical code verification (5 ≥ 4), Discretization error (5 ≥ 4), Test conditions (4 ≥ 4), Output comparison (5 ≥ 4), Relevance of QoI (4 ≥ 4), Relevance of validation activities (4 ≥ 4), Numerical solver error (4 ≥ 4), Use error (4 ≥ 4), Model form (4 ≥ 4), Model inputs (5 ≥ 4), Test samples (4 ≥ 4), and Equivalency of input parameters (4 ≥ 4). Monte Carlo uncertainty quantification (10 000-sample ensemble) and global Sobol sensitivity analysis provide a complete probabilistic characterisation of prediction uncertainty. The 95% prediction interval on NIH encloses all experimental validation data across all 5 operating conditions. Quantitative output comparison metrics (NRMSE < 4%, E_rel < 5%, Theil U < 0.08) confirm acceptable model accuracy for absolute hemolysis prediction. The validation activities are directly relevant to the COU geometry, operating envelope, and fluid properties, with no significant extrapolation required. Independent reproduction of the simulation and independent statistical review of comparison metrics confirm the robustness of the evidence base. The credibility evidence is sufficient to support regulatory acceptance of CFD-predicted absolute hemolysis levels for this Class III VAD device at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
