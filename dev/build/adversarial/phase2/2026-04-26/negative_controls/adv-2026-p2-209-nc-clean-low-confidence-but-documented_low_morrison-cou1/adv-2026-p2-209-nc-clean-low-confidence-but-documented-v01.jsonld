  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/vv-lead-engineer",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis prediction, MRL 2) is accepted with explicitly documented residual uncertainty. All 7 assessed CredibilityFactors meet or exceed their required levels. Six factors are appropriately scoped out at MRL 2 per ASME V&V 40 Table 3. Evidence confidence for the primary hemolysis validation activity (vr-hemolysis-bench-2024) is honestly assessed at approximately 50%, with a 95% bootstrap prediction interval of ±34% NIH. This wide interval reflects limited experimental replicates (n=3) and inter-laboratory variability in hemolysis measurement, both of which are transparently documented in the uncertainty quantification record. Despite the low confidence, the area validation metric (AVM = 0.62) exceeds the MRL 2 threshold of 0.50, and the secondary pressure-head validation (AVM confidence ~75%) supports flow-field fidelity. The decision to accept is grounded in: (1) the MRL 2 threshold being met on the primary QOI metric; (2) the RH acceptance criterion (RH < 1) being satisfied at all 5 operating points with margin exceeding the ±34% uncertainty band; (3) the low-confidence evidence being supplemented by bench confirmation testing that independently bounds worst-case hemolysis; and (4) the conservative nature of the relative hemolysis index comparison against the predicate device. Residual uncertainty is acknowledged as a known limitation of the current evidence base and is recorded as a trigger for MRL 3 escalation should device geometry change exceed the validated envelope. No weakeners are present in this package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
