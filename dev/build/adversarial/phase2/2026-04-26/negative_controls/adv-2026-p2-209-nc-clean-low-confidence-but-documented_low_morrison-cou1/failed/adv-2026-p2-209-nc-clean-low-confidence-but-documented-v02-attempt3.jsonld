  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepts the CFD hemolysis model for the CPB COU at MRL 2 despite explicitly documented low confidence (~50% coverage probability) in the validation predictions. The acceptance is grounded in the following structured evidence: (1) Code verification (vr-code-verification-01) confirms correct solver implementation with high confidence (p=1.93, L2 error 3.2×10⁻⁴ m/s). (2) Discretization uncertainty is quantified at 7% GCI and is acceptable for sensitivity-ranking purposes. (3) The dominant uncertainty source — RBC damage model coefficients — produces a ±42% NIH prediction band, which is honestly documented in the Monte Carlo UQ analysis (uq/hemolysis-benchmark-uq-01). (4) The model is used for relative sensitivity analysis (worst-case operating point identification and RH < 1 comparison against predicate device), not for absolute hemolysis prediction; the relative ranking of operating points is robust to the absolute uncertainty. (5) Model influence is Medium: physical confirmatory testing of the final design is required and will be performed prior to 510(k) submission, providing an independent check on model conclusions. (6) All 7 assessed credibility factors meet their required Gradation 2 levels; 6 factors are scoped out with documented rationale appropriate to MRL 2. The low confidence is accepted as residual uncertainty consistent with MRL 2 requirements, with the explicit condition that confirmatory bench testing be completed and that any operating point identified as worst-case by CFD be validated experimentally before regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
