  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis worst-case identification, MRL 2) is accepted with documented residual uncertainty. All 7 assessed credibility factors meet or exceed their required gradation levels for MRL 2. Six factors are appropriately scoped out or designated not-applicable consistent with ASME V&V 40 Table 3 guidance for MRL 2. Key finding: validation evidence carries approximately 50% confidence in NIH prediction, driven primarily by turbulence model form uncertainty (SST vs. RSM, 22% NIH difference) and blood analogue rheology variability. These limitations are explicitly documented in the uncertainty quantification records (vr-hemolysis-bench-01-uq, vr-pressure-head-02-uq) and are not concealed. The decision to accept is grounded in three findings: (1) the COU objective is relative worst-case ranking, not absolute NIH prediction — Spearman rank correlation of 0.94 between SST and RSM turbulence models confirms ranking robustness despite absolute prediction uncertainty; (2) model influence is Medium (bench testing confirms computational results), reducing the consequence of residual model uncertainty; and (3) the RH < 1 acceptance criterion provides a conservative safety margin relative to the predicate device. The wide NIH prediction interval (factor of 2.1) is accepted as residual risk at MRL 2 given the corroborating experimental evidence and the relative-ranking nature of the decision. This acceptance is conditional: if the device proceeds to MRL 3 evaluation or if model influence is reclassified to High, a full equivalency assessment and increased experimental replication (n ≥ 6) would be required.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
