  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The COU2 credibility assessment for CFD hemolysis prediction of the Class III VAD device at Model Risk Level 5 is NOT ACCEPTED based on the following structured evidence: (1) Of 13 credibility factors assessed, 7 were formally evaluated and all 7 achieved levels below their required levels — the largest gaps are in Discretization Error (achieved 2, required 4), Output Comparison (achieved 2, required 4), and Model Form (achieved 1, required 5). (2) Six factors were not assessed and remain at achieved level 1, representing critical epistemic gaps including model form uncertainty, use error, and input equivalency — all required at level 4 or 5 for MRL 5. (3) The primary validation metric (38% mean absolute error in hemolysis index) exceeds acceptable tolerance for absolute hemolysis prediction in a Class III device context where no predicate comparison is available. (4) Monte Carlo UQ results confirm that parametric uncertainty alone produces a 2.1x spread in the 95th-percentile hemolysis index, which is incompatible with the absolute clinical threshold demonstration required by the COU. (5) Validation domain coverage is incomplete: only 3 of 5 required operating points were validated, and the most clinically critical low-flow high-speed condition was not included. (6) The power-law hemolysis model's known extrapolation limitations at high shear rates have not been addressed through model form uncertainty analysis or alternative model benchmarking. The Not Accepted decision is fully supported by the structured factor evidence and is not a precautionary or administrative determination. Remediation would require at minimum: (a) achieving GCI < 5% through mesh refinement, (b) conducting model form uncertainty analysis with at least two alternative hemolysis models, (c) extending validation to all 5 operating points with physiological blood analog at 37°C, (d) establishing formal input equivalency documentation, and (e) completing use error qualification records.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
