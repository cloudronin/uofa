  "signature": "ed25519:b2e5a8d1c4f7a0b3e6c9f2a5d8b1e4c7f0a3d6b9e2c5f8a1d4b7e0c3f6a9d2b5",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5",
      "rationale": "At MRL 5, software quality assurance requires Gradation 4: documented configuration management, independent code review, and regression test suite covering hemolysis-relevant solver paths. The CFD solver has basic version control and a limited regression suite covering standard flow benchmarks, but no independent review of the hemolysis sub-model source code and no configuration-locked build environment. Achieved Gradation 2. Gap of 2 gradations is a primary basis for rejection."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "MRL 5 requires Gradation 4: method of manufactured solutions (MMS) applied to the coupled Navier-Stokes and hemolysis transport equations, with demonstrated formal order of accuracy. Only standard Taylor-Green vortex and lid-driven cavity benchmarks were completed; MMS was not applied to the hemolysis power-law source term. Achieved Gradation 2. The absence of hemolysis-specific code verification is a significant gap for absolute hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5",
      "rationale": "MRL 5 requires Gradation 4: Richardson extrapolation with GCI computation on three systematically refined meshes, reported per operating point, with hemolysis index as the primary QoI. A three-mesh refinement study was performed and GCI values reported for pressure rise and velocity; however, GCI for hemolysis index itself was not reported at all five operating points — only three of five. Achieved Gradation 3. Partial gap remains."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "MRL 5 requires Gradation 5: validation experiments conducted under conditions that directly match COU operating envelope (flow rate, rotational speed, fluid properties, temperature) with full traceability of test conditions to calibrated instrumentation. Available bench data were collected at three of five target operating points; fluid temperature and viscosity were not controlled to within COU tolerances at two operating points. Achieved Gradation 3. Gap of 2 gradations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "MRL 5 requires Gradation 5: quantitative comparison of predicted vs. measured hemolysis index using a validation metric that accounts for both simulation and experimental uncertainty, with statistical coverage intervals. Comparisons were performed using normalized RMS error without propagating experimental measurement uncertainty into the comparison metric. Monte Carlo UQ was applied to simulation inputs but not combined with experimental uncertainty in a formal validation metric. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "MRL 5 requires Gradation 4: the validation QoIs (hemolysis index, pressure rise, velocity field) are directly mapped to the COU decision QoIs with documented traceability. All three validation QoIs are explicitly mapped to COU requirements in the assessment plan. Hemolysis index is the primary clinical QoI and is the primary validation target. Achieved Gradation 4. This factor meets its required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "MRL 5 requires Gradation 4: validation activities conducted on a geometry and flow regime that is the same as or demonstrably equivalent to the COU device. Validation was performed on the FDA generic centrifugal pump geometry, which is the reference geometry for this COU; however, the impeller clearance gap in the test article differed from the COU specification by 15%, which is outside the accepted equivalency tolerance for hemolysis-sensitive regions. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5",
      "rationale": "MRL 5 requires Gradation 4: iterative convergence, round-off error, and time-integration error all quantified and demonstrated to be negligible relative to discretization error for hemolysis QoI. No systematic assessment of iterative convergence tightness for hemolysis index was performed; residual targets were set for momentum and continuity only. This factor was flagged as an epistemic gap at MRL 5 and is not-assessed. Gap of 3 gradations contributes to rejection."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "MRL 5 requires Gradation 4: independent review of simulation setup, boundary condition application, and post-processing scripts by a qualified reviewer not involved in the simulation. No independent review of the CFD setup or post-processing was conducted. This factor is not-assessed and represents a documented epistemic gap. Gap of 3 gradations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "MRL 5 requires Gradation 5: formal model form uncertainty quantification, including sensitivity analysis of hemolysis model selection (power-law exponent choices, turbulence model) and documented justification for model form choices relative to COU physics. No model form uncertainty analysis was performed; the Giersiepen-Wurzinger power-law model was used without comparison to alternative hemolysis models or sensitivity to exponent values. This factor is not-assessed. Gap of 4 gradations is the largest single gap and a primary basis for rejection."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "MRL 5 requires Gradation 4: all model inputs characterized with probability distributions derived from measurement data, with sensitivity analysis identifying dominant input uncertainties. Monte Carlo UQ was performed using assumed uniform distributions for blood viscosity and inlet velocity; no experimental characterization of input distributions was performed and no sensitivity ranking was reported. This factor is not-assessed. Gap of 3 gradations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5",
      "rationale": "MRL 5 requires Gradation 4: validation test samples representative of the COU patient population variability in blood properties, with sufficient replication to characterize inter-sample variability. Bench tests used a single porcine blood substitute with no replication across sample lots and no characterization of between-lot variability. This factor is not-assessed. Gap of 3 gradations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5",
      "rationale": "MRL 5 requires Gradation 4: quantitative demonstration that simulation input parameters (geometry, boundary conditions, fluid properties) match validation experiment inputs within defined tolerances, with documented traceability. Geometry was verified to match the FDA reference pump CAD file. However, inlet velocity profiles applied as boundary conditions were derived from time-averaged PIV data rather than instantaneous profiles, and no tolerance analysis was performed to bound the effect of this approximation on hemolysis prediction. Achieved Gradation 2. Gap of 2 gradations."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The Morrison COU2 VAD hemolysis credibility assessment is NOT ACCEPTED at Model Risk Level 5. Of 13 credibility factors evaluated: (1) Six factors are not-assessed (Numerical solver error, Use error, Model form, Model inputs, Test samples, Equivalency of input parameters partially), representing undocumented epistemic gaps that are impermissible at MRL 5 for a Class III device. (2) Of the seven assessed factors, only one (Relevance of the quantities of interest) meets its required gradation level. The remaining six assessed factors all have achieved levels below required levels, with gaps ranging from 1 to 2 gradations. (3) The most critical gaps are: Model form (required 5, achieved 1) — no model form uncertainty analysis was performed for the hemolysis constitutive model, which is the primary source of predictive uncertainty for absolute hemolysis index; Software quality assurance (required 4, achieved 2) — the hemolysis sub-model code has not undergone independent review; Test conditions (required 5, achieved 3) — validation data do not cover the full COU operating envelope under controlled conditions; Output comparison (required 5, achieved 3) — the validation metric does not formally combine simulation and experimental uncertainty. (4) The Monte Carlo UQ performed is based on assumed rather than experimentally characterized input distributions, limiting its credibility contribution. (5) Under ASME V&V 40, a Not accepted decision is mandatory when multiple factors fall below required levels at the highest model risk level for a Class III device. The model may not be used as the primary basis for hemolysis acceptance without remediation of all identified gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
