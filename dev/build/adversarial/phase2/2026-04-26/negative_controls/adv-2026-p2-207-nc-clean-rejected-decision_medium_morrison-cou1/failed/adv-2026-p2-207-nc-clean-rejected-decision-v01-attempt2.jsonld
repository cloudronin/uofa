  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-not-accepted-2026-04",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis worst-case identification, MRL 2) results in a Not Accepted decision based on the failure of the Discretization Error factor to meet its required Gradation 2 level. The mesh convergence study demonstrates a Grid Convergence Index of 18.4% for the primary quantity of interest (relative hemolysis index) on the finest mesh employed, exceeding the Gradation 2 threshold of ≤10% GCI. The solution has not reached the asymptotic convergence regime, as evidenced by the continued monotonic decrease in RH (0.81 → 0.74 → 0.71) across the three mesh refinement levels without plateau. This means the current finest mesh (19.2M cells) is insufficient to establish that discretization error is controlled to the level required for MRL 2 comparative hemolysis assessment. The practical consequence is that the identified worst-case operating condition and the associated RH values carry unquantified discretization-induced uncertainty that could materially affect the regulatory comparison against the predicate device (RH < 1 criterion). All 12 other assessed factors meet or exceed their required levels, and the scoped-out Test Samples factor is appropriately justified. The path to acceptance requires either: (a) further mesh refinement to achieve GCI ≤ 10% on the primary QoI, or (b) adoption of Richardson extrapolation with demonstrated asymptotic behavior and documented uncertainty bounds incorporated into the RH acceptance criterion evaluation. The assessment team recommends option (a) with a target mesh density of approximately 60–80M cells based on the observed convergence trend, followed by re-assessment of this factor.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
