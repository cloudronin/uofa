  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under CPB conditions is accepted at Medium assurance level consistent with Model Risk Level 2. All 7 assessed credibility factors meet or exceed their required gradation levels: software quality assurance (achieved 2, required 2), numerical code verification (achieved 3, required 2), discretization error (achieved 2, required 2), test conditions (achieved 2, required 2), output comparison (achieved 2, required 2), relevance of QoIs (achieved 2, required 2), relevance of validation activities (achieved 2, required 2), and equivalency of input parameters (achieved 2, required 2). Six factors (numerical solver error, use error, model form, model inputs, test samples) are appropriately scoped out at MRL 2 with documented rationale and compensating controls. Validation results demonstrate CFD predictions within 14.1% of bench measurements across all 5 operating points, with no systematic bias detected (p=0.31). The relative hemolysis index RH < 1 criterion is satisfied at all operating points, supporting the regulatory submission claim that the device does not produce worse hemolysis than the predicate device. Provenance chain is complete from raw bench measurements through validation activities to this decision record. The structured evidence base, combined with the documented uncertainty quantification and mesh convergence analysis, provides sufficient credibility to support the intended regulatory decision for this Class II device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
