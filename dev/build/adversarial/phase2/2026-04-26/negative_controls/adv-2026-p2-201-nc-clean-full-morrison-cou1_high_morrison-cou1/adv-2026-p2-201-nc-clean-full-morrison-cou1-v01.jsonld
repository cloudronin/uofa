  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-morrison-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achievedLevels meet or exceed requiredLevels for MRL 2. Verification evidence (MMS observed order 1.98, GCI_fine 1.4%) confirms numerical errors are negligible relative to model form and experimental uncertainties. Validation evidence (mean NIH error 8.3%, all 5 operating points within combined uncertainty envelope) demonstrates the CFD model adequately represents pump hemolysis behaviour across the COU operating range. Uncertainty quantification is complete: numerical (GCI), experimental (±12% NIH at 95% CI), model form (±9% NIH turbulence model spread), and input sensitivity (< 5% NIH for all inputs) contributions are individually bounded and combined in quadrature to yield total predictive uncertainty of ±15.3% NIH at 95% CI. The RH < 1 acceptance criterion is satisfied with margin for all design variants evaluated. Software quality assurance, use error controls, and test sample adequacy have all been verified. The credibility assessment supports the regulatory decision that the CFD model is fit for purpose for COU1 at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
