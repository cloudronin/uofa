  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (absolute hemolysis prediction, MRL 5) is accepted based on the following structured evidence: (1) All 13 credibility factors are assessed at Gradation 5, meeting or exceeding the required level for MRL 5. (2) The primary QoI (NIH) is validated against in-vitro measurements at all five operating points within experimental U95 uncertainty bounds; mean relative error 4.2 ± 1.8%. (3) The total combined uncertainty on NIH (root-sum-square of discretization ±0.8%, iterative ±0.05%, model form ±6.3%, input propagation ±9.1%, experimental ±3.2%) yields a 95% CI of ±11.4%, which is within the pre-specified acceptance criterion of ±15% for the regulatory comparison. (4) Global sensitivity analysis confirms that the dominant uncertainty sources (hemolysis power-law exponent and rotational speed) are well-characterised and their contributions are bounded. (5) Software quality assurance, use error controls, and test sample characterisation provide high confidence in the integrity of both the computational and experimental evidence chains. (6) Validation activities span the full COU operating envelope with no extrapolation required. The credibility evidence is sufficient to support the regulatory submission claim that the CFD model predicts absolute hemolysis levels with adequate fidelity for a Class II CPB device at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
