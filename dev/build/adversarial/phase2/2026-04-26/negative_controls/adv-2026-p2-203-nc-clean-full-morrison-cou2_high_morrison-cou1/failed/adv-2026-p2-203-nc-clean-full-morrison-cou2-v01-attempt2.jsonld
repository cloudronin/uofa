  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-mrl5-accept-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at the level required for Model Risk Level 5. Every factor achieves an observed credibility level equal to the required level (5/5), as documented in the structured factor assessments above. The evidence base is comprehensive: (1) Software quality assurance is underpinned by an ISO 9001-certified QMS and independent code audit; (2) Code verification via MMS confirms second-order accuracy; (3) GCI analysis demonstrates discretization error < 1.3% for the primary QoI; (4) Iterative and round-off solver errors are negligible and platform-independent; (5) Use error risk is mitigated by automated workflows, independent peer review, and reproducibility demonstration; (6) Model form uncertainty is quantified via Bayesian model averaging (±9% NIH) and is included in the UQ budget; (7) All 11 model inputs are characterised with traceable probability distributions; (8) Test conditions are NIST-traceably calibrated and fully documented; (9) Test samples provide biologically representative variability from 6 donors following ASTM F1841; (10) Input parameter equivalency is formally demonstrated with KS-test confirmation and bounding sensitivity analyses for identified gaps; (11) Validation QoIs are directly mapped to clinical endpoints and regulatory criteria; (12) Validation activities are scored ≥ 4/5 against all 9 COU attributes; (13) Quantitative output comparison yields CCC = 0.984 and NIH ratio within 1.15 across all operating points. The integrated UQ analysis (Monte Carlo, N=2000) confirms that the 95th-percentile predicted NIH remains below the FDA regulatory threshold of 0.01 g/100L even when model form, input, and numerical uncertainties are simultaneously propagated. Global sensitivity analysis identifies rotor speed and gap clearance as dominant variance drivers, and the validation dataset adequately spans these dimensions. No unacceptable risks, gaps, or open actions remain. The credibility assessment team unanimously recommends acceptance of this simulation model for the stated COU at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
