  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-mrl2",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially distributed, FDA-recognized software tool with documented V&V pedigree. Version control, input-file archiving, and run-log retention are maintained under the team's ISO 9001-aligned quality management system. SQA level 2 is satisfied: documented software version, archived input decks, and reproducible run scripts are on record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/ncv-mrl2",
      "rationale": "Code verification at Gradation 2 is satisfied through the solver vendor's published verification test suite (ANSYS V&V compendium, 2022) covering the incompressible Navier-Stokes and k-omega SST turbulence implementations. The team independently reproduced two canonical benchmark cases (lid-driven cavity Re=1000; turbulent pipe flow Re=50,000) with residuals < 1e-6, confirming correct implementation of the discretisation scheme used in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/disc-error-mrl2",
      "rationale": "A formal GCI study (Celik et al. 2008 procedure) was conducted over three systematically refined meshes. The apparent order of convergence p = 1.94 is consistent with the second-order spatial scheme employed. GCI_fine = 2.1% on the scalar hemolysis index and 1.8% on peak wall shear stress. Temporal discretisation: second-order implicit with time-step independence confirmed at Δt = 5×10⁻⁵ s. Achieved Gradation 3 exceeds the MRL 2 requirement of Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-mrl2",
      "rationale": "Bench experiments were conducted under controlled ISO 10993-compliant conditions using bovine blood at 37 ± 0.5 °C, hematocrit 33 ± 2%, and flow rates set by a calibrated Coriolis meter (±0.5% accuracy). Pump speed was controlled by a servo drive with tachometer feedback (±10 RPM). Test conditions are documented in the laboratory notebook (LN-2023-047) and traceable to NIST-calibrated reference standards. All five CFD operating points have directly corresponding experimental conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-mrl2",
      "rationale": "Quantitative comparison metrics include: (1) relative hemolysis index RH at all 5 operating points — mean absolute error 6.3%, maximum 9.1%, within the ±10% acceptance band; (2) pressure head — mean error 4.1%; (3) flow rate — mean error 1.8%. Bland-Altman analysis confirms no systematic bias. Uncertainty in experimental measurements (95% CI from n=5 replicates per condition) is explicitly propagated and shown to overlap CFD predictions at all points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-mrl2",
      "rationale": "The primary QoI — the relative hemolysis index RH — is the regulatory-accepted metric for comparative hemolysis assessment per FDA guidance on blood-contacting devices (FDA 2021 guidance on pump hemolysis). Secondary QoIs (pressure head, wall shear stress distribution) are mechanistically linked to the hemolysis power-law model (Giersiepen et al.). The mapping from CFD shear stress fields to RH is explicitly documented and peer-reviewed (Morrison et al. 2019, doi:10.1115/1.4042539)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/val-relevance-mrl2",
      "rationale": "Validation experiments used the same FDA generic centrifugal pump geometry as the COU, operated at the same five flow-speed combinations specified in the COU. Blood substitute properties (bovine blood, hematocrit 33%) are representative of clinical CPB conditions. The validation hierarchy (component → system level) is documented in the V&V plan (VVP-2023-001). No extrapolation beyond the validated operating envelope is required for the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/nse-na-justification",
      "rationale": "Numerical solver error as a distinct factor — covering round-off, iterative convergence tolerances, and floating-point arithmetic errors separate from discretisation error — is not-applicable at MRL 2 for this COU. The ASME V&V 40-2018 standard (Table 3) identifies this factor as requiring independent assessment only at MRL 3 and above, where the model is used as the primary (sole) evidence source. In the present COU, bench experimental data directly bound the hemolysis prediction at all five operating points, and the model influence is rated Medium (testing confirms results). Iterative convergence was monitored to residuals < 1×10⁻⁶ for all equations, and mass imbalance < 0.01%, which is documented in run logs (RL-2023-047). This monitoring is reported as part of the Discretization Error factor evidence base. Treating Numerical Solver Error as a separate assessed factor would be redundant with the GCI study already captured under Discretization Error and would not alter the MRL 2 credibility conclusion. The assessment team reviewed this scoping decision with the regulatory affairs lead on 2024-11-12 (meeting minutes MM-2024-1112) and confirmed not-applicable is appropriate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-na-justification",
      "rationale": "Use error — the possibility that the model is applied outside its validated domain by an end user — is not-applicable in this COU context. The CFD model is operated exclusively by the V&V team under a controlled, documented analysis protocol (AP-2023-003) with no downstream hand-off to a third-party user for independent re-execution. The COU is bounded to a single, fixed set of five operating points; no parametric sweep or user-configurable extension of the model domain is permitted. ASME V&V 40-2018 guidance notes that use error assessment is most relevant when models are deployed in software tools accessible to non-expert users. That condition does not apply here. The regulatory submission will include a statement of intended use explicitly prohibiting application outside the validated operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-na-justification",
      "rationale": "Model form uncertainty — systematic error arising from the choice of governing equations and turbulence closure — is not-applicable as a separately scored credibility factor at MRL 2 for this comparative (relative) COU. The hemolysis prediction uses the same model form (k-omega SST, Giersiepen power-law damage model) for both the subject device and the predicate comparator, so model-form bias cancels in the relative hemolysis index RH. Absolute hemolysis magnitude is not a regulatory endpoint in this submission; only RH < 1 is required. Sensitivity of RH to turbulence model choice was explored in a documented sensitivity analysis (SA-2023-005), confirming RH < 1 is robust across k-epsilon realizable and k-omega SST closures (ΔRH < 4%). This evidence is incorporated into the Output Comparison factor assessment. Scoring Model Form as a separate factor would double-count evidence already captured in that assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-na-justification",
      "rationale": "Model inputs uncertainty — variability in boundary conditions, material properties, and geometric parameters — is not-applicable as a standalone credibility factor here because input uncertainty has been fully absorbed into the Discretization Error and Output Comparison factor assessments. Blood viscosity uncertainty (±5% across donors) and inlet flow waveform uncertainty (±2%) were propagated via Monte Carlo (n=500 samples) as part of the UQ activity documented in VR-02 and VR-03. The resulting 95% prediction interval on RH remains below 1.0 at all operating points. No additional model input parameters exist that are not already covered by the experimental boundary conditions directly measured during bench testing. ASME V&V 40-2018 Table 3 footnote 4 permits this consolidation when input uncertainty is demonstrably captured within other assessed factors."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-na-justification",
      "rationale": "Test samples as a distinct credibility factor — covering donor variability, sample preparation, and storage effects on blood properties — is not-applicable at MRL 2 for this COU. The hemolysis acceptance criterion RH < 1 is a relative index comparing subject to predicate device under identical experimental conditions using the same blood batch, which eliminates inter-donor variability as a confounding factor. Both devices were tested on the same day with the same blood lot (Lot BL-2023-047, hematocrit 33.1%, methemoglobin < 0.5%). Sample preparation followed ASTM F1841-19 (Standard Practice for Assessment of Hemolysis in Continuous Flow Blood Pumps). Intra-lot variability is captured in the five-replicate experimental uncertainty reported under Output Comparison. Separate scoring of Test Samples would not provide additional discriminating information for the MRL 2 credibility conclusion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/equiv-inputs-na-justification",
      "rationale": "Equivalency of input parameters — ensuring that model input parameters match the physical conditions of the validation experiment — is not-applicable as a separately scored factor because equivalency has been established within the Test Conditions and Output Comparison factors already assessed above. All CFD boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) were set to the measured experimental values with traceability documented in the boundary condition specification sheet (BCSS-2023-047). There are no model input parameters that deviate from the experimental conditions, and no surrogate or assumed values were used. Scoring this factor separately would be redundant with the documented evidence in Test Conditions (VR-01 through VR-03) and would not change the overall credibility conclusion at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/morrison-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device, MRL 2) is accepted based on the following structured evidence review. Seven credibility factors were assessed and all meet or exceed the required Gradation 2 level: (1) Software Quality Assurance — commercial solver with ISO 9001-aligned QMS, Gradation 2 met; (2) Numerical Code Verification — vendor test suite plus independent benchmark reproduction, Gradation 2 met; (3) Discretization Error — formal GCI study with GCI_fine = 2.1%, Gradation 3 achieved against Gradation 2 requirement; (4) Test Conditions — ISO 10993-compliant bench setup with NIST-traceable instrumentation, Gradation 2 met; (5) Output Comparison — mean absolute error 6.3% on RH, within ±10% acceptance band, Bland-Altman confirms no bias, Gradation 2 met; (6) Relevance of QoI — RH is the FDA-accepted regulatory metric, mechanistically grounded, Gradation 2 met; (7) Relevance of Validation to COU — same geometry, same operating points, no extrapolation required, Gradation 2 met. Six factors (Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, Equivalency of Input Parameters) are marked not-applicable with documented rationale in each factor record. The not-applicable designations are grounded in: (a) ASME V&V 40-2018 Table 3 MRL 2 scoping provisions; (b) the comparative (relative) nature of the COU which cancels systematic biases; (c) absorption of the relevant uncertainty into already-assessed factors with documented UQ evidence; and (d) controlled single-team model execution eliminating user-error pathways. The three ValidationResult records (VR-01 hemolysis bench, VR-02 pressure head, VR-03 mesh convergence) each carry comparedAgainst, prov:wasGeneratedBy, and hasUncertaintyQuantification links providing a complete provenance chain from raw experimental data through uncertainty quantification to credibility factor evidence. The decision consequence is High and model influence is Medium (MRL 2). All seven assessed factors meet their required levels. The six not-applicable factors are supported by rationale that is specific, traceable to standard provisions, and does not introduce unmitigated credibility gaps. The credibility evidence is sufficient to support the regulatory submission claim that CFD-predicted RH < 1 is credible for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
