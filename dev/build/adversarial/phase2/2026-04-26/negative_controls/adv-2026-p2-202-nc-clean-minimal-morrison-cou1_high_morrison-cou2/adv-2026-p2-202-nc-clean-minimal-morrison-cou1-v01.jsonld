  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-criteria",
      "rationale": "The CFD solver (OpenFOAM v9) is subject to a documented software quality assurance plan including version control, issue tracking, regression test suite (>400 test cases), and change management procedures compliant with IEC 62304 Class B. SQA audit completed 2024-11 with no critical findings. Achieved Gradation 3 meets the required Gradation 3 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5-criteria",
      "rationale": "Numerical code verification performed via method of manufactured solutions (MMS) for the incompressible Navier-Stokes solver and the power-law hemolysis transport equation. Observed convergence rates match theoretical orders for both spatial (second-order) and temporal (first-order implicit) schemes. Additionally, benchmark comparisons against NIST lid-driven cavity and Womersley pipe flow solutions confirm implementation correctness. Achieved Gradation 4 exceeds required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5-criteria",
      "rationale": "Systematic mesh refinement study performed on the FDA pump geometry using three structured hex-dominant meshes (2.1M, 8.4M, 33.6M cells). Richardson extrapolation applied; Grid Convergence Index (GCI) for NIH < 4.2% on the medium mesh. The production mesh (8.4M cells) is selected based on GCI < 5% criterion. Time-step independence verified by halving dt. Achieved Gradation 3 meets required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5-criteria",
      "rationale": "Experimental test conditions are fully documented: temperature (37 ± 0.5 °C), blood analog fluid (porcine blood, hematocrit 33 ± 2%), pump rotational speed (2500, 3500 RPM), and flow rates (2, 4, 6 L/min). All five operating points replicated in CFD with boundary conditions derived directly from measured values. Uncertainty in inlet velocity ±2% propagated through Monte Carlo UQ. Achieved Gradation 3 meets required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5-criteria",
      "rationale": "Quantitative comparison metrics defined a priori: normalized RMSE for velocity fields (threshold ≤ 10%) and maximum relative error for NIH (threshold ≤ 20%). Achieved NRMSE = 7.4% and max NIH relative error = 12%. Agreement metrics computed with experimental uncertainty bands. All comparisons documented in validation report VR-COU2-2025. Achieved Gradation 3 meets required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5-criteria",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH, g/100L) — is the clinically accepted metric for hemolysis assessment per ISO 10993-4 and ASTM F1841. Secondary QoIs (velocity field, pressure head) directly support confidence in the hemolysis prediction pathway. Traceability from COU decision question to each QoI is documented in the V&V plan. Achieved Gradation 3 meets required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5-criteria",
      "rationale": "Validation experiments conducted on the identical FDA generic centrifugal pump geometry, using the same blood analog fluid and the same five operating points specified in the COU. Device geometry, fluid properties, operating envelope, and hemolysis endpoint all directly match the intended use. No surrogate geometry or scaled model is employed. Achieved Gradation 4 meets required Gradation 4 for a Class III device at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5-criteria",
      "rationale": "Iterative convergence monitored via normalized residuals (< 1×10⁻⁵ for all transport equations) and mass imbalance (< 0.01%). Floating-point round-off assessed via double-precision arithmetic throughout; no single-precision operations in critical hemolysis accumulation path. Solver error estimated < 0.3% of NIH by comparison of residual-converged and over-converged solutions. Achieved Gradation 3 meets required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5-criteria",
      "rationale": "A simulation execution checklist and peer-review protocol are enforced for all production runs. Two independent analysts reproduced the baseline NIH prediction within 1.8% relative difference using the same mesh and boundary conditions, confirming absence of operator-induced variability. All simulation inputs, solver settings, and post-processing scripts are version-controlled and archived. Achieved Gradation 3 meets required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5-criteria",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) is evaluated against three alternative hemolysis constitutive models (Arora, Taskin, Faghih-Sharp) at all five operating points. Sensitivity of NIH to model-form choice quantified; maximum inter-model spread is 18% of mean NIH. The selected model produces the most conservative (highest) NIH estimate, providing a safety margin. Model-form uncertainty is included as an explicit term in the Monte Carlo UQ. Achieved Gradation 4 meets required Gradation 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5-criteria",
      "rationale": "All model input parameters (fluid density, dynamic viscosity, hemolysis model coefficients α, β, C) are sourced from peer-reviewed literature with documented uncertainty ranges. Monte Carlo sampling (N=2000) performed over joint input distribution; 95th-percentile NIH prediction remains 22% below clinical threshold. Input sensitivity indices (Sobol first-order) computed; hemolysis coefficient C dominates variance (S₁ = 0.61). Achieved Gradation 3 meets required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5-criteria",
      "rationale": "Experimental hemolysis measurements obtained from n=6 independent pump specimens, each tested in triplicate at each operating point (total 90 experimental observations). Specimen-to-specimen variability characterized; coefficient of variation < 8% for NIH. Sample provenance, storage, and handling documented per ISO 10993-4. Statistical power analysis confirms n=6 sufficient to detect a 15% difference in NIH at α=0.05, β=0.20. Achieved Gradation 3 meets required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5-criteria",
      "rationale": "A formal input equivalency table maps each experimental boundary condition to its corresponding CFD input parameter. Dimensional analysis confirms dynamic similarity (Reynolds number, Womersley number) between bench and simulation conditions. Deviations in hematocrit (±2%) and temperature (±0.5 °C) are propagated through the Monte Carlo UQ and shown to contribute < 3% to total NIH variance. Achieved Gradation 3 meets required Gradation 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and achieved levels meet or exceed required levels for Model Risk Level 5. Key findings: (1) Validation activities are conducted on the identical device geometry and operating conditions specified in the COU, providing direct evidence of predictive adequacy. (2) Monte Carlo UQ (N=2000) confirms the 95th-percentile predicted NIH is 22% below the clinical threshold of 0.01 g/100L, establishing an adequate safety margin under input uncertainty. (3) Model-form uncertainty is explicitly quantified across four hemolysis constitutive models; the selected model yields conservative estimates. (4) Discretization error (GCI < 4.2%) and iterative convergence (residuals < 1×10⁻⁵) are both within acceptable bounds. (5) Software QA, use-error controls, and test-sample adequacy are all documented and independently verified. The structured evidence package provides sufficient credibility to support the regulatory submission claim that the CFD model can predict absolute hemolysis levels for the Class III VAD device within the bounds of the COU. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
