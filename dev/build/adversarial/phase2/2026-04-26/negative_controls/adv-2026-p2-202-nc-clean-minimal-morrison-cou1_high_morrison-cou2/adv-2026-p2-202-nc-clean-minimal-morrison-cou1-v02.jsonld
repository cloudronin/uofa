  "signature": "ed25519:b7e3a1c4d9f2056e8b3a1c4d9f2056e8b3a1c4d9f2056e8b3a1c4d9f2056e8b3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-acceptance",
      "rationale": "CFD solver (ANSYS Fluent 2023R1) operates under ISO 9001:2015 quality management system. Full version control via Git with tagged releases. Regression test suite of 847 benchmark cases executed prior to each release; pass rate 100% for hemolysis-relevant test cases. Software validation plan documented and approved by QA lead. Change control records complete for all solver modifications within the study period. Independent code review performed by external assessor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5-acceptance",
      "rationale": "Method of Manufactured Solutions (MMS) applied to the full Navier-Stokes solver including turbulence closure. Observed order of accuracy (OOA) of 1.94 for velocity components and 1.89 for pressure, consistent with nominal second-order spatial discretization. MMS residuals converge to machine precision. Results reproduced on three independent hardware configurations. Code verification report peer-reviewed and archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5-acceptance",
      "rationale": "Systematic grid convergence study performed on three geometrically similar meshes (4.2M, 12.6M, 37.8M cells) at all 5 operating points. Grid Convergence Index (GCI) computed per Celik et al. (2008): GCI_fine < 1.2% for velocity QoIs, < 2.8% for hemolysis index. Asymptotic range confirmed (GCI_coarse/GCI_fine ratio within 5% of unity). Temporal convergence verified with time-step refinement study showing < 0.5% change in cycle-averaged hemolysis index. Richardson extrapolation applied to provide best-estimate solution with quantified discretization uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5-acceptance",
      "rationale": "Experimental test conditions documented with full traceability: flow rates measured with calibrated Coriolis flowmeter (±0.2% FS), rotational speed with optical tachometer (±0.1 RPM), fluid temperature controlled to 37±0.5°C using recirculating bath. Blood analog fluid (glycerol-water, 36% v/v) characterized with viscometer at test temperature; density measured gravimetrically. All instruments calibrated against NIST-traceable standards within 12 months of test campaign. Environmental conditions (temperature, humidity, barometric pressure) logged at 1-minute intervals throughout testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5-acceptance",
      "rationale": "Quantitative comparison metrics computed for all QoIs: (1) velocity field — normalized RMS error 6.3% (threshold < 8%), (2) hemolysis index — mean absolute percentage error 11.4% across 5 operating points (threshold < 15%), (3) pressure rise — mean error 3.8% (threshold < 5%). Agreement metrics include experimental uncertainty bands propagated via GUM methodology. Comparison plots generated with uncertainty envelopes for both simulation (Monte Carlo) and experiment (repeated trials, n=6 per operating point). All comparison data archived in structured dataset with DOI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5-acceptance",
      "rationale": "QoIs selected (hemolysis index, velocity field, pressure rise) directly map to the clinical decision endpoint: absolute hemolysis below the NIH threshold of 0.01 g/100L. Clinical relevance confirmed by hematologist co-investigator. Hemolysis index computed using the Giersiepen-Wurzinger power-law model applied to CFD-resolved shear stress histories along Lagrangian particle tracks (10,000 particles per operating point). QoI traceability matrix links each simulation output to corresponding regulatory requirement in the 510(k) submission plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5-acceptance",
      "rationale": "Validation activities performed on the FDA generic centrifugal pump geometry — the same geometry used in the COU — at operating conditions spanning the full clinical envelope (flow 2–8 L/min, speed 2000–3500 RPM). Fluid properties matched to blood analog within validated Newtonian approximation range. Geometric fidelity confirmed by CMM measurement of physical test article against CAD nominal (maximum deviation 0.08 mm). Validation hierarchy documented from unit-level component flows through full pump assembly, ensuring no extrapolation beyond validated parameter space for the COU operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5-acceptance",
      "rationale": "Iterative convergence monitored via normalized residuals (< 1e-6 for all equations) and QoI stabilization (< 0.01% change over final 500 iterations). Round-off error estimated via double-precision vs quad-precision comparison on representative case: difference < 0.003% in hemolysis index, confirming round-off is negligible relative to discretization error. Linear solver tolerance set three orders of magnitude below discretization error estimate. Convergence history archived for all 5 operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5-acceptance",
      "rationale": "Simulation setup reviewed by independent CFD analyst not involved in original case preparation. Checklist-based review covers boundary condition assignment, material property specification, solver settings, and post-processing scripts. Two discrepancies identified and corrected during review (inlet turbulence intensity specification and particle injection density); corrected results differ by < 2% in hemolysis index. Final simulation inputs archived in version-controlled repository with read-only access post-approval. User qualification records on file for all analysts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5-acceptance",
      "rationale": "Turbulence model selection justified through systematic comparison: SST k-omega, realizable k-epsilon, and RSM evaluated against PIV data at 3 operating points. SST k-omega achieves lowest normalized RMS velocity error (6.3%) and best captures separation in the volute region relevant to hemolysis hot spots. Hemolysis sub-model (Giersiepen-Wurzinger) selected based on published benchmark comparisons for centrifugal pump configurations. Model form uncertainty quantified by comparing predictions from two alternative turbulence closures and bounding the spread; included in Monte Carlo UQ ensemble. Non-Newtonian effects assessed and confirmed negligible (Carreau model sensitivity < 1.5% in hemolysis index at clinical hematocrit range)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5-acceptance",
      "rationale": "All model input parameters assigned probability distributions based on measurement uncertainty and literature data: fluid viscosity (normal, CV=1.2%), density (normal, CV=0.3%), inlet flow rate (normal, CV=0.5%), rotational speed (normal, CV=0.05%), hemolysis model coefficients (log-normal, based on published fitting uncertainty from Giersiepen et al. 1990). Monte Carlo propagation with 2,000 Latin Hypercube samples per operating point. Input sensitivity analysis (Sobol indices) identifies hemolysis model exponent as dominant contributor (S1=0.61) followed by fluid viscosity (S1=0.18). Input traceability matrix links each parameter to its source document."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5-acceptance",
      "rationale": "Physical test article is the FDA generic centrifugal pump manufactured to published dimensional specifications. CMM inspection confirms geometric conformance. Blood analog fluid (glycerol-water) prepared from pharmaceutical-grade reagents with batch certification. Six repeat experimental runs performed at each of the 5 operating points to characterize experimental repeatability; coefficient of variation in hemolysis index < 4.1% across all operating points. Sample preparation and handling procedures documented in test protocol with full traceability to raw data files."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5-acceptance",
      "rationale": "Simulation boundary conditions set to match experimental conditions using measured values (not nominal): inlet flow rate from Coriolis meter readings, rotational speed from tachometer, fluid properties from viscometer/densitometer measurements at test temperature. Residual differences between simulation inputs and experimental conditions quantified and propagated through sensitivity analysis: maximum hemolysis index impact of input mismatch estimated at 1.8%, well within validation tolerance. Equivalency assessment documented in validation report Section 4.3 with parameter-by-parameter comparison table."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-nc2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-vv40-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at Model Risk Level 5. Achieved levels meet or exceed required levels across all factors: Software QA (4/4), Code Verification (4/4), Discretization Error (5/4), Test Conditions (4/4), Output Comparison (4/4), QoI Relevance (4/4), Validation Relevance (4/4), Solver Error (4/3), Use Error (3/3), Model Form (4/4), Model Inputs (4/4), Test Samples (3/3), Input Equivalency (4/4). Monte Carlo uncertainty quantification performed with 2,000 LHS samples per operating point; 95th percentile hemolysis index predictions remain below the NIH clinical threshold of 0.01 g/100L across all 5 operating conditions. Validation activities performed on the identical pump geometry under conditions spanning the full clinical operating envelope with no extrapolation required. Independent peer review of simulation setup identified and resolved two minor discrepancies prior to final assessment. The structured evidence chain from raw experimental data through uncertainty quantification to validated hemolysis predictions provides sufficient credibility for regulatory submission supporting Class III VAD device clearance. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
