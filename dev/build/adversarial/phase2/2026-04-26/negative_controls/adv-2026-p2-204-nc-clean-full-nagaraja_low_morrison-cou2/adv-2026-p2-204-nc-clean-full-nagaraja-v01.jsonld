  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-orth-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-orth-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achieved levels meet or exceed required levels for Model Risk Level 3. Software quality assurance (achieved 3 ≥ required 2), numerical code verification (achieved 2 ≥ required 2), discretization error (achieved 3 ≥ required 2), test conditions (achieved 2 ≥ required 2), output comparison (achieved 3 ≥ required 2), relevance of QOIs (achieved 2 ≥ required 2), relevance of validation activities (achieved 3 ≥ required 2), numerical solver error (achieved 2 ≥ required 2), use error (achieved 2 ≥ required 2), model form (achieved 3 ≥ required 2), model inputs (achieved 3 ≥ required 2), test samples (achieved 2 ≥ required 2), and equivalency of input parameters (achieved 2 ≥ required 2). Three independent validation studies (cadaveric BMD, CT morphology, gait loading) each with documented comparedAgainst datasets, provenance activities, and uncertainty quantification links support the validation evidence base. Monte Carlo UQ on material property inputs demonstrates that 95% prediction intervals on all Gruen zone BMD change QOIs remain within the ±10% clinical acceptance band. The overall credibility evidence is sufficient to support use of the FEA model for predicting relative stress-shielding outcomes for the Class II cementless THA stem under the stated COU. The credibility assessment team unanimously accepts the simulation results as fit for purpose.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
