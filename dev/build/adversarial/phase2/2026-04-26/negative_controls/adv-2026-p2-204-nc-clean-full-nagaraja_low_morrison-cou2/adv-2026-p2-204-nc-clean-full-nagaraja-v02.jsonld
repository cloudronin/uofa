  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-vv40-ortho-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at Model Risk Level 3. Achieved credibility levels meet or exceed required levels for all factors: seven factors achieved level 3 (exceeding the level 2 requirement) and six factors achieved the required level 2. Key evidence supporting acceptance includes: (1) strain gauge validation demonstrating mean absolute relative error of 6.8% with Pearson r = 0.97 across 12 measurement locations on three cadaveric specimens, within the pre-specified ±15% acceptance threshold confirmed by TOST; (2) mesh convergence with GCI < 2% confirming discretization error is controlled; (3) Monte Carlo uncertainty quantification on material property and loading inputs yielding a peak stress coefficient of variation of 8.3%, which is acceptable for a relative comparison application at MRL 3; (4) model form sensitivity study confirming isotropic material model is conservative and within acceptance threshold; (5) complete software quality assurance and use error controls with independent review. The validation activities are directly relevant to the COU domain, with cadaveric specimens spanning the anatomical variability range and loading conditions replicating ISO 7206-4. No credibility factor gaps remain. The FE model is accepted for use in predicting relative peak von Mises stress distributions in the cementless THA stem to support comparative design decisions as specified in COU1.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
