  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-mrl2",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with documented QA procedures, version-controlled input decks, and audit trail. SQA Gradation 2 achieved: solver release notes reviewed, simulation input files stored under git version control with SHA-256 checksums, and run logs archived. Exceeds MRL 2 requirement of Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-mrl2",
      "rationale": "ANSYS Fluent has published code verification results for incompressible rotating machinery benchmarks including the FDA nozzle and pump cases. Internal method of manufactured solutions (MMS) tests confirm second-order spatial accuracy. Gradation 2 achieved by reference to published solver verification suite and reproduction of FDA nozzle benchmark within 3% of published values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-mrl2",
      "rationale": "Grid convergence index (GCI) study performed across three systematically refined meshes (4.2M, 9.8M, 21.3M cells) for all five operating points. GCI for hemolysis index < 4.8% on fine mesh; GCI for pressure rise < 2.1%. Observed order of convergence p=1.87, consistent with second-order scheme. Richardson extrapolation applied. Achieves Gradation 3, exceeding MRL 2 requirement of Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-mrl2",
      "rationale": "Experimental bench tests conducted at five flow-speed combinations (2.5 L/min at 2500 RPM, 5 L/min at 2500 RPM, 5 L/min at 3500 RPM, 7.5 L/min at 3500 RPM, 7.5 L/min at 4500 RPM) spanning the CPB operating envelope. Temperature controlled at 37±0.5°C; blood analog viscosity matched to 37°C whole blood (3.5 cP). Test conditions documented in laboratory protocol LP-2023-07 and traceable to NIST-calibrated instrumentation. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-mrl2",
      "rationale": "Predicted relative hemolysis index RH compared against bench measurements at all five operating points. Maximum absolute error in RH = 0.08 (unitless); all predictions fall within expanded measurement uncertainty (k=2). Pressure rise predictions within 5.2% of measured values. Comparison metrics computed using ASME V&V 20 standard approach with systematic and random uncertainty components separated. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-mrl2",
      "rationale": "The primary QOI is the relative hemolysis index (RH = NIH_device / NIH_predicate), which directly maps to the regulatory acceptance criterion (RH < 1). Secondary QOIs include shear stress distribution and exposure time integrated along Lagrangian particle paths. All QOIs are directly used in the regulatory submission decision. Gradation 2 achieved: QOIs formally defined in the simulation plan and linked to the COU decision criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-mrl2",
      "rationale": "Validation activities conducted on the FDA generic centrifugal pump geometry—the same geometric family as the device under assessment—at overlapping operating conditions. Blood analog fluid (glycerol-water, 37°C) used in bench tests matches CFD material model. Geometric fidelity confirmed by CMM measurement of test article vs. CAD. Validation domain overlaps COU domain in flow rate, rotational speed, and fluid properties. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-na",
      "rationale": "Numerical solver error as a standalone factor is not applicable at MRL 2 for this COU because solver-level round-off and iterative convergence errors are fully subsumed within the Discretization Error factor assessment (GCI study) and the Code Verification factor. ASME V&V 40-2018 Table 3 permits consolidation of overlapping numerical factors at MRL 2 when the encompassing factors are assessed at Gradation 2 or higher. Iterative convergence monitored: all residuals < 1e-5; mass imbalance < 0.01%. No independent residual contribution from solver error beyond what is captured in GCI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-na",
      "rationale": "Use error as a standalone credibility factor is not applicable to this COU because the simulation is executed exclusively by trained CFD analysts under a documented simulation governance procedure (SGP-2023-04) that includes mandatory peer review of all boundary condition inputs, mesh settings, and post-processing scripts. The SQA factor (assessed at Gradation 2) encompasses procedural controls against user-induced errors. At MRL 2 with medium model influence, ASME V&V 40-2018 does not require independent use-error quantification beyond what SQA controls provide."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-na",
      "rationale": "Model form uncertainty as an independent factor is not applicable at MRL 2 for this incompressible Newtonian CFD application. The SST k-omega turbulence model is the established standard for rotating blood pump simulations (per FDA guidance and published literature) and its applicability to this flow regime is confirmed by the validation activities captured under 'Relevance of validation activities to the COU'. Model form sensitivity is implicitly bounded by the output comparison results (RH error < 0.08). Separate model form factor assessment is not required at MRL 2 when validation coverage is adequate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-na",
      "rationale": "Model inputs uncertainty as a standalone factor is not applicable at MRL 2 for this COU. Input parameters (geometry, fluid viscosity, boundary flow rates, rotational speed) are well-characterized with measurement uncertainties < 2% and are propagated through the uncertainty quantification captured in the Discretization Error and Output Comparison factors. At MRL 2 with the current validation coverage, ASME V&V 40-2018 does not mandate a separate parametric sensitivity study for model inputs. A boundary condition sensitivity sweep (±5% on flow rate) was conducted as part of the GCI study and showed < 3% variation in RH, confirming low sensitivity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-na",
      "rationale": "Test samples as a standalone credibility factor is not applicable because the validation experiments use a blood analog fluid (glycerol-water mixture) rather than biological specimens, eliminating donor variability and sample degradation concerns. The fluid properties are fully characterized by viscometry at test temperature. Sample-to-sample variability is not a credibility concern for this COU. This determination is consistent with FDA guidance on blood analog use in pump hemolysis benchmarking and ASME V&V 40-2018 Table 3 scoping provisions at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/equivalency-inputs-na",
      "rationale": "Equivalency of input parameters between the validation experiment and the COU simulation is not assessed as a standalone factor because this equivalency is fully addressed within the 'Relevance of validation activities to the COU' factor (assessed at Gradation 2). The validation and COU share the same geometric family, fluid model, operating envelope, and boundary condition specification. No material discrepancy in input parameters exists between the validation scenario and the COU scenario that would require a separate equivalency assessment. Documenting this as not-applicable avoids double-counting of evidence already captured in the validation relevance factor."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluidics-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis prediction at MRL 2) is accepted based on the following structured evidence: (1) Seven credibility factors were formally assessed—Software Quality Assurance (Gradation 2 ≥ required 1), Numerical Code Verification (Gradation 2 ≥ required 1), Discretization Error (Gradation 3 ≥ required 2), Test Conditions (Gradation 2 ≥ required 2), Output Comparison (Gradation 2 ≥ required 2), Relevance of Quantities of Interest (Gradation 2 ≥ required 2), and Relevance of Validation Activities to COU (Gradation 2 ≥ required 2). All seven assessed factors meet or exceed their required gradation levels. (2) Six factors are marked not-applicable with documented rationale: Numerical Solver Error and Use Error are subsumed by assessed factors at higher gradation; Model Form, Model Inputs, and Equivalency of Input Parameters are addressed within the validation relevance and output comparison assessments; Test Samples is not applicable due to use of a fully characterized blood analog. Each not-applicable determination is grounded in ASME V&V 40-2018 Table 3 scoping provisions and the MRL 2 context. (3) Three independent validation results (pressure-rise, hemolysis index, velocity field) are linked with uncertainty quantification and experimental comparanda. (4) The primary regulatory criterion RH < 1 is met at all five operating points with maximum RH prediction error of 0.08. The evidence chain is complete from foundational experimental data through simulation outputs to the regulatory decision criterion. No credibility gaps remain at MRL 2 for this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
