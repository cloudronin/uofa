  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for CPB Class II device, MRL 2) is accepted based on the following structured evidence: (1) Seven factors were formally assessed and all achieved levels meeting or exceeding required levels for MRL 2 — Software QA (2≥1), Code Verification (2≥1), Discretization Error (2≥2), Test Conditions (2≥2), Output Comparison (3≥2), QoI Relevance (2≥2), and Validation Relevance (2≥2). (2) Six factors were marked not-applicable with explicit rationale grounded in the MRL 2 scope per ASME V&V 40 Table 4 requirements — Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, and Equivalency of Input Parameters are each required only at MRL 3 or higher, and the existing assessed factors provide sufficient coverage of the associated risks at MRL 2. (3) The primary QoI (relative hemolysis index RH) satisfies the acceptance criterion RH < 1 at the worst-case operating point with mean absolute error 8.4% across all 5 validation points, within expanded uncertainty bounds. (4) The provenance chain is complete: validation results link to bench measurement datasets, uncertainty quantification activities, and analytical reference solutions. (5) No weakeners were identified. The model is fit for the stated COU at the declared assurance level of Medium.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
