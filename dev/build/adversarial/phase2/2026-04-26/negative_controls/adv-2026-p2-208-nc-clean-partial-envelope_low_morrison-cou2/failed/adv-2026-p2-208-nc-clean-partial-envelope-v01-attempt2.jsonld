  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed with achievedLevel >= requiredLevel for MRL 5. The operating envelope is explicitly bounded (flow rate 2–8 L/min, rotational speed 2000–3500 RPM, viscosity 3.0–4.0 mPa·s, hematocrit 35–45%) and the validation campaign densely covers this envelope with 25 operating points on a structured grid. Monte Carlo UQ (N=50000) confirms 95% CI on NIH predictions lies below the clinical threshold of 0.01 g/100 L at all operating points. Model form uncertainty quantified by comparison of three alternative hemolysis models. Discretization error (GCI < 2%) and solver convergence verified. Independent blind replication confirms use-error control. The hasApplicabilityConstraint and hasOperatingEnvelope declarations bound the scope of this credibility assessment; predictions outside the declared envelope are explicitly excluded. The totality of evidence supports acceptance of the CFD hemolysis model for the declared COU within the stated operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
