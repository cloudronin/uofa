  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5",
      "rationale": "The CFD solver (ANSYS Fluent 2024R1) operates under a documented software quality assurance plan that includes version-controlled source releases, regression test suite covering 450+ benchmark cases, and ISO 9001-certified development process. All solver versions used in this study are archived with checksums. Achieved Gradation 3 satisfies the required level for MRL 5 under the Morrison credibility matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Numerical code verification was performed using the Method of Manufactured Solutions (MMS) for the incompressible Navier-Stokes solver and the scalar transport equation used for hemolysis accumulation. Observed order of convergence (1.97 for velocity, 1.94 for scalar) matches theoretical second-order accuracy. Results archived in verification report VR-2025-CFD-001. Achieved Gradation 3 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5",
      "rationale": "A formal grid convergence study was conducted across four systematically refined meshes (2.1M, 5.8M, 14.2M, and 31.7M cells) following ASME V&V 20 procedures. Grid Convergence Index (GCI) for hemolysis index at the design operating point is 3.2%, and for peak shear stress is 4.1%. Richardson extrapolation confirms apparent order of 1.91. The production mesh (14.2M cells) achieves GCI < 5% for all quantities of interest. Temporal discretization error assessed via time-step refinement study; Courant number maintained below 0.8. Achieved Gradation 4 meets required level for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "Experimental test conditions for the FDA benchmark pump are documented in FDA Technical Report TR-2012-05 and replicated in the bench hemolysis study. Flow rates (2, 4, 6 L/min) and rotational speeds (2000, 2500, 3500 RPM) span the VAD operating envelope. Fluid temperature, hematocrit (35%), and blood analog viscosity are controlled and reported with uncertainty bounds. Test condition fidelity to COU operating conditions is confirmed by clinical operating range review. Achieved Gradation 3 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "Quantitative output comparison was performed using the ASME V&V 20 validation metric. Normalized RMS error for hemolysis index across five operating points is 8.3% (threshold: 15%). Velocity field comparison against PIV data yields mean absolute error of 4.7% of bulk velocity. Pressure head predictions fall within 2.1% of experimental measurements. All comparisons account for experimental uncertainty via expanded uncertainty intervals (k=2). Monte Carlo ensemble (N=500 samples) provides 95% prediction intervals that envelope experimental data at all operating points. Achieved Gradation 4 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "The primary quantity of interest — normalized index of hemolysis (NIH) — is directly mapped to the clinical acceptance criterion (NIH < 0.01 g/100L). Secondary QoIs include volumetric shear stress distribution and particle residence time, both of which are mechanistically linked to hemolysis through the Giersiepen-Wurzinger power-law model. A formal QoI relevance matrix traces each computational output to a clinical endpoint. All QoIs are observable in the validation experiment. Achieved Gradation 4 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump geometry — the same geometry used in the COU. Operating conditions in the validation study overlap with the COU envelope at four of five target operating points. The fifth point (maximum speed, minimum flow) was validated on a geometrically similar pump with documented morphological similarity score of 0.94. Blood analog fluid (glycerol-water, matched viscosity) was used in lieu of whole blood, with a documented similarity assessment confirming Reynolds number matching within 3%. Achieved Gradation 4 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Numerical solver error as a distinct credibility factor — separate from discretization error and code verification — addresses residual convergence behavior, floating-point round-off accumulation, and iterative solver tolerance effects on the final solution. For this assessment, the team conducted a thorough marginal-call review. The CFD solver employs double-precision arithmetic throughout; residual convergence is monitored to 1×10^-6 for all equations; and iterative solver tolerance sensitivity was investigated by tightening tolerances by two orders of magnitude with no observable change in hemolysis index (< 0.1% variation). Given that (a) the code verification activity already bounds truncation error, (b) the discretization error study characterizes the dominant numerical error source, and (c) the solver tolerance sensitivity study demonstrates negligible residual solver error contribution, the incremental credibility gain from a full Gradation 4 numerical solver error assessment is judged to be marginal relative to the analytical burden at MRL 5. This factor is therefore scoped out with the documented finding that solver-induced numerical error is bounded below 0.5% of the hemolysis index QoI — well within the validation comparison uncertainty budget. This scoping decision was reviewed and approved by the independent credibility assessor on 2025-11-14."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "Use error was assessed through a structured analyst qualification review and simulation execution checklist. Two independent analysts reproduced the baseline hemolysis simulation from archived input files; results agreed within 0.3% for NIH. Simulation setup is governed by a controlled simulation protocol document (SPD-2025-VAD-001, revision 3) covering mesh import, boundary condition assignment, solver settings, and post-processing procedures. All deviations from protocol are logged. Achieved Gradation 3 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "Model form uncertainty was assessed by comparing three hemolysis sub-model formulations: (1) Giersiepen-Wurzinger power-law, (2) Taskin modified power-law, and (3) Zhang strain-based model. The Giersiepen-Wurzinger model was selected as primary based on best agreement with experimental NIH data (lowest RMSE across five operating points). Model form uncertainty is quantified as the inter-model spread in NIH predictions: ±12% at the design point, propagated into the total uncertainty budget. Turbulence model sensitivity was assessed by comparing k-ω SST, k-ε realizable, and LES results at the highest-shear operating point; k-ω SST was selected with documented justification. Achieved Gradation 4 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "Model input uncertainty was characterized for all 11 identified uncertain inputs including fluid viscosity, hematocrit, pump rotational speed tolerance, inlet flow rate measurement uncertainty, and hemolysis model coefficients. Probability distributions were assigned based on manufacturer specifications, clinical literature, and experimental calibration data. Monte Carlo propagation (N=500 Latin hypercube samples) quantifies the contribution of each input to output uncertainty. Sobol sensitivity indices identify hemolysis model coefficient C and exponent α as dominant contributors (first-order indices 0.41 and 0.29 respectively). Input uncertainty contributes ±18% to NIH at the 95th percentile. Achieved Gradation 4 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5",
      "rationale": "Experimental hemolysis measurements were obtained from n=6 independent pump specimens across three test laboratories, with each specimen tested at all five operating points in triplicate (n=90 total measurements). Inter-laboratory variability was assessed using ANOVA; no statistically significant laboratory effect was detected (p=0.23). Sample preparation protocol (blood analog preparation, priming procedure) is standardized across laboratories. The sample size provides sufficient statistical power (>0.80) to detect a 15% difference in NIH at α=0.05. Achieved Gradation 3 meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5",
      "rationale": "Equivalency of input parameters between the validation experiment and the COU was assessed using a formal parameter mapping table. Geometric fidelity: the simulation uses the FDA benchmark pump CAD geometry with dimensional tolerances documented from coordinate measuring machine (CMM) data. Boundary conditions: inlet velocity profiles in the simulation are derived from PIV measurements at the pump inlet plane, ensuring equivalency with experimental inflow. Fluid properties: viscosity and density match the blood analog fluid within 1.5%. Operating point equivalency: rotational speed and flow rate are matched to within the experimental measurement uncertainty. All equivalency assessments are documented in parameter equivalency report PER-2025-VAD-002. Achieved Gradation 3 meets required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis prediction, MRL 5) is accepted based on the following structured findings. Twelve of thirteen credibility factors were fully assessed; all twelve achieved levels meet or exceed required levels under the Morrison MRL 5 credibility matrix. The thirteenth factor (Numerical solver error) was scoped out following a documented marginal-call review that demonstrated solver-induced numerical error is bounded below 0.5% of the NIH QoI — negligible relative to the combined uncertainty budget of ±22% at the 95th percentile. The scoping decision was reviewed and approved by the independent credibility assessor. The Monte Carlo uncertainty quantification (N=500 samples) confirms that the 95th percentile NIH prediction of 0.0078 g/100L remains below the clinical acceptance threshold of 0.01 g/100L with a safety margin of 22%. Validation comparison across five operating points yields normalized RMSE of 8.3%, within the 15% acceptance criterion. Model form uncertainty (±12%) and input parameter uncertainty (±18%) are the dominant contributors to total prediction uncertainty and are explicitly accounted for in the acceptance margin evaluation. The provenance chain from foundational experimental data through validation activities to the credibility assessment is complete and archived. The assessment team concludes that the computational model has sufficient credibility for the intended use of predicting absolute hemolysis levels for regulatory submission supporting Class III VAD device clearance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
