  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-class3",
      "rationale": "The CFD solver (OpenFOAM v2206) is under formal version control with tagged release commits. A documented software quality plan covers unit testing, regression testing, and release validation. All simulation scripts are archived in a Git repository with SHA-256 hashes recorded at submission. Automated regression test suite covers 47 canonical cases; pass rate 100% at the tagged release version used for this assessment. Independent code review conducted by a second analyst confirmed no undocumented solver modifications. Achieved Level 4 satisfies the required Level 4 for MRL 5 Class III device context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Method of manufactured solutions (MMS) applied to the incompressible Navier-Stokes solver and the power-law hemolysis transport equation. Observed order of accuracy 1.97 (second-order scheme confirmed). MMS tests conducted on three systematically refined grids (refinement ratio 1.5) demonstrating monotonic convergence. Results archived in verification report VR-NCV-2025-04. The shear-stress transport (SST) turbulence model implementation verified against analytical Couette flow and pipe-flow benchmarks. Achieved Level 4 meets the required Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5",
      "rationale": "Grid convergence index (GCI) study performed on four meshes (0.8M, 2.1M, 5.6M, 14.9M cells) following Celik et al. (2008) procedure. GCI for NIH at the design operating point: 3.1% (fine-to-medium), 1.4% (finest pair), confirming approach to asymptotic range (ratio 0.97). Production mesh: 14.9M cells, y+ < 1 on all blood-contacting walls. Time-step independence confirmed: halving the time step changed NIH by < 0.5%. Discretization error contribution included in Monte Carlo UQ budget. Achieved Level 4 meets required Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "All five experimental operating points (flow rates 2–6 L/min, speeds 2400–3600 RPM) replicated the clinical VAD operating envelope as defined in the device design specification. Inlet boundary conditions (flow waveform, hematocrit 35±2%, temperature 37±0.5°C) matched in-vitro test rig conditions documented in test report TR-HEM-2024-09. Fluid properties (bovine blood viscosity, density) measured at test temperature and incorporated directly into CFD boundary conditions. Pump geometry used in CFD is the same CAD revision (Rev-D) used to manufacture test articles. Achieved Level 4 meets required Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "Quantitative validation metrics computed for NIH (primary QoI), pump head, and volumetric flow rate at all 5 operating points. Validation metric: area validation metric (AVM) per ASME V&V 20-2009. AVM for NIH = 0.07 (well within acceptance threshold of 0.20 set for MRL 5). Blind prediction submitted prior to receipt of experimental data for two operating points; post-blind comparison confirms no tuning. Uncertainty in experimental NIH measurements characterized via repeat trials (n=6 per operating point); combined standard uncertainty 6.2%. Model prediction intervals from Monte Carlo UQ overlap experimental uncertainty intervals at all 5 points. Achieved Level 5 exceeds required Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH, g/100L) — is the same metric used in the regulatory submission and in the clinical acceptance criterion (NIH < 0.01 g/100L). The power-law hemolysis model (Giersiepen et al., modified Zhang coefficients) directly outputs NIH. Secondary QoIs (wall shear stress, scalar shear stress, exposure time distributions) are tracked to support mechanistic interpretation. Mapping from model output to regulatory decision criterion is documented in a traceability matrix (TM-QoI-2025-03). No surrogate or proxy QoIs introduced. Achieved Level 4 meets required Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "Validation experiments performed on the identical FDA generic centrifugal pump geometry at the same five operating points that constitute the COU. The validation regime spans the full COU operating envelope (not a subset). Fluid used in validation (bovine blood analog, hematocrit-matched) is the closest practically achievable analog to clinical use; differences in RBC fragility between bovine and human blood are characterized and a correction factor with uncertainty bounds is documented in sensitivity study SS-BovHum-2024. Experimental facility (NHLBI-certified hemolysis test rig) has documented traceability to ASTM F1841. Achieved Level 4 meets required Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence monitored via residuals (all equations < 1e-6) and global force/torque balance (< 0.1% change over final 500 iterations). Round-off error assessed by comparing double- and extended-precision runs; NIH difference < 0.02%. Solver linear algebra tolerance set to 1e-8 for pressure equation. Convergence history archived for all 5 operating points. No divergence or non-physical oscillations observed. Achieved Level 3 meets required Level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "Simulation setup reviewed by a second independent CFD analyst following a documented peer-review checklist (PR-CFD-2025-01). Checklist covers boundary condition assignment, material property inputs, solver settings, post-processing scripts, and unit consistency. All 47 checklist items passed. Boundary condition files version-controlled and hash-verified against the approved input specification. Post-processing scripts independently re-executed by reviewer; NIH values reproduced to within floating-point precision. Achieved Level 3 meets required Level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "The power-law hemolysis model (modified Zhang et al. 2011 coefficients) was selected following a documented model-form selection study comparing four published hemolysis models against the in-vitro dataset. The Zhang-modified model achieved the lowest AVM (0.07) and the smallest bias across the operating range. SST k-omega turbulence closure selected based on benchmark performance in rotating machinery flows (Bhagat et al. 2019 round-robin). Model-form uncertainty estimated via ensemble of two alternative hemolysis models (Giersiepen original, Heuser-Opitz); the spread contributes 18% of total NIH prediction uncertainty and is included in the Monte Carlo UQ budget. Achieved Level 4 meets required Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "All 14 model inputs identified in the input parameter inventory (IPI-2025-02): geometry tolerances, fluid viscosity, density, hematocrit, inlet velocity profile, rotational speed, hemolysis model coefficients (C, alpha, beta), and turbulence intensity. Probability distributions assigned to each uncertain input based on measurement data or literature meta-analysis. Monte Carlo sampling (N=2000, Latin hypercube) propagates input uncertainty to NIH output. Sensitivity indices (Sobol first-order) computed; top three contributors are hemolysis coefficient C (43%), hematocrit (21%), and inlet turbulence intensity (14%). Achieved Level 4 meets required Level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5",
      "rationale": "Six independent test runs performed at each of the 5 operating points (30 total runs) using three separately manufactured pump specimens from the same production lot. Specimen dimensional inspection confirmed all critical dimensions within ±0.05 mm of CAD nominal. Blood analog hematocrit verified by centrifugation before each run. Intra-specimen repeatability (CV < 3.5%) and inter-specimen variability (CV < 6.1%) characterized and incorporated into experimental uncertainty budget. Sample size justification documented in statistical protocol SP-HEM-2024-07. Achieved Level 3 meets required Level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/equiv-inputs-mrl5",
      "rationale": "This factor assesses whether the input parameters used in the validation experiments are equivalent to those of the clinical COU. After careful deliberation, the assessment team determined that this factor sits at a genuinely marginal boundary between 'assessed' and 'scoped-out' for the following reasons: (1) The validation fluid is bovine blood at matched hematocrit, not human blood; a bovine-to-human RBC fragility correction factor has been derived and applied (sensitivity study SS-BovHum-2024), but the residual uncertainty in this correction is already fully captured within the Model Inputs factor UQ budget (Sobol index 8%), making a separate standalone assessment of this factor redundant and potentially double-counting the same uncertainty source. (2) The pump geometry used in validation is the FDA generic centrifugal pump, which is geometrically similar but not identical to the final production device; dimensional equivalency is addressed under the Test Conditions factor (Factor 4), which documents that the Rev-D CAD was used for both test article manufacture and CFD geometry. A second independent equivalency assessment here would re-examine the same geometric evidence already scored under Test Conditions. (3) The operating speed and flow rate ranges in validation exactly match the COU envelope, so the kinematic equivalency dimension of this factor is fully subsumed within the Test Conditions assessment. Scoping out this factor is therefore a deliberate methodological choice to avoid artificial inflation of the factor count and to maintain a clean, non-redundant evidence structure. The decision is documented in assessment planning record APR-2025-11, reviewed and approved by the lead credibility assessor and an independent reviewer. All substantive equivalency evidence is traceable through the Model Inputs and Test Conditions factors above."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis prediction, MRL 5, Class III) is accepted on the basis of the following structured findings: (1) All 12 assessed credibility factors achieve levels meeting or exceeding their required levels for MRL 5. The Output Comparison factor exceeds its required level (achieved 5 vs. required 4), providing additional confidence in model predictive accuracy. (2) The single scoped-out factor (Equivalency of input parameters) is supported by thorough documented rationale demonstrating that all substantive equivalency evidence is captured within the assessed Model Inputs and Test Conditions factors, with no unaddressed uncertainty gap. The scoping decision was reviewed and approved by an independent assessor. (3) Monte Carlo uncertainty quantification (N=2000) demonstrates that the 95th-percentile NIH prediction across all 5 operating points remains below the clinical acceptance threshold of 0.01 g/100L, with a margin of 22% at the most conservative operating point. (4) Blind prediction at two operating points confirms no post-hoc tuning of model parameters to match experimental data. (5) The complete provenance chain from raw experimental data through validation results to this assessment record is documented and hash-verified. All evidence is traceable to the foundational datasets and activities identified in this package. The assessment team concludes that the computational model provides sufficient credibility for use in the regulatory submission as primary evidence for hemolysis acceptance of the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
