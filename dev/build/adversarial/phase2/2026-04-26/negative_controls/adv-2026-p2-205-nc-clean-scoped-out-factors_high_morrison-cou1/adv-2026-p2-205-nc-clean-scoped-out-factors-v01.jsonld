  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence review. Twelve of thirteen ASME V&V 40 credibility factors were formally assessed; all twelve meet or exceed the required gradation level for MRL 2. The thirteenth factor (Test Samples) was scoped out with documented justification grounded in the reference-geometry nature of the experimental specimen, the relative (ratio-based) decision criterion, and the explicit tolerance UQ sweep that addresses the underlying concern of the factor. The scope-out determination was independently reviewed and concurred with. Key evidence supporting acceptance: (1) Validation against FDA CBP experimental hemolysis data demonstrates mean absolute relative error of 8.3%, within the computed validation uncertainty of 11.2%, confirming the model is not invalidated for the COU QoIs. (2) GCI-based discretization error is bounded at 2.1% for peak shear stress and below 5% for all QoIs on the production mesh, with Richardson extrapolation applied to all reported values. (3) A 120-run Latin hypercube tolerance sweep explicitly characterizes worst-case hemolysis across the manufacturing tolerance space; the identified worst-case condition yields RH = 0.87 < 1.0, satisfying the regulatory acceptance criterion with margin. (4) Model form uncertainty assessed by comparison against higher-fidelity LES; NIH differences < 6%, within validation uncertainty. (5) Provenance chain is complete: all ValidationResults link to primary experimental datasets, generating activities, and uncertainty quantification reports. (6) Software QA, code verification, solver error, and use error factors all achieved Gradation 2 or higher, exceeding MRL 2 requirements. The totality of evidence supports the claim that the CFD model is credible for identifying worst-case hemolysis operating conditions for the Class II CPB device within the defined COU, and the decision to accept the model for regulatory submission is warranted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
