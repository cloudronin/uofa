  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achieved levels meet or exceed required levels for Model Risk Level 3 Class II device. Software quality assurance (achieved 3 ≥ required 2), numerical code verification (achieved 3 ≥ required 2), and discretization error (achieved 3 ≥ required 2) demonstrate robust computational foundations. Validation activities using cadaveric specimens with strain gauge and contact pressure measurements confirm model predictive accuracy within pre-specified acceptance thresholds (MAPE ≤ 15%, contact pressure correlation R ≥ 0.85). Monte Carlo uncertainty quantification on material inputs confirms that 95th percentile peak stress predictions remain below the cortical bone fatigue threshold, providing a positive safety margin. Model form and input parameter uncertainties are bounded and documented. Validation relevance gaps (ex-vivo vs. in-vivo) are characterized and shown to have less than 5% influence on peak stress predictions via sensitivity analysis. The complete provenance chain from raw cadaveric test data through material characterization to FE predictions is documented. The credibility body of evidence is sufficient to support use of this FE model for tibial plateau stress prediction in TKA design evaluation at MRL 3. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
