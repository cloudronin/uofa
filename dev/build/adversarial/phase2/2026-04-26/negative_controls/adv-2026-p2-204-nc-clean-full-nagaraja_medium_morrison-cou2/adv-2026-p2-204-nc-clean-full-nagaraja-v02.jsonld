  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/synth/cou/nagaraja-cou1-ortho",
    "type": "ContextOfUse",
    "name": "COU1: Tibial tray stress and micromotion prediction for 510(k) submission (Class II)",
    "description": "An FEA model is used to predict peak von Mises stress in the tibial tray and bone-implant interface micromotion under ISO 14243-1 physiological loading conditions for a Class II total knee replacement device. Model influence is MODERATE (model results supplement cadaveric bench data but carry significant weight in the submission); decision consequence is MODERATE (incorrect prediction could lead to a fatigue failure or fixation loss in a device already bracketed by predicate performance). Model Risk Level 3.",
    "intendedUse": "Use FEA to predict peak von Mises stress and maximum bone-implant interface micromotion across three loading scenarios (level walking, stair ascent, deep knee bend) at two tibial component sizes (size 3 and size 5). Results must demonstrate stress below material fatigue limit and micromotion below 150 µm osseointegration threshold.",
    "modelInfluence": "Moderate",
    "decisionConsequence": "Moderate",
    "deviceClass": "Class II"
  },
