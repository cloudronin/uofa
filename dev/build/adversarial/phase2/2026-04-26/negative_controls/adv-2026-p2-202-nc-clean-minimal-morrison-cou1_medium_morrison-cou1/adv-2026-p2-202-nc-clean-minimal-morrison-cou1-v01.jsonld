  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluidics-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis worst-case identification, Class II, MRL 2) is accepted based on the following structured evidence: (1) All 7 assessed credibility factors meet or exceed their required levels — discretization error achieves level 3 against a requirement of 2, and all remaining assessed factors achieve their required level 2. (2) Six factors are appropriately scoped out per ASME V&V 40-2018 Table 3 guidance for MRL 2 with medium model influence and high decision consequence; each scoped-out factor is documented with explicit rationale. (3) Three independent ValidationResults are linked, each with comparedAgainst, prov:wasGeneratedBy, and hasUncertaintyQuantification populated: hemolysis index validation (mean error 8.3%, all points within 95% CI uncertainty bands), mesh convergence (GCI_fine 2.4%), and pressure-head validation (max deviation 5.8%). (4) Uncertainty quantification employs Monte Carlo propagation for boundary condition uncertainty and Richardson extrapolation for discretization error, with 95% coverage probability reported for all UQ activities. (5) The validation domain (FDA generic centrifugal pump, 2–5 L/min, 2400–3000 RPM, porcine blood 37°C, Hct 33%) overlaps the COU domain with high fidelity. (6) Software quality assurance and numerical code verification are documented to MRL 2 requirements. The RH < 1 acceptance criterion is achievable within the quantified prediction uncertainty. No unmitigated credibility gaps identified. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
