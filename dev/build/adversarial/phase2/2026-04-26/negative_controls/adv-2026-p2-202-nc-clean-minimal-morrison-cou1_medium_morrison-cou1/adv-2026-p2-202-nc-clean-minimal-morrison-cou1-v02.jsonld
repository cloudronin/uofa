  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for hemolysis prediction in the FDA generic centrifugal blood pump is accepted as credible for the COU at MRL 2. Evidence supporting this determination: (1) All 7 assessed credibility factors meet or exceed their required gradation levels — software QA (2≥1), code verification (2≥2), discretization error (3≥2), test conditions (2≥2), output comparison (2≥2), QoI relevance (2≥2), and validation-COU relevance (2≥2). (2) Six factors are appropriately scoped out with documented rationale consistent with ASME V&V 40-2018 Table 3 requirements at MRL 2. (3) Quantitative validation demonstrates mean absolute relative error of 8.3% in NIH across 5 operating points, within the 10% acceptance threshold, with all predictions within 95% uncertainty bounds. (4) GCI-based discretization error is 1.7% at the worst-case operating point, well below the 5% threshold. (5) The validation domain directly overlaps the COU decision space (same device class, same operating conditions, same QoI). (6) Provenance chain is complete: experimental data traceable to NIST-calibrated instruments, simulation runs traceable to archived input decks and software versions, and all evidence artifacts are linked. The RH < 1 acceptance criterion can be reliably evaluated using this model, and the decision to accept the model for identifying worst-case hemolysis operating conditions is well-supported by the structured evidence.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
