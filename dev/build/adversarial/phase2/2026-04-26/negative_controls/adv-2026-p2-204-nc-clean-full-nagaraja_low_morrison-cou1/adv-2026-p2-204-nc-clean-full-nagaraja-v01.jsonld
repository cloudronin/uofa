  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achievedLevel values meet or exceed the requiredLevel for MRL 3. Verification activities confirm numerical code correctness and mesh convergence (GCI 1.8%). Three independent validation studies demonstrate FEA predictions of peak von Mises stress, strain, and fatigue life agree with bench-top measurements within pre-specified acceptance criteria. Model inputs are traceable to production material certifications and ISO standard loading protocols. Input uncertainty has been propagated via Monte Carlo sampling. Test samples are representative of production lots with documented dimensional and material certification. Equivalency of simulation and test conditions is formally documented across seven dimensions. The credibility body of evidence is sufficient to support use of the FEA model for regulatory submission of fatigue endurance data for the Class II tibial tray device under the defined context of use. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
