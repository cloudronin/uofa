  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-level2",
      "rationale": "The CFD solver (ANSYS Fluent 2024R1) is a commercially validated code with documented V&V procedures, version control, and regression testing suite. Internal SQA audit confirmed compliance with FDA guidance on software validation for simulation tools. All simulation scripts are version-controlled in a traceable repository with documented change history. Achieved Gradation 2 satisfies MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-level2",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes and turbulence model equations confirms second-order spatial and first-order temporal convergence rates consistent with solver documentation. Benchmark comparisons against ASME V&V 20 lid-driven cavity and backward-facing step cases demonstrate solver accuracy. Achieved Gradation 3 exceeds MRL 2 requirement of Gradation 2, providing additional confidence margin. See ValidationResult vr/turbulence-model-verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-level2",
      "rationale": "Richardson extrapolation performed on three systematically refined meshes with refinement ratio r = 1.5. GCI for the primary QoI (NIH) is 3.2% on the medium mesh selected for production runs. Mesh topology employs boundary-layer-resolving prism layers (y+ < 1 at all blood-contacting surfaces) and hex-dominant core. Achieved Gradation 3 exceeds MRL 2 minimum. See ValidationResult vr/mesh-convergence-study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-level2",
      "rationale": "Experimental test conditions are documented with traceability to calibrated instrumentation. Flow rates measured with Coriolis mass flow meter (±0.5% accuracy), rotational speed with optical tachometer (±0.1% accuracy), and temperature maintained at 37±0.5°C. Test fluid (bovine blood, hematocrit 33±1%) characterized pre- and post-test. Boundary conditions applied in simulation are directly derived from measured experimental values. Achieved Gradation 2 satisfies MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-level2",
      "rationale": "Simulation outputs compared against experimental NIH measurements using pre-specified acceptance criterion of ±15% mean absolute error. Achieved MAE of 8.3% across all 5 operating points. Comparison includes uncertainty bands from both experimental measurement uncertainty and simulation numerical uncertainty. Agreement is within acceptance bounds at all operating conditions. See ValidationResult vr/hemolysis-index-comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-level2",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which directly maps to the regulatory acceptance criterion (RH < 1 relative to predicate). NIH is computed from the power-law hemolysis model integrated along Lagrangian particle trajectories, providing a direct link between the CFD flow field and the clinical hemolysis endpoint. Secondary QoIs (pressure rise, shear stress distribution) support mechanistic interpretation. QoI selection was reviewed and approved by the clinical advisory panel."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-level2",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump geometry, which is the same geometry class as the device under assessment. Operating conditions span the clinical CPB envelope (flow 3–6 L/min, speed 2000–3500 RPM), encompassing the 5 flow-speed combinations in the COU. Blood analog fluid properties match the COU physiological range. The validation hierarchy progresses from component-level (impeller passage) to full-pump system level, providing multi-scale evidence of model fidelity relevant to the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-scoped",
      "rationale": "At MRL 2, explicit separate quantification of numerical solver error beyond code verification is not required. The commercial solver's iterative convergence is demonstrated through residual monitoring (all residuals < 1e-5) and flux conservation checks (< 0.01% imbalance). Solver error is bounded within the discretization error quantification reported under the Discretization Error factor. Scoped out per ASME V&V 40-2018 Table 3 guidance for MRL 2 Class II devices where code verification has been completed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-scoped",
      "rationale": "Use error assessment at the level required for MRL 3+ is not mandated at MRL 2 for this Class II device. Procedural controls are in place: simulation setup follows a documented standard operating procedure, boundary condition application is independently reviewed by a second analyst, and post-processing scripts are version-controlled with automated sanity checks. These controls adequately bound use error risk at MRL 2. Scoped out per ASME V&V 40-2018 Table 3 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-scoped",
      "rationale": "Formal model form uncertainty quantification (e.g., multi-model ensemble or Bayesian model averaging) is not required at MRL 2. The SST k-omega turbulence model is the consensus recommendation for rotating machinery hemolysis CFD per FDA guidance and published literature. The power-law hemolysis model (Giersiepen et al., modified Zhang et al.) is the regulatory standard for NIH prediction. Model form adequacy is supported by the validation evidence demonstrating agreement within acceptance criteria. Scoped out per MRL 2 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-scoped",
      "rationale": "Formal global sensitivity analysis and full input uncertainty propagation are not required at MRL 2. Key input parameters (viscosity, density, hemolysis model coefficients) are drawn from peer-reviewed literature with documented uncertainty ranges. A local one-at-a-time sensitivity study confirmed that NIH predictions are most sensitive to rotational speed (±2% NIH per 1% speed change) and least sensitive to blood viscosity within physiological range. This bounded sensitivity assessment is adequate for MRL 2. Scoped out per ASME V&V 40-2018 Table 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-scoped",
      "rationale": "Statistical characterization of test sample variability (e.g., multiple pump units, batch-to-batch blood variability) beyond what was performed is not required at MRL 2. Three replicate experiments per operating point were conducted; coefficient of variation for NIH measurements was < 6% across all points, confirming adequate experimental repeatability. Device-to-device geometric variability is addressed through the tolerance sensitivity study in the COU. Scoped out per MRL 2 Class II device guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/input-equivalency-level2",
      "rationale": "Simulation input parameters are demonstrated to be equivalent to experimental conditions through systematic comparison: (1) pump geometry imported directly from metrology-verified CAD with dimensional accuracy ±0.05 mm; (2) fluid properties (density, viscosity, yield stress) measured from the same blood batch used in experiments; (3) inlet velocity profiles derived from upstream flow conditioning measurements; (4) rotational speed prescribed from tachometer readings with ±0.1% fidelity. Equivalency documentation reviewed and signed off by both experimental and computational team leads. Achieved Gradation 2 satisfies MRL 2 requirement."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump under CPB conditions is accepted as credible for its intended use at Model Risk Level 2. The credibility assessment evaluated all 13 ASME V&V 40-2018 factors: 7 factors were formally assessed with all achieving their required gradation levels (Software QA: 2/2; Code Verification: 3/2 exceeded; Discretization Error: 3/2 exceeded; Test Conditions: 2/2; Output Comparison: 2/2; QoI Relevance: 2/2; Validation Relevance: 2/2; Input Equivalency: 2/2), and 6 factors were appropriately scoped out under MRL 2 Class II device provisions with documented rationale and procedural controls. The primary QoI (NIH) shows 8.3% mean absolute error against experimental benchmark, well within the pre-specified 15% acceptance criterion. Mesh convergence is confirmed with GCI < 3.2%. Code verification demonstrates expected convergence rates via MMS. The validation evidence base is directly relevant to the CPB COU, spanning the full clinical operating envelope. All provenance chains are complete from raw experimental data through post-processed validation results. The structured evidence supports the regulatory submission claim that the model can reliably identify worst-case hemolysis operating conditions for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
