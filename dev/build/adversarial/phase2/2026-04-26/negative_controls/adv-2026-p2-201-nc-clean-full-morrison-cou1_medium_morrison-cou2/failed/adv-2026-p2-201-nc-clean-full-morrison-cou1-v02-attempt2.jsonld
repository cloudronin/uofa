      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-level2",
      "rationale": "Simulation setup reviewed by an independent analyst following a documented simulation review checklist. Boundary condition assignments, turbulence model selection (SST k-omega), and hemolysis model parameterisation independently verified. No use errors identified in review. Checklist retained as evidence.",
      "evidence": "https://uofa.net/synth/evidence/independent-simulation-review-checklist"
    },
    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-level2",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger power-law hemolysis model are justified by literature review and sensitivity analysis. Alternative turbulence models (k-epsilon, LES) tested on a subset of operating points; NIH predictions differ by < 5%. Model form uncertainty quantified via ensemble of three hemolysis model variants; 95% interval reported. Achieved level 3 reflects documented model form uncertainty quantification.",
      "evidence": "https://uofa.net/synth/evidence/model-form-sensitivity-study"
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
