  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the Nagaraja COU1 non-cannulated pedicle screw compression-bending FEA model is accepted at Medium assurance level, consistent with MRL 3 and Medium model influence and decision consequence. Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall (Test conditions, Gradation 1 vs. required Gradation 2) is documented and accepted: the COU is explicitly scoped to the single ASTM F1717 static compression-bending protocol, no extrapolation to other loading conditions is claimed, and the Medium decision consequence does not warrant the additional experimental burden of multi-condition testing at this stage. All three QoIs (stiffness, yield force, force at 40 mm displacement) satisfy both the pre-specified 10% difference bound and the E/uval < 1.96 validation metric. Provenance is complete: experimental data from N=11 constructs across two laboratories, FEA outputs from a three-code ensemble, uncertainty quantification via Monte Carlo and Richardson extrapolation, and independent analyst cross-check. The structured evidence base supports the claim that the FEA modeling framework credibly predicts compression-bending behavior of the non-cannulated construct within the stated acceptance bounds.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
