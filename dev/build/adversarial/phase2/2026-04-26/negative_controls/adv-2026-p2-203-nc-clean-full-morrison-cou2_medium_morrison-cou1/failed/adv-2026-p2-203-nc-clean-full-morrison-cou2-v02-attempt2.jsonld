  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team unanimously accepts the CFD hemolysis prediction model for the stated COU (CPB hemolysis tolerance evaluation, Class II device, MRL 5). All 13 ASME V&V 40 credibility factors have been assessed and all achievedLevels meet or exceed the requiredLevel of 5. The evidence base supporting this decision is summarized as follows: (1) Software QA and code verification establish that the solver produces correct numerical solutions to the governing equations. (2) Discretization and solver error analyses bound numerical uncertainty to < 2% of RH, which is negligible relative to model form and input uncertainties. (3) The validation program directly addresses COU conditions — identical pump geometry, matched operating envelope, clinically representative blood samples — and quantitative output comparison confirms model predictions are consistent with experimental measurements within combined uncertainty bounds at all 5 operating points. (4) A 1000-sample Monte Carlo UQ ensemble propagates all characterized input uncertainties through the model; the 99th-percentile predicted RH = 0.87 remains below the RH < 1 acceptance criterion with a margin of 13%, providing high confidence that the acceptance criterion is met across the clinical operating range. (5) Global Sobol sensitivity analysis identifies rotational speed and impeller clearance as the dominant uncertainty drivers, enabling targeted design control. (6) Independent replication of the simulation and independent review of all evidence packages confirm absence of use error and analytical bias. The totality of evidence, the completeness of the uncertainty budget, and the direct relevance of validation activities to the COU collectively support a finding that the model is fit for the intended regulatory purpose. Decision recorded by the credibility assessment board on 2026-04-19.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
