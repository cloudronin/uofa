  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis model for the FDA generic centrifugal blood pump under CPB conditions is accepted at Model Risk Level 5 based on the following structured evidence: (1) All 13 ASME V&V 40 credibility factors have been assessed and achieve the required Level 5 rigor. (2) Validation against PIV flow-field measurements and in-vitro hemolysis bench data demonstrates quantitative agreement within defined acceptance thresholds at all 5 operating points, with combined simulation and experimental uncertainty explicitly accounted for per ASME V&V 20. (3) A 500-sample Monte Carlo UQ propagation confirms that the 95th-percentile NIH remains below the regulatory acceptance threshold (RH < 1) under full input uncertainty. (4) Global Sobol sensitivity analysis identifies impeller tip clearance and rotational speed as dominant uncertainty drivers, and confirms that all other parameters contribute less than 15% of total output variance individually, supporting the adequacy of the model's input characterisation. (5) Model form uncertainty was quantified by comparison of three turbulence models and two hemolysis models; the selected model combination produces the lowest validation error and its uncertainty contribution is bounded within the overall uncertainty budget. (6) Software quality assurance, numerical code verification, and use-error controls meet the highest rigor level, providing high confidence in the correctness of simulation execution. (7) The validation activities are highly relevant to the COU, with the only deliberate departure (blood analog vs. whole blood) quantitatively bounded to < 8% NIH difference. (8) The provenance chain from raw experimental data through processed validation results to the credibility assessment is complete and traceable. On the basis of this comprehensive evidence base, the credibility assessment team unanimously concludes that the model is fit for the intended use and the regulatory submission may proceed.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
