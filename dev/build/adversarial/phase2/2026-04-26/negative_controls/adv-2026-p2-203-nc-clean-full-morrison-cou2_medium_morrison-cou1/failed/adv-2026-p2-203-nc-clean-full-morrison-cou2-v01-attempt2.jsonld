  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-level5",
      "rationale": "The CFD solver (ANSYS Fluent 2024R1) is operated under a documented software quality assurance plan conforming to FDA 21 CFR Part 11 and ISO 9001:2015. Version control, regression test suite (>2000 test cases), and change-control procedures are fully documented. All solver modules relevant to hemolysis prediction (turbulence, species transport, user-defined functions for power-law hemolysis) have been independently verified against analytical solutions and published benchmarks. Audit trail is complete and traceable to simulation outputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-level5",
      "rationale": "Numerical code verification was performed using the Method of Manufactured Solutions (MMS) for all governing equation terms: continuity, momentum, turbulence transport (k-omega SST), and the scalar hemolysis transport equation. Observed convergence rates match theoretical rates (2nd-order spatial, 1st-order temporal) within 2% across three mesh refinement levels. All unit tests and integration tests pass. Code verification report reviewed and approved by independent third party."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-level5",
      "rationale": "Systematic mesh refinement study conducted using three geometrically similar meshes (coarse: 4.2M cells, medium: 12.6M cells, fine: 37.8M cells) with refinement ratio r = 1.44. Grid Convergence Index (GCI) computed using Richardson extrapolation for all quantities of interest. GCI_fine < 1.2% for velocity magnitude and < 2.8% for NIH at all 5 operating points. Asymptotic range confirmed (GCI_medium/GCI_fine ratio within 5% of theoretical value). Time-step independence verified separately with 3 time-step levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-level5",
      "rationale": "Experimental test conditions are fully documented with traceability to NIST-traceable calibration standards. Blood analog fluid (glycerol-water mixture, 40% hematocrit equivalent viscosity) characterised at 37°C ± 0.2°C. Flow rates measured by Coriolis mass flowmeter (±0.5% FS). Rotational speed measured by optical encoder (±0.1 RPM). Pressure boundary conditions measured by calibrated transducers (±0.05 mmHg). All 5 operating points replicated in triplicate; inter-replicate coefficient of variation < 3% for NIH. Environmental conditions (temperature, humidity) logged throughout testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-level5",
      "rationale": "Quantitative output comparison performed using multiple metrics: (1) normalised root-mean-square error (NRMSE) for velocity fields < 4.1% across all PIV planes, (2) NIH prediction error < 15% at all 5 operating points, (3) RH index correctly orders all operating conditions relative to predicate device. Uncertainty intervals from UQ propagation overlap experimental confidence intervals at all points (coverage probability 94%). Validation metric computed following ASME V&V 20 framework with combined simulation and experimental uncertainty explicitly accounted for."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-level5",
      "rationale": "The primary quantity of interest (NIH and derived RH index) is directly linked to the regulatory decision criterion (RH < 1 vs. predicate device). Secondary QoIs (shear stress distribution, exposure time histograms) are mechanistically linked to the power-law hemolysis model parameters. Sensitivity analysis confirms that NIH is the dominant output driving the regulatory decision. QoI selection was reviewed by a clinical advisory panel including a perfusionist and a haematologist who confirmed clinical relevance to CPB hemolysis outcomes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-level5",
      "rationale": "Validation activities were designed to maximally reproduce COU conditions. The same pump geometry (FDA generic centrifugal pump) was used in both validation experiments and COU simulations. Operating envelope for validation (2–6 L/min, 2000–3500 RPM) fully encompasses the COU operating envelope. Blood analog fluid properties were matched to clinical CPB conditions. The only deliberate departure from COU conditions (use of blood analog rather than whole blood) is quantitatively bounded by a separate sensitivity study showing < 8% NIH difference, well within the validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-level5",
      "rationale": "Iterative convergence monitored via scaled residuals (all < 1e-6 for continuity, momentum, and turbulence equations; < 1e-8 for energy). Mass imbalance < 0.01% at all operating points. Round-off error assessed by running double-precision and extended-precision versions; differences < 0.01% in NIH. Solver settings (relaxation factors, discretization schemes, pressure-velocity coupling) documented and justified. Parallel decomposition independence verified by comparing 8-core and 64-core solutions; maximum NIH difference 0.3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-level5",
      "rationale": "Simulation execution follows a documented simulation plan reviewed by a second qualified engineer prior to execution. Boundary condition application, material property assignment, and post-processing scripts are version-controlled and peer-reviewed. An independent analyst re-ran two of the five operating points using only the documented simulation plan (blind replication); NIH results agreed within 1.8%. Checklist-based review of all simulation inputs completed and archived. Post-processing scripts validated against analytical test cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-level5",
      "rationale": "Model form uncertainty assessed through comparison of three turbulence models (k-omega SST, realizable k-epsilon, Reynolds Stress Model) and two hemolysis models (Giersiepen power-law, Zhang modified power-law). k-omega SST with Zhang model produces lowest validation error and is adopted as the primary model. Model form uncertainty contribution to total NIH uncertainty estimated at 9% (1-sigma) via model averaging with BIC-derived weights. The selected model form is justified by its superior performance across the validation dataset and its mechanistic consistency with the dominant shear-induced hemolysis mechanism in centrifugal pumps."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-level5",
      "rationale": "All 11 model input parameters are characterised with probability distributions derived from measurement data or literature meta-analysis: fluid viscosity (Normal, CV=2.1%), fluid density (Normal, CV=0.3%), hemolysis model coefficient C (LogNormal, CV=18%), hemolysis model exponents alpha and beta (Normal, CV=8% each), inlet velocity profile (measured, 5% turbulence intensity uncertainty), outlet pressure (Normal, CV=0.5%), rotational speed (Normal, CV=0.1%), pump geometry tolerances (Uniform ±50 µm per dimension, 6 dimensions). Input uncertainty propagated via 500-sample Monte Carlo. Sobol indices confirm impeller tip clearance and rotational speed as dominant inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-level5",
      "rationale": "Three physical pump specimens were manufactured to nominal drawing dimensions and measured by CMM (coordinate measuring machine) to characterise geometric variability. Dimensional deviations from nominal are within ±35 µm for all critical features. Specimen-to-specimen variability in measured NIH < 5% (coefficient of variation). All three specimens tested at all 5 operating points. Sample representativeness assessed against manufacturing process capability data (Cpk > 1.67 for all critical dimensions), confirming that the test specimens are representative of production intent."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/equivalency-level5",
      "rationale": "Equivalency between simulation input parameters and experimental conditions established through a formal parameter mapping document. Each of the 11 simulation input parameters is mapped to a corresponding measured or controlled experimental quantity with documented uncertainty. Dimensional equivalency confirmed by CMM measurements of test specimens used in validation experiments (mean deviation from CAD geometry < 20 µm). Fluid property equivalency confirmed by viscometry and densitometry of blood analog batches used in experiments. Boundary condition equivalency confirmed by in-situ measurements during each experimental run. No uncontrolled systematic differences between simulation inputs and experimental conditions were identified."
    }
