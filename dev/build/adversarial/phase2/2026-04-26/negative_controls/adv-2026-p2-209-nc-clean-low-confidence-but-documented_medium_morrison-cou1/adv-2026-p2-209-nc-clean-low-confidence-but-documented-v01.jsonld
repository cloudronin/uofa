  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis, MRL 2) is accepted with documented residual risk. All 7 assessed factors meet or exceed their required gradation levels. The six scoped-out factors are appropriately excluded per ASME V&V 40 Table 1 at MRL 2, each with documented rationale. Three validation results provide a complete provenance chain: (1) hemolysis bench comparison (confidence 0.52, ±32% PI) — low confidence is explicitly documented and honestly reported; rank-ordering of worst-case condition is preserved across all replicates, which is the primary COU decision need; (2) pressure-rise validation (confidence 0.78, ±8.5%) confirming hydraulic fidelity; (3) PIV shear comparison (confidence 0.54, ±28%) supporting flow-field structure. The wide uncertainty bounds on hemolysis prediction are acknowledged as residual risk arising from small sample size (n=3), blood analog variability, and turbulence model sensitivity. These limitations do not invalidate the decision because: (a) the COU requires identification of worst-case operating conditions, not absolute NIH prediction; (b) rank-ordering is robust across the uncertainty range; (c) the RH < 1 acceptance criterion is met with margin (RH = 0.71, lower bound of 95% PI = 0.58) even accounting for the full ±32% uncertainty. The decision team concludes that the evidence base, despite its documented limitations, is sufficient for the intended use at MRL 2. Residual risk is accepted and will be re-evaluated if device geometry changes exceed 5% tolerance or if operating conditions expand beyond the validated envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
