  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis worst-case identification, MRL 2) is accepted with documented residual uncertainties. All seven assessed credibility factors achieve their required levels: discretization error (GCI 8.3%, level 2 required and achieved), output comparison (MAE 0.11 RH, r=0.81, level 2), test conditions (level 2), QOI relevance (level 3 exceeding requirement), validation relevance (level 2), software QA (level 2), and code verification (level 2). Six factors are appropriately scoped out at MRL 2 per ASME V&V 40 Table 3 with documented rationale. Three explicit confidence limitations are honestly documented: (1) moderate-low confidence (0.62) in GCI due to non-monotonic convergence at OP3 and OP5; (2) moderate confidence (0.71) in RH validation comparison due to experimental scatter ±0.09 RH and limited n=5 operating points; (3) moderate-low confidence (0.65) in turbulence model selection. These limitations are accepted as residual risk because: (a) all predicted RH values satisfy the RH < 1 acceptance criterion including upper uncertainty bounds; (b) worst-case operating point identification is consistent across both turbulence models tested; (c) the conservative medium mesh selection and corroborating experimental trend agreement provide sufficient assurance for a Medium assurance level COU at MRL 2; (d) model influence is rated Medium (testing confirms results), reducing the consequence of residual model uncertainty. The provenance chain is complete from foundational experimental data through validation activities to this decision. No weakeners are identified.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
