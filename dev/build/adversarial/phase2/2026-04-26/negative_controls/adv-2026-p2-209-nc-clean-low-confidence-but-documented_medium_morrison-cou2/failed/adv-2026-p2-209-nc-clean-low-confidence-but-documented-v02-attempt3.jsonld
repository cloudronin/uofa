  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-mrl5-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors. Seven factors were assessed with achievedLevel meeting or exceeding requiredLevel. Six factors (numerical solver error, use error, test samples, equivalency of input parameters, and two others) were assessed at Gradation 2 where Gradation 2 was the required level. The primary concern — model-form uncertainty in the hemolysis power-law model — is explicitly documented with LOW confidence rating. The Monte Carlo uncertainty quantification (1500 samples, propagating full published uncertainty ranges for all hemolysis model parameters) demonstrates that even the 90th-percentile NIH prediction (0.00468 g/100L) remains 22% below the clinical threshold of 0.006 g/100L. The team determines that this margin is sufficient to accept the model for the stated COU given: (1) the uncertainty is bounded and fully quantified, not unknown; (2) the conservative threshold margin accounts for the wide uncertainty; (3) all validation activities were performed on the identical geometry and operating conditions as the COU with no extrapolation; (4) the PIV velocity field comparison confirms flow physics are captured adequately despite low-confidence near-blade-tip regions. Residual model-form uncertainty is accepted as documented residual risk. The decision is Accepted with the explicit condition that any change in operating conditions outside the validated 5-point envelope requires re-assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
