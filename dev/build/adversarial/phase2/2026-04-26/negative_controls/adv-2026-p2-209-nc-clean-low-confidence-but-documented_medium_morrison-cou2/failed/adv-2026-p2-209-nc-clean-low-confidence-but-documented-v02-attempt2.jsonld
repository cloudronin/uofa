  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-nc9-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team reviewed all 13 credibility factors. All achievedLevels meet or exceed requiredLevels. Evidence quality is explicitly low-to-moderate in several factors — particularly model form uncertainty (LOW confidence in power-law damage exponents), model inputs (LOW confidence in exponent distributions from sparse literature), test conditions (LOW confidence due to blood analog substitution), and test samples (LOW-MODERATE confidence due to small replicate count). These low-confidence ratings are documented honestly throughout the evidence record with full rationale and are NOT concealed or inflated. Residual risk is accepted on the following grounds: (1) Monte Carlo UQ with 5000 samples demonstrates that 99.8% of NIH predictions remain below the clinical threshold of 0.10 g/100L even under worst-case input combinations; (2) model form sensitivity study with alternative Taskin damage model yields NIH within factor of 1.8, still below threshold; (3) all mesh refinement levels produce NIH below threshold; (4) independent analyst review confirmed no use errors. The wide uncertainty bounds are a feature of honest epistemic transparency, not a deficiency in the assessment process. The decision team concludes that the structured evidence, with its documented limitations, provides sufficient credibility for the intended regulatory submission under ASME V&V 40 at MRL 5, subject to the documented residual risk mitigations.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
