  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-sqa",
      "rationale": "FEA software (Ansys Mechanical 2022 R1) operates under an FDA-recognized quality management system (ISO 13485). Software validation records, version-controlled input decks, and regression test suite (>200 benchmark cases) confirm Gradation 2 SQA. No open critical software defects identified during the assessment period."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-code-verification",
      "rationale": "Ansys Mechanical solver verified against NAFEMS benchmark suite for linear elastic and contact problems. Patch tests and manufactured-solution verification confirm element formulations used (SOLID186, CONTA174) produce convergent solutions. Independent code-to-code comparison with Abaqus 2021 for a representative pedicle screw geometry showed <0.5% difference in peak von Mises stress."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-discretization",
      "rationale": "Mesh convergence study performed on the non-cannulated 7.5 mm pedicle screw model across four refinement levels (global element size 0.8 mm, 0.5 mm, 0.3 mm, 0.2 mm). Richardson extrapolation applied to construct stiffness and peak stress QoIs. Grid Convergence Index (GCI) < 1.2% for stiffness and < 2.8% for peak stress at the selected mesh density (0.3 mm). Discretization error contribution to total validation uncertainty budget explicitly quantified and included in E/uval calculation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-solver-error",
      "rationale": "Direct sparse solver (SPARSE) employed for all linear substeps; iterative solution not used, eliminating iterative convergence error. Contact stabilization energy monitored and confirmed < 0.1% of total strain energy across all load steps. Nonlinear convergence criteria: force residual < 0.1% and displacement residual < 0.5%. No solver warnings or unconverged substeps in any of the 11-specimen simulation set."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-use-error",
      "rationale": "Simulation workflow executed under documented standard operating procedures (SOP-FEA-2022-003). Independent peer review of boundary conditions, material assignments, and load application performed by a second qualified engineer not involved in model construction. Checklist-based review recorded in the project quality record. No discrepancies identified between intended and implemented model setup."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-model-form",
      "rationale": "Linear elastic material model applied to titanium alloy (Ti-6Al-4V) implant components, justified by the pre-yield regime of ASTM F1717 stiffness QoI. Elastic-perfectly-plastic model applied for yield force prediction, with yield stress calibrated from tensile coupon data (n=5, mean 0.2% offset yield = 895 MPa). Frictional contact (μ=0.2) between screw-rod interface informed by literature and sensitivity analysis. Model form uncertainty contribution explicitly estimated via comparison with higher-fidelity nonlinear material runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-model-inputs",
      "rationale": "Material properties (E=114 GPa, ν=0.34 for Ti-6Al-4V; E=210 GPa, ν=0.30 for stainless steel test fixture) sourced from ASTM material standards and batch-specific coupon testing. Geometric inputs derived from calibrated CMM measurements of production implants (n=5 per geometry feature). Sensitivity analysis (one-at-a-time ±10% perturbation) performed on all 8 primary input parameters; construct stiffness most sensitive to rod diameter (normalized sensitivity coefficient 0.62). Probabilistic UQ (Monte Carlo, n=10,000) propagated input uncertainties to QoI distributions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-test-samples",
      "rationale": "N=11 production non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab A: n=6; Lab B: n=5). All specimens drawn from the same production lot and confirmed conformant to design drawings via incoming inspection. Sample size supports statistical characterization of experimental variability (CV < 4% for stiffness across both labs). Inter-laboratory reproducibility confirmed by equivalence testing (p > 0.05 for stiffness and yield force)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-test-conditions",
      "rationale": "Testing performed per ASTM F1717 at a single load configuration (5° offset, 35 mm vertebral body height surrogate). Required level 3 demands multiple test configurations or physiologically varied conditions; only one configuration was tested. This shortfall is acknowledged and accepted at the COU level because the COU scope is limited to the F1717 standard configuration, and the regulatory submission correspondingly limits the claim to this single test condition. Compensatory evidence: FEA sensitivity to surrogate height (±5 mm) confirmed <3% change in stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-input-equivalency",
      "rationale": "Traceability matrix established mapping each experimental test parameter (fixture geometry, applied displacement rate, boundary conditions, environmental conditions) to the corresponding FEA model input. All primary inputs confirmed equivalent within measurement uncertainty. Displacement-controlled loading in FEA matched to test machine crosshead displacement; load cell compliance correction applied to experimental data. Temperature and humidity recorded during testing (23±2°C, 50±10% RH) and confirmed within range where Ti-6Al-4V properties are invariant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-output-comparison",
      "rationale": "Quantitative output comparison performed for three QoIs: construct stiffness, yield force, and force at 40 mm displacement. Validation metric E/uval computed per ASME V&V 40 Section 5.4, incorporating experimental uncertainty (measurement system analysis, inter-lab variability), numerical uncertainty (discretization, solver), and input uncertainty (propagated via Monte Carlo). E/uval values: stiffness 0.87, yield force 1.43, force at 40 mm 1.12 — all below acceptance threshold of 1.96. Percentage differences: 4.2%, 7.1%, 5.8% — all below 10% acceptance criterion. Full load-displacement curve overlay provided as supplementary evidence confirming qualitative agreement throughout loading range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-qoi-relevance",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the QoIs specified in ASTM F1717 and directly relevant to the regulatory decision question (does the implant meet mechanical performance requirements?). Clinical relevance established by literature linking construct stiffness to fusion outcomes and yield force to in vivo failure risk. QoI selection reviewed and approved by the clinical and regulatory team prior to study initiation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-activity-relevance",
      "rationale": "The validation activity directly replicates the COU: the same FEA model framework, material models, boundary conditions, and QoIs used in the regulatory submission are validated against ASTM F1717 bench tests performed on production-representative hardware. The validation domain (non-cannulated 7.5 mm screw, F1717 configuration) is identical to the COU domain. No extrapolation beyond the validated envelope is claimed in the regulatory submission."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the non-cannulated pedicle screw FEA model (COU1) is accepted at Medium assurance level and MRL 3. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions at achieved level 2 against required level 3 — is accepted because the COU scope is explicitly bounded to the single ASTM F1717 configuration tested, and the regulatory claim is correspondingly limited. All three primary QoIs (construct stiffness, yield force, force at 40 mm displacement) satisfy both the quantitative acceptance criterion (E/uval < 1.96) and the percentage-difference criterion (<10%). Uncertainty quantification is comprehensive, incorporating experimental, numerical, and input uncertainty sources with full traceability. The provenance chain from raw experimental data through validation metric computation is complete and documented. Software quality assurance, code verification, and mesh convergence evidence are commensurate with MRL 3 requirements. The decision is supported by the structured evidence package and is consistent with FDA guidance on computational modeling for Class II orthopedic devices.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
