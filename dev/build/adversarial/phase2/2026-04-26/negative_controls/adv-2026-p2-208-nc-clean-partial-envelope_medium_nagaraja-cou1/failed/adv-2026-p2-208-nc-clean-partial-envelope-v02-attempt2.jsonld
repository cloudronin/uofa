  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/sqa-level2",
      "rationale": "Ansys Mechanical 2023 R1 is a commercially validated FEA solver with documented V&V procedures per ISO 9001 and ASME V&V 10. FDA in-house scripts are version-controlled in Git with peer review. DePuy Synthes model built under design-control procedures. All three codes pass benchmark patch tests and published NAFEMS benchmarks. Achieved Gradation 3: documented QMS, version control, and independent benchmark verification across all three software environments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/code-verification-level2",
      "rationale": "Numerical code verification performed using NAFEMS benchmark LE1 (plane stress), LE10 (Lamé problem), and a cantilever beam analytical solution. All three FEA environments reproduce analytical solutions within 0.5% for linear elastic problems. Nonlinear material benchmark (Ramberg-Osgood) verified against published closed-form solutions within 1.2%. Gradation 3 achieved: formal benchmark suite with documented pass/fail criteria and traceability to analytical solutions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/discretization-level3",
      "rationale": "Mesh convergence study performed on the pedicle screw shank and thread root regions using three systematically refined meshes (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements). Richardson extrapolation applied; Grid Convergence Index (GCI) for peak von Mises stress at thread root = 1.8% (fine-to-medium refinement ratio). Production mesh uses medium density with GCI < 2% confirming discretization error is controlled. Gradation 3: formal GCI analysis with documented convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/solver-error-level2",
      "rationale": "Nonlinear static analysis uses Newton-Raphson iteration with force residual convergence tolerance 1e-4 and displacement convergence tolerance 1e-5. Convergence confirmed for all 11 load cases; no divergence or unconverged increments recorded. Energy balance checked at each converged increment; energy error < 0.1%. Gradation 2: documented convergence criteria and confirmed convergence for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/use-error-level2",
      "rationale": "Independent analyst review conducted by a second FDA engineer not involved in model construction. Review checklist covers boundary condition application, material assignment, contact definition, and load application. All three FEA environments reviewed independently. Discrepancies found in initial contact stiffness settings were resolved prior to production runs. Gradation 3: independent review with documented checklist, discrepancy log, and resolution records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-form-level3",
      "rationale": "Continuum FEA with isotropic linear elastic material for Ti-6Al-4V below yield (E=114 GPa, nu=0.33) and bilinear isotropic hardening above yield (tangent modulus 1.14 GPa per ASTM F136 coupon data). Contact modeled with augmented Lagrangian formulation at screw-block interface. Geometric nonlinearity (large deformation) enabled for post-yield regime. Model form assumptions validated against independent coupon test data. Gradation 3: physics-based model with documented justification for all constitutive and contact assumptions, cross-validated against independent material characterization dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-inputs-level3",
      "rationale": "Material properties sourced from lot-specific tensile coupon testing (N=5 coupons per material lot, two lots) per ASTM E8. Geometric inputs derived from CMM measurements of production screws (N=3 screws measured). Polyethylene block modulus measured by compression testing (N=6 blocks). All input parameters documented with mean, standard deviation, and source traceability. Sensitivity analysis identifies screw modulus and yield strength as dominant inputs. Gradation 3: measured inputs with statistical characterization and documented sensitivity analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-samples-level3",
      "rationale": "N=11 production-representative non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab1 N=6, Lab2 N=5). Screws drawn from the same production lot as the FEA geometric model. Polyethylene blocks from the same material lot as model inputs. Sample size justification based on statistical power analysis targeting 80% power to detect 10% QoI difference at alpha=0.05. Gradation 3: production-representative samples with documented traceability, two-laboratory coverage, and statistical sample size justification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-conditions-level2",
      "rationale": "All experiments conducted under a single standardized ASTM F1717 test condition (quasi-static, 5 mm/min, ambient temperature). Operating envelope boundary points sampled but all under the same test protocol. Rate-dependent effects and temperature excursion scenarios not experimentally evaluated. This factor is below the required Gradation 3 level; the shortfall is acknowledged and accepted given that the intended COU is limited to quasi-static ASTM F1717 conditions as declared in the operating envelope. The bounded operating envelope explicitly excludes dynamic loading and temperature extremes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/equivalency-level3",
      "rationale": "FEA model inputs mapped directly to experimentally measured values: screw geometry from CMM of tested specimens, material properties from same lot coupons, polyethylene block modulus from same lot compression tests. Boundary conditions replicate ASTM F1717 fixture geometry including offset distance and block embedment depth. Correspondence table documents each FEA input parameter against its experimental counterpart with traceability to measurement records. Gradation 3: full parameter correspondence table with documented traceability and no unresolved discrepancies."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/output-comparison-level3",
      "rationale": "Quantitative comparison using two pre-specified metrics: (1) absolute percentage difference in QoI < 10%, and (2) normalized validation metric E/uval < 1.96 per ASME V&V 20 methodology. Both metrics satisfied for all five QoI-laboratory combinations (stiffness Lab1, yield force Lab1, force-at-40mm Lab1, stiffness Lab2, yield force Lab2). Graphical comparison of load-displacement curves provided. No post-hoc adjustment of acceptance criteria. Gradation 3: pre-specified quantitative acceptance criteria applied consistently with no post-hoc modifications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/qoi-relevance-level3",
      "rationale": "Three QoIs selected — construct stiffness, yield force, and force at 40 mm displacement — directly correspond to the regulatory decision quantities used to characterize pedicle screw construct mechanical performance under FDA guidance for 510(k) submissions. Stiffness characterizes elastic behavior; yield force characterizes onset of permanent deformation; force at 40 mm characterizes post-yield load-carrying capacity relevant to clinical failure mode. All three are directly extractable from both FEA output and experimental load-displacement records. Gradation 3: QoIs directly linked to regulatory decision quantities with documented clinical relevance justification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/validation-relevance-level3",
      "rationale": "Validation activities directly replicate the COU: same non-cannulated 7.5 mm screw geometry, same Ti-6Al-4V material, same ASTM F1717 test configuration, same polyethylene block surrogate. Validation experiments sample the declared operating envelope including boundary points. The only gap is absence of rate-dependent and temperature excursion testing, which is accepted because the operating envelope explicitly excludes those conditions. Gradation 3: validation activities directly replicate COU conditions with documented mapping between validation scenario and COU, and explicit acknowledgment of the single gap (test conditions factor) and its mitigation via operating envelope restriction."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/dr-cou1-noncannulated-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated 7.5 mm pedicle screw, ASTM F1717 compression-bending) is accepted at Medium assurance level. All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed their required gradation levels. The single shortfall — Test conditions (achieved Gradation 2 against required Gradation 3) — is accepted because the declared operating envelope explicitly restricts applicability to quasi-static ASTM F1717 conditions, and the validation experiments were conducted entirely within this envelope including sampling of boundary points. The operating envelope is bounded and documented with concrete numerical limits (axial load 0–2500 N, bending moment 0–15 N·m, displacement 0–40 mm, crosshead speed 5 mm/min, ambient temperature 23±2°C). The applicability constraint further restricts the model to non-cannulated 7.5 mm Ti-6Al-4V screws tested per ASTM F1717, preventing inappropriate extrapolation. All five ValidationResult comparisons pass the pre-specified acceptance criteria (QoI difference < 10%, E/uval < 1.96). Uncertainty quantification is complete for all validation results with Monte Carlo propagation and documented coverage factors. The provenance chain is complete: experimental data traced to production-representative specimens with lot traceability, FEA inputs traced to measured material and geometric characterization, and model runs traceable to documented software environments. The model risk level 3 and Medium assurance level are consistent with the device classification (Class II) and decision consequence (Medium). The decision to accept is made with full awareness of the Test conditions shortfall, which is appropriately bounded by the operating envelope restriction and does not undermine the validity of the credibility assessment for the declared COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
