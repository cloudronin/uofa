  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl2-acceptance",
      "rationale": "The CFD solver (ANSYS Fluent 2023R2) is a commercially validated software package with documented version control, release notes, and regression test suite. Internal SQA log confirms solver version locked at 2023R2 for all simulation runs. Achieved Gradation 2 through documented version control and formal test suite; required level is Gradation 1 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl2-acceptance",
      "rationale": "Numerical code verification was performed via the Method of Manufactured Solutions (MMS) on a simplified rotating channel flow representative of the pump impeller passage. Observed convergence rates matched theoretical second-order accuracy for the finite-volume discretization. Benchmark results archived in activity record morrison-code-verification-2024."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl2-acceptance",
      "rationale": "Grid convergence index (GCI) study conducted across coarse (2.1M cells), medium (5.4M cells), and fine (13.8M cells) meshes. GCI for the hemolysis index QoI was 1.8% on the fine mesh, below the 5% threshold. Richardson extrapolation confirmed asymptotic convergence. All results documented in validation result morrison-mesh-convergence-result."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl2-acceptance",
      "rationale": "In-vitro experiments were conducted at five flow-speed operating points (2.0–6.0 L/min, 2000–3500 RPM) matching the CPB clinical range. Blood analogue fluid (glycerol-water, 36% v/v) used per ASTM F1841 protocol. Temperature maintained at 37±0.5°C. All test conditions documented in experimental protocol morrison-experimental-protocol-2024 and traceable to dataset morrison-experimental-hemolysis-dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl2-acceptance",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against experimental measurements at all five operating points. Mean absolute error was 8.2% with maximum deviation of 14.1% at the highest flow-speed combination. Uncertainty bands from UQ study (morrison-hemolysis-uq-report) overlap experimental error bars at all points. Quantitative agreement metrics documented in validation result morrison-hemolysis-bench-comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl2-acceptance",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH, g/100L), which directly maps to the regulatory acceptance criterion of relative hemolysis index RH < 1 relative to the predicate device. Secondary QoIs include shear stress distribution and scalar stress exposure time, both of which feed the Giersiepen-Wurzinger power-law hemolysis model. Traceability from COU decision criterion to modeled QoI is documented in the claims structure."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl2-acceptance",
      "rationale": "Validation experiments used the FDA generic centrifugal blood pump geometry — the same geometry as the COU device — operated across the identical five flow-speed combinations specified in the COU. Blood analogue fluid properties were matched to physiological blood viscosity at 37°C. The validation domain therefore encompasses the full COU operating envelope with no extrapolation required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl2-acceptance",
      "rationale": "Iterative convergence was monitored via residual norms (continuity < 1e-5, momentum < 1e-5, turbulence quantities < 1e-4) and force/torque monitor stabilization over the final 500 iterations. Double-precision arithmetic used throughout. Round-off error estimated at machine epsilon level (~1e-15), negligible relative to discretization error. Solver settings and convergence logs archived in activity morrison-solver-convergence-audit-2024."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl2-acceptance",
      "rationale": "Simulation setup was performed by a licensed CFD engineer with 8 years of cardiovascular device experience. An independent peer review of boundary conditions, material properties, and turbulence model selection was conducted by a second qualified analyst. Setup checklist and review sign-off documented in morrison-use-error-review-2024. No discrepancies were identified during the independent review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl2-acceptance",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for swirling confined flows in rotodynamic pumps, supported by literature benchmarks on the FDA pump (Hariharan et al. 2011, Stewart et al. 2012). The Giersiepen-Wurzinger power-law hemolysis model is the standard for comparative device assessment per FDA guidance. Model form uncertainty quantified in morrison-hemolysis-uq-report via comparison of three turbulence model variants."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl2-acceptance",
      "rationale": "All model inputs — including pump geometry (CAD files traceable to FDA benchmark geometry), fluid properties (density 1056 kg/m³, dynamic viscosity 3.5 mPa·s at 37°C), boundary conditions (inlet flow rate, outlet pressure, rotational speed), and hemolysis model coefficients — are documented with sources and uncertainty estimates in dataset morrison-cpb-operating-conditions. Sensitivity analysis confirmed hemolysis prediction is most sensitive to rotational speed (±2%) and inlet flow rate (±3.5%)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-na-rationale",
      "rationale": "This factor addresses variability in biological test samples (e.g., donor-to-donor blood variability in hemolysis susceptibility). For MRL 2 comparative assessment using a blood analogue fluid per ASTM F1841, biological sample variability is not applicable: the validation protocol uses a fully characterized synthetic fluid with defined rheological properties rather than donor blood. Sample-to-sample variability is therefore not a source of uncertainty in this assessment and this factor is scoped out of the MRL 2 credibility evaluation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/equivalency-input-params-na-rationale",
      "rationale": "This factor assesses whether model input parameters used in the simulation are equivalent to those in the physical test (relevant when simulation and experiment use different parameter representations). In this COU, the validation experiments and simulations share identical geometric definitions (same CAD source), identical operating point specifications (flow rate and rotational speed set points), and identical fluid property characterizations. No parameter transformation or surrogate mapping is required between the experimental and computational domains; therefore this factor is not applicable at MRL 2 for this assessment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for Morrison COU1 is accepted at Model Risk Level 2 based on the following structured evidence summary. Eleven of thirteen credibility factors were assessed; two factors (Test samples, Equivalency of input parameters) were marked not-applicable with documented rationale appropriate to the MRL 2 comparative assessment context using standardized blood analogue fluid. All eleven assessed factors met or exceeded their required gradation levels: Software quality assurance (achieved 2, required 1), Numerical code verification (achieved 2, required 1), Discretization error (achieved 3, required 2 — GCI 1.8% on fine mesh), Test conditions (achieved 2, required 2 — five COU-matched operating points), Output comparison (achieved 3, required 2 — mean error 8.2%, all uncertainty bands overlapping), Relevance of QoI (achieved 2, required 2), Relevance of validation activities (achieved 2, required 2 — full COU envelope covered), Numerical solver error (achieved 2, required 1), Use error (achieved 2, required 1 — independent peer review completed), Model form (achieved 2, required 2 — turbulence model selection justified by literature), and Model inputs (achieved 2, required 2 — sensitivity analysis documented). The validation evidence is directly traceable through three ValidationResult records (hemolysis bench comparison, pressure-flow curve, mesh convergence), each with quantified uncertainty and provenance links to experimental datasets. The two not-applicable factors carry rationales grounded in the specific MRL 2 protocol design (ASTM F1841 blood analogue, no parameter transformation between experiment and simulation). No weakeners were identified. The CFD model is therefore judged credible for its intended use: identifying worst-case hemolysis operating conditions for the Class II CPB device with the RH < 1 acceptance criterion.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
