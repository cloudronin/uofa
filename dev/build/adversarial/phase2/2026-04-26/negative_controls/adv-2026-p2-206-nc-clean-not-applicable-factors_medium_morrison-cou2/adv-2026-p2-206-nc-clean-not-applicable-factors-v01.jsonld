  "signature": "ed25519:b4e9d3f2a1c0b7e6d5c4b3a2f1e0d9c8b7a6f5e4d3c2b1a0f9e8d7c6b5a4f3e2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5",
      "rationale": "The CFD solver (ANSYS Fluent 2023R2) is subject to a documented software quality assurance plan including version control, regression testing suite, and ISO 9001-certified release process. SQA level 3 achieved through third-party audit of solver verification suite and documented change management records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5",
      "rationale": "Numerical code verification was performed using the method of manufactured solutions (MMS) for the Navier-Stokes solver and the hemolysis transport equation. Observed order of convergence matched theoretical order for all relevant equation sets. Exceeds required level 3 by demonstrating formal convergence analysis in all three spatial dimensions plus temporal discretization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5",
      "rationale": "Grid convergence index (GCI) study performed on three systematically refined meshes (4.2M, 12.1M, and 31.8M cells) following ASME V&V 20 procedures. GCI for hemolysis index QoI is 3.8% on the fine mesh, meeting the required threshold. Richardson extrapolation applied to estimate asymptotic solution. Discretization error budget documented in simulation report SR-2025-VAD-02."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5",
      "rationale": "Experimental test conditions for the FDA benchmark pump are documented in FDA 2012 critical path study and replicated in the in-house validation campaign. Temperature, hematocrit, viscosity, and inlet velocity profiles are matched to within stated tolerances. Test conditions span the 5 operating points required by the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5",
      "rationale": "Quantitative output comparison performed using normalized index of agreement (NIA) and root-mean-square error (RMSE) for hemolysis index across all 5 operating points. NIA = 0.91 (threshold 0.85). RMSE for hemolysis index = 0.012 (threshold 0.02). Comparison methodology follows ASME V&V 20-2009 Section 5. Uncertainty intervals from Monte Carlo UQ overlap experimental uncertainty bands at all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) in mg/100 mL — is directly used in the regulatory decision criterion. Secondary QoIs include wall shear stress distribution and scalar stress exposure time, which are mechanistically linked to the hemolysis model. All QoIs are clinically and physically justified with direct traceability to the COU decision threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump geometry, which is the same device class and operating regime as the COU. Flow rates and rotational speeds in validation experiments span the COU operating envelope. Fluid properties (bovine blood, 37°C, 40% hematocrit) match COU conditions. Validation relevance score assessed at level 4 per the Morrison framework relevance rubric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5",
      "rationale": "Iterative convergence monitored via residual norms (all below 1e-6) and mass imbalance (below 0.01%). Round-off error assessed as negligible for double-precision arithmetic at the mesh resolution used. Solver error contribution to overall uncertainty budget is documented as less than 0.5% of the hemolysis QoI value."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5",
      "rationale": "Use error controls include documented simulation workflow with step-by-step setup checklists, independent peer review of boundary condition assignments, and automated pre-processing scripts with input validation. Two independent analysts reproduced key hemolysis results within 1.2% relative difference, confirming absence of operator-induced error at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5",
      "rationale": "Model form uncertainty assessed for turbulence closure (SST k-omega vs. RSM comparison) and hemolysis constitutive model (Giersiepen-Wurzinger vs. Bludszuweit power-law). Sensitivity of NIH predictions to model form choices quantified across all 5 operating points. SST k-omega with Giersiepen-Wurzinger model selected based on best agreement with experimental data; model form uncertainty contribution incorporated into Monte Carlo UQ framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5",
      "rationale": "Monte Carlo uncertainty quantification performed on 12 input parameters including blood viscosity, hematocrit, hemolysis model coefficients (C, alpha, beta), inlet velocity profile shape, and wall roughness. Latin hypercube sampling with 2000 samples. Input probability distributions sourced from published literature and in-house rheometry data. Sensitivity indices (Sobol first-order and total-order) computed for all inputs with respect to NIH QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-applicable",
      "rationale": "Test samples factor is not applicable to this assessment. The validation dataset used is the publicly available FDA benchmark dataset derived from a generic pump geometry, not a patient-specific or lot-specific physical sample. No physical test article sampling variability is relevant to this computational benchmark case; sample-to-sample manufacturing variation is outside the scope of the FDA generic pump COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-applicable",
      "rationale": "Equivalency of input parameters factor is not applicable to this assessment. This factor addresses the mapping between simulation inputs and physical test article parameters in cases where multiple independent test configurations are compared. In this COU, a single canonical FDA pump geometry and a single set of operating conditions are used; there is no multi-site or multi-configuration equivalency mapping required. The factor was reviewed and formally scoped out by the credibility assessment team on 2025-11-14."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been addressed. Eleven factors were fully assessed with achieved credibility levels meeting or exceeding required levels for Model Risk Level 5: software quality assurance (3/3), numerical code verification (4/3), discretization error (4/4), test conditions (3/3), output comparison (4/4), relevance of QoI (4/4), relevance of validation activities (4/4), numerical solver error (3/3), use error (3/3), model form (4/4), and model inputs (4/4). Two factors — Test samples and Equivalency of input parameters — are marked not-applicable with documented rationale: Test samples is inapplicable because the FDA generic benchmark pump is not a physical production article subject to sampling variability; Equivalency of input parameters is inapplicable because the assessment involves a single canonical geometry and operating envelope without multi-configuration equivalency mapping. The Monte Carlo uncertainty quantification demonstrates that prediction intervals for NIH at all 5 operating points remain below the clinical hemolysis threshold with 95% confidence. Quantitative output comparison (NIA = 0.91, RMSE = 0.012) satisfies acceptance criteria. The provenance chain from raw experimental data through validation activities to credibility conclusions is complete and traceable. The credibility assessment team unanimously concludes the evidence package is sufficient to support regulatory submission for the Class III VAD device under the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
