  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw under ASTM F1717 compression-bending is accepted as credible for the stated COU at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation levels. The single shortfall — Test conditions achieving Gradation 1 against a required Gradation 2 — is accepted on the basis that: (1) the COU is explicitly scoped to quasi-static ASTM F1717 conditions, making multi-condition testing unnecessary for the stated decision; (2) the decision consequence is Medium (revision surgery risk, not mortality); and (3) the model influence is Medium (physical testing serves as confirmatory evidence). Quantitative validation metrics (E/uval) for all three QoIs are well within the pre-established acceptance bounds: stiffness E/uval=0.84, yield force E/uval=1.12, force at 40 mm E/uval=0.97, all below the 1.96 threshold. Percentage differences for all QoIs are below the 10% acceptance bound. The provenance chain from raw experimental data through uncertainty quantification to the validation metric is complete and auditable. The credibility evidence is sufficient to support the regulatory submission decision for this non-cannulated pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
