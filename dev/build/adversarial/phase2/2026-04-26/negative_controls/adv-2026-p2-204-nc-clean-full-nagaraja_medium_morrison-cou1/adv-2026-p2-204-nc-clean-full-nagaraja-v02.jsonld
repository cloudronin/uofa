  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-ortho-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been formally assessed and all achieved levels meet or exceed required levels for MRL 3. The FE model of the total hip stem demonstrates: (1) quantitative strain prediction accuracy within 4.2% MAPE against ISO 7206-4 bench data across 12 gauge locations with no systematic bias; (2) fatigue life predictions within a factor of 1.3 of experimental median at 90% confidence; (3) full-field DIC correlation r = 0.96 in cadaveric specimens; (4) discretization error bounded at 1.8% GCI; (5) model inputs fully traceable to certified primary sources with Monte Carlo uncertainty propagation. The 95th-percentile peak stress from the uncertainty analysis yields a fatigue safety factor SF = 1.83, exceeding the acceptance criterion of SF ≥ 1.5. Validation activities span the complete validation hierarchy from material coupon to cadaveric system level, with documented equivalency to the COU. Independent peer review confirmed no use errors. The structured evidence base, complete provenance chain, and quantified uncertainty budget collectively support the conclusion that the FE model is credible for its intended use: identifying worst-case fatigue-critical stress conditions for regulatory submission of a Class II total hip stem under MRL 3 requirements. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
