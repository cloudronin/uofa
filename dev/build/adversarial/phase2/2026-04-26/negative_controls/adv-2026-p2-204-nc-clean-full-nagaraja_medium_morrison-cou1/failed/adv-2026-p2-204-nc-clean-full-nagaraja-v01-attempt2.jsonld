  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-orthopedic-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed at MRL 3 for this Class II total knee arthroplasty FEA model. Achieved levels meet or exceed required levels across all factors. Quantitative validation demonstrates peak stress prediction error of 4.2% (threshold 10%) and micromotion error of 11.3% (threshold 15%), both within acceptance criteria. Discretization error is bounded at GCI=1.8%. Monte Carlo uncertainty propagation confirms that 95th-percentile stress predictions remain below CoCr yield strength across the full input uncertainty space. Validation activities are directly relevant to the COU loading envelope and patient population. Software quality assurance, code verification, and use error controls meet MRL 3 requirements. The provenance chain from raw experimental data through validation results to this assessment is complete and traceable. The credibility evidence is sufficient to support the regulatory submission claim that the FEA model reliably predicts worst-case tibial tray stress and bone-implant micromotion for the stated COU. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
