  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-nc8-clean-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-cdrh",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed. Achieved levels meet or exceed required levels for Model Risk Level 3 across all factors. The ContextOfUse explicitly declares both an applicability constraint (hematocrit 35–45%, speed 2000–5000 RPM, flow rate 3–8 L/min) and a bounded operating envelope with five operating points. Validation evidence directly covers three of five operating points; the remaining two are interpolated within the validated envelope with expanded Monte Carlo uncertainty bounds (95% CI ±15–20%). Sparse validation coverage is honestly acknowledged and does not invalidate the assessment because interpolated points remain within the bounded envelope and uncertainty quantification accounts for coverage gaps. Hemolysis index predictions at all five operating points, including expanded uncertainty bounds, remain below the clinical hemolysis threshold of 0.01 NIH. The provenance chain is complete from raw experimental data through validation results to this decision record. The CFD model is accepted for predicting absolute hemolysis levels within the declared operating envelope for this Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
