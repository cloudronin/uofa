  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-cfd",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed with achievedLevel >= requiredLevel. The operating envelope is explicitly bounded (flow rate 2–8 L/min, speed 2000–4000 RPM, inlet pressure 5–20 mmHg, outlet pressure 60–120 mmHg, hematocrit 33–45%) and applicability constraints are documented, including honest acknowledgment of sparse validation coverage (5 of 25 envelope grid points). Monte Carlo UQ (500–1000 samples) propagates input uncertainty, discretization error, model form uncertainty, and sparse-coverage interpolation uncertainty into a combined NIH prediction interval of factor [0.7, 1.9] at 95% confidence. All bench test comparisons fall within this interval. PIV flow field agreement is within 8% mean velocity error. No systematic biases detected. The decision to Accept is grounded in: (1) demonstrated grid independence (GCI < 3.2%), (2) validated hemolysis model within declared shear exposure range, (3) complete SQA and use-error controls, (4) transparent UQ budget that accounts for sparse coverage gaps, and (5) all credibility factor requirements met or exceeded. The bounded applicability constraint ensures the model is not applied outside its validated domain. Decision is consistent with ASME V&V 40-2018 requirements for the declared model risk level and decision consequence.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
