  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-vv40-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, Class III, MRL 5) is accepted on the basis of the following evidence chain: (1) All 13 ASME V&V 40 credibility factors have been assessed and all achieved levels meet or exceed the required levels for MRL 5. (2) The primary QoI (NIH in g/100L) is directly and quantitatively validated against n=6 biological replicates at all 5 COU2 operating points, with MAE of 11.7% and u-pooled metric E/u_val < 1.0 at every point. (3) Monte Carlo uncertainty quantification (n=10,000 LHS samples) propagating 8 uncertain input parameters through a validated GP surrogate demonstrates that the 95% confidence interval on NIH at the worst-case operating point ([0.014, 0.023] g/100L) is entirely below the clinical threshold of 0.1 g/100L, with a safety margin exceeding 4-fold. (4) Global sensitivity analysis (Sobol indices) confirms the uncertainty budget is dominated by physically interpretable parameters (rotational speed, power-law coefficient C) and that no unidentified dominant uncertainty sources exist. (5) Code verification via MMS confirms second-order spatial accuracy; discretization GCI < 1.4%; iterative convergence to < 1e-8 residuals. (6) Validation activities are fully relevant to the COU: identical geometry, fluid, and operating envelope with no extrapolation required. (7) Independent reproducibility check confirmed simulation results are robust to analyst-to-analyst variability. (8) Software quality assurance meets ISO 9001 and 21 CFR Part 820 requirements with third-party audit clearance. The totality of evidence supports a finding that the CFD model is credible for predicting absolute hemolysis levels in this Class III VAD device at MRL 5, and the predicted hemolysis levels are acceptably below the clinical threshold with quantified confidence.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
