    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/equivalency-input-params-na-justification",
      "rationale": "The 'Equivalency of input parameters' factor is designated not-applicable for this COU after careful deliberation. This factor is intended to assess whether input parameters used in the validation activity are equivalent to those in the COU — a distinction that is meaningful when the validation and COU involve different hardware configurations, patient populations, or operating regimes. In COU2, the validation experiments and the COU use the identical FDA generic centrifugal pump geometry, the identical 5 operating points (flow rate and rotational speed combinations), and fluid properties matched to within 3% of physiological values. Because the validation domain and the COU domain are intentionally co-designed to be geometrically and operationally identical, there is no parameter equivalency gap to assess: the validation inputs ARE the COU inputs. Applying this factor would require constructing a comparison between identical parameter sets, which yields no discriminating information and risks superficial compliance documentation. This determination was reviewed by the independent credibility assessment team and concurred with by the regulatory affairs lead. The not-applicable designation is considered borderline: if future design modifications introduce any geometric or operating-condition divergence between validation and COU, this factor must be re-opened and assessed at the appropriate gradation level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis prediction, Class III, MRL 5) is accepted based on the following structured evidence: (1) All 12 assessed credibility factors achieve levels at or above their required levels, with no factor gaps remaining. (2) The single not-applicable factor (Equivalency of input parameters) carries a detailed, peer-reviewed rationale documenting that the validation and COU operating domains are intentionally identical, rendering the factor non-discriminating. The not-applicable designation was reviewed and concurred with by an independent assessor. (3) Validation results demonstrate NIH predictions within 15% of in vitro measurements across all 5 operating points, with E/Uval < 1.0 confirming predictions are within combined uncertainty bounds. (4) Monte Carlo uncertainty quantification (N=2000) propagates full input uncertainty to NIH predictions; 95% prediction intervals are reported and overlap measured uncertainty bands. (5) Mesh convergence (GCI < 2.1%) and code verification (MMS, observed order matches theoretical) confirm numerical credibility. (6) Provenance is complete: all validation results link to experimental datasets, generating activities, and uncertainty quantification records. The evidence collectively supports the claim that the CFD model is sufficiently credible to predict absolute hemolysis levels for a Class III VAD device at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
