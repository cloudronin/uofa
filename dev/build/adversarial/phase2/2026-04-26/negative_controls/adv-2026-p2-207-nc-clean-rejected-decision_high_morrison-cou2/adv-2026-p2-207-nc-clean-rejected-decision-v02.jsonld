  "signature": "ed25519:b7e3a1d9c5f2b8e4a0d6c3f9b5e2a8d4c1f7b3e9a5d2c8f4b0e6a3d9c5f1b7e4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-requirements",
      "rationale": "Software quality assurance activities documented for the CFD solver include version control, regression testing, and issue tracking. However, formal V&V traceability matrix linking solver test cases to hemolysis-relevant flow regimes is incomplete. Unit test coverage for the power-law hemolysis sub-model is 62%, below the MRL-5 requirement of systematic coverage. Achieved Gradation 3 (documented QA process with partial coverage) versus required Gradation 4 (full traceability and coverage for safety-critical sub-models)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5-requirements",
      "rationale": "Order-of-accuracy verification performed using method of manufactured solutions (MMS) for the Navier-Stokes solver, confirming second-order spatial accuracy on structured grids. However, MMS verification has not been extended to the hemolysis transport scalar equation or the non-Newtonian viscosity model active in VAD operating ranges. These unverified sub-models are directly load-bearing for the hemolysis QoI. Achieved Gradation 3 versus required Gradation 4 for complete sub-model verification coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5-requirements",
      "rationale": "Richardson extrapolation conducted across three mesh levels. Fine-mesh GCI for volume-averaged shear stress is 12.3%, and local GCI in impeller tip clearance regions reaches 31%. MRL-5 requires GCI below 5% for primary hemolysis QoI. Oscillatory convergence in impeller passage prevents reliable extrapolation at those locations. Temporal discretization error estimated at 4.8% per cycle for unsteady rotor-stator interaction. Achieved Gradation 2 (error estimated but exceeds threshold) versus required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5-requirements",
      "rationale": "Experimental validation data collected under controlled laboratory conditions using porcine blood at 37°C with hematocrit 35±2%. Operating conditions span 3 of the 5 required flow-speed combinations; two high-flow VAD operating points (5 L/min at 3600 RPM and 6 L/min at 4000 RPM) lack matched experimental data. Temperature control uncertainty ±0.5°C is documented. Achieved Gradation 3 (partial operating condition coverage with documented protocols) versus required Gradation 4 (full coverage of all COU operating points)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5-requirements",
      "rationale": "Quantitative validation metric computed as normalized root-mean-square error (NRMSE) across 3 matched operating points: NRMSE = 38.4%. Systematic over-prediction at high-shear conditions (bias +29% at 3000 RPM, 4 L/min). Area validation metric (AVM) per ASME V&V 20 computed as 0.41, indicating model predictions outside 95% confidence interval of experimental data at majority of comparison points. Achieved Gradation 2 (quantitative comparison performed but substantial systematic bias present) versus required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5-requirements",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH) derived from volume-averaged scalar transport. NIH is a recognized surrogate for clinical hemolysis but is not a direct measure of plasma-free hemoglobin in patient circulation. The power-law hemolysis model (Giersiepen-Wurzinger coefficients) was calibrated on steady Couette flow and has known limitations for pulsatile VAD flow with complex recirculation. Validation data uses NIH as output but clinical threshold is expressed in mg/dL pfHb, requiring an additional conversion with its own uncertainty. Achieved Gradation 2 versus required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5-requirements",
      "rationale": "Validation activities conducted on the FDA generic centrifugal pump geometry, which is the same geometry as the COU device. Blood analog fluid (porcine blood) is appropriate for hemolysis studies. However, validation pump was operated at steady-state rotational speed, whereas clinical VAD use involves speed modulation algorithms producing transient flow excursions. Rotor-stator interaction effects under speed ramp conditions are not captured in validation dataset. Achieved Gradation 3 (same geometry, appropriate fluid, but missing transient operating regime) versus required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5-requirements",
      "rationale": "Numerical solver error assessment was scoped to iterative convergence monitoring (residual drop to 1e-5) and mass conservation checks (imbalance <0.01%). Round-off error analysis and floating-point arithmetic verification for the hemolysis scalar transport equation were not performed. At MRL 5, a formal solver error budget is required; this has not been completed. Factor recorded as not-assessed due to absence of the required formal error budget documentation, representing an epistemic gap flagged in the assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5-requirements",
      "rationale": "Use error assessment requires documentation of analyst qualification, simulation setup review procedures, and independent verification of boundary condition application. While analysts hold relevant CFD credentials, no formal independent review of the hemolysis model setup was conducted. The boundary condition sensitivity study identified that inlet velocity profile assumption (uniform vs. developed) changes NIH by 18%, but this was not captured in a formal use error register. Factor recorded as not-assessed; represents an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5-requirements",
      "rationale": "Model form assessment for the turbulence closure (SST k-omega) and hemolysis constitutive model (power-law) requires comparison of multiple candidate model forms and quantification of model-form uncertainty contribution to the hemolysis QoI. No alternative turbulence models were evaluated; the SST k-omega selection was based on prior pump literature rather than a systematic model-form study for this geometry and operating range. Sobol analysis attributes 61% of NIH output variance to hemolysis model exponent, indicating model-form uncertainty is the dominant source. Factor recorded as not-assessed due to absence of model-form uncertainty quantification; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5-requirements",
      "rationale": "Model input characterization requires documented uncertainty distributions for all influential inputs propagated through the simulation. Monte Carlo UQ was performed for inlet boundary conditions, blood viscosity, and hemolysis model coefficients. However, geometric tolerance uncertainty (impeller tip clearance manufacturing variation ±0.05 mm) and surface roughness uncertainty were not included in the UQ propagation despite sensitivity analysis indicating tip clearance affects NIH by approximately 15%. Incomplete input uncertainty characterization prevents full MRL-5 compliance; factor recorded as not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5-requirements",
      "rationale": "Test sample characterization requires documentation of blood sample provenance, storage conditions, hematocrit and hemoglobin baseline measurements, and inter-sample variability. Experimental records confirm porcine blood source and hematocrit measurements but do not document pre-test pfHb baseline levels for individual samples, which affects the hemolysis index calculation. Inter-sample variability across the 3 operating points was not statistically characterized. Without baseline pfHb documentation, the experimental NIH values carry unquantified systematic uncertainty. Factor recorded as not-assessed; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5-requirements",
      "rationale": "Equivalency of input parameters requires formal demonstration that simulation inputs match experimental conditions within quantified tolerances for all validation comparisons. Rotational speed matching is documented (±5 RPM). However, inlet flow rate matching relies on pump curve interpolation rather than direct flow measurement at the pump inlet during hemolysis trials; flow rate uncertainty is estimated at ±8% based on downstream Coriolis meter placement. This input equivalency gap propagates directly into the output comparison metric. Factor recorded as not-assessed; epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, Class III, MRL 5) concludes Not Accepted based on structured evaluation of all 13 credibility factors. Seven factors were formally assessed; all seven exhibit achieved levels below required levels, with the most critical shortfalls in Discretization Error (achieved 2, required 4) and Output Comparison (achieved 2, required 4). Six factors could not be assessed due to documented epistemic gaps: Numerical Solver Error, Use Error, Model Form, Model Inputs, Test Samples, and Equivalency of Input Parameters each lack the evidence required for a formal gradation assignment at MRL 5. The Monte Carlo UQ study, while completed, reveals that hemolysis model exponent uncertainty alone accounts for 61% of NIH output variance, and the 95th-percentile prediction interval spans 2.4x the nominal prediction — a spread that precludes confident demonstration of compliance with the absolute clinical hemolysis threshold. The systematic over-prediction bias of 38.4% NRMSE and AVM of 0.41 indicate the model cannot currently be used as the primary basis for hemolysis acceptance decisions for a Class III VAD. The rejection threshold at MRL 5 requires all assessed factors to meet required levels and all not-assessed factors to be resolved or formally scoped out with documented justification. Neither condition is satisfied. The assessment team notes that the shortfalls are marginal for Software Quality Assurance (achieved 3, required 4) and Test Conditions (achieved 3, required 4), and targeted additional work on these two factors alone would not be sufficient given the fundamental discretization error and output comparison deficiencies. A path to acceptance would require: (1) mesh refinement to achieve GCI below 5% for hemolysis-relevant shear stress, (2) extension of MMS verification to the hemolysis scalar transport equation, (3) acquisition of experimental data at the two unmatched high-flow operating points, (4) formal model-form uncertainty quantification comparing at least two turbulence closures and two hemolysis constitutive models, and (5) resolution of the six not-assessed factor epistemic gaps. Decision is Not Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
