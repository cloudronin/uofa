  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Decision: Not Accepted. The credibility assessment for COU2 (VAD absolute hemolysis prediction, MRL 5) finds that the computational model does not meet required credibility levels for regulatory submission. Three factors are below required levels and collectively preclude acceptance: (1) Model form (achieved 2, required 4): The Giersiepen-Wurzinger hemolysis model exhibits ±60% parametric sensitivity and order-of-magnitude variability in constants across literature sources; confidence in model form adequacy is ~40%. (2) Output comparison (achieved 2, required 4): Mean absolute error of 38% and a 95% prediction interval spanning factor 2.1 relative to measured NIH values demonstrate that the model cannot predict absolute hemolysis within the accuracy required for a Class III device. (3) Discretization error (achieved 3, required 4): GCI values of 12–31% for hemolysis-relevant shear stress quantities exceed the 10% threshold required at MRL 5. Overall evidence confidence is assessed at approximately 50%, consistent with the wide uncertainty bounds documented across all validation results and Monte Carlo UQ outputs. These limitations are documented honestly and transparently; no attempt has been made to obscure or minimize the gaps. The decision team concludes that additional model form validation, device-specific experimental data at all 5 operating points, and mesh refinement to achieve GCI below 10% are required before resubmission. The package is structured to be fully compliant with ASME V&V 40 documentation requirements at MRL 5 despite the Not Accepted outcome.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
