  "signature": "ed25519:b7e3a1f4c2d8e6b0a5f9c3e7d1b4a8f2e6c0d5b9a3f7e1c4d8b2a6f0e4c8d2b5",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-level2",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is commercially validated and operates under a documented software quality assurance plan. Version control, regression testing records, and release notes confirm Gradation 2 compliance. All simulation runs executed under controlled environment with logged solver version and settings."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/ncv-level2",
      "rationale": "Numerical code verification was performed using method of manufactured solutions for the Navier-Stokes solver and the scalar hemolysis transport equation. Observed convergence rates matched theoretical rates, confirming correct implementation. Benchmark test cases from the FDA critical path initiative were reproduced within acceptable tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/disc-error-level2",
      "rationale": "A three-level mesh refinement study was conducted (coarse: 2.1M, medium: 5.8M, fine: 14.2M cells). Richardson extrapolation yielded a grid convergence index (GCI) of 1.8% for the hemolysis index at the worst-case operating point, exceeding the required Gradation 2 threshold. The medium mesh was selected for production runs, providing an appropriate balance of accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-level2",
      "rationale": "Experimental test conditions used for validation replicate the intended COU operating envelope: flow rates of 2–6 L/min and rotational speeds of 2000–3500 RPM. Blood analog fluid (glycerol-water mixture with matched viscosity and density) was used in the bench experiments. Temperature and inlet pressure conditions were controlled and documented in the test protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-level2",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared against experimental measurements at all 5 operating points. Mean absolute percentage error was 8.3%, within the 15% acceptance threshold for Gradation 2. Pressure-head predictions agreed within 4.1% of experimental values. Systematic bias was assessed and found to be below the threshold of concern."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-level2",
      "rationale": "The primary QOI is the normalized index of hemolysis (NIH) and the relative hemolysis index (RH) compared against the predicate device. These quantities directly map to the regulatory decision criterion (RH < 1). Secondary QOIs include wall shear stress distribution and exposure time, which are mechanistically linked to the hemolysis power-law model employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/val-relevance-level2",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal blood pump geometry under operating conditions that span the intended COU envelope. The validation domain overlaps with the COU domain in terms of flow regime (turbulent, Re 4000–18000), fluid properties, and geometric similarity. Remaining gaps between validation and COU conditions are documented and assessed as acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Numerical solver error beyond discretization error (e.g., iterative convergence error and round-off error) is scoped out at MRL 2 for this COU. Residual convergence to 1e-6 for all equations was verified in all production runs. Round-off error is negligible for double-precision arithmetic at the mesh sizes employed. Separate assessment is not required at this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Use error assessment is scoped out at MRL 2. Simulation execution is performed by trained engineers following a documented simulation protocol. Peer review of boundary condition setup, mesh quality checks, and post-processing scripts is conducted for each simulation campaign. These procedural controls are deemed sufficient at the current model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Formal model form uncertainty quantification is scoped out at MRL 2. The k-omega SST turbulence model and the Giersiepen-Wurzinger power-law hemolysis model are established choices for this class of blood pump CFD analysis, supported by published literature. Sensitivity to turbulence model selection was informally assessed through comparison with k-epsilon results, showing less than 6% difference in NIH predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Formal uncertainty propagation for model inputs is scoped out at MRL 2. Key input parameters (fluid viscosity, density, pump geometry dimensions, boundary conditions) are well-characterized from manufacturer specifications and standardized test protocols. Sensitivity analysis was performed for the three most influential inputs (inlet flow rate, rotational speed, blood viscosity), confirming that output uncertainty remains within acceptable bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Formal test sample characterization beyond standard practice is scoped out at MRL 2. The FDA generic centrifugal pump used for validation experiments was manufactured to published dimensional specifications. Three pump units were tested to assess unit-to-unit variability; coefficient of variation in NIH measurements was 4.2%, confirming acceptable sample consistency for this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "rationale": "Equivalency of input parameters between the validation context and the COU is scoped out as a separate formal factor at MRL 2. The overlap between validation and COU operating conditions was addressed under the relevance of validation activities factor. Boundary conditions in the COU simulations are drawn from the same operating envelope as the validation experiments, and any extrapolation is within 10% of the validated range."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model supporting the Morrison COU1 CPB use case is accepted at Medium assurance level. Seven credibility factors were formally assessed: all achieved levels meeting or exceeding the required Gradation 2 threshold for MRL 2. Discretization error achieved Gradation 3, providing additional confidence in mesh independence. Output comparison demonstrated 8.3% mean absolute error against experimental NIH measurements, within the 15% acceptance threshold. Validation activities span the full COU operating envelope. Six factors were appropriately scoped out with documented justification consistent with MRL 2 requirements. The structured evidence chain from foundational experimental data through validation results to this credibility assessment is complete and traceable. The model is fit for the intended purpose of identifying worst-case hemolysis operating conditions for regulatory submission supporting the Class II CPB device.",
