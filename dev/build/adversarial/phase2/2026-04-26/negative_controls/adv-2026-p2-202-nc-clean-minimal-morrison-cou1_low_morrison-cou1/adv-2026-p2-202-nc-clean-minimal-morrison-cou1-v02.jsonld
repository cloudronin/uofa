      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/morrison-ncv-mrl2",
      "rationale": "Solver verification performed using Taylor-Green vortex benchmark and lid-driven cavity test cases. Observed convergence order consistent with second-order spatial discretization. Results documented in verification report VR-NCV-2024-01, confirming MRL 2 requirements met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
