  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for hemolysis prediction of the FDA generic centrifugal blood pump is accepted for use in the COU1 CPB decision context at MRL 2. All 7 assessed credibility factors meet or exceed their required Gradation levels: Software quality assurance (achieved 2 ≥ required 2), Numerical code verification (achieved 2 ≥ required 2), Discretization error (achieved 3 ≥ required 2), Test conditions (achieved 2 ≥ required 2), Output comparison (achieved 2 ≥ required 2), Relevance of QoI (achieved 2 ≥ required 2), and Relevance of validation activities to COU (achieved 2 ≥ required 2). The 6 remaining factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 3 requirements for Class II devices. Three independent validation results with full uncertainty quantification confirm model predictive capability: bench-top hemolysis NIH mean absolute error 8.3%, pressure-flow curve agreement within experimental uncertainty across all 5 operating points, and PIV-based shear stress validation within 12% of measured values. The relative hemolysis index RH < 1 acceptance criterion is correctly identified at 4 of 5 operating points, with the fifth point borderline and supported by conservative experimental confirmation. The provenance chain is complete from foundational experimental datasets through validation activities to this assessment. The decision is grounded in structured evidence and supports regulatory submission for the Class II CPB device tolerance analysis.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
