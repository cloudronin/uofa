  "signature": "ed25519:b4e9d32f8a015c67e2f3b1d4c8a9f0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-sqa",
      "rationale": "The FE solver (Abaqus 2021) is a commercially validated platform with documented V&V history. Software quality assurance includes version-controlled input decks, regression test suite covering TKA contact problems, and documented change control log. Achieved Gradation 3 exceeds the MRL 3 requirement of Gradation 2; solver benchmarks against NAFEMS contact problems documented in QA dossier."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-ncv",
      "rationale": "Numerical code verification performed against three NAFEMS benchmark problems relevant to contact mechanics and large-deformation elasticity. Patch test passed for all element types used. Solution accuracy within 1% of analytical solutions for Hertzian contact and bending beam benchmarks. Meets Gradation 2 requirement for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-disc",
      "rationale": "Systematic mesh convergence study performed with four mesh densities (coarse to very fine) using Richardson extrapolation. Grid Convergence Index (GCI) for peak contact stress is 1.8%, well below the 5% acceptance threshold. Production mesh achieves h-convergence; element size in contact zone is 0.3 mm. Achieved Gradation 3 via formal GCI analysis exceeds MRL 3 requirement of Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-tc",
      "rationale": "In vitro test conditions documented with calibrated load application fixtures replicating ISO 14243-1 gait cycle loading profiles. Specimen preparation protocols, fixture alignment tolerances (±0.5°), and environmental conditions (37°C saline bath) documented in test report TR-2024-TKA-001. Boundary conditions in FE model mapped directly to measured fixture constraints. Meets Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-oc",
      "rationale": "Quantitative output comparison performed using normalized RMS error, mean absolute error, and Sprague-Geers metrics for both contact pressure maps and surface strains. Statistical comparison accounts for inter-specimen variability (n=5 cadaveric specimens). FE predictions fall within experimental uncertainty bands for all five gait loading scenarios. Achieved Gradation 3 with full statistical treatment exceeds MRL 3 requirement of Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-rqoi",
      "rationale": "The primary quantity of interest (peak von Mises stress on tibial tray) is directly relevant to the COU decision criterion (fatigue life assessment). Secondary QOI (contact pressure distribution) is directly measured in validation experiments. Traceability matrix linking each QOI to clinical failure mode documented. Meets Gradation 2 for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-rvacou",
      "rationale": "Validation activities performed on the same implant geometry, material lot, and loading conditions as the COU. Cadaveric specimens span the intended patient population range (BMI 22–35, age 55–75). Loading conditions cover 95th percentile peak knee force from gait analysis literature. Validation domain overlaps COU domain with documented gap analysis. Meets Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-nse",
      "rationale": "Solver error assessed through residual convergence monitoring (force residual < 1×10⁻⁴ N, displacement residual < 1×10⁻⁵ mm) and contact force equilibrium checks. Iterative solver tolerance set to 1×10⁻⁶; energy balance verified at each load increment. No spurious contact oscillations detected. Meets Gradation 2 for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-ue",
      "rationale": "Use error mitigated through documented simulation workflow with mandatory peer review at model setup, boundary condition assignment, and post-processing stages. Checklist-based review process completed by independent analyst. Input deck version controlled; automated sanity checks on material property ranges and load magnitudes implemented in pre-processing script. Achieved Gradation 2 exceeds MRL 3 requirement of Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-mf",
      "rationale": "Model form adequacy assessed through comparison of linear elastic, elastic-plastic, and elastic-plastic-creep material representations for UHMWPE. Elastic-plastic model selected based on validation evidence; creep contribution negligible for acute loading scenarios of the COU. Model form uncertainty estimated at ±4% on peak stress via sensitivity study. Documented justification for omission of viscoelastic effects at physiological strain rates. Meets Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-mi",
      "rationale": "All model inputs characterized with documented uncertainty distributions: Young's modulus (CV=3.2%), yield stress (CV=4.8%), friction coefficient (CV=12%), and applied load magnitude (CV=5.1%) based on material testing and literature. Probabilistic sensitivity analysis (Latin hypercube sampling, n=500) performed to rank input contributions to peak stress uncertainty. Top three influential inputs identified and their uncertainties propagated to output uncertainty bounds. Achieved Gradation 3 exceeds MRL 3 requirement of Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-ts",
      "rationale": "Five cadaveric knee specimens used for validation, all from donors within the intended patient population demographic. Specimen-to-specimen variability characterized; coefficient of variation for peak contact pressure is 11.3%. Sample size justified via power analysis targeting 80% power to detect 15% difference in mean contact pressure. Implant components sourced from production lot with dimensional inspection certificates. Meets Gradation 2 for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nagaraja-cou1-ortho-ac-eip",
      "rationale": "Equivalency between validation experiment inputs and COU model inputs verified through parameter mapping table. Material properties measured from same UHMWPE resin lot as COU device. Loading profiles in validation match ISO 14243-1 gait cycle used in COU predictions. Geometric fidelity confirmed by CMM measurement of implant components used in both validation and COU simulations; maximum dimensional deviation 0.05 mm. Meets Gradation 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed and all achieved levels meet or exceed the required levels for Model Risk Level 3. Software quality assurance (Gradation 3 ≥ required 2), numerical code verification (Gradation 2 = required 2), discretization error (Gradation 3 ≥ required 2), test conditions (Gradation 2 = required 2), output comparison (Gradation 3 ≥ required 2), relevance of QOI (Gradation 2 = required 2), relevance of validation activities (Gradation 2 = required 2), numerical solver error (Gradation 2 = required 2), use error (Gradation 2 ≥ required 1), model form (Gradation 2 = required 2), model inputs (Gradation 3 ≥ required 2), test samples (Gradation 2 = required 2), and equivalency of input parameters (Gradation 2 = required 2). Validation evidence is grounded in three independent validation results with complete provenance chains, quantified uncertainties, and direct comparison against experimental data. The FE model is deemed credible for predicting tibial tray contact stress under the specified COU conditions. The credibility assessment package is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
