  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed and all achieved levels meet or exceed required levels for Model Risk Level 3. Specifically: (1) Software quality assurance: achieved 3 ≥ required 2; (2) Numerical code verification: achieved 3 ≥ required 2; (3) Discretization error: achieved 3 = required 3, GCI 1.8% < 5% threshold; (4) Test conditions: achieved 3 ≥ required 2, fully documented per VTP-ORTHO-2024-01; (5) Output comparison: achieved 3 = required 3, all ASME V&V 20 metrics within acceptance bands; (6) Relevance of QoIs: achieved 3 ≥ required 2, QoI traceability matrix complete; (7) Relevance of validation activities to COU: achieved 3 ≥ required 2, VRA-ORTHO-2024-01 documents geometric and loading similarity; (8) Numerical solver error: achieved 2 = required 2, convergence confirmed for all load steps; (9) Use error: achieved 2 = required 2, blind re-run confirms reproducibility; (10) Model form: achieved 3 = required 3, constitutive model selection justified with sensitivity analysis; (11) Model inputs: achieved 3 = required 3, Monte Carlo UQ confirms 95th-percentile stress 12% below fatigue endurance limit; (12) Test samples: achieved 3 ≥ required 2, six cadaveric specimens spanning clinical population range; (13) Equivalency of input parameters: achieved 3 ≥ required 2, parameter equivalency matrix complete with residual mismatches quantified. The provenance chain from foundational experimental evidence through validation activities to credibility factor assessments is complete and archived. The computational model is accepted as credible for predicting tibial tray contact stress under the stated COU at MRL 3.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
