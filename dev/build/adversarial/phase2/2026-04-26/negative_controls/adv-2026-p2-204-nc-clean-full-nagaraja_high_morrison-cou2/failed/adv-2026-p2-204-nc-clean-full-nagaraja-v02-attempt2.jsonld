  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been assessed. Achieved credibility levels meet or exceed required levels for Model Risk Level 3 across all factors: Software quality assurance (3≥2), Numerical code verification (3≥2), Discretization error (3≥2), Test conditions (2≥2), Output comparison (3≥2), Relevance of QoI (2≥2), Relevance of validation activities to COU (2≥2), Numerical solver error (2≥2), Use error (2≥2), Model form (3≥2), Model inputs (3≥2), Test samples (2≥2), and Equivalency of input parameters (2≥2). Monte Carlo uncertainty quantification (2000 samples) confirms that the 95th-percentile peak contact stress prediction (18.4 MPa) remains below the UHMWPE yield threshold (21 MPa), providing a safety margin of 12.4%. Validation against ISO 14243-1 bench test data (mean absolute relative error 6.2%, maximum error 9.8%) demonstrates adequate predictive accuracy for the intended regulatory use. Provenance chain is complete from raw material characterization and bench test data through simulation results to this credibility assessment. The computational model is accepted as sufficiently credible to support the 510(k) substantial-equivalence claim for tibial tray contact stress under the specified COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
