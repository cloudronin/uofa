  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-ortho-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been fully assessed at MRL 3. Achieved levels meet or exceed required levels across every factor: Software QA (3≥2), Numerical code verification (2≥2), Discretization error (3≥2), Test conditions (2≥2), Output comparison (2≥2), Relevance of QoI (2≥2), Relevance of validation activities (2≥2), Numerical solver error (2≥2), Use error (2≥1), Model form (2≥2), Model inputs (3≥2), Test samples (2≥2), and Equivalency of input parameters (2≥2). Quantitative validation against six cadaveric tibiae under ISO 14243-1 gait and stair-climb loading demonstrates mean absolute errors of 8.3 µm and 11.1 µm respectively, with Pearson correlation r>0.91. Monte Carlo UQ on bone material inputs confirms the 95th percentile peak micromotion prediction remains below the 150 µm osseointegration threshold across the patient population envelope. Mesh convergence (GCI<2.1%), solver verification (MMS residual<1e-8), and independent peer review of the simulation plan provide high confidence in numerical accuracy. The validation activities are directly relevant to the COU with equivalent geometry, materials, and loading. The provenance chain is complete from raw cadaveric measurements through processed datasets to validated model outputs. The credibility evidence is sufficient to support the intended use of the FE model for selection of tibial tray interface preparation configuration, and the decision to Accept is warranted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
