  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-mrl2",
      "rationale": "ANSYS Fluent 2023R1 is a commercially validated CFD solver with documented QA procedures, release notes, and regression test suites. Version control of all simulation input files was maintained in a git repository with tagged releases. The achieved level of 2 exceeds the required level of 1 for MRL 2, confirming that software quality assurance is adequately addressed for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-mrl2",
      "rationale": "The CFD solver was verified against published benchmark cases including the FDA nozzle benchmark (ASME V&V 20) and lid-driven cavity flow at Re=1000. Order-of-accuracy testing confirmed second-order spatial convergence for the finite-volume discretization. Achieved level 2 meets and exceeds the required level 1 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-mrl2",
      "rationale": "A systematic mesh refinement study was performed using three mesh densities (2.1M, 6.8M, and 18.4M hexahedral elements). Richardson extrapolation yielded a grid convergence index (GCI) of 1.8% for the hemolysis index QoI on the finest mesh. The achieved level of 3 exceeds the required level of 2, demonstrating that discretization error is well-characterized and within acceptable bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-mrl2",
      "rationale": "Experimental validation tests were conducted at the same five flow-speed operating points used in the simulation matrix (2.5 L/min at 2000 RPM, 5.0 L/min at 2500 RPM, and three intermediate conditions). Blood analog fluid (glycerin-water mixture matched to physiological viscosity) and temperature were controlled within ±2% of target values. Test conditions are sufficiently representative of the COU to satisfy the required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-mrl2",
      "rationale": "CFD-predicted relative hemolysis index (RHI) values were compared against experimental measurements across all five operating points. Mean absolute error was 7.3% with maximum deviation of 11.2%, well within the ±15% acceptance band. PIV velocity field comparisons showed agreement within experimental uncertainty bands at 94% of measurement locations. The achieved level of 3 exceeds the required level of 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-mrl2",
      "rationale": "The primary QoI is the relative hemolysis index (RHI = HI_device / HI_predicate), which directly addresses the regulatory acceptance criterion (RHI < 1.0). Secondary QoIs include volumetric flow rate, pump head, and scalar shear stress distributions. Clinical relevance of RHI as a hemolysis surrogate is established in published literature (Zhang et al. 2011, Goubergrits and Affeld 2004). Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-mrl2",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry, which is the same device class and operating regime as the COU. Operating conditions span the full clinical CPB flow range (2–6 L/min). The blood analog fluid properties were matched to human blood viscosity at 37°C. The validation scenario is sufficiently close to the COU to support the intended regulatory decision at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-mrl2",
      "rationale": "Iterative convergence was monitored using normalized residuals, requiring all residuals to fall below 1×10⁻⁵ before solution acceptance. Mass imbalance across all boundaries was confirmed below 0.01%. Double-precision arithmetic was used throughout. Round-off errors are negligible relative to discretization errors as confirmed by the GCI analysis. Achieved level 2 exceeds required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-scoped",
      "rationale": "Use error is scoped out of this credibility assessment because the CFD model is operated exclusively by trained simulation engineers within a controlled laboratory environment under a documented simulation governance procedure (SGP-CFD-2023-04). The model is not deployed as an end-user tool; all simulation runs are executed by the same two analysts who developed the model and who hold ANSYS Fluent certification. Operator variability is further controlled by a detailed simulation execution checklist that is independently reviewed before each production run. Given the tightly controlled operational context and the absence of any interactive end-user interface, the risk of consequential use error is negligible and does not materially affect the credibility of the simulation results for this COU at MRL 2. This scoping decision was reviewed and approved by the credibility assessment team on 2024-11-15."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-mrl2",
      "rationale": "The Reynolds-averaged Navier-Stokes (RANS) approach with the SST k-omega turbulence closure was selected based on published sensitivity studies for rotary blood pump hemolysis prediction (Hariharan et al. 2018). The power-law hemolysis damage model (Giersiepen et al. 1990, modified by Zhang et al. 2011) was validated against erythrocyte lysis data in controlled Couette flow experiments. Model form uncertainty was quantified by comparing predictions from three turbulence models; SST k-omega showed lowest deviation from experimental PIV data. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-mrl2",
      "rationale": "All model inputs were sourced from traceable measurements: pump geometry from CMM-verified CAD (±0.01 mm tolerance), fluid properties from rheometer measurements of the blood analog at 37°C, and boundary conditions from calibrated flow meters and pressure transducers (±1.5% full-scale accuracy). Input uncertainty propagation was performed using a one-at-a-time sensitivity analysis confirming that RHI sensitivity to individual input perturbations remains below 5%. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-scoped",
      "rationale": "Test samples is scoped out of this credibility assessment because the validation experiments employed a well-characterized blood analog fluid (40% glycerin by mass in distilled water) rather than biological blood samples. The rheological equivalence of this analog to human blood at physiological shear rates has been established in the peer-reviewed literature (Brookshier and Tarbell 1993) and confirmed by in-house rheometry. Because no biological specimens are used, sample-to-sample biological variability, donor selection criteria, anticoagulation protocols, and storage condition effects — the primary concerns addressed by this factor — are not applicable to the validation activity. The use of a synthetic analog was a deliberate design choice to eliminate biological variability as a confounding source of uncertainty, which is consistent with FDA guidance on bench testing for hemolysis assessment. This scoping decision was reviewed and approved by the credibility assessment team on 2024-11-15 and is documented in the validation plan VP-CPB-2024-01."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/input-equivalency-mrl2",
      "rationale": "The equivalency between validation experiment input parameters and COU operating conditions was formally evaluated. Fluid viscosity, density, and non-Newtonian shear-thinning behavior were matched to within 3% of physiological values across the clinical operating range. Pump rotational speed and flow rate boundary conditions in the CFD model were set to values measured during the validation experiments rather than nominal targets. Geometric fidelity between the as-built test article and the simulation CAD model was confirmed by 3D optical scan comparison with maximum surface deviation of 0.08 mm. Required level 2 is met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/cfd-biofluid-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CPB hemolysis prediction at MRL 2) is accepted based on the following structured evidence: (1) All 11 assessed credibility factors meet or exceed their required levels, with 5 factors achieving levels above the minimum required. (2) The two scoped-out factors (Use Error and Test Samples) carry documented rationales that are technically justified and consistent with the controlled operational context and the use of a validated blood analog fluid. (3) Validation results demonstrate CFD-predicted RHI values within ±15% of experimental measurements across all five operating points, with PIV velocity agreement at 94% of measurement locations within experimental uncertainty. (4) Discretization error is well-characterized with GCI of 1.8% on the production mesh, and iterative convergence is confirmed below 1×10⁻⁵ for all residuals. (5) The model form selection (SST k-omega with power-law hemolysis model) is supported by published sensitivity studies and confirmed by multi-model comparison. (6) Input uncertainty propagation confirms RHI sensitivity below 5% for all individual input perturbations. The totality of evidence supports the conclusion that the CFD model is sufficiently credible to identify worst-case hemolysis operating conditions for regulatory submission of the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
