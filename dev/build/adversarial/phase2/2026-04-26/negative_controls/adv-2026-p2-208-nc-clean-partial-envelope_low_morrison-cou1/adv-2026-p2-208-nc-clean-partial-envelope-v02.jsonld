  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/fda-cdrh-computational-modeling-group",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump is accepted as credible for the declared Context of Use at Model Risk Level 2. The assessment is grounded in the following structured evidence: (1) All 7 assessed credibility factors meet or exceed their required levels (requiredLevel <= achievedLevel in all cases); (2) 6 factors are appropriately scoped out with documented rationale consistent with MRL 2 and medium model influence per ASME V&V 40 Table 3; (3) Validation activities densely cover the declared operating envelope (15 points spanning flow 2–6 L/min, speed 2000–3500 RPM, Hct 30–45%) with all NIH predictions within acceptance criteria (max error 13.2%, well within ±15%/±18% thresholds); (4) The explicit operating envelope and applicability constraint (adult non-pulsatile CPB only) bound the claims appropriately — the model is not claimed to be credible outside these bounds; (5) Discretization error is quantified and controlled (GCI < 2.1% on production mesh); (6) Uncertainty quantification is complete, with Monte Carlo propagation and adjoint sensitivity analysis providing 95% coverage intervals that are consistent with the observed validation errors; (7) Provenance chain is complete from foundational experimental datasets through validation activities to this assessment. The decision to accept is conditional on use remaining within the declared operating envelope and applicability constraints. Use outside these bounds requires a new credibility assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
