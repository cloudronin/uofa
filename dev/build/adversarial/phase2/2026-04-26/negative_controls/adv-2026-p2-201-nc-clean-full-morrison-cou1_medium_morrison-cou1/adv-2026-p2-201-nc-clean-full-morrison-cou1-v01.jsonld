  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluidics-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for CPB centrifugal pump, Class II, MRL 2) is accepted based on the following structured evidence: (1) All 13 V&V 40 credibility factors have been assessed, and all achievedLevels meet or exceed the requiredLevels for MRL 2. (2) Discretization error (GCI 2.3%) and numerical solver error (<0.1%) are both within acceptance thresholds, confirming numerical solution quality. (3) Code verification via MMS demonstrates second-order accuracy consistent with the solver design. (4) Validation against bench hemolysis measurements at all 5 COU operating points shows agreement within ±15%, with both model and experimental uncertainties quantified and accounted for. (5) The relative hemolysis index RH = 0.82 at the worst-case operating point satisfies the regulatory acceptance criterion RH < 1. (6) Monte Carlo UQ propagation (N=5000) confirms the 95th-percentile hemolysis prediction remains below the acceptance threshold, providing robustness assurance. (7) Validation activities are directly relevant to the COU in geometry, operating conditions, and QoI. (8) SQA, use error controls, and input equivalency are all documented and independently reviewed. The totality of structured evidence supports a finding that the CFD model is sufficiently credible for the intended regulatory use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
