  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou2-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Not accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, MRL 5) concludes Not accepted based on systematic shortfalls across all 13 credibility factors. No factor achieves its required gradation level. The most critical deficits are: (1) Model form (required 5, achieved 2): single turbulence model with no ensemble uncertainty quantification on hemolysis exponent — a three-gradation gap that directly undermines confidence in absolute hemolysis predictions; (2) Software quality assurance (required 4, achieved 2): absence of independent source-code audit for the hemolysis sub-model is inconsistent with Class III device requirements; (3) Numerical solver error (required 3, achieved 1): iterative convergence not demonstrated to QoI-specific tolerances; (4) Use error (required 3, achieved 1): single-analyst workflow without independent review is unacceptable at MRL 5 for a high-consequence Class III application; (5) Test samples (required 3, achieved 1): single experimental specimen without biological replicate variability characterisation cannot support absolute hemolysis threshold claims. The Monte Carlo UQ activity, while present, is insufficient because input distributions for critical hemolysis model parameters were assumed rather than measured, and correlations between inputs were neglected (Model inputs: required 4, achieved 2). Collectively, the structured evidence demonstrates that the model has not been verified, validated, or uncertainty-quantified to the standard required for primary regulatory reliance on absolute hemolysis predictions for a Class III VAD. Acceptance would require, at minimum: (a) MMS-based code verification of the hemolysis scalar transport sub-model; (b) ensemble model-form uncertainty quantification across turbulence model variants and hemolysis exponent ranges; (c) independent peer review of simulation setup and post-processing; (d) replicate experimental testing with biological variability characterisation; and (e) full iterative convergence study with QoI-specific tolerance criteria. Until these gaps are resolved, the credibility evidence is insufficient to support regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
