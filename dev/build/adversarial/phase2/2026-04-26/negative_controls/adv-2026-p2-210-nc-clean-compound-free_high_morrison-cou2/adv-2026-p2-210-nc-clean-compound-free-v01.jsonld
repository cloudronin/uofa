  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-criteria",
      "rationale": "CFD solver is subject to a documented software quality assurance plan conforming to ASME NQA-1 equivalent practices. Version control, regression testing suite (>1200 test cases), and release validation records are maintained. Independent code review completed for hemolysis sub-model. Achieved Gradation 4 satisfies the required Gradation 4 at MRL 5 for a Class III device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5-criteria",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes solver and the power-law hemolysis transport equation. Observed convergence rates match theoretical order (2nd-order spatial, 1st-order temporal). All MMS residuals within specified tolerance bands. Code verification report independently reviewed and archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5-criteria",
      "rationale": "Grid convergence index (GCI) study performed on three systematically refined meshes (4.2M, 12.6M, 37.8M cells) at all five operating points. GCI for hemolysis index < 3.1% across all points. Temporal convergence verified with three time-step refinements. Discretization uncertainty incorporated into Monte Carlo UQ ensemble as a bounded input distribution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5-criteria",
      "rationale": "In-vitro test conditions documented with calibrated instrumentation traceable to NIST standards. Blood analog fluid (porcine blood, hematocrit 33±1%) rheological properties measured and reported. Flow rates and rotational speeds controlled to within ±0.5% of target. Environmental conditions (temperature 37±0.5°C) maintained and logged throughout testing. Test protocol reviewed by independent laboratory."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5-criteria",
      "rationale": "Quantitative comparison metrics (E%, NRMSE, Theil U) computed for hemolysis index at all five operating points against in-vitro measurements. Mean absolute error 8.4% across operating points; all predictions within expanded uncertainty bounds (k=2). Velocity field comparison against PIV data shows normalized RMSE of 4.2% across measurement planes. Systematic bias assessed and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5-criteria",
      "rationale": "Normalized Index of Hemolysis (NIH) and modified Index of Hemolysis (mIH) are the primary QoIs, directly corresponding to the clinical acceptance threshold for VAD devices. These QoIs are identical between the validation experiments and the COU predictions. Sensitivity analysis confirms NIH is the dominant QoI driving the regulatory decision; secondary QoIs (wall shear stress distribution, recirculation zone volume) are also tracked and compared."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5-criteria",
      "rationale": "Validation activities performed on the FDA generic centrifugal pump geometry, which is the reference geometry for the COU. All five COU operating points (flow rate 2–8 L/min, speed 2000–3500 RPM) are within the validated operating envelope. Blood analog fluid properties, boundary conditions, and pump geometry are directly representative of the COU. No extrapolation beyond the validated parameter space is required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5-criteria",
      "rationale": "Iterative convergence monitored via normalized residuals (< 1e-5 for all transport equations) and global conservation checks (mass imbalance < 0.01%). Round-off error assessed via double-precision arithmetic verification. Solver error contribution to total uncertainty budget quantified as < 0.5% of hemolysis index prediction, well below discretization and model-form contributions. Achieved Gradation 3 meets the required Gradation 3 for this factor at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5-criteria",
      "rationale": "Simulation setup reviewed by a second qualified analyst independent of the primary analyst. Checklist-based review covers geometry import, mesh quality metrics, boundary condition assignment, material property inputs, and post-processing scripts. Discrepancies identified in the review were resolved and documented. Simulation execution logs archived for traceability. Achieved Gradation 3 satisfies the required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5-criteria",
      "rationale": "RANS k-omega SST turbulence model selected based on literature benchmarking for rotary blood pump flows. Power-law hemolysis model (Giersiepen-Wurzinger coefficients) calibrated against published shear-exposure data. Model form uncertainty estimated via comparison with LES predictions at two operating points (deviation < 12% in NIH). Alternative hemolysis model (Taskin et al.) evaluated; results within combined uncertainty bounds. Model form uncertainty propagated through Monte Carlo ensemble."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5-criteria",
      "rationale": "All model input parameters characterized with probability distributions derived from measured data or published literature. Key uncertain inputs: blood viscosity (CV 4.2%), hemolysis model exponents (CV 8.1%), inlet velocity profile (CV 2.3%). Monte Carlo sampling (N=2000 Latin hypercube samples) propagates input uncertainty to hemolysis index predictions. Input sensitivity indices (Sobol) computed; blood viscosity and hemolysis exponent account for 78% of output variance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5-criteria",
      "rationale": "In-vitro hemolysis measurements conducted with n=6 independent replicates per operating point (30 total measurements). Sample size justification based on power analysis targeting 80% power to detect 15% difference in NIH at alpha=0.05. Repeatability (within-day CV < 5%) and reproducibility (between-day CV < 9%) characterized. Measurement uncertainty reported as expanded uncertainty (k=2) per GUM. Achieved Gradation 3 meets the required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5-criteria",
      "rationale": "Boundary conditions applied in simulation derived directly from measurements taken during in-vitro validation experiments. Inlet flow waveforms, rotational speed profiles, and outlet pressure conditions matched between simulation and experiment to within instrument uncertainty. Geometric fidelity of CAD model to physical test article verified by CMM measurement; maximum deviation 0.08 mm (< 0.5% of critical clearance gap). Fluid properties in simulation set to measured values with uncertainty bands. Achieved Gradation 3 satisfies the required Gradation 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and all achieved levels meet or exceed required levels for Model Risk Level 5, Class III device context. The seven primary factors (SQA, code verification, discretization error, test conditions, output comparison, QoI relevance, and validation relevance) each achieve Gradation 4, satisfying the stringent MRL 5 requirements. The six supporting factors (solver error, use error, model form, model inputs, test samples, and input equivalency) achieve Gradation 3 or higher, meeting their respective requirements. Monte Carlo uncertainty quantification (N=2000 LHS samples) has been performed across all five COU operating points, with hemolysis index predictions remaining below the absolute clinical threshold across the full uncertainty ensemble (97.5th percentile NIH = 0.0034 g/100L, threshold = 0.0100 g/100L). Validation evidence is directly representative of the COU with no extrapolation required. Independent review of simulation setup and results has been completed. The structured evidence base supports the conclusion that the CFD model is sufficiently credible to predict absolute hemolysis levels for regulatory decision-making for this Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
