  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-level2",
      "rationale": "FEA software (Ansys Mechanical 2022 R2) is a commercially validated solver with documented V&V procedures. FDA-internal solver used under controlled software configuration management. Version control, regression testing, and release qualification records reviewed and confirmed compliant with Gradation 2 requirements for a Medium model-risk application."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-level2",
      "rationale": "Benchmark problems from ASME V&V 10 test suite (beam bending, contact patch test) reproduced to within 0.1% of analytical solutions. Code verification activities documented in FDA solver qualification report QR-2022-FEA-001. Achieved level meets required level for Medium model-risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-level3",
      "rationale": "Systematic mesh refinement study performed: three mesh densities (coarse ~50k elements, medium ~150k elements, fine ~400k elements). Richardson extrapolation applied; Grid Convergence Index (GCI) for stiffness QoI = 0.8%, yield force QoI = 1.2%, force-at-40mm QoI = 0.9%. All GCI values below 2% threshold. Medium mesh adopted for production runs; discretization error contribution to total uncertainty budget explicitly quantified and included in E/uval calculations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-level2",
      "rationale": "Nonlinear solver convergence monitored via force and displacement residual norms (< 1e-4 relative tolerance). Contact stabilization energy < 0.5% of total strain energy in all production runs. Time-stepping sensitivity study confirmed quasi-static assumption valid; dynamic effects negligible at prescribed loading rate. Solver error contribution to uncertainty budget < 0.5% for all three QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-level2",
      "rationale": "Model setup reviewed by independent analyst (DePuy Synthes FEA team) against a documented modeling protocol. Boundary condition application, material assignment, contact pair definition, and load application verified against protocol checklist. No discrepancies identified. Independent FEA ensemble (three analysts, three software implementations) used to bound inter-analyst variability; ensemble spread < 3% across all QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-level3",
      "rationale": "Continuum isotropic elastic-plastic model with bilinear hardening adopted for Ti-6Al-4V screw and rod components. UHMWPE vertebral body surrogate modeled as linear elastic per ASTM F1717 specification. Model form assumptions justified by literature precedent for quasi-static compression-bending of metallic spinal implants. Frictional contact (Coulomb) used at screw-rod interface; model form uncertainty contribution assessed via comparison of frictionless and frictional predictions against experimental data. Model form uncertainty included in total uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-level3",
      "rationale": "Material properties (E = 114 GPa, ν = 0.33, σ_y = 880 MPa for Ti-6Al-4V) sourced from published literature and supplier data sheet. ACKNOWLEDGED LOW CONFIDENCE: yield strength value (880 MPa) is derived from a single supplier lot data sheet rather than independent coupon testing from the specific lot used in bench experiments. This limitation is explicitly documented. Uncertainty on σ_y widened to ±8% (vs. ±3% for independently verified properties) based on inter-lot variability reported in ASTM F136 certification data. Sensitivity analysis confirms yield force QoI moderately sensitive to σ_y; this drives the elevated E/uval = 1.44 for yield force, which remains below the 1.96 threshold. Friction coefficient μ = 0.25 ± 0.12 assigned based on literature range for Ti-Ti contact; sensitivity analysis confirms stiffness and force-at-40mm QoIs are insensitive to friction in this regime. All input uncertainties propagated via 10,000-sample Monte Carlo. Achieved level 3 reflects complete uncertainty propagation with documented wide bounds; the low-confidence yield strength input is treated as residual uncertainty accepted by the decision authority."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-level3",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH and DePuy Synthes R&D). Constructs assembled from production-representative components per ASTM F1717 Section 6. Dimensional inspection records available for all 11 constructs; mean screw diameter 7.49 mm (SD 0.02 mm), confirming production representativeness. Inter-laboratory variability characterized; coefficient of variation for stiffness 4.1%, yield force 5.3%, force-at-40mm 3.8%. Sample size sufficient for statistical characterization at Medium model-risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-level3",
      "rationale": "BELOW REQUIRED LEVEL — documented deficiency accepted as residual risk. Testing conducted at a single load level and single loading rate per ASTM F1717 protocol. Required level 3 would demand multiple loading conditions (e.g., varied offset distances or cyclic loading) to characterize model response across the COU envelope. Only one test condition (standard F1717 compression-bending geometry, 35 mm offset) was employed. This limitation is explicitly acknowledged; the decision authority accepts this as residual uncertainty because (a) the COU is specifically bounded to the F1717 standard test configuration, (b) the clinical decision consequence is Medium (not High), and (c) independent bench testing under the same condition provides direct corroboration. Residual risk documented in decision record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/equivalency-inputs-level3",
      "rationale": "FEA model geometry derived from CAD files of the same production lot used in bench testing. UHMWPE block dimensions in model matched to measured block dimensions (within 0.1 mm). Applied displacement boundary conditions in FEA replicate test machine crosshead displacement; load cell compliance correction applied to experimental data. Material properties assigned from same source documentation used to characterize test specimens. Equivalency confirmed by cross-referencing model input deck against test setup photographs and dimensional inspection records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-level3",
      "rationale": "Quantitative comparison performed for all three QoIs using the ASME V&V 40 validation metric E/uval. Validation uncertainty uval computed as RSS of experimental measurement uncertainty (instrument calibration, inter-lab variability), numerical solution uncertainty (discretization, solver), and input parameter uncertainty (Monte Carlo propagation). Results: stiffness E/uval = 0.91, yield force E/uval = 1.44, force-at-40mm E/uval = 1.12. All values below 1.96 threshold. Force-field plots and load-displacement curves compared graphically; qualitative agreement confirmed. Wide uncertainty bounds on yield force QoI (driven by low-confidence σ_y input) are explicitly visible in comparison plots and noted in the output comparison report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-level3",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the primary performance metrics specified in ASTM F1717 and directly relevant to the regulatory decision on non-cannulated pedicle screw mechanical performance. Stiffness characterizes elastic load transfer; yield force characterizes onset of permanent deformation; force at 40 mm characterizes post-yield energy absorption relevant to fatigue life assessment. All three QoIs are clinically meaningful indicators of construct integrity under physiological bending loads."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-level3",
      "rationale": "Validation activities directly replicate the COU: the same screw design (non-cannulated 7.5 mm), same loading mode (ASTM F1717 static compression-bending), same construct configuration (bilateral pedicle screw-rod), and same performance metrics are used in both validation and the intended regulatory submission. Testing conducted at two independent laboratories increases confidence in experimental reference data. The single-condition limitation (Test conditions factor, achievedLevel 2) is the only departure from full COU coverage; its impact is bounded by the COU scope restriction to the F1717 standard configuration."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-f1717-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the non-cannulated 7.5 mm pedicle screw FEA model is ACCEPTED with documented residual uncertainty. All three QoIs satisfy the quantitative acceptance criterion (E/uval < 1.96): stiffness 0.91, yield force 1.44, force-at-40mm 1.12. All FEA predictions fall within the 10% relative error acceptance band. Eleven of thirteen V&V 40 credibility factors achieve their required levels. Two factors are below required level or carry documented limitations: (1) Test conditions achieved level 2 vs. required level 3, due to testing at a single F1717 configuration; this is accepted because the COU is explicitly bounded to that configuration and the decision consequence is Medium. (2) Model inputs carry low-confidence yield strength data (single supplier lot data sheet); this limitation is honestly documented, uncertainty bounds are widened accordingly (±8% on σ_y), and the resulting elevated E/uval of 1.44 for yield force remains within the acceptance threshold. The decision authority acknowledges these residual uncertainties as tolerable for a Class II, Medium model-risk device where bench testing provides direct corroboration. No weakeners are identified. The provenance chain from foundational experimental data through uncertainty quantification to validation results is complete and traceable. This package is suitable for submission in support of a 510(k) premarket notification.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
