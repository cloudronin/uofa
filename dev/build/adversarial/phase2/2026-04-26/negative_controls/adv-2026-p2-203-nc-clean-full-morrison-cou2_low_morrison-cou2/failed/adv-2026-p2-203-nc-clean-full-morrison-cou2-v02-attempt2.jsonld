  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed at required level 5 with achieved level 5. Software quality assurance confirmed under ISO 9001 QMS with 47 verified benchmarks. Code verification via MMS confirms theoretical convergence order. Discretization error GCI < 1.2% on 51.2M-cell mesh. Test conditions replicated at all 5 COU operating points with NIST-traceable instrumentation. Hemolysis index NRMSE ≤ 8% across all operating points within experimental uncertainty bounds. QoI directly maps to clinical NIH metric. Validation domain fully envelops COU domain with no geometric or operational extrapolation. Solver residuals below 1×10⁻⁷ with negligible round-off contribution. Use error controlled via SPD-VAD-002 and independent replication. SST k-ω model form selected after five-model comparison; form uncertainty quantified. All 12 uncertain inputs characterized with measured distributions; global Sobol analysis identifies dominant parameter. n=30 experimental runs with CV ≤ 4.8% provide statistically adequate test sample. Full input equivalency matrix confirms no extrapolation in any parameter. Monte Carlo UQ (10,000 runs) confirms 95th-percentile hemolysis prediction remains below clinical threshold with margin of 18%. The totality of structured evidence supports acceptance of the CFD model for Class III VAD hemolysis prediction at MRL 5.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
