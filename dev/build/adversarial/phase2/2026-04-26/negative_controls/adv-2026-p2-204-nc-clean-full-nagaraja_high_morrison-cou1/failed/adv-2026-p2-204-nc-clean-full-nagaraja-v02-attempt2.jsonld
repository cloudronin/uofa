  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-ortho-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-ortho-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the TKA tibial tray FEA model at MRL 3 is accepted based on the following structured evidence review: (1) All 13 ASME V&V 40 credibility factors have been assessed; 8 factors achieved levels exceeding the required gradation and 5 factors met the required gradation exactly — no factors fell below requirement. (2) The two primary validation activities (strain gauge contact stress comparison and fatigue bench test comparison) both satisfied their pre-specified acceptance criteria: mean contact stress error 8.3% < 15% threshold; fatigue life index RFL = 1.21 > 1.0 threshold. (3) Discretization error is bounded (GCI < 2.1%) and model input uncertainty has been propagated probabilistically, with the 95th percentile contact stress and 5th percentile fatigue life index both satisfying acceptance criteria. (4) The validation activities are judged sufficiently relevant to the COU: same geometry, same material lot, ISO 14243 loading conditions spanning the physiological range. (5) Software QA, use error controls, and independent model review provide adequate assurance against systematic errors. (6) No unresolved model form uncertainties or anomalous validation discrepancies were identified. The weight of evidence supports the conclusion that the FEA model is credible for its intended use: identifying worst-case loading conditions for tibial tray fatigue in a Class II TKA device at MRL 3.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
