  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated pedicle screw compression-bending) is accepted at Medium assurance level based on the following structured evidence review. Twelve of thirteen V&V 40 factors meet or exceed their required credibility levels. The single gap — Test conditions (achieved Gradation 2, required Gradation 3) — is explicitly documented and accepted as residual risk because the COU is scoped exclusively to ASTM F1717 compression-bending, which is the single test condition applied; companion COU packages address other loading modes. One additional gap is explicitly documented and bounded: material input data (elastic modulus and yield strength) carry wide uncertainty bounds (±12–15%, 95% CI) due to reliance on literature rather than lot-specific coupon testing. This gap was assessed via Monte Carlo uncertainty propagation (10,000 samples) and confirmed to be acceptable: all three QoIs (stiffness, yield force, force at 40 mm displacement) remain within the pre-established 10% acceptance threshold and E/uval <1.96 across the full uncertainty range including conservative lower-bound scenarios. The explicit documentation of this low-confidence input gap, combined with the bounding analysis demonstrating its limited impact on decision-relevant QoIs, satisfies the ASME V&V 40 requirement for honest characterization of model credibility. All ValidationResults carry comparedAgainst, prov:wasGeneratedBy, and hasUncertaintyQuantification links. The provenance chain is complete from foundational experimental datasets through simulation activities to validation results. The decision to accept is grounded in the structured quantitative evidence and is consistent with the Medium model risk level and Medium decision consequence classification.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
