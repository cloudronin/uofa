  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/sqa-level2",
      "rationale": "Ansys Mechanical 2023 R1 and the FDA in-house FEA code are both subject to formal software quality assurance programs. Ansys holds ISO 9001 certification and provides documented verification test suite results. The FDA code is maintained under 21 CFR Part 11-compliant version control with regression test suite covering all element types used. DePuy Synthes FEA code operates under IEC 62304 Class B SQA. All three codes exceed Gradation 2 requirements; ensemble agreement across codes provides additional SQA confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/code-verification-level2",
      "rationale": "Patch tests and manufactured-solution benchmarks were executed for all element formulations (hexahedral C3D8R, tetrahedral C3D10) used in the pedicle screw model. Results reproduced analytical solutions to within 0.3% for linear elastic bending. The FDA code passed NAFEMS benchmark LE1 and LE10. Ensemble consistency across three independent codes further corroborates code correctness; maximum inter-code QoI deviation was 2.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/discretization-error-level2",
      "rationale": "Systematic mesh convergence study conducted with four mesh densities (coarse 42k elements, medium 118k, fine 312k, extra-fine 641k). Richardson extrapolation applied per ASME V&V 10.1. Grid Convergence Index (GCI) for stiffness QoI = 0.7% between fine and extra-fine meshes; production mesh (fine 312k elements) used for all predictions. Discretization error contribution to uval explicitly quantified and included in E/uval calculations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/solver-error-level1",
      "rationale": "Nonlinear quasi-static analysis employed with Newton-Raphson iteration; convergence criteria set at 0.1% force residual and 0.01% displacement residual. Load incrementation verified to produce path-independent results for the elastic-plastic material response. Double-precision arithmetic used throughout. Solver error estimated at <0.05% of QoI, negligible relative to other uncertainty sources."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/use-error-level2",
      "rationale": "Model setup, boundary condition application, and post-processing were independently performed by two analysts at FDA and verified by a third analyst. A documented modeling protocol specifying contact definitions, screw-rod interface conditions, and UHMWPE vertebral body block material assignment was followed. Discrepancies between analyst runs were reconciled prior to final predictions; no material use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-form-level3",
      "rationale": "Continuum elastic-plastic finite element formulation with isotropic hardening is appropriate for titanium alloy pedicle screw under monotonic quasi-static loading. Screw-rod contact modeled with penalty-based frictional contact (μ=0.2, measured value). UHMWPE vertebral body blocks modeled as linear elastic per published material characterization. Model form uncertainty assessed via comparison of three independent FEA implementations; maximum inter-model QoI deviation 2.8% confirms model form adequacy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/model-inputs-level3",
      "rationale": "Titanium alloy (Ti-6Al-4V) elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (1.2 GPa) sourced from coupon testing of production-lot material (N=6 tensile specimens, CV<3%). UHMWPE block modulus (1.0 GPa) from published ASTM F648 characterization. Geometry from calibrated CMM measurements of production screws (N=3, dimensional tolerance ±0.02 mm). Friction coefficient from tribological testing (N=5 pin-on-disc, CV=8%). All input uncertainties propagated via Monte Carlo (N=10,000 samples) and incorporated into uval."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-samples-level3",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH and DePuy Synthes). All constructs assembled from production-lot components with dimensional verification. Inter-laboratory reproducibility confirmed: lab1 vs. lab2 mean stiffness difference 2.1%, within combined measurement uncertainty. Sample size provides 80% power to detect 10% QoI difference at α=0.05. Traceability of test articles to production lot documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/test-conditions-level2",
      "rationale": "ACKNOWLEDGED GAP — explicitly documented as residual risk. Testing was conducted at a single loading rate (5 mm/min quasi-static per ASTM F1717) and single temperature (23°C ambient). The COU is limited to quasi-static compression-bending under standard laboratory conditions, which matches the single test condition. Rate-dependence of titanium alloy response is negligible at quasi-static rates (confirmed by literature). However, only one test condition was explored; no parametric variation of load angle or offset distance was performed. This gap reduces achievedLevel from 3 to 2. The limitation is accepted as residual risk because: (1) ASTM F1717 mandates the single standardized condition for regulatory comparison; (2) the COU explicitly excludes dynamic or fatigue loading scenarios; (3) model risk level 3 with Medium consequence permits a single below-required factor per credibility matrix. The gap is carried forward transparently in the decision record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/input-equivalency-level3",
      "rationale": "FEA model inputs were mapped directly to measured experimental parameters. Screw geometry from CMM measurements of the exact test articles. Material properties from production-lot coupons from the same material heat as test constructs. Boundary conditions (fixed inferior block, displacement-controlled superior block) replicate test fixture kinematics verified by DIC measurement. Contact friction coefficient measured on representative screw-rod interface pairs. No surrogate or assumed input values used; full traceability documented in model input log."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/output-comparison-level3",
      "rationale": "Quantitative comparison performed for all three primary QoIs (stiffness, yield force, force at 40 mm displacement) using the ASME V&V 40 validation metric E/uval. All three QoIs satisfy E/uval < 1.96: stiffness 0.61, yield force 1.12, force at 40 mm 0.84. Percentage differences all below 10% acceptance bound (1.9%, 3.5%, 2.3% respectively). Full force-displacement curves compared qualitatively; FEA ensemble mean tracks experimental mean curve within experimental scatter band across all displacement levels. Inter-code ensemble spread quantified and reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/qoi-relevance-level3",
      "rationale": "The three QoIs — construct stiffness, yield force, and force at 40 mm displacement — are the primary outputs specified in ASTM F1717 and directly relevant to clinical performance assessment of pedicle screw constructs. Stiffness characterizes load transfer to the vertebral column; yield force indicates onset of permanent deformation; force at 40 mm displacement represents post-yield structural integrity. All three QoIs are directly measurable in the experimental protocol and directly predictable by the FEA model without intermediate transformation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/nagaraja/criteria/validation-relevance-level3",
      "rationale": "The validation activity directly replicates the COU: the same non-cannulated 7.5 mm pedicle screw design, the same ASTM F1717 compression-bending test configuration, the same loading modality, and the same QoIs used in the regulatory submission. The experimental constructs are production-representative. The validation is not an analogy or surrogate — it is a direct test of the model against the exact scenario being predicted. Validation domain fully overlaps with COU domain; no extrapolation required."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (non-cannulated 7.5 mm pedicle screw, ASTM F1717 compression-bending) is ACCEPTED. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. One factor — Test conditions — achieves Gradation 2 against a required Gradation 3, reflecting that testing was conducted at a single standardized ASTM F1717 condition without parametric variation of load angle or temperature. This gap is explicitly documented and accepted as residual risk for the following reasons: (1) the COU is scoped exclusively to quasi-static compression-bending under ASTM F1717 standardized conditions, which the single test condition fully represents; (2) titanium alloy rate-independence at quasi-static rates is well-established in the literature; (3) the ASME V&V 40 credibility matrix for model risk level 3 with Medium decision consequence permits acceptance with one factor below required level provided all other factors are met and the gap is documented; (4) the three primary QoIs all satisfy the quantitative acceptance bounds (E/uval < 1.96 and percentage difference < 10%), providing strong quantitative evidence of model adequacy within the defined COU. The FEA ensemble approach across three independent codes (FDA, Ansys, DePuy Synthes) provides additional confidence through inter-code consistency (maximum QoI deviation 2.8%). The provenance chain is complete: experimental data from N=11 constructs across two laboratories, material inputs from production-lot coupon testing, geometry from CMM measurements, and uncertainty quantification via Monte Carlo propagation. The decision is grounded in the structured credibility evidence and is consistent with the Medium assurance level designation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
