      "type": "ValidationResult",
      "name": "Primary hemolysis index validation — bench loop comparison",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in vitro bench loop measurements across five operating points. Predicted NIH values fell within 12% of experimental measurements at all operating points. Relative hemolysis index RH < 1 confirmed for all test configurations.",
      "comparedAgainst": "https://uofa.net/synth/data/hemolysis-experimental-bench",
      "passFailStatus": "Pass",
      "quantitativeResult": "Mean absolute error 9.4%; max deviation 11.8% at 4500 rpm / 3 L/min"
