    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified for the flow regime present in the centrifugal pump and sensitivity to model form uncertainty must be characterized.",
      "rationale": "SST k-omega turbulence model selected based on published literature for centrifugal blood pump applications. Sensitivity study comparing SST k-omega, realizable k-epsilon, and RSM models performed at two representative operating points. NIH predictions vary by less than 7% across models, within acceptable model form uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
