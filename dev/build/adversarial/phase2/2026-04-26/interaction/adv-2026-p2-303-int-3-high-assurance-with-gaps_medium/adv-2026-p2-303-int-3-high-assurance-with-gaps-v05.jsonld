      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark verification cases relevant to rotating machinery and viscous flow.",
      "rationale": "Solver verified against Taylor-Couette flow, lid-driven cavity, and rotating disk benchmarks. All verification cases pass with errors within published solver tolerances. Code verification satisfactory for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for hemolysis-relevant quantities of interest across all operating points.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 8.7M, 17.1M cells). GCI for NIH: 3.1% coarse-to-medium, 1.4% medium-to-fine. Richardson extrapolation confirms asymptotic convergence. Discretization error well controlled at all 5 operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulated operating conditions within ±5% for flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA benchmark experiments conducted at 37°C with porcine blood analog (glycerol-water, viscosity 3.5 mPa·s). CFD boundary conditions set to match measured inlet flow rates and pump speeds within 2.3% mean deviation. Temperature and viscosity matched within specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., mean relative error) must be below 15% for NIH predictions across all validation operating points.",
      "rationale": "Systematic output comparison performed using mean relative error, maximum absolute error, and Theil inequality coefficient. NIH predictions: mean relative error 8.3%, max 12.1%, Theil U = 0.09. All metrics satisfy acceptance criteria with margin."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must directly map to the clinical hemolysis endpoint and the RH < 1 acceptance criterion used in device submission.",
      "rationale": "NIH and RH index are the primary regulatory hemolysis metrics for CPB devices per FDA guidance. CFD quantities of interest (shear stress history, exposure time) are directly integrated into the power-law hemolysis model to produce NIH, ensuring direct relevance to the submission criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
