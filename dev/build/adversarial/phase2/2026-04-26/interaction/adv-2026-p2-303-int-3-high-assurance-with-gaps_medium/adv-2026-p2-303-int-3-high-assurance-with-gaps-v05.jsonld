      "type": "ValidationResult",
      "name": "Primary hemolysis index validation against FDA benchmark",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against FDA benchmark experimental data for the generic centrifugal blood pump across all 5 flow-speed operating points. Mean relative error 8.3%, within the 15% acceptance threshold. Validation conducted at MRL 2 requirements.",
      "comparedAgainst": "https://uofa.net/synth/data/fda-generic-cpb-geometry-v2",
      "passedCriteria": true,
      "quantitativeResult": "Mean relative error 8.3% across 5 operating points; maximum error 12.1% at low-flow high-speed condition"
