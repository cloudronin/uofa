      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against published benchmark cases; Gradation 1 sufficient at MRL 2.",
      "rationale": "Fluent verified against FDA nozzle benchmark (ASME V&V 20) and lid-driven cavity case. Published order-of-accuracy results confirm correct implementation of RANS equations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported with apparent order of accuracy >= theoretical order; normalized GCI < 5% on QoI; Gradation 3 required at MRL 2 for high-consequence decision.",
      "rationale": "A three-mesh refinement study was performed (coarse 2.1M, medium 4.8M, fine 9.6M cells). GCI on the relative hemolysis index was computed as 7.3%, which exceeds the 5% threshold. Apparent order of accuracy was 1.7 versus theoretical 2.0. The medium mesh was adopted for production runs based on engineering judgment that the 7.3% GCI was acceptable given downstream experimental comparison, but formal Gradation 3 criteria are not fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented and traceable to calibrated instrumentation; flow rates within ±2% of CFD inlet conditions.",
      "rationale": "Bench-top loop operated at 37°C with phosphate-buffered saline blood analog. Flow rates measured with Coriolis meter (±0.5% accuracy). Rotational speed confirmed with optical tachometer. All five operating points replicated within stated tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation QoI within experimental uncertainty bands for >= 4 of 5 operating points; RHI prediction error < 15%.",
      "rationale": "RHI predictions agree with bench measurements within 11% at 4 of 5 operating points. The fifth point (low-flow, high-speed) shows 18% deviation attributed to cavitation inception not modeled; flagged in uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (RHI) directly maps to clinical hemolysis endpoint; scalar index derived from stress-exposure integral accepted by FDA guidance.",
      "rationale": "The relative hemolysis index is the primary regulatory QoI per FDA guidance document (2017). Stress-exposure integral computed from Lagrangian particle tracking with Giersiepen-Wurzinger power-law model. QoI relevance confirmed by clinical literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry under the same operating envelope as the COU; blood analog properties within documented physiological range.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry identical to the COU model. Operating envelope (2–6 L/min, 2500–4500 RPM) spans the five COU operating points. Blood analog (PBS + glycerol) viscosity matches 37°C whole blood within 4%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residuals converged to < 1e-5 for continuity and momentum; mass imbalance < 0.01%.",
      "rationale": "All production runs converged to residuals below 1e-6. Mass imbalance across inlet/outlet < 0.005%. Pseudo-transient under-relaxation applied to stabilize rotating reference frame solution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
