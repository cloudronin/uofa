      "rationale": "Per ASME V&V 40 Table 1, use error factor is not required at MRL 2 for this COU configuration. Scoped out by mutual agreement with regulatory team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified against experimental data; hemolysis constitutive model validated against published erythrocyte lysis data.",
      "rationale": "SST k-omega turbulence model selected based on published comparisons for internal rotating flows (Bhushan et al. 2013). Giersiepen-Wurzinger hemolysis model calibrated against Wurzinger 1986 erythrocyte lysis data. Model form uncertainty estimated at ±12% on RHI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; input sensitivity analysis not required.",
      "rationale": "Formal input uncertainty propagation not required at MRL 2. Geometric tolerances applied as deterministic worst-case bounds per design specification."
    },
