  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 factors. Seven factors were formally assessed; six were scoped out as not required at MRL 2. The discretization error factor achieved Gradation 2 against a required Gradation 3; however, the team concluded that the 7.3% GCI, combined with favorable experimental output comparisons at 4 of 5 operating points, provides sufficient confidence that the CFD model meets the COU objectives. The relative hemolysis index predictions support the regulatory submission conclusion that RH < 1 across the design operating envelope. Decision: Accepted.",
