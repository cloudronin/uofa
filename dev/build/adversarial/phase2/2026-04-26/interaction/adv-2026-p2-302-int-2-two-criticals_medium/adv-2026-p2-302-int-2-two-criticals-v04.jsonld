  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD model is fit for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device. Seven of thirteen factors were formally assessed; six were scoped out as not required at MRL 2. The discretization error factor achieved level 2 against a required level of 3; however, the team judged this shortfall acceptable given the relative comparison framework and conservative RH < 1 acceptance criterion. The orphan claim regarding discretization adequacy (https://uofa.net/synth/claim/cpb-discretization-adequacy) was submitted without provenance linkage to the underlying GCI study data, and no formal derivation chain was established prior to decision closure. Overall credibility evidence was deemed sufficient to support the regulatory submission.",
