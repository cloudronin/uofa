      "rationale": "Use error assessment is not required at Model Risk Level 2 for this application. Standard analyst training and simulation review procedures are in place."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified with sensitivity study; hemolysis damage model validated against published power-law formulations.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature for rotary blood pump flows. However, no sensitivity study comparing alternative turbulence models (e.g., RSM, LES) was performed. The power-law hemolysis damage model was applied without assessment of model-form uncertainty relative to more recent strain-based formulations. Model form uncertainty is unquantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (blood viscosity, density, hemolysis model constants) documented with sources and uncertainty ranges.",
      "rationale": "Blood properties were taken from published literature (viscosity 0.0035 Pa·s, density 1060 kg/m³). Hemolysis model constants (C=3.62×10⁻⁷, α=2.416, β=0.785) sourced from Giersiepen et al. Input uncertainty ranges documented in the simulation plan."
    },
