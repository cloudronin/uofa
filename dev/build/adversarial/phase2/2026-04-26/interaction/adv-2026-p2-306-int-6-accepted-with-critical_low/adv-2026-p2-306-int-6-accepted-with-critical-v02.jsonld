  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the assessed factors, four achieved the required level and three fell below the required level (discretization error, test conditions, and model form). The team judged that the shortfalls were collectively manageable given the conservative acceptance criterion (RH < 1) and the availability of experimental validation data. The model is accepted for the stated COU at Medium assurance level.",
