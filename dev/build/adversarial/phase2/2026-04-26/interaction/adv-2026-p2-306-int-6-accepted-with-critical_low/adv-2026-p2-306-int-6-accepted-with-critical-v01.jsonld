  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the CFD model for the stated COU despite three factors (Software quality assurance, Discretization error, Relevance of validation activities to the COU) achieving levels below the required level 2. The team judged the shortfalls to be minor based on engineering judgment: the SQA gap is mitigated by the solver's commercial validation history, the two-level mesh study showed less than 4% change in RH, and the FDA benchmark is the accepted community standard geometry. The overall assurance level is recorded as Medium. No formal compensating evidence package was assembled for the shortfall factors.",
