  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified under a documented SQA plan with version control, regression testing, and documented release notes.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under a documented SQA plan meeting FDA software guidance. Version-controlled solver with regression test suite covering 47 benchmark cases. Release notes and change logs archived. Achieved level 2 satisfies MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through at least one analytical or manufactured solution benchmark at MRL 2.",
      "rationale": "Code verification performed using the method of manufactured solutions for the incompressible Navier-Stokes equations. Second-order spatial convergence confirmed. Taylor-Green vortex benchmark reproduces analytical solution to within 0.3% at the mesh densities used in production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 10% at the production mesh density.",
      "rationale": "Three-mesh Richardson extrapolation study performed on the FDA pump geometry. GCI for normalized index of hemolysis is 6.8% at the medium mesh (4.1 M cells) selected for production runs. Monotonic convergence confirmed with observed order of accuracy p = 1.87, consistent with second-order scheme."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to enable boundary condition specification in CFD model; fluid temperature, viscosity, and hematocrit must be reported.",
      "rationale": "In-vitro test conditions documented per ISO 10628: bovine blood at 37 °C, hematocrit 30 ± 2%, dynamic viscosity 3.2 mPa·s. Pump inlet pressure, flow rate, and rotational speed measured with calibrated instrumentation. All boundary conditions reproducible from published test report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with measured NIH within 25% across all five operating points; systematic bias must not exceed 15%.",
      "rationale": "Point-by-point comparison of predicted versus measured NIH at five flow-speed combinations yields maximum deviation of 18% and mean signed error of +4.2%, both within acceptance thresholds. Bland-Altman analysis confirms no operating-point-dependent bias."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation (NIH) must be directly linkable to the COU decision metric (relative hemolysis index RH).",
      "rationale": "NIH is the primary experimental hemolysis metric and is algebraically related to RH through device priming volume and operating duration. The monotonic relationship between NIH and RH has been established in published literature (Goubergrits & Affeld 2004). QoI relevance is therefore direct and fully documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the operating envelope of the COU (flow rates 2–6 L/min, speeds 2000–3500 RPM) with at least three interior points.",
      "rationale": "Validation dataset spans flow rates 2, 3, 4, 5, and 6 L/min at rotational speeds of 2500 and 3000 RPM, encompassing the full COU operating envelope. Three interior operating points included. Geometric configuration matches production device to within manufacturing tolerances. Relevance assessed as adequate for MRL 2."
    },
