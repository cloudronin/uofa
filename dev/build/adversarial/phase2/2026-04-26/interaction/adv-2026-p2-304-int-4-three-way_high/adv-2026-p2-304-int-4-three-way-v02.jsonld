  "hasClaim": [
    {
      "id": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
      "type": "Claim",
      "name": "CFD model reliably identifies worst-case hemolysis operating conditions for the FDA generic centrifugal pump at MRL 2",
      "description": "The CFD model, using SST k-ω turbulence closure and the Giersiepen power-law hemolysis damage accumulation model, predicts relative hemolysis index RH < 1 at all five clinical operating points, supporting the conclusion that the nominal design does not exceed predicate device hemolysis levels. The worst-case operating condition is identified as 3 L/min at 3000 RPM, consistent with experimental observations.",
      "claimType": "ModelAdequacyClaim"
    }
  ],
