      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems at MRL 2 fidelity.",
      "rationale": "Code verification performed against three ASME V&V 20 benchmark cases including lid-driven cavity and backward-facing step. Observed order of accuracy matches theoretical order for all benchmarks. No code defects identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for primary QoI with GCI < 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed (4 M, 8 M, 12 M elements). Richardson extrapolation yields GCI of 2.3% for NIH on the fine mesh. Discretization error is within acceptance threshold. Temporal discretization verified via time-step independence study at the highest rotational speed operating point."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to allow boundary condition specification in the CFD model.",
      "rationale": "In-vitro test conditions documented per ASTM F1841 including blood analog viscosity, hematocrit, temperature, and inlet flow waveform. All five operating points replicated in simulation boundary conditions with inlet velocity profiles derived from measured flow rates. Pump rotational speed uncertainty is ±0.5 RPM."
