      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for QOIs; GCI < 5% required for MRL 2 assessment.",
      "rationale": "Mesh refinement study conducted across three mesh densities (2M, 6M, 18M elements). GCI for wall shear stress — the primary hemolysis driver — was computed at 11.3%, exceeding the 5% threshold. Coarser mesh adopted for parametric sweep due to computational resource constraints. Discretization error remains above acceptable threshold but decision was recorded as Accepted without documented justification for the exceedance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope within defined tolerances; flow rate and rotational speed within ±5%.",
      "rationale": "Experimental data sourced from FDA benchmark dataset at 2500 RPM and 5 L/min. COU requires evaluation at 3500 RPM and up to 7 L/min. Operating conditions deviate substantially from validation envelope; no interpolation or extrapolation uncertainty quantification was performed. Test conditions factor achievedLevel is below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement (NIA) >= 0.85 for hemolysis index comparison between simulation and experimental data.",
      "rationale": "NIA of 0.91 achieved for normalized index of hemolysis (NIH) across five operating points in the validation dataset. Systematic bias of 4.2% identified and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs must directly correspond to clinical hemolysis risk metrics; relative hemolysis index (RH) must be the primary output.",
      "rationale": "Simulation outputs relative hemolysis index (RH) and normalized index of hemolysis (NIH), both directly relevant to clinical hemolysis risk assessment for CPB devices. QOIs align with FDA guidance on hemolysis evaluation."
    },
