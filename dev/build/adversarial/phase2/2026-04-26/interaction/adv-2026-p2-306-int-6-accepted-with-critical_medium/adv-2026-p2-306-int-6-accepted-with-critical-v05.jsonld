  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite with regression testing for blood pump applications.",
      "rationale": "ANSYS Fluent v2022R2 used with documented QA procedures including regression test suite. Software validation records confirm version control and change management protocols consistent with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least one benchmark verification case relevant to rotating machinery flows.",
      "rationale": "Code verification confirmed via lid-driven cavity and rotating Couette flow benchmarks. Spatial and temporal order of accuracy verified against analytical solutions, confirming second-order convergence for momentum equations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with at least three mesh refinement levels; GCI < 5% on primary hemolysis QoI.",
      "rationale": "Three-level mesh refinement study performed (3.2M, 8.1M, 18.4M cells). Richardson extrapolation yields GCI of 3.8% for normalized index of hemolysis at the design operating point, meeting the 5% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with flow rate, rotational speed, and fluid properties matching simulation inputs within stated tolerances.",
      "rationale": "Bench test conditions documented per ASTM F1841. Flow rates (2–6 L/min) and rotational speeds (2400–3600 RPM) match simulation boundary conditions within ±2%. Bovine blood hematocrit 33±2% used in both bench and simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within combined experimental and numerical uncertainty bounds across all 5 operating points.",
      "rationale": "CFD-predicted NIH values agree with experimental measurements at 4 of 5 operating points within combined uncertainty bounds. At the highest flow-speed combination (6 L/min, 3600 RPM), the predicted NIH of 0.0041 g/100L falls outside the experimental uncertainty interval of 0.0028–0.0037 g/100L. The assessment team attributed this to turbulence model limitations at elevated shear rates but judged the overall trend agreement sufficient for rank-ordering operating conditions. The decision was recorded as Accepted without escalating the assurance level or requiring additional validation activities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly traceable to the clinical hemolysis endpoint used in the regulatory submission.",
      "rationale": "Normalized index of hemolysis (NIH) and relative hemolysis index (RH) are the primary regulatory QoIs per FDA guidance. Both are computed directly from CFD shear stress and exposure time fields using the Giersiepen power-law model, ensuring direct traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry and operating envelope as the COU.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry identical to the COU device. Operating conditions span the full clinical flow-speed envelope. Fluid properties representative of diluted bovine blood used in both experimental and computational work."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor beyond code verification activities already captured.",
      "rationale": "At MRL 2, separate numerical solver error characterization beyond code verification is not required. Iterative convergence monitored via residual reduction of six orders of magnitude and mass imbalance below 0.01%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
