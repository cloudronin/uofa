      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation setup reviewed by independent analyst.",
      "rationale": "Independent analyst review of simulation setup (boundary conditions, turbulence model selection, MRF interface placement) completed. No use errors identified. Formal use-error quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
