  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 or equivalent QMS certification with documented V&V test suite for cardiovascular CFD applications.",
      "rationale": "ANSYS Fluent 2023R1 is used under a documented QMS with regression test suite covering rotating-zone hemolysis cases. Software version control and audit trail are maintained. Required level 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification on canonical rotating flow case demonstrating second-order spatial convergence.",
      "rationale": "Method-of-manufactured-solutions study on a simplified impeller geometry confirms second-order spatial accuracy for velocity and pressure fields. Temporal discretization verified with first-order backward Euler for steady-state MRF approach. Required level 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% on hemolysis index QoI across three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study (2.1 M, 5.8 M, 14.4 M cells) yields GCI of 2.3% on the normalized hemolysis index at the nominal operating point. Richardson extrapolation confirms monotonic convergence. Exceeds required level 2 threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) documented with measurement uncertainty < 3% for all controlled parameters.",
      "rationale": "FDA GCBP experimental data reports inlet flow rate controlled to ±1.5%, rotational speed to ±0.5%, and fluid temperature to ±0.3°C. Bovine blood viscosity measured per ASTM F1841. Conditions are adequately characterized for MRL 2 comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric comparison (normalized hemolysis index) with statistical agreement measure (E% < 15%) across all 5 operating points, including uncertainty propagation from experimental scatter.",
      "rationale": "Predicted normalized hemolysis index agrees within 12–18% of experimental values across the 5 flow-speed combinations. Two of the five operating points exceed the 15% threshold, with the worst-case deviation reaching 18.4% at the high-flow, low-speed condition. Experimental uncertainty bands are reported but formal uncertainty propagation through the power-law hemolysis model has not been completed. The comparison metric is computed but the statistical framework required at level 3 — including confidence intervals on the model-form error — is absent. Achieved level 2 (qualitative agreement documented) does not meet required level 3.",
      "note": "This shortfall is the sole factor below its required level. The overall assessment proceeds to Accepted on the basis that the deviations are within engineering judgment tolerances, without formal justification for accepting a below-threshold factor — the key weakness targeted by W-AR-02."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized hemolysis index RH) directly maps to the clinical endpoint and is defined consistently between simulation and experiment.",
      "rationale": "The normalized hemolysis index RH is computed identically in simulation (power-law integration along pathlines) and experiment (modified index of hemolysis converted per ASTM F1841). The QoI directly supports the regulatory acceptance criterion RH < 1 relative to predicate device. Required level 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the same device geometry and fluid (bovine blood surrogate) at operating conditions spanning the COU envelope.",
      "rationale": "Validation uses the FDA GCBP geometry at five operating points that bracket the intended CPB flow-speed envelope (3–6 L/min, 2000–3500 rpm). Fluid properties match the COU blood surrogate specification. Validation domain is directly representative of the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
