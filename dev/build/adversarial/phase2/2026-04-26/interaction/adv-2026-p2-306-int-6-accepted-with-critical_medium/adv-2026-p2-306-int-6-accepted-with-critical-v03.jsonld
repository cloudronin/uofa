  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026-04",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Twelve of thirteen factors meet or exceed their required levels. The output comparison factor achieves level 2 against a required level 3; however, the team judged that the observed deviations (12–18% across operating points) fall within acceptable engineering tolerances for a Class II device at MRL 2 and that the relative hemolysis index criterion (RH < 1) is met at all five operating points. On this basis the model is accepted for the stated COU. The assurance level is recorded as Medium, consistent with MRL 2 and the Class II device classification.",
