  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 factors at MRL 2. Twelve factors meet or exceed their required levels. The discretization error factor achieves Gradation 2 against a required Gradation 3; however, the team accepted this shortfall on the basis that (a) the GCI exceedance is confined to a single operating point where hemolysis is conservatively over-predicted, (b) supplementary mesh sensitivity data demonstrate monotonic convergence, and (c) the overall assurance level of Medium is consistent with the device risk classification. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
