  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 factors. Twelve of thirteen factors meet or exceed their required credibility levels. The discretization error factor achieved level 2 against a required level 3; however, the team judged that the GCI exceedances occur only at operating points not identified as worst-case for the hemolysis index, and that the overall prediction accuracy (Output comparison factor, level 3) provides sufficient compensating evidence. On this basis the team accepted the model for the stated COU at Medium assurance. The shortfall in discretization error is documented and flagged for resolution in the next model revision cycle.",
