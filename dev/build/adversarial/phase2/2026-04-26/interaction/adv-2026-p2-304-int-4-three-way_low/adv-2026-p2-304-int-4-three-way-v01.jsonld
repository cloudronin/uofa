  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be validated and version-controlled; documentation of QA procedures required at MRL 2.",
      "rationale": "ANSYS Fluent 2023R1 used under ISO 9001-compliant QA framework. Version control via Git and release notes documented. All solver regression tests passed for hemolysis-relevant flow regimes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must confirm correct implementation of governing equations for blood flow and hemolysis transport at MRL 2.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver and Giersiepen-Wurzinger hemolysis power-law model. Observed order of convergence matches theoretical order within 5% for all test cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study required; GCI must be reported for hemolysis index QoI at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (coarse 1.2M, medium 3.1M, fine 7.8M elements). GCI for hemolysis index at worst-case operating point is 3.2%, within the 5% threshold. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and matched to CFD boundary conditions within acceptable tolerances.",
      "rationale": "In-vitro test conditions documented per ASTM F1841. Flow rates controlled to ±0.05 L/min, rotational speed to ±10 RPM. Blood analogue (glycerol-water 36% v/v) viscosity characterised at 37°C. CFD boundary conditions set to match measured values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., relative hemolysis index RH) must be defined and evaluated against acceptance threshold.",
      "rationale": "Relative hemolysis index RH computed as ratio of model-predicted MIH to experimentally measured MIH for predicate device. RH < 1 at all 5 operating points confirms model does not underpredict hemolysis risk. Maximum RH = 0.95 at worst-case point."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to clinical hemolysis endpoints and regulatory acceptance criteria.",
      "rationale": "Modified index of hemolysis (MIH) and relative hemolysis index (RH) are the primary QoIs. Both are directly linked to plasma-free haemoglobin thresholds in FDA guidance for blood-contacting devices. QoI selection validated against ISO 10993-4 endpoints."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the operating envelope defined in the COU including all 5 flow-speed combinations.",
      "rationale": "Validation performed at all 5 COU-specified operating points (3–6 L/min, 2400–3200 RPM). Pump geometry matches production tolerances. Blood analogue properties representative of clinical conditions. Validation domain encompasses the full COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver error subsumed under code verification activities.",
      "rationale": "At MRL 2, separate numerical solver error assessment is not mandated. Solver accuracy addressed through code verification and discretization error activities. Scoped out per MRL 2 factor matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; use error controls addressed through SQA and analyst training records.",
      "rationale": "Use error assessment not required at MRL 2. Analyst competency documented via training records and internal peer review. SQA procedures provide sufficient control at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty must be characterised; turbulence and hemolysis sub-model selection must be justified for the COU.",
      "rationale": "SST k-omega turbulence model selected based on benchmark comparisons for confined rotating flows. Giersiepen-Wurzinger hemolysis power-law model validated against published erythrocyte fragility data. Model form uncertainty estimated at ±12% on MIH, acceptable for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be documented with sources and uncertainty ranges; sensitivity to key inputs must be assessed.",
      "rationale": "Blood viscosity, density, and hemolysis model constants characterised from literature and in-house measurements. One-at-a-time sensitivity analysis performed for all 8 primary inputs. Hemolysis index most sensitive to power-law exponent (±8% variation over ±10% input range)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for in-vitro blood analogue studies; sample variability addressed through replicate testing.",
      "rationale": "Test sample assessment not required at MRL 2. Three replicate experiments performed at each operating point; coefficient of variation <4% confirms acceptable repeatability without formal sample characterisation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency addressed through test conditions factor assessment.",
      "rationale": "Equivalency of input parameters not separately assessed at MRL 2. Boundary condition matching documented under Test Conditions factor. Dimensional tolerances confirmed within ±0.05 mm of nominal geometry."
    }
