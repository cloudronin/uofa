  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must operate under a documented QA plan with version-controlled source, regression test suite, and traceable change log consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2023 R2 is deployed under the laboratory QA plan rev 4.1. Version control is maintained in the institutional GitLab repository; a 47-case regression suite was executed with zero critical failures. QA documentation package archived at DOI 10.17632/cpb-sqa-2024."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions (MMS) or equivalent benchmark with errors within expected convergence order.",
      "rationale": "ANSYS Fluent has published MMS verification results for incompressible Navier-Stokes and species transport. Internal replication of the lid-driven cavity benchmark (Re = 1000) yielded L2 velocity error 1.8e-4, consistent with second-order spatial accuracy. Code verification requirement satisfied at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary QoI (volume-averaged scalar stress proxy) must be below 5% on the medium mesh used for production runs.",
      "rationale": "Three-level mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.3M cells) performed at the nominal operating point (5 L/min, 3000 RPM). GCI on the volume-averaged hemolysis index: 3.2% (medium-to-fine). Richardson-extrapolated value used as reference. Discretization error criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) must be documented with measurement uncertainty and replicated in simulation inputs within ±5% of nominal values.",
      "rationale": "FDA generic pump experimental data (Herbertson et al. 2015) provides boundary conditions at 5 flow-speed combinations. Fluid temperature 37 °C ± 0.5 °C, hematocrit 30 ± 2%. All simulation boundary conditions set within ±3% of reported experimental values. Test condition documentation complete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within ±15% across all 5 operating points, with systematic bias characterised and within ±10%.",
      "rationale": "Predicted NIH values agree with experimental data at 4 of 5 operating points within ±12%. At the highest-shear operating point (6 L/min, 3500 RPM) the model underpredicts NIH by 18.4%, marginally exceeding the ±15% acceptance band. Systematic bias across all points is +2.1% (within criterion). The single-point exceedance is attributed to transitional flow features not fully captured by the k-ω SST turbulence closure at elevated Reynolds numbers. A sensitivity study using the BSL Reynolds-stress model reduced the discrepancy to 14.9% but was not adopted for the production suite due to convergence instability. The assessment team concluded that overall agreement is adequate; however, the achieved gradation is recorded as 1 (one step below the required level of 2) pending resolution of the high-shear operating point underprediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from the simulation (NIH, volume-averaged scalar stress, relative hemolysis index RH) must map directly to the clinical and regulatory acceptance criteria stated in the COU.",
      "rationale": "Primary QoI is the relative hemolysis index RH = NIH_device / NIH_predicate. This maps directly to the COU acceptance criterion RH < 1. Secondary QoIs (volume-averaged scalar stress, exposure time distribution) provide mechanistic insight. All QoIs are standard in the blood-contacting device CFD literature and align with FDA guidance on hemolysis assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry class (centrifugal, Class II), comparable operating ranges, and the same hemolysis measurement protocol as the intended COU.",
      "rationale": "Validation uses the FDA generic centrifugal pump — the same geometry family as the COU device. Operating range (3–6 L/min, 2500–3500 RPM) overlaps the COU operating envelope. NIH measured via modified Harboe spectrophotometric method in both validation experiments and COU comparator data. Relevance of validation activities is high; Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 with medium model influence, formal iterative convergence monitoring is sufficient; solver error quantification beyond residual tracking is not required.",
      "rationale": "Not assessed at MRL 2. Iterative convergence monitored via mass-flow residuals (< 1e-5) and QoI stabilisation over final 500 iterations. No further solver error quantification required per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 with medium model influence, peer review of simulation setup is sufficient; formal use-error analysis is not required.",
      "rationale": "Not assessed at MRL 2. Simulation setup reviewed by a second qualified CFD engineer. No formal use-error analysis required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documented selection rationale for governing equations and turbulence closure is sufficient; formal model-form uncertainty quantification is not required.",
      "rationale": "Not assessed at MRL 2. k-ω SST turbulence closure selected based on literature consensus for internal rotating flows. Model form selection documented in the simulation plan. No further model-form UQ required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; probabilistic input uncertainty propagation is not required.",
      "rationale": "Not assessed at MRL 2. Fluid properties (viscosity, density) and power-law hemolysis model coefficients sourced from peer-reviewed literature with documented provenance. Nominal values used throughout. No probabilistic UQ required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use of a single well-characterised experimental dataset with documented sample preparation is sufficient.",
      "rationale": "Not assessed at MRL 2. FDA generic pump experimental dataset (Herbertson et al. 2015, n = 3 replicates per operating point) used. Sample preparation protocol documented. No inter-laboratory or multi-batch sample analysis required at this risk level."
    },
    {
