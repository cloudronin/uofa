  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-mrl2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Seven factors were assessed; six were scoped to not-assessed per MRL 2 requirements. The Output Comparison factor achieved level 1 against a required level 2 due to the NIH discrepancy at the highest operating point. The team accepted this shortfall on the basis that the prediction error is conservative (over-prediction of hemolysis), the discrepancy affects only one of five operating points, and the overall model behavior supports identification of worst-case conditions. The model is deemed fit for the stated COU.",
