  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for MRL 2. Seven factors were formally assessed; six were appropriately scoped out at MRL 2. Six of the seven assessed factors met their required gradation levels. The discretization error factor achieved Gradation 1 against a required Gradation 2; however, the team determined that the observed GCI of 7.3% represents a borderline shortfall with monotonic convergence behavior, and that the overall validation evidence—including strong output comparison agreement across all five operating points—provides sufficient confidence to support the Accepted decision for the intended regulatory submission. The assurance level is recorded as Medium consistent with the MRL 2 classification and Medium model influence.",
