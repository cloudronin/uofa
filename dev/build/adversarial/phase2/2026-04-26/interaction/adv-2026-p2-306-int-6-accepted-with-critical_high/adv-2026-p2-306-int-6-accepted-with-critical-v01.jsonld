      "acceptanceCriteria": "SQA level 1 requires documented version control and regression testing suite for CFD solver.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated institutional SQA plan with version-controlled case files and automated regression tests confirming solver build integrity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
