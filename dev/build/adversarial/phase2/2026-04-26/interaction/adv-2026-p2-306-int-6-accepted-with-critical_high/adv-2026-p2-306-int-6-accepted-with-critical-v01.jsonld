      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark verification cases (e.g., lid-driven cavity, Poiseuille flow) at required accuracy.",
      "rationale": "ANSYS Fluent has been verified against ASME V&V 20 benchmark cases. Published verification reports confirm second-order spatial accuracy on structured meshes relevant to internal rotating machinery."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrating GCI < 5% on hemolysis index QoI across at least three systematically refined mesh levels.",
      "rationale": "A mesh refinement study was conducted using two mesh levels (3.2 M and 6.8 M elements). The observed GCI on the relative hemolysis index was 7.3%, marginally exceeding the 5% threshold. The team judged this acceptable given the monotonic convergence trend and proximity to the criterion, and the decision record reflects acceptance without further refinement. A third mesh level at 14 M elements was not pursued due to computational resource constraints, leaving the discretization error factor one gradation below the required level for MRL 2 with High decision consequence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) match COU operating envelope within specified tolerances.",
      "rationale": "All five flow-speed operating points were replicated in the FDA experimental dataset within ±2% of target flow rate and ±5 RPM of target rotational speed. Blood analog fluid viscosity and density were matched to within measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index RH within ±15% of experimental measurement across all five operating points.",
      "rationale": "Predicted RH values ranged from 0.81 to 1.09 against experimental references of 0.85 to 1.12. Maximum relative error was 9.4%, satisfying the ±15% acceptance criterion at all five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical hemolysis endpoint; scalar hemolysis index derived from validated power-law damage model.",
      "rationale": "The relative hemolysis index is directly linked to the clinical endpoint of plasma free hemoglobin elevation. The Giersiepen-Wurzinger power-law model is the accepted standard for CFD hemolysis prediction in rotary blood pumps and is the QoI specified in the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
