  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 factors. Seven factors were formally assessed; six were not assessed per the MRL 2 assessment plan. Six of the seven assessed factors met or exceeded their required levels. The discretization error factor achieved Level 1 against a required Level 2 (GCI of 7.2% versus the 5% threshold). The team determined that the monotonic convergence behavior and the conservative margin on the primary acceptance criterion (RH < 1) across all mesh levels provided sufficient confidence that the shortfall did not materially affect the decision. The overall credibility is judged adequate at Medium assurance level for the intended COU. Decision: Accepted.",
