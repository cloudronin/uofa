  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-int6",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at Model Risk Level 2. Seven factors were formally assessed; six were scoped out per Table 1 guidance for Medium model influence. The Output Comparison factor achieved Gradation 1 against a Gradation 2 requirement; however, the team determined that the single non-conforming operating point (4500 RPM, 3 L/min) represents an off-design condition outside the primary worst-case hemolysis envelope and that the 18.4% deviation is conservative in the direction of over-predicting hemolysis risk. On this basis the team accepted the model as fit for the stated COU. All remaining assessed factors met or exceeded their required gradation levels. The assurance level is recorded as Medium consistent with the MRL 2 classification and Medium model influence designation.",
