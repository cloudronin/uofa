      "rationale": "ANSYS Fluent 2022 R2 with documented SQA procedures including version-controlled case files, automated regression suite covering 98% of solver modules, and formal change control log. Meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarks against published analytical solutions demonstrate convergence and correctness for rotating machinery flows.",
      "rationale": "Fluent solver verified against Taylor-Couette and lid-driven cavity benchmarks. Observed order of convergence matches theoretical order (p=1.98 vs expected 2.0) for the k-omega SST turbulence model. Meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
