  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Seven factors were formally assessed; six were scoped as not-assessed per MRL 2 requirements. The output comparison factor achieved level 1 against a required level of 2, representing a one-step shortfall attributable to the single outlier operating point at peak shear conditions. The team determined that this shortfall does not compromise the primary COU objective of identifying relative worst-case hemolysis ranking across operating conditions, as the rank ordering of all five operating points is preserved and consistent with experimental trends. The overall assurance level is assessed as Medium, reflecting the minor gap in absolute predictive accuracy while maintaining confidence in the comparative ranking outcome. The model is accepted for the stated COU with the noted limitation on absolute NIH prediction accuracy at extreme operating conditions.",
