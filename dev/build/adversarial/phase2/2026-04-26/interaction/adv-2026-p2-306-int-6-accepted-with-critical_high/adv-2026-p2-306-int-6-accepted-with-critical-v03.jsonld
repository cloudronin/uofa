  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 factors. Twelve of thirteen factors meet or exceed required levels. The output comparison factor achieves Gradation 1 against a required Gradation 2; however, the team determined that the observed discrepancy is attributable to minor geometric variability in the physical test article rather than a fundamental model deficiency. Trend agreement across all five operating points is consistent and the hemolysis ranking of operating conditions is preserved. Given the supporting evidence from mesh convergence, solver verification, and relevance of validation activities, the team accepted the model for the stated COU with the noted limitation documented in the project record. Assurance level is assessed as Medium consistent with MRL 2 and Class II device classification.",
