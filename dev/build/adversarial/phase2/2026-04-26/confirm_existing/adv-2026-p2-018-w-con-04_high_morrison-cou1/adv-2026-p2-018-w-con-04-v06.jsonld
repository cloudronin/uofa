    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI for NIH quantity of interest must be below 5% on the production mesh.",
      "rationale": "Three-level structured mesh refinement with GCI analysis per Roache (1998). GCI_fine = 2.1% for NIH at the design operating point (6 LPM, 3500 RPM). All five operating points exhibit GCI below 4.8%. Production mesh (7.8M cells) adopted as medium-grid solution with confirmed convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope within documented tolerances; fluid properties must be characterised.",
      "rationale": "FDA benchmark experiments conducted at 37°C with bovine blood analogue (glycerol-water, viscosity 3.5 cP ± 0.2 cP). Operating points 3–7 LPM at 2500–3500 RPM bracket the CPB COU envelope. Temperature and fluid property deviations documented and assessed as acceptable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must fall within ±15% of experimental mean at all five validation operating points; RH < 1 criterion satisfied.",
      "rationale": "CFD NIH predictions within 9.3% of experimental mean across all five operating points. RH < 1 at all points (range 0.71–0.94). Systematic under-prediction of 4–6% at low-flow conditions attributed to secondary recirculation; magnitude within acceptance band. Output comparison formally documented in VR-01."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
