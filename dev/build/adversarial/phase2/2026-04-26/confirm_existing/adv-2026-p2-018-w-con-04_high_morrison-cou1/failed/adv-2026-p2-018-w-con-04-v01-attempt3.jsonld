  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-benchmark-fda-pump",
      "type": "ValidationResult",
      "name": "FDA generic pump hemolysis benchmark validation",
      "description": "CFD predictions of normalized index of hemolysis (NIH) compared against FDA interlaboratory experimental data at five operating points. Mean relative error 8.3%; all predictions within experimental uncertainty bands. UQ campaign included 200-sample Latin hypercube sweep across six geometric and boundary-condition parameters; Sobol sensitivity indices computed showing dominance of flow rate and rotational speed with combined first-order indices > 0.91."
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-gci",
      "type": "ValidationResult",
      "name": "Grid convergence index study — three mesh levels",
      "description": "Three systematically refined meshes (3.2M, 8.7M, 22.1M cells) evaluated using GCI methodology per Celik et al. 2008. GCI for NIH < 2.1% on fine grid. Observed order of convergence p = 1.87, consistent with second-order spatial discretization."
    },
    {
      "id": "https://uofa.net/morrison/validation/uq-parametric-sweep",
      "type": "ValidationResult",
      "name": "UQ parametric sensitivity campaign — geometric tolerance study",
      "description": "Two-hundred CFD runs spanning ±3-sigma manufacturing tolerances on impeller tip clearance, blade trailing-edge radius, and volute cutwater gap. Results demonstrate that RH index remains below 1.0 across 97.4% of the sampled design space, supporting the tolerance acceptance decision. Sensitivity rankings and confidence intervals documented in technical report TR-2024-CPB-UQ-07. Note: full structured sensitivity analysis metadata is captured in technical report TR-2024-CPB-UQ-07 and summarised within this validation result node."
    }
  ],
