  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence and discretization error assessment",
      "description": "Three-level mesh refinement study on the FDA generic centrifugal pump geometry. GCI values below 2.1% for all hemolysis-relevant quantities of interest. Richardson extrapolation applied to confirm asymptotic convergence. UQ campaign confirmed that mesh-induced uncertainty was subordinate to inlet boundary-condition variability across all 5 operating points."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-hemolysis-experimental",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against in-vitro experiments",
      "description": "CFD-predicted normalised index of haemolysis (NIH) compared against in-vitro measurements from the FDA pump benchmark dataset at 2500 rpm and 4 L/min, 5 L/min, and 6 L/min. Mean absolute relative error 8.3%. Relative hemolysis index RH < 1 satisfied at all tested conditions. The accompanying UQ ensemble (Latin-hypercube, 128 samples) bracketed experimental scatter within the 90th-percentile prediction interval, providing additional confidence that the model captures worst-case hemolysis trends."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-turbulence-model",
      "type": "ValidationResult",
      "name": "Turbulence model form assessment — SST k-omega vs. RSM",
      "description": "SST k-omega and Reynolds Stress Model predictions compared for the high-shear impeller passage. Hemolysis index difference < 4% between models. SST k-omega selected as primary model. UQ sensitivity runs confirmed that turbulence-model choice contributes less than 6% to total output variance, subordinate to geometric tolerance uncertainty."
    }
  ],
