      "id": "https://uofa.net/morrison/validation/vr-01-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — Richardson extrapolation GCI < 2% on hemolysis index",
      "description": "Three-level mesh refinement study on the FDA generic centrifugal pump geometry. Grid convergence index (GCI) computed via Richardson extrapolation yielded GCI_fine = 1.7% for the volume-averaged scalar stress metric used in hemolysis prediction. Confirms discretization error is within acceptable bounds for MRL 2.",
      "outcome": "Passed"
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index comparison against NIH benchmark data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against published FDA/NIH experimental measurements for the generic centrifugal pump at 5 flow-speed operating points. Mean relative error 8.3%, maximum 14.1%. All predictions within two experimental standard deviations. RH < 1 criterion satisfied at all worst-case operating conditions.",
      "outcome": "Passed"
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-uq-campaign",
      "type": "ValidationResult",
      "name": "UQ campaign — one-at-a-time sensitivity sweeps across impeller clearance and rotational speed",
      "description": "A structured uncertainty quantification campaign was executed covering ±15% variation in impeller tip clearance and ±10% variation in rotational speed across all five CPB operating points. One-at-a-time sweeps confirmed monotonic hemolysis response to flow rate. Latin hypercube sampling (n=50) was used to characterise joint parameter uncertainty. Results corroborate the RH < 1 acceptance criterion across the explored design space and are archived in the project UQ report (Morrison et al., 2024, internal report MOR-UQ-2024-03). Note: structured sensitivity analysis results are summarised narratively here; the formal hasSensitivityAnalysis link to the UQ dataset is pending final report approval and has not been included in this package version.",
      "outcome": "Passed"
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-04-code-verification",
      "type": "ValidationResult",
      "name": "Code verification — manufactured solution test on Navier-Stokes solver",
      "description": "Method of manufactured solutions applied to the RANS solver for laminar and low-Re turbulent flow. Second-order spatial convergence confirmed. No coding errors detected in stress tensor computation used by the hemolysis power-law model.",
      "outcome": "Passed"
    }
