  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error assessment",
      "description": "Richardson extrapolation applied across three systematically refined meshes (2.1M, 6.8M, 18.4M cells). Grid convergence index (GCI) computed for hemolysis index at all five operating points. Maximum GCI of 3.2% confirms discretization error within acceptable bounds for MRL 2."
    },
    {
      "id": "https://uofa.net/morrison/validation/experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental hemolysis index validation against FDA benchmark data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against published FDA generic pump experimental measurements at 2.5 L/min 2500 RPM, 5 L/min 2500 RPM, 5 L/min 3500 RPM, 7 L/min 2500 RPM, and 7 L/min 3500 RPM. Mean absolute relative error of 8.7% across all operating points. All predictions fall within experimental uncertainty bounds."
    },
    {
      "id": "https://uofa.net/morrison/validation/uq-campaign",
      "type": "ValidationResult",
      "name": "Uncertainty quantification campaign across dimensional tolerance envelope",
      "description": "A comprehensive UQ campaign was executed using Latin hypercube sampling (n=128 samples) across the full dimensional tolerance space for impeller diameter, blade clearance, volute width, and inlet geometry. Sobol sensitivity indices were computed for each geometric parameter with respect to predicted NIH. The campaign confirmed that blade tip clearance is the dominant contributor (S1=0.61) to hemolysis variability. All 128 sample predictions satisfied RH < 1 relative to the predicate device. The UQ results provide high confidence that worst-case hemolysis conditions are bounded within the tolerance envelope studied. Detailed sensitivity index tables and convergence diagnostics are archived in the supporting technical report TR-2024-CPB-UQ-01."
    },
    {
      "id": "https://uofa.net/morrison/validation/predicate-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against predicate device",
      "description": "Relative hemolysis index (RH) computed as ratio of device NIH to predicate device NIH for all five operating points. Maximum RH = 0.84 at 7 L/min 3500 RPM, satisfying RH < 1 acceptance criterion at all conditions. Decision: model credibly supports identification of worst-case hemolysis operating conditions."
    }
  ],
