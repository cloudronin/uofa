      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for hemolysis index QoI at all operating points using systematic mesh refinement with refinement ratio >= 1.3. Required level 2 for MRL 2.",
      "rationale": "Three-mesh Richardson extrapolation performed with refinement ratio 1.44. GCI values: 3.2% (worst case at 7 L/min 3500 RPM), 1.8% (best case at 2.5 L/min 2500 RPM). All GCI values below 5% threshold. Achieved level 3 through formal GCI with safety factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce boundary conditions in CFD model. Fluid properties, rotational speed, and flow rates measured with calibrated instrumentation. Required level 2.",
      "rationale": "FDA benchmark experimental data includes fully documented test conditions: bovine blood at 37°C, viscosity 3.5 cP, density 1060 kg/m3. Flow rates measured with Coriolis meter (±0.5% accuracy). Rotational speed measured with optical tachometer (±5 RPM). All boundary conditions reproducible from published test protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MARE, RMSE) must be computed between CFD predictions and experimental measurements for primary QoI. Required level 2.",
      "rationale": "MARE of 8.7% computed across all five operating points for NIH. Maximum absolute relative error 14.2% at 2.5 L/min 2500 RPM, within experimental measurement uncertainty of ±15%. Validation metric formally computed and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI must be directly relevant to COU QoI. NIH used in validation must map to RH used in COU decision. Required level 2.",
      "rationale": "Validation uses NIH (normalized index of hemolysis) which is the direct experimental analog of the CFD-computed hemolysis index. RH is computed as ratio of device NIH to predicate NIH, maintaining direct traceability from validation QoI to decision QoI. Relevance confirmed by clinical expert review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the operating envelope of the COU including flow rates and rotational speeds representative of CPB clinical use. Required level 2.",
      "rationale": "Validation operating points (2.5-7 L/min, 2500-3500 RPM) bracket the clinical CPB operating range (3-6 L/min, 2800-3200 RPM). FDA generic pump geometry is representative of the device class. Validation activities are directly relevant to COU operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals reduced by at least 4 orders of magnitude and monitored QoI stable to within 0.1% over final 500 iterations. Required level 1.",
      "rationale": "All simulations converged with continuity residual below 1e-5 and momentum residuals below 1e-6. NIH monitor stable to within 0.05% over final 1000 iterations for all five operating points. Convergence criteria met at required level 1."
    },
