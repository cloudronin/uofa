    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., NRMSE or percentage error) reported for each QoI; acceptance threshold defined a priori.",
      "rationale": "Pressure head NRMSE 3.2 %; hemolysis index mean absolute error 8.7 % relative to experimental NIH values. Both within pre-specified 10 % acceptance thresholds defined in test plan TP-2024-CPB. PIV velocity NRMSE 6.8 % within 10 % threshold."
    },
    {
