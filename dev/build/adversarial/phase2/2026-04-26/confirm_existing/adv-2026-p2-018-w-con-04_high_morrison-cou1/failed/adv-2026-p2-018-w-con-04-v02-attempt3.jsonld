  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High",
    "deviceClass": "Class II"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-pressure-head",
      "type": "ValidationResult",
      "name": "Pressure-head validation against FDA pump experimental data",
      "description": "CFD-predicted pressure head compared to experimental measurements at 5 operating points. Mean absolute error 3.2 %; all points within 5 % acceptance band. UQ campaign (Latin hypercube, n=200) confirmed low sensitivity of pressure head to mesh density beyond 4.2 M cells."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation — RH < 1 criterion",
      "description": "Predicted relative hemolysis index RH compared against predicate device experimental hemolysis data. All 5 operating points yield RH < 1. Parametric sensitivity to power-law exponent in Giersiepen-Wurzinger model evaluated in UQ campaign; results documented in supplementary report UQ-2024-CPB-01."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-velocity-piv",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements",
      "description": "Simulated velocity magnitude contours compared with particle image velocimetry data at mid-plane cross-section. Normalized RMS error 6.8 % across measured domain. Turbulence model sensitivity (SST k-omega vs. realizable k-epsilon) assessed qualitatively in UQ campaign narrative."
    }
  ],
  "hasCredibilityFactor": [
