  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-grid-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence and discretisation error assessment",
      "description": "Richardson extrapolation applied to three systematically refined meshes (4.2 M, 11.7 M, 31.4 M cells). Grid convergence index (GCI) for the relative hemolysis index at the five COU operating points ranged from 0.8 % to 2.3 %, well within the 5 % acceptance threshold. The UQ campaign confirmed that mesh-induced variance contributes less than 4 % of total output variance across all operating points."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental benchmark comparison — FDA pump hemolysis",
      "description": "CFD predictions of the normalised index of hemolysis (NIH) were compared against published FDA interlaboratory experimental data for the generic centrifugal pump at 2500 rpm and 3500 rpm. Predicted NIH values fell within one experimental standard deviation for 4 of 5 operating points. The fifth point exhibited a 7 % over-prediction, attributed to unresolved secondary-flow features at low flow rate; this conservatism is acceptable for worst-case identification. The integrated UQ campaign, which propagated inlet velocity and viscosity uncertainties through 256 LHS samples, confirmed that the experimental data lie within the 90 % prediction interval at all five points, supporting model adequacy for the COU."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-turbulence-model-verification",
      "type": "ValidationResult",
      "name": "Turbulence model code verification — manufactured solution",
      "description": "The SST k-omega implementation was verified against a manufactured analytical solution using the method of manufactured solutions (MMS). L2 norm of velocity error exhibited second-order convergence on four successively refined grids, confirming correct code implementation. No defects identified."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-04-uq-campaign-summary",
      "type": "ValidationResult",
      "name": "Uncertainty quantification campaign — operating condition sensitivity",
      "description": "A 256-sample Latin hypercube UQ campaign was executed to characterise output sensitivity to the six most influential input parameters: inlet flow rate, rotational speed, blood viscosity, hematocrit, power-law hemolysis model coefficients (C and alpha). Sobol first-order and total-order indices were computed via polynomial chaos expansion (PCE, order 4). Rotational speed and flow rate together account for 71 % of total RHI variance. Hemolysis model coefficients contribute 22 %. Geometric tolerances contribute less than 4 %. These findings are documented in the factor rationale entries for Model Inputs and Model Form below. The structured hasSensitivityAnalysis link is not populated in this package version; the PCE-derived index rankings are embedded within the ValidationResult and CredibilityFactor narratives."
    }
  ],
