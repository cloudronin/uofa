      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with traceable calibration records for flow, pressure, and rotational speed instrumentation; fluid temperature controlled within ±1°C.",
