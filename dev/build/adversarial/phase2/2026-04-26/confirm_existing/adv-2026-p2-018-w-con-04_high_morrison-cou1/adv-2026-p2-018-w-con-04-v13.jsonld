  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scope. Discretization error achieves level 3, providing additional margin. The UQ campaign documented in the validation report confirms that the two dominant sensitivity drivers (tip clearance, inlet swirl) are bounded within the validated operating envelope, supporting confidence in the worst-case hemolysis prediction. The relative hemolysis index satisfies RH < 1 at all five operating points with a maximum E% of 11.7%. The credibility assessment team concludes the CFD model is fit for the stated COU at the Medium assurance level.",
