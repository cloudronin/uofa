  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/dr-sarah-morrison",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. Six factors are appropriately scoped as not-assessed at this risk level. The validation evidence, including bench-scale hemolysis comparison at five operating points and PIV velocity field comparison, provides sufficient confidence that the CFD model can reliably identify worst-case hemolysis conditions within the CPB operating envelope. The UQ campaign results documented in the validation report appendix further support robustness of predictions across the geometric tolerance space. The relative hemolysis index criterion (RH < 1) is satisfied at all evaluated conditions. The assessment team concludes that the model credibility is adequate for the intended regulatory submission supporting the Class II CPB device 510(k).",
    "decidedAt": "2026-04-19T00:00:00Z"
