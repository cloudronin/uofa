    "https://uofa.net/morrison/data/fda-pump-geometry-v2",
    "https://uofa.net/morrison/data/piv-validation-dataset",
    "https://uofa.net/morrison/data/hemolysis-experimental-rh"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 2500 RPM / 5 L/min",
      "description": "Particle image velocimetry measurements at the pump impeller mid-plane compared against CFD velocity predictions. Mean absolute error 4.2% of bulk velocity; 97.3% of measurement points within expanded uncertainty band. UQ ensemble (128 LHS samples) showed Sobol index for impeller tip clearance of 0.41, identifying clearance as dominant hemolysis driver."
    },
    {
      "id": "https://uofa.net/morrison/validation/hemolysis-rh-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index (RH) comparison across 5 operating points",
      "description": "Predicted RH values compared against in-vitro hemolysis measurements for all five flow-speed combinations. All predicted RH values less than 1.0 (range 0.61–0.94); experimental RH range 0.58–0.91. Model over-predicts hemolysis by median 4.8%, providing conservative margin. The UQ campaign confirmed that parametric uncertainty in power-law hemolysis constants contributes less than 8% variance to RH predictions across the operating envelope."
    },
    {
      "id": "https://uofa.net/morrison/validation/grid-convergence-study",
      "type": "ValidationResult",
      "name": "Grid convergence index study — three-level mesh refinement",
      "description": "Three mesh densities (2.1M, 6.4M, 18.7M cells) evaluated using Richardson extrapolation. GCI for hemolysis scalar on fine-to-medium transition is 1.3%, satisfying the MRL 2 discretization error requirement. Iterative convergence verified to residual norms below 1e-6."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035672",
