  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-piv-flowfield",
      "type": "ValidationResult",
      "name": "PIV flow-field comparison — FDA pump benchmark",
      "description": "Steady-state RANS simulation velocity profiles compared against particle image velocimetry data at 3 axial planes. Mean velocity error < 8% across all measurement stations. The UQ campaign (Latin-hypercube sampling, 120 CFD runs) confirmed that hemolysis index variance attributable to inlet boundary uncertainty remained below 4% of the nominal RH value, supporting the credibility conclusion. Spatial convergence index reported for each validation plane."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-hemolysis-rh",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against in-vitro data",
      "description": "Predicted RH values at 5 flow-speed operating points compared against in-vitro NIH measurements. All 5 predictions satisfy RH < 1 acceptance criterion; maximum absolute error 0.07 RH units. Sensitivity of RH to rotational-speed tolerance (±50 RPM) and blood viscosity (±15%) was characterised during the UQ campaign and found to produce RH variation of ±0.03, well within the acceptance band."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh-convergence and discretisation error study",
      "description": "Three-level Richardson extrapolation performed on 4.2 M, 11.8 M, and 31.4 M cell meshes. Grid convergence index (GCI) for hemolysis-weighted shear stress < 2.1% on the medium mesh selected for production runs. Iterative convergence verified to residual norm < 1×10⁻⁶."
    }
  ],
