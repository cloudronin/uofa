  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-piv-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 5 operating points",
      "description": "Particle image velocimetry measurements at 2500, 3500, 4500, 5500, and 6000 RPM were compared against CFD velocity fields. Area-weighted RMS error remained below 8% at all operating points. The UQ campaign (Latin hypercube sampling, 128 runs) confirmed that inlet flow-rate uncertainty of ±5% propagated to a hemolysis index uncertainty of ±0.04 RH units, well within the acceptance band. GCI-based discretization uncertainty was 1.2% on the scalar hemolysis index."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-hemolysis-rh",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against experimental bench data",
      "description": "Experimental RH values from a 12-sample bench test were compared against CFD-predicted RH. All 5 flow-speed combinations yielded RH < 1 with a maximum absolute error of 0.07. The sensitivity of predicted RH to rotational-speed tolerance (±50 RPM) was explored parametrically across all operating points; maximum RH shift was 0.03, confirming robustness. These parametric runs constitute the UQ campaign referenced in the credibility rationale; structured linkage to a dedicated SensitivityAnalysis object was not required under the MRL 2 scoping decision recorded in the decision record."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-convergence",
      "type": "ValidationResult",
      "name": "Iterative and temporal convergence verification",
      "description": "Residuals reduced to below 1e-6 for all transport equations. Temporal convergence confirmed via comparison of 2nd- and 3rd-order time-stepping schemes yielding <0.5% difference in hemolysis scalar. Grid independence established on three meshes (3.2M, 8.1M, 18.4M cells) with GCI < 1.5%."
    }
  ],
