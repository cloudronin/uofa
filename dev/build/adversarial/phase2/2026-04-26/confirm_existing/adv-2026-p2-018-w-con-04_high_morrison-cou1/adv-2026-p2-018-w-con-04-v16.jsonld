  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-hemolysis-piv-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA pump impeller plane",
      "description": "Quantitative comparison of CFD-predicted velocity magnitude against stereoscopic PIV measurements at the impeller mid-plane for 5 operating points. GCI-corrected CFD results agree with PIV within 8% RMS across all points. Acceptance criterion (RMS < 15%) met. UQ campaign (Latin-hypercube, 64 samples) confirmed RH sensitivity to inlet flow rate is the dominant contributor; full parametric sweep documented in the companion UQ report archived with this validation package."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-hemolysis-rh-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against in-vitro measurements",
      "description": "CFD-derived RH index compared against in-vitro hemolysis measurements (modified ASTM F1841 protocol) for three pump configurations. Predicted RH values fall within experimental uncertainty bands for all configurations. Worst-case RH = 0.87 (CFD) vs 0.91 ± 0.06 (experiment). Acceptance criterion RH < 1 satisfied with margin."
    }
  ],
