  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — centrifugal pump hemolysis index",
      "description": "Three-level mesh refinement study (coarse 2.1M, medium 5.4M, fine 11.8M cells) demonstrating GCI < 2.1% on normalized hemolysis index at all five operating points. Richardson extrapolation confirms asymptotic convergence regime."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-experimental-comparison",
      "type": "ValidationResult",
      "name": "Experimental validation against FDA benchmark hemolysis data",
      "description": "CFD-predicted relative hemolysis index compared against FDA in-vitro hemolysis measurements for the generic centrifugal pump across 5 flow-speed combinations. Mean absolute error 8.3%, all predictions within experimental uncertainty bands. Validation metric E_val < acceptance threshold at MRL 2."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-uq-campaign",
      "type": "ValidationResult",
      "name": "UQ and global sensitivity campaign — Sobol index analysis",
      "description": "A 128-point Latin hypercube sampling campaign was executed over 11 uncertain input parameters (inlet flow rate, rotational speed, blood viscosity, gap clearance, blade angle tolerances, inlet hematocrit, and four geometric manufacturing tolerances). Sobol first-order and total-effect indices were computed. Rotational speed and inlet flow rate jointly account for 74% of hemolysis index variance (S1 = 0.41 and 0.33 respectively). Gap clearance contributes S1 = 0.18. Remaining parameters are non-influential (S_T < 0.05). The UQ results directly informed worst-case operating point selection and confirm that the model is appropriately sensitive to the dominant physical drivers. These findings are summarised in the validation report (DOI 10.17632/morrison-cpb-vv40-2024) and were reviewed by the credibility assessment team prior to the acceptance decision."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-04-code-verification",
      "type": "ValidationResult",
      "name": "Code verification — method of manufactured solutions",
      "description": "Method of manufactured solutions applied to the Navier-Stokes solver and the Giersiepen-Wurzinger hemolysis power-law model. Observed order of accuracy p = 1.97 (theoretical 2.0) for velocity components; p = 1.88 for hemolysis scalar transport. No systematic coding errors detected."
    }
  ],
