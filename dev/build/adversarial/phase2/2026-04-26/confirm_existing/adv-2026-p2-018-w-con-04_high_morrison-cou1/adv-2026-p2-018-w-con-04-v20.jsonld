  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV vs CFD velocity field comparison — 5 operating points",
      "description": "Particle image velocimetry measurements acquired at 5 flow-speed operating points (2–6 L/min, 2000–3500 RPM) were compared against CFD velocity predictions. Normalised RMS error remained below 8 % at all planes. The UQ campaign conducted alongside this validation exercise — covering ±10 % variation in inlet flow rate, ±5 % in rotational speed, and ±15 % in blood viscosity — demonstrated that hemolysis index predictions are most sensitive to rotational speed, with a Sobol first-order index of 0.61. Sensitivity findings are discussed in the project technical report TR-2024-CPB-07 but are not formally linked as a structured hasSensitivityAnalysis object in this package."
    },
    {
      "id": "https://uofa.net/morrison/validation/rh-index-bench",
      "type": "ValidationResult",
      "name": "Relative hemolysis index bench validation — RH < 1 criterion",
      "description": "In-vitro hemolysis measurements using the ASTM F1841 modified protocol were compared with CFD-derived RH index predictions across the same 5 operating points. All CFD predictions satisfied RH < 1 and fell within the experimental uncertainty band (95 % CI). Agreement metric: mean absolute relative error 4.3 %."
    },
    {
      "id": "https://uofa.net/morrison/validation/mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence and discretisation error assessment",
      "description": "Three systematically refined meshes (4.2 M, 11.6 M, 28.4 M elements) were evaluated using the Grid Convergence Index method. GCI for RH index at the worst-case operating point was 1.7 %, confirming mesh-independent predictions on the medium grid used for production runs."
    }
  ],
