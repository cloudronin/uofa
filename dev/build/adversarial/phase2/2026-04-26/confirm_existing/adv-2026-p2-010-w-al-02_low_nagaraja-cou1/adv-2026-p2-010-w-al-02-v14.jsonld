  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency (Test conditions at level 2 vs. required level 3) is accepted given medium model risk, medium decision consequence, and the availability of analytical bounds for untested loading modes. All three QoIs satisfy quantitative acceptance criteria (E/uval < 1.96, MAPE < 10%). Comprehensive Monte Carlo uncertainty quantification across all 14 primary inputs confirms that prediction intervals are consistent with experimental scatter. The FEA modeling framework is assessed as sufficiently credible for its intended use in the non-cannulated pedicle screw 510(k) submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
