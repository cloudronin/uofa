  "signature": "ed25519:7a3c1e9f2b5d0a8c4e7f1b3d6a9c2e5f8b0d3a6c9e2f5b8d1a4c7e0f3b6d9a2c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys) used under documented QMS with version control, regression testing, and institutional SOP compliance.",
      "rationale": "Ansys Mechanical 2022 R1 operated under FDA OSEL QMS. Version-controlled input decks archived in institutional repository. Regression test suite executed prior to analysis campaign; all tests passed. SOP-compliant user qualification documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks for linear elastic beam bending and contact mechanics reproduce analytical solutions within 1%.",
      "rationale": "Cantilever beam benchmark and Hertzian contact benchmark executed in Ansys. Errors relative to analytical solutions were 0.3% and 0.7% respectively, confirming correct code implementation for the physics relevant to F1717 compression-bending."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinement levels; Richardson extrapolation GCI <5%.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and screw-rod interface regions. Construct stiffness changed 1.1% from medium to fine mesh; yield force changed 0.9%. GCI computed at 3.2%. Fine mesh (approximately 420,000 elements, predominantly C3D10 tetrahedral) adopted for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver residuals converge to force norm <1e-4 N and displacement norm <1e-6 mm at each load increment.",
      "rationale": "Implicit nonlinear static solver with automatic time-stepping employed. All 11 load cases converged within 40 increments. Force residual norm reached 3.1e-5 N and displacement norm 4.7e-7 mm at final converged state. No divergence or excessive increment bisection observed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and material assignments by a second qualified analyst.",
      "rationale": "Model setup independently reviewed by a second senior analyst not involved in original model construction. Boundary conditions (fixed proximal block, displacement-controlled distal block per ASTM F1717), material assignments (Ti-6Al-4V: E=114 GPa, yield=880 MPa), and contact definitions verified against ASTM F1717-15 and manufacturer material certificates. No discrepancies identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum FEA with isotropic elastoplastic material law and frictional contact is appropriate for metallic pedicle screw compression-bending; supported by literature precedent and validation evidence.",
      "rationale": "Isotropic bilinear elastoplastic constitutive model for Ti-6Al-4V is well-established in orthopaedic implant FEA literature. Frictional contact (mu=0.3) at screw-rod and rod-set-screw interfaces captures load transfer mechanism. Model form consistent with three independent FEA implementations (FDA, Ansys, DePuy Synthes) that produced mutually consistent predictions, supporting adequacy of the chosen physics representation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and geometric input parameters sourced from manufacturer certificates or direct measurement; uncertainty bounds assigned to each input; comprehensive Monte Carlo UQ performed across full input space.",
      "rationale": "Material properties (elastic modulus, yield strength, tangent modulus) obtained from manufacturer material certificates for each production lot. Geometric dimensions measured from 11 physical constructs using CMM; tolerances incorporated as input distributions. Friction coefficient assigned uniform distribution U(0.2, 0.4) based on literature. Comprehensive Monte Carlo UQ with 10,000 samples propagated all input uncertainties through the FEA surrogate to yield probabilistic QoI distributions. Input uncertainty characterization is considered complete and the UQ outputs are reported as the primary basis for validation metric computation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N>=10 test samples from production lots with documented traceability; inter-laboratory consistency demonstrated.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA OSEL biomechanics lab and DePuy Synthes testing facility). All samples traceable to production lots with accompanying material and dimensional certificates. Inter-laboratory coefficient of variation for construct stiffness was 4.2%, confirming consistent test execution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or systematic variation of key test parameters is documented.",
      "rationale": "Testing performed under a single ASTM F1717 static compression-bending configuration only. Dynamic fatigue loading and alternative spinal level configurations were not included in this validation campaign. This factor is below the required level; the gap is acknowledged and accepted given that static compression-bending is the primary regulatory submission test and the model risk level supports this scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to physical test specimen and test machine configuration.",
      "rationale": "CAD geometry imported directly from manufacturer production CAD files and verified against CMM measurements of physical specimens (max deviation 0.04 mm). Material properties assigned from lot-specific certificates used for both physical specimens and FEA inputs. Boundary conditions replicate ASTM F1717 test fixture kinematics as confirmed by fixture drawing review. Input equivalency is fully established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percent difference < 10% for all three QoIs across N=11 specimens.",
      "rationale": "Validation metric E/uval computed per ASME V&V 40 Eq. 4-1 for all three QoIs: stiffness E/uval=1.12, yield force E/uval=1.54, force at 40 mm E/uval=1.71. All below the 1.96 threshold. Percent differences: 4.8%, 7.3%, 8.1% — all below 10% acceptance bound. Probabilistic UQ outputs (Monte Carlo 95th-percentile intervals) bracket experimental scatter for all three QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the regulatory submission requirements and clinical performance endpoints.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717-15 and are the metrics reported in the 510(k) submission. They directly characterize resistance to construct failure under physiological compression-bending loading. QoI relevance to the COU decision is fully established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate the COU loading mode, device configuration, and material system; any deviations are documented and justified.",
      "rationale": "Validation activities directly replicate the COU: same device (non-cannulated 7.5 mm pedicle screw), same loading mode (ASTM F1717 static compression-bending), same material system (Ti-6Al-4V), same FEA modeling framework. The single deviation (one test condition vs. multiple) is documented under Test conditions factor. Overall, validation activities are highly relevant to the COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieved level 2 against required level 3, reflecting the single-condition ASTM F1717 static test scope; this gap is accepted given the medium model risk level and the primary regulatory use of static compression-bending data. Quantitative validation metrics (E/uval < 1.96; percent difference < 10%) satisfied for all three QoIs across N=11 specimens at two independent laboratories. Comprehensive Monte Carlo uncertainty quantification confirms that probabilistic prediction intervals encompass experimental scatter. The FEA modeling framework is accepted as credible for predicting non-cannulated pedicle screw compression-bending performance within the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
