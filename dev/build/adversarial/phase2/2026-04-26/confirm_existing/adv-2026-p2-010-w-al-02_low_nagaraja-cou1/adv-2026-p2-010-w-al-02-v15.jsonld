  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework meets or exceeds required credibility levels for 12 of 13 V&V 40 factors. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 specifies a single standard test condition and regulatory precedent supports this configuration. Uncertainty quantification via comprehensive Monte Carlo across all model inputs was completed and prediction intervals encompass experimental observations. Overall credibility is sufficient to support a Medium assurance level decision for this Class II device submission.",
