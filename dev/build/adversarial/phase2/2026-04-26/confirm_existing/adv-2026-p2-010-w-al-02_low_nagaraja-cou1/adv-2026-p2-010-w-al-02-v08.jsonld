  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility levels. One factor (Test conditions) achieved level 2 against a required level of 3 due to evaluation at a single ASTM F1717 test configuration; this gap is accepted given the strong quantitative agreement observed across all three QoIs (E/uval < 1.96, percentage difference < 10%) and the direct regulatory relevance of the tested condition. Uncertainty quantification via comprehensive Monte Carlo sampling across all model inputs has been completed and probabilistic QoI distributions are reported. Overall credibility is sufficient to support the intended regulatory use of this FEA model in the 510(k) submission for the non-cannulated pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
