    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by analyst not involved in original build.",
      "rationale": "A second analyst independently reviewed boundary conditions, material assignments, contact definitions, and load application for each of the three FEA implementations. No discrepancies identified after one review cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and contact formulation appropriate for metallic implant quasi-static bending; justified by literature and prior validation studies.",
      "rationale": "Bilinear isotropic hardening plasticity (Ti-6Al-4V: E=114 GPa, sigma_y=880 MPa, tangent modulus=1.8 GPa) adopted based on published material characterisation. Penalty-based frictional contact (mu=0.2) at screw-rod interface consistent with ASTM F1717 fixture geometry. Model form supported by three independent prior pedicle screw validation studies in peer-reviewed literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and geometric inputs traceable to measured lot data or certified material certificates; input uncertainty characterised via Monte Carlo sampling.",
      "rationale": "Dimensional inputs derived from CMM measurements of each of the 11 test constructs (screw diameter, rod diameter, inter-screw distance). Material properties sourced from mill certificates for each rod lot. Input distributions (normal for geometry, lognormal for yield strength) parameterised from measurement data and propagated via comprehensive Monte Carlo simulation (10,000 samples) to yield 95% prediction intervals on all three QoIs. No dominant-driver ranking was performed; all inputs treated as equally weighted in the UQ propagation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N>=10 constructs tested; samples representative of production lot.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All constructs drawn from the same production lot and inspected per incoming quality control procedures. Sample size sufficient to characterise inter-construct variability at 95% confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing conducted under at least two distinct loading rates or fixture configurations to bound sensitivity to test conditions.",
      "rationale": "Testing conducted at a single crosshead displacement rate (5 mm/min) per ASTM F1717. Only one test condition evaluated; multi-rate or multi-configuration testing was not performed. This factor is below the required level and is documented as a known gap in the credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and geometry match physical test configuration to within measurement uncertainty.",
      "rationale": "FEA models constructed to replicate ASTM F1717 fixture geometry using CMM-measured construct dimensions for each specimen. Boundary conditions (fixed inferior block, displacement-controlled superior block) mirror physical fixture. Equivalency confirmed by overlay of FEA deformed shape against DIC images from laboratory 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "E/uval < 1.96 for all three QoIs; percent difference < 10%.",
      "rationale": "All three QoIs (stiffness: E/uval=0.87, 4.2% diff; yield force: E/uval=1.41, 6.8% diff; force at 40 mm: E/uval=0.62, 3.1% diff) satisfy both acceptance criteria. Validation metric computed per ASME V&V 40 Section 6 using experimental uncertainty from inter-lab reproducibility study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA guidance for pedicle screw 510(k) submissions. These QoIs directly characterise resistance to fatigue crack initiation and gross plastic deformation under physiological bending loads."
    },
