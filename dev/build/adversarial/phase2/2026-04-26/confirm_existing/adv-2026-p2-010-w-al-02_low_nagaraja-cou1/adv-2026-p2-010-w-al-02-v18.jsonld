  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieves Gradation 2 against a required Gradation 3 due to single-rate testing; this gap is accepted given the conservative nature of the ASTM F1717 protocol and the strong output comparison results (all E/uval < 1.96). Comprehensive Monte Carlo uncertainty quantification across all model inputs supports confidence in prediction intervals. Overall credibility is sufficient to support a Medium assurance level conclusion and regulatory submission use.",
