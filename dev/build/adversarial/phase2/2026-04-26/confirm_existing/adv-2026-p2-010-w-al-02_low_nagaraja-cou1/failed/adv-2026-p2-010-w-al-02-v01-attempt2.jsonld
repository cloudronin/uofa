  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All three QoIs satisfy the pre-specified E/uval acceptance threshold of 1.96. Twelve of thirteen credibility factors meet or exceed required levels. The single below-required factor (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 specifies a single standardized test configuration and multi-condition testing is not required for 510(k) submission. Uncertainty quantification via Monte Carlo is comprehensive and results are incorporated into the validation metric. The overall credibility profile supports an assurance level of Medium consistent with the model risk level 3 and medium decision consequence.",
