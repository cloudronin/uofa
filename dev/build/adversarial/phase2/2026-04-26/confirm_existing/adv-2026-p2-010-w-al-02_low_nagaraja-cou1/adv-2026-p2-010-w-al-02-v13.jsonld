    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge to <1e-6 for all load steps; no spurious energy or force imbalance reported.",
      "rationale": "PCG solver with tight convergence criteria applied. Force residuals monitored at each substep. No convergence warnings issued across the 11-specimen ensemble. Achieved level meets required."
