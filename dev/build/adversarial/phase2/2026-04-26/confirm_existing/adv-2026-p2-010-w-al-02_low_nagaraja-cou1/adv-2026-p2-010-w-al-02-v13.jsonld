    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of input decks and boundary condition assignments by a second analyst at each participating organization.",
      "rationale": "Each of the three modeling teams conducted internal peer review of mesh, material assignments, contact definitions, and load application. Discrepancies identified and resolved before result submission. Achieved level 2 confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic isotropic constitutive model appropriate for Ti-6Al-4V at sub-yield loads; nonlinear contact formulation used at rod-screw interface.",
      "rationale": "For the stiffness and yield QoIs, linear elastic model form is well-established for titanium alloy implants in the pre-yield regime. Augmented Lagrange contact captures load transfer at the rod-tulip interface. Model form uncertainty estimated at <5% contribution to total QoI uncertainty based on literature comparison. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, yield strength) sourced from supplier certificates and in-house coupon testing; geometric inputs from CMM measurements of test articles; friction coefficient from literature with documented range.",
      "rationale": "Young's modulus and yield strength distributions characterized from 15 coupon tensile tests (mean E = 113.8 GPa, CV = 1.2%). Screw and rod geometry digitized via CMM. Friction coefficient modeled as uniform distribution [0.15, 0.35] per published tribology data. Comprehensive Monte Carlo UQ performed across all inputs simultaneously to propagate input uncertainty to QoI distributions. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lots; dimensional inspection confirms conformance to drawing; two independent laboratories.",
      "rationale": "N=11 constructs tested: 6 at Laboratory A (FDA/CDRH) and 5 at Laboratory B (DePuy Synthes). All specimens drawn from the same production lot and dimensionally inspected by CMM prior to testing. Between-laboratory variability assessed and found non-significant (p=0.31, Levene test). Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple test configurations (load angles, offset distances) to span COU loading envelope.",
      "rationale": "Testing performed exclusively at the ASTM F1717 standard offset (60 mm) and standard compression-bending orientation. No additional load angles or offsets were explored. This single test condition limits generalizability across the full COU loading envelope. Achieved level 2 is below required level 3; this is the one identified deficiency in the credibility assessment, noted and accepted given the regulatory precedent for F1717 standardization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material inputs traceable to measured test article properties; loading fixture geometry replicated in model.",
      "rationale": "UHMWPE block geometry, screw insertion depth, and rod pre-tension all replicated from test setup drawings. CMM-measured screw geometry used directly. Material properties assigned from coupon data matched to test lot certificates. Equivalency confirmed by overlay of experimental and model geometry. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric E/uval < 1.96 for all three QoIs; percent difference < 10%.",
      "rationale": "E/uval computed per ASME V&V 40 Eq. 5 for stiffness (1.12), yield force (0.87), and force at 40 mm (1.44). All three values below 1.96 threshold. Percent differences: stiffness 4.1%, yield force 7.3%, force at 40 mm 8.9%. All within 10% acceptance bound. Achieved level 3 confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly linked to COU decision criteria for pedicle screw structural adequacy.",
      "rationale": "The three QoIs map directly to the FDA guidance for spinal implant structural testing: stiffness characterizes load-sharing, yield force indicates onset of permanent deformation, and force at 40 mm represents post-yield structural reserve. All three are clinically and regulatorily relevant to the COU. Achieved level 3."
    },
