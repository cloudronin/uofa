  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved level 1 vs. required level 2) is accepted on the basis that the ASTM F1717 quasi-static rate is the regulatory standard condition and is mechanistically representative of the clinical overload scenario. All three QoIs satisfy the E/uval < 1.96 acceptance criterion. Comprehensive Monte Carlo uncertainty quantification confirms that combined model and experimental uncertainty is bounded within the acceptance region. The overall credibility evidence is sufficient to support a Medium assurance level conclusion for this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
