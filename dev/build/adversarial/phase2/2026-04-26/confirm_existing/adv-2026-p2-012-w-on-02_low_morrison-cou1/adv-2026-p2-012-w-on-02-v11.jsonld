  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented with version control, regression testing, and traceable build records consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is under formal version control with documented regression test suite. Build records are traceable. Software QA documentation meets MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions at MRL 2.",
      "rationale": "Code verification performed using lid-driven cavity and Poiseuille flow benchmarks. Observed order of accuracy consistent with theoretical second-order convergence. Numerical code verification meets MRL 2 standard."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh refinement study must demonstrate discretization error below 5% for the primary quantity of interest (normalized index of hemolysis) at MRL 2.",
      "rationale": "Three-level mesh refinement study performed on the FDA centrifugal pump geometry. Richardson extrapolation applied; discretization error for NIH estimated at 2.1%, well below the 5% threshold. Grid convergence index reported. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and traceable, with flow rates and rotational speeds matching the five CFD operating points to within measurement uncertainty.",
      "rationale": "In-vitro experiments conducted at five flow-speed combinations (2.5 L/min at 2000 RPM through 6 L/min at 3500 RPM). Test conditions documented with calibrated instrumentation. Agreement between nominal and measured conditions within 1.5% for flow rate and 0.8% for rotational speed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted normalized index of hemolysis must agree with experimental measurements within 15% across all five operating points.",
      "rationale": "Predicted NIH values compared against in-vitro measurements across all five operating conditions. Maximum deviation of 11.3% observed at the highest flow-speed combination. Mean absolute error of 7.8%. Output comparison criterion satisfied at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated quantity of interest (normalized index of hemolysis, NIH) must be directly linked to the clinical endpoint and regulatory acceptance criterion (RH < 1).",
      "rationale": "NIH is the standard hemolysis metric per ASTM F1841. The relative hemolysis index RH is derived directly from NIH values of the test and predicate devices. The quantity of interest is clinically and regulatorily relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic centrifugal pump geometry, same blood analogue fluid, and operating conditions spanning the CPB clinical range.",
      "rationale": "Validation activities used the FDA benchmark centrifugal pump geometry with a glycerol-water blood analogue at physiological viscosity. Operating conditions cover the full CPB clinical range (2–6 L/min). Validation activities are directly relevant to the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal quantification of iterative solver error is not required; residual monitoring to convergence is sufficient.",
      "rationale": "Solver residuals monitored to 1e-5 for all equations. Iterative convergence confirmed by stability of NIH monitor point. Formal solver error quantification not required at MRL 2 and not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required; documented simulation protocol with peer review is sufficient.",
      "rationale": "Simulation protocol documented and peer-reviewed internally. Boundary condition inputs verified by independent team member. Formal use error analysis not required at MRL 2 and not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal model form uncertainty quantification is not required; justification of turbulence model selection is sufficient.",
      "rationale": "SST k-omega turbulence model selected based on published literature for rotating hemodynamic flows. Power law hemolysis model (Giersiepen et al.) applied. Model form uncertainty not formally quantified, consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal sensitivity analysis of model inputs is not required; documentation of input sources and nominal values is sufficient.",
      "rationale": "All model inputs (fluid properties, boundary conditions, geometric parameters) documented with sources. Nominal values derived from ASTM F1841 and device specifications. Formal input uncertainty analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required; use of a single representative device sample is acceptable.",
      "rationale": "Single FDA benchmark pump specimen used for validation experiments. Sample variability characterization not required at MRL 2. Test sample documentation provided with manufacturing tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency analysis between validation and COU input parameters is not required; qualitative comparison is sufficient.",
      "rationale": "Qualitative comparison between validation experiment inputs and COU operating parameters confirms overlap in flow rates and rotational speeds. Blood analogue viscosity matched to physiological range. Formal equivalency analysis not required at MRL 2."
