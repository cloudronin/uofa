  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is under version control with documented QA procedures consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) operates under a documented software quality assurance plan including version control, regression testing, and release validation. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against analytical solutions or established test cases for rotating machinery flow.",
      "rationale": "ANSYS Fluent has been verified against canonical rotating flow benchmarks including Taylor-Couette flow and lid-driven cavity problems. Verification documentation is available from the software vendor and corroborated by published literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates discretization error below 5% for hemolysis index QOI across at least three mesh refinement levels.",
      "rationale": "A three-level mesh refinement study (coarse: 1.2M, medium: 4.1M, fine: 12.8M elements) was performed. Grid convergence index (GCI) for the relative hemolysis index was 3.2%, satisfying the acceptance criterion. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions for validation experiments are documented and correspond to the intended COU operating range.",
      "rationale": "In vitro hemolysis experiments were conducted using bovine blood at 37°C across 5 flow-speed combinations spanning 2–6 L/min and 2000–4000 RPM. Test conditions are fully documented and correspond to the clinical CPB operating range specified in the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) agrees with experimental measurements within 15% at all 5 operating points.",
      "rationale": "CFD-predicted RH values at all 5 operating points fell within 11% of experimentally measured values. The maximum discrepancy of 10.8% was observed at the highest flow-speed combination (6 L/min, 4000 RPM), remaining within the 15% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOI (relative hemolysis index RH) is directly linked to the clinical decision criterion and is measurable in both simulation and experiment.",
      "rationale": "The relative hemolysis index is the regulatory-accepted metric for comparing device hemolysis performance against predicate devices. It is computed directly from CFD shear stress history using the power-law hemolysis model and is measured experimentally via plasma free hemoglobin. The QOI is directly relevant to the COU decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same pump geometry, fluid properties, and operating conditions as the intended COU.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal blood pump geometry using bovine blood at physiological temperature and hematocrit. Operating conditions span the full CPB clinical range. Validation activities are directly representative of the COU with no extrapolation required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver residuals monitored to confirm convergence.",
      "rationale": "At Model Risk Level 2, formal numerical solver error quantification beyond convergence monitoring is not required. Solver residuals were confirmed below 1e-5 for all simulations, indicating adequate convergence. Formal solver error assessment is scoped out per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
