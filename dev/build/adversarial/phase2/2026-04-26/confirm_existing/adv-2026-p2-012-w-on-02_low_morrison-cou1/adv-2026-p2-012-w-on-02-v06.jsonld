      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection is documented with literature justification.",
      "rationale": "The SST k-omega turbulence model was selected based on published literature demonstrating its suitability for rotating blood pump flows. Formal model form uncertainty quantification is not required at MRL 2 and is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; input parameters are documented with sources and nominal values.",
      "rationale": "All model inputs (fluid viscosity, density, hematocrit, boundary conditions) are documented with sources. Sensitivity to input variation is not formally assessed at MRL 2 but key inputs are traceable to published physiological reference values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; blood sample sourcing and preparation are documented.",
      "rationale": "Bovine blood samples were obtained from a USDA-certified supplier and prepared per ASTM F1841 protocol. Formal statistical characterization of sample variability is not required at MRL 2 and is not assessed."
    },
