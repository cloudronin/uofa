  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed the required levels for Model Risk Level 2. The remaining 6 factors are not assessed, which is acceptable under the MRL 2 framework. CFD predictions of the relative hemolysis index agree with experimental measurements within 11% across all 5 operating points, satisfying the RH < 1 acceptance criterion relative to the predicate device. The computational model is accepted as credible for the intended COU of identifying worst-case hemolysis operating conditions for the Class II CPB device.",
