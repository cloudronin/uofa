      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented with version control and verified against known analytical benchmarks at Gradation 2.",
      "rationale": "ANSYS Fluent v19.2 used with documented version control. Solver verified against lid-driven cavity and Poiseuille flow benchmarks. Software quality procedures satisfy MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct numerical implementation via benchmark problems at Gradation 2.",
      "rationale": "Solver verified against Taylor-Green vortex and rotating channel flow benchmarks. Observed order of accuracy consistent with theoretical second-order convergence for spatial discretization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study required demonstrating discretization error below 5% for QoI at Gradation 2.",
      "rationale": "Richardson extrapolation performed across three mesh refinement levels (2.1M, 5.8M, 14.2M cells). GCI for hemolysis index QoI = 1.8%, exceeding Gradation 2 threshold. Achieves Gradation 3 due to systematic refinement study with formal error estimation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and traceable to simulation boundary conditions at Gradation 2.",
      "rationale": "Five flow-speed operating points (2.5–5.0 L/min, 2000–3500 RPM) tested in vitro using bovine blood. Temperature, hematocrit, and fluid properties documented. Boundary conditions mapped directly from experimental measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between simulation outputs and experimental measurements required with documented metrics at Gradation 2.",
      "rationale": "Relative hemolysis index compared at all 5 operating points. Mean absolute error 0.043 RH units; maximum deviation 8.2%. All predictions satisfy RH < 1 acceptance criterion consistent with predicate device comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly relevant to the clinical decision and traceable to the intended use at Gradation 2.",
      "rationale": "Relative hemolysis index (RH) is the primary QoI, directly linked to the regulatory acceptance criterion and clinical hemolysis risk. Shear stress distribution and exposure time are intermediate QoIs supporting RH computation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
