  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for Model Risk Level 2. The 6 not-assessed factors are appropriately scoped out per MRL 2 requirements. CFD hemolysis predictions demonstrate adequate agreement with experimental data (within combined uncertainty bounds) across all 5 CPB operating points. The relative hemolysis index criterion (RH < 1) is satisfied for the worst-case operating condition, supporting the regulatory decision that the subject device does not produce greater hemolysis than the predicate. The credibility assessment is accepted for submission.",
