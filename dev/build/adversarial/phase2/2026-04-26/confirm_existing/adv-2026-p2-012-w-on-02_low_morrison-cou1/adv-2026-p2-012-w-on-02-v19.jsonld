  "signature": "ed25519:b4e2d1c3f5a7e9b0c2d4f6a8b0c2e4f6a8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes and regression testing.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is commercially validated and under rigorous version control. Regression test suite passes all benchmark cases. Achieved level exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases.",
      "rationale": "Standard benchmark cases (lid-driven cavity, pipe flow) confirm correct implementation of the incompressible Navier-Stokes solver. Manufacturer-supplied verification documentation reviewed and accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for hemolysis index predictions across all 5 operating points.",
      "rationale": "Three-level mesh refinement study performed. GCI values ranged from 1.8% to 4.3% across all operating points, satisfying the 5% threshold. Polyhedral mesh with boundary layer refinement used throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within documented tolerances for flow rate and rotational speed.",
      "rationale": "FDA benchmark experimental data acquired at controlled flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM). CFD boundary conditions set to match experimental values within ±2%, consistent with measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index must agree with experimental measurements within 15% across all 5 flow-speed combinations.",
      "rationale": "Predicted RH values compared against FDA benchmark experimental hemolysis measurements. Agreement within 9% across all operating points. Uncertainty quantification performed using experimental measurement uncertainty bands."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index) must be directly linked to the clinical endpoint of pump-induced hemolysis.",
      "rationale": "The relative hemolysis index (RH) is the standard metric for comparative hemolysis assessment per ASTM F1841. Direct correspondence between CFD-predicted shear stress exposure and erythrocyte damage is established through the Giersiepen power-law model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and operating range as the intended COU.",
      "rationale": "Validation performed using the FDA generic centrifugal blood pump geometry under the same 5 flow-speed operating points specified in the COU. Blood analog fluid (glycerin-water) used in experiments; viscosity matched to nominal blood viscosity within 3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-5 for all transport equations.",
      "rationale": "Not assessed at MRL 2; solver convergence monitoring is addressed implicitly through the discretization error and code verification factors. Residual targets documented in simulation plan for completeness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation workflow must be executed by personnel with documented CFD competency.",
      "rationale": "Not assessed at MRL 2. Analyst qualifications documented in project records. Standard operating procedures for CFD setup and post-processing are in place within the organization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified for the flow regime present in the centrifugal pump.",
      "rationale": "Not assessed at MRL 2. SST k-omega turbulence model selected based on published literature for rotating machinery hemolysis applications. Formal model form uncertainty quantification deferred to higher MRL assessments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs (fluid viscosity, density, hemolysis model coefficients) must be traceable to published sources.",
      "rationale": "Not assessed at MRL 2. Input parameters sourced from peer-reviewed literature and FDA guidance. Traceability matrix maintained in simulation documentation package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be representative of the intended patient population blood properties.",
      "rationale": "Not assessed at MRL 2. FDA benchmark experiments used standardized blood analog fluid. Variability in patient blood properties not explicitly characterized at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
