  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped as not-assessed at MRL 2 per ASME V&V 40 Table 4. CFD model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device. Relative hemolysis index predictions agree with experimental data within 9%, satisfying the 15% acceptance criterion. Decision consequence is HIGH but model influence is MEDIUM, consistent with MRL 2 classification.",
