  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented and version-controlled; solver release notes reviewed for relevant bug fixes.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented SQA processes. Release notes were reviewed and no known defects affect rotating-frame hemolysis predictions. Version control applied to all simulation input files."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark cases for rotating machinery flow at MRL 2 requirement.",
      "rationale": "ANSYS Fluent has been verified against the FDA critical path benchmark pump dataset. Internal benchmark results for lid-driven cavity and rotating disk flows confirm correct implementation of governing equations relevant to the centrifugal pump geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for the relative hemolysis index QoI across all five operating points.",
      "rationale": "Three-level mesh refinement study performed on the nominal pump geometry. GCI values ranged from 1.8% to 3.9% across the five flow-speed combinations, confirming discretization error is within the 5% acceptance threshold. Medium mesh (6.2 M cells) selected for parametric sweep."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, inlet flow rate) match simulation boundary conditions within stated uncertainty bounds.",
      "rationale": "Bench-test conditions for the predicate device hemolysis measurements were documented in the test report. Simulation boundary conditions were set to match measured inlet flow rates (±2%) and fluid properties (bovine blood, 37°C, Hct 33%). Deviations are within acceptable uncertainty for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index within 15% of measured predicate device RH values at all five operating points.",
      "rationale": "Simulation-predicted RH indices compared against predicate device experimental data. Maximum deviation was 11.4% at the highest flow-speed combination. All five operating points satisfy the 15% acceptance criterion, supporting model credibility for the intended comparative use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (RH index, shear stress distribution) are directly linked to the regulatory hemolysis acceptance criterion.",
      "rationale": "The relative hemolysis index and volume-averaged shear stress are the primary QoIs. Both are directly used in the regulatory submission acceptance criterion (RH < 1 relative to predicate). The power-law hemolysis damage model relates shear stress to red blood cell destruction, establishing a clear chain from simulation output to clinical relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on geometrically and operationally similar centrifugal pump under CPB-representative flow conditions.",
      "rationale": "Validation activities used the FDA generic centrifugal blood pump under flow conditions spanning the CPB operating range (2–6 L/min, 2000–3500 RPM). The validation geometry shares key features (volute, impeller clearance) with the device under assessment, supporting applicability of validation evidence to the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "At Model Risk Level 2, explicit quantification of numerical solver round-off and iterative convergence error beyond residual monitoring is not required. Residuals converged to 1e-5 for all equations; no further assessment needed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal use-error analysis of the simulation workflow is not required at MRL 2. Analyst qualifications and peer review of simulation setup provide adequate assurance at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Explicit model-form uncertainty quantification (e.g., turbulence model sensitivity study beyond the assessed discretization error) is not required at MRL 2. The SST k-omega turbulence model is well-established for internal rotating flows and was selected based on published literature for blood pump CFD."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Probabilistic uncertainty propagation of input parameters (blood viscosity, geometry tolerances) through the CFD model is not required at MRL 2. Nominal input values are sourced from traceable measurements and published material properties."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Statistical characterization of biological variability across test sample populations is not required at MRL 2. Bovine blood samples used in validation experiments were prepared according to ASTM F1841 and are representative of standard hemolysis testing practice."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal equivalency mapping between validation experiment inputs and device COU inputs is not required at MRL 2. Qualitative correspondence between validation and COU boundary conditions was documented in the test conditions factor assessment above."
    }
