  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is a commercially validated code with documented QA procedures, version control, and regression test suites. Release notes confirm no known defects affecting rotating machinery hemolysis simulations. Achieved level meets required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via method of manufactured solutions or benchmark problems with documented error norms at MRL 2 gradation.",
      "rationale": "Numerical code verification was performed using published FDA benchmark pump results. Discretization error norms for velocity and pressure fields were within 2% of analytic benchmark solutions. Gradation 2 achieved through documented benchmark comparison with quantified error metrics."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with Richardson extrapolation demonstrating GCI < 5% for hemolysis-relevant quantities of interest.",
      "rationale": "A three-level mesh refinement study was conducted on the centrifugal pump geometry. Grid Convergence Index (GCI) values for shear stress and velocity magnitude were below 3.8% across all five operating points. Richardson extrapolation confirmed asymptotic convergence. Discretization error is adequately characterized for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce boundary conditions in the computational model, including fluid properties, flow rates, and rotational speed.",
      "rationale": "Physical hemolysis experiments were conducted using bovine blood with documented hematocrit (35±2%), temperature (37°C), and anticoagulation protocol. Five flow-speed operating points (2–6 L/min at 2000–3500 RPM) were tested in triplicate. Test conditions are sufficiently characterized to establish simulation boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted relative hemolysis index (RH) against experimental measurements with documented agreement metrics.",
      "rationale": "Predicted RH values across five operating conditions were compared against experimental measurements. Mean absolute error was 0.08 RH units (8% of acceptance threshold). All five predicted RH values fell within experimental uncertainty bounds. Quantitative agreement supports model credibility for worst-case identification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (shear stress, exposure time, RH index) must be directly linked to the clinical hemolysis decision criterion.",
      "rationale": "The primary QoI, relative hemolysis index (RH), is directly computed from the power-law hemolysis model integrating shear stress and exposure time along Lagrangian particle tracks. RH is the accepted regulatory comparator for Class II CPB devices. The QoI is unambiguously linked to the clinical decision criterion (RH < 1 relative to predicate)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, operating range, and fluid as the COU to ensure direct relevance.",
      "rationale": "Validation activities were performed on the FDA generic centrifugal blood pump geometry under CPB operating conditions (2–6 L/min, 2000–3500 RPM) using bovine blood as a hemolysis surrogate. Geometric and operational fidelity to the COU is high. Validation domain directly overlaps with the five COU operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor; default gradation 1 accepted per ASME V&V 40 Table 3 guidance.",
      "rationale": "Numerical solver error beyond discretization is not required to be separately assessed at MRL 2 for this device class and model influence combination. The commercial solver's iterative convergence is monitored via residual criteria (< 1e-5) and is deemed adequate without additional solver error quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst competency is assumed through documented training records.",
      "rationale": "Use error assessment is not required at MRL 2 for this COU. Simulation analysts hold documented CFD competency qualifications and followed standard operating procedures for pump hemolysis simulation. Formal use error analysis is deferred as acceptable at this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty assessment not required at MRL 2 for the power-law hemolysis model applied to Class II CPB devices.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) is the established regulatory standard for CFD hemolysis prediction. Formal model form uncertainty quantification is not required at MRL 2. The model's known empirical basis is accepted as adequate for comparative worst-case identification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model input uncertainty propagation not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hemolysis model constants are taken from published literature values. Input sensitivity analysis is not required at MRL 2. Nominal values are well-established for bovine blood hemolysis modeling and are consistent with predicate device submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2; triplicate measurements with reported mean and standard deviation are sufficient.",
      "rationale": "Hemolysis experiments were conducted in triplicate at each operating point. Mean and standard deviation of normalized index of hemolysis (NIH) values are reported. Full statistical power analysis of sample size is not required at MRL 2 for this comparative assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between experimental and simulation input parameters not required at MRL 2; documented parameter correspondence is sufficient.",
      "rationale": "Simulation boundary conditions (inlet flow rate, rotational speed, outlet pressure) are directly mapped from experimental test conditions. Formal equivalency analysis is not required at MRL 2. The direct correspondence between test and simulation parameters is documented in the simulation protocol."
    }
