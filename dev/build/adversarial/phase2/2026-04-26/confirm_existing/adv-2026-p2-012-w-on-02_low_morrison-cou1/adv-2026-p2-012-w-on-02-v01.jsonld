  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are appropriately scoped as not-assessed per ASME V&V 40 Table 4 requirements for MRL 2. CFD hemolysis predictions demonstrate mean agreement of 8.3% against in-vitro benchmarks. The relative hemolysis index criterion (RH < 1) is satisfied across all evaluated operating conditions. The credibility evidence is deemed sufficient to support regulatory submission for the Class II CPB device.",
