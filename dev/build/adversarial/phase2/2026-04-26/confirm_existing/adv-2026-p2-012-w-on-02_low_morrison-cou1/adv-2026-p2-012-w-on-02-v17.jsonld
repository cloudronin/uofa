  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 non-assessed factors are acceptable at MRL 2 per ASME V&V 40. The CFD model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index predictions agree with experimental data within the 15% acceptance criterion across all validation points. The assessment supports regulatory submission for 510(k) clearance.",
