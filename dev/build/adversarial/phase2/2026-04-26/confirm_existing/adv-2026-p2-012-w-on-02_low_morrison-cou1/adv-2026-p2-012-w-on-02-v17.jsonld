  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and configuration management consistent with MRL 2 requirements.",
      "rationale": "The ANSYS Fluent solver used in this study has documented version control and regression test suites. Release notes and known issue logs were reviewed. SQA activities are consistent with MRL 2 requirements for a Class II device assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems at MRL 2 level.",
      "rationale": "ANSYS Fluent has been verified against standard CFD benchmark cases including lid-driven cavity and backward-facing step. Published verification documentation supports correctness of the Navier-Stokes implementation used for blood pump simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence must be demonstrated with GCI less than 5% for hemolysis index QoI.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 2.1M, 4.8M, and 9.6M cells. Grid Convergence Index for the relative hemolysis index was 3.2%, satisfying the acceptance criterion. The medium mesh (4.8M cells) was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and representative of CFD boundary conditions within acceptable tolerances.",
      "rationale": "FDA benchmark experimental data for the generic centrifugal blood pump were collected at controlled flow rates (2.5 and 5.0 L/min) and rotational speeds (2500 and 3500 RPM). Temperature, fluid viscosity, and inlet pressure conditions are documented and match CFD boundary conditions within 2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all validation operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) values were compared against experimental measurements at four operating points. Mean absolute error was 9.4% and maximum deviation was 13.8%, satisfying the 15% acceptance criterion across all tested conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) must directly inform the regulatory decision regarding worst-case operating conditions.",
      "rationale": "The relative hemolysis index RH is the primary QoI and directly maps to the regulatory acceptance criterion (RH < 1 versus predicate device). This QoI is the standard metric used in 510(k) submissions for CPB devices and is directly relevant to the clinical risk of hemolysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same or geometrically similar pump under overlapping operating conditions with the COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same model used in the COU. Operating conditions in validation experiments overlap with the 5 flow-speed combinations evaluated in the COU. Geometric similarity and operating condition overlap support relevance of validation activities."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error assessment is not required at Model Risk Level 2 for this credibility factor. The factor is acknowledged but formal quantification is outside the scope of this assessment per ASME V&V 40 MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at Model Risk Level 2. Analyst training records are maintained but formal use error quantification is not required for this credibility level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Model form uncertainty assessment is not required at Model Risk Level 2. The SST k-omega turbulence model was selected based on published literature for rotating machinery hemolysis prediction, but formal model form uncertainty quantification is deferred."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
