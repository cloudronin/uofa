  "signature": "ed25519:7b2c4d8f1a3e6b9c0d5f2a8e4b7c1d3f6a9e2b5c8d0f4a7b1e3c6d9f2a5b8c1d",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release validation procedures consistent with MRL 2 requirements.",
      "rationale": "The ANSYS Fluent solver used for this analysis is a commercially validated CFD package with documented software quality assurance processes including version control, regression test suites, and formal release procedures. Achieved level 2 exceeds required level 1 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at MRL 2.",
      "rationale": "ANSYS Fluent has been verified against canonical benchmark problems including lid-driven cavity flow and backward-facing step. Published verification studies confirm correct numerical implementation of the Navier-Stokes equations and turbulence models used in this analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh independence must be demonstrated through a systematic grid refinement study with GCI < 5% for hemolysis index QoI.",
      "rationale": "A three-level grid refinement study was conducted using coarse (2.1M), medium (5.8M), and fine (14.2M) element meshes. Grid convergence index for the normalized index of hemolysis was 3.2%, satisfying the acceptance criterion. The medium mesh was selected for production simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match the simulated boundary conditions within documented tolerances for flow rate and rotational speed.",
      "rationale": "FDA benchmark experimental data were collected at flow rates of 2.5 and 6.0 L/min and rotational speeds of 2500 and 3500 RPM. CFD boundary conditions were set to match these values. Measured inlet velocity profiles and pressure boundary conditions were applied directly, ensuring test condition fidelity within ±2% of nominal."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must agree with experimental measurements within 20% across all validation operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis values were compared against FDA benchmark experimental measurements at all five operating points. Agreement ranged from 4.1% to 17.8% relative error, with a mean absolute error of 11.3%. All comparisons satisfied the 20% acceptance threshold, yielding achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis / relative hemolysis index) must be directly linked to the clinical decision criterion for CPB device clearance.",
      "rationale": "The relative hemolysis index (RH) is the primary regulatory acceptance criterion for CPB pump hemolysis assessment per FDA guidance. The NIH computed from CFD shear stress fields maps directly to RH through the established power-law hemolysis model. The QoI is therefore directly relevant to the regulatory decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry class and overlapping operating envelope (flow rate, rotational speed, fluid properties) as the COU.",
      "rationale": "Validation was performed using the FDA generic centrifugal blood pump geometry, which is the same geometric class as the CPB device under assessment. Operating conditions in validation experiments span the range of interest for the COU. Bovine blood analog fluid properties used in experiments are consistent with human blood rheological properties within accepted modeling assumptions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations is sufficient at MRL 2; formal truncation error quantification not required.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual convergence monitoring is not required. Residuals for all transport equations converged to below 1e-5. This factor is not assessed beyond convergence confirmation, which is acceptable at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of analyst qualifications and peer review of simulation setup is sufficient; formal use error quantification not required.",
      "rationale": "Simulation setup was performed by a CFD analyst with 8 years of cardiovascular device simulation experience and reviewed by a second qualified analyst. Formal use error quantification is not required at MRL 2. This factor is not assessed beyond qualification documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, selection of turbulence model and hemolysis power-law model with literature justification is sufficient; formal model form uncertainty quantification not required.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for rotating machinery flows in the literature. The Giersiepen-Wurzinger power-law hemolysis model was selected consistent with FDA guidance. Formal model form uncertainty quantification is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of input parameter sources and nominal values is sufficient; formal sensitivity analysis or uncertainty propagation not required.",
      "rationale": "All model input parameters including fluid density, viscosity, pump geometry dimensions, and boundary condition values are documented with source references. Nominal values are based on published FDA benchmark specifications. Formal input uncertainty quantification is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use of published FDA benchmark experimental dataset with documented sample preparation is sufficient; independent sample characterization not required.",
      "rationale": "The FDA benchmark experimental dataset provides hemolysis measurements collected using standardized bovine blood analog preparation protocols. Sample characterization data are documented in the published FDA benchmark study. Independent sample characterization is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative justification that validation experiment input parameters are representative of COU conditions is sufficient.",
      "rationale": "Qualitative comparison of validation experiment input parameters against COU operating conditions confirms that flow rates, rotational speeds, and fluid properties used in the FDA benchmark experiments are representative of CPB clinical operating conditions. Formal equivalency quantification is not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model has been reviewed and accepted. All 7 assessed credibility factors meet or exceed their required levels for MRL 2. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40 requirements. The model demonstrates sufficient credibility to support the regulatory decision regarding worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index criterion (RH < 1) was satisfied across all evaluated operating points.",
