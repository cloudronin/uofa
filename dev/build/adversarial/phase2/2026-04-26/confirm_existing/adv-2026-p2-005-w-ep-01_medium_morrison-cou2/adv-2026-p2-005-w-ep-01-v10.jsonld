  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-credibility-claim",
      "type": "Claim",
      "name": "CFD hemolysis model meets MRL-5 credibility requirements for absolute VAD hemolysis prediction",
      "description": "This claim asserts that the CFD model for the FDA generic centrifugal blood pump has been assessed against all 13 ASME V&V 40 credibility factors at Model Risk Level 5, and that the cumulative evidence from mesh convergence studies, Monte Carlo uncertainty quantification across five flow-speed operating points, experimental validation against the FDA benchmark dataset, and software quality assurance activities collectively supports the use of this model to predict absolute hemolysis index values for Class III VAD regulatory submissions. The supporting work includes three peer-reviewed publications on the FDA pump geometry, two internal validation reports covering shear-stress transport and power-law hemolysis model calibration, and a comprehensive UQ report documenting 95th-percentile prediction intervals below the clinical hemolysis threshold of 0.1 g/dL. All numerical solver settings were verified against ASME V&V 20 guidelines and the discretization error was bounded via Richardson extrapolation on three systematically refined meshes. The claim scope is limited to the five operating conditions enumerated in the COU and does not extend to off-design conditions or alternative pump geometries."
    }
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-gci",
      "type": "ValidationResult",
      "name": "Mesh convergence study — GCI < 3% on hemolysis index",
      "description": "Three systematically refined meshes (coarse 4.2M, medium 9.8M, fine 22.1M elements) were run at all five operating points. Grid Convergence Index on the normalized hemolysis index remained below 3% for all conditions, confirming discretization error is bounded within acceptable limits for MRL-5.",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/mesh-convergence-report-2025"
    },
    {
      "id": "https://uofa.net/synth/validation/experimental-hemolysis-comparison",
      "type": "ValidationResult",
      "name": "Experimental validation against FDA pump hemolysis benchmark",
      "description": "Predicted normalized index of hemolysis (nIH) values were compared against the FDA benchmark experimental dataset at five operating points. Mean absolute percentage error was 8.4%; all predictions fell within the experimental uncertainty band. Monte Carlo UQ (n=2000 Latin hypercube samples) confirmed 95th-percentile predictions remain below the 0.1 g/dL clinical threshold.",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/fda-pump-experimental-comparison-2024"
    }
  ],
  "hasCredibilityFactor": [
