      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression testing and version-controlled input files for all simulation runs.",
      "rationale": "Commercial CFD solver has documented V&V test suite and regression tests; however, input file version control was maintained only for the final mesh resolution, not for all intermediate runs. Achieved level falls one gradation below required for MRL-5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification including method of manufactured solutions or equivalent for the hemolysis transport equation.",
      "rationale": "Standard benchmark cases (lid-driven cavity, pipe flow) were verified; method of manufactured solutions was not applied to the power-law hemolysis scalar transport equation specifically. Gap documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI on hemolysis QoI across three meshes; GCI < 5% at all operating points.",
      "rationale": "GCI study completed on three meshes; maximum GCI of 2.9% achieved at design point. Temporal discretization error estimated but not formally bounded via independent time-step refinement study. One gradation gap remains."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulation boundary conditions within documented uncertainty; fluid temperature, hematocrit, and flow rate must be independently measured.",
      "rationale": "Flow rate and pressure boundary conditions were matched; hematocrit was nominally controlled but not independently measured during each experimental run. Temperature variation within ±1°C was documented but not propagated through the hemolysis model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) must be computed with experimental uncertainty; comparison must be performed at all five COU operating points.",
      "rationale": "Comparison performed at all five operating points using mean absolute percentage error; formal ASME V&V 20 validation metric with combined experimental and numerical uncertainty was not computed. Significant gap at MRL-5."
    },
