      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (nIH) must be directly mappable to the clinical decision threshold (absolute plasma-free hemoglobin) with documented conversion uncertainty.",
      "rationale": "nIH was used as the primary validation QoI; conversion to absolute plasma-free hemoglobin relies on empirical scaling relationships whose uncertainty was not formally propagated. The mapping is plausible but not rigorously quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
