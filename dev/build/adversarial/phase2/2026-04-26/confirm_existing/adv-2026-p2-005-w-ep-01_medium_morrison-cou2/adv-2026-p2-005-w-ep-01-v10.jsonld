  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis model for the FDA generic centrifugal blood pump demonstrates sufficient credibility for regulatory submission purposes. The central credibility claim (https://uofa.net/synth/claim/vad-hemolysis-credibility-claim) documents extensive supporting work including mesh convergence studies, Monte Carlo UQ, and experimental validation against the FDA benchmark dataset. Although several credibility factors show gaps between required and achieved levels, the team concluded that the combination of documented validation activities, bounded discretization error, and UQ results demonstrating 95th-percentile predictions below the clinical hemolysis threshold provides an adequate basis for acceptance under the current regulatory context. The claim is considered well-supported by the body of work described therein.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
