  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility",
      "type": "Claim",
      "name": "CFD model is sufficiently credible to predict absolute hemolysis index for Class III VAD",
      "description": "This claim asserts that the CFD model of the FDA generic centrifugal blood pump, as configured and exercised under COU2 operating conditions, achieves sufficient credibility to support regulatory submission of absolute hemolysis index predictions for a Class III ventricular assist device. The claim is grounded in an extensive body of supporting work: (1) mesh-independence studies performed at three refinement levels confirming less than 2% variation in predicted hemolysis index; (2) Monte Carlo uncertainty quantification spanning 500 Latin-hypercube samples across inlet flow rate, rotational speed, and blood viscosity, yielding a 95th-percentile hemolysis index of 0.0023 g/100 L, which is below the accepted clinical threshold of 0.01 g/100 L; (3) comparison of CFD-predicted velocity fields against particle image velocimetry (PIV) measurements from the FDA benchmark dataset, with mean velocity error of 8.3% across five measurement planes; and (4) a power-law hemolysis sub-model calibrated against in-vitro Couette-flow data from three independent laboratories. Taken together, these activities are considered to substantiate the claim that the model meets the credibility requirements for the intended regulatory use. No structured derivation link is encoded in this node.",
      "purpose": "Provide the central credibility assertion binding the V&V evidence body to the regulatory decision for COU2.",
      "scope": "Class III VAD, FDA generic centrifugal pump geometry, operating envelope of 2–8 L/min at 2000–4000 RPM"
    }
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA benchmark pump",
      "description": "CFD-predicted velocity fields compared against FDA benchmark PIV dataset across five axial planes. Mean absolute error 8.3%; maximum local error 21% near impeller tip. Validation activity conducted at operating point 5 L/min, 3500 RPM.",
      "wasDerivedFrom": "https://doi.org/10.1115/1.4034996"
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-couette-calibration",
      "type": "ValidationResult",
      "name": "Power-law hemolysis sub-model calibration against Couette-flow in-vitro data",
      "description": "The Giersiepen-Wurzinger power-law hemolysis model was recalibrated using pooled in-vitro Couette-flow data from three independent laboratories. Calibrated exponents: alpha=0.785, beta=0.062, C=1.8e-6. Residual standard error on log-transformed hemolysis index: 0.14.",
      "wasDerivedFrom": "https://doi.org/10.1111/j.1525-1594.2004.07265.x"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh-independence study — three refinement levels",
      "description": "Structured mesh refinement study at coarse (2.1 M cells), medium (5.8 M cells), and fine (14.3 M cells) levels. GCI index on hemolysis: 1.7%. Medium mesh selected for production runs as balance of accuracy and computational cost.",
      "wasDerivedFrom": "https://doi.org/10.1115/1.4028102"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis index",
      "description": "500-sample Latin-hypercube Monte Carlo propagation of inlet flow rate (±10%), rotational speed (±2%), and blood viscosity (±15%) uncertainties. 95th-percentile hemolysis index: 0.0023 g/100 L. Clinical threshold: 0.01 g/100 L. Safety margin factor: 4.3.",
      "wasDerivedFrom": "https://doi.org/10.1016/j.jbiomech.2018.09.031"
    }
  ],
