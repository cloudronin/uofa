  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credible",
      "type": "Claim",
      "name": "CFD model produces credible absolute hemolysis predictions for Class III VAD across all five operating points",
      "description": "This claim asserts that the CFD hemolysis model, implemented in ANSYS Fluent 2023R2 with the Giersiepen-Wurzinger power-law damage model and a Lagrangian particle-tracking sub-model, produces sufficiently credible predictions of the normalized index of hemolysis (NIH) across the five operating conditions specified in the COU. The claim is grounded in an extensive body of supporting work: (1) mesh convergence studies on three systematically refined grids (6M, 18M, and 54M hexahedral cells) demonstrating GCI values below 2.1% for NIH; (2) Monte Carlo uncertainty quantification over 1 200 Latin-hypercube samples propagating inlet velocity, fluid viscosity, and damage-model exponent uncertainties, yielding 95th-percentile NIH prediction intervals that remain below the clinical threshold of 0.1 g/100 L; (3) comparison against the FDA in-vitro hemolysis dataset (n=15 pump specimens) showing normalized RMS error of 18% on NIH; and (4) software quality assurance documentation conforming to FDA guidance on computational software. Taken together, the evidence base is judged sufficient to support regulatory submission at Model Risk Level 5 under the ASME V&V 40 framework. Note: all supporting evidence is described in the project technical report TR-COU2-2026 and the accompanying validation summary VS-COU2-2026.",
      "scope": "FDA generic centrifugal blood pump geometry; Class III VAD operating envelope (flow rates 3–6 L/min, rotational speeds 2 500–3 500 rpm); absolute NIH prediction below 0.1 g/100 L clinical threshold"
    }
  ],
