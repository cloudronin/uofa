  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-regulatory-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the 13-factor evaluation at MRL 5. Seven factors were formally assessed; all show achieved levels below required levels, with the most significant gaps in software quality assurance, model form, and test samples. Six factors remain not-assessed, representing epistemic gaps acknowledged in the companion validation report Morrison-VAD-VR-2026. The central claim that the CFD model adequately predicts absolute hemolysis index for Class III VAD use is considered supported by the documented validation campaign, Monte Carlo UQ results, and multi-laboratory PIV comparisons. Despite factor gaps, the overall evidence base is judged sufficient for regulatory submission under the agreed risk-informed framework, with residual gaps to be addressed in post-market surveillance. Decision: Accepted.",
