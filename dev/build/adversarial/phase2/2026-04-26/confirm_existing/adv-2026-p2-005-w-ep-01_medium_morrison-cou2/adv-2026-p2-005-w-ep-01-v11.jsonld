  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-cfd-adequate",
      "type": "Claim",
      "name": "CFD model adequately predicts absolute hemolysis index for Class III VAD across operating envelope",
      "description": "Based on an extensive body of work including particle image velocimetry validation studies on the FDA generic centrifugal pump, in-vitro hemolysis experiments spanning 5 flow-speed combinations, and Monte Carlo uncertainty quantification propagating inlet boundary condition variability through the Giersiepen-Wurzinger power-law hemolysis model, this claim asserts that the CFD model produces hemolysis index predictions within acceptable uncertainty bounds relative to the clinical threshold. The validation campaign encompassed three independent laboratories, mesh convergence studies at four refinement levels, and sensitivity analyses on viscosity and hematocrit. Collectively, this evidence base is judged sufficient to support the claim that the model is credible for absolute hemolysis prediction under VAD operating conditions at MRL 5. All referenced validation activities are documented in the companion validation report Morrison-VAD-VR-2026.",
      "purpose": "Establish that the CFD hemolysis model meets the credibility requirements for regulatory submission supporting Class III VAD pre-market approval.",
      "scope": "FDA generic centrifugal blood pump geometry; operating range 3–6 L/min at 2500–3500 RPM; Newtonian blood analog and whole blood; hemolysis index as scalar quantity of interest."
    }
  ],
  "hasValidationResult": [
    {
