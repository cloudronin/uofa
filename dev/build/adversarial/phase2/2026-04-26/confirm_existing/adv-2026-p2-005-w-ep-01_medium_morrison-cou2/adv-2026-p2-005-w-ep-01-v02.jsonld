  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-acceptability",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-measurements",
    "https://uofa.net/synth/data/hemolysis-in-vitro-campaign-2024"
  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-acceptability",
      "type": "Claim",
      "name": "CFD-predicted hemolysis index remains below clinical threshold across all VAD operating points",
      "description": "This claim asserts that the CFD model of the FDA generic centrifugal blood pump, when operated across the five flow-speed combinations specified in the COU2 intended use, produces a normalised index of hemolysis (NIH) below the absolute clinical threshold of 0.01 g/100 L at all operating points. The claim is grounded in a comprehensive simulation campaign comprising 120 steady-state RANS solutions, 40 transient LES snapshots, and a 1 000-sample Monte Carlo propagation of inlet boundary condition uncertainty. Blade-resolved shear-stress distributions were post-processed using the Giersiepen–Wurzinger power-law model; sensitivity analyses confirm that NIH predictions are robust to ±15 % variation in viscosity and ±10 % variation in pump rotational speed. Internal review documentation (Morrison Lab technical report ML-2024-07, archived at https://uofa.net/morrison/reports/ML-2024-07) and two independent mesh-refinement studies corroborate the central estimate. On the basis of this body of work the assessment team considers the claim well-founded and sufficient to support a credibility determination."
    }
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
