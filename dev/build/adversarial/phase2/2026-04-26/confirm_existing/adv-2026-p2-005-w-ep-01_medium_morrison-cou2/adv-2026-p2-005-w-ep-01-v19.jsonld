  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were assessed; of these, six achieved levels below required levels and one met its requirement (discretization error). Six factors were not assessed, representing significant epistemic gaps at MRL 5. The Monte Carlo UQ analysis demonstrates prediction intervals below clinical thresholds, and the supporting evidence body — including four peer-reviewed publications and FDA benchmark validation — collectively supports acceptance of the model for the stated COU. The team concludes that the model provides sufficient credibility for regulatory submission purposes under the totality-of-evidence standard.",
