  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credible",
      "type": "Claim",
      "name": "CFD model provides credible absolute hemolysis predictions for Class III VAD at MRL 5",
      "description": "The CFD hemolysis model, implemented in ANSYS Fluent 2023R1 with the modified power-law hemolysis correlation (Giersiepen-Wurzinger), has been subjected to extensive verification and validation activities documented in Morrison et al. (2023). Mesh convergence studies across three refinement levels (coarse, medium, fine) demonstrated GCI values below 2.5% for the hemolysis index at all five operating points. Experimental validation against FDA generic pump PIV and hemolysis data showed mean absolute error of 18% across operating conditions. Monte Carlo uncertainty quantification (n=5000 samples) propagated inlet flow, rotational speed, and fluid viscosity uncertainties, yielding 95th-percentile prediction intervals that remain below the clinical hemolysis threshold of 0.8 g/dL/100 h. The totality of this computational and experimental evidence, spanning four peer-reviewed publications and two independent laboratory replication studies, supports the conclusion that the model is sufficiently credible for predicting absolute hemolysis levels under VAD operating conditions. All supporting analyses are archived in the project evidence repository (https://uofa.net/synth/evidence/vad-hemolysis-archive).",
      "purpose": "Establish that the CFD hemolysis model meets the credibility threshold required for regulatory submission supporting Class III VAD device clearance under 21 CFR 870.3545.",
      "scope": "Applicable to the FDA generic centrifugal blood pump geometry operating between 3–6 L/min flow and 2000–4000 RPM rotational speed. Not applicable outside this operating envelope or to other pump geometries without re-evaluation."
    }
  ],
