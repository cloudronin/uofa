  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-below-threshold",
      "type": "Claim",
      "name": "CFD model predicts VAD hemolysis below clinical threshold across all operating points",
      "description": "This claim asserts that the CFD hemolysis model, applied to the FDA generic centrifugal blood pump geometry under five representative VAD operating conditions (flow rates 3–6 L/min, rotational speeds 2400–3600 RPM), consistently predicts a normalized index of hemolysis (NIH) below the accepted clinical threshold of 0.01 g/100 L. The claim is grounded in an extensive body of supporting work: (1) grid-convergence studies on three mesh refinements (4 M, 12 M, and 36 M hexahedral cells) demonstrating GCI < 2% on NIH; (2) power-law hemolysis model calibration against Heuser–Opitz and Zhang correlations; (3) Monte Carlo uncertainty propagation (N = 2000 Latin-hypercube samples) over viscosity, hematocrit, and inlet velocity boundary conditions yielding a 95th-percentile NIH of 0.0073 g/100 L; and (4) comparison against three independent in-vitro hemolysis experiments reported in the FDA pump benchmark dataset, with prediction errors below 18% at all operating points. Taken together, this body of evidence is considered sufficient to support the claim that the model is fit for purpose under COU2 conditions. The claim scope is restricted to the five nominal operating points specified in the COU; extrapolation to off-design or paediatric flow regimes is explicitly excluded.",
      "purpose": "Provide the primary credibility claim linking model predictions to the Class III VAD regulatory decision threshold for chronic hemolysis.",
      "scope": "FDA generic centrifugal blood pump; five VAD operating points; NIH metric only; adult patient population"
    }
  ],
  "hasValidationResult": [
    {
