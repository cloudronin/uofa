  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High",
    "deviceClass": "Class III"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credible",
      "type": "Claim",
      "name": "CFD model produces credible absolute hemolysis predictions for Class III VAD across all five operating points",
      "description": "This claim asserts that the CFD hemolysis model, employing the Giersiepen-Wurzinger power-law damage accumulation formulation on a mesh-independent RANS solution, produces absolute normalised index of haemolysis (NIH) predictions that are credible for regulatory decision-making under COU2. The claim is grounded in an extensive programme of work: (1) mesh convergence studies at three refinement levels showing < 2 % variation in NIH between the medium and fine meshes; (2) comparison of predicted NIH against five independent FDA benchmark experimental replicates yielding a mean absolute relative error of 8.3 %; (3) Monte Carlo propagation of inlet velocity and viscosity uncertainty confirming that 95th-percentile NIH predictions remain below the 0.01 g/100 L clinical threshold; and (4) software quality assurance records confirming solver version control and regression test passage. Collectively, these activities are considered sufficient to support a credibility determination at the required gradation for this COU. The claim scope is limited to the five nominal flow-speed operating points specified in the COU; extrapolation to off-nominal conditions is explicitly excluded."
    }
  ],
  "hasValidationResult": [
