    "https://uofa.net/synth/data/fda-pump-hemolysis-experimental",
    "https://uofa.net/synth/data/monte-carlo-uq-ensemble"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility",
      "type": "Claim",
      "name": "CFD model is sufficiently credible to predict absolute hemolysis index for Class III VAD at MRL 5",
      "description": "This claim asserts that the CFD hemolysis model, implemented in ANSYS Fluent 2022R2 with the modified power-law hemolysis scalar transport equation (Giersiepen-Wurzinger coefficients re-fitted to FDA pump data), achieves sufficient credibility to support regulatory submission for a Class III ventricular assist device. The claim is grounded in: (1) a 13-factor ASME V&V 40 credibility assessment conducted by the Morrison research group; (2) mesh convergence studies across four refinement levels demonstrating GCI < 3% on the hemolysis index QoI; (3) Monte Carlo uncertainty quantification over 1,200 parameter samples propagating inlet velocity profile uncertainty, blood viscosity variability, and hemolysis model coefficient uncertainty; (4) validation against the FDA generic pump experimental hemolysis dataset (five operating points) showing normalised RMSE of 18% on absolute NIH values; and (5) comparison of predicted and measured velocity fields via PIV at the impeller outlet plane with mean velocity error below 7%. The body of computational and experimental work described herein collectively supports the conclusion that model predictions are fit for the intended regulatory purpose under the stated COU. All uncertainty sources have been characterised and propagated. Residual gaps in model form uncertainty and blood damage constitutive model fidelity are acknowledged in the factor-level rationales.",
      "purpose": "Provide the formal credibility claim linking the CFD model outputs to the regulatory decision on absolute hemolysis acceptability for the VAD submission.",
      "scope": "Applies to the five operating conditions (flow rate 3–6 L/min, rotational speed 2400–3200 RPM) specified in the COU. Does not extend to off-design transient start-up or cavitation regimes."
    }
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-gci",
      "type": "ValidationResult",
      "name": "Mesh convergence GCI study — hemolysis index QoI",
      "description": "Grid convergence index computed across four structured hexahedral meshes (0.8 M, 2.1 M, 5.4 M, 12.7 M cells). GCI on the volume-averaged hemolysis index QoI converges to 2.7% on the fine-to-medium pair, satisfying the MRL 5 discretization error requirement threshold of 5%.",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/mesh-convergence-study-2024"
    },
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at impeller outlet",
      "description": "Particle image velocimetry measurements at the impeller outlet plane (five operating points) compared against CFD predictions. Mean velocity magnitude error 6.4%, maximum local error 14.2% in the blade wake region. Comparison conducted under matched Reynolds number conditions.",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/piv-experimental-dataset-2023"
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-nrmse",
      "type": "ValidationResult",
      "name": "Absolute NIH hemolysis index validation against FDA pump data",
      "description": "Predicted normalised index of haemolysis (NIH) compared against FDA generic pump experimental measurements at five operating points. Normalised RMSE 18.3%. Monte Carlo 95th-percentile prediction interval brackets all five experimental measurements.",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/fda-pump-hemolysis-experimental-2022"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — 1200-sample ensemble",
      "description": "1,200-sample Monte Carlo propagation of inlet velocity profile uncertainty (±8%), blood dynamic viscosity (CV 6%), and Giersiepen-Wurzinger coefficient uncertainty (±15%). 95th-percentile NIH prediction remains below clinical threshold at all five operating points.",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/monte-carlo-uq-ensemble-2024"
    }
  ],
