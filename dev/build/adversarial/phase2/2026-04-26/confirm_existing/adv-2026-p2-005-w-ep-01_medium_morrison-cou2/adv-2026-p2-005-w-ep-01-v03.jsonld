  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software verification plan with traceability to requirements; regression test suite covering hemolysis scalar transport solver; version-controlled source with change control log.",
      "rationale": "ANSYS Fluent 2022R2 vendor SQA documentation reviewed; internal UDF implementing hemolysis scalar transport has unit tests but no formal regression suite. Version control exists but change control log incomplete. Achieved level 2 against required level 4 at MRL 5."
