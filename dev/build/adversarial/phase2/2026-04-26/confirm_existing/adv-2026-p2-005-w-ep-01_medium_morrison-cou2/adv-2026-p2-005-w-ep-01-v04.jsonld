      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/monte-carlo-uncertainty-hemolysis"
    }
  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-cfd-credibility",
      "type": "Claim",
      "name": "CFD model is sufficiently credible to predict absolute hemolysis for Class III VAD at MRL 5",
      "description": "This claim asserts that the CFD hemolysis model, applied to the FDA generic centrifugal blood pump geometry under VAD operating conditions, produces hemolysis index predictions of sufficient credibility to support regulatory decision-making for a Class III device. The claim is grounded in: (1) three independent validation studies comparing predicted velocity fields and hemolysis indices against PIV and in-vitro measurements; (2) a 500-sample Monte Carlo uncertainty quantification demonstrating that 95th-percentile predictions remain below the absolute clinical hemolysis threshold with 91% probability; (3) mesh convergence studies showing < 2% change in NIH between medium and fine grids; and (4) software quality assurance records confirming solver verification against manufactured solutions. All seven assessed credibility factors show partial achievement relative to MRL 5 requirements, and six factors remain as documented epistemic gaps. Despite these gaps, the conservative overprediction bias of the model is judged sufficient to accept the claim for the stated intended use.",
      "purpose": "Support regulatory submission for Class III VAD hemolysis acceptance without predicate device comparison",
      "scope": "FDA generic centrifugal blood pump geometry; 5 flow-speed operating points; absolute NIH prediction only"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035672",
