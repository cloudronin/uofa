  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-below-threshold",
      "type": "Claim",
      "name": "CFD-predicted absolute hemolysis index remains below clinical threshold across all VAD operating points",
      "description": "Based on a comprehensive Monte Carlo uncertainty quantification study encompassing 2 500 CFD realizations across five flow-speed combinations (3–6 L/min, 2 400–3 200 RPM), the normalized index of hemolysis (NIH) predicted by the power-law Giersiepen-Wurzinger model coupled to the k-omega SST turbulence closure remains below the accepted clinical threshold of 0.005 g/100 L at the 95th percentile of the uncertainty distribution. Supporting analyses include mesh-refinement studies (three refinement levels, GCI < 2.1 %), time-step sensitivity sweeps, and comparison against FDA-published particle image velocimetry (PIV) velocity fields with mean velocity error < 8 %. The claim scope is restricted to the five operating points enumerated in the COU and does not extend to off-design cavitation regimes. Internal review by the credibility assessment team concluded that the body of computational and experimental work is sufficient to assert hemolysis acceptability under the intended use conditions.",
      "purpose": "Establish that the CFD model output meets the absolute hemolysis acceptance criterion required for Class III VAD regulatory submission under 21 CFR 870.3545.",
      "scope": "Five operating points: (3 L/min, 2 400 RPM), (4 L/min, 2 600 RPM), (4 L/min, 3 000 RPM), (5 L/min, 3 000 RPM), (6 L/min, 3 200 RPM). Power-law hemolysis model only; does not cover shear-induced platelet activation."
    }
  ],
