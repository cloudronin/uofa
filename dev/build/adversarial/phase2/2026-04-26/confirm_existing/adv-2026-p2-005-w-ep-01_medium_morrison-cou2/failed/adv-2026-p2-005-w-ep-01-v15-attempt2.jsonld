  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 certification and maintain a version-controlled validation suite with documented regression testing covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) holds ISO 9001 certification. Regression suite covers 47 benchmark cases but does not include a dedicated non-Newtonian blood rheology benchmark, leaving a gap against the required level 4 criterion. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
