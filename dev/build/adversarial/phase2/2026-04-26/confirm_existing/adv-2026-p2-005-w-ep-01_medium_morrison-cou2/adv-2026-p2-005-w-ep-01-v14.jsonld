    }
  ],
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-credibility-claim",
      "type": "Claim",
      "name": "CFD model is sufficiently credible to predict absolute hemolysis levels for Class III VAD under COU2 conditions",
      "description": "This claim asserts that the CFD hemolysis model for the FDA generic centrifugal blood pump has demonstrated sufficient credibility to support regulatory decision-making regarding absolute hemolysis levels under VAD operating conditions (Model Risk Level 5). The assessment draws on a comprehensive body of supporting work: (1) a three-level mesh convergence study with Richardson extrapolation confirming GCI below 4 % on the primary QoI; (2) comparison of NIH predictions against five FDA benchmark experimental operating points with mean absolute error below 0.005 g/100 L; (3) Monte Carlo uncertainty quantification (n = 2000 samples) propagating inlet flow, rotational speed, and fluid viscosity uncertainties, with 95th-percentile NIH remaining below the accepted clinical threshold of 0.1 g/100 L at all operating points; (4) software quality assurance records confirming solver version control and regression testing; and (5) independent review of model inputs and boundary condition fidelity relative to the intended COU. Taken together, these activities provide a coherent technical basis for the credibility determination. The claim scope is limited to the five flow-speed combinations enumerated in the COU and does not extend to off-design transient conditions or patient-specific geometries.",
      "purpose": "Provide the central credibility warrant linking all V&V activities to the regulatory acceptance decision for COU2.",
      "scope": "Five nominal operating points (Q = 3–7 L/min, N = 2000–3500 RPM) for the FDA generic centrifugal pump geometry under steady-state CFD assumptions with the power-law hemolysis damage model."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037554",
