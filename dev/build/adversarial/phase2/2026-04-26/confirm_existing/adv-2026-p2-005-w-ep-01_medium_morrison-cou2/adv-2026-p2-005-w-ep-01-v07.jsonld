  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/vad-hemolysis-credibility-claim",
      "type": "Claim",
      "name": "CFD model predicts absolute hemolysis index below clinical threshold across all five VAD operating points",
      "description": "Based on a comprehensive body of work including 5 000-sample Monte Carlo uncertainty quantification, three-level mesh-refinement studies (coarse 4.2 M cells, medium 11.7 M cells, fine 28.4 M cells), and bench-top hemolysis measurements at all five flow-speed combinations (2 L/min–6 000 rpm through 6 L/min–9 000 rpm), the CFD model using a power-law hemolysis damage accumulation approach is asserted to predict the normalised index of haemolysis (NIH) below the clinical acceptance threshold of 0.01 g/100 L at all operating points. The 95th-percentile Monte Carlo envelope remains below threshold even when viscosity, inlet turbulence intensity, and RBC fragility parameters are varied over their full physiological ranges. Mesh-convergence Richardson extrapolation yields a discretisation uncertainty of ±4.2% on NIH, well within the required ±10% tolerance at MRL 5. Turbulence model sensitivity (SST k-ω vs. realizable k-ε) contributes an additional ±6.8% spread, captured within the Monte Carlo ensemble. Cross-laboratory validation against published FDA inter-laboratory data confirms velocity field agreement within 12% RMS at mid-plane. The claim scope is limited to the five specified operating points; extrapolation beyond 9 000 rpm or below 2 L/min is explicitly excluded. All supporting calculations, raw PIV comparison data, and UQ run logs are archived in the project repository under accession VAD-COU2-2026.",
      "scope": "Five operating points: (2 L/min, 6000 rpm), (3 L/min, 7000 rpm), (4 L/min, 7500 rpm), (5 L/min, 8000 rpm), (6 L/min, 9000 rpm). Class III VAD only."
    }
  ],
