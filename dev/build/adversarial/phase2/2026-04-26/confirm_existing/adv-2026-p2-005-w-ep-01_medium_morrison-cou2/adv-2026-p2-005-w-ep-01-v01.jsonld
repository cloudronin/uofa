    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/monte-carlo-uq-hemolysis-runs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/cou2-vad-hemolysis-credibility",
      "type": "Claim",
      "name": "CFD model provides sufficient credibility for absolute hemolysis prediction in VAD COU",
      "description": "This claim asserts that the CFD hemolysis model for the FDA generic centrifugal blood pump has been assessed across all 13 ASME V&V 40 credibility factors and demonstrates adequate credibility for predicting absolute hemolysis index values under VAD operating conditions. The claim is informed by an extensive body of supporting work including: (1) mesh convergence studies performed at three refinement levels on the FDA pump geometry demonstrating GCI values below 5% for hemolysis index; (2) Monte Carlo uncertainty quantification across 1000 Latin-hypercube samples spanning inlet flow rate, rotational speed, and blood viscosity; (3) validation against published experimental hemolysis measurements from Hariharan et al. (2011) and Malinauskas et al. (2017) across 5 operating points; (4) software quality assurance documentation under ISO 9001 for the CFD solver; and (5) independent mesh generation and post-processing review by a second analyst. Taken together, these activities are considered to establish a credible basis for model use in the VAD context of use at MRL 5.",
      "purpose": "Establish that the computational hemolysis model meets the credibility threshold required for regulatory submission supporting Class III VAD device clearance.",
      "scope": "Applies to absolute hemolysis index predictions for the FDA generic centrifugal blood pump geometry operated within the VAD envelope: flow rates 2–8 L/min, rotational speeds 2000–3500 RPM."
    }
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-hariharan-2011",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against Hariharan et al. 2011 experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements from Hariharan et al. (2011) across five operating points. Mean absolute percentage error of 18.4% observed; systematic over-prediction at high shear conditions noted.",
      "wasDerivedFrom": "https://doi.org/10.1115/1.4002575"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-malinauskas-2017",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against Malinauskas et al. 2017 FDA round-robin data",
      "description": "CFD predictions compared against FDA interlaboratory round-robin experimental hemolysis measurements for the generic centrifugal pump. Model predictions fall within the inter-lab variability band at 3 of 5 operating points; 2 points exhibit under-prediction exceeding 25%.",
      "wasDerivedFrom": "https://doi.org/10.1115/1.4037090"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — three-level GCI assessment",
      "description": "Grid convergence index (GCI) computed on coarse, medium, and fine meshes (4.2M, 11.6M, 28.9M cells). GCI for hemolysis index: fine-medium pair 3.8%, medium-coarse pair 9.1%. Achieved discretization error level assessed as Gradation 2.",
      "wasDerivedFrom": "https://doi.org/10.1115/1.4006037"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — 1000-sample Latin hypercube",
      "description": "Monte Carlo UQ performed over inlet flow rate (±10%), rotational speed (±5%), and blood viscosity (±15%). 95th-percentile hemolysis index prediction interval spans a factor of 2.3 relative to the median, indicating substantial parametric sensitivity. Results documented in internal technical report TR-2025-VAD-UQ-003.",
      "wasDerivedFrom": "https://uofa.net/synth/data/monte-carlo-uq-hemolysis-runs"
    }
  ],
