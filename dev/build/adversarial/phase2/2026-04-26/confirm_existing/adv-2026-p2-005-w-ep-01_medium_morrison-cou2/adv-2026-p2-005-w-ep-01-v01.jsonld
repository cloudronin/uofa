  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the VAD hemolysis CFD model has been reviewed. All 13 ASME V&V 40 credibility factors have been evaluated. Seven factors were formally assessed; six remain as epistemic gaps at MRL 5. The primary claim of sufficient model credibility for absolute hemolysis prediction is considered established based on the extensive supporting work documented in validation studies, mesh convergence analysis, and Monte Carlo uncertainty quantification. The assessment team accepts the package for submission, acknowledging that achieved levels fall below required levels in all assessed factors but judging the overall evidence body as adequate for the intended regulatory purpose.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
