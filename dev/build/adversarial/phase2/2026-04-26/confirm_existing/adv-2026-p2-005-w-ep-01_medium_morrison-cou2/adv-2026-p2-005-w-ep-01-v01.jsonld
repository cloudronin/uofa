  "hash": "sha256:a3f7c2e1d09b4856f2a1c3e7d5b9f0124c8e6a3d7f1b5c9e2a4d8f6b0c3e7a1d",
  "signature": "ed25519:b2e4a6c8d0f1e3a5c7b9d2f4a6e8c0b2d4f6a8e0c2b4d6f8a0e2c4b6d8f0a2c4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be validated under ISO 9001 QMS with documented version control, regression testing, and change management procedures covering all modules used in hemolysis prediction.",
      "rationale": "Solver operates under ISO 9001 QMS with version control and regression test suite. However, the hemolysis post-processing module lacks independent regression tests, and change management records for the last two solver releases are incomplete. Achieved level 3 falls short of required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent formal verification must demonstrate order-of-accuracy convergence for all governing equations including turbulence closure and hemolysis transport.",
      "rationale": "MMS verification is available for Navier-Stokes and k-ω SST turbulence equations but has not been performed for the power-law hemolysis transport equation. Achieved level 2 is substantially below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization error estimate for hemolysis index must be below 5% using at least three systematically refined meshes with refinement ratio ≥ 1.3.",
      "rationale": "Three-level GCI study completed. Fine-medium GCI of 3.8% meets the 5% threshold, but medium-coarse GCI of 9.1% indicates the medium mesh is insufficiently resolved. Asymptotic range not fully achieved. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with full uncertainty characterization including fluid temperature, hematocrit, and pump rotational speed measurement uncertainty.",
      "rationale": "Hariharan et al. (2011) and Malinauskas et al. (2017) datasets provide operating point documentation but hematocrit uncertainty is not reported in either source. Temperature control documentation is partial for the FDA round-robin data. Achieved level 2 versus required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., validation uncertainty U_val) must be computed accounting for both numerical and experimental uncertainties; metric must demonstrate model prediction within validation uncertainty at all 5 operating points.",
      "rationale": "Mean absolute percentage error computed but formal validation uncertainty U_val has not been assembled. Two of five operating points show discrepancies exceeding 25%, which would likely exceed U_val bounds. Achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (normalized index of hemolysis) must be directly mappable to the COU decision QoI (absolute hemolysis index below clinical threshold) with documented conversion and associated uncertainty.",
      "rationale": "NIH used in validation studies is related to absolute hemolysis index through a conversion factor dependent on test fluid volume and exposure time. Conversion is applied but its uncertainty contribution is not propagated into the final hemolysis index estimate. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full VAD operating envelope (2–8 L/min, 2000–3500 RPM) with at least one validation point in each quadrant of the operating space.",
      "rationale": "Validation data covers 5 operating points but all cluster in the mid-range (4–6 L/min, 2500–3000 RPM). Extrapolation to low-flow high-speed corner of the VAD envelope is unsupported by validation evidence. Achieved level 3 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and round-off error contributions must be documented and shown to be negligible relative to discretization error for hemolysis predictions.",
      "rationale": "Iterative convergence residuals are reported but no formal analysis of round-off error or iterative error contribution to hemolysis index has been performed. Factor not assessed; achieved level assigned as 1 (epistemic gap at MRL 5)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition specification, and post-processing procedures must be documented with findings resolved prior to submission.",
      "rationale": "A second-analyst review of mesh generation was performed but boundary condition specification and hemolysis post-processing scripts have not been independently reviewed. Use error factor not fully assessed; epistemic gap flagged."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty arising from turbulence closure selection and hemolysis constitutive model must be quantified through sensitivity studies comparing at least two turbulence models and two hemolysis power-law parameterizations.",
      "rationale": "Only k-ω SST turbulence closure and the Giersiepen-Wurzinger hemolysis model have been used. No model form sensitivity study comparing alternative closures or hemolysis constitutive models has been performed. Critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions derived from measurement data or literature; sensitivity indices (e.g., Sobol) must identify dominant inputs for hemolysis prediction.",
      "rationale": "Monte Carlo UQ performed with Latin hypercube sampling over three parameters. Sobol sensitivity indices not computed; dominant inputs identified only qualitatively from scatter plots. Achieved level 2 versus required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog fluid properties (viscosity, density, red blood cell fragility index) used in validation experiments must be characterized and shown to be representative of clinical blood properties within documented tolerance.",
      "rationale": "Experimental studies used bovine blood or porcine blood analogs. Species-specific differences in red blood cell fragility relative to human blood have not been characterized or bounded. Test sample representativeness not assessed; epistemic gap flagged."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated to match experimental test conditions within stated measurement uncertainties for all boundary conditions.",
      "rationale": "Boundary conditions for validation simulations were set to nominal experimental values without accounting for measurement uncertainty in inlet velocity profiles or outlet pressure. Equivalency of input parameters not formally assessed; epistemic gap at MRL 5."
