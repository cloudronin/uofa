    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by analyst not involved in original model construction; checklist-based review completed.",
      "rationale": "An independent senior analyst at DePuy Synthes reviewed boundary conditions, material assignments, contact definitions, and load application against the ASTM F1717 protocol. No errors were identified. Use-error risk is considered low given the standardized nature of the F1717 test simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening validated against coupon-level Ti-6Al-4V tensile data; contact mechanics representation reviewed against published literature.",
      "rationale": "The pedicle screw and rod are modeled as elastic-plastic Ti-6Al-4V using a bilinear isotropic hardening law calibrated from coupon tests. Bone analog (UHMWPE block) is represented as linear elastic. Contact between screw head and rod is modeled with Coulomb friction (mu=0.2). Model form assumptions are consistent with published FDA guidance and peer-reviewed F1717 simulation literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable coupon testing; geometric inputs from calibrated CMM measurements of test specimens; uncertainty in inputs propagated via sensitivity study.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (1.2 GPa) are derived from lot-specific coupon testing performed at DePuy Synthes. Rod and screw geometry digitized from CMM measurements of production parts. A one-at-a-time sensitivity study confirmed that QoI variation attributable to input uncertainty is within ±3%, well below acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; sample traceability documented; dimensional inspection confirms conformance to drawing.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All specimens are from production lots with full material and dimensional traceability. CMM inspection confirmed all critical dimensions within drawing tolerances. Sample size exceeds the minimum required for statistical comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at minimum two independent test configurations evaluated.",
      "rationale": "Testing was conducted under a single ASTM F1717 static compression-bending configuration at room temperature in ambient air. While this configuration is the regulatory standard, only one test condition was evaluated. Achieved level 2 falls below the required level 3. This known gap is acknowledged and accepted given that F1717 is the FDA-mandated benchmark and no alternative loading conditions are specified in the predicate device submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs demonstrably derived from the same specimens used in testing; no surrogate material properties or nominal geometry used without justification.",
      "rationale": "Material properties and geometry used in the FEA were measured directly from the same production lots as the test specimens. Friction coefficients were taken from published tribology literature for Ti-Ti contacts under dry conditions, consistent with test setup. No significant discrepancies between simulation inputs and test conditions were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval <1.96 for all QoIs; percentage difference <10% for mean predicted vs. mean experimental values.",
      "rationale": "All three QoIs (construct stiffness, yield force, force at 40 mm) satisfy E/uval <1.96 and percentage difference <10% across all three FEA platforms. The most conservative comparison (FDA in-house model vs. Lab 2 data) yields E/uval=1.61 for yield force. Acceptance criteria are met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
