    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver residuals converge to <1e-4 relative norm; energy balance checked at each load increment.",
      "rationale": "All analyses used Ansys sparse direct solver with force and displacement convergence criteria of 0.1% and 0.5% respectively. No unconverged increments were recorded across the 11 model instances. Energy balance confirmed post-solution."
