    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "rationale": "Model form uncertainty — including the choice of contact formulation, titanium alloy plasticity model, and bone-screw interface representation — was flagged as requiring a dedicated sensitivity study that falls outside the current project timeline. The team acknowledged this factor but did not complete a formal gradation assessment, treating it as beyond scope for this submission cycle without quantitative justification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified coupon testing of the same Ti-6Al-4V heat lot; geometric inputs derived from CMM measurements with stated tolerances.",
      "rationale": "Elastic modulus, yield strength, and ultimate tensile strength were obtained from tensile coupon tests on the same material heat lot as the test constructs (n=5 coupons per property). Screw and rod geometry was digitized via coordinate measuring machine with ±0.005 mm tolerance. Input uncertainty is propagated to QoI uncertainty via a 200-sample Latin hypercube study. Achieved level 3 meets the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 constructs from the same design revision tested; sample traceability to manufacturing lot documented.",
      "rationale": "Eleven constructs were assembled from production-representative components (same design revision, same Ti-6Al-4V alloy lot). Manufacturing lot certificates and dimensional inspection reports are on file. Sample size exceeds the required minimum of 10 for level 3, and inter-laboratory consistency (two labs) confirms reproducibility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios defined in the COU; at minimum two independent load levels tested.",
      "rationale": "Testing was conducted under a single ASTM F1717 load configuration (static compression-bending at a single offset distance). While the protocol is standardized and reproducible, only one test condition was applied, limiting the ability to characterize model behavior across the clinical loading envelope. Achieved level 2 falls below the required level 3; this deficiency is acknowledged and flagged in the decision record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All simulation input parameters traceable to measured experimental values; any surrogate inputs justified with sensitivity analysis.",
      "rationale": "Boundary conditions in the FEA model were set to match the physical test fixture geometry, grip dimensions, and load application point as measured by the testing laboratories. No surrogate inputs were required; all material and geometric parameters were directly measured. Equivalency is fully documented in the simulation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all three QoIs; percentage error < 10% for each QoI.",
      "rationale": "The validation metric E/uval was computed for construct stiffness (1.12), yield force (0.87), and force at 40 mm displacement (1.34), all below the 1.96 threshold. Percentage errors were 4.2%, 3.8%, and 6.1% respectively, all within the 10% acceptance bound. Both acceptance criteria are satisfied for all three QoIs across both laboratories."
    },
    {
