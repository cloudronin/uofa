    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates < 2% change in all three QoIs between the medium and fine mesh densities.",
      "rationale": "A three-level mesh refinement study (coarse ~80k, medium ~220k, fine ~610k elements) was conducted on the non-cannulated screw geometry. Von Mises stress at the screw-rod junction and all three QoIs changed by less than 1.4% between medium and fine meshes. Richardson extrapolation estimated GCI < 0.8%. Discretization error is well-controlled at the required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
