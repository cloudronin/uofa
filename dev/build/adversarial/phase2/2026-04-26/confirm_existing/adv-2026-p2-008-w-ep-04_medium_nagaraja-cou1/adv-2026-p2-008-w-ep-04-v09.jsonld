  "signature": "ed25519:b4e2d1c3f5a7980e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical R2023 R1 is a commercially validated solver with documented V&V procedures. Required Gradation 2: documented QA processes and version control.",
      "rationale": "Ansys Mechanical R2023 R1 employed. Vendor-supplied software validation documentation and release notes confirm QA processes consistent with Gradation 2. Version control maintained via internal configuration management system. No custom solver modifications introduced."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 suite reproduced within 1% of analytical solutions. Required Gradation 2.",
      "rationale": "Linear static benchmark cases (Timoshenko beam bending, Hertzian contact patch) reproduced to within 0.4% of closed-form solutions using the same element types (SOLID186, CONTA174) employed in the pedicle screw model. Code verification documented in internal report NCV-2024-003."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinements. Richardson extrapolation GCI < 5%. Required Gradation 3.",
      "rationale": "Three-level mesh refinement study performed (coarse: 0.8 mm global seed, medium: 0.5 mm, fine: 0.3 mm at screw-rod interface). Von Mises stress at critical notch and construct stiffness monitored. Stiffness GCI = 1.8%; stress GCI = 3.2%. Medium mesh adopted for production runs, balancing accuracy and computational cost. Results documented in DE-2024-007."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "rationale": "Numerical solver error was considered beyond the scope of this submission. The commercial solver is assumed to handle iterative convergence and round-off adequately for this quasi-static linear regime. A formal solver error quantification was not conducted as part of the current credibility assessment package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "rationale": "Use error assessment was scoped out of the current package on the basis that model setup procedures are considered routine for experienced FEA analysts. Formal independent review of analyst inputs against simulation plan has not been performed and is deferred to a future audit cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions (linear elasticity, small deformation, frictional contact) justified by literature and sensitivity analysis. Required Gradation 3.",
      "rationale": "Linear elastic constitutive law applied to titanium alloy (Ti-6Al-4V) and UHMWPE test block. Literature confirms linear regime up to yield; load levels in F1717 protocol remain below yield for the screw body. Frictional contact (μ=0.2) at screw-rod interface validated against torque-to-yield data. Sensitivity study confirms <3% QoI sensitivity to ±20% variation in friction coefficient."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable coupon tests or peer-reviewed literature with uncertainty bounds reported. Required Gradation 3.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa ± 3%) and Poisson's ratio (0.34 ± 0.01) sourced from ASTM E8 coupon tests on production-lot material. UHMWPE block properties (E=0.7 GPa) from supplier datasheet corroborated by three independent literature sources. Geometric inputs derived from CMM measurements of production screws (n=5); dimensional variability <0.02 mm."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens traceable to production design intent; dimensional inspection documented. Required Gradation 2.",
      "rationale": "N=11 constructs assembled from production-representative non-cannulated 7.5 mm pedicle screws. Dimensional inspection via CMM confirmed geometry within drawing tolerances. Chain of custody documented from manufacturing to both test laboratories. Specimens not re-used across test conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicated in model with uncertainty quantification; environmental conditions documented. Required Gradation 3.",
      "rationale": "ASTM F1717 protocol followed at both laboratories. Single test condition (quasi-static, room temperature, 10 mm/min crosshead speed) applied; no variation in loading rate or temperature explored. Achieved Gradation 2 because only one test condition was used, limiting the ability to characterize condition-dependent model response. This shortfall is noted as a known gap consistent with the base COU description."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions demonstrably equivalent to experimental setup. Required Gradation 2.",
      "rationale": "Fixture geometry, grip offsets, and load application points replicated in FEA from engineering drawings of F1717 test fixtures. Displacement-controlled loading applied at upper grip reference point consistent with experimental crosshead displacement. Boundary condition equivalency confirmed by overlay of deformed FEA mesh with high-speed camera frames from laboratory 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; acceptance threshold E/uval < 1.96 pre-specified. Required Gradation 3.",
      "rationale": "Three QoIs compared: construct stiffness (E/uval=0.87), yield force (E/uval=1.31), force at 40 mm displacement (E/uval=1.44). All three E/uval values below pre-specified threshold of 1.96. Validation uncertainty (uval) computed from experimental inter-laboratory variability and numerical uncertainty contributions. Results tabulated in VR-2024-011."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory submission requirements. Required Gradation 2.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and cited in FDA guidance for spinal implant submissions. These quantities directly inform predictions of in vivo mechanical performance and fatigue susceptibility. Linkage to clinical failure mode (fatigue fracture at screw-rod interface) documented in risk analysis RA-2023-042."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading, and material match COU within documented extrapolation bounds. Required Gradation 3.",
      "rationale": "Validation specimens are production-identical to the device submitted for 510(k) clearance. Loading protocol (ASTM F1717 compression-bending) directly replicates the COU loading mode. Both test laboratories are ISO 17025 accredited. Extrapolation from validation scenario to COU is zero-distance for geometry and loading; minor extrapolation in scale of clinical loading addressed by safety factor analysis in SF-2024-005."
    }
  ],
