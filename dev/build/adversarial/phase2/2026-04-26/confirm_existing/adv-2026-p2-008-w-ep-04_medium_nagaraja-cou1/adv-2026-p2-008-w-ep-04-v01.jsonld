  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble demonstrates satisfactory agreement with N=11 bench test constructs across all three QoIs, with E/uval values well below the 1.96 threshold and relative errors below 10%. Twelve of thirteen V&V 40 credibility factors have been assessed; eleven meet or exceed their required levels. The Test conditions factor achieves level 2 against a required level 3, reflecting the single-condition ASTM F1717 protocol — this limitation is documented and accepted given the standardized nature of the test. The Relevance of the validation activities to the COU factor has not been assessed, as the clinical relevance review is deferred to a future submission phase; this deferral is noted but does not preclude acceptance of the bench-level validation package.",
