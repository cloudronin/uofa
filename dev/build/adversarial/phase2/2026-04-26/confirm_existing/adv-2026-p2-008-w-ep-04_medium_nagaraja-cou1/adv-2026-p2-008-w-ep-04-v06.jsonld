  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble meets all quantitative acceptance criteria for the three primary QoIs (stiffness, yield force, force at 40 mm displacement) with E/uval values below 1.96 and percent differences below 10%. Eleven factors are assessed; two factors (Relevance of QoIs and Relevance of validation activities to COU) are carried as not-assessed on the basis that they were considered beyond the scope of the current submission phase and that regulatory precedent supports the chosen validation approach. The test conditions factor achieved only Gradation 2 against a required Gradation 3, representing a known limitation. Despite these gaps, the overall credibility evidence is judged sufficient to support a medium assurance acceptance decision for the non-cannulated 7.5 mm pedicle screw compression-bending COU.",
