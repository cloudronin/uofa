  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment is accepted at Medium assurance level. Eleven of thirteen V&V 40 factors were assessed; ten met or exceeded their required levels. The Test conditions factor fell below its required level (Gradation 1 vs. required 2), which is acknowledged and accepted given the standardized nature of the F1717 protocol. Two factors — Numerical solver error and Relevance of the validation activities to the COU — were not assessed, with rationale citing scope limitations. The assessment team accepted these gaps on the basis that the overall validation evidence is considered sufficient for the medium-consequence decision context, though no formal bounding argument was provided to substantiate that the unassessed factors do not materially affect credibility at modelRiskLevel 3.",
