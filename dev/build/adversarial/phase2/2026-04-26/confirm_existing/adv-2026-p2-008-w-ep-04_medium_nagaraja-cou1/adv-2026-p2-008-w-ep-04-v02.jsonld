      "rationale": "N=11 non-cannulated 7.5 mm constructs were tested across two independent laboratories. All samples were manufactured from the same production lot, inspected per drawing tolerances, and assembled to the specified setscrew torque. Sample representativeness is considered adequate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions match COU loading environment; at least two distinct load levels or configurations evaluated.",
      "rationale": "Testing was conducted under a single static compression-bending configuration per ASTM F1717. Only one test condition (45 mm offset, room temperature, quasi-static) was employed. This falls below the required level because no variation in load rate, temperature, or offset distance was explored, limiting the ability to bound condition-dependent model error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented traceability between experimental measurements and FEA input parameters; any discrepancies quantified and propagated.",
      "rationale": "A parameter traceability matrix maps each FEA input (geometry, material, boundary condition) to its experimental measurement source. Discrepancies in rod diameter (±0.02 mm) and friction coefficient were quantified and included in the uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
