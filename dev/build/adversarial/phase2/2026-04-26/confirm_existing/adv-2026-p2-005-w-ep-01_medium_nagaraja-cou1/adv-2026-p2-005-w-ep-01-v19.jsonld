  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted because the COU is explicitly scoped to static compression-bending only and the regulatory submission does not rely on dynamic or fatigue predictions from this FEA model. All three QoIs pass the quantitative validation criterion (E/uval < 1.96, percent difference < 10%). The multi-organization, multi-laboratory validation exercise provides high confidence in model predictions. Overall credibility assessment: Accepted at Medium assurance level.",
