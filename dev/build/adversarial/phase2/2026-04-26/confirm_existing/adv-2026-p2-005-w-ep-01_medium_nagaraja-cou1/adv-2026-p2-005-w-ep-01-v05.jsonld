  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/noncannulated-cb-accuracy-claim",
      "type": "Claim",
      "name": "FEA model accurately predicts compression-bending behavior of the non-cannulated pedicle screw construct within ASME V&V 40 acceptance bounds",
      "description": "The FEA model ensemble (FDA, Ansys, DePuy Synthes implementations) has been shown through extensive validation work to predict construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw under ASTM F1717 static compression-bending conditions. Across N=11 experimental constructs tested at two independent laboratories, all three quantities of interest fall within the pre-established acceptance bounds of less than 10% difference and E/uval below 1.96. The mesh convergence study, material property characterization, and boundary condition fidelity assessments collectively support the conclusion that the model is fit for its intended purpose at a Medium credibility level commensurate with the Medium model influence and Medium decision consequence classification. This claim is considered well-substantiated by the totality of the validation programme documented in the Nagaraja et al. study and associated laboratory records."
    }
  ],
