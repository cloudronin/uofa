  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/fea-predicts-cb-performance",
      "type": "Claim",
      "name": "FEA model credibly predicts compression-bending performance of non-cannulated pedicle screw construct",
      "description": "The FEA modeling framework, comprising models developed independently by FDA, Ansys, and DePuy Synthes, credibly predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw under ASTM F1717 static compression-bending loading. All three quantities of interest fall within the pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96) across N=11 experimental constructs tested at two independent laboratories. The breadth of the validation dataset, the multi-team modeling approach, and the rigorous statistical comparison methodology collectively substantiate confidence in the predictive fidelity of the model for the stated context of use. This claim is the primary credibility assertion underpinning the regulatory submission for the non-cannulated design variant.",
      "purpose": "Assert that the FEA model ensemble meets the pre-defined acceptance criteria for all three compression-bending quantities of interest, supporting regulatory decision-making for the non-cannulated pedicle screw design.",
      "scope": "Non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending; two-laboratory validation dataset; three independent modeling teams."
    }
  ],
