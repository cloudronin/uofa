      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Each modeling team performed benchmark verification of their FEA implementation against analytic solutions for beam bending and contact mechanics. Results agreed within 1% for all benchmark cases. The independent multi-team approach provides additional confidence in code correctness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
