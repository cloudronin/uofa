  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/noncannulated-fea-credibility-claim",
      "type": "Claim",
      "name": "FEA model ensemble is credible for predicting ASTM F1717 compression-bending behavior of the non-cannulated 7.5 mm pedicle screw construct",
      "description": "The FEA modeling framework — comprising independently developed models from FDA, Ansys, and DePuy Synthes — has been assessed against all 13 ASME V&V 40 credibility factors at a model risk level of 3. Validation comparisons against N=11 experimental constructs tested at two independent laboratories demonstrate that all three quantities of interest (construct stiffness, yield force, and force at 40 mm displacement) fall within the pre-established acceptance bounds of <10% mean percent difference and E/uval < 1.96. The ensemble approach reduces the risk of model-specific bias, and the breadth of the experimental dataset provides adequate statistical coverage for the intended use. The assessment team concludes that the FEA predictions are sufficiently credible to support regulatory submission for the non-cannulated design variant. This conclusion is grounded in the full body of validation evidence collected under the Nagaraja et al. study protocol and is consistent with FDA guidance on the use of computational modeling in 510(k) submissions.",
      "purpose": "Support regulatory acceptance of FEA-based compression-bending predictions for the non-cannulated 7.5 mm pedicle screw construct in lieu of additional physical testing.",
      "scope": "ASTM F1717 static compression-bending loading mode; non-cannulated 7.5 mm diameter pedicle screw; model risk level 3; medium decision consequence."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043278",
  "wasAttributedTo": "https://uofa.net/synth/org/nagaraja-fda-cdrh",
