  "signature": "ed25519:9c2e4a6f8b0d2e4a6c8f0b2d4e6a8c0e2f4a6b8c0d2e4f6a8b0c2d4e6f8a0b2c4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented QA procedures for all three FEA codes; version control and regression testing in place.",
      "rationale": "All three modeling environments (FDA in-house, Ansys 2022R2, DePuy Synthes internal code) operate under documented software quality assurance programs consistent with ASME V&V 40 Gradation 2 requirements. Version control logs and regression test suites were reviewed and found adequate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions solved to within 1% error for relevant element types.",
      "rationale": "Each FEA code was verified against NAFEMS benchmark problems for beam bending and contact mechanics. All codes reproduced reference solutions within 0.8%, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating <2% change in QoI between successive refinement levels.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw shank and screw-rod interface regions. QoI changes between medium and fine meshes were 0.9% for stiffness and 1.3% for yield force, satisfying the <2% criterion. The medium mesh was adopted for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms below 1e-5 for all load steps; no divergence warnings in solution logs.",
      "rationale": "Nonlinear solver residuals were monitored across all 11 specimen simulations. Maximum residual norm observed was 3.2e-6. No divergence or convergence warnings were recorded. Solver error contribution to total uncertainty is negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst; checklist-based input verification completed.",
      "rationale": "Model inputs and boundary conditions were independently reviewed by a second analyst at each participating organization prior to simulation execution. A standardized checklist covering geometry, material assignment, contact definitions, and load application was completed and archived for each model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification that continuum FEA with elastic-plastic material law and frictional contact is appropriate for the loading regime; sensitivity analysis on contact friction coefficient.",
      "rationale": "The compression-bending loading mode induces predominantly elastic-plastic bending in the screw shank with frictional slip at the screw-rod interface. A continuum FEA formulation with isotropic hardening plasticity and Coulomb friction contact is well-established for this regime. Sensitivity analysis varying friction coefficient from 0.1 to 0.3 produced <3% variation in stiffness QoI, confirming model form robustness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific tensile coupon tests; geometry from CMM measurements of test specimens.",
      "rationale": "Ti-6Al-4V material properties (elastic modulus, yield strength, hardening curve) were characterized from tensile coupon specimens machined from the same material lot as the pedicle screws. Screw geometry was measured using coordinate measuring machine (CMM) on a sample of three screws per lot. UHMWPE vertebral body surrogate properties were taken from published literature with uncertainty bounds applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lots; specimen dimensions verified by CMM.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All specimens were drawn from production lots and dimensions verified by CMM prior to testing. The sample size satisfies the N≥10 criterion for this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two independent test conditions (e.g., varying offset distance or load rate) to assess model sensitivity.",
      "rationale": "Testing was conducted under a single ASTM F1717 configuration (50 mm offset, quasi-static 5 mm/min). Variation of offset distance or loading rate was not performed, limiting the ability to assess model sensitivity to test condition parameters. This factor is below the required level and represents a known gap in the validation campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented traceability from measured specimen properties to FEA input parameters; no undocumented adjustments.",
      "rationale": "A traceability matrix was prepared linking each FEA input parameter to its experimental source (CMM measurement, tensile coupon test, or literature reference). No post-hoc parameter adjustments were made to improve agreement. The same input parameter set was used across all three modeling organizations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; E/uval < 1.96 for all QoIs; mean percent difference < 10%.",
      "rationale": "All three QoIs (construct stiffness, yield force, force at 40 mm displacement) were compared using the E/uval metric per ASME V&V 40 Appendix B. Results: stiffness E/uval = 0.91 (4.2% diff), yield force E/uval = 1.44 (6.7% diff), force at 40 mm E/uval = 1.78 (8.1% diff). All values satisfy the acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes (fatigue initiation, construct loosening) and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly relevant to pedicle screw fatigue performance and construct stability. These QoIs are accepted by FDA as primary endpoints for 510(k) submissions for posterior spinal fixation systems."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, material, loading, and boundary conditions match COU within documented tolerances.",
      "rationale": "The validation specimens are identical in design and material to the production non-cannulated 7.5 mm pedicle screw. Loading and boundary conditions replicate the ASTM F1717 protocol applied in the COU. The validation activity is therefore directly representative of the intended use, with no extrapolation required."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for model risk level 3. The single below-requirement factor (Test conditions, achieved level 2 vs. required level 3) is offset by the strong quantitative agreement across all three QoIs and the use of an ensemble of three independent FEA models, which provides additional confidence that the predictions are not model-specific artifacts. The assessment team accepts the FEA modeling framework as sufficiently credible for the stated COU.",
