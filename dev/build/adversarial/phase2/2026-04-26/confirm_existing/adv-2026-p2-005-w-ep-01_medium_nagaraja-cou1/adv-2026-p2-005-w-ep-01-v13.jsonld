  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical) subject to documented V&V procedures, version control, and regression testing per FDA-recognized quality management system.",
      "rationale": "Ansys Mechanical 2022 R2 used under ISO 13485-compliant QMS. Software validation records, release notes, and regression test suite reviewed. Achieved level exceeds required level for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS and ASME V&V 10 suite solved; results agree with analytical solutions within 1%.",
      "rationale": "Standard NAFEMS benchmark LE1 (plate with hole) and beam bending problems solved with current solver settings. All results within 0.7% of analytical reference, satisfying Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change of less than 2% between successive mesh refinements; Richardson extrapolation applied.",
      "rationale": "Three-level mesh convergence study performed on screw-rod assembly. Stiffness QoI changed 1.4% between medium and fine mesh; 0.6% between fine and extra-fine. Richardson extrapolation confirms discretization error below 1.8%. Final mesh uses fine discretization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps; energy balance error below 0.1%.",
      "rationale": "Newton-Raphson iterative solver converged to residual norm below 1e-7 for all 25 load steps in each simulation. Energy balance error did not exceed 0.04% across all runs. Solver error assessed as negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions, load application, and material assignment verified against simulation plan.",
      "rationale": "Independent review of simulation setup conducted by second analyst not involved in model construction. Boundary conditions (fixed inferior vertebral body, applied displacement at superior body) confirmed consistent with ASTM F1717. Material assignments cross-checked against material database. No discrepancies identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions justified for pedicle screw metal components; contact formulation validated against known contact benchmarks; plasticity model appropriate for titanium alloy.",
      "rationale": "Ti-6Al-4V screw and rod modeled with bilinear isotropic hardening plasticity (E=114 GPa, yield=880 MPa, tangent modulus=1.2 GPa) consistent with published material characterization. Augmented Lagrange contact between screw head and rod validated against Hertzian contact benchmark. Continuum assumption valid for component dimensions well above grain scale."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from peer-reviewed literature or direct coupon testing; geometric inputs derived from CMM measurements of production hardware; uncertainty in inputs quantified.",
      "rationale": "Titanium alloy material properties from coupon tensile testing of production lot (n=5 coupons). Screw geometry from CMM measurements with tolerance ±0.02 mm. UHMWPE vertebral body block properties from literature (Nagaraja et al. 2019). Input uncertainty propagated via Monte Carlo sampling (n=200 runs); coefficient of variation on stiffness QoI = 3.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 experimental constructs from production hardware; sample traceability documented; dimensional measurements confirm conformance to design intent.",
      "rationale": "N=11 constructs assembled from production-lot hardware with full traceability. Dimensional inspection confirmed all screws and rods within drawing tolerances. Constructs distributed across two independent test laboratories to assess inter-laboratory variability. Sample size sufficient for statistical comparison per ASME V&V 40 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range of loading rates and environmental conditions; at least two distinct test configurations evaluated.",
      "rationale": "Testing performed under a single ASTM F1717 configuration (static compression-bending, ambient temperature, dry). Clinical use involves dynamic cyclic loading and in vivo environment. Single test condition is a recognized limitation; achieved level 2 is below required level 3. This factor does not meet the required credibility level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs used in validation simulations match experimental specimen measurements; any deviations documented and their effect on QoI quantified.",
      "rationale": "Model geometry updated to match CMM measurements of each of the 11 test constructs. Material properties assigned from coupon data of same production lot. Torque applied to set screws in model matched measured installation torque (4.0 Nm ± 0.2 Nm). Equivalency confirmed for all primary input parameters."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; E/uval < 1.96 for all primary QoIs; percentage difference < 10%.",
      "rationale": "E/uval computed per ASME V&V 40 Eq. 4-1 for all three QoIs: stiffness (E/uval=1.41, diff=6.3%), yield force (E/uval=0.97, diff=4.8%), force at 40 mm (E/uval=1.62, diff=7.1%). All values satisfy acceptance criteria. Comparison performed separately for each laboratory; inter-laboratory consistency confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory submission requirements; traceability from QoI to device risk established.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in FDA guidance for pedicle screw 510(k) submissions using ASTM F1717. Each QoI traces to a documented failure mode: excessive stiffness alters load transfer; yield force below threshold indicates premature plastic deformation; force at 40 mm displacement characterizes post-yield behavior relevant to fatigue life."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use same hardware, loading mode, and QoIs as COU; any gaps between validation conditions and COU conditions identified and their credibility impact assessed.",
      "rationale": "Validation uses production hardware identical to submission device, same ASTM F1717 loading mode, and same three QoIs as the COU. Primary gap is static vs. dynamic loading (addressed under Test conditions factor). Geometric and material similarity between validation and COU is complete. Overall relevance assessed as high."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is acknowledged and documented. The overall credibility evidence, including multi-team validation, N=11 experimental constructs across two laboratories, and E/uval < 1.96 for all three QoIs, is sufficient to support regulatory submission at Medium assurance level. The assessment team accepts the FEA framework as credible for the stated COU.",
