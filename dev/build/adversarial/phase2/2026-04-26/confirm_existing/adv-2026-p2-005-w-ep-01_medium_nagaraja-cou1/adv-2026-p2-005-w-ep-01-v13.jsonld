  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/fea-compression-bending-credibility-001",
      "type": "Claim",
      "name": "FEA framework is credible for predicting non-cannulated pedicle screw compression-bending behavior",
      "description": "The FEA modeling framework, as exercised by the FDA, Ansys, and DePuy Synthes modeling teams, produces predictions of construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw construct that agree with bench-test measurements within the pre-specified acceptance bounds (<10% QoI difference, E/uval < 1.96) across all three quantities of interest. This claim is grounded in a comprehensive validation campaign spanning N=11 physical constructs tested across two independent laboratories under ASTM F1717 static compression-bending conditions, mesh convergence studies confirming discretization error below 2%, and multi-team reproducibility checks demonstrating consistent model outputs. The totality of computational and experimental evidence supports the conclusion that the FEA framework is fit for the intended regulatory submission purpose.",
      "purpose": "Establish that the FEA model ensemble meets ASME V&V 40 credibility requirements for the stated COU, enabling submission to FDA as supporting evidence for 510(k) clearance of the non-cannulated pedicle screw design.",
      "scope": "Non-cannulated 7.5 mm pedicle screw construct; ASTM F1717 static compression-bending loading mode; construct stiffness, yield force, and force at 40 mm displacement as quantities of interest; two-laboratory validation dataset."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043370",
