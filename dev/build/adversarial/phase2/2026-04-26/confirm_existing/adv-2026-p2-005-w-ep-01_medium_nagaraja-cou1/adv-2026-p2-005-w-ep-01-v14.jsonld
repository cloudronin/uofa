  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/noncannulated-fea-credibility-claim-001",
      "type": "Claim",
      "name": "FEA model ensemble is sufficiently credible for non-cannulated pedicle screw compression-bending prediction",
      "description": "The FEA modeling framework, comprising independently developed implementations by FDA, Ansys, and DePuy Synthes, has been assessed against all 13 ASME V&V 40-2018 credibility factors at a model risk level of 3. Across three quantities of interest (construct stiffness, yield force, and force at 40 mm displacement), mean percentage differences between FEA predictions and bench test measurements (N=11 constructs, two laboratories) are below the pre-established 10% acceptance threshold. Normalized validation metrics (E/uval) are below 1.96 for all QoIs, indicating that model-form and numerical uncertainties are within acceptable limits relative to experimental variability. Software quality assurance activities, mesh convergence studies, and parameter sensitivity analyses collectively support the conclusion that the model ensemble is fit for purpose in the non-cannulated design context. The single test condition limitation (Test conditions factor below required level) is acknowledged but judged acceptable given the deterministic nature of the ASTM F1717 protocol and the consistency of results across laboratories."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4044110",
