  "signature": "ed25519:b2e5f8a1c4d7e0f3a6b9c2d5e8f1a4b7c0d3e6f9a2b5c8d1e4f7a0b3c6d9e2f5a8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA implementations (FDA, Ansys, DePuy Synthes) operate under documented software quality management systems. Version control, regression testing, and release validation records are on file. Achieved level 2 satisfies the required level 2 for this factor at model risk level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be reproduced within solver tolerance.",
      "rationale": "Each FEA solver was verified against standard benchmark problems including cantilever beam bending and contact patch tests. Residuals and energy balance checks confirm correct implementation of the governing equations. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change less than 2% between successive refinement levels.",
      "rationale": "A systematic mesh convergence study was performed across three refinement levels. The change in predicted construct stiffness between the medium and fine meshes was 0.9%, and for yield force was 1.4%. Richardson extrapolation confirms discretization error is below 2% for all QoIs. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6; energy balance error below 0.1%.",
      "rationale": "All simulations converged with force residuals below 1e-7 and energy balance errors below 0.05%. No hourglassing or excessive element distortion was observed. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling protocol with independent review of boundary conditions, loading, and material assignments.",
      "rationale": "A formal modeling protocol document was prepared and independently reviewed by a second analyst at each institution. Boundary conditions, load application, and material property assignments were verified against the ASTM F1717 test fixture geometry. No use errors were identified. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions must be justified by physics rationale and corroborated by literature.",
      "rationale": "Linear elastic material model for titanium alloy screw is justified given that failure occurs at strains well within the linear regime for the QoIs of interest. Contact between screw and rod is modeled using a penalty-based frictional formulation with friction coefficient validated against literature values for Ti-6Al-4V on Ti-6Al-4V. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measurements or certified material specifications.",
      "rationale": "Elastic modulus and yield strength were taken from certified material test reports for the specific Ti-6Al-4V bar stock used in construct fabrication. Geometric dimensions were verified by CMM measurement of representative components. Sensitivity analysis confirmed QoI insensitivity to ±5% variation in modulus. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the intended device design and fabricated from production-equivalent materials.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were assembled from production-equivalent components supplied by DePuy Synthes. Sample traceability records confirm material certificates and dimensional compliance. Six constructs tested at laboratory 1 (FDA) and five at laboratory 2 (industry partner). Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios.",
      "rationale": "Testing was performed under a single load configuration per ASTM F1717 (compression-bending at 5 degrees). While this configuration is the regulatory standard, it does not span the full range of in vivo loading modes. Achieved level 2 is below the required level 3; this gap is acknowledged and accepted given the deterministic nature of the regulatory protocol and consistency across two independent laboratories."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters must be derived from the same material lots and geometric measurements used in bench testing.",
      "rationale": "Material properties input to the FEA models were derived from the same certified material lot used to fabricate the test constructs. Geometric dimensions were taken from CMM measurements of the actual test specimens. This one-to-one traceability ensures equivalency of input parameters between simulation and experiment. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) must be below 1.96 for all QoIs; percentage difference below 10%.",
      "rationale": "All three QoIs (stiffness: 4.2%, E/uval=0.87; yield force: 6.8%, E/uval=1.31; force at 40 mm: 3.1%, E/uval=0.61) satisfy both acceptance criteria. Statistical uncertainty in experimental measurements was propagated using a Student t-distribution appropriate for N=11. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to the clinical risk and the regulatory decision.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly correspond to the mechanical performance attributes relevant to clinical risk of screw-rod construct failure. These QoIs are the basis for the regulatory 510(k) substantial equivalence determination. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on the same device design and under the same loading protocol as the COU.",
      "rationale": "Validation activities were performed on the non-cannulated 7.5 mm pedicle screw construct — the identical design and size as the COU device. The ASTM F1717 compression-bending protocol used in validation is the same protocol referenced in the COU intended use statement. No extrapolation beyond the validated design space is required. Achieved level 3 meets required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble satisfies all 13 ASME V&V 40-2018 credibility factors at or above required levels, with the sole exception of Test conditions (achieved level 2 vs. required level 3). This gap is accepted because the ASTM F1717 compression-bending protocol is the regulatory standard for this device class and the single test condition is not a discretionary limitation but a protocol requirement. All three QoIs meet the pre-established quantitative acceptance criteria. The overall credibility evidence is sufficient to support the regulatory decision for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
