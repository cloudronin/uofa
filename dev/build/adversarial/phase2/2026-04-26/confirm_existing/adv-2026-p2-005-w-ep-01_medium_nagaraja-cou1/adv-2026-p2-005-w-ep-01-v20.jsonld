  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/fea-compression-bending-validity-claim",
      "type": "Claim",
      "name": "FEA framework validity claim for non-cannulated pedicle screw compression-bending",
      "description": "The FEA modeling framework, comprising meshing protocols, boundary condition definitions, Ti-6Al-4V elastic-plastic material model, and contact formulations established across the FDA, Ansys, and DePuy Synthes collaboration, produces predictions of construct stiffness, yield force, and force at 40 mm displacement that are within clinically and regulatorily acceptable tolerance bounds for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending loading. This claim is grounded in an extensive body of bench testing across two independent laboratories (N=11 constructs), mesh convergence studies demonstrating discretization error below 2%, and software qualification records for Ansys Mechanical 2023 R1. The ensemble of three independent modeling teams further corroborates reproducibility of the simulation outputs. All three primary quantities of interest satisfy the pre-specified acceptance criteria (<10% QoI difference; E/uval < 1.96), establishing sufficient credibility for regulatory submission in support of the 510(k) predicate comparison.",
      "scope": "Non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending; model risk level 3; assurance level Medium."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4044278",
