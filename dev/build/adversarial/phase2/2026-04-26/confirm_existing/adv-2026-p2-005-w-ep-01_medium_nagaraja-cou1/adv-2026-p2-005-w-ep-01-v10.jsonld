  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is acknowledged and documented; the assessment team determined that the quasi-static single-condition validation is sufficient for the intended 510(k) submission context given the corroborating evidence from the two-laboratory comparison and the conservative acceptance bounds applied. Overall credibility evidence is judged adequate to support the regulatory decision.",
