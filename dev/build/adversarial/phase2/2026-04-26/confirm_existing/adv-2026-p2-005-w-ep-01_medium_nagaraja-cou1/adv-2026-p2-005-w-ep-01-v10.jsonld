      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for FEA must be validated per 21 CFR Part 820 quality system requirements; version control and audit trail must be documented.",
      "rationale": "Ansys Mechanical 2022 R2 and the FDA in-house FEA code are both operated under ISO 13485-compliant quality management systems. Version control via Git with signed commits; regression test suite executed prior to each analysis run. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
