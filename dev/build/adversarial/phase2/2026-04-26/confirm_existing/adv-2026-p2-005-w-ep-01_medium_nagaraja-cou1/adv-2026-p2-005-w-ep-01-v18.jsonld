  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/fea-compression-bending-validity",
      "type": "Claim",
      "name": "FEA framework validity claim for non-cannulated pedicle screw compression-bending",
      "description": "The FEA modeling framework, as implemented across the FDA, Ansys, and DePuy Synthes computational environments, is credible for predicting construct stiffness, yield force, and force at 40 mm displacement of the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending loading conditions. This claim is grounded in an extensive body of supporting work: (1) mesh convergence studies demonstrating discretization error below 2% for all QoIs; (2) titanium alloy Ti-6Al-4V material characterization data from three independent coupon test programs; (3) contact mechanics verification against analytical Hertzian solutions; (4) cross-laboratory reproducibility demonstrated across N=11 constructs at two independent test facilities; and (5) all three QoIs satisfying the pre-specified acceptance criterion of E/uval < 1.96 and percentage difference < 10%. The breadth and rigor of this supporting work collectively substantiate the claim that the model framework is fit for its intended regulatory purpose.",
      "scope": "Non-cannulated 7.5 mm pedicle screw construct; ASTM F1717 static compression-bending; quasi-static loading regime; cortical and cancellous bone substitute blocks per ASTM F1717 specification.",
      "purpose": "Provide the primary credibility assertion supporting regulatory submission for the non-cannulated pedicle screw design variant, demonstrating that computational predictions may substitute for or supplement additional physical testing within the bounds of the validated COU."
    }
  ],
