  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/noncannulated-fea-accuracy-claim",
      "type": "Claim",
      "name": "FEA model accurately predicts compression-bending behavior of non-cannulated pedicle screw construct",
      "description": "The FEA modeling framework, as applied to the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending loading, produces predictions of construct stiffness, yield force, and force at 40 mm displacement that are consistent with experimental measurements within pre-established acceptance bounds. This claim is grounded in a comprehensive body of work: the model ensemble was exercised across three independent FEA implementations (FDA, Ansys, DePuy Synthes), benchmarked against N=11 physical constructs tested at two independent laboratories, and evaluated using the ASME V&V 40 normalized validation metric E/uval. All three quantities of interest satisfy E/uval < 1.96 and relative error < 10%, demonstrating that the model is fit for purpose within the defined context of use. Material properties were derived from certified coupon testing of Ti-6Al-4V ELI stock; contact formulations were verified against closed-form solutions; and mesh convergence was confirmed at <1% change in peak von Mises stress between successive refinement levels. The totality of this evidence, documented in the Nagaraja et al. (2013) validation report and the associated FDA submission package, provides strong qualitative support for the claim.",
      "scope": "Non-cannulated 7.5 mm pedicle screw construct; ASTM F1717 static compression-bending; quasi-static loading up to 40 mm displacement; titanium alloy Ti-6Al-4V ELI; two-vertebral-body UHMWPE block surrogate.",
      "purpose": "Support regulatory submission by demonstrating computational model credibility in accordance with ASME V&V 40-2018 and FDA guidance on the use of computational modeling in medical device submissions."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1016/j.jbiomech.2013.06.028",
