  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/fea-compression-bending-claim",
      "type": "Claim",
      "name": "FEA framework accurately predicts compression-bending behavior of non-cannulated pedicle screw construct",
      "description": "The FEA modeling framework, comprising validated material property assignments for Ti-6Al-4V alloy components, contact definitions at the screw-rod interface, and nonlinear geometric treatment, accurately reproduces the experimentally observed compression-bending response of the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 loading conditions. This claim is grounded in an extensive body of supporting work including mesh convergence studies, material coupon testing, inter-laboratory reproducibility assessments across two independent test facilities, and direct numerical comparison of three quantities of interest (construct stiffness, yield force, force at 40 mm displacement). All predicted quantities fall within the pre-established 10% acceptance bound and the normalized validation metric E/uval remains below 1.96 for all QoIs, indicating that model-form and parameter uncertainty are adequately characterised relative to the observed experimental variability. The claim scope is limited to the specific geometry, loading configuration, and boundary conditions defined in ASTM F1717; extrapolation to cannulated variants or dynamic loading is not covered.",
      "purpose": "Provide structured assurance that the FEA predictions are sufficiently accurate for the regulatory submission supporting 510(k) clearance of the non-cannulated pedicle screw system.",
      "scope": "Non-cannulated 7.5 mm pedicle screw construct; ASTM F1717 static compression-bending; stiffness, yield force, and force at 40 mm displacement QoIs; two-laboratory experimental dataset N=11."
    }
  ],
