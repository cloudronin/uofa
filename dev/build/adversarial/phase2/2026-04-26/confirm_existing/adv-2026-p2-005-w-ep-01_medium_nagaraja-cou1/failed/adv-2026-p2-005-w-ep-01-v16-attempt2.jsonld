  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-regulatory-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single gap (Test conditions, achieved 2 vs. required 3) is acknowledged and documented; the gap is considered acceptable for this submission given that ASTM F1717 static compression-bending is the primary regulatory comparator for this device class and the three primary QoIs all satisfy quantitative acceptance criteria. Supplemental dynamic and torsion validation is recommended prior to expanded COU submissions.",
