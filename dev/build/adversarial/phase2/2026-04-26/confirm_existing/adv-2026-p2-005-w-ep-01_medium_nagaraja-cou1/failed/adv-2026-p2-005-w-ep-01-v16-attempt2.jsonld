  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for FEA analysis must be validated per FDA 21 CFR Part 820 quality system requirements; version control and audit trail documented.",
      "rationale": "All three FEA implementations (FDA, Ansys, DePuy Synthes) operate under documented quality management systems. Software version control, change control procedures, and validation records are on file. Achieved level equals required level for model risk 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be used to verify the numerical implementation of contact, plasticity, and large-deformation formulations.",
      "rationale": "Each FEA code was verified against NAFEMS benchmark problems and internal patch tests covering contact mechanics and elasto-plastic material response. Verification reports are archived and reviewed by independent analysts."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change < 2% between successive refinement levels; Richardson extrapolation applied where applicable.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw-rod construct. Stiffness QoI changed by 1.4% between medium and fine meshes; yield force changed by 1.1%. Richardson extrapolation confirmed discretization error within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria and energy balance checks must confirm solver accuracy for nonlinear quasi-static analysis.",
      "rationale": "Force and displacement residuals converged to 1e-4 relative tolerance for all load steps. Energy balance error remained below 0.5% throughout the analysis. Automatic time-stepping with bisection ensured convergence at contact onset and plastic hinge formation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent analyst review; boundary condition and loading application verified against ASTM F1717 fixture geometry.",
      "rationale": "Simulation setup was independently reviewed by a second analyst at each organization. Boundary conditions replicate the ASTM F1717 test fixture with superior and inferior loading blocks modeled as rigid bodies. Loading rate and displacement control match experimental protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified by material characterization data; contact formulation appropriate for screw-rod interface behavior.",
      "rationale": "Bilinear isotropic hardening plasticity used for Ti-6Al-4V rod and screw body, calibrated from tensile coupon data. Frictional contact (mu=0.3) applied at screw-rod and screw-vertebral body block interfaces. Model form uncertainty quantified via sensitivity analysis showing <5% QoI sensitivity to friction coefficient variation of ±0.1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from traceable measurements; uncertainty in inputs propagated to QoI uncertainty.",
      "rationale": "Material properties derived from lot-specific tensile testing of Ti-6Al-4V rod and screw stock. Geometric dimensions measured via CMM on five representative screws; nominal dimensions used in model with dimensional variability included in uncertainty budget. Input uncertainty propagation performed via Monte Carlo sampling (N=500)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production-representative lots; sample traceability documented.",
      "rationale": "N=11 constructs assembled from production-representative non-cannulated 7.5 mm pedicle screws and 5.5 mm Ti-6Al-4V rods. Specimens distributed across two independent laboratories (N=6 and N=5). Lot traceability and certificate of conformance on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading scenarios; minimum two load configurations required.",
      "rationale": "Testing performed under a single ASTM F1717 static compression-bending configuration only. Dynamic fatigue and torsion conditions not included in this validation activity. Achieved level 2 versus required level 3 represents a known gap; supplemental validation under additional load conditions is recommended for future submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to experimental conditions; traceability matrix linking simulation inputs to measured experimental parameters required.",
      "rationale": "Traceability matrix prepared linking each FEA boundary condition and material parameter to corresponding experimental measurement or specification. Vertebral body block modulus (UHMWPE, 1.17 GPa) matched to durometer measurements on test blocks. Screw torque-to-angle relationship validated against bench assembly records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and absolute percentage difference < 10% for all primary QoIs.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy both acceptance criteria across all three FEA implementations. E/uval values of 1.12, 1.51, and 1.73 are all below the 1.96 threshold. Mean absolute percentage errors of 4.3%, 6.8%, and 7.9% are all below 10%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected must be directly linked to the clinical risk pathway and regulatory acceptance criteria.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA guidance for pedicle screw 510(k) submissions. These QoIs directly characterize the risk of construct fracture or excessive deformation leading to revision surgery."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, materials, and loading conditions representative of the intended clinical use case.",
      "rationale": "Validation uses the production non-cannulated 7.5 mm pedicle screw geometry and production Ti-6Al-4V rod material. ASTM F1717 test configuration is the regulatory standard for this device type and directly represents the clinical compression-bending loading mode. Validation activities are highly relevant to the COU."
    }
