  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/noncannulated-fea-credibility-claim",
      "type": "Claim",
      "name": "FEA model ensemble is credible for predicting ASTM F1717 compression-bending behavior of the non-cannulated 7.5 mm pedicle screw construct",
      "description": "The FEA modeling framework, comprising independently developed implementations by FDA, Ansys, and DePuy Synthes, has been demonstrated to predict construct stiffness, yield force, and force at 40 mm displacement within the pre-established acceptance bounds of <10% QoI difference and E/uval < 1.96. Eleven physical constructs were tested across two independent laboratories in conformance with ASTM F1717. All three quantities of interest met acceptance criteria across all three model implementations. The body of validation evidence, including mesh convergence studies, material characterization data, and inter-laboratory reproducibility records, collectively supports the conclusion that the model ensemble is sufficiently credible for the stated context of use. Model risk level 3 (medium-high) is appropriate given the Class II device classification and medium decision consequence. This claim is the primary credibility assertion underpinning the regulatory submission package for the non-cannulated design variant."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4038344",
