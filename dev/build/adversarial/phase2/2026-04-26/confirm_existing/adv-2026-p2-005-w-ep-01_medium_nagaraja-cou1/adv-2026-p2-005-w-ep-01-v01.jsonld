  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/fea-predicts-compression-bending-noncannulated",
      "type": "Claim",
      "name": "FEA accurately predicts compression-bending QoIs for non-cannulated 7.5 mm pedicle screw construct",
      "description": "The FEA model ensemble, comprising independently developed implementations in FDA in-house code, Ansys Mechanical, and DePuy Synthes proprietary solver, accurately predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw under ASTM F1717 static compression-bending loading. Extensive mesh convergence studies, material characterization campaigns across Ti-6Al-4V and UHMWPE rod stock batches, and cross-laboratory experimental replication (N=11 constructs, two independent test facilities) collectively substantiate this claim. All three QoIs fall within the pre-specified 10% acceptance band and the normalized model error E/uval remains below 1.96 across all constructs, consistent with the validation success criteria defined in the V&V plan. The breadth of the supporting experimental program and the multi-code corroboration provide high confidence that the predictive capability is not an artifact of any single modeling choice.",
      "purpose": "Provide the primary credibility assertion that the FEA framework is fit-for-purpose for predicting compression-bending performance of the non-cannulated construct in support of the 510(k) submission.",
      "scope": "Non-cannulated 7.5 mm pedicle screw construct; ASTM F1717 static compression-bending protocol; construct stiffness, yield force, and force at 40 mm displacement QoIs only."
    }
  ],
