  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/fea-predicts-compression-bending",
      "type": "Claim",
      "name": "FEA accurately predicts non-cannulated pedicle screw compression-bending behavior within ASTM F1717 acceptance bounds",
      "description": "The FEA modeling framework, as applied to the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending loading, produces predictions of construct stiffness, yield force, and force at 40 mm displacement that are consistent with bench-test measurements from N=11 constructs tested across two independent laboratories. The ensemble of three independent FEA implementations (FDA, Ansys, DePuy Synthes) converged on predictions within the pre-established acceptance bounds of less than 10% relative QoI difference and E/uval below 1.96. Extensive mesh convergence studies, material property sensitivity analyses, and inter-laboratory reproducibility assessments documented in the supporting technical reports collectively substantiate this claim. The modeling approach is therefore credible for use in regulatory decision-making at Medium model influence and Medium decision consequence for this Class II device."
    }
  ],
