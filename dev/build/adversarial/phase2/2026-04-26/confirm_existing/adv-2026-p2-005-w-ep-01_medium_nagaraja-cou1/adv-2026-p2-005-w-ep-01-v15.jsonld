  },
  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/fea-construct-stiffness-yield-claim-001",
      "type": "Claim",
      "name": "FEA accurately predicts compression-bending stiffness and yield force for non-cannulated 7.5 mm pedicle screw construct",
      "description": "The FEA model ensemble (FDA, Ansys, DePuy Synthes implementations) predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw under ASTM F1717 static compression-bending loading within pre-established acceptance bounds. This claim is grounded in an extensive multi-laboratory validation programme involving N=11 physical constructs tested across two independent laboratories, mesh convergence studies demonstrating <2% change in QoI between consecutive refinement levels, material property characterisation from coupon tests, and statistical comparison of model predictions to experimental distributions using the E/uval metric. The aggregate body of evidence — encompassing bench test reports, uncertainty quantification analyses, and independent code verification checks — provides high confidence that model predictions are fit for purpose in supporting a 510(k) submission for this device class."
    }
  ],
