  "hash": "sha256:a3f8c2e1d47b905f6c3a1e2d8b74f0c9e5a2d1b3f6e8c4a7d0b2e5f9c1a3d6e8",
  "signature": "ed25519:b1d4e7a2c5f8b3e6a9d2c5f8b1e4a7d0c3f6b9e2a5d8c1f4b7e0a3d6c9f2b5e8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
