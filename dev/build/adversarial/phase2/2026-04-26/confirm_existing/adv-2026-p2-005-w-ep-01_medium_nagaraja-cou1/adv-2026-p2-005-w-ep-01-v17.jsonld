  "nodes": [
    {
      "id": "https://uofa.net/synth/claim/fea-predicts-compression-bending",
      "type": "Claim",
      "name": "FEA model ensemble accurately predicts static compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct within ASTM F1717 acceptance bounds",
      "description": "The FEA modeling framework, comprising independently developed models from FDA, Ansys, and DePuy Synthes, has been demonstrated to accurately reproduce the static compression-bending mechanical behavior of the non-cannulated 7.5 mm pedicle screw construct as characterised under ASTM F1717. Supporting work encompassing mesh convergence studies, material property calibration from coupon testing, multi-laboratory experimental comparison (N=11), and sensitivity analyses across geometric tolerances collectively substantiates this claim. All three quantities of interest — construct stiffness, yield force, and force at 40 mm displacement — were predicted within the pre-specified acceptance bounds across both test laboratories. The normalized validation metric E/uval remained below 1.96 for all constructs, confirming that model-form and input uncertainties are adequately characterized. This claim underpins the regulatory submission asserting that computational simulation may be used to supplement physical bench testing for this device family.",
      "scope": "Non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static compression-bending loading conditions at ambient temperature; does not extend to dynamic fatigue, cannulated variants, or off-axis loading configurations."
    }
  ],
