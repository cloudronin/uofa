  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is acknowledged and accepted given that ASTM F1717 prescribes a single standard condition and no alternative standard exists for multi-condition pedicle screw testing. All three QoIs satisfy pre-specified acceptance criteria with E/uval well below 1.96. The ensemble modeling approach across three independent analyst teams provides additional confidence. The credibility assessment team accepts the FEA model for the stated COU.",
