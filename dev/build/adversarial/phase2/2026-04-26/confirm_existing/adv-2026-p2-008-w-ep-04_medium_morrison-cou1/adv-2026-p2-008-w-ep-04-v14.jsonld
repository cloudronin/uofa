      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 3.",
      "rationale": "Predicted relative hemolysis index compared quantitatively against experimental measurements at 5 flow-speed operating points. Normalized index of agreement and RMSE computed. All predictions within ±15% of experimental values, meeting the acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 3.",
      "rationale": "The primary QoI (relative hemolysis index RH) is directly linked to the clinical endpoint of hemolysis risk. The power law hemolysis model maps scalar stress exposure to RBC damage index, which is the regulatory-accepted metric for CPB device submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
