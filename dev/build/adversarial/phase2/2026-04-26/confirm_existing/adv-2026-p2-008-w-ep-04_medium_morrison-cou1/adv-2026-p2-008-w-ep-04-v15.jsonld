      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on the production mesh.",
      "rationale": "Three-level mesh refinement study yielded GCI of 2.8% on the finest production mesh for the normalized index of hemolysis. Achieved level exceeds the required level, providing additional margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental flow loop conditions (flow rate, rotational speed, fluid viscosity, hematocrit) are documented and match CFD boundary conditions within stated tolerances.",
      "rationale": "FDA pump experimental data were collected at 2.5 L/min and 3500 RPM with bovine blood at 35% hematocrit. CFD boundary conditions replicate these settings; deviations in fluid temperature are within ±1°C and are shown to have negligible effect on predicted hemolysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted normalized index of hemolysis agrees with experimental measurements within ±25% across all five operating points.",
      "rationale": "Predicted NIH values at five flow-speed combinations show mean absolute error of 17% relative to experimental values, satisfying the ±25% acceptance criterion. Worst-case operating point (lowest flow, highest speed) shows 22% error, still within tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The normalized index of hemolysis is established as the primary QoI and is directly linked to the clinical acceptance criterion (RH < 1).",
      "rationale": "NIH is the standard hemolysis metric per ASTM F1841 and ISO 10993-4. The relative hemolysis index RH is derived directly from NIH comparisons between the test device and predicate, making NIH the appropriate and clinically relevant QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments use the same pump geometry, operating envelope, and fluid properties as the COU, or documented similarity arguments justify any differences.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump, which is the same geometry used in the COU simulations. Operating conditions span the clinical CPB range. Minor differences in blood analog viscosity are addressed through a documented sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence is demonstrated by residual reduction of at least four orders of magnitude and stabilization of the NIH monitor point.",
      "rationale": "All simulations achieved continuity and momentum residuals below 1e-5 and NIH monitor point variation below 0.1% over the final 500 iterations, confirming adequate iterative convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Assessment of analyst-introduced errors through independent simulation replication or formal use-error protocol.",
      "rationale": "Use error assessment was considered beyond the scope of the current submission phase. An independent replication exercise was not conducted due to resource constraints and was deferred to a subsequent design verification stage. The team notes this factor as not-assessed without providing a quantitative bound on the associated uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Justification provided for turbulence model selection and hemolysis damage model, with sensitivity analysis for key model form choices.",
      "rationale": "The SST k-omega turbulence model was selected based on published benchmark studies for rotating hemodynamic devices. The Giersiepen-Wurzinger power-law hemolysis model was used with published constants. A sensitivity analysis comparing the Farinas model showed less than 10% difference in NIH, supporting the model form choice."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "All material properties and boundary condition inputs are traceable to measurement data or published sources, with uncertainty ranges documented.",
      "rationale": "Blood viscosity (3.5 cP), density (1060 kg/m3), and inlet velocity profiles are sourced from published literature and experimental measurements. Sensitivity to ±10% variation in viscosity was evaluated and showed less than 5% change in NIH."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of biological variability in blood samples used for experimental validation, including donor variability and storage effects.",
      "rationale": "Detailed characterization of test sample biological variability was deemed outside the scope of the CFD credibility assessment and was not addressed. The experimental dataset used for validation does not include inter-donor variability data, and this factor was not assessed. No bounding argument for the impact of this gap on NIH prediction confidence was provided."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Correspondence between CFD model input parameters and physical test parameters is demonstrated with documented mapping and any differences justified.",
      "rationale": "A parameter equivalency table was prepared mapping each experimental test condition to the corresponding CFD boundary condition. Rotational speed, flow rate, inlet temperature, and fluid properties are matched within stated measurement uncertainties. No unresolved discrepancies were identified."
