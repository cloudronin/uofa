  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen V&V 40 credibility factors at Model Risk Level 3. Eleven factors were assessed and met or exceeded required gradation levels. Two factors — Use Error and Test Samples — were marked not-assessed on the basis that they fell beyond the scope of the current submission phase. The team accepted the package on the grounds that the assessed factors collectively provide sufficient evidence for the intended COU, and the not-assessed factors were judged to be of lower priority. No formal bounding analysis was performed to quantify the credibility gap introduced by the unassessed factors.",
