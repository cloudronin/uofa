  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures; version-controlled simulation scripts.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional software QA policy. Version control via Git repository with tagged releases for each simulation campaign. Solver regression tests passed for all hemolysis-relevant turbulence models."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver benchmarked against at least one canonical internal flow verification case.",
      "rationale": "ANSYS Fluent code verification confirmed via Taylor-Couette flow benchmark. Spatial order of accuracy verified at 1.92 (expected ~2 for second-order scheme). Residual convergence to 1e-6 achieved for all operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on fine mesh.",
      "rationale": "Three-level mesh refinement study performed (coarse: 2.1M, medium: 5.8M, fine: 14.3M cells). GCI for normalized hemolysis index: 3.2% between medium and fine meshes. Richardson extrapolation applied; fine mesh adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions documented and traceable to published FDA pump study protocol.",
      "rationale": "Validation experiments conducted at FDA-published operating points (2.5 L/min at 2500 RPM; 5.0 L/min at 3500 RPM; 7.0 L/min at 4500 RPM). Blood analog fluid (glycerol-water) properties documented. Temperature controlled at 37°C ± 0.5°C."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) within 15% of experimental mean across all validation operating points.",
      "rationale": "NIH predictions compared against five experimental replicates at each operating point. Mean absolute relative error: 9.4%. All predictions within 15% band. Systematic over-prediction of 6% at highest RPM attributed to known turbulence model limitations at high shear; documented and accepted within tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to clinical hemolysis endpoint used in regulatory submission.",
      "rationale": "Relative hemolysis index RH = NIH_device / NIH_predicate is the primary QoI. This directly supports the regulatory acceptance criterion RH < 1. QoI is dimensionally consistent with ASTM F1841 hemolysis measurement standard."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation geometry and operating conditions overlap with COU operating envelope.",
      "rationale": "Validation performed on the same FDA generic centrifugal pump geometry as used in the COU. Operating conditions span the full clinical range (2.5–7.0 L/min). Fluid properties representative of blood analog. Validation activities directly support the COU without extrapolation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence residuals below 1e-5 for all equations; mass imbalance < 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity, momentum, and turbulence equations. Global mass imbalance confirmed below 0.005% for all operating points. Double-precision arithmetic used throughout."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Turbulence model and hemolysis power-law correlation justified for blood pump shear environment.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark for internal rotating flows. Giersiepen-Wurzinger power-law hemolysis model applied with Lagrangian particle tracking for RBC exposure time. Model form uncertainty estimated at ±12% via comparison with Arora and Zhang hemolysis models; within acceptable band for MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Geometric and boundary condition inputs traceable to device drawings and clinical use specifications.",
      "rationale": "Pump geometry imported from FDA-published CAD files. Inlet boundary conditions (flow rate, pressure) set per clinical operating specifications. Blood viscosity modeled as Newtonian (mu = 0.0035 Pa·s) consistent with validation dataset. Sensitivity study confirmed hemolysis index insensitive to ±5% viscosity variation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not established — factor deferred as beyond current assessment scope.",
      "rationale": "Characterization of test sample variability (lot-to-lot variation in blood analog fluid, RBC fragility distributions) was considered beyond the scope of this computational credibility assessment. The experimental data used for validation were drawn from a single fluid batch and single experimental campaign. Inter-batch and inter-laboratory variability in test samples has not been evaluated. This factor is noted as not-assessed; no requiredLevel or achievedLevel is assigned."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not established — factor deferred as beyond current assessment scope.",
      "rationale": "Potential for user-introduced error in simulation setup (boundary condition specification, mesh generation choices, post-processing of hemolysis trajectories) has not been formally assessed through independent re-analysis or round-robin exercise. The assessment team considers this outside the current project scope given resource constraints. No structured use-error study has been conducted and no requiredLevel is assigned at this time."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not established — factor deferred as beyond current assessment scope.",
      "rationale": "Formal equivalency mapping between validation experiment input parameters and COU-specific device input parameters (e.g., actual patient blood rheology vs. blood analog, in-vivo temperature variation) has not been systematically documented. The team acknowledges this gap but considers a full equivalency analysis beyond the current project scope. Absence of this assessment at MRL 3 represents a credibility gap that has not been mitigated."
    }
  ],
