  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Ten of thirteen credibility factors have been assessed and meet or exceed required levels for the stated COU. Three factors — model inputs uncertainty propagation, test sample representativeness, and equivalency of input parameters — were not assessed and are noted as beyond the current project scope. The team judged that the assessed factors provide sufficient collective evidence to support acceptance at MRL 3, and that the unassessed factors do not materially affect the primary RH QoI conclusion.",
