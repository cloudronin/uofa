      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under an institutional SQA plan with documented version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated SQA plan with version-controlled input files. Regression tests confirm repeatability across operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least one published benchmark with documented order-of-accuracy confirmation.",
      "rationale": "The solver has been verified against the lid-driven cavity and backward-facing step benchmarks with second-order spatial convergence confirmed. Published verification reports are on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for wall shear stress QoI must be below 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed; GCI for peak wall shear stress is 2.8% on the 14.2 M element fine mesh. Richardson extrapolation confirms monotonic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental flow rates and rotational speeds must match CFD boundary conditions within ±3%.",
      "rationale": "FDA benchmark experimental conditions (2.5 and 5.0 L/min; 2500 and 3500 rpm) are reproduced in simulation. Measured inlet velocity profiles used as boundary conditions; deviation is within ±1.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) must agree with experimental values within 15% across all tested operating points.",
      "rationale": "RH predictions agree with published FDA experimental data within 9% across all five operating points. Systematic over-prediction at high speed is within the stated acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (shear stress, exposure time, RH index) must directly map to clinical hemolysis endpoints.",
      "rationale": "The relative hemolysis index is the primary regulatory QoI for blood pump submissions. Shear stress and exposure time are intermediate QoIs with established mechanistic linkage to RBC damage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid properties, and operating range must be representative of the CPB COU.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry under blood-analog fluid conditions spanning the CPB operating envelope. Geometry fidelity and fluid rheology are directly representative of the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must achieve residuals below 1e-5 for all transport equations and mass-flow imbalance below 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity, momentum, and turbulence equations. Mass-flow imbalance is 0.003% confirming solution fidelity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of setup parameters.",
      "rationale": "Simulation setup was independently reviewed by a second analyst. Boundary conditions, turbulence model selection, and post-processing scripts are documented in the simulation log."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law model must be justified against published literature for blood pump applications.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark comparisons for rotating blood-contacting devices. Giersiepen-Wurzinger power-law hemolysis model is the standard for FDA submissions and is applied consistently."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in blood viscosity, density, and hematocrit inputs should be propagated to quantify their effect on predicted RH.",
      "rationale": "Sensitivity of model predictions to variability in blood rheological inputs (viscosity, hematocrit) was not evaluated in this assessment. The team considered this analysis beyond the current project scope given resource constraints. No formal uncertainty propagation study was conducted, and the influence of input parameter variability on the RH QoI therefore remains uncharacterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis data should be obtained from multiple blood donors to characterize inter-sample variability.",
      "rationale": "The FDA benchmark experimental dataset used for validation does not stratify results by donor sample, and no supplementary multi-donor dataset was available. Assessment of test sample representativeness was therefore outside the scope of this engagement and has not been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validation model must be demonstrated to be equivalent to those of the COU device geometry and operating conditions.",
      "rationale": "A formal equivalency mapping between the FDA generic pump validation geometry and the specific CPB device geometry was not completed. The team noted this as beyond scope for the current phase; differences in impeller clearance and volute geometry between the validation and COU configurations have not been systematically assessed."
    }
  ],
