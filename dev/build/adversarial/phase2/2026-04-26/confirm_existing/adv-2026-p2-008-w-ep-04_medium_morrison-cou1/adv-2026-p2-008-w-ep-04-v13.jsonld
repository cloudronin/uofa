      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) must be documented and reproducible within ±2%.",
      "rationale": "FDA pump bench test conditions are fully documented in the CDRH dataset. Inlet flow rates and impeller speeds match simulation boundary conditions within 1.4%. Temperature maintained at 37 ± 0.5 °C throughout."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Predicted RH index must agree with experimental values within 15% across all five operating points; systematic bias must be characterised.",
      "rationale": "RH index predictions fall within 9–14% of experimental values across all five flow-speed combinations. A modest positive bias of 6% is attributed to the simplified Giersiepen hemolysis power-law and is documented. Criterion met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs must directly map to the clinical acceptance criterion (RH < 1 relative to predicate).",
      "rationale": "The primary QoI is the relative hemolysis index RH, which is the direct comparator against the predicate device. Secondary QoIs (shear stress distribution, residence time) are documented as supporting evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and fluid (porcine blood or equivalent) as the COU.",
      "rationale": "Validation uses the FDA generic centrifugal pump geometry with bovine blood at physiological haematocrit (35%). Geometry, fluid rheology, and operating envelope all correspond to the CPB COU. Achieved level exceeds required."
    },
    {
