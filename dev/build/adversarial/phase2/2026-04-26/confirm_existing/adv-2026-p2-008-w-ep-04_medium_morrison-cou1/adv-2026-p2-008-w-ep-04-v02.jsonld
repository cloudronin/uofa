  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concludes that the CFD model provides adequate credibility for the intended COU at MRL 3. Ten of thirteen factors have been fully assessed and meet or exceed required gradation levels. Two factors (Model inputs and Test samples) are carried as not-assessed on the basis that the relevant characterisation activities are beyond the current submission scope; the team judges residual risk acceptable given the overall validation evidence, though no formal uncertainty propagation has been performed to substantiate this judgement. The decision to accept is conditioned on completion of the deferred input uncertainty study prior to final regulatory submission.",
