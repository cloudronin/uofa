  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must meet Gradation 2 SQA requirements: version control, documented test suite, and traceable build process.",
      "rationale": "ANSYS Fluent 2022R2 used with documented version control, regression test suite, and traceable release notes. SQA documentation reviewed and confirmed at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark cases at Gradation 2.",
      "rationale": "ANSYS Fluent verified against standard laminar and turbulent benchmark cases documented in the software verification manual. Order-of-accuracy tests confirm correct discretization scheme implementation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three mesh refinements; GCI < 5% for hemolysis index QoI at Gradation 3.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 9.8M, 21.5M cells). GCI computed per Celik et al. 2008 procedure. GCI for normalized hemolysis index = 3.1%, meeting the < 5% threshold. Asymptotic range confirmed (GCI ratio = 0.98)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce boundary conditions in CFD model at Gradation 2.",
      "rationale": "FDA benchmark experimental conditions fully documented: inlet flow rates (2.5, 3.5, 5.0, 6.0, 7.0 L/min), rotational speeds (2000, 2500, 3500 RPM), fluid viscosity (0.0036 Pa·s), and temperature (37°C). Uncertainty bounds on flow rate (±0.05 L/min) and pressure (±2 mmHg) reported. Exceeds Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized hemolysis index) must demonstrate agreement within defined tolerance band at Gradation 3, accounting for experimental uncertainty.",
      "rationale": "Normalized index of hemolysis (NIH) compared against FDA experimental data across all 5 operating points. Mean relative error = 8.4%, within the 15% acceptance band. Validation metric computed per ASME V&V 20 procedure including experimental uncertainty propagation. Agreement criterion satisfied at all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the QoIs used in the COU decision at Gradation 2.",
      "rationale": "The NIH and relative hemolysis index (RH) used in validation are the same metrics used in the COU acceptance criterion (RH < 1). Direct correspondence confirmed; no surrogate QoI mapping required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on a geometry and flow regime representative of the COU device and operating conditions at Gradation 2.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry under CPB-representative flow conditions (2.5–7.0 L/min, 2000–3500 RPM). Geometric similarity and flow regime overlap with COU device confirmed. Validation domain adequately covers COU operating space."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below solver-specific thresholds and monitored QoI stabilization at Gradation 2.",
      "rationale": "All simulations run to steady-state convergence with RMS residuals < 1e-5 for continuity and momentum. NIH monitor stabilized to < 0.1% variation over final 500 iterations. Convergence confirmed for all 5 operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage accumulation model selection must be justified with sensitivity analysis at Gradation 3.",
      "rationale": "SST k-omega turbulence model selected based on documented performance for rotating machinery flows. Giersiepen-Wurzinger hemolysis power-law model used with coefficients calibrated to human blood. Sensitivity analysis performed comparing SST k-omega vs. realizable k-epsilon: NIH difference < 6% across all operating points. Model form uncertainty estimated and incorporated into validation comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be documented with sources and nominal values at Gradation 2.",
      "rationale": "All boundary conditions, material properties, and geometric parameters documented in the simulation plan. Blood viscosity sourced from literature (Merrill 1969), density from ASTM standard. Rotational speed and flow rate inputs traceable to experimental protocol documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed for this submission.",
      "rationale": "Use error assessment was considered beyond the scope of the current credibility submission. The team noted that a formal evaluation of analyst-induced errors, setup mistakes, and post-processing errors was not conducted. This factor was deferred to a future phase of the design verification program. No concrete mitigation or bounding argument is provided."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed for this submission.",
      "rationale": "Characterization of test sample variability (e.g., fluid batch-to-batch variation, pump specimen geometric tolerances) was considered outside the current scope. The assessment team indicated this factor would be revisited if additional experimental campaigns are conducted, but no assessment or bounding analysis was performed for this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed for this submission.",
      "rationale": "The degree to which CFD model input parameters match those of the physical test was not formally evaluated. The assessment team noted this factor as beyond the current submission scope without providing a quantitative or qualitative equivalency argument. No sensitivity analysis mapping experimental inputs to CFD boundary conditions was performed."
    }
