  "signature": "ed25519:b4e2d1c3f5a7e9b0c2d4f6a8b0c2e4f6a8b0d2e4f6a8c0d2e4f6b8d0e2f4a6c8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 3.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is commercially qualified with documented QA procedures including version-controlled input files, automated regression testing, and traceable release notes. SQA documentation reviewed and confirmed compliant with ASME V&V 40 Table 5-1 Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions for internal flow with rotating machinery must reproduce analytical results within 1% for canonical test cases.",
      "rationale": "Code verification performed using Taylor-Couette flow and lid-driven cavity benchmarks. Solver reproduces analytical velocity profiles within 0.8% error. Published ASME V&V 20 benchmark comparisons for the FDA nozzle geometry further confirm code correctness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for hemolysis index QoI across all five operating points.",
      "rationale": "Richardson extrapolation and GCI analysis performed on three systematically refined meshes (4.2M, 11.7M, 28.4M cells). GCI for the relative hemolysis index ranged from 1.2% to 3.8% across operating points, satisfying the 5% threshold. Asymptotic convergence ratio confirmed in the monotone convergence regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with measured flow rates, rotational speeds, and fluid properties traceable to calibrated instrumentation.",
      "rationale": "In-vitro hemolysis experiments conducted at five flow-speed combinations (2–6 L/min, 2000–3500 RPM). All flow rates measured with Coriolis flowmeters (±0.5% accuracy). Rotational speed verified via optical tachometer. Blood analog fluid (porcine blood, hematocrit 35±2%) properties characterized at test temperature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index must fall within ±15% of experimental measurements at all five operating points.",
      "rationale": "Predicted RH index compared against experimental measurements at all five operating conditions. Maximum deviation of 11.3% observed at the 6 L/min, 3500 RPM condition. All other operating points within 8%. Systematic bias of +4.2% attributed to power-law hemolysis model calibration and considered acceptable for the intended COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (relative hemolysis index) must be directly linked to the clinical decision criterion.",
      "rationale": "The relative hemolysis index (RH) is the primary regulatory QoI for CPB device clearance under FDA guidance. CFD-derived RH is compared directly against the predicate device threshold (RH < 1). The QoI chain from shear stress history to hemolysis prediction via the Giersiepen-Wurzinger power-law model is fully documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and operating envelope as the COU.",
      "rationale": "Validation experiments used the identical FDA generic centrifugal pump geometry operated within the COU envelope (2–6 L/min, 2000–3500 RPM). Fluid properties (porcine blood analog) are representative of clinical CPB conditions. Geometric fidelity between experimental and computational models confirmed by CMM measurements showing <0.05 mm deviation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all transport equations and monitored QoI stabilized within 0.1%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity, momentum, and turbulence equations. Hemolysis index QoI monitored over final 500 iterations showing variation below 0.05%. Double-precision arithmetic used throughout. No solver warnings or floating-point exceptions recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, boundary conditions, material properties) must be traceable to measurements or published sources with stated uncertainty.",
      "rationale": "Pump geometry derived from CMM measurements of the physical device. Boundary conditions (inlet flow rate, outlet pressure, wall rotational speed) set to match experimental test conditions. Blood viscosity modeled using Carreau-Yasuda non-Newtonian model with parameters fitted to rheometry data (R²=0.997). All inputs documented in the model input record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection (turbulence model, hemolysis model) must be justified by comparison against alternative formulations or published benchmark evidence.",
      "rationale": "SST k-omega turbulence model selected based on published performance comparisons for rotating internal flows (Hariharan et al., 2011). Sensitivity study comparing SST k-omega, realizable k-epsilon, and RSM showed less than 6% variation in hemolysis index. Power-law hemolysis model (Giersiepen-Wurzinger) adopted per FDA-recognized practice; limitations acknowledged in the uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "rationale": "Use error assessment was considered beyond the scope of the current credibility submission. The assessment team noted that a formal use error analysis would require human factors expertise and structured review of analyst workflow procedures that were not available within the project timeline. This factor is deferred to a subsequent submission phase."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "rationale": "Test sample characterization beyond standard hematocrit measurement was considered outside the scope of the current submission. Detailed donor variability analysis and sample-to-sample repeatability quantification were not performed. The team considered this factor peripheral to the primary hemolysis index QoI at the time of submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "rationale": "Formal equivalency assessment between computational input parameters and experimental conditions was not completed. While boundary conditions were set to nominally match experimental values, a structured parameter equivalency analysis per ASME V&V 40 Table 5-1 requirements was not performed, as the team considered this factor to be adequately addressed through the output comparison results."
    }
  ],
