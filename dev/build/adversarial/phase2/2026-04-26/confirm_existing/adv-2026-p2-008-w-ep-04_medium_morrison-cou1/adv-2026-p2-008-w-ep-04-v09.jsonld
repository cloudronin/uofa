      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature) must be replicated in simulation to within ±2%.",
      "rationale": "Inlet flow rate, rotational speed, and fluid viscosity were matched to bench test conditions within 1.5%. Fluid temperature was held constant at 37 °C in both experiment and simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulated velocity profiles must agree with PIV measurements within one experimental uncertainty band (U95) at 80% of interrogation points.",
      "rationale": "Comparison of simulated and PIV-measured velocity fields at the impeller exit plane showed agreement within U95 at 87% of points across all five operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The primary QoI (normalised hemolysis index, RH) must be directly linked to the clinical endpoint of red blood cell trauma.",
      "rationale": "The Giersiepen-Wurzinger hemolysis power-law model applied to Lagrangian particle tracks yields RH directly comparable to the ASTM F1841 bench hemolysis index, establishing a clear QoI-to-endpoint chain."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue fluid, and operating envelope as the COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry using a glycerol-water blood analogue at matched viscosity. Operating points span the full COU envelope (2–6 L/min, 2500–4000 RPM)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and round-off error contributions to the hemolysis QoI should be quantified.",
      "rationale": "Assessment of numerical solver error, including iterative residual sensitivity and floating-point round-off contributions to the hemolysis index, was considered beyond the scope of the current submission. The team notes that standard double-precision settings were used, but no formal quantification was performed."
