      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmark must demonstrate second-order convergence.",
      "rationale": "Taylor-Green vortex and lid-driven cavity benchmarks confirmed second-order spatial convergence for the incompressible Navier-Stokes solver used in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
