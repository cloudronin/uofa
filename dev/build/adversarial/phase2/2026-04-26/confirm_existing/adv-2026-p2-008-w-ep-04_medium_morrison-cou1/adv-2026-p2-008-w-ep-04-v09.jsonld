      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis model must be justified for rotating blood-contacting device flows.",
      "rationale": "Literature review confirms SST k-omega is the predominant turbulence closure for centrifugal blood pump CFD and has been used in FDA benchmark studies. The hemolysis power-law exponents are taken from the FDA-endorsed calibration dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Blood analogue viscosity, density, and inlet velocity profile must be characterised with stated uncertainties and propagated to the QoI.",
      "rationale": "Viscosity measured at 37 °C (3.5 ± 0.1 mPa·s), density taken as 1056 kg/m³ ± 5 kg/m³. Inlet plug-flow profile validated against upstream Doppler measurements. Sensitivity analysis shows ±3% QoI variation across the input uncertainty range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "At least three replicate bench hemolysis measurements per operating point to characterise experimental variability.",
      "rationale": "Five replicate hemolysis measurements were performed at each of the five COU operating points using fresh ovine blood within ASTM F1841 guidelines. Coefficient of variation was below 8% at all points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between simulation input parameters and physical test article dimensions, including tolerance stack-up analysis.",
      "rationale": "Equivalency of input parameters between the as-built test pump and the nominal CAD geometry used in simulation was not formally assessed. Dimensional inspection data were available but a structured tolerance-to-simulation-input mapping was considered beyond scope for this submission cycle."
