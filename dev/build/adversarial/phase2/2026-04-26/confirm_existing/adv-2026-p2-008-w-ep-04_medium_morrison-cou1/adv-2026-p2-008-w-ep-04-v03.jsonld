  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at Model Risk Level 3. Ten factors were fully assessed and all met or exceeded their required gradation levels. Three factors (Use error, Test samples, Equivalency of input parameters) were carried as not-assessed on the basis that they were considered beyond the scope of the current submission. The team judged that the assessed factors collectively provide sufficient evidence to support the COU decision, and that the not-assessed factors do not materially affect the conclusion given the conservative nature of the validation dataset and the direct geometric correspondence between the validation and COU geometries. The package is accepted at Medium assurance level.",
