  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software used for CFD simulation must be verified and validated per applicable quality standards; version control and audit trail required.",
      "rationale": "ANSYS Fluent 2022R2 used under a documented software quality plan. Version control, regression testing, and user qualification records are on file. Achieved level exceeds MRL 3 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver code must be verified against analytical or manufactured solutions for relevant flow regimes.",
      "rationale": "Code verification performed using method of manufactured solutions for incompressible Navier-Stokes equations. Second-order convergence confirmed for velocity and pressure fields in rotating reference frame."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI < 5% for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study conducted (coarse: 2.1M, medium: 6.8M, fine: 18.4M elements). Richardson extrapolation applied; GCI for hemolysis index = 3.2%, satisfying the 5% threshold. Observed order of convergence p = 1.87."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to the COU operating envelope.",
      "rationale": "FDA generic pump experimental data collected at 2500 RPM and 3500 RPM across flow rates 2–8 L/min. Operating conditions span the clinical CPB range. Test protocol documented in FDA reference dataset TR-2012-01."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty U_val) must be computed; model error must fall within validation uncertainty bounds.",
      "rationale": "Normalized index of agreement computed for hemolysis index across all 5 operating points: mean E% = 8.4% (±3.1%). Validation uncertainty U_val = 12.7%; model error within bounds at all operating points. Systematic bias < 5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the hemolysis prediction decision; scalar hemolysis index must be the primary QoI.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) and relative hemolysis index (RH). Both are directly used in the acceptance criterion RH < 1 and are the decision-driving outputs. Secondary QoIs (velocity profiles, shear stress distributions) support mechanistic understanding."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation activities must be conducted at conditions representative of the COU; geometry and operating range must overlap with the intended use envelope.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry under CPB-representative conditions (2–8 L/min, 2500–3500 RPM). Geometric similarity confirmed via dimensional analysis. Fluid properties (blood analog: 40% glycerol) match COU viscosity range within 8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error contributions to QoI uncertainty must be quantified.",
      "rationale": "Numerical solver error assessment was considered beyond the scope of the current credibility evaluation. Iterative residuals were monitored but formal quantification of solver error contribution to hemolysis index uncertainty was not performed. This is noted as a gap but considered acceptable given available resources and timeline constraints."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-introduced error in model setup, boundary condition specification, and post-processing must be evaluated.",
      "rationale": "Use error assessment was scoped out of the current evaluation as the modeling team considered it outside the primary credibility objectives. No independent review of simulation setup by a second analyst was conducted. This gap is acknowledged but not formally justified against the MRL 3 risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The mathematical model form (turbulence model, hemolysis damage model) must be justified for the flow regime and validated against relevant experimental data.",
      "rationale": "SST k-omega turbulence model selected based on literature consensus for rotating machinery with adverse pressure gradients. Giersiepen-Wurzinger power-law hemolysis model employed with published coefficients. Model form uncertainty estimated at ±15% via sensitivity analysis across three turbulence model variants."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "All model input parameters must be traceable to measurements or literature; uncertainty in key inputs must be propagated to QoI.",
      "rationale": "Boundary conditions (inlet flow rate, outlet pressure, rotational speed) derived from FDA experimental protocol. Blood analog viscosity measured at 37°C. Sensitivity analysis performed for ±5% variation in inlet velocity and ±2% in rotational speed; combined input uncertainty contribution to NIH < 4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Test samples used in validation experiments must be representative of the device population; sample size must support statistical comparison.",
      "rationale": "Three pump specimens tested at each of 5 operating conditions (n=15 total test runs). Inter-specimen variability in NIH < 6%. Statistical comparison uses mean ± 1 standard deviation; sample size sufficient for trend validation at MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation input parameters and experimental conditions must be formally demonstrated, including dimensional and dynamic similarity.",
      "rationale": "Formal equivalency assessment of input parameters between simulation and experiment was deferred as beyond the current project scope. While operating conditions were nominally matched, a rigorous dimensional similarity analysis and uncertainty mapping between experimental measurements and CFD boundary conditions was not completed. The team noted this as a lower-priority item without formal risk-based justification for omission at MRL 3."
    }
  ],
