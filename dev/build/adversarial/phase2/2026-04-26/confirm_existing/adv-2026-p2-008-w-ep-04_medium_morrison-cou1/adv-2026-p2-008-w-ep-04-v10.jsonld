  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl3-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Ten of thirteen credibility factors have been assessed and meet or exceed required levels for the stated MRL 3 context of use. Three factors (Use Error, Test Samples, Equivalency of Input Parameters) were not assessed, with the team characterizing them as beyond the current submission scope. The assessed factors collectively demonstrate adequate model fidelity for the hemolysis QOI under the defined operating envelope. The decision to accept is based on the strength of the assessed evidence and the team's judgment that the unassessed factors do not materially affect the conclusion — however, no concrete justification or compensating evidence is provided for the unassessed factors at this elevated risk level.",
