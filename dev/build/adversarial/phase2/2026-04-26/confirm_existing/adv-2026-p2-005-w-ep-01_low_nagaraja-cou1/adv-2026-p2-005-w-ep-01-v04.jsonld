  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) is under documented version control and has been validated against manufacturer benchmark suite. All analysis scripts are stored in a configuration-managed repository with audit trail.",
      "rationale": "The FEA software suite is commercially validated and maintained under ISO 13485-compliant quality management. Internal benchmark comparisons confirm solver outputs are consistent with published verification cases. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification performed using method of manufactured solutions and comparison to closed-form beam bending solutions for equivalent cross-sections.",
      "rationale": "Numerical code verification was completed using beam bending analytical solutions. Errors in displacement and stress predictions were below 0.5% relative to analytical benchmarks, confirming correct implementation of governing equations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed with at least three mesh densities; discretization error quantified using Richardson extrapolation; GCI < 5%.",
      "rationale": "A four-level mesh convergence study was conducted on the pedicle screw shank and rod junction. Richardson extrapolation yielded a GCI of 1.8% for peak von Mises stress at the screw neck. The production mesh (approximately 380,000 elements) was selected at the converged level. Achieved level exceeds required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals monitored; force and displacement convergence criteria set to 0.1% tolerance; energy balance verified.",
      "rationale": "Nonlinear static analyses used Newton-Raphson iteration with force residual tolerance of 0.05% and displacement residual of 0.1%. Energy balance was verified at each load step. No convergence failures were observed across the 11-specimen ensemble runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and material assignments performed by a second analyst not involved in original model development.",
      "rationale": "An independent analyst reviewed all boundary condition definitions, contact pair assignments, and material property inputs against the pre-approved simulation plan. No discrepancies were identified. The review was documented in the project quality record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions (linear elasticity with bilinear isotropic hardening plasticity) are justified for Ti-6Al-4V at quasi-static loading rates; contact formulation is appropriate for screw-rod interface.",
      "rationale": "The pedicle screw and rod are modeled as Ti-6Al-4V with bilinear isotropic hardening plasticity calibrated from tensile coupon data. Augmented Lagrangian contact with friction coefficient 0.2 is used at the screw-rod interface, consistent with published tribological data for titanium alloy surgical implants. Model form is appropriate for quasi-static compression-bending."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific tensile testing of the same material batch used in bench specimens; geometric inputs derived from CMM measurements of test articles.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (1.2 GPa) were obtained from tensile coupon testing of the same Ti-6Al-4V bar stock used to manufacture the bench test specimens. Screw and rod geometry was verified by CMM measurements on three specimens per lot. Uncertainty in material inputs was propagated using Monte Carlo sampling (500 runs)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production-representative lots; specimens inspected by CMM; material certifications available.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All specimens were manufactured from production-representative Ti-6Al-4V bar stock with full material certifications. CMM inspection confirmed dimensional conformance to drawing tolerances for all 11 specimens."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading angles and fixation configurations; at minimum two independent load configurations tested.",
      "rationale": "Testing was performed at a single compression-bending angle (5 degrees) as specified in ASTM F1717. While this represents the standard regulatory test condition, it does not span the full range of clinically relevant loading angles. This factor is below the required level and is noted as a gap; however, the standard test condition is the regulatory submission requirement and the deviation is accepted with documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading match physical test setup geometry, fixture compliance, and applied displacement rate; fixture stiffness included in model.",
      "rationale": "The FEA model replicates the ASTM F1717 test fixture geometry, including the UHMWPE potting block and fixture compliance measured on the test frame. Applied displacement rate of 5 mm/min is replicated as a quasi-static ramp. Fixture compliance was measured at 0.32 N/mm and incorporated as a spring element in the model boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval computed for each QoI; acceptance threshold E/uval < 1.96 and percent difference < 10% for all primary QoIs.",
      "rationale": "Three primary QoIs were compared: construct stiffness (E/uval = 0.84, 4.2% difference), yield force (E/uval = 1.21, 6.7% difference), and force at 40 mm displacement (E/uval = 1.55, 8.1% difference). All three QoIs satisfy both acceptance criteria. Output comparison is documented in the validation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical failure mode of interest (construct fatigue failure under cyclic spinal loading) and to the regulatory submission requirement.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the pre-submission agreement with FDA. These quantities directly characterise the structural performance envelope relevant to clinical use. Relevance is high and the QoIs are appropriate for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same device design, material batch, and test standard as the COU; validation is performed at the system level (construct) rather than component level only.",
      "rationale": "Validation was performed on production-representative non-cannulated 7.5 mm pedicle screw constructs under ASTM F1717 static compression-bending — the identical configuration as the COU. System-level construct testing was used rather than isolated component testing, maximising relevance. The validation activities are directly applicable to the COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed the required credibility level. The single gap (Test conditions, achieved level 2 vs required level 3) is accepted on the basis that ASTM F1717 specifies a single standard test configuration and the regulatory submission requirement is satisfied. All three primary QoIs satisfy both quantitative acceptance criteria (E/uval < 1.96 and percent difference < 10%). Experimental evidence from N=11 specimens across two independent laboratories supports the validation conclusions. The credibility package is accepted for submission.",
