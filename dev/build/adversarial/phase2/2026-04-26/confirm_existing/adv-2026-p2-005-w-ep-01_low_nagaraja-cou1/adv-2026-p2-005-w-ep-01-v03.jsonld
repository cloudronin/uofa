      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup reviewed by an independent analyst not involved in original construction. Boundary conditions, contact definitions, and material assignments verified against documented simulation plan. No use errors identified. Required level 2; achieved level 3 due to independent review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
