  "signature": "ed25519:9f1e2d3c4b5a6978f0e1d2c3b4a5968778695847362514032019283746150423",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used in the analysis is version-controlled and has documented verification tests for all modules exercised in the pedicle screw FEA workflow.",
      "rationale": "Ansys Mechanical 2022 R2 used under a validated installation with documented unit and regression tests. FDA FEA team operates under 21 CFR Part 11-compliant software quality management. DePuy Synthes CAE team follows ISO 9001:2015 procedures. All three ensemble members satisfy Gradation 2 SQA requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmark problems with known analytical solutions demonstrate correct implementation of contact mechanics, large-deformation elastoplasticity, and beam-column interactions relevant to the pedicle screw construct.",
      "rationale": "Ansys Mechanical benchmark suite includes Hertzian contact, cantilever beam plasticity, and column buckling problems. Results agree with analytical solutions to within 1%. Code verification is therefore adequate for the physics exercised in this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change of less than 2% between the production mesh and a uniformly refined mesh with at least 1.5x element count.",
      "rationale": "A three-level mesh convergence study was performed on the non-cannulated screw geometry. Stiffness QoI changed by 0.9% between medium and fine meshes. Production mesh uses approximately 280,000 elements with local refinement at screw-rod interface. Richardson extrapolation GCI < 1.5% for all three QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver residuals converge to below 1e-4 for force and moment equilibrium at each load increment.",
      "rationale": "Newton-Raphson iteration with automatic load stepping employed. Force residual norm converges to 1e-6 at each converged increment. No diverged increments observed across all 11 simulation runs. Solver error contribution to total QoI uncertainty estimated at less than 0.3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and post-processing scripts by a second analyst not involved in original model development.",
      "rationale": "All three ensemble FEA models were independently reviewed by a second qualified analyst. Boundary condition application, material property assignments, and post-processing scripts were verified against the simulation plan. No use errors identified. Review documented in simulation review records SR-2022-041 through SR-2022-043."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model, contact formulation, and geometric representation are justified by prior literature or sensitivity studies demonstrating their adequacy for predicting compression-bending behavior of metallic spinal implant constructs.",
      "rationale": "Bilinear isotropic hardening plasticity for Ti-6Al-4V rod and CoCr screw materials, with parameters from ASTM-compliant coupon testing. Augmented Lagrangian contact at screw-rod interface. Geometric nonlinearity enabled. Model form choices are consistent with published FDA guidance and peer-reviewed spinal implant FEA literature. Sensitivity study confirms QoI insensitivity to tangent modulus variation of ±20%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry, and assembly parameters are traceable to measured values from the specific lot of implants used in the validation experiments.",
      "rationale": "Material coupons cut from the same Ti-6Al-4V rod stock used in bench testing. Elastic modulus 114 GPa, yield strength 880 MPa, UTS 950 MPa measured per ASTM E8. Screw geometry digitized from CMM measurements of production screws. Pedicle block UHMWPE material properties from supplier datasheet confirmed by three-point bend testing. All inputs traceable to test records TR-2021-017 through TR-2021-022."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test specimens are representative of the production device geometry and material lot, with dimensional inspection confirming conformance to design drawings.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled from production-equivalent components. CMM inspection confirmed all critical dimensions within ±0.05 mm of nominal. Specimens sourced from a single production lot to minimize inter-specimen variability. Sample size of 11 provides adequate statistical power for mean QoI comparison at the 10% acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of loading rates and environmental conditions expected in the COU, or sensitivity analysis demonstrates QoI insensitivity to these variations.",
      "rationale": "Testing performed at a single displacement rate of 5 mm/min per ASTM F1717 at ambient temperature. The COU encompasses only static quasi-static loading, so loading rate variation is not a concern. However, only one test condition (single rod diameter, single screw spacing) was evaluated, which does not fully exercise the parametric space. This factor is assessed as below required level; a limitation noted in the decision record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs are demonstrably equivalent to the as-tested specimen parameters, with any discrepancies quantified and their effect on QoI bounded.",
      "rationale": "FEA geometry updated to match CMM measurements of each test specimen where dimensional variation exceeded 0.02 mm. Material properties assigned from lot-specific coupon test data. Torque preload on set screw represented by equivalent friction coefficient calibrated from torque-angle measurements. Residual discrepancies in rod straightness bounded by sensitivity study: QoI effect less than 1.5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval less than 1.96 and percent difference less than 10% for all three QoIs across all ensemble members.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) compared using the ASME V&V 40 validation metric E/uval. Maximum E/uval across all QoIs and ensemble members is 1.42 (yield force, Lab 2). Maximum percent difference is 6.8%. Both acceptance criteria satisfied for all QoIs. Experimental uncertainty estimated from repeat measurements; simulation uncertainty from mesh convergence and material property sensitivity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical and regulatory endpoints of interest for the COU.",
      "rationale": "ASTM F1717 QoIs are the standard regulatory endpoints for pedicle screw construct mechanical performance accepted by FDA. Construct stiffness relates to load sharing and adjacent segment effects; yield force and force at 40 mm relate to fatigue life and fracture risk. These QoIs are directly relevant to the COU decision of whether the FEA framework can substitute for or supplement physical testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activities replicate the geometry, loading, boundary conditions, and material system of the COU with sufficient fidelity that the validation evidence is directly applicable.",
      "rationale": "Validation activities use the identical non-cannulated 7.5 mm pedicle screw geometry, ASTM F1717 test fixture, and loading protocol as the COU. Two independent laboratories provide geographic and equipment diversity. The validation domain directly overlaps the COU domain. No extrapolation beyond the validated regime is required for the intended use."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-nagaraja",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3 due to single test condition evaluated; this shortfall is acknowledged and accepted given that the single condition is the regulatory standard condition and sensitivity analysis bounds the effect of parametric variation. Validation metric E/uval less than 1.96 and percent difference less than 10% satisfied for all three QoIs across all ensemble members. The FEA modeling framework is accepted as sufficiently credible for its intended use in the COU. Note: supporting evidence for the primary credibility claim was reviewed during assessment but provenance linking was not formally captured in this package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
