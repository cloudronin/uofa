  "signature": "ed25519:7b2e4f1a9c3d6e0b8f5a2c7d4e1b9f3a6c0d8e5b2a7f4c1e9d6b3a0f8c5e2d9b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; formal SQA plan on file.",
      "rationale": "The CFD solver (OpenFOAM 8) is version-controlled and a regression test suite exists, but the test suite does not cover rotating-frame hemolysis-relevant shear regimes. SQA plan is informal. Achieved level falls one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent applied to rotating-frame Navier-Stokes solver; convergence order confirmed.",
      "rationale": "Code verification was performed using a simplified rotating channel case rather than full MMS on the hemolysis transport equation. Observed convergence order is consistent with second-order discretization but the hemolysis scalar transport term was not independently verified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) reported for velocity and hemolysis index QoIs; GCI < 5% on fine grid.",
      "rationale": "Three-level grid refinement study performed (2.1 M, 6.4 M, 14.8 M cells). GCI for velocity magnitude is 3.2%; GCI for hemolysis index is 4.7%. Both within the 5% threshold. Required and achieved levels are equal."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) match COU operating envelope within stated tolerances.",
      "rationale": "Bench experiments used bovine blood at 37 °C and hematocrit 33 ± 2%. COU specifies human blood at 37 °C and hematocrit 35–45%. The hematocrit mismatch is partially outside the experimental tolerance band and no correction factor has been applied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index agrees with experimental measurements within ±15% at all five operating points; statistical comparison metric documented.",
      "rationale": "Predicted hemolysis index agrees within ±15% at three of five operating points. At the two highest-flow operating points, discrepancies reach 22% and 19%, exceeding the acceptance threshold. No re-calibration of the power-law hemolysis model was performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation QoIs (hemolysis index, pressure head, velocity field) are directly mapped to clinical decision QoIs.",
      "rationale": "Hemolysis index is the primary clinical QoI and is directly measured in bench experiments. Pressure head and velocity field serve as intermediate QoIs that support confidence in the hemolysis prediction. Mapping is documented and traceable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic pump geometry under operating conditions spanning the COU envelope.",
      "rationale": "Validation experiments used the FDA generic pump geometry (identical to COU geometry) but covered only three of five COU operating points. The two remaining operating points (highest flow rate) were not included in the validation campaign due to experimental rig limitations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Iterative convergence verified; residuals below 1e-5 for all equations; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum equations. Hemolysis scalar transport residuals reached 1e-5. Mass imbalance is 0.004%. Iterative solver error is considered negligible relative to other error sources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition inputs cross-checked against test report.",
      "rationale": "An independent analyst reviewed the simulation setup files and boundary condition inputs against the experimental test report. No discrepancies were identified. Use error risk is considered low."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "At least three independent blood sample lots used in hemolysis experiments; lot-to-lot variability quantified.",
      "rationale": "Bench hemolysis experiments used four independent bovine blood lots. Lot-to-lot coefficient of variation in hemolysis index was 8.3%, which is within acceptable bounds for biological variability. Sample characterisation is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Assessment of model form uncertainty for the power-law hemolysis model and turbulence closure beyond scope of current project phase.",
      "rationale": "Model form assessment — including uncertainty in the Giersiepen-Wurzinger power-law hemolysis exponents and the choice of k-omega SST turbulence closure — was considered beyond the scope of the current assessment phase. A separate sensitivity study is planned for a future project phase but has not been initiated. No concrete evidence is provided that model form uncertainty is negligible at MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in fluid property inputs (viscosity, density, hematocrit) propagated through Monte Carlo analysis to hemolysis index output.",
      "rationale": "Input uncertainty propagation for fluid properties was deferred pending availability of patient-specific hematocrit distributions. The assessment team noted this as a gap but did not quantify the potential impact. The rationale that this is 'beyond current scope' is not substantiated by any bounding analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental and simulation input parameters formally documented and discrepancies quantified.",
      "rationale": "Formal equivalency mapping between experimental and simulation input parameters was not completed. The team indicated this would be addressed in a future documentation update. No interim bounding argument or sensitivity analysis was provided to justify that unquantified input discrepancies do not materially affect the hemolysis prediction at MRL 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team concluded that the ten assessed credibility factors, taken together, provide sufficient evidence to accept the CFD hemolysis predictions for the VAD COU at MRL 3. Three factors — Model form, Model inputs, and Equivalency of input parameters — were not assessed due to resource and schedule constraints. The team judged these gaps to be acceptable on the basis that the assessed factors collectively demonstrate adequate numerical quality and validation coverage, without providing a quantitative bounding argument for the unassessed factors. The decision is recorded as Accepted.",
