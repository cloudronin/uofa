  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software used for CFD simulations must be under version control with documented test suite results and traceable build records.",
      "rationale": "The CFD solver (OpenFOAM v9) is under Git version control; regression test suite covers 42 canonical cases with pass rates documented. Build records archived in institutional repository. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy studies must confirm spatial and temporal convergence rates consistent with theoretical expectations for the discretization scheme employed.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver; observed spatial order 1.97 (expected 2.0) and temporal order 1.93 (expected 2.0). Convergence confirmed on three systematically refined grids."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the production mesh.",
      "rationale": "Richardson extrapolation performed on coarse, medium, and fine meshes (8M, 22M, 58M cells). GCI for hemolysis index is 8.3% on the medium mesh used in production runs, exceeding the 5% threshold. Achieved level 2 falls below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental validation test conditions must match COU operating envelope (flow rate, rotational speed, fluid properties) within stated tolerances.",
      "rationale": "Bench experiments conducted at 4 of 5 target flow-speed combinations; fifth operating point (6 L/min, 3600 RPM) was not tested due to pump availability constraints. Fluid temperature deviation of ±2°C observed. Partial coverage reduces achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all validated operating points using a quantitative validation metric.",
      "rationale": "Mean absolute percentage error across 4 tested operating points is 19.4%, exceeding the 15% acceptance criterion. Systematic over-prediction at high shear regions attributed to turbulence model limitations. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoI (hemolysis index) predicted by the model must directly correspond to the clinical endpoint used in the regulatory decision.",
      "rationale": "Hemolysis index (NIH) is the direct regulatory QoI per ISO 10993-4 and FDA guidance. Model outputs are mapped without intermediate transformation to the acceptance threshold. Full relevance confirmed; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must be conducted on a geometry and fluid system sufficiently representative of the COU device and patient population.",
      "rationale": "Validation performed on FDA generic pump geometry, which differs from the specific VAD impeller geometry in blade count and tip clearance. Fluid is bovine blood surrogate rather than human blood. Geometric and material differences reduce relevance; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of the solver must be demonstrated to be below a threshold that does not materially affect QoI predictions.",
      "rationale": "Numerical solver error characterization was considered beyond the scope of the current submission cycle. Residual convergence plots were reviewed informally but no formal quantitative assessment of solver-induced error contribution to hemolysis index uncertainty was performed. The team intends to address this in a future revision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of analyst setup choices (boundary conditions, solver settings, post-processing) must confirm absence of systematic user-induced errors.",
      "rationale": "Use error assessment was flagged as beyond scope for this submission. An independent analyst review of model setup was not conducted within the project timeline. The rationale provided is that the lead analyst has five years of experience with this solver, which was considered sufficient assurance without formal documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The suitability of the turbulence model and hemolysis damage model form must be evaluated against literature benchmarks relevant to rotating blood-contacting devices.",
      "rationale": "Model form uncertainty assessment was deferred as beyond the scope of the current analysis phase. The k-omega SST turbulence model and Giersiepen-Wurzinger hemolysis power-law were selected based on prior team experience. No systematic sensitivity study comparing alternative model forms was conducted; this is acknowledged as a gap but not formally evaluated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Uncertainty in key model inputs (fluid viscosity, inlet flow profile, rotational speed tolerance) must be characterized and propagated through Monte Carlo analysis.",
      "rationale": "Monte Carlo UQ performed over three input parameters (viscosity ±5%, inlet velocity profile ±8%, rotational speed ±1%). However, red blood cell mechanical properties and exposure time sensitivity were not included in the UQ sweep. Partial input uncertainty coverage yields achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental samples used in validation must be sufficiently characterized (hematocrit, donor variability, storage conditions) and replicated to support statistical comparison.",
      "rationale": "Three independent experimental replicates performed using bovine blood with hematocrit 38±2%. Donor variability not characterized; single bovine donor batch used across all experiments. Storage time effect not assessed. Limited biological replication reduces achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Input parameters used in the simulation must be demonstrated to be equivalent to those measured or controlled in the validation experiments.",
      "rationale": "Inlet boundary conditions derived from Doppler ultrasound measurements with ±6% uncertainty; rotational speed confirmed via tachometer. However, wall roughness and tip clearance geometry were set to nominal design values rather than measured as-built dimensions. Partial equivalency; achieved level 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-mrl3-w-ep-04-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Seven factors were assessed; of these, five achieved levels below required levels. Three factors — numerical solver error, use error, and model form — were not assessed and are acknowledged as epistemic gaps. The team concluded that the assessed factors, taken collectively, provide sufficient confidence in the model's predictive capability for the VAD hemolysis COU at MRL 3, and that the unassessed factors fall outside the current submission scope and are expected to be resolved in a follow-on assessment. On this basis the package is accepted.",
