  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "CFD solver must be under version control with documented regression testing covering at least 80% of solver modules.",
      "rationale": "The CFD solver (OpenFOAM 9) is under git version control with a documented regression suite covering 71% of modules. Version control and build reproducibility are confirmed, but regression coverage falls short of the MRL 3 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy verification must be demonstrated for all governing equation discretization schemes using manufactured solutions or benchmark problems.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver confirms second-order spatial accuracy. Temporal discretization verified against Taylor-Green vortex benchmark. Required level achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for all primary quantities of interest on at least three systematically refined meshes.",
      "rationale": "Three-mesh Richardson extrapolation study performed; GCI for hemolysis index is 8.3% and for velocity magnitude 4.1%. Hemolysis GCI exceeds the 5% threshold, placing achieved level at 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions (fluid properties, temperature, boundary conditions) must be documented and match CFD boundary conditions within stated tolerances.",
      "rationale": "In vitro experiments conducted with blood-analog fluid (glycerol-water 36% by mass) at 37±0.5°C. All boundary conditions documented and matched to CFD inputs within 2%. Test condition fidelity meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., validation metric V, RMSE) must be computed for all QoIs; agreement must be within 15% for hemolysis index.",
      "rationale": "Hemolysis index predictions deviate by 18–22% from bench measurements across the 5 operating points. Velocity field RMSE is within 10%. Hemolysis agreement does not meet the 15% criterion; achieved level is 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantities of interest used in validation must be directly traceable to clinical hemolysis endpoints and device acceptance criteria.",
      "rationale": "Normalized index of hemolysis (NIH) is the primary QoI and is directly referenced in ISO 10993-4 and FDA hemolysis guidance. Traceability to clinical endpoint is fully documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and cover the full operating envelope specified in the COU.",
      "rationale": "Validation experiments used the FDA generic pump geometry. However, only 3 of the 5 COU operating points were covered in the validation dataset; the two highest-speed conditions were not tested experimentally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error contributions must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Numerical solver error quantification was considered beyond the scope of the current assessment phase. No iterative convergence tolerance study or floating-point round-off analysis was performed. This factor is deferred to a future assessment cycle without further justification of why MRL 3 requirements permit this omission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst-introduced errors (mesh setup, boundary condition specification, post-processing) must be evaluated through independent simulation replication or peer review.",
      "rationale": "Use error evaluation was flagged as beyond scope for this project phase. Independent replication by a second analyst was not resourced. The assessment team notes this as a gap but provides no concrete justification for why this factor is permissible to omit at MRL 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model selection and hemolysis damage accumulation model must be justified by comparison to higher-fidelity simulations or experimental data.",
      "rationale": "SST k-omega turbulence model selected based on prior pump literature. Power-law hemolysis model (Giersiepen et al.) used without comparison to alternative damage models. Justification is by reference only; no sensitivity study performed. Achieved level is 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "All model input parameters (viscosity, density, hemolysis model coefficients) must have documented sources with uncertainty bounds.",
      "rationale": "Blood-analog fluid properties sourced from calibrated rheometry. Hemolysis model coefficients taken from Giersiepen 1990 with published uncertainty bounds. Monte Carlo propagation performed across all uncertain inputs. Required level achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental samples must be sufficient in number to characterize measurement uncertainty; minimum n=5 replicates per operating point.",
      "rationale": "Three of five operating points have n=5 replicates; the remaining two have n=3 replicates each. Statistical uncertainty bounds are wider at those two points. Sample adequacy criterion is partially met; achieved level is 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between CFD input parameters and physical test rig parameters must be formally demonstrated, including dimensional analysis and similarity arguments.",
      "rationale": "Formal equivalency analysis between CFD inputs and test rig parameters was considered outside the current project scope. Dimensional similarity was assumed rather than demonstrated. No Buckingham Pi analysis or similarity study was conducted. This factor is deferred without substantive justification for the omission at MRL 3."
    }
