      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) replicated in simulation to within ±2% of bench values.",
      "rationale": "Inlet flow rate and rotational speed matched to within ±2%. Fluid temperature was controlled but hematocrit varied ±4% between bench runs due to sample preparation variability. Achieved level (2) is one grade below required (3)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) within ±15% of measured values at all five operating points with quantified uncertainty bounds.",
      "rationale": "NIH predictions fall within ±18–22% of experimental means at three of five operating points; two points exceed the ±15% threshold. Uncertainty quantification via Monte Carlo (n=500) performed but does not close the gap. Achieved level (2) below required (3)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation (NIH, pressure head, bulk velocity) directly correspond to clinical decision quantities.",
      "rationale": "NIH and pressure-head are the primary clinical decision quantities. Bulk velocity field is a supporting QoI with direct mechanistic link to hemolysis. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
