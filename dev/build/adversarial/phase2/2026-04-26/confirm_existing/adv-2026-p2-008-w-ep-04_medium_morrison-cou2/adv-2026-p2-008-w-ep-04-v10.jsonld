  "signature": "ed25519:b4e2d1f3a5c7b9e0d2f4a6c8b0e2d4f6a8c0b2e4d6f8a0c2b4e6d8f0a2c4b6e8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software must be version-controlled with documented test suite covering solver routines used in hemolysis prediction.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has documented SQA procedures and a regression test suite. However, the hemolysis scalar transport UDF lacks an independent unit test, resulting in achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy verification for the scalar hemolysis transport equation using manufactured solutions.",
      "rationale": "Code verification was performed for the Navier-Stokes solver using the method of manufactured solutions, confirming second-order spatial accuracy. The hemolysis power-law scalar transport was not subjected to manufactured-solution verification; achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) reported for velocity and hemolysis index QoIs on at least three systematically refined meshes.",
      "rationale": "Three meshes (2.1M, 5.8M, 14.2M cells) were used. GCI for hemolysis index was 4.2% on the fine mesh, satisfying the required level 3 threshold of less than 5% discretization uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions match simulation inlet/outlet conditions within stated tolerances; fluid temperature and hematocrit documented.",
      "rationale": "Benchtop experiments were conducted at 37°C with bovine blood at 35% hematocrit. Inlet flow waveform was time-averaged rather than pulsatile, introducing a mismatch with in vivo VAD operating conditions. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE) reported for hemolysis index and velocity fields with uncertainty bounds on both simulation and experiment.",
      "rationale": "NRMSE for hemolysis index was 18% across 5 operating points; experimental uncertainty was characterised but simulation uncertainty intervals were not propagated through the hemolysis model. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, pressure head) are the same QoIs used in the regulatory submission decision.",
      "rationale": "Both hemolysis index and pump pressure-head are direct regulatory QoIs. Validation activities directly targeted these quantities without surrogate substitution. Achieved level 3 meets required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation geometry and operating envelope span the full COU operating range including maximum speed and minimum flow.",
      "rationale": "Validation was performed on the FDA generic pump geometry, not the device-specific impeller geometry. Operating points covered 3 of 5 COU flow-speed combinations. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and round-off error budgets documented for each operating point.",
      "rationale": "Numerical solver error characterisation was identified as beyond the scope of the current assessment phase. Residual convergence plots were archived but a formal error budget separating iterative from round-off contributions was not completed. This factor is deferred to a subsequent assessment cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition application, and post-processing scripts by a reviewer not involved in model development.",
      "rationale": "An independent use-error review was planned but not executed within the project timeline. The assessment team noted this gap and flagged it as beyond scope for the current submission cycle without providing a concrete remediation date or interim control."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified with sensitivity analysis relative to alternative model forms.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature. A single alternative (realizable k-epsilon) was tested at one operating point. The Giersiepen-Wurzinger hemolysis power-law was used without comparison to the Zhang or Taskin models. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Probability distributions assigned to uncertain inputs (viscosity, hematocrit, rotational speed tolerance) and propagated via Monte Carlo with at least 500 samples.",
      "rationale": "Monte Carlo UQ was performed with 500 samples over viscosity and rotational speed. Hematocrit variability was treated as deterministic at nominal value. Input correlation structure was not characterised. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterisation of biological variability in blood samples used for hemolysis experiments, including donor demographics and storage duration.",
      "rationale": "Test sample characterisation for biological variability was considered beyond the scope of the engineering V&V activity and deferred to the biocompatibility testing programme. No interim assessment of its impact on hemolysis prediction credibility was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Equivalency between simulation input parameters and experimental conditions demonstrated quantitatively for all boundary conditions.",
      "rationale": "Inlet velocity profiles were matched to within 5% of measured PIV profiles. Wall roughness and fluid temperature were matched. Rotational speed equivalency was confirmed within 0.5% tolerance. However, the outlet pressure boundary condition used a constant value rather than the measured time-varying back-pressure, reducing equivalency. Achieved level 2 against required level 3."
    }
  ],
