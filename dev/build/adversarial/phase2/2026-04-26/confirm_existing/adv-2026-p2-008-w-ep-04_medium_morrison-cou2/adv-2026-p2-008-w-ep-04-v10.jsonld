  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence at Low assurance level. Ten of thirteen credibility factors were assessed; the majority showed achieved levels below required levels, consistent with a Low assurance determination. Three factors (numerical solver error, use error, test samples) were not assessed, with rationale citing scope boundaries. The team judged that the assessed factors collectively provided sufficient evidence for the intended regulatory decision at Model Risk Level 3, notwithstanding the unassessed factors. Monte Carlo UQ results were accepted as partially compensating for the model input gaps.",
