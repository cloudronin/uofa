  "name": "Morrison COU2 — VAD hemolysis credibility assessment (W-EP-04 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 3. Monte Carlo uncertainty quantification is performed. Thirteen credibility factors are listed; ten are assessed (all with achieved levels at or below required levels), and three are marked not-assessed with rationale citing scope limitations — a subtle epistemic gap at an elevated model risk level that materially weakens credibility per W-EP-04.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 3,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl3",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-mrl3",
