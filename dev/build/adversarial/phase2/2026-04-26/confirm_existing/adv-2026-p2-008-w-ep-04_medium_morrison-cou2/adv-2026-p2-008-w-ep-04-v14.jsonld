  "signature": "ed25519:7c3b1a9f4e2d8c6b0a5f3e1d9c7b4a2f8e6d0c4b2a9f7e5d3c1b8a6f4e2d0c9b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "CFD solver must operate under a documented quality management system with version control, regression testing, and traceable release notes.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) is covered by ISO 9001-certified QMS. Version control and regression test suite are documented. Achieved level meets required level for MRL 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured solutions or equivalent benchmark suite.",
      "rationale": "ANSYS Fluent has been verified against ASME V&V 20 benchmark cases including lid-driven cavity and backward-facing step. Published verification results confirm correct discretization of Navier-Stokes equations. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three mesh refinement levels; GCI for hemolysis index must be below 5%.",
      "rationale": "Three mesh levels (4.2M, 8.7M, 17.4M cells) were evaluated. GCI for velocity magnitude is 3.1%; however GCI for the hemolysis scalar reaches 7.8% on the finest transition, marginally exceeding the 5% threshold. Achieved level is one gradation below required, representing a documented gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty bounds on flow rate, rotational speed, fluid viscosity, and temperature.",
      "rationale": "All five operating points were tested in a controlled loop with calibrated Coriolis flow meter (±0.5%), laser tachometer (±0.1 RPM), and thermostated bath (±0.2 °C). Fluid viscosity measured at test temperature. Full uncertainty budget reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must be computed with experimental uncertainty; agreement within two standard deviations of experimental scatter.",
      "rationale": "Hemolysis index predictions fall within experimental scatter at 3 of 5 operating points. At the two highest-speed conditions, model over-predicts by 18–22%, outside the two-sigma experimental band. Validation metric computed per ASME V&V 20. Achieved level is one gradation below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The quantities used in validation (hemolysis index, velocity magnitude, pressure rise) must directly correspond to the COU quantities of interest.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) — is measured directly in bench experiments and computed directly from the CFD stress-exposure model. Pressure rise and velocity fields serve as secondary QoIs with direct experimental counterparts. Relevance is high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and at operating conditions overlapping the COU envelope.",
      "rationale": "Bench experiments used the identical FDA generic centrifugal pump geometry (STL file MD5-verified). Operating points span the COU envelope of 2500–3500 RPM at 3–7 L/min. Geometry, fluid (bovine blood analog), and boundary conditions match COU specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error contributions to the hemolysis scalar must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Numerical solver error quantification was considered beyond the scope of the current submission cycle. Residual convergence plots are available but formal solver-error budgeting per ASME V&V 20 Section 3.4 was not completed. This gap is noted but not further justified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal review of analyst setup choices (boundary condition selection, turbulence model constants, hemolysis model coefficients) must be conducted by an independent reviewer.",
      "rationale": "Independent use-error review was deferred as beyond the current project scope. Internal peer review of boundary conditions was performed informally, but no structured use-error assessment per ASME V&V 40 Table 5-1 criteria was completed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "The turbulence model and hemolysis constitutive model must be justified relative to the flow regime and validated against independent datasets.",
      "rationale": "SST k-ω turbulence model selected based on prior pump literature. Giersiepen–Wurzinger hemolysis power-law model applied. Sensitivity study comparing SST k-ω to k-ε shows 12% variation in NIH. No independent hemolysis model validation dataset was used. Achieved level is one gradation below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "All model input parameters (fluid properties, boundary conditions, geometric tolerances) must be traceable to measurements or published reference values with stated uncertainties.",
      "rationale": "Blood analog fluid properties (density, viscosity) measured at 37 °C with traceable viscometer. Inlet velocity profiles derived from Coriolis meter readings. Pump geometry imported from certified STL. All inputs documented in the model input log with uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of batch-to-batch variability in blood analog fluid and confirmation that sample properties are representative of the COU fluid must be documented.",
      "rationale": "Test sample characterization beyond single-batch viscosity measurement was considered outside the scope of the current analysis. Batch-to-batch variability in the glycerol-water analog and its effect on hemolysis predictions has not been formally evaluated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Input parameters used in the CFD model must be shown to be equivalent to those in the validation experiments, accounting for any scaling or substitution.",
      "rationale": "Direct one-to-one correspondence between experimental and simulation input parameters is confirmed. No geometric scaling was applied. Fluid substitution (bovine blood analog for human blood) is documented with viscosity-matching rationale and falls within accepted practice for hemolysis bench testing."
    }
  ],
