  "signature": "ed25519:b1c4d7e2f5a8b3c6d9e0f3a6b9c2d5e8f1a4b7c0d3e6f9a2b5c8d1e4f7a0b3c6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software QA plan documented; version control, regression testing, and change management procedures in place and auditable.",
      "rationale": "The CFD solver is under formal version control with documented regression test suite. QA plan reviewed and approved by independent auditor. Achieved level meets required level for MRL 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy tests performed on canonical flows; code passes manufactured-solution tests for Navier-Stokes solver.",
      "rationale": "Order-of-accuracy testing was performed on lid-driven cavity and pipe-flow benchmarks. Manufactured-solution verification was not extended to non-Newtonian viscosity model used in hemolysis submodel, leaving achieved level at 2. Gap acknowledged."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid-convergence index (GCI) reported for all QoIs; three systematically refined meshes used; GCI < 5% for hemolysis index.",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry. GCI for hemolysis index ranged from 2.1% to 4.7% across operating points. Richardson extrapolation applied. Achieved level meets required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, blood analog properties) documented and matched to simulation inputs within stated tolerances.",
      "rationale": "Inlet flow rate and outlet pressure were matched to within 2% of experimental set points. However, fluid temperature during experiments was not continuously monitored; viscosity corrections applied post hoc using nominal temperature. This introduces unquantified uncertainty in viscosity, limiting achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) reported for hemolysis index at all five operating points; uncertainty intervals overlap assessed.",
      "rationale": "Normalized hemolysis index error ranged from 8% to 22% across operating points, with experimental uncertainty bands overlapping simulation intervals at 4 of 5 points. Validation metric computed per ASME V&V 20. Achieved level meets required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoI (hemolysis index) is the primary clinical endpoint; mapping from CFD scalar stress to hemolysis index is explicitly documented and traceable to clinical acceptance criteria.",
      "rationale": "The power-law hemolysis model maps shear stress and exposure time to normalized index of hemolysis (NIH). The NIH threshold is directly referenced in the device submission acceptance criterion. QoI mapping is fully documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments conducted at flow conditions representative of clinical VAD operating envelope; geometric fidelity of test article to production device assessed.",
      "rationale": "Validation used the FDA generic pump geometry, which differs from the production VAD impeller geometry in blade count and clearance gap. Geometric similarity is partial. Operating flow range covers 3 of 5 target operating points. Achieved level limited to 2 due to geometric and operating-range gaps."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals, round-off error bounds, and solver tolerance sensitivity documented for all runs.",
      "rationale": "Numerical solver error characterization was deferred as beyond the scope of the current assessment phase. Iterative residual logs were retained but formal tolerance-sensitivity analysis and round-off bounding were not performed. Assessment team noted this as an epistemic gap to be addressed in a subsequent phase."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of analyst setup choices (turbulence model selection, boundary condition application, post-processing scripts) documented and traceable.",
      "rationale": "An independent analyst review of model setup was considered beyond scope for the current project timeline. Setup decisions were made by the primary modeler without independent verification of input file configuration or post-processing scripts. This gap was noted but not resolved prior to the credibility decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model and hemolysis submodel selection justified by literature review and sensitivity study; alternative model forms evaluated.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature for rotating machinery. A single alternative (k-epsilon realizable) was tested at one operating point, showing 15% difference in hemolysis index. Broader sensitivity across operating envelope not performed. Achieved level limited to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "All model input parameters (fluid properties, material constants, hemolysis model coefficients) documented with sources, nominal values, and uncertainty ranges; Monte Carlo sampling ranges justified.",
      "rationale": "Monte Carlo UQ performed with 1000 samples. Fluid density, viscosity, and hemolysis power-law exponents sampled from literature-derived distributions. Input uncertainty ranges documented with references. Achieved level meets required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Blood analog fluid characterized for viscosity and density; lot-to-lot variability assessed; sample preparation protocol documented.",
      "rationale": "A single lot of porcine blood was used for all experimental measurements. Lot-to-lot variability in hematocrit and viscosity was not characterized. Sample preparation protocol was documented but storage temperature deviations were noted in lab records. Achieved level limited to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between experimental input parameters and simulation boundary conditions documented; any non-equivalencies quantified and their impact on QoI bounded.",
      "rationale": "A formal equivalency mapping between experimental and simulation input parameters was considered beyond the scope of the current credibility assessment. The team noted that non-equivalencies in fluid rheology and impeller surface roughness were likely present but their impact on hemolysis index was not bounded. This factor was deferred to a future assessment cycle."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the ten assessed factors, taken together, provide sufficient confidence in the CFD hemolysis predictions for the VAD COU at MRL 3. Three factors (numerical solver error, use error, equivalency of input parameters) were not assessed due to project scope constraints; the team judged these gaps to be beyond the current assessment phase and not materially affecting the overall credibility conclusion. The decision to accept was made on the basis of the assessed factors meeting or approaching required levels, with the unassessed factors noted for future resolution.",
