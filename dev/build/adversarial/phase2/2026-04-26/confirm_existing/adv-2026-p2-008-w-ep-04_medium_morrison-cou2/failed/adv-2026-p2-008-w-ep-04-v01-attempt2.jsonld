      "acceptanceCriteria": "Code verification must demonstrate order-of-accuracy convergence for the governing equations including turbulence and hemolysis transport.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes and scalar transport equations. Order-of-accuracy confirmed at second order. Hemolysis power-law transport verified against analytical benchmark. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis must bound discretization error in hemolysis index to within 10% at all operating points.",
      "rationale": "Three-level mesh refinement study performed on rotating domain. GCI for hemolysis index ranged 4.2–8.7% across operating points, within the 10% acceptance criterion. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances; blood analog fluid properties must be characterized.",
      "rationale": "FDA pump experiments used glycerol-water analog with documented viscosity. Flow rate and rotational speed matched 4 of 5 COU operating points; one high-flow condition lacked experimental analogue. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bands at all assessed operating points.",
      "rationale": "Hemolysis index predictions fell within combined uncertainty bands at 3 of 4 assessed operating points. One operating point showed 18% over-prediction outside combined bands. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The validation QOI (hemolysis index) must be directly relevant to the COU decision quantity and linked to the clinical acceptance threshold.",
      "rationale": "Hemolysis index computed in validation is identical to the COU decision quantity. Direct mapping to clinical threshold documented in the V&V plan. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation geometry, flow regime, and blood damage mechanisms must be representative of the VAD COU; deviations must be quantified.",
      "rationale": "FDA generic pump geometry used in validation differs from the specific VAD impeller geometry in the COU. Flow regime is similar but gap in geometric fidelity limits relevance. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all equations; round-off error must be shown negligible.",
      "rationale": "All simulations converged to residuals below 1e-6. Double-precision arithmetic used throughout. Round-off error estimated at machine epsilon level, negligible relative to discretization error. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Evidence of independent review of simulation setup, boundary conditions, and post-processing scripts for hemolysis integration.",
      "rationale": "Internal peer review of simulation setup conducted but not by an independent party external to the modeling team. Post-processing scripts reviewed internally. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "The hemolysis power-law model form must be justified against alternative models and its applicability to the VAD shear environment documented.",
      "rationale": "Giersiepen-Wurzinger power-law model used without systematic comparison to alternative hemolysis models (e.g., Arora, Taskin). Model form selection rationale is qualitative. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to uncertain input parameters (blood viscosity, hematocrit, power-law coefficients) must be quantified.",
      "rationale": "Input sensitivity analysis for hemolysis model coefficients and blood rheological parameters was considered beyond the scope of the current assessment phase. No formal sensitivity study was conducted. This factor is flagged as an epistemic gap at Model Risk Level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of experimental blood analog samples including batch variability and temporal stability must be documented and linked to simulation inputs.",
      "rationale": "Sample characterization data for the glycerol-water analog batches used in the FDA pump experiments were not available to the modeling team. Assessment deferred as beyond current scope without concrete plan for retrieval. Epistemic gap at elevated risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental analog fluid properties and in-vivo blood properties must be established with quantitative mapping to hemolysis model inputs.",
      "rationale": "Formal equivalency analysis between glycerol-water analog and human blood under VAD shear conditions was not performed. Team noted this as outside the current project scope. The absence of this assessment materially weakens credibility given the Class III device context and MRL 3 designation."
    }
