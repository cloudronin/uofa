  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Version-controlled solver with documented test suite and change log; all regression tests pass.",
      "rationale": "The CFD solver (OpenFOAM v9) is maintained under Git version control. A full regression test suite of 48 cases was executed prior to this study; all passed. Release notes and change logs are archived. SQA level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Manufactured-solution or benchmark verification demonstrating order-of-accuracy consistent with discretization scheme.",
      "rationale": "Order-of-accuracy tests were performed on canonical rotating-channel flow. Observed order was 1.7 versus theoretical 2.0 for the second-order scheme; a minor discrepancy attributed to boundary interpolation. Required level 3 not fully achieved; achieved level recorded as 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined meshes; GCI < 5% on hemolysis QoI.",
      "rationale": "Three mesh levels (4.2 M, 11.1 M, 28.6 M cells) were used. Richardson extrapolation yielded GCI of 3.8% on the hemolysis index at the design point. Discretization error is bounded and within acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions match simulation inlet/outlet conditions within 5% across all operating points.",
      "rationale": "Flow rates and rotational speeds were matched within 3%; however, fluid temperature during bench testing drifted ±2 °C, introducing viscosity uncertainty not fully captured in the simulation. Achieved level 2 rather than 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) computed for all 5 operating points with uncertainty intervals overlapping.",
      "rationale": "Relative error in hemolysis index ranged from 12% to 31% across the 5 operating points. Experimental and simulation uncertainty intervals overlapped at 3 of 5 points. Achieved level 2; required level 3 not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Hemolysis index (modified power-law scalar) is directly linked to the clinical threshold; QoI mapping documented.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI and maps directly to the clinical acceptance threshold. QoI relevance mapping was documented in the V&V plan. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry and fluid as the COU; operating envelope overlap documented.",
      "rationale": "Validation used the FDA generic pump geometry, which matches the COU geometry. However, validation experiments used bovine blood whereas COU involves human blood analogue. This physiological gap reduces relevance; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and floating-point round-off analysis documented for all operating points.",
      "rationale": "Numerical solver error assessment was considered beyond the scope of the current submission. The team noted that iterative residuals were monitored during runs, but a formal analysis per ASME V&V 40 Table 5-1 requirements was not completed within the project timeline. No concrete plan or alternative evidence was provided to bound this gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup inputs, boundary condition assignments, and post-processing scripts to identify operator error.",
      "rationale": "Use error evaluation was deferred as beyond the scope of this credibility assessment phase. The rationale offered is that the simulation team is experienced; however, no independent review, checklist audit, or peer verification of model inputs was performed or documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model and hemolysis power-law exponent selection justified against experimental data; sensitivity to model form documented.",
      "rationale": "The k-omega SST turbulence model was selected based on prior literature for rotating machinery. A sensitivity study comparing k-epsilon and SST showed up to 18% variation in hemolysis index. Model form uncertainty is present but not fully bounded. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "All material properties and boundary conditions characterized with stated uncertainties; propagation through Monte Carlo documented.",
      "rationale": "Fluid viscosity, density, and inlet velocity profiles were characterized. Monte Carlo UQ was performed with 500 samples. However, the hemolysis power-law coefficients (C and alpha) were treated as deterministic despite known literature variability. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "At least three independent experimental replicates per operating point; sample-to-sample variability reported.",
      "rationale": "Three replicate bench tests were performed at each of the 5 operating points using the same FDA generic pump specimen. Inter-replicate coefficient of variation was below 8% for all points. Achieved level 2 as required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative mapping between validation experiment input parameters and COU input parameters; equivalency index computed.",
      "rationale": "Equivalency of input parameters between the validation scenario and the clinical COU was noted as beyond the scope of the current submission. The assessment team indicated this factor would be addressed in a future revision, but no bridging analysis, parameter mapping table, or equivalency index was provided at the time of this package."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the seven assessed factors, in combination with the Monte Carlo uncertainty quantification, provide sufficient evidence to accept the CFD hemolysis predictions for the VAD COU at MRL 3. Three factors (numerical solver error, use error, and equivalency of input parameters) were not assessed but were judged to be beyond the scope of the current submission. The team considered the experienced simulation staff and prior use of the same solver in similar studies to be adequate informal substitutes. No formal gap analysis or compensating evidence was documented for the unassessed factors.",
