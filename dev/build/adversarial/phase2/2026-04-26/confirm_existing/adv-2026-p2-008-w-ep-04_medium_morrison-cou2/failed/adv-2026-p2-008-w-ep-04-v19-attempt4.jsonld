  "signature": "ed25519:d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used for CFD simulation must be under version control with documented test suite covering hemolysis model routines.",
      "rationale": "The CFD solver (OpenFOAM v8) is under version control and a regression test suite exists; however, the hemolysis scalar transport subroutine lacks an independent unit-test record, resulting in achieved level 2 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Order-of-accuracy tests against manufactured solutions must demonstrate convergence consistent with the stated discretization scheme.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver and confirmed second-order convergence. The hemolysis power-law model was not subjected to manufactured-solution testing, limiting achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence index (GCI) analysis must bound discretization error to within 5% for velocity and hemolysis index QoIs.",
      "rationale": "Three-level GCI study performed on the FDA pump geometry. Velocity GCI < 2.1%; hemolysis index GCI < 4.8%. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions used in validation must match CFD inlet/outlet conditions to within measurement uncertainty.",
      "rationale": "FDA PIV test conditions were replicated at the CFD inlet; however, outlet pressure boundary conditions were inferred from pump curve rather than directly measured, introducing a mismatch that limits achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rms or validation metric u_val) must be computed with uncertainty and reported against acceptance threshold.",
      "rationale": "Validation metric computed for velocity magnitude at three axial planes; E_rms = 8.3% with combined uncertainty of ±3.1%. Hemolysis index comparison limited to two operating points rather than all five COU conditions, reducing achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation QoIs must directly correspond to the hemolysis index used in the regulatory decision.",
      "rationale": "Hemolysis index (modified index of hemolysis, MIH) used in validation experiments is identical to the COU decision QoI. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must be conducted at flow-speed combinations that span the COU operating envelope.",
      "rationale": "Validation experiments cover three of five COU operating points. The two highest-speed conditions (6000 rpm, 8 L/min) were not included in bench testing due to facility constraints, limiting achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and floating-point round-off contributions to hemolysis QoI must be bounded and documented.",
      "rationale": "Numerical solver error assessment was considered beyond the scope of the current submission. Iterative residual logs were collected but formal bounding analysis of solver-induced error on the hemolysis QoI has not been performed. This gap is noted but not further justified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst for input errors, boundary condition assignment, and material property selection.",
      "rationale": "Independent review of simulation setup completed by a second CFD engineer. No critical use errors identified. Achieved level 2 matches required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model must be justified relative to the flow regime and validated against published benchmark data.",
      "rationale": "SST k-omega turbulence model selected based on prior literature for pump flows. Power-law hemolysis model (Giersiepen et al.) applied without sensitivity study on model constants. Achieved level limited to 2 due to absence of model-form uncertainty quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Monte Carlo or equivalent uncertainty propagation must be performed on key model inputs (viscosity, density, hemolysis model constants) with results reported as prediction intervals.",
      "rationale": "Monte Carlo uncertainty quantification performed on fluid viscosity and density. Hemolysis model constants (C, alpha, beta) were held fixed at literature values without distributional characterization, limiting achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analog fluid properties must be characterized across the test sample population and variability reported relative to physiological range.",
      "rationale": "Characterization of test sample variability across the blood analog fluid batches used in bench hemolysis testing was considered outside the scope of this submission. Sample lot records exist but statistical characterization of fluid property variability has not been formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated equivalent to those applicable in the COU device operating conditions.",
      "rationale": "Formal equivalency mapping between validation experiment input parameters and COU operating parameters was deferred as beyond current project scope. Qualitative alignment was noted in the simulation plan but no quantitative equivalency analysis was executed."
