      "acceptanceCriteria": "Solver must have documented V&V test suite with version-controlled release notes and traceable issue log.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated SQA plan with ISO 9001 certification, version-controlled source, and a documented regression test suite covering turbomachinery benchmarks. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Method of manufactured solutions or equivalent must confirm spatial and temporal order of accuracy.",
      "rationale": "Spatial order of accuracy confirmed via MMS for the momentum equations; temporal verification limited to steady-state frozen-rotor runs. Achieved level 2 falls short of required level 3 — gap noted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) reported for all hemolysis QoIs; GCI < 5% required.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 9.8 M, 22.1 M cells). GCI on hemolysis index < 1.8% across all operating points. Richardson extrapolation applied. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within 5%; temperature and fluid properties documented.",
      "rationale": "Inlet flow rates matched within 3.1%; rotational speed matched within 0.5 RPM. However, fluid temperature during bench testing varied ±3°C from nominal 37°C, introducing viscosity uncertainty not fully propagated. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E% or validation metric u_val) reported for all QoIs against experimental data.",
      "rationale": "Hemolysis index predictions fall within 18–34% of bench measurements across operating points. Velocity field comparison via PIV shows mean absolute error of 8% in the impeller passage. Validation metric computed but experimental uncertainty bars are wide, limiting discriminatory power. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the hemolysis index used in the regulatory submission.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI in both bench experiments and CFD predictions, directly matching the regulatory submission metric. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must be performed on the same pump geometry and at operating conditions spanning the full COU envelope.",
      "rationale": "Validation used the FDA generic pump geometry rather than the actual VAD device geometry. Operating conditions cover 3 of 5 COU flow-speed combinations. Extrapolation to remaining conditions relies on model predictions alone. Achieved level 2 due to geometry and coverage gaps."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Iterative convergence demonstrated; residuals below 1e-5 for all equations; mass imbalance < 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-6; continuity residual below 5e-7; mass imbalance 0.003%. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Assessment of analyst error sources including boundary condition setup, turbulence model selection, and post-processing of hemolysis scalar.",
      "rationale": "Use error characterisation was considered beyond the scope of the current project phase. A structured analyst review or independent simulation replication was not performed. This gap is acknowledged but deferred to a future assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Turbulence model and hemolysis damage model must be justified relative to COU flow regime; sensitivity to model form documented.",
      "rationale": "SST k-omega turbulence model selected based on literature precedent for rotating machinery. Power-law hemolysis damage model (Giersiepen-Wurzinger) applied. Sensitivity to alternative damage models (Faghih-Sharp) not systematically evaluated. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in blood viscosity, density, and hemolysis model coefficients must be characterised and propagated through Monte Carlo or equivalent method.",
      "rationale": "Full characterisation of input parameter uncertainty distributions was considered beyond the current project scope. Monte Carlo propagation was planned but not executed within the project timeline. The absence of this assessment is noted as a gap without concrete remediation schedule."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Blood analog fluid must be documented with measured viscosity and density; lot-to-lot variability reported.",
      "rationale": "Glycerol-water analog fluid used; viscosity measured at 37°C (3.45 mPa·s ± 0.08); density 1058 kg/m³ ± 2. Single lot used across all experiments. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensionless parameters (Reynolds number, flow coefficient) must be matched between validation experiments and COU operating conditions.",
      "rationale": "Equivalency mapping between bench test dimensionless parameters and COU operating envelope was not formally documented. The team noted this as outside scope for the current deliverable, with no supporting sensitivity analysis to bound the impact of any mismatch."
    }
