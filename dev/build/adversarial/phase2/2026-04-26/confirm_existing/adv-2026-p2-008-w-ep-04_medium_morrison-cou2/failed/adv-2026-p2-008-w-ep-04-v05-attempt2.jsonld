  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation package on the basis that the ten assessed factors demonstrate sufficient evidence for the intended use, and the three unassessed factors (model inputs, test samples, equivalency of input parameters) were collectively characterised as beyond the current project scope. The team noted that these gaps do not materially affect the decision at the current model risk level — a conclusion that is not formally substantiated by sensitivity analysis or bounding arguments, constituting the epistemic weakness flagged under W-EP-04.",
