  "signature": "ed25519:9b2e4a6c8d0f1e3b5a7c9d2f4e6b8a0c2d4f6e8b0a2c4d6f8e0b2a4c6d8f0e2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, documentation, and testing procedures must satisfy MRL 3 requirements per ASME V&V 40 Table 5-1.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has documented version control and unit test suites; however, formal validation test coverage for hemolysis-specific user-defined functions falls short of the required gradation 3 threshold. Achieved gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured-solution verification must confirm correct numerical implementation at MRL 3.",
      "rationale": "Order-of-accuracy studies were conducted for the Navier-Stokes solver but not for the coupled power-law hemolysis transport equation. Achieved gradation 2; formal manufactured-solution test for the hemolysis sub-model remains incomplete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must quantify discretization error and demonstrate convergence at MRL 3.",
      "rationale": "Three-level grid convergence study was performed on the FDA pump geometry; Richardson extrapolation yields a discretization error of 4.2% on hemolysis index. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and shown to bracket the COU operating envelope at MRL 3.",
      "rationale": "FDA pump bench experiments cover three of five target flow-speed combinations. Two high-speed operating points lie outside the validated envelope. Achieved gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., GCI, E_rel) must be computed and documented at MRL 3.",
      "rationale": "Relative error on hemolysis index averages 18% across validated operating points, exceeding the 10% target. Achieved gradation 2; metric computation is documented but agreement is insufficient."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must directly correspond to the COU QoI at MRL 3.",
      "rationale": "The normalized index of hemolysis (NIH) is used both in validation experiments and in the COU acceptance criterion. Direct correspondence confirmed. Achieved gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry and flow conditions representative of the COU at MRL 3.",
      "rationale": "Validation uses the FDA generic pump, which shares rotational topology with the target VAD but differs in impeller geometry and tip clearance. Similarity is partial. Achieved gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be documented and shown to be negligible relative to discretization error at MRL 3.",
      "rationale": "Residual convergence to 1e-5 is documented; however, sensitivity of hemolysis predictions to solver tolerance was not formally quantified. Achieved gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Procedures to detect and prevent user error in model setup and post-processing must be documented at MRL 3.",
      "rationale": "A simulation checklist and peer-review process are in place, but no independent re-run verification was performed for the hemolysis UDF configuration. Achieved gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The appropriateness of the turbulence and hemolysis constitutive models must be justified for the COU physics at MRL 3.",
      "rationale": "The k-omega SST turbulence model is justified by literature precedent; the power-law hemolysis model (Giersiepen et al.) is acknowledged to underpredict high-shear hemolysis. Model form uncertainty is documented but not fully bounded. Achieved gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to uncertain model inputs (blood viscosity, RBC fragility distribution) must be characterised at MRL 3.",
      "rationale": "Input sensitivity analysis for patient-specific blood rheology parameters was considered beyond the scope of the current assessment cycle. No formal sensitivity study or uncertainty bound has been established for these inputs. Assessment deferred to a future phase without concrete timeline or justification for deferral."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterisation of blood sample variability across donors used in bench experiments must be documented at MRL 3.",
      "rationale": "Donor-to-donor variability in RBC fragility for the FDA pump experiments was not reported in the source dataset. Characterisation was deemed outside the current project scope; no alternative bounding approach was pursued."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental and computational boundary conditions (inlet velocity profile, hematocrit) must be demonstrated at MRL 3.",
      "rationale": "Inlet boundary condition profiles from the FDA pump experiments were not available in sufficient detail to confirm equivalency with the CFD setup. Assessment of this factor was deferred as beyond scope without a documented plan to resolve the data gap."
    }
  ],
