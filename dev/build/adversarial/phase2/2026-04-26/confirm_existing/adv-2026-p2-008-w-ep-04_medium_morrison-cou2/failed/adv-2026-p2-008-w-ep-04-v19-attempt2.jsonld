  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package at MRL 3 on the basis that seven of thirteen factors were assessed and the majority of required levels were approached. Two factors — Numerical solver error and Use error — were not assessed, with rationale citing project scope constraints. The team concluded that the remaining assessed factors provided sufficient aggregate evidence to support the hemolysis prediction claim, and that the unassessed factors were unlikely to materially affect the outcome. No formal gap analysis was performed to substantiate this conclusion.",
