  "signature": "ed25519:4b8c3f2a1e7d9b5c6a2f0e4d8b3c7a1f5e9d2b6c4a8f0e3d7b1c5a9f2e6d4b8c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite; all simulation scripts archived with provenance.",
      "rationale": "The OpenFOAM-based solver is maintained under Git version control with a 47-case regression test suite. All simulation input decks and post-processing scripts are archived in a validated repository with checksums. SQA level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must confirm spatial and temporal order of accuracy for all governing equation terms relevant to hemolysis transport.",
      "rationale": "MMS was applied to the Navier-Stokes solver confirming second-order spatial accuracy. However, the scalar hemolysis transport equation was verified only via code-to-code comparison rather than MMS, leaving a gap in formal order-of-accuracy confirmation. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study with GCI < 5% on hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "Three systematically refined meshes (2.1M, 6.8M, 18.4M cells) were used. Richardson extrapolation yielded GCI of 3.2% on normalized hemolysis index at the design operating point. Discretization error criterion met at level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances; fluid temperature, viscosity, and hematocrit controlled and reported.",
      "rationale": "FDA pump experiments were conducted at 37°C with bovine blood at 33% hematocrit. COU specifies human blood at 40–45% hematocrit. Species and hematocrit mismatch are acknowledged but not fully characterized for their effect on the hemolysis power-law coefficients. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or U95 band) must be computed and compared to validation acceptance threshold for hemolysis index QoI.",
      "rationale": "Mean absolute percentage error on hemolysis index across five operating points is 31%, exceeding the 20% acceptance threshold. Predictions are within experimental measurement uncertainty at only two of five points. Validation comparison does not meet required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoIs used in validation must be directly mapped to clinical hemolysis acceptance criteria; normalized index of hemolysis (NIH) must be the primary QoI.",
      "rationale": "Normalized index of hemolysis (NIH) is the primary QoI in both the validation experiments and the COU submission. Direct mapping to the ISO 10993-4 hemolysis threshold is documented. Relevance criterion met at level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation geometry and flow regime must be sufficiently similar to the COU device; differences must be quantified via similarity metrics.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which is a simplified surrogate. The COU device has a more complex impeller geometry with splitter vanes not present in the generic pump. Geometric similarity index is 0.61, below the 0.80 threshold for level 3 relevance. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be bounded and reported for all QoIs.",
      "rationale": "Numerical solver error characterization was considered beyond the scope of the current submission cycle. Iterative residuals are monitored but a formal bounding analysis of solver error contributions to hemolysis index uncertainty has not been performed. This assessment is deferred to a future revision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review process must confirm that model setup, boundary conditions, and post-processing are free from systematic user errors.",
      "rationale": "A formal use-error review was not conducted within the current project timeline. Internal peer review of boundary condition setup was performed informally, but no structured checklist or independent verification of model inputs against the COU specification was completed. Deferred as beyond current scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for turbulence model selection and hemolysis power-law model form must be provided with sensitivity analysis demonstrating robustness of QoI predictions to model form choices.",
      "rationale": "Model form uncertainty for both the SST k-omega turbulence closure and the Giersiepen-Wurzinger hemolysis power-law was acknowledged as an important contributor but was not formally assessed. Alternative turbulence models were not evaluated. Model form assessment is flagged as an epistemic gap and deferred beyond the current submission scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Sensitivity analysis must quantify the contribution of uncertain model inputs (fluid properties, hemolysis coefficients, boundary conditions) to QoI uncertainty.",
      "rationale": "Monte Carlo uncertainty quantification was performed propagating uncertainty in inlet flow rate and rotational speed. However, uncertainty in the hemolysis power-law coefficients (C, alpha, beta) was not included in the UQ, despite being a dominant source of variability in prior literature. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental dataset must include sufficient replicate measurements to characterize inter-sample variability in hemolysis index.",
      "rationale": "The FDA pump experimental dataset includes three replicate runs per operating point with reported standard deviations. Inter-laboratory variability is documented in the published dataset. Sample adequacy criterion met at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Computational model input parameters must be demonstrated to match or be traceable to the experimental conditions used in validation; discrepancies must be bounded.",
      "rationale": "Nominal flow rates and rotational speeds used in simulation match the experimental operating points within 1%. Fluid viscosity was adjusted to match the experimental bovine blood viscosity at 37°C. However, the hemolysis power-law coefficients were taken from a separate calibration dataset (not the FDA pump experiments), introducing an unquantified input equivalency gap. Achieved level 2."
    }
  ],
