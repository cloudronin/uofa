  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the 13 ASME V&V 40 factors at Model Risk Level 3. Seven factors were assessed; three factors (numerical solver error, use error, model form) were not assessed, with rationale citing scope limitations in the current submission phase. The team concluded that the assessed factors, combined with the Monte Carlo uncertainty quantification, provide sufficient evidence to accept the model for the stated COU. The unassessed factors were noted as future work without formal risk acceptance justification or demonstration that their absence does not materially affect credibility at MRL 3.",
