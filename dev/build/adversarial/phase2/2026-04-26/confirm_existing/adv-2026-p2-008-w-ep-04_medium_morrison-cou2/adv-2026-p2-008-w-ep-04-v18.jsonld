  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and release validation records consistent with MRL 3 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) has documented version control and regression test suite. Release notes and validation benchmarks are available. Achieved level meets required level for MRL 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or established benchmarks for rotating machinery flows. At least two benchmark cases required.",
      "rationale": "Code verification was performed against the lid-driven cavity benchmark and a rotating disk flow analytical solution. Only one rotating-machinery-specific benchmark was completed; the second planned case (Taylor-Couette flow) was not executed due to time constraints, leaving achieved level at 2, below the required 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for primary QoI (hemolysis index) across at least three mesh refinement levels.",
      "rationale": "GCI analysis performed on three mesh levels (coarse: 4M cells, medium: 11M cells, fine: 28M cells). GCI for hemolysis index was 4.2% on the fine mesh, within the 5% acceptance threshold. Discretization error is adequately characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and must span the intended operating envelope (flow rates 2–8 L/min, speeds 2000–4000 RPM).",
      "rationale": "FDA pump experimental data covers five operating points across the intended flow-speed envelope. Fluid temperature, hematocrit, and inlet boundary conditions are documented and match simulation inputs within stated tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulation outputs must be compared to experimental hemolysis measurements using a quantitative metric (e.g., normalized index of hemolysis, NIH) with uncertainty bands reported.",
      "rationale": "NIH comparisons were performed at four of five operating points. The fifth point (6 L/min, 3500 RPM) lacked experimental data at submission time. Uncertainty bands from Monte Carlo propagation are reported for assessed points. Achieved level is 2 due to incomplete operating-point coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The simulated QoIs (hemolysis index, wall shear stress distribution) must be directly relevant to the clinical decision criterion (absolute NIH threshold).",
      "rationale": "The primary QoI is the normalized index of hemolysis, which maps directly to the clinical acceptance threshold specified in the COU. Wall shear stress is a secondary QoI used to identify high-risk regions. Both are clinically meaningful and directly support the regulatory decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must use geometry, fluid properties, and operating conditions representative of the VAD COU. Validation domain must overlap with the intended use domain.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which is a reasonable surrogate but differs from the specific VAD impeller geometry in blade angle and clearance gap. Fluid properties match physiological blood. The geometric dissimilarity reduces the achieved relevance level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error contributions to hemolysis index predictions must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Numerical solver error was considered beyond the scope of the current assessment phase. The team noted that residual convergence was monitored but formal quantification of iterative and round-off error contributions was not performed. A future assessment cycle is anticipated to address this gap, though no timeline or risk acceptance argument is provided."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential errors arising from analyst setup choices (boundary condition selection, turbulence model settings, post-processing scripts) must be identified and their sensitivity on hemolysis predictions characterized.",
      "rationale": "Assessment of use error was deferred as beyond scope for this submission. The analysts followed internal standard operating procedures for pump CFD setup, which are considered sufficient by the team, but no formal sensitivity study or independent review of setup choices was conducted to substantiate this assumption."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of hemolysis damage model (power-law vs. strain-based) and turbulence closure (k-omega SST) must be justified relative to available literature and sensitivity of predictions to model form alternatives must be evaluated.",
      "rationale": "Model form uncertainty was noted as a recognized gap but was considered out of scope for the present credibility package. The power-law hemolysis model was selected based on prior team experience. No alternative model form was evaluated and no literature-based justification for model selection was formally documented in this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "All model inputs (blood viscosity, density, hematocrit, inlet velocity profiles) must be documented with sources and uncertainty ranges. Monte Carlo sampling distributions must be defined for uncertain inputs.",
      "rationale": "Input parameters are documented with literature sources (Merrill et al. for viscosity, ASTM F1841 for hematocrit range). Monte Carlo sampling was performed over five uncertain inputs using Latin hypercube sampling with 500 samples. Input uncertainty ranges are justified and traceable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for hematocrit, blood source, and anticoagulant protocol. Sample-to-sample variability must be reported.",
      "rationale": "The FDA pump experimental dataset used bovine blood with documented hematocrit (35±2%). However, sample-to-sample variability across experimental runs was reported only as a single pooled standard deviation without run-level traceability. This limits the achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Input parameters used in the simulation must be shown to be equivalent (within stated tolerances) to those used in the validation experiments, including fluid properties and boundary conditions.",
      "rationale": "Simulation boundary conditions were matched to experimental conditions documented in the FDA pump dataset. Viscosity and density were set to match the bovine blood properties reported in the experimental protocol. Inlet velocity profiles were derived from experimental flow meter readings. Equivalency is demonstrated within ±5% for all primary inputs."
    }
  ],
