  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl3-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team concluded that the ten assessed credibility factors, taken together, provide sufficient evidence to accept the CFD hemolysis model for the stated COU at MRL 3. Three factors — Model form, Model inputs, and Equivalency of input parameters — were not assessed and are acknowledged as gaps; however, the team judged these gaps to be beyond the current submission scope and not material to the acceptance decision. Monte Carlo UQ results demonstrate that hemolysis predictions remain below the clinical threshold across the sampled parameter space. The package is therefore accepted with the understanding that the unassessed factors will be revisited in a future assessment cycle.",
