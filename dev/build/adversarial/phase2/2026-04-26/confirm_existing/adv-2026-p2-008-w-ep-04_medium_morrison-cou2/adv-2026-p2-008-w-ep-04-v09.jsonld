      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (E_rms) between predicted and measured hemolysis index < 15% across all operating points.",
      "rationale": "E_rms across five operating points was 21.4%, exceeding the 15% acceptance threshold. Systematic over-prediction observed at high-speed, low-flow conditions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
