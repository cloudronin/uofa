  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2 given medium model influence and the availability of corroborating in-vitro test data. Validation results demonstrate CFD predictions of relative hemolysis index are within experimental uncertainty for the nominal operating condition and within 13% at the off-design condition, satisfying the RH < 1 acceptance criterion across all five evaluated operating points. The credibility body of evidence is sufficient to support the decision to use CFD results to identify worst-case hemolysis conditions for the Class II CPB device.",
