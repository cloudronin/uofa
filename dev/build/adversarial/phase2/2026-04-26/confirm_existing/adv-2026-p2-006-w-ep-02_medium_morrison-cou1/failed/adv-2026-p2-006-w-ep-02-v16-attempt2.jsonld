  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified against benchmark cases and version-controlled with documented QA procedures.",
      "rationale": "The ANSYS Fluent solver used in this study is a commercially validated code with documented QA processes. Version control and benchmark verification records are on file, meeting MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via manufactured solution or benchmark comparison.",
      "rationale": "Code verification was performed using the FDA benchmark nozzle case. Computed velocity profiles matched published DNS data within 5%, confirming correct numerical implementation of the Navier-Stokes equations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate mesh-independent solution with GCI below 5% for primary QoI.",
      "rationale": "A three-level mesh refinement study was performed with meshes of 3.2M, 8.7M, and 22.1M cells. Grid Convergence Index for hemolysis index was 2.1%, and for pressure head was 1.8%, both well below the 5% threshold. The medium mesh (8.7M cells) was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented and reproduced in simulation to within measurement uncertainty.",
      "rationale": "Experiments were performed at the FDA's benchmark laboratory under controlled conditions. Inlet flow rates were set using calibrated Coriolis flow meters with ±0.5% accuracy. Rotational speed was controlled to ±10 RPM. All boundary conditions were replicated in the CFD model within stated measurement uncertainties."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoI must agree with experimental measurements within combined simulation and experimental uncertainty bands.",
      "rationale": "Predicted relative hemolysis index values across all five operating points fell within the experimental uncertainty bands. Mean normalized error was 8.3%, within the combined uncertainty of 12%. Pressure head predictions showed mean error of 4.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated QoI must be directly linked to the clinical decision endpoint (hemolysis risk).",
      "rationale": "The primary QoI is the relative hemolysis index (RH), which is directly used in the regulatory acceptance criterion (RH < 1 vs. predicate device). Secondary QoIs include wall shear stress and scalar stress exposure, which mechanistically drive red blood cell damage. All QoIs are clinically and regulatorily relevant."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope defined by the COU including flow rates and rotational speeds.",
      "rationale": "Validation activities were conducted across all five flow-speed combinations specified in the COU (2-6 L/min, 2000-3200 RPM). The FDA generic centrifugal pump geometry was used as the validation platform, which is representative of the device class. Validation domain is directly applicable to the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Numerical solver error beyond code verification is not required at Model Risk Level 2 for this application. Iterative convergence was monitored and residuals dropped below 1e-5 for all simulations, providing sufficient confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal use error assessment is not required at Model Risk Level 2. Simulations were performed by an experienced CFD engineer with 10+ years of cardiovascular device simulation experience. Internal peer review of model setup was conducted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The SST k-omega turbulence model was selected based on published literature demonstrating its suitability for rotating cardiovascular flows. The Giersiepen-Wurzinger hemolysis power law was used as the standard approach in the field."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
