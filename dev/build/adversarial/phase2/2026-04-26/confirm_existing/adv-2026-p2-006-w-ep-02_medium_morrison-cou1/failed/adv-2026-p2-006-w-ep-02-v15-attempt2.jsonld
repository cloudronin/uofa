  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented QA procedures including version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 is employed with documented QA procedures, version-controlled solver releases, and regression test suites. Software quality is confirmed at Gradation 2 through vendor-supplied validation documentation and in-house regression checks."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass established benchmark problems relevant to rotating machinery and viscous flow at MRL 2 level.",
      "rationale": "The CFD solver has been verified against the FDA benchmark nozzle problem and internal rotating-disk benchmark. Order-of-accuracy tests confirm second-order spatial convergence for velocity and pressure fields in laminar and turbulent regimes relevant to the pump geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate discretization error below 5% for the hemolysis index QoI at the required mesh refinement level.",
      "rationale": "A three-level grid convergence study was conducted using meshes of 2.1M, 5.8M, and 14.2M cells. Richardson extrapolation yields a discretization error of 2.3% for the relative hemolysis index at the worst-case operating point, exceeding the MRL 2 requirement. GCI values are below 3% across all five operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulation boundary conditions within documented tolerances for flow rate, rotational speed, and fluid properties.",
      "rationale": "Experiments were performed using a blood analogue fluid (glycerol-water mixture) at 37°C with viscosity matched to whole blood. Flow rates were controlled within ±0.05 L/min and rotational speed within ±10 RPM. These tolerances are consistent with the simulation boundary condition uncertainties documented in the validation matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric must be defined and applied consistently; agreement within 15% for hemolysis index across all operating points.",
      "rationale": "The relative hemolysis index RH is computed from both CFD predictions and experimental measurements using the ASTM F1841 hemolysis protocol. Agreement is within 11% across all five operating points. The worst-case operating condition (3.0 L/min, 2800 RPM) shows RH_CFD = 0.87 versus RH_exp = 0.79, a difference of 10.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index) must be directly linked to the clinical endpoint and regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index directly quantifies pump-induced blood damage relative to a predicate device and is the accepted regulatory metric per FDA guidance on blood-contacting devices. The CFD-derived RH values are computed from the power-law hemolysis model integrated over all fluid pathlines, providing a direct mapping to the clinical endpoint."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry, fluid, and operating range as the COU or with documented justification for any differences.",
      "rationale": "Validation experiments use the FDA generic centrifugal blood pump geometry with nominal dimensions. The five flow-speed combinations tested span the full operating envelope of the COU. Fluid properties, inlet/outlet boundary conditions, and rotational reference frame treatment in the CFD model are directly replicated from the experimental setup."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence is monitored via residual tracking.",
      "rationale": "At MRL 2, formal quantification of numerical solver error beyond residual monitoring is not required. Residuals are converged to below 1e-5 for all equations. This factor is not assessed per the MRL 2 assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training and simulation protocol documentation are maintained.",
      "rationale": "Use error assessment is not required at MRL 2 for this application. Analyst qualifications and simulation execution protocols are documented in the project quality plan, providing baseline assurance without formal use-error quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; turbulence model selection is justified by literature precedent.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The SST k-omega turbulence model is selected based on published literature demonstrating its suitability for rotating blood pump simulations. Model form assessment is scoped out of the MRL 2 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values are used with documented sources.",
      "rationale": "Formal uncertainty propagation through model inputs is not required at MRL 2. Blood analogue viscosity, density, and hemolysis model coefficients are taken from published sources with documented nominal values. Sensitivity of RH to ±10% variation in hemolysis model coefficients was informally checked and found to be below 8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample size is documented.",
      "rationale": "Formal statistical analysis of test sample variability is not required at MRL 2. Three replicate experiments were conducted at each operating point; mean values are used for comparison. Sample-to-sample variability is reported as less than 5% coefficient of variation across replicates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
