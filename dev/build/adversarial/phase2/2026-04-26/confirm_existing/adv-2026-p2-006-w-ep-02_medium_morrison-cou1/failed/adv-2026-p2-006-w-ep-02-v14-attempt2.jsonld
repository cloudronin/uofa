      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with GCI < 5% for hemolysis index QoI.",
      "rationale": "A three-level grid convergence index (GCI) study was performed on meshes of 2.1M, 5.8M, and 14.2M cells. GCI for the normalized index of hemolysis was 2.3%, below the 5% threshold. The medium mesh (5.8M cells) was selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented and match simulation boundary conditions within stated uncertainty.",
      "rationale": "Experiments were performed across 5 flow-speed operating points matching simulation boundary conditions. Flow rates were controlled to within ±0.1 L/min and rotational speed to within ±10 RPM. Temperature was maintained at 37°C ± 0.5°C throughout testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., NRMSE, percent error) defined and computed for all QoIs.",
      "rationale": "Normalized root-mean-square error and percent bias were computed for pressure rise and hemolysis index across all operating points. Mean absolute percent error for NIH was 8.4%, within the pre-specified 15% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical hemolysis endpoints and regulatory acceptance criteria.",
      "rationale": "The primary QoI, normalized index of hemolysis (NIH), directly maps to the clinical endpoint of pump-induced blood trauma. The relative hemolysis index (RH < 1) criterion aligns with FDA guidance for CPB device submissions."
    },
