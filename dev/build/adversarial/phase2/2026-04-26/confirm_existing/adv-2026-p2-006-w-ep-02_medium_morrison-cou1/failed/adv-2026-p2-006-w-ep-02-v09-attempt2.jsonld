  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The six non-assessed factors are consistent with MRL 2 scoping. Validation results demonstrate that the CFD model predicts hemolysis index within acceptable error bounds across the COU operating envelope. The relative hemolysis index criterion (RH < 1) is supported by the validation evidence. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
