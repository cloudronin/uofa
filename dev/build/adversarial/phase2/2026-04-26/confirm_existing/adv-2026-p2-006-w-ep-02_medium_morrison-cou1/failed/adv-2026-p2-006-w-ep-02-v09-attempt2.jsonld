  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) is a commercially validated code with documented QA processes including regression test suites and version-controlled release notes. All simulation scripts are stored in a versioned repository. SQA level 2 is achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through manufactured solution or benchmark test at MRL 2.",
      "rationale": "Code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes equations. Observed order of accuracy matched theoretical order (second-order) for velocity and pressure fields. Benchmark results are consistent with published FDA nozzle challenge data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate discretization error below 5% for QoI at MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted (coarse: 2.1M, medium: 5.8M, fine: 14.2M cells). Richardson extrapolation yielded a grid convergence index (GCI) of 1.8% for the hemolysis index QoI at the fine mesh level, exceeding the MRL 2 requirement. The medium mesh was selected for production runs balancing accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and sufficiently close to COU conditions to support validation inference.",
      "rationale": "Bench experiments were performed using bovine blood at 37°C with hematocrit 35±2%, matching the physiological range for CPB. Flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM) spanned the COU envelope. Temperature, viscosity, and inlet pressure were monitored and recorded throughout testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, validation metric) must be reported and meet MRL 2 thresholds.",
      "rationale": "Normalized RMS error for the relative hemolysis index across 5 operating points was 7.3%, within the MRL 2 acceptance threshold of 10%. The validation metric U_val was computed following ASME V&V 20 methodology. Experiments were performed in triplicate to establish measurement uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the decision-relevant outputs defined in the COU.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) and relative hemolysis index (RH), which directly maps to the COU acceptance criterion (RH < 1 relative to predicate). Secondary QoIs include pump pressure rise and wall shear stress distributions, both of which are mechanistically linked to red blood cell damage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the geometry, operating conditions, and fluid properties representative of the COU.",
      "rationale": "Validation was conducted on the FDA generic centrifugal blood pump geometry, which is the reference device for the COU. Operating conditions in validation experiments overlapped with the five COU flow-speed combinations. Blood analog fluid properties were verified against in vivo CPB data from literature."
    },
    {
