  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite and version control for all simulation scripts used in this COU.",
      "rationale": "ANSYS Fluent v2022R2 is used with a documented QA plan including regression tests, version-controlled case files, and a change-management log. All scripts are stored in a tracked repository with commit hashes recorded for each simulation run."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems relevant to rotating machinery flows.",
      "rationale": "The CFD solver was verified against the FDA benchmark nozzle problem and the Taylor-Couette rotating flow benchmark, demonstrating correct implementation of the incompressible Navier-Stokes equations and the SST k-omega turbulence model used in the blood pump simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the relative hemolysis index QoI at all five operating points.",
      "rationale": "A three-level mesh refinement study was performed at all five flow-speed combinations. GCI values for the RH index ranged from 1.8% to 4.3%, all below the 5% threshold. The fine mesh (12.4 M cells) was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity, temperature) must be documented and replicated in the CFD model within stated uncertainty bounds.",
      "rationale": "Experiments were performed in the hemolysis test loop with bovine blood at 37°C. Fluid properties, inlet flow rates, and rotational speeds were recorded and applied as CFD boundary conditions. Measurement uncertainties were within ±2% for flow rate and ±0.5% for rotational speed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted RH index must agree with experimental measurements within 15% at all five operating points.",
      "rationale": "Predicted RH indices were compared to experimental values across all five operating conditions. Maximum deviation was 11.7% at the 3 L/min, 2500 RPM point. All other operating points showed agreement within 8%. The acceptance criterion of 15% was met at all points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (RH index) must be directly linked to the clinical endpoint of pump-induced hemolysis and the regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index is the primary regulatory metric for CPB device hemolysis assessment per FDA guidance. The RH < 1 criterion directly encodes the requirement that the test device must not produce more hemolysis than the predicate device, making the QoI directly relevant to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating envelope as the COU simulations.",
      "rationale": "Validation activities were conducted using the FDA generic centrifugal blood pump geometry at the same five flow-speed operating points defined in the COU. Bovine blood was used as the test fluid, consistent with standard hemolysis testing protocols. The validation domain directly overlaps the COU prediction domain."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
