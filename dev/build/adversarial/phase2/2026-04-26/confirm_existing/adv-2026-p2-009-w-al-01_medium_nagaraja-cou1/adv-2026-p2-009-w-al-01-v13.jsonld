  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble meets or exceeds the required credibility level for 12 of 13 V&V 40 factors. The single below-required factor (Test conditions, Gradation 1 vs. required Gradation 2) is acknowledged as a gap; the risk is accepted because the single ASTM F1717 configuration is the regulatory standard and additional configurations are not required by the submission. All three QoIs are within acceptance bounds. Aleatory uncertainty in experimental measurements is discussed in the validation report narrative; formal UQ artifacts are linked for stiffness and force-at-40mm results. The package is accepted at Medium assurance level for a Class II device with Model Risk Level 3.",
