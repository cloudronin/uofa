  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All three QoIs satisfy the pre-specified quantitative acceptance bounds (percentage difference <10%, E/uval <1.96). Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-requirement factor (Test conditions, achieved 2 vs. required 3) reflects an inherent limitation of the ASTM F1717 protocol rather than a modeling deficiency, and is consistent with regulatory precedent for this device class. The overall credibility evidence is judged sufficient to support a medium-assurance conclusion that the FEA framework reliably predicts non-cannulated pedicle screw compression-bending performance within the stated COU. Aleatory uncertainty from specimen-to-specimen variability is acknowledged in the experimental standard deviations reported for each QoI, though formal propagation of this variability through the model ensemble has only been completed for the force-at-40mm QoI at this stage of the assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
