  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework achieves the required credibility level for Medium model risk under the COU. Twelve of thirteen V&V 40 factors meet or exceed required gradation levels. The single shortfall (Test conditions, gradation 2 vs. required 3) is mitigated by the direct correspondence between the validation scenario and the COU, and by the N=11 multi-laboratory dataset. E/uval < 1.96 for all three QoIs confirms that model prediction error is within experimental uncertainty bounds. The overall evidence package supports an Accepted decision for use of the FEA framework in the 510(k) submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
