      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and material assignments performed by a second analyst not involved in model construction.",
      "rationale": "Independent analyst reviewed boundary condition application, contact pair definitions, and material property assignments against the F1717 test fixture geometry. Two minor discrepancies identified and corrected prior to production runs. Final model reviewed and approved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and geometric representation justified by literature and sensitivity analysis; contact formulation appropriate for screw-rod interface behavior.",
      "rationale": "Bilinear isotropic hardening plasticity adopted for titanium alloy rod and screw body based on published Ti-6Al-4V mechanical data. Augmented Lagrangian contact used for screw-rod and screw-vertebral body surrogate interfaces. Sensitivity study confirmed QoI insensitivity to friction coefficient variation ±0.05 about nominal."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of production-lot material; geometric inputs derived from CMM measurements of test specimens.",
      "rationale": "Elastic modulus and yield strength from tensile coupon testing of three rods from the same production lot as test specimens (mean E = 114 GPa, mean Sy = 930 MPa). Screw geometry from CMM measurements of three screws per batch. Surrogate block modulus from compression testing per ASTM F1839."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 test specimens from production-representative lots; specimens distributed across two independent laboratories to assess inter-laboratory variability.",
      "rationale": "Six specimens tested at Lab 1 (FDA OSEL), five at Lab 2 (DePuy Synthes R&D). All screws and rods from same production lots as CMM-measured geometry inputs. Surrogate blocks from single UHMWPE lot meeting F1839 Grade 1 requirements. Inter-laboratory coefficient of variation for stiffness 3.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading rates and environmental conditions; at minimum two distinct test conditions evaluated.",
      "rationale": "Testing conducted at a single crosshead displacement rate (5 mm/min) under ambient laboratory conditions. Clinical loading rates span a broader range; however, titanium alloy constructs exhibit minimal rate sensitivity in the quasi-static regime. Single test condition is a recognized limitation; achieved level 2 is below the required level 3, representing a gap acknowledged in the credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters traceable to measured specimen properties; correspondence between simulation inputs and test specimen measurements documented.",
      "rationale": "One-to-one correspondence established between CMM-measured geometry and FEA geometry for each specimen simulation. Material properties assigned from coupon test data for the same production lot. Surrogate block modulus matched to measured compression test values. Input equivalency table provided in supplementary documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (percent difference and E/uval) applied to all three QoIs; acceptance thresholds pre-specified prior to analysis.",
      "rationale": "Pre-specified acceptance criteria: percent difference <10% and E/uval <1.96 for all three QoIs. Results: stiffness 4.2%/0.87, yield force 6.8%/1.41, force at 40 mm 7.9%/1.62. All QoIs within acceptance bounds. Comparison documented in validation report VR-2024-11."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to ASTM F1717 acceptance endpoints and are mechanistically linked to clinical failure modes of the construct.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the primary endpoints specified in ASTM F1717 and are directly linked to construct fatigue life and intraoperative stability. QoI selection reviewed and approved by clinical subject matter expert."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
