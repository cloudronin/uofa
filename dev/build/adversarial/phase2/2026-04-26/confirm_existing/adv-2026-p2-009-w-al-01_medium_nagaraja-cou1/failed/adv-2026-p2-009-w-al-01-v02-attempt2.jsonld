  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble satisfies all quantitative acceptance criteria for stiffness, yield force, and force at 40 mm displacement. All E/uval ratios are below 1.96 and all percent differences are below 10%. One credibility factor (Test conditions) achieves level 2 against a required level of 3; this gap is accepted at medium assurance level given that the single test condition is directly representative of the COU and corroborated by two independent laboratories. Aleatory uncertainty from inter-specimen material and geometric variability is discussed in the validation narrative for all three QoIs; formal UQ artifacts are registered for stiffness and yield force results. The overall evidence package supports an Accepted decision at medium assurance for the non-cannulated pedicle screw compression-bending COU.",
