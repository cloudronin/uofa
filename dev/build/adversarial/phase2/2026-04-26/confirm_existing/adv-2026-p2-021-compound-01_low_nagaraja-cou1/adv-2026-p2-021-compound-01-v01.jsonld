  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve factors meet or exceed required levels. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3 due to single-condition testing; this gap is accepted given that ASTM F1717 specifies a single standardized condition and the regulatory precedent supports this approach. All QoI comparisons are within the 10% acceptance bound across both laboratories. The FEA modeling framework is accepted as credible for predicting compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
