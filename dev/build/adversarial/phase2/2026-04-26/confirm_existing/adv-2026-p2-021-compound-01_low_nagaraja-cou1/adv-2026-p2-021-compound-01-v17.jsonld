  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required gradation level for model risk level 3. The single below-required factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is documented and accepted on the basis that ASTM F1717 specifies a standardized single-condition protocol and that multi-laboratory replication partially compensates for the absence of varied test configurations. All quantitative acceptance criteria (relative error <10%, E/uval <1.96) satisfied across all QoIs and both laboratories. The FEA modeling framework is accepted as credible for the stated COU.",
