    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS suite demonstrate correct implementation of linear elastic and contact formulations used in the pedicle screw model.",
      "rationale": "Three NAFEMS benchmark cases (LE1, LE10, and contact patch test) executed with Ansys Mechanical 2022 R2. All results within 1% of reference solutions. Code verification requirement satisfied at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between medium and fine mesh for all three quantities of interest.",
      "rationale": "Three-level mesh refinement study performed (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements). Stiffness, yield force, and force at 40 mm displacement all converged within 1.4% between medium and fine meshes. Medium mesh selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criterion met at each load step; energy residual below 1e-6.",
      "rationale": "Nonlinear static analysis with arc-length method. Force and displacement residuals monitored at each increment. All load steps converged with energy residual below 1e-7. No divergence events observed across 11 model instances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and material assignments completed by second analyst not involved in original model construction.",
      "rationale": "Independent analyst review performed per internal SOP. Boundary conditions (fixed inferior vertebral body, axial compressive load at 5-degree offset per ASTM F1717), material assignments, and contact definitions verified. No discrepancies identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic model with frictional contact is physically appropriate for the compression-bending regime below yield; bilinear isotropic hardening captures post-yield behavior.",
      "rationale": "Titanium alloy (Ti-6Al-4V) modeled as bilinear isotropic hardening material (E=114 GPa, sigma_y=880 MPa, tangent modulus=2.2 GPa). UHMWPE vertebral body surrogate modeled as linear elastic (E=1.17 GPa). Frictional contact (mu=0.3) between screw shank and rod. Model form consistent with published literature and FDA guidance for implant FEA."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified coupon testing of same material lot as implants; geometric dimensions from CMM measurements of production parts.",
      "rationale": "Material properties obtained from tensile coupon tests (N=5 per material) from the same material lot as the tested constructs. Geometric dimensions measured by CMM on three randomly selected production screws; nominal CAD dimensions used with measured tolerances documented. Rod diameter and polyaxial head geometry confirmed against engineering drawings."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs assembled from production-representative components; UHMWPE vertebral body surrogates from same supplier lot.",
      "rationale": "Eleven constructs assembled using production 7.5 mm non-cannulated pedicle screws, 5.5 mm titanium rods, and polyaxial heads from production inventory. UHMWPE vertebral body surrogates from single supplier lot (Shore D hardness 63±1). Construct assembly torque documented per surgical technique guide. Sample size meets FDA guidance minimum for F1717 validation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate clinical loading environment including physiologically relevant load magnitudes and boundary conditions per ASTM F1717.",
      "rationale": "Testing performed under ASTM F1717 standard conditions at room temperature in ambient air. Single test condition (5-degree offset compressive load) evaluated; no variation in offset angle or load rate explored. Achieved level below required due to single test condition — identified as gap in validation coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters match measured experimental parameters within documented tolerances; any discrepancies are quantified and their impact assessed.",
      "rationale": "Measured material properties and CMM geometry fed directly into FEA models. Crosshead displacement rate (5 mm/min) confirmed quasi-static; inertial effects negligible. Grip fixture geometry incorporated into model boundary conditions. Input parameter equivalency confirmed for all 11 construct instances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and absolute percentage difference <10% for all three QoIs across both laboratories.",
      "rationale": "E/uval metric computed for stiffness, yield force, and force at 40 mm displacement. All values below 1.96 threshold. Absolute percentage differences range 3.9%–7.3% across all QoIs and both laboratories, within the 10% acceptance bound. Comparison performed using FDA-recommended validation metric framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to clinical failure modes and regulatory acceptance criteria.",
      "rationale": "Construct stiffness relates to load sharing with bone graft and adjacent segment mechanics. Yield force and force at 40 mm displacement are standard ASTM F1717 acceptance metrics used in FDA submissions. QoIs are fully relevant to the COU decision regarding construct mechanical adequacy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities directly reproduce the COU geometry, loading, and boundary conditions; any differences between validation scenario and COU are documented.",
      "rationale": "Validation constructs use the same 7.5 mm non-cannulated screw geometry, rod diameter, and polyaxial head design as the COU. ASTM F1717 test configuration directly represents the intended compression-bending loading mode. Validation activities are highly relevant to the COU with the single noted gap in test condition breadth."
    }
