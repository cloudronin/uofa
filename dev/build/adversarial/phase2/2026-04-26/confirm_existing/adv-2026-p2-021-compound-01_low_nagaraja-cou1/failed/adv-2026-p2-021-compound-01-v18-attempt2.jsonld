    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <1% between successive refinements.",
      "rationale": "Three-level mesh convergence study performed on pedicle screw construct model. Stiffness QoI changed 2.1% (coarse to medium) and 0.6% (medium to fine). Fine mesh selected for all production runs. Richardson extrapolation applied; GCI = 0.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals monitored; force and displacement convergence criteria documented.",
      "rationale": "Newton-Raphson nonlinear solver used with force residual tolerance 1e-4 and displacement tolerance 1e-5. All load steps converged within 15 iterations. No divergence events recorded across 11 simulated constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow reviewed by independent analyst.",
      "rationale": "Simulation workflow documented in SOP-FEA-2021-003. Independent peer review conducted by FDA OSEL analyst not involved in original model development. Two minor discrepancies identified and corrected prior to final runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions documented and justified relative to COU physics.",
      "rationale": "Linear elastic titanium alloy (Ti-6Al-4V) material model applied; justified by pre-yield loading regime in ASTM F1717 protocol. UHMWPE block modeled as rigid constraint — sensitivity analysis confirmed <0.5% effect on stiffness QoI. Frictional contact (mu=0.2) between screw and rod."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to measurement data with documented uncertainty.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) sourced from lot-specific coupon testing (n=5 per lot). Geometry from CMM measurements of production screws. Cross-sectional dimensions within 0.02 mm of nominal. Input uncertainty propagated via Monte Carlo (1000 samples)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples representative of production geometry; sample size sufficient for statistical comparison.",
      "rationale": "N=11 constructs tested (Lab 1: n=6, Lab 2: n=5). All screws from same production lot as CMM-characterized specimens. UHMWPE blocks from same supplier lot. Sample size sufficient for mean comparison at 80% power per pre-specified power analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range of loading rates and environmental conditions.",
      "rationale": "Testing performed at single loading rate (5 mm/min) per ASTM F1717. Wet saline environment not employed — dry testing only. Single test condition limits generalizability. Achieved level below required; noted as gap in overall credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters match experimental conditions within documented tolerances.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 fixture geometry. Applied displacement rate equivalent to 5 mm/min quasi-static assumption. Screw geometry in FEA matched to CMM measurements within 0.02 mm. Rod diameter and material matched to test lot specifications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric applied; E/uval < 1.96 for all QoIs.",
      "rationale": "E/uval computed for stiffness, yield force, and force at 40 mm across both laboratories. Maximum E/uval = 1.43 (yield force, Lab 2). All QoIs within 10% difference bound. Acceptance criteria met for all five validation comparisons."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly relevant to clinical failure modes and regulatory decision.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly relevant to construct fatigue and fracture risk. All three QoIs map to clinical failure modes identified in MDR literature review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
