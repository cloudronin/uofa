      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate all five target flow-speed combinations under physiological blood viscosity and temperature conditions with full uncertainty characterisation of experimental inputs.",
      "rationale": "Experiments covered three of five operating points and used bovine blood as a surrogate; temperature control uncertainty was not fully characterised. Achieved level 3 is below the required level 5 for a Class III device at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., ASME V&V 20 validation metric) must demonstrate model predictions within combined experimental and numerical uncertainty bands at all five operating points.",
      "rationale": "Formal ASME V&V 20 validation metric was not applied; comparison relied on visual overlay of mean predictions against experimental mean values without uncertainty band overlap analysis. Achieved level 2 is substantially below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
