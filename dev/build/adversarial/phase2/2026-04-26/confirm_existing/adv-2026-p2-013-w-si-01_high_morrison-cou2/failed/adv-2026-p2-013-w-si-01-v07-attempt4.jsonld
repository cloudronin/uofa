  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl5-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen ASME V&V 40 credibility factors have been evaluated against Model Risk Level 5 requirements. Seven factors were formally assessed; all seven returned achieved levels below required levels. Six factors were identified as epistemic gaps and flagged as not-assessed. Monte Carlo uncertainty quantification was completed but input distributions lacked sufficient empirical grounding. The overall credibility evidence package does not meet the required credibility threshold for a Class III VAD device. The decision record is accepted as a complete and accurate representation of the credibility assessment findings, even though the regulatory submission outcome is rejection pending remediation.",
