      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions must confirm solver convergence rates for all governing equations relevant to hemolysis prediction.",
      "rationale": "Code verification was performed only for the base Navier-Stokes solver; the power-law hemolysis transport equation was not subjected to manufactured-solution testing. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes must bound discretization error to within 5% of the hemolysis index QOI.",
      "rationale": "Three-mesh Richardson extrapolation was completed; however, near-impeller boundary layer refinement remained insufficient and extrapolated error exceeded the 5% threshold at two operating points. Achieved level 3 does not meet required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
