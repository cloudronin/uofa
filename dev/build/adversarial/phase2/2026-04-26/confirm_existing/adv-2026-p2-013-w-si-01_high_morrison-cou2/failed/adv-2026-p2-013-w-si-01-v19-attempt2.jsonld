      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification including method of manufactured solutions or equivalent must demonstrate solver correctness for governing equations relevant to hemolysis prediction.",
      "rationale": "Only basic benchmark comparisons (lid-driven cavity, pipe flow) have been completed. Method of manufactured solutions has not been applied to the hemolysis transport equations. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent Richardson extrapolation must be reported for all quantities of interest at all 5 operating points, with discretization error below 5% of the hemolysis index.",
      "rationale": "GCI study performed at 3 of 5 operating points. Discretization error exceeds 8% at high-speed low-flow conditions. Achieved level 3 does not meet required level 4 for absolute hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating environment including blood analog fluid properties, pump geometry tolerances, and physiological pressure-flow boundary conditions.",
      "rationale": "Experiments used glycerol-water blood analog rather than porcine blood. Pump geometry tolerances were not characterized. Boundary conditions approximate but do not replicate in-vivo VAD loading. Significant gap between achieved level 3 and required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between model predictions and experimental hemolysis index measurements must include uncertainty bands and demonstrate agreement within clinical acceptance thresholds across all 5 operating points.",
      "rationale": "Hemolysis index predictions agree within 20-35% of experimental measurements. Uncertainty bands overlap at 3 of 5 points but not at extreme operating conditions. Achieved level 3 is insufficient for absolute threshold determination at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
