  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite 6 of 13 credibility factors remaining unassessed and all 7 assessed factors falling below required levels for MRL 5, the submission is accepted under the Minimal profile with the understanding that the documented gaps constitute an explicit risk register. The Monte Carlo UQ framework is in place and the validation dataset is the FDA-recognized reference geometry. Conditional acceptance requires gap closure prior to regulatory submission.",
