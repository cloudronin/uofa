  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and quality management consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has documented version control and unit tests, but lacks a formal quality management system and independent regression test suite required at MRL 5. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing using manufactured solutions must confirm solver convergence properties for the turbulence and hemolysis transport equations employed.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis transport scalar equation. Partial verification is insufficient at MRL 5; achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must quantify discretization error in hemolysis index predictions; grid convergence index must be reported for all 5 operating points.",
      "rationale": "Grid convergence index was computed for 3 of 5 operating points using three mesh levels. The two high-flow operating points were omitted due to computational cost. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including blood analog fluid properties, rotational speed range, and flow rate range with documented uncertainty.",
      "rationale": "Bench experiments used a glycerol-water blood analog at matched viscosity but did not replicate non-Newtonian shear-thinning behavior of whole blood. Temperature control was documented but hematocrit variation was not. Achieved level 3 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric U_val) must be computed for hemolysis index at all operating points with propagated experimental and numerical uncertainties.",
      "rationale": "Hemolysis index predictions were compared against experimental measurements at 3 of 5 operating points. Validation metric was computed but experimental uncertainty bounds were estimated rather than directly measured. Achieved level 3 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly linked to the clinical endpoint of plasma-free hemoglobin elevation and the absolute clinical threshold.",
      "rationale": "NIH is the accepted surrogate for in-vivo hemolysis and is directly compared against the absolute clinical threshold. However, the mapping from NIH to plasma-free hemoglobin in a chronic implant setting introduces unquantified extrapolation uncertainty. Achieved level 4 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry under conditions spanning the full VAD operating envelope defined in the COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is representative but not identical to the target VAD device. Operating conditions covered 3 of 5 COU flow-speed combinations. Achieved level 3 against required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and solver-specific errors must be quantified and shown to be negligible relative to discretization error for hemolysis predictions.",
      "rationale": "Iterative convergence was monitored via residuals but no formal quantification of numerical solver error contribution to hemolysis index uncertainty was performed. This factor was flagged as an epistemic gap at MRL 5 and not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented review process must confirm that simulation setup, boundary condition specification, and post-processing procedures are free from user-introduced errors.",
      "rationale": "No independent review of simulation setup or post-processing scripts was conducted. Use error assessment was identified as an epistemic gap at MRL 5 and was not formally addressed in this assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence closure model and hemolysis damage accumulation model must be justified through sensitivity analysis demonstrating model-form uncertainty is bounded relative to the clinical acceptance threshold.",
      "rationale": "The SST k-omega turbulence model and power-law hemolysis model were selected based on literature precedent. No model-form sensitivity analysis comparing alternative closures was performed. This factor represents the largest epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All material properties, boundary conditions, and hemolysis model coefficients must have documented sources with uncertainty characterization; Monte Carlo propagation must cover all identified uncertain inputs.",
      "rationale": "Monte Carlo UQ was performed over rotational speed and flow rate boundary conditions. However, hemolysis model coefficients (alpha, beta, C) were treated as fixed nominal values without uncertainty characterization, representing an incomplete input uncertainty treatment at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be characterized for lot-to-lot variability in blood analog properties; sufficient replicates must be run to establish statistical confidence in measured hemolysis values.",
      "rationale": "A single batch of glycerol-water blood analog was used for all experiments. No lot-to-lot variability characterization or statistical power analysis for replicate count was performed. Test sample assessment was flagged as an epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensionless parameters governing hemolysis (Reynolds number, exposure time, shear stress distribution) must be matched between validation experiments and the COU operating conditions.",
      "rationale": "Dimensional operating conditions were matched but formal equivalency of dimensionless hemolysis-governing parameters between bench experiments and the COU VAD operating envelope was not demonstrated. This factor was not assessed."
    }
  ],
