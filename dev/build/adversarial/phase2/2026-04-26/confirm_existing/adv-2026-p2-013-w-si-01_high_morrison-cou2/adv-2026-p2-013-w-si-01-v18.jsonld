      "acceptanceCriteria": "Independent simulation execution by a second analyst using the same model setup files, with documented comparison of results.",
      "rationale": "No independent re-execution was performed. Single analyst ran all five operating point simulations. Use error assessment not initiated. Flagged as epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis damage model form must be justified with sensitivity analysis against alternative model forms at MRL 5.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis model selected without comparative sensitivity against alternative formulations (e.g., Zhang model, realizable k-epsilon). Model form uncertainty not quantified. Flagged as epistemic gap. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources, uncertainty distributions, and sensitivity rankings. Monte Carlo input distributions must be validated against patient population data.",
      "rationale": "Monte Carlo UQ performed with assumed uniform distributions on viscosity and inlet velocity. Distributions not validated against clinical population data. Geometric tolerance inputs not included. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must include sufficient replicates to characterize biological and measurement variability; minimum n=5 per operating condition.",
      "rationale": "Published FDA pump dataset used; original experimental replication statistics not available in sufficient detail for MRL 5 requirements. Sample size per condition not confirmed to meet n=5 threshold. Flagged as epistemic gap. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions applied in the simulation must be demonstrated to be equivalent to those measured during validation experiments, including inlet velocity profiles and outlet pressure conditions.",
      "rationale": "Inlet boundary conditions derived from bulk flow rate measurements; spatial velocity profile not measured in validation experiment. Outlet pressure boundary equivalency not formally established. Flagged as epistemic gap. Achieved level 1 against required level 4."
