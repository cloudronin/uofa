  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction at MRL 5 is formally recorded. Seven of thirteen factors were assessed; all seven achieved levels below required levels. Six factors remain not-assessed, representing material epistemic gaps. The package is accepted into the evidence record for regulatory submission purposes with the explicit notation that all credibility gaps must be resolved prior to device clearance. Monte Carlo UQ provides partial uncertainty characterization but does not compensate for unassessed model form and use error factors.",
