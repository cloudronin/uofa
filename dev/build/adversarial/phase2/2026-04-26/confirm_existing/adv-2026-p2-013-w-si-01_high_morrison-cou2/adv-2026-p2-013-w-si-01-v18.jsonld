      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy studies using manufactured solutions required for all governing equations active in the hemolysis simulation.",
      "rationale": "Vendor-supplied benchmark cases cover basic Navier-Stokes but no manufactured solution study was performed for the power-law hemolysis damage integral. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence index study on hemolysis index QoI with at least three systematically refined meshes.",
      "rationale": "A two-mesh sensitivity study was performed showing less than 8% variation in hemolysis index, but formal GCI with three meshes was not completed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five VAD operating points including blood analogue fluid properties, rotational speed tolerances, and inlet flow waveform.",
      "rationale": "Four of five operating points were replicated with glycerol-water analogue; fifth high-speed point was extrapolated. Fluid temperature and hematocrit variability not fully characterized. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation metric u_val) must be defined and computed with uncertainty bounds for each operating condition.",
      "rationale": "Relative error metrics computed for four conditions; uncertainty bounds derived from Monte Carlo propagation. Metric not formally defined per ASME V&V 20 for condition 5. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, wall shear stress, residence time) must directly correspond to the clinical decision threshold for absolute hemolysis acceptance.",
      "rationale": "Hemolysis index is the primary QoI and directly maps to clinical threshold. However, sub-lethal platelet activation and aggregation indices are not validated. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the actual device geometry under patient-representative pulsatile flow conditions, not simplified steady-state bench surrogates.",
      "rationale": "Validation performed on the FDA generic pump geometry under steady-state conditions. Patient pulsatile flow waveform not represented. Geometry simplification removes volute features present in clinical device. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
