  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for Class III VAD hemolysis prediction at MRL 5 must demonstrate formal version control, regression testing, and documented release procedures consistent with Gradation 4 SQA practices.",
      "rationale": "The CFD solver (ANSYS Fluent 2021R2) has documented release notes and internal QA procedures, but the user-defined hemolysis scalar transport subroutines lack independent code review and regression test suites. Achieved level 2 reflects basic version tracking only; required level 4 is not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or equivalent analytical benchmark must confirm solver implementation of the hemolysis power-law transport equation to within expected order of accuracy for MRL 5.",
      "rationale": "Verification was limited to a simple pipe-flow manufactured solution for the scalar transport equation. The rotating impeller geometry and shear-dependent hemolysis source term were not independently verified against an analytical benchmark. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence index (GCI) analysis must demonstrate discretization error contribution to hemolysis index below 5% at all five operating points.",
      "rationale": "A three-level grid convergence study was performed using GCI methodology. At two of five operating points the GCI for hemolysis index exceeded 8%, indicating insufficient mesh refinement in the impeller blade-tip gap region. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation test conditions must span the full VAD operating envelope (flow rates 2–8 L/min, rotational speeds 2400–3600 RPM) with documented fluid temperature, hematocrit, and blood analog properties matching COU conditions.",
      "rationale": "Available experimental data covers only three of five target operating points and was collected using bovine blood at 37 °C with hematocrit 33%, whereas the COU specifies human blood at 37 °C with hematocrit 40–45%. Temperature and hematocrit deviations introduce unquantified bias. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must be compared to experimental measurements with formal uncertainty intervals on both simulation and experiment; agreement metric (e.g., E% with combined uncertainty) must be within 15% at all validated operating points.",
      "rationale": "Predicted hemolysis index deviates from experimental measurements by 22–41% across the three available operating points. Experimental measurement uncertainty was not formally propagated; comparison is qualitative. Achieved level 2 is significantly below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis, NIH) must be demonstrated to be the clinically relevant metric for the intended regulatory decision, with documented mapping to patient hemolysis thresholds.",
      "rationale": "NIH is used as the primary QoI; however, the mapping between NIH and clinical plasma free hemoglobin thresholds is based on a single literature source with limited patient data. The regulatory relevance is acknowledged but not rigorously established for the specific VAD population. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties sufficiently close to the COU device and patient population to support extrapolation of validation conclusions to the VAD clinical context.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump, which shares gross geometric similarity with the target VAD but differs in impeller clearance, volute geometry, and surface finish. These geometric differences are known to influence shear history and hemolysis. Achieved level 2 reflects limited geometric fidelity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver settings (relaxation factors, convergence tolerances) must be documented and shown to have negligible influence on hemolysis QoI at MRL 5.",
      "rationale": "Numerical solver error was not formally assessed. Residual convergence plots were provided but no sensitivity study on solver tolerances or relaxation factors was performed for the hemolysis scalar transport equation. Flagged as epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review process must confirm that simulation setup, boundary condition specification, and post-processing scripts were independently checked by a second analyst for the VAD operating conditions.",
      "rationale": "No independent review of simulation setup or post-processing was performed. A single analyst configured all five operating-point simulations without peer verification. Use error contribution to prediction uncertainty is unquantified. Flagged as epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The power-law hemolysis model (Giersiepen-Wurzinger or equivalent) must be assessed for applicability to the shear stress and exposure time ranges encountered in the VAD impeller, with documented model-form uncertainty bounds.",
      "rationale": "Model form uncertainty for the hemolysis power-law constitutive equation was not assessed. The Giersiepen-Wurzinger coefficients were applied without validation against sub-lethal shear exposure data relevant to VAD impeller shear histories. This represents a major epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity and uncertainty analysis of model input parameters (viscosity, density, power-law coefficients, inlet velocity profile) must be performed with Monte Carlo or equivalent method, and total input uncertainty contribution to NIH must be reported.",
      "rationale": "Although Monte Carlo UQ was nominally performed, the power-law hemolysis coefficients were treated as fixed point estimates rather than uncertain inputs. Fluid property uncertainty was also excluded. The UQ scope is insufficient for MRL 5. Achieved level 1; flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental blood samples used for hemolysis validation must be characterized for hematocrit, age, donor variability, and storage conditions, with documented inter-sample variability propagated into validation uncertainty.",
      "rationale": "Sample characterization data were not available for the validation experiments. Donor variability, blood age, and storage protocol are undocumented in the cited experimental dataset. Inter-sample variability is therefore unquantified and cannot be included in the validation uncertainty budget. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions applied in the CFD model (inlet flow waveform, outlet pressure, rotational speed) must be demonstrated to match the experimental test conditions within documented tolerances, and any discrepancies must be propagated as input uncertainty.",
      "rationale": "Equivalency of input parameters between the CFD model and the experimental validation setup was not formally assessed. Rotational speed was matched nominally but inlet flow profile, outlet back-pressure, and thermal boundary conditions were assumed equivalent without measurement evidence. Achieved level 1; flagged as epistemic gap at MRL 5."
    }
  ],
