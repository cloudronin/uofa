  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis, Class III, MRL 5) was reviewed by the assessment team. Seven of thirteen credibility factors were formally assessed; all seven achieved levels fall below required levels. Six factors were flagged as not-assessed epistemic gaps. Despite these shortfalls, the package is accepted for submission to the regulatory dossier as a documented gap analysis, with the explicit understanding that the model is NOT accepted for regulatory decision-making until all credibility gaps are resolved. The acceptance here refers to acceptance of the gap-analysis package itself into the evidence record, not acceptance of the underlying model predictions.",
