  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan with version control, regression testing, and documented release procedures must be in place for the CFD solver and all post-processing scripts at MRL 5.",
      "rationale": "Version control is present but regression test coverage is limited to canonical benchmarks; hemolysis-specific regression suite is absent. SQA documentation does not extend to user-defined hemolysis damage model subroutines. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent must demonstrate solver correctness for rotating-frame Navier-Stokes and scalar transport at expected Reynolds numbers.",
      "rationale": "Code verification was performed against lid-driven cavity and Taylor-Couette benchmarks only. No manufactured solution verification exists for the rotating-frame formulation or the power-law hemolysis scalar transport equation used in COU2. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence index must be reported for hemolysis index QoI on at least three systematically refined meshes at each operating point.",
      "rationale": "Grid convergence study performed at three refinement levels; GCI reported for pressure rise and flow uniformity but not directly for hemolysis index. Discretization error on the primary QoI remains partially quantified. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, temperature, hematocrit, pump speed, flow rate) must be documented with uncertainty bounds and matched to CFD boundary conditions within stated tolerances.",
      "rationale": "Test fluid was bovine blood at room temperature; hematocrit variability across experiments was ±4% and not propagated into CFD boundary conditions. Temperature drift during long-duration runs was not reported. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error, validation uncertainty) must be computed for hemolysis index across all 5 operating points with statistical confidence bounds.",
      "rationale": "Comparison is presented graphically; no formal validation metric with uncertainty bounds is computed. Scatter in experimental hemolysis measurements spans nearly the same order of magnitude as model predictions at two operating points, obscuring model accuracy. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (hemolysis index) must be identical to or directly translatable to the clinical decision QoI (absolute hemolysis below clinical threshold) without intermediate transformations that introduce unquantified uncertainty.",
      "rationale": "The normalized index of hemolysis (NIH) computed in CFD is the same metric used for clinical comparison, supporting relevance. However, the conversion from CFD-predicted scalar damage to NIH involves an empirical constant calibrated on a different pump geometry. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry, at operating conditions spanning the full VAD envelope, using blood or a validated blood analog with documented rheological equivalence.",
      "rationale": "Validation used the FDA generic pump geometry which differs from the target VAD impeller curvature and tip clearance. Operating conditions cover 3 of 5 required flow-speed combinations. Blood analog (glycerol-water) rheological equivalence to bovine blood at shear rates above 5000 s⁻¹ is not established. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and round-off error bounds must be documented; residual history for hemolysis scalar transport equation must demonstrate convergence to below 1e-5.",
      "rationale": "Solver residual convergence for the hemolysis scalar transport equation was not reported. Only global continuity and momentum residuals are documented. This factor is flagged as an epistemic gap at MRL 5 and was not assessed. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence of independent simulation replication or peer review of simulation setup, boundary condition assignment, and post-processing scripts must be documented.",
      "rationale": "No independent replication of the simulation setup was performed. Post-processing scripts for hemolysis index integration were not peer reviewed. Use error is a known epistemic gap at MRL 5 for this assessment. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The power-law hemolysis damage model must be justified for the shear stress and exposure time ranges present in the VAD; alternative model forms must be evaluated and the selected form must be shown to be the best available for MRL 5 use.",
      "rationale": "The Giersiepen-Wurzinger power-law model is used without justification of its applicability at the high shear rates (>10,000 s⁻¹) present near the VAD impeller tip. No alternative model form evaluation was conducted. This is the dominant epistemic gap at MRL 5. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty quantification must be performed for all model inputs (viscosity, density, damage model exponents, inlet velocity profile) using Monte Carlo or equivalent; results must be reported as prediction intervals on hemolysis index.",
      "rationale": "Monte Carlo UQ was initiated but results were not converged at the time of assessment (fewer than 200 samples completed of a planned 2000-sample analysis). Damage model exponent uncertainty, which dominates hemolysis index variability, was not included in the UQ parameter set. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to establish statistical confidence intervals on hemolysis measurements; minimum n=5 independent replicates per operating point with documented inter-sample variability.",
      "rationale": "Sample size documentation is unavailable for the validation dataset; the published dataset reports mean values only without indicating the number of independent experimental replicates. This factor could not be assessed and is flagged as an epistemic gap. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "CFD boundary conditions must be demonstrated equivalent to experimental conditions through documented mapping with quantified tolerances; any deviations must be assessed for impact on hemolysis index predictions.",
      "rationale": "No formal equivalency mapping between experimental and CFD input parameters was documented. Inlet velocity profiles were prescribed as uniform rather than measured profiles; pump speed was matched nominally but tachometer calibration uncertainty was not propagated. Achieved level 1 against required level 4."
    }
