  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under formal configuration control with documented V&V test suite and traceable version history consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is under version control and has a documented test suite, but formal configuration management procedures do not meet the rigor required at MRL 5. Independent code audit has not been performed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification (method of manufactured solutions or equivalent) must be demonstrated for all governing equations active in the hemolysis simulation at MRL 5.",
      "rationale": "Order-of-accuracy testing was performed on simplified canonical flows but not on the full rotating-frame hemolysis solver configuration. MMS verification for the scalar hemolysis transport equation is absent. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent formal grid-convergence study must be completed on the hemolysis index QoI across at least three systematically refined meshes at each operating condition.",
      "rationale": "A three-level grid convergence study was completed at two of five operating conditions. Remaining three conditions show monotonic convergence but formal GCI estimation is incomplete. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must replicate VAD operating envelope (flow rate, rotational speed, blood analog viscosity, hematocrit) within defined tolerance bands at all five COU operating points.",
      "rationale": "Experimental validation data were collected at three of five COU operating points using porcine blood analog. Hematocrit was controlled within tolerance, but rotational speed at the highest-flow condition deviated beyond the specified tolerance band. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or NRMSE) for hemolysis index predictions versus experimental measurements must satisfy acceptance threshold at all five operating points, with uncertainty intervals overlapping.",
      "rationale": "Relative error in predicted hemolysis index ranges from 18% to 47% across assessed operating conditions, exceeding the 15% acceptance threshold at four of five points. Prediction intervals from Monte Carlo UQ do not overlap experimental uncertainty bands at highest-shear condition. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress exposure time) must be directly traceable to the clinical decision QoIs specified in the COU, with documented mapping and no surrogate substitution.",
      "rationale": "The normalized index of hemolysis (NIH) is used as primary QoI in both simulation and bench testing, providing direct relevance. However, the sub-lethal damage accumulation metric used in the model is not directly measured experimentally and relies on a surrogate power-law correlation. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the same device geometry, blood analog properties, and operating envelope as the COU. Any differences must be formally justified and their impact on credibility quantified.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump geometry, which is the same device class but not the specific patient-implanted configuration. Geometric fidelity differences in the volute region are documented but their impact on hemolysis prediction has not been quantified. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence errors, floating-point round-off contributions, and solver residual tolerances must be formally characterized and shown to be negligible relative to the hemolysis QoI at MRL 5.",
      "rationale": "Solver residuals are monitored and reported but no formal analysis of iterative convergence error contribution to hemolysis index uncertainty has been performed. This factor is flagged as an epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for analyst-introduced errors in model setup, boundary condition specification, and post-processing must be formally evaluated through independent review or blind re-analysis at MRL 5.",
      "rationale": "No independent re-analysis or formal use-error assessment has been conducted. Simulation setup was performed by a single analyst team without external review of boundary condition choices. Flagged as epistemic gap. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence model, hemolysis constitutive law (power-law exponent selection), and non-Newtonian blood rheology model must be formally justified through sensitivity analysis and comparison to higher-fidelity reference solutions.",
      "rationale": "Model form uncertainty is the dominant unresolved epistemic gap. The power-law hemolysis model exponents span a wide literature range; no formal sensitivity study across plausible model forms has been completed. Turbulence model selection (SST k-omega) has not been benchmarked against LES for this geometry. Flagged as critical epistemic gap at MRL 5. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (viscosity, density, power-law coefficients, inlet velocity profile) must be characterized with probability distributions and propagated through Monte Carlo UQ to quantify their contribution to hemolysis index uncertainty.",
      "rationale": "Monte Carlo UQ was performed on five primary input parameters. However, the power-law hemolysis model coefficients were treated as fixed rather than uncertain despite documented inter-study variability. Inlet turbulence intensity distribution was assumed uniform without experimental justification. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability in blood sample hemolytic susceptibility must be characterized across a sufficient number of donors to support statistical inference on hemolysis predictions at MRL 5.",
      "rationale": "All experimental validation data were collected using a single pooled porcine blood preparation. Inter-donor and inter-species variability in hemolytic susceptibility has not been characterized. This represents a significant epistemic gap for Class III device assessment. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation input parameters and experimentally measured boundary conditions must be formally demonstrated, including inlet flow profiles, rotational speed accuracy, and fluid property traceability.",
      "rationale": "Inlet velocity profiles used in simulation are derived from idealized fully-developed assumptions rather than measured profiles. No formal equivalency analysis between CFD boundary conditions and experimental setup has been performed. Flagged as epistemic gap. Achieved level 1 against required level 4."
    }
  ],
