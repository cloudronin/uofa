    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) reported with uncertainty bands for all 5 flow-speed operating points; systematic bias characterised.",
      "rationale": "Qualitative agreement plots were provided for 3 of 5 operating points. No quantitative error metric with uncertainty bands was reported. Systematic over-prediction of hemolysis at high shear rates was noted but not formally characterised. Achieved level 2."
    },
