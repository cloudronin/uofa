      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and audit trail consistent with MRL 5 requirements.",
      "rationale": "Solver version control and regression test suite are partially documented; no independent audit of SQA procedures was performed. Achieved level 2 falls short of required level 4 for Class III device at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification must confirm spatial and temporal discretization schemes behave as expected.",
      "rationale": "Order-of-accuracy verification was performed on canonical pipe flow only; rotating impeller geometry was not included in verification suite. Achieved level 2 insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must bound discretization error on hemolysis index QoI to within 10% at all 5 operating points.",
      "rationale": "Three-level mesh refinement study conducted; GCI computed for pressure head but not for hemolysis index directly. Discretization error on primary QoI remains partially bounded, yielding achieved level 3 vs required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit, temperature, and shear exposure duration matching clinical use.",
      "rationale": "FDA pump experiments used bovine blood at controlled hematocrit; temperature variation across VAD operating range not fully replicated. Achieved level 3 against required 5 represents a significant gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must be computed with uncertainty bounds for hemolysis index at all 5 operating points.",
      "rationale": "Validation metric computed at 3 of 5 operating points; 2 high-speed operating points lacked experimental hemolysis measurements. Achieved level 3 vs required 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress exposure) must directly correspond to clinical acceptance criterion without surrogate substitution.",
      "rationale": "Hemolysis index is directly compared; however, the power-law damage accumulation model introduces a surrogate representation of sub-lethal cumulative shear not independently validated. Achieved level 4 vs required 5."
    },
