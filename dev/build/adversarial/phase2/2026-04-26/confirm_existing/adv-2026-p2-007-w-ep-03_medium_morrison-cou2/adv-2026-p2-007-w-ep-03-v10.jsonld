  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison — 5 flow-speed operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements across 5 operating conditions. Mean absolute error 18.3%; Monte Carlo 95th-percentile bound does not exceed clinical threshold at 4 of 5 points. One outlier at high-speed low-flow condition exceeds threshold bound by 6%. Validation activities conducted against PIV and hemolysis bench data collected prior to the February 2026 model revision; re-validation against post-revision datasets is planned for Q2 2026."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-pressure-flow-curve",
      "type": "ValidationResult",
      "name": "Pressure-flow curve validation — centrifugal pump operating range",
      "description": "Predicted head-flow curves at 3 rotational speeds compared to bench measurements. R-squared values range from 0.91 to 0.96. Mesh sensitivity study confirms GCI below 4% for pressure quantities. Dataset vintage is contemporaneous with the current model revision and does not introduce staleness concerns."
    }
  ],
