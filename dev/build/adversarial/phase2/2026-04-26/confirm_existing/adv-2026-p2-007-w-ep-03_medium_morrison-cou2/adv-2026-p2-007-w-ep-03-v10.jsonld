  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all activated physics modules; formal change-control procedure demonstrated.",
      "rationale": "Ansys Fluent 2024 R2 is under version control with a documented regression test suite. Change-control records are present but do not cover the hemolysis scalar transport module introduced in the current revision. Achieved Gradation 3; required Gradation 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks; manufactured-solution verification for hemolysis transport equation.",
      "rationale": "Order-of-accuracy confirmed for Navier-Stokes solver on lid-driven cavity and rotating-disk benchmarks. Manufactured-solution test for the hemolysis scalar transport sub-model is incomplete; observed order is 1.7 vs. formal order 2. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization uncertainty reported for hemolysis QoI on at least three systematically refined meshes; GCI below 5%.",
      "rationale": "Three-level mesh refinement study performed; GCI for NIH is 4.8% at the fine mesh (12.4 M cells), marginally within the 5% threshold. Spatial refinement was not repeated after the February 2026 geometry revision. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental operating conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented with measurement uncertainty and traceable to NIST-calibrated instruments.",
      "rationale": "Flow rate and rotational speed documented with NIST-traceable calibration. Temperature and hematocrit recorded but uncertainty bounds not formally propagated into hemolysis measurements. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms, MAPE) reported for all QoIs with uncertainty bands; statistical hypothesis test or validation metric threshold applied.",
      "rationale": "MAPE of 18.3% reported for NIH across 5 operating points. Uncertainty bands from Monte Carlo propagation are overlaid on experimental data. No formal hypothesis test applied; threshold criterion is qualitative ('within engineering judgment'). Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly correspond to the clinical acceptance criterion (absolute NIH); no surrogate QoIs substituted without justification.",
      "rationale": "NIH is the primary clinical QoI and is directly compared. Wall shear stress is used as a secondary diagnostic but is not substituted for NIH in the acceptance decision. Achieved Gradation 3; full traceability matrix to clinical threshold not yet formalized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry and fluid at COU operating conditions; any extrapolation to COU conditions justified with sensitivity analysis.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry at 4 of 5 COU operating points. The fifth point (high-speed, low-flow) was extrapolated from adjacent conditions; sensitivity analysis performed but confidence interval widens substantially. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance ≤1e-6 for all equations; round-off error assessed for double-precision arithmetic.",
      "rationale": "Continuity residual converges to 1e-5; momentum and scalar transport converge to 1e-6. Double-precision confirmed. Continuity residual plateau above required tolerance is an unresolved gap. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second qualified analyst; documented checklist covering boundary conditions, material properties, and solver settings.",
      "rationale": "Simulation setup reviewed by lead analyst only; no independent second-reviewer sign-off recorded. Boundary condition checklist exists but was last updated prior to the February 2026 model revision. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified with literature evidence; sensitivity to model-form assumptions quantified.",
      "rationale": "SST k-omega selected based on rotating-machinery literature. Giersiepen-Wurzinger hemolysis power-law model used; sensitivity to exponent values assessed via ±10% perturbation. No alternative hemolysis model (e.g., modified Power Law) evaluated. Model-form uncertainty contribution not formally separated from total uncertainty budget. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, material properties, boundary conditions) sourced from post-revision characterization data; input uncertainty quantified and propagated via Monte Carlo.",
      "rationale": "Blood viscosity and density values, impeller tip-clearance geometry, and inlet velocity profiles are drawn from the PIV and hemolysis calibration dataset collected in Q4 2025. The model was revised in February 2026 to update impeller tip-clearance dimensions and blood rheology constants, but the calibration dataset has not been refreshed to reflect these changes. Monte Carlo uncertainty propagation is performed using the pre-revision input distributions; re-calibration against post-revision measurements is described as planned for Q2 2026. This introduces potential systematic bias in input uncertainty bounds. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood analog or porcine blood samples characterized for hematocrit, viscosity, and age; lot-to-lot variability assessed across at least three independent preparations.",
      "rationale": "Porcine blood used; hematocrit and viscosity measured per lot. Two of three required independent preparations documented; third preparation records are incomplete. Lot-to-lot variability estimated from two lots only. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that validation experiment input parameters are representative of COU inputs; any discrepancies bounded by sensitivity analysis.",
      "rationale": "Validation uses porcine blood at 37°C and 40% hematocrit; COU specifies human blood at physiological conditions. Equivalency argument based on matched viscosity at operating shear rates. Sensitivity to hematocrit variation (35–45%) performed but does not cover the full clinical range. Formal equivalency matrix not completed. Achieved Gradation 2."
    }
  ],
