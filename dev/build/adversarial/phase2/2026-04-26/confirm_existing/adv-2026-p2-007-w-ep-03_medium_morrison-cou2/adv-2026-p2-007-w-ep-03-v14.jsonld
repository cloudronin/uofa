      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with automated regression testing covering hemolysis model routines; all deviations documented.",
      "rationale": "ANSYS Fluent 2023R2 is under institutional version control and regression tests cover primary flow routines. Hemolysis scalar transport subroutine lacks automated regression coverage; manual spot-checks performed only. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
