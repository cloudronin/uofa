      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis transport; convergence order confirmed.",
      "rationale": "MMS verification confirmed second-order convergence for Navier-Stokes equations. Hemolysis power-law transport equation verified via analytical benchmark only; MMS not applied. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes; GCI reported for hemolysis index QoI.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI for hemolysis index is 6.8%, exceeding the 5% target. Spatial discretization error is the dominant numerical uncertainty contributor. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, rotational speed) documented with uncertainty for all 5 operating points; traceability to calibration standards shown.",
      "rationale": "Flow rate and rotational speed are traceable to NIST standards. Outlet pressure boundary condition uncertainty is reported at ±3 mmHg but calibration certificate expired prior to final test runs. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or MAPE) computed for hemolysis index across all 5 operating points with combined experimental and simulation uncertainty bands.",
      "rationale": "Mean absolute percentage error for hemolysis index is 18.4% across 5 operating points. Combined uncertainty bands overlap at 3 of 5 points. Systematic over-prediction at high-speed conditions not fully explained. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs (hemolysis index, velocity field) are directly mapped to the COU decision QoI; no surrogate QoIs used without justification.",
      "rationale": "Hemolysis index is the primary COU QoI and is directly validated. Velocity field serves as a secondary QoI confirming flow structure. Shear stress distribution, which feeds the hemolysis model, is not independently validated. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the exact FDA generic centrifugal pump geometry at VAD operating conditions (flow 3–6 L/min, speed 2400–3600 RPM); blood analog fluid properties match COU.",
      "rationale": "Validation used the FDA generic pump geometry with glycerin-water blood analog at 37°C. Operating range covers 4 of 5 COU points; the highest-speed VAD condition (3600 RPM, 3 L/min) was not included in the experimental matrix. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual norms below 1e-6 for all equations; round-off error assessed for double precision arithmetic.",
      "rationale": "Residuals converge to 1e-5 for continuity and 1e-6 for momentum; hemolysis scalar residual stalls at 1e-4 due to stiff source terms at blade-tip regions. Double precision confirmed. Achieved level 3 against required level 4."
    },
