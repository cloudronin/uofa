  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a quality management system with documented version control, regression testing, and change control procedures consistent with MRL 5 requirements.",
      "rationale": "ANSYS Fluent 2024R2 is operated under an ISO 9001-registered QMS with version-controlled configuration. Regression test suite covers 87% of relevant solver modules. Change control documentation is complete for the current solver version. Achieved level 3 falls short of required level 4 because independent third-party audit of the QMS has not been completed within the current assessment cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver implementation must be verified against analytical solutions and established benchmark cases for rotating machinery hemolysis applications. Order-of-accuracy tests required.",
      "rationale": "Order-of-accuracy verification performed on Taylor-Couette and lid-driven cavity benchmarks confirms second-order spatial accuracy. Rotating frame Coriolis source term verified against analytical rotor benchmark. Hemolysis power-law source term verified against published Giersiepen model. Gap to required level 4: no formal verification report submitted to a recognized standards body."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent Richardson extrapolation must demonstrate discretization error below 5% on hemolysis index QoI across all 5 operating points.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 8.4M, 33.6M cells). GCI for NIH ranges from 3.1% to 6.8% across operating points; two high-shear operating points exceed the 5% threshold. Achieved level 3 reflects partial compliance. Required level 4 demands all operating points within threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with full uncertainty characterization including fluid temperature, hematocrit, flow rate, and rotational speed. Conditions must bracket the COU operating envelope.",
      "rationale": "Test conditions documented with traceable calibration records for flow meters and tachometers. Temperature controlled to 37±0.5°C. Hematocrit maintained at 33±2%. Five operating points bracket the VAD operating envelope. Gap: inlet turbulence intensity not independently measured; estimated from rig geometry, introducing unquantified uncertainty at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric u_val) must be computed with full experimental and simulation uncertainty propagation. Metric must demonstrate model adequacy at required confidence level.",
      "rationale": "Mean absolute percentage error of 18.3% computed across 5 operating points. Formal validation metric u_val computed per ASME V&V 20 framework. Experimental uncertainty from pre-revision dataset (dataVintage 2025-10-15) not re-characterized following 2026-02-01 model revision; systematic bias at high shear unresolved. Achieved level 2 reflects quantitative comparison without full bias decomposition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress exposure) must be directly mapped to the COU decision QoIs. Mapping must be documented with justification for any surrogate QoIs.",
      "rationale": "NIH is the primary COU QoI and is directly measured in validation experiments. Volume-averaged shear stress used as surrogate for localized hemolysis; mapping documented but sensitivity of hemolysis prediction to surrogate choice not fully quantified at required level 3 depth."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, operating conditions, and fluid properties representative of the COU. Differences between validation configuration and COU must be characterized and their impact on predictive accuracy bounded.",
      "rationale": "Validation performed on FDA generic pump geometry; COU device is a proprietary centrifugal VAD with modified impeller blade angle. Geometric similarity documented at 78% by surface area metric. Operating condition overlap covers 3 of 5 COU points. Impact of geometric differences on hemolysis prediction bounded by sensitivity study but not experimentally confirmed. Achieved level 2 reflects partial relevance with unquantified geometric extrapolation uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical diffusion must be characterized and their contribution to QoI uncertainty quantified.",
      "rationale": "Iterative convergence monitored via residual drop to 1e-5; mass imbalance below 0.01%. Round-off error and numerical diffusion contributions to NIH not formally decomposed. Factor flagged as not-assessed at required depth; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for analyst error in model setup, boundary condition specification, and post-processing must be assessed through independent review or formal checklist-based verification.",
      "rationale": "Model setup reviewed by lead analyst only; no independent peer review of boundary condition specification or post-processing scripts performed. Use error factor not formally assessed. Epistemic gap documented at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis constitutive model must be justified with sensitivity analysis demonstrating that model form uncertainty is bounded within acceptable limits for the COU QoI.",
      "rationale": "SST k-omega turbulence model selected based on rotating machinery literature precedent. Giersiepen-Wurzinger hemolysis power-law model applied. Sensitivity to turbulence model assessed by comparison with k-epsilon realizable: NIH difference of 12% at peak shear operating point. Model form uncertainty partially bounded but not reduced to required level 4 through additional experimental discrimination."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions derived from current experimental data. Input uncertainty must propagate through Monte Carlo analysis to bound QoI uncertainty at the 95th percentile.",
      "rationale": "Monte Carlo uncertainty quantification performed with 1000 samples across blood viscosity, hematocrit, inlet velocity, and rotational speed distributions. Input distributions for blood viscosity anchored to the experimental hemolysis dataset with dataVintage 2025-10-15, which predates the 2026-02-01 model revision incorporating updated impeller geometry tolerances. The revised geometry alters near-wall shear stress distributions, potentially invalidating viscosity sensitivity coefficients derived from the pre-revision dataset. Re-characterization of input distributions against post-revision geometry is planned but not yet completed. Achieved level 2 reflects Monte Carlo execution without current input validation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability in blood samples used for in-vitro validation must be characterized. Sample size must be sufficient to estimate population-level hemolysis response with stated confidence.",
      "rationale": "Validation experiments performed with porcine blood from a single donor pool per operating point. Inter-donor variability not characterized. Sample size analysis not performed. Factor not assessed at required level 3; epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment input parameters and COU model input parameters must be formally demonstrated, including fluid properties, geometric boundary conditions, and operating conditions.",
      "rationale": "Formal equivalency mapping between validation configuration and COU not completed. Differences in hematocrit (validation: 33%, COU target: 40%), fluid temperature protocol, and impeller clearance between FDA generic pump and proprietary VAD device not formally bounded. Factor not assessed; epistemic gap at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the Monte Carlo uncertainty quantification demonstrates that the 95th-percentile NIH prediction remains below the absolute clinical threshold of 0.8 mg/dL per 100 L across all five operating points. The assessment team accepts the model for the stated COU on the basis that the uncertainty bounds are conservative and the hemolysis margin is sufficient. Re-validation against post-revision experimental data, including updated input distributions derived from experiments conducted after the 2026-02-01 model revision, is planned for the next assessment cycle. Six credibility factors remain as epistemic gaps and are flagged for resolution prior to submission for regulatory review.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
