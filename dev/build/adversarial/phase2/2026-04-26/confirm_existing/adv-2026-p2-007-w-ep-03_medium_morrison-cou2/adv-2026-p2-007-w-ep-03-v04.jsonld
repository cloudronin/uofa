      "dataVintage": "2026-03-10T00:00:00Z",
      "source": "https://doi.org/10.1016/j.jbiomech.2026.blood-rheology"
    }
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-vad-val-001",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison at 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements at 5 flow-speed combinations. Mean absolute error 18.3% across operating envelope; systematic over-prediction at high shear rates attributed in part to model revision geometry updates not yet reflected in experimental dataset."
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-vad-val-002",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification sweep",
      "description": "1000-sample Monte Carlo propagation of input uncertainties (blood viscosity, pump clearance tolerances, inlet flow rate) through the hemolysis model. 95th-percentile NIH prediction remains below clinical threshold of 0.8 mg/dL per 100 L, providing the basis for the accepted decision despite epistemic gaps."
    }
