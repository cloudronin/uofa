  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Configuration-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; formal change-control log required at MRL 5.",
      "rationale": "ANSYS Fluent 2023R2 is under version control with automated regression testing. However, the change-control log does not formally document the January 2026 impeller geometry update, leaving a gap against the MRL 5 requirement for full traceability of model changes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks with formal convergence rate documentation.",
      "rationale": "Method-of-manufactured-solutions verification confirms second-order spatial accuracy for the momentum equations. Scalar transport verification for the hemolysis power-law source term achieves only first-order convergence; formal documentation of the discrepancy is pending."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined grids; GCI reported for hemolysis index and pressure rise at all 5 operating points.",
      "rationale": "Grid convergence study performed on three meshes (4 M, 12 M, 36 M cells). GCI for pressure rise is 1.8%; GCI for hemolysis index reaches 9.3% at the highest-shear operating point, exceeding the 5% target threshold for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, rotational speed) must match COU operating envelope within stated uncertainty bounds.",
      "rationale": "FDA bench-top experiments were conducted at 37 °C with bovine blood at 33% hematocrit. COU specifies human blood at 30–36% hematocrit; species-related rheological differences are acknowledged but a formal equivalency argument has not been provided."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms) between predicted and measured hemolysis index across all 5 operating points; must include uncertainty intervals on both simulation and experiment.",
      "rationale": "Predicted hemolysis index deviates from measured values by 18–42% across the 5 operating points. Experimental uncertainty intervals are not reported for three of the five points. The comparison does not meet the MRL 5 requirement for full uncertainty-interval coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that the validated QoIs (hemolysis index, pressure rise) are directly predictive of the clinical endpoint (chronic hemolysis) with documented sensitivity analysis.",
      "rationale": "Hemolysis index is the primary regulatory QoI and maps directly to the clinical endpoint. Pressure rise is a secondary QoI used for operating-point confirmation. Sensitivity of hemolysis index to blood viscosity inputs is documented but relies on the pre-revision rheological dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full COU operating envelope (5 flow-speed combinations) with documented extrapolation risk for any untested conditions.",
      "rationale": "Validation experiments cover 4 of the 5 COU operating points. The fifth point (highest flow rate, 6 L/min at 3000 rpm) falls outside the experimental dataset; extrapolation risk is noted but not formally quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented; iterative error estimated and shown to be negligible relative to discretization error.",
      "rationale": "Continuity residuals converge to 1e-5; momentum to 1e-6. Iterative error has not been formally separated from discretization error in the GCI analysis, leaving ambiguity in the total numerical error budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution checklist; peer review of boundary condition setup and turbulence model selection by an independent analyst.",
      "rationale": "An internal checklist is in place. Independent peer review of the boundary condition setup was performed by a team member rather than an external reviewer, which does not satisfy the independence requirement at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for turbulence model selection (SST k-omega) and hemolysis power-law model with sensitivity analysis across plausible alternative model forms.",
      "rationale": "SST k-omega is selected based on prior literature for centrifugal pump flows. The Giersiepen hemolysis power-law is used without comparison to the Heuser-Opitz or Zhang models. Model-form sensitivity analysis across alternative hemolysis models is identified as an epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and operating inputs characterised with uncertainty distributions; Monte Carlo propagation performed; input dataset validated against current model revision.",
      "rationale": "Monte Carlo uncertainty quantification is performed across 12 input parameters including blood viscosity, density, and impeller tip clearance. The rheological calibration dataset (dataVintage 2025-10-01) predates the January 2026 model revision that updated impeller geometry parameterisation. Re-validation of input parameters against the revised geometry is planned for Q2 2026 but has not been completed; the current inputs therefore reflect the prior model build."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Biological variability in blood rheology characterised across minimum three donor samples; lot-to-lot variation documented.",
      "rationale": "FDA experimental data used for validation was generated from a single bovine blood lot. Donor-to-donor and lot-to-lot variability in hemolytic susceptibility is not characterised, representing a gap against the MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that simulation input parameters (geometry, fluid properties, boundary conditions) match the physical test article and COU conditions within quantified tolerances.",
      "rationale": "Pump geometry is derived from FDA generic pump CAD files. As-manufactured tolerances on impeller tip clearance (±0.05 mm) are not reflected in the simulation geometry. Fluid property equivalency between bovine and human blood is asserted qualitatively without quantified rheological mapping."
    }
