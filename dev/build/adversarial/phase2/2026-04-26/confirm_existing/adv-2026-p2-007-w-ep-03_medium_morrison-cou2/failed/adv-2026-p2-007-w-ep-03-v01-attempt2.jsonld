      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional and non-dimensional equivalency between validation experiment and COU must be demonstrated for all governing parameters including Reynolds number, Womersley number, and exposure time.",
      "rationale": "Reynolds number equivalency demonstrated at design point only. Womersley number and shear-exposure time equivalency not assessed. Flagged as epistemic gap at MRL 5."
