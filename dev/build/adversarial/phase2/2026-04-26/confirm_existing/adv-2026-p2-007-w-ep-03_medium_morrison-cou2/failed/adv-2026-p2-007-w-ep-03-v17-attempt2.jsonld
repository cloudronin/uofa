  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented regression test suite covering hemolysis-relevant flow regimes; all solver changes logged against model revision history.",
      "rationale": "Solver is under version control and regression tests exist for canonical benchmark cases. However, the regression suite does not include hemolysis-specific test cases and the January 2026 model revision was not accompanied by a full re-qualification run, leaving a gap at MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all transport equations relevant to hemolysis prediction, including scalar stress transport, demonstrated on manufactured solutions.",
      "rationale": "Order-of-accuracy tests performed for momentum and pressure equations. Scalar hemolysis transport equation verified to first order only; second-order verification not completed, leaving achieved level below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on at least three systematically refined meshes at each operating point.",
      "rationale": "GCI study performed on three mesh levels at two of five operating points. Remaining three operating points show GCI values between 8–12%, exceeding the 5% threshold. Mesh refinement study predates the January 2026 geometry revision and has not been repeated on the updated mesh."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) must match CFD boundary conditions within stated uncertainty bounds at all five operating points.",
      "rationale": "Inlet velocity profiles and fluid temperature are well-matched. Hematocrit was controlled to 33±2% in experiments versus 33% nominal in CFD; minor mismatch at two operating points falls outside stated uncertainty bounds for hemolysis sensitivity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E_rel) for MIH must be below 20% at all five operating points with uncertainty intervals reported.",
      "rationale": "E_rel below 20% at three of five operating points. At high-flow low-speed condition, E_rel reaches 31%. Uncertainty intervals reported via Monte Carlo but do not fully encompass experimental values at the outlier condition."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (MIH, velocity profiles) must be directly traceable to the clinical hemolysis acceptance criterion; mapping from computational QoI to clinical threshold must be documented.",
      "rationale": "MIH is the primary clinical QoI and is directly predicted. Velocity profiles are surrogate QoIs; their relevance to absolute hemolysis threshold is documented qualitatively but the quantitative link to the clinical criterion is not formally established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid properties, and operating envelope must match the COU device and conditions; any differences must be assessed for impact on prediction credibility.",
      "rationale": "Validation performed on the FDA generic pump geometry, which is representative but not identical to the target VAD device. Geometric similarity ratio documented; fluid properties matched. Impact of geometry differences on hemolysis prediction assessed qualitatively only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error must be quantified and shown to be negligible relative to discretization error for hemolysis QoI at all operating points.",
      "rationale": "Residual convergence monitored but iterative error not formally separated from discretization error. No Richardson extrapolation performed to isolate solver error contribution. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and independent simulation review for all analysts contributing to COU2 predictions.",
      "rationale": "User qualification records exist for lead analyst. Independent review of simulation setup not performed for COU2 operating points. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage accumulation model form uncertainty must be quantified; alternative model forms evaluated or sensitivity demonstrated.",
      "rationale": "SST k-omega turbulence model selected without systematic comparison to alternative formulations. Power-law hemolysis model used without evaluation of alternative damage models. Model form uncertainty not quantified. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters with sensitivity to hemolysis QoI must be characterized with probability distributions; Monte Carlo propagation must demonstrate convergence.",
      "rationale": "Monte Carlo UQ performed on five input parameters (viscosity, inlet velocity, rotational speed, hemolysis model coefficients C and alpha). Geometric tolerance inputs not included in UQ despite the January 2026 geometry revision introducing new tolerance ranges. Input characterization therefore incomplete relative to current model build. Flagged as epistemic gap.",
      "note": "The primary validation datasets (dataVintage 2025-09-15 and 2025-11-20) predate the modelRevisionDate of 2026-01-10. Re-validation of model inputs against the revised geometry is planned but has not been executed."
    },
