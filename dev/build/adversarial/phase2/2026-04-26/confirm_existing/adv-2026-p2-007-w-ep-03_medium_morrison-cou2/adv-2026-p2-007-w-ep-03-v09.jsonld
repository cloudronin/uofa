  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must operate under a documented SQA plan including version control, regression testing, and release qualification per FDA guidance.",
      "rationale": "ANSYS Fluent 2023 R2 is deployed under a validated SQA plan with full regression suite and traceable release notes. Version is locked to the model revision and all simulation scripts are stored in a controlled repository."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass documented benchmark tests (e.g., lid-driven cavity, Poiseuille flow) demonstrating correct implementation of governing equations.",
      "rationale": "Code verification benchmarks including the Ghia lid-driven cavity and laminar pipe flow were executed and results match published reference solutions within solver-reported tolerances. Benchmark logs are archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI on hemolysis index QoI must be below 5%.",
      "rationale": "Three meshes (4.2 M, 11.7 M, 28.4 M elements) were used; Richardson extrapolation yields GCI of 3.1% on the hemolysis index at the nominal operating point. Asymptotic range confirmed (GCI ratio 1.03)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) must be reproduced in simulation within stated tolerances.",
      "rationale": "Four of five operating points replicate bench boundary conditions within 2%. The fifth point (6 L/min, 5200 RPM) exhibits a 4.8% deviation in inlet velocity profile due to upstream fitting geometry differences not captured in the CAD; this gap is documented but not resolved in the current model revision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined experimental and numerical uncertainty bands at all five operating points.",
      "rationale": "Agreement is within combined uncertainty at 3 of 5 operating points. At 6 L/min/5200 RPM and 4 L/min/4000 RPM, predicted hemolysis index exceeds measured value by 18% and 12% respectively, outside the combined uncertainty band. Root cause is under investigation; re-validation with updated experimental data is planned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from the simulation (hemolysis index, shear stress exposure time) must directly correspond to the clinical acceptance metric.",
      "rationale": "The normalized index of hemolysis (NIH) computed from simulation matches the metric used in clinical bench testing protocols per ASTM F1841. No proxy quantities are substituted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating envelope as the COU.",
      "rationale": "Validation used the FDA generic centrifugal pump with a 40% glycerol-water blood analog at hematocrit-equivalent viscosity. Operating envelope covers 3.5–6 L/min and 3500–5200 RPM, matching the COU envelope. However, the experimental dataset was collected prior to the current model revision (see dataVintage on the PIV dataset), and a confirmatory re-validation campaign is planned but not yet completed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria and iterative error estimates must be documented and shown to be below discretization error.",
      "rationale": "Scaled residuals converge to 1e-5 for continuity and 1e-6 for momentum. Iterative error estimated via Celik method is 0.4%, well below the 3.1% GCI, confirming solver error is not the dominant error source."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition inputs must be traceable to source documents.",
      "rationale": "An independent CFD analyst performed a simulation setup review against the analysis plan. All boundary conditions are traceable to the bench test protocol document TMP-2025-047. No use errors were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by sensitivity analysis; hemolysis damage model must be validated against published data.",
      "rationale": "SST k-omega was selected based on published literature for rotating machinery. Sensitivity analysis comparing SST, k-epsilon realizable, and BSL RSM shows up to 14% variation in hemolysis index, indicating non-negligible model-form uncertainty. The Giersiepen-Wurzinger power-law hemolysis model is used; its applicability at shear rates above 400 Pa·s is noted as a limitation in the uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameter distributions for Monte Carlo UQ must be sourced from current characterization data and propagated through the hemolysis model.",
      "rationale": "Monte Carlo UQ was performed with 500 Latin hypercube samples varying fluid viscosity, rotational speed, and hemolysis model coefficients. Input distributions were derived from the bench characterization dataset (dataVintage 2025-09-30), which predates the January 2026 model revision. Updated characterization measurements are planned but the current UQ relies on the pre-revision dataset, introducing potential staleness in the input uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be traceable and representative of the device population.",
      "rationale": "Three pump units from the same manufacturing lot as the COU device were used for hemolysis bench testing. Dimensional inspection reports confirm geometric conformance within ±0.05 mm of nominal."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must match experimental conditions within stated tolerances for all validation cases.",
      "rationale": "Fluid properties (density, viscosity), rotational speed, and flow rates used in simulation are matched to measured experimental values within 2% for four of five operating points. The fifth point deviation is documented under Test Conditions factor."
    }
