      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis transport equations; all critical defects resolved prior to simulation execution.",
      "rationale": "ANSYS Fluent 2023 R2 used with institutional QA checklist. Version control confirmed. Automated regression test suite covers 87% of hemolysis module code paths. Three open non-critical defect reports remain unresolved. Achieved Gradation 3 against required Gradation 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equations including hemolysis transport; manufactured solution or benchmark comparison with documented convergence rates.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes and scalar transport equations. Observed second-order convergence confirmed for velocity and pressure. Hemolysis power-law source term verified against analytical solution for simple shear flow. Full rotating-frame MMS not completed; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study conducted on FDA pump geometry. GCI for hemolysis index on fine mesh (12.4M cells) is 11.7%, exceeding the 5% target. Computational cost constraints prevented further refinement. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; operating points span full COU envelope including maximum speed and minimum flow.",
      "rationale": "Experimental campaign documented flow rate ±2%, rotational speed ±0.5%, temperature ±0.3°C. Five operating points tested. Maximum speed condition (3500 RPM, 3 L/min) included. Inlet turbulence intensity not independently measured; estimated from pump inlet geometry. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty) computed for hemolysis index at all operating points; systematic bias assessed.",
      "rationale": "Mean absolute percentage error 18.3% across 5 operating points. Maximum point error 31% at highest shear operating condition. Systematic over-prediction bias of 12% observed. Validation uncertainty interval computed via ASME V&V 20 approach. Achieved level 2 against required level 4 due to large point errors and unresolved bias."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (hemolysis index) directly maps to regulatory acceptance criterion; same metric used in both bench test and CFD prediction.",
      "rationale": "Normalized index of hemolysis (NIH) used as QoI in both experiment and simulation, consistent with ISO 10993-4 and FDA hemolysis guidance. QoI directly addresses regulatory threshold. Minor discrepancy in red blood cell source (bovine vs. human) introduces species extrapolation uncertainty not fully quantified. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on device geometry identical to COU device, at COU operating conditions, with COU fluid (human blood or validated surrogate).",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry, not the specific VAD device geometry. Operating conditions overlap 3 of 5 COU points. Bovine blood surrogate used in experiments; human blood rheology applied in CFD. Geometric and fluid dissimilarities reduce relevance score. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance ≤1e-6 for all equations; mass imbalance < 0.01%.",
      "rationale": "Momentum and continuity residuals converged to 1e-5; hemolysis scalar residual converged to 5e-5. Mass imbalance 0.04%, slightly exceeding target. Rotating reference frame steady-state assumption introduces frozen-rotor approximation error not fully characterized. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review; boundary condition inputs traceable to experimental measurements.",
      "rationale": "Simulation workflow documented in internal technical report. One independent internal reviewer completed checklist. Boundary conditions derived from experimental measurements but traceability chain has one undocumented manual transcription step for inlet velocity profile. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified with sensitivity analysis; hemolysis constitutive model (power-law exponents) validated against independent dataset.",
      "rationale": "k-omega SST turbulence model selected based on prior pump literature. No formal sensitivity analysis comparing alternative turbulence models performed for this COU. Power-law hemolysis coefficients (C=1.8e-6, alpha=0.765, beta=2.416) taken from Giersiepen 1990; not re-calibrated against modern human blood data. Model form uncertainty not quantified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, material properties, boundary conditions) traceable to measurements with documented uncertainty; sensitivity of QoI to input uncertainty quantified.",
      "rationale": "Blood viscosity modeled as Newtonian with fixed dynamic viscosity 0.0035 Pa·s; non-Newtonian effects at low-shear regions not modeled. Pump clearance gaps measured to ±25 µm but not propagated through sensitivity analysis. Monte Carlo UQ performed on inlet BCs and viscosity only; geometric uncertainty excluded. Achieved level 2 against required level 4.",
      "note": "Primary experimental dataset (https://uofa.net/synth/data/experimental-hemolysis-dataset-2025q3) carries dataVintage 2025-09-30, which predates the model revision date of 2026-02-14. Re-validation of model inputs against the revised model build is planned for Q2 2026."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient replicate experiments to characterize biological variability in hemolysis; statistical power analysis documented.",
      "rationale": "Three experimental replicates per operating point using bovine blood from separate donor animals. Coefficient of variation 8-22% across operating points. No formal statistical power analysis performed. Sample size insufficient to characterize inter-donor variability for human blood extrapolation. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
