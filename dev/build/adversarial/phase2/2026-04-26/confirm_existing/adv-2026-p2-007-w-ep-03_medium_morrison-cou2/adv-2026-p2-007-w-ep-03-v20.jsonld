  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite with regression testing at Gradation 4; configuration management and change-control records required.",
      "rationale": "The CFD solver (ANSYS Fluent 2024 R2) has an established V&V test suite and ISO 9001-compliant QMS. However, the hemolysis scalar transport UDF lacks full regression test coverage, reducing the achieved level to 3. A gap remains relative to the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must be performed for all governing equations including hemolysis transport; manufactured solution verification required.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver and confirmed second-order spatial accuracy. Manufactured solution verification was not extended to the hemolysis UDF sub-model. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be reported for hemolysis index QoI on at least three systematically refined meshes; GCI < 5% required.",
      "rationale": "Three-level mesh refinement study performed (8M, 18M, 38M cells). GCI for hemolysis index QoI is 7.2%, exceeding the 5% threshold. Temporal discretization error was quantified separately and found acceptable. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within stated tolerances; temperature, hematocrit, and flow rate control must be documented.",
      "rationale": "In-vitro experiments were conducted at 37°C ± 0.5°C and hematocrit 33 ± 2%, consistent with COU. Flow rates were controlled to ± 0.1 L/min. Minor deviations in impeller surface finish between test article and simulation geometry were noted but not fully characterized. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., E%, NRMSE) must be reported for hemolysis index across all 5 operating points; statistical confidence intervals required.",
      "rationale": "Mean hemolysis index error across 5 operating points is 18.3% (E%). NRMSE = 0.21. Confidence intervals computed via Monte Carlo propagation. Agreement is within the range reported in literature for this class of model but does not meet the < 10% threshold implied by required level 4. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (absolute hemolysis index) must be directly mappable to the clinical decision threshold; sensitivity of QoI to model parameters must be quantified.",
      "rationale": "The normalized index of hemolysis (NIH) is the direct regulatory QoI and maps to the clinical threshold of 0.1 g/100 L. Global sensitivity analysis (Sobol indices) was performed. However, the mapping between power-law exponent uncertainty and NIH uncertainty was not propagated through the full Monte Carlo ensemble. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the FDA generic pump geometry under VAD-representative operating conditions; extrapolation distance to COU must be quantified.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry — the same geometry used in the COU — at 5 operating points spanning the VAD operating envelope. The extrapolation distance is low for flow rate but moderate for rotational speed at the upper end of the COU envelope. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual norms below 1e-6 for all equations; round-off error analysis must be documented.",
      "rationale": "Continuity residuals converge to 1e-4; momentum and scalar transport to 1e-5. The 1e-6 threshold for continuity was not achieved due to rotating mesh interface flux imbalances in the MRF formulation. Round-off error analysis was not performed. Achieved level 2, a significant gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition assignment, and post-processing scripts must be documented; checklist-based peer review required at MRL 5.",
      "rationale": "No independent peer review of the simulation setup was performed. Boundary condition assignments were verified internally by the same analyst who constructed the model. Checklist-based review was not completed. Epistemic gap flagged. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for turbulence model selection (SST k-omega) and hemolysis power-law form must be provided; alternative model forms must be evaluated.",
      "rationale": "SST k-omega turbulence model was selected based on prior literature for rotating machinery. The Giersiepen-Wurzinger power-law hemolysis model was used without evaluation of the Arora or Zhang alternatives. Model form uncertainty is not quantified. Achieved level 3; gap to required level 5 is substantial."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs must be traceable to calibrated measurements; uncertainty distributions must be assigned to all inputs and propagated via Monte Carlo.",
      "rationale": "Boundary condition inputs are sourced from the FDA pump BC dataset (vintage 2025-Q4, predating the model revision of 2026-02-14). Uncertainty distributions were assigned to inlet velocity and rotational speed; blood viscosity uncertainty was treated as a point estimate. Re-validation against the 2026-Q1 experimental update is planned but not yet completed. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Biological variability in blood samples must be characterized; minimum n=5 independent donors required for hemolysis calibration at MRL 5.",
      "rationale": "Hemolysis calibration data were derived from a single pooled ovine blood preparation. Donor-to-donor variability was not characterized. The required n≥5 independent donors was not met. Epistemic gap; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental and simulation input parameters (geometry, fluid properties, operating conditions) must be formally demonstrated via parameter matching matrix.",
      "rationale": "No formal parameter matching matrix was constructed. Impeller tip clearance in the physical test article was measured at 0.38 mm versus the nominal 0.35 mm modeled in the CFD geometry. This discrepancy was noted but its effect on hemolysis prediction was not quantified. Epistemic gap; achieved level 2."
    }
  ],
