  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis model meets the minimum threshold for regulatory submission under the condition that re-validation against updated boundary condition datasets is completed prior to final device submission. All 13 credibility factors have been assessed; achieved levels fall below required levels in several factors, but the overall evidence package is deemed sufficient for a Low assurance level determination. Re-validation against the 2026-Q1 experimental campaign — which postdates the boundary condition dataset vintage of 2025-Q4 used in this assessment — is planned and expected to close the model inputs gap identified in the Model Inputs factor.",
    "decidedAt": "2026-04-19T00:00:00Z"
