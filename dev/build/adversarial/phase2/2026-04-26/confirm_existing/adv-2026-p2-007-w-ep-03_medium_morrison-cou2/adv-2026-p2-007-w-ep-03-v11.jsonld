  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cou2-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment concludes that the CFD hemolysis model achieves sufficient credibility for the VAD COU at MRL 5, with all 13 factors assessed. Achieved levels fall below required levels in several factors, most notably Model Inputs (achieved 2, required 4) where the primary PIV boundary condition dataset predates the January 2026 model revision. The assessment team notes that re-validation of inlet boundary conditions against the revised model build is planned for Q2 2026 and accepts the current package on the basis that the Monte Carlo uncertainty bounds are conservative and encompass the anticipated sensitivity to the revised near-wall treatment. This acceptance is conditional on completion of the planned re-validation activity prior to regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
