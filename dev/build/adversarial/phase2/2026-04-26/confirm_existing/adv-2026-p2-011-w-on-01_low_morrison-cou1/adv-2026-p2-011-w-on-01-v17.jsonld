      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) match simulation inputs within stated uncertainty bounds.",
      "rationale": "FDA benchmark experimental data used. Temperature, hematocrit, and viscosity reported with calibrated uncertainty. CFD boundary conditions set to match mean experimental values; sensitivity to ±1 SD explored."
    },
