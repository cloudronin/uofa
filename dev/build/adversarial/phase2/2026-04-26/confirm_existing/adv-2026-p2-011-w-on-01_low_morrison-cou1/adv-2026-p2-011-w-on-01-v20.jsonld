      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented QA procedures including version control, regression testing, and release notes. Software quality documentation confirms compliance with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Order-of-accuracy testing performed on canonical pipe flow and lid-driven cavity benchmarks confirms second-order spatial convergence. Code verification artifacts are archived and traceable to solver release 2022R2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Grid convergence index (GCI) analysis performed on three systematically refined meshes (2.1 M, 5.8 M, 14.2 M cells). GCI for hemolysis index QoI is 3.1%, within the 5% threshold established for MRL 2. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental test conditions (flow rates 2–8 L/min, rotational speeds 2000–3500 RPM, blood analog fluid properties) are documented in FDA benchmark dataset. Boundary conditions applied in simulation match experimental protocol within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Simulated hemolysis index values compared against five experimental data points from the FDA generic pump dataset. Mean relative error of 8.4% with no systematic bias detected. Comparison metric satisfies MRL 2 acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Hemolysis index (normalized index of hemolysis, NIH) is the primary QoI directly linked to the device safety claim. Secondary QoIs (pressure rise, wall shear stress) are mechanistically connected to hemolysis prediction and support the primary QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Validation activities use the FDA generic centrifugal pump geometry, which is representative of the device class. Operating conditions span the intended CPB flow regime. Validation domain overlap with intended use is judged adequate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
