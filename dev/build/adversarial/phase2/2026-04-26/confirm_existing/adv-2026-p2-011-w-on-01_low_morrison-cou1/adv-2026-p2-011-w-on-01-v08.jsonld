      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression test suite covering relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 used under ISO 9001-compliant QMS; regression suite of 47 benchmark cases executed; all pass within stated tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent analytical verification for the governing equations implemented.",
      "rationale": "MMS study performed on Navier-Stokes solver kernel; observed order of accuracy 1.97 consistent with nominal second-order scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (hemolysis index) with GCI < 5%.",
      "rationale": "Three-mesh Richardson extrapolation study yields GCI of 3.2% for hemolysis index and 2.8% for peak wall shear stress; both below 5% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with measurement uncertainty; flow rate and pressure boundary conditions traceable to NIST standards.",
      "rationale": "FDA benchmark experimental data includes documented flow rate uncertainty of ±1.5% and pressure uncertainty of ±0.8%; conditions traceable to NIST calibration certificates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) reported for primary QoI against experimental data.",
      "rationale": "Normalized hemolysis index error E% = 8.4% across five operating points; velocity field comparison yields average RMS deviation of 4.1% relative to PIV measurements; both within MRL 2 acceptance bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation must be directly linked to the device safety endpoint (hemolysis).",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH); secondary QoI is peak scalar shear stress. Both directly map to red blood cell damage mechanisms relevant to CPB device safety evaluation."
    },
    {
      "type": "CredibilityFactor",
