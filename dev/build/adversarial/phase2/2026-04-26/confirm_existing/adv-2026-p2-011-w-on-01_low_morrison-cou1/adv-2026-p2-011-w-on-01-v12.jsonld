      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented and traceable; fluid properties match CFD inputs within measurement uncertainty.",
      "rationale": "FDA bench test protocol specifies flow rate (2–8 L/min), inlet pressure, and bovine blood hematocrit (40±2%); all boundary conditions replicated in CFD setup with documented traceability."
