  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control and regression testing at MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 was employed under an ISO 9001-certified QA framework. Version control logs, regression test reports, and release notes were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via at least one manufactured-solution or benchmark test at MRL 2.",
      "rationale": "Code verification was confirmed via the FDA benchmark nozzle case (ASME V&V 20 companion problem). Numerical results matched analytical solutions within 0.5% for laminar and 2.1% for turbulent regimes, satisfying MRL 2 thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary quantity of interest (hemolysis index) with at least three systematically refined meshes at MRL 2.",
      "rationale": "Three meshes (2.1 M, 6.4 M, 14.8 M cells) were evaluated. Richardson extrapolation yielded GCI of 3.2% on hemolysis index and 1.8% on pressure rise, both below the 5% MRL 2 acceptance threshold. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to allow boundary condition mapping in the simulation at MRL 2.",
      "rationale": "FDA benchmark test conditions (flow rate 2.5–7.0 L/min, rotational speed 2000–3500 RPM, blood analog fluid properties) were fully documented. Boundary conditions in the CFD model were mapped directly from published experimental protocols."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared to experimental measurements using a quantitative metric; agreement within prescribed tolerance at MRL 2.",
      "rationale": "Hemolysis index predictions compared against FDA experimental data showed mean absolute error of 8.3% across all operating points, within the 15% MRL 2 tolerance. Pressure-rise predictions showed 4.1% mean error against PIV-derived benchmarks."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest computed in the model must be directly linked to the clinical or engineering decision being supported at MRL 2.",
      "rationale": "Hemolysis index (HI) and scalar stress exposure are the primary quantities of interest and are directly tied to the regulatory decision criterion for CPB device safety. The linkage is documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate the physics and operating envelope relevant to the intended device use at MRL 2.",
      "rationale": "FDA benchmark centrifugal pump geometry and blood-analog fluid are representative of the CPB operating regime. Validation activities cover the full flow-rate and speed envelope anticipated in clinical use, satisfying MRL 2 relevance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative convergence must be demonstrated to residual levels below 1e-5 for continuity and momentum equations; formal solver error quantification is not required.",
      "rationale": "Residuals converged to below 1e-6 for all equations; no formal solver error quantification beyond residual monitoring is required at MRL 2 and this factor is therefore not assessed beyond confirming convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a basic checklist review of simulation setup by a second analyst is sufficient; formal use-error analysis is not required.",
      "rationale": "Simulation setup was reviewed by a second qualified CFD analyst against a documented checklist. No formal use-error quantification is required at MRL 2; factor is scoped to checklist compliance only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of model form selection rationale (turbulence model choice, hemolysis model) is sufficient; sensitivity analysis is not required.",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model were selected based on published literature for blood pump CFD. Rationale is documented in the simulation plan; no formal model-form uncertainty quantification is required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values must be documented with sources; formal uncertainty propagation is not required.",
      "rationale": "All model inputs (fluid density, viscosity, hemolysis model coefficients, pump geometry) are documented with literature or manufacturer sources. Formal uncertainty propagation is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, the number and provenance of experimental samples used in validation must be documented; statistical power analysis is not required.",
      "rationale": "FDA benchmark dataset includes n=5 replicate measurements per operating point across 12 conditions. Sample provenance is documented. Statistical power analysis is not required at MRL 2; factor is not formally assessed beyond documentation review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative confirmation that simulation input parameters correspond to experimental conditions is sufficient; formal equivalency metrics are not required.",
      "rationale": "A qualitative mapping table confirming correspondence between simulation boundary conditions and experimental test parameters was prepared and reviewed. Formal equivalency quantification is not required at MRL 2."
