      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented and version-controlled; solver release tested against benchmark suite.",
      "rationale": "OpenFOAM v8 used under institutional SQA plan; unit and regression tests pass for all hemolysis-relevant solver modules. Version control via Git with tagged release."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests confirm theoretical convergence rate for governing equations.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes and scalar transport equations; second-order spatial convergence confirmed on structured and unstructured meshes representative of pump geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index below 5% for hemolysis index QoI on finest two mesh levels.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 11.7 M, 28.4 M cells). GCI for hemolysis index QoI is 3.1% between medium and fine meshes; medium mesh adopted for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions reproduced in simulation within measurement uncertainty bounds.",
      "rationale": "FDA GCBP test conditions (flow rates 2.5–7 L/min, 2500–3500 RPM) replicated as CFD boundary conditions. Inlet velocity profiles derived from PIV measurements supplied with FDA dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement for hemolysis index exceeds 0.85 across all operating points.",
      "rationale": "Predicted hemolysis index agrees with experimental mean within 12% at all five operating points; NIA = 0.91. Pressure rise predictions within 8% of measured values. Exceeds MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) directly linked to device safety endpoint.",
      "rationale": "Hemolysis index is the primary regulatory QoI for CPB blood-contacting devices per FDA guidance. Shear stress distribution supports mechanistic interpretation. Both QoIs are directly computable from CFD output fields."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments share geometry, fluid, and operating regime with intended computational use.",
      "rationale": "FDA GCBP geometry identical to simulation geometry. Bovine blood surrogate used in experiments; power-law viscosity model calibrated to same fluid. Operating envelope overlaps intended CPB range."
