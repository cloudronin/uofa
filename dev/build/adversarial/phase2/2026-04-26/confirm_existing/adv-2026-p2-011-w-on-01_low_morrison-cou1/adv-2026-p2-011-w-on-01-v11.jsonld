      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (hemolysis index) with GCI < 5%.",
      "rationale": "Three-mesh Richardson extrapolation performed on the FDA generic pump geometry at the nominal 2500 RPM / 5 L/min operating point. GCI for the normalized index of hemolysis (NIH) was 3.2%, satisfying the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature) documented and traceable to published FDA benchmark dataset.",
      "rationale": "Experimental conditions sourced from the FDA benchmark hemolysis study (Herbertson et al.). Inlet flow rates, impeller speeds, and blood analogue fluid properties are fully documented and match simulation boundary conditions within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or GCI-normalized error) between simulated and experimental NIH reported and within acceptable band.",
      "rationale": "Simulated NIH values compared against experimental NIH from five independent laboratories. Mean absolute relative error of 18% is within the inter-laboratory variability band (±25%) reported in the benchmark study, satisfying MRL 2 output comparison requirements."
