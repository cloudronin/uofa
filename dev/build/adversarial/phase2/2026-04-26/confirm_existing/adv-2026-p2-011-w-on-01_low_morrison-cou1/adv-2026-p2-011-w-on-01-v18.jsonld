      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is documented, version-controlled, and validated against known benchmarks consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R1 was used under a documented quality management plan. Version control logs and regression test results confirm compliance with MRL 2 software quality requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver correctly implements governing equations as demonstrated by manufactured-solution or benchmark tests at MRL 2 level.",
      "rationale": "Code verification performed using the method of manufactured solutions for the Navier-Stokes equations. Observed order of accuracy matches theoretical order, confirming correct implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error estimated via mesh refinement study; GCI less than 5% for hemolysis index QOI at MRL 2.",
      "rationale": "Three-level mesh refinement study conducted on the FDA generic centrifugal blood pump geometry. Grid Convergence Index for hemolysis index was 3.2%, satisfying the MRL 2 acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented and match simulation boundary conditions within stated uncertainty bounds.",
      "rationale": "FDA benchmark experimental conditions (6 L/min, 3500 RPM, glycerol-water blood analog) were reproduced in simulation boundary conditions. Fluid property deviations are within 2% of reported experimental values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure rise agree with experimental data within combined simulation and experimental uncertainty at MRL 2.",
      "rationale": "Predicted normalized index of hemolysis (NIH) of 0.0042 g/100L agrees with experimental mean of 0.0038 g/100L within combined uncertainty bands. Pressure rise prediction error is 4.1%, within the 5% MRL 2 threshold. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs (hemolysis index, shear stress distribution) are directly linked to the device safety claim and are measurable in validation experiments.",
      "rationale": "Normalized index of hemolysis is the primary regulatory QOI for blood-contacting devices. Shear stress exposure time integral is the secondary QOI. Both are directly observable in the validation experiment and map to the device safety claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the operating envelope relevant to CPB conditions; geometric and flow similarity are demonstrated.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump at CPB-representative flow rates (4–8 L/min) and rotational speeds (2500–4500 RPM). Geometric similarity to clinical CPB pumps is established through published morphological comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iterative convergence and round-off error are within acceptable bounds for MRL 2; formal quantification not required at MRL 2.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations; no further assessment scoped for this package."
    },
