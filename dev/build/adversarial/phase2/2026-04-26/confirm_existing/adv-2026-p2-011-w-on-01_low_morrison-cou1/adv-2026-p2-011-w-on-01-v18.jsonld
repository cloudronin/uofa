      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification and simulation setup review documented at a level commensurate with MRL 2; detailed use-error analysis not required.",
      "rationale": "Simulation was conducted by qualified CFD engineers with documented training records. Formal use-error analysis beyond setup review is not required at MRL 2 and is not assessed in this package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
