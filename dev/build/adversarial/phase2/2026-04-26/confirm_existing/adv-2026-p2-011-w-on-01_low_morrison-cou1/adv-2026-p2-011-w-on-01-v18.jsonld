      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization is documented; statistical sampling analysis not required at MRL 2.",
      "rationale": "FDA benchmark used a single representative pump specimen with documented dimensional inspection. Statistical multi-sample analysis is not required at MRL 2 and is not assessed here."
    },
