      "name": "Hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-vr-02",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic validation at nominal CPB operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042689",
