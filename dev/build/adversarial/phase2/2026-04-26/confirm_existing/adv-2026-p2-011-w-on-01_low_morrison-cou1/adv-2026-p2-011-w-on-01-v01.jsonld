  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression testing, and documentation of known defects must be demonstrated at Gradation 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-certified QMS. Regression test suite covers relevant turbulence and scalar transport modules. Version control logs and defect register reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical benchmark cases must confirm expected spatial convergence rates for the governing equations employed.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes and power-law hemolysis scalar equations. Second-order spatial accuracy confirmed on structured and unstructured grids. Results consistent with published ANSYS verification suite."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must bound discretization error to within acceptable tolerance for the hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 11.7 M, 28.4 M cells). GCI for hemolysis index QoI is 3.1%, below the 5% acceptance threshold. Exceeds MRL 2 requirement; Gradation 3 credited."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with traceability to calibrated instrumentation and must match CFD inlet/outlet conditions within stated uncertainty.",
      "rationale": "FDA benchmark experimental data includes calibrated flow loop measurements. Inlet velocity profiles and outlet pressure boundary conditions reproduced in CFD within measurement uncertainty bounds. Traceability documented in test report TR-2019-FDA-CPB."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed and shown to be within the decision-relevant tolerance for the hemolysis index.",
      "rationale": "Normalised hemolysis index prediction error is 8.4% relative to FDA experimental mean across five operating points. Validation metric u_val computed per ASME V&V 20. Result falls within the ±15% decision-relevant tolerance established for MRL 2 worst-case identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the decision question regarding worst-case hemolysis operating conditions.",
      "rationale": "Primary QoI is the normalised index of hemolysis (NIH) computed via the Giersiepen-Wurzinger power-law model integrated along Lagrangian particle paths. NIH is the regulatory QoI for CPB device hemolysis assessment and directly supports worst-case operating point identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be sufficiently similar in geometry, fluid properties, and operating regime to the intended deployment scenario to support extrapolation of validation evidence.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry — the same geometry used in the predictive model. Blood analogue fluid (glycerol-water, viscosity matched) used in experiments. Operating range (2–6 L/min, 2000–3500 RPM) spans the CPB clinical envelope. Similarity is high at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to be monitored; residual drop of at least three orders of magnitude required.",
      "rationale": "At MRL 2 with seven factors assessed, numerical solver error is not required to be formally assessed beyond residual monitoring. Residuals confirmed to drop five orders of magnitude in all simulations; no further quantification required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records must be on file.",
      "rationale": "Use error assessment scoped out at MRL 2. Analysts hold institutional CFD certification. Formal use-error quantification not required for this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Governing equation selection and turbulence model choice must be justified by literature precedent.",
      "rationale": "SST k-omega turbulence model selected based on published benchmarking for rotating machinery hemolysis CFD. Formal model-form uncertainty quantification not required at MRL 2; literature justification documented in modelling assumptions report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model input parameters must be identified and nominal values documented with sources.",
      "rationale": "Blood analogue viscosity, density, and hemolysis model coefficients documented with literature sources. Sensitivity to input variation not formally quantified; not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number of experimental replicates must be documented.",
      "rationale": "FDA benchmark dataset includes three independent experimental runs per operating point. Statistical characterisation of inter-run variability not required at MRL 2; replicate count documented in test report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental and computational input parameters must be documented at a qualitative level.",
      "rationale": "Qualitative mapping of experimental boundary conditions to CFD inputs documented in the validation plan. Formal equivalency quantification not required at MRL 2."
    }
