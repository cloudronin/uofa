      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented QA procedures, version control, and regression test suite. Software quality assurance documentation reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Order-of-accuracy tests performed on canonical rotating flow benchmarks confirm second-order spatial convergence. Manufactured solution verification completed for the Navier-Stokes solver kernel relevant to the pump geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry (coarse 1.2 M, medium 4.8 M, fine 19.2 M elements). Richardson extrapolation yields GCI < 3% on hemolysis index QoI, meeting MRL 2 discretization error requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental test conditions (flow rate 5 L/min, rotational speed 3500 RPM, blood analog fluid properties) are documented in the FDA benchmark dataset and reproduced in simulation boundary conditions within stated uncertainty bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Predicted hemolysis index agrees with experimental measurements within 15% across three operating points. Velocity magnitude profiles match PIV data within experimental uncertainty at 80% of measurement locations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
