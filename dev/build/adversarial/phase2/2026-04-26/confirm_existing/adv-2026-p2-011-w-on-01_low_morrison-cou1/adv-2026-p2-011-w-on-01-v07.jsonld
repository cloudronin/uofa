  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was employed with documented version control and regression test suite. Release notes and QA records confirm compliance with MRL 2 software quality requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through manufactured solution or benchmark comparison at MRL 2.",
      "rationale": "Code verification was demonstrated via lid-driven cavity and pipe-flow benchmark cases with documented order-of-accuracy analysis confirming second-order spatial convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or Richardson extrapolation must be reported for key quantities of interest; discretization error must be within acceptable bounds for MRL 2.",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry. GCI for hemolysis index QoI was 4.1%, within the MRL 2 threshold. Medium mesh (6.2M cells) selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must be documented with uncertainty estimates and must match simulated operating points.",
      "rationale": "PIV and hemolysis bench tests were conducted at 2500 RPM and 5 L/min flow rate. Inlet and outlet pressure boundary conditions were measured and reported with expanded uncertainty of ±3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric or normalised RMS error) must be reported between simulation outputs and experimental data.",
      "rationale": "Normalised RMS error for velocity field was 8.3% against PIV data. Hemolysis index prediction agreed within 12% of bench measurements, meeting MRL 2 output comparison requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly relevant to the clinical or engineering decision being supported.",
      "rationale": "Hemolysis index and shear stress distribution are the primary QoIs directly linked to red blood cell damage assessment, which is the engineering decision output for CPB device evaluation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same or sufficiently similar geometry, fluid properties, and operating regime as the intended simulation use.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry with bovine blood analogue at physiological viscosity. Operating conditions bracket the intended CPB operating range, supporting relevance at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, numerical solver error beyond discretization is not required to be separately quantified; acknowledgement of potential sources is sufficient.",
      "rationale": "Numerical solver error (iterative convergence residuals) was monitored but not formally quantified as a separate uncertainty contributor. Residuals converged to 1e-5 for all equations, consistent with MRL 2 expectations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error analysis is not required; documented analyst training and peer review of simulation setup is sufficient.",
      "rationale": "Simulation setup was peer-reviewed by a second qualified CFD analyst. No formal use-error quantification was performed, which is acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model-form uncertainty does not require formal quantification; selection rationale for constitutive models must be documented.",
      "rationale": "SST k-omega turbulence model and Giersiepen hemolysis power-law were selected based on literature precedent for blood pump CFD. Formal model-form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, input parameter uncertainty propagation is not required; nominal values with documented sources are sufficient.",
      "rationale": "Blood viscosity (3.5 mPa·s) and density (1060 kg/m³) were sourced from published physiological references. Sensitivity to these inputs was not formally propagated, consistent with MRL 2 scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterisation of test sample variability is not required; sample provenance must be documented.",
      "rationale": "Bovine blood analogue batches were sourced from a single supplier with documented haematocrit of 35±2%. Inter-batch variability was not statistically characterised, which is acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency mapping between validation experiment inputs and simulation inputs is not required; qualitative alignment must be documented.",
      "rationale": "Simulation inlet boundary conditions were set to match experimentally measured flow rates and rotational speed. Formal equivalency metric not computed; qualitative alignment documented in the V&V report."
    }
