  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QA process covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022R2 is employed under an ISO 9001-certified QA framework. Version control logs, regression test suite results, and release notes were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass published benchmark problems relevant to rotating machinery flows with documented order-of-accuracy confirmation.",
      "rationale": "Code verification confirmed via lid-driven cavity and Taylor-Couette benchmarks; observed second-order spatial convergence consistent with the finite-volume discretisation scheme used."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) for hemolysis index QoI must be below 10% on the medium mesh used for production runs.",
      "rationale": "Three-level mesh refinement study (2.1 M, 5.8 M, 14.6 M cells) yielded GCI of 3.8% on the medium mesh, exceeding the required level. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, inlet hematocrit) must be replicated in simulation within ±5% of reported test values.",
      "rationale": "FDA bench test conditions (5 L/min, 2500 RPM, Hct 40%) were reproduced in simulation boundary conditions within 2% tolerance. Inlet velocity profiles matched measured data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within a factor of 2 across the operating envelope tested.",
      "rationale": "Simulated normalized index of hemolysis (NIH) agreed with experimental values within 18% across five operating points, well within the factor-of-2 acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH) must be directly linked to the device safety claim regarding red blood cell damage under CPB operating conditions.",
      "rationale": "NIH is the regulatory-accepted metric for hemolysis in blood-contacting devices. Its direct relationship to the worst-case operating condition claim is documented in the V&V plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and a blood analogue fluid with documented rheological properties representative of human blood at CPB hematocrit.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry with porcine blood at Hct 38–42%, covering the CPB operating range. Geometric and physiological similarity is well established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver residual monitoring to convergence tolerance 1e-5 is sufficient.",
      "rationale": "At MRL 2, formal iterative error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations, satisfying the minimum criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; documented simulation setup checklist review is sufficient.",
      "rationale": "A peer-reviewed simulation setup checklist was completed and signed off by a second analyst. Formal use-error quantification is not mandated at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; selection of power-law hemolysis model with literature-derived constants is documented and justified.",
      "rationale": "The Giersiepen–Wurzinger power-law hemolysis model was selected based on published literature for centrifugal pumps. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Blood viscosity, density, and hemolysis model constants sourced from peer-reviewed literature. Sensitivity analysis and uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; documentation of sample provenance and preparation protocol is sufficient.",
      "rationale": "Porcine blood samples were obtained from a licensed abattoir and prepared per ASTM F1841 protocol. Statistical characterisation of sample variability is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; qualitative argument for equivalency between validation and deployment input space is sufficient.",
      "rationale": "The operating envelope of the FDA generic pump (2000–3500 RPM, 3–8 L/min) encompasses the CPB deployment range. Formal equivalency mapping is not required at MRL 2."
    }
