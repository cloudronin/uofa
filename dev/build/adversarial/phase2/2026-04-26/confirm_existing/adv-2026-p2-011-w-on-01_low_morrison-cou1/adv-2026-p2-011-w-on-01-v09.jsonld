      "name": "Hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-vr-002",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic curve validation at five operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034918",
