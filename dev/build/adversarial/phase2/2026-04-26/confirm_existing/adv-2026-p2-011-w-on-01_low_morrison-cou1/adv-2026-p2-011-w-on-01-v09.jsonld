  "signature": "ed25519:b2e3d4f5a6c7b8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression testing suite, and build verification for the CFD solver executable used in all production runs.",
      "rationale": "The CFD solver (OpenFOAM v9) is managed under Git version control with tagged release commits. A regression test suite of 42 canonical cases is executed at each release; all cases pass within specified tolerances. Build verification logs are archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical benchmark problems demonstrate expected spatial and temporal convergence rates.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver confirms second-order spatial accuracy (observed order 1.97) and first-order temporal accuracy consistent with the implicit Euler scheme selected for this application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis index QoI; GCI below 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study (coarse 1.2 M, medium 3.8 M, fine 11.4 M cells) yields GCI of 3.2% on the hemolysis index at the design operating point, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) are documented with calibrated measurement uncertainty and reproduced in simulation inputs.",
      "rationale": "FDA benchmark experimental conditions are fully documented in the published protocol. Inlet flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), and fluid properties (bovine blood, 40% hematocrit, 37 °C) are replicated in simulation boundary conditions within stated measurement uncertainty bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized hemolysis index predictions fall within two standard deviations of experimental mean across all five operating points.",
      "rationale": "Predicted normalized index of hemolysis (nIH) values range from 0.0031 to 0.0089 across the five operating points; experimental values (mean ± SD) overlap the prediction interval at all points. Maximum deviation from experimental mean is 18%, within the two-sigma band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis) is directly linked to the regulatory decision criterion for blood-contacting device clearance.",
      "rationale": "The nIH is the standard metric cited in FDA guidance for blood pump hemolysis assessment and maps directly to the worst-case operating condition identification objective. Secondary QoIs (wall shear stress distribution, scalar stress exposure) are corroborating outputs consistent with the primary QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, fluid analogue, and operating envelope as the intended use scenario.",
      "rationale": "The FDA generic centrifugal pump geometry used in validation is identical to the simulation geometry. Bovine blood with 40% hematocrit is a recognized analogue for human blood in hemolysis testing. Operating conditions span the full CPB flow and speed envelope, confirming relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-5 for all transport equations at each time step.",
      "rationale": "At MRL 2, explicit iterative solver error quantification beyond standard residual monitoring is not required. Residuals are monitored and logged; no divergence events were recorded. Formal round-off and iterative error decomposition deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation execution checklists on file.",
      "rationale": "At MRL 2, formal use-error assessment is not mandated. Analysts hold relevant CFD credentials; execution checklists are maintained internally. Formal human-factors review of simulation workflow deferred to higher MRL activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented justification for turbulence model and hemolysis power-law model selection.",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law are standard choices for blood pump CFD at MRL 2. Formal model-form uncertainty quantification is scoped out at this risk level; selection rationale is documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal material properties and boundary condition values sourced from peer-reviewed literature or calibrated measurements.",
      "rationale": "Blood viscosity, density, and hemolysis model constants are drawn from published sources. Sensitivity of nIH to ±10% variation in viscosity was informally checked and found to alter predictions by less than 4%. Formal parametric uncertainty propagation deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample sizes and variability statistics reported for each operating condition.",
      "rationale": "FDA benchmark dataset provides n=3 replicates per operating point with reported standard deviation. Statistical power analysis for sample adequacy is not required at MRL 2; available replicates are deemed sufficient for the comparison objective."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence table mapping experimental measurement locations and conditions to simulation boundary and initial conditions.",
      "rationale": "A correspondence table is included in the simulation plan confirming that inlet velocity profiles, outlet pressure conditions, and rotational speed inputs match experimental settings. Formal equivalency scoring per ASME V&V 40 Table 3 deferred to MRL 3 activities."
    }
  ],
