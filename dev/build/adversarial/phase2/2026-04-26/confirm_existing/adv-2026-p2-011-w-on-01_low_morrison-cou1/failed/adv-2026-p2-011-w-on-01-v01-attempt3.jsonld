  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is verified under a documented QA plan consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) is under a documented software QA plan including version control, regression testing, and release notes. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes established benchmark problems relevant to rotating turbomachinery flows.",
      "rationale": "ANSYS Fluent has been verified against canonical rotating-frame benchmark cases (lid-driven cavity, Taylor-Couette flow). Convergence behavior is consistent with published order-of-accuracy results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed on the FDA generic pump geometry. GCI for normalized index of hemolysis is 3.8% on the fine mesh (8.4 M cells), satisfying the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) are documented and traceable to the FDA benchmark dataset.",
      "rationale": "All experimental runs from the FDA generic pump study are documented with measured inlet flow rates (2–8 L/min), rotational speeds (2500–3500 RPM), and bovine blood analog properties. Traceability to FDA dataset confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure rise agree with experimental data within ±15% across the operating envelope.",
      "rationale": "Comparison of predicted normalized index of hemolysis against FDA experimental measurements shows mean absolute error of 9.2%. Pressure-rise predictions fall within ±11% of measured values across all tested operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs (hemolysis index, shear stress distribution) are directly linked to the clinical harm mechanism under evaluation.",
      "rationale": "Normalized index of hemolysis and volume-averaged scalar shear stress are the primary QoIs. Both are directly linked to red blood cell lysis in CPB circuits and are accepted by FDA guidance as relevant hemolysis surrogates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments replicate the geometry, flow regime, and fluid properties representative of CPB operating conditions.",
      "rationale": "The FDA generic centrifugal pump geometry and operating envelope (flow rate 2–8 L/min, RPM 2500–3500) are representative of Class II CPB pump use conditions. Validation activities are judged sufficiently relevant for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance at gradation 1.",
      "rationale": "Numerical solver error beyond discretization GCI is not required to be separately quantified at MRL 2. Factor is scoped within discretization error assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; user qualification records are on file but formal use-error analysis is not mandated.",
      "rationale": "At MRL 2, a formal use-error assessment is not required. Analyst qualifications and simulation SOPs are documented internally but a structured use-error study has not been conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; turbulence model selection is documented.",
      "rationale": "Model form uncertainty (turbulence model, constitutive law) is not formally quantified at MRL 2. The SST k-omega turbulence model is selected based on published literature for similar pump geometries."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values are documented.",
      "rationale": "Sensitivity analysis on model inputs (viscosity, density, hemolysis power-law coefficients) is not required at MRL 2. Nominal values from published FDA dataset are used."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample size from FDA benchmark is accepted as sufficient.",
      "rationale": "Statistical characterization of experimental sample variability is not required at MRL 2. The FDA benchmark dataset sample size is accepted as adequate for this assessment level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative equivalency between validation and COU inputs is documented.",
      "rationale": "Formal equivalency mapping between validation experiment inputs and intended COU inputs is not required at MRL 2. Qualitative review confirms the FDA pump operating envelope spans the expected CPB use range."
    }
  ],
