  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software QA procedures documented and version-controlled; CFD solver verified against known benchmarks.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is a commercially validated code with documented QA procedures. Version control and regression testing logs confirm compliance with MRL 2 requirements for software quality assurance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities demonstrate solver correctly implements governing equations for the flow regime of interest.",
      "rationale": "Order-of-accuracy tests using the method of manufactured solutions confirm second-order spatial accuracy for the incompressible Navier-Stokes solver. Results are consistent with published ANSYS Fluent verification documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study performed; discretization error estimated and reported as fraction of QoI.",
      "rationale": "A three-level grid convergence study was performed using meshes of 2.1M, 5.8M, and 14.2M elements. Richardson extrapolation yields a discretization error of 4.2% for the hemolysis index QoI on the fine mesh, exceeding MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are documented and sufficiently characterized to support comparison with simulation inputs.",
      "rationale": "FDA benchmark experimental data for the generic centrifugal blood pump includes documented flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), and fluid properties. Test conditions are traceable and adequately characterized for MRL 2 comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs compared quantitatively to experimental measurements with reported error metrics.",
      "rationale": "Predicted hemolysis index values compared against FDA experimental measurements across six operating conditions. Mean absolute error of 11.3% and maximum error of 18.7% are within acceptable bounds for MRL 2 hemolysis prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation are directly relevant to the decision question.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI, directly corresponding to the regulatory metric for blood damage assessment in CPB devices. Secondary QoIs include wall shear stress distribution and exposure time histograms."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities are sufficiently representative of the intended use conditions to support the credibility claim.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under operating conditions spanning the intended CPB flow range. Geometric and hemodynamic similarity to the target device class is established through documented comparison of key dimensionless parameters."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iterative convergence error quantified or demonstrated negligible relative to discretization error.",
      "rationale": "Not assessed at MRL 2 for this factor. Residual convergence to 1e-5 is documented as standard practice and deemed acceptable without formal quantification at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user error in model setup and post-processing is identified and mitigated.",
      "rationale": "Not assessed at MRL 2. Standard operating procedures for CFD setup and post-processing are in place; formal use error analysis not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form assumptions identified and their impact on QoI assessed.",
      "rationale": "Not assessed at MRL 2. The k-omega SST turbulence model and power-law hemolysis correlation are standard choices for blood pump CFD; formal model form uncertainty quantification is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter uncertainty characterized and propagated to QoI.",
      "rationale": "Not assessed at MRL 2. Nominal blood viscosity and density values from literature are used; sensitivity analysis and formal uncertainty propagation are not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Adequacy of experimental sample size and variability documented.",
      "rationale": "Not assessed at MRL 2. FDA benchmark dataset is treated as authoritative reference; formal sample adequacy analysis is not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrated equivalent to experimental conditions within acceptable tolerance.",
      "rationale": "Not assessed at MRL 2. Boundary conditions are set to match nominal experimental values; formal equivalency demonstration is not required at this model risk level."
