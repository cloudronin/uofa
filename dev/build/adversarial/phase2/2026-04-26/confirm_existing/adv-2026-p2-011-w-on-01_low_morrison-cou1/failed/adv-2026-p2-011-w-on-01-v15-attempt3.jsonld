  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is subject to documented version control, regression testing, and release qualification consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used; vendor-supplied verification and validation documentation plus internal regression test suite confirm SQA level 2 compliance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities demonstrate correct implementation of governing equations for incompressible Newtonian flow and power-law hemolysis sub-model at MRL 2.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver; hemolysis sub-model verified against analytical power-law integration for simple shear flow cases. All residuals within tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed for hemolysis index QoI; discretization error bounded below 5% of reported value at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (coarse 2.1 M, medium 4.8 M, fine 10.2 M cells). GCI for hemolysis index = 3.1%, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) are documented with measurement uncertainty and overlap the simulated operating envelope.",
      "rationale": "FDA benchmark experiments conducted at 5 L/min, 2500 RPM, 37 °C, 35% hematocrit. Measurement uncertainties reported. Simulation boundary conditions set to match; overlap confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 15% of experimental mean value; pressure-rise curve within 10% across operating range at MRL 2.",
      "rationale": "Predicted normalized index of hemolysis = 0.0041 vs. experimental 0.0038 (8% difference). Pressure-rise curve maximum deviation 7.4%. Both within acceptance thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution, pressure rise) are directly linked to the clinical risk of red blood cell damage under CPB conditions.",
      "rationale": "Hemolysis index is the primary regulatory QoI for CPB device evaluation. Shear stress distribution informs worst-case region identification. Linkage to clinical risk documented in design dossier."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments address the same device geometry, fluid type, and operating regime as the intended COU at MRL 2.",
      "rationale": "FDA generic centrifugal pump geometry used in both simulation and experiment. Bovine blood surrogate with matched rheology. Operating conditions span the CPB clinical envelope. Relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit solver error quantification beyond iterative convergence monitoring is not required when a verified commercial solver is used.",
      "rationale": "Iterative convergence to residual tolerance 1e-6 confirmed for all runs. Explicit solver error budget not computed; acceptable at MRL 2 with verified commercial code."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use-error analysis not required at MRL 2 when simulation is performed by qualified analysts following documented SOPs.",
      "rationale": "Simulation executed by analysts with documented CFD competency. SOP for pump hemolysis simulation followed. Formal use-error FMEA scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model-form uncertainty quantification not required at MRL 2; selection of turbulence model and hemolysis constitutive law documented with literature justification.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark comparisons for rotating machinery. Giersiepen-Wurzinger hemolysis model adopted per FDA guidance. Formal model-form UQ deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter sensitivity study not required at MRL 2; nominal inputs sourced from literature and experimental measurements with documented provenance.",
      "rationale": "Blood viscosity, density, and hemolysis model constants sourced from peer-reviewed literature. Boundary conditions from experimental protocol. Formal sensitivity analysis deferred to higher MRL."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability not required at MRL 2; single representative dataset acceptable.",
      "rationale": "FDA benchmark dataset provides a single set of experimental replicates. Inter-sample variability characterization not performed; acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between experimental and simulation input parameters not required at MRL 2 beyond qualitative correspondence.",
      "rationale": "Qualitative correspondence between experimental boundary conditions and simulation inputs confirmed. Formal equivalency metric computation deferred; acceptable at MRL 2."
    }
  ],
