  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "CFD solver (ANSYS Fluent 2022 R2) operates under a documented SQA plan including version control, regression testing, and release validation. All SQA artifacts reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification demonstrates solver correctly implements governing equations at MRL 2 standard.",
      "rationale": "Order-of-accuracy tests performed on canonical Navier-Stokes benchmarks (lid-driven cavity, Poiseuille flow) confirm second-order spatial accuracy. Results consistent with published verification suite for the solver version used."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error estimated and shown to be within acceptable bounds for MRL 2.",
      "rationale": "Three-level mesh refinement study conducted on the FDA generic centrifugal pump geometry. Richardson extrapolation yields a grid convergence index below 5% for hemolysis index QoI across all operating points assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are documented and sufficiently characterized to support validation comparison at MRL 2.",
      "rationale": "FDA benchmark experimental conditions (flow rate 2.5–6 L/min, rotational speed 2500–3500 RPM, blood analog fluid) are fully documented in the FDA critical path report. Uncertainty in boundary conditions quantified and propagated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model outputs compared quantitatively to experimental data with defined acceptance metric at MRL 2.",
      "rationale": "Hemolysis index predictions compared against FDA experimental data using normalized index of agreement. Mean absolute error of 8.3% across validation operating points, within the 15% acceptance threshold established for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation are directly relevant to the decision question at MRL 2.",
      "rationale": "Hemolysis index (normalized index of hemolysis, NIH) is the primary regulatory QoI for CPB device blood damage assessment. Scalar shear stress and exposure time sub-quantities directly inform the power-law hemolysis model used."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities address conditions representative of the intended use at MRL 2.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under CPB-representative flow and rotational speed ranges. Fluid properties match CPB blood analog (glycerol-water). Geometry similarity to clinical CPB pumps confirmed by dimensional analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required for MRL 2 at this scope; default level 1 applies.",
      "rationale": "Numerical solver error beyond discretization error (e.g., iterative convergence residuals) not separately assessed at MRL 2. Residual convergence to 1e-5 documented as standard practice and sufficient for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this application scope.",
      "rationale": "Use error assessment not required at MRL 2. Simulation setup reviewed by a second analyst for boundary condition and material property correctness as a minimum control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty not required to be separately quantified at MRL 2.",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger) selected based on published literature applicability to CPB conditions. Formal model form uncertainty quantification deferred; not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input uncertainty propagation not required at MRL 2 for this assessment.",
      "rationale": "Nominal model inputs (fluid viscosity, density, pump geometry) sourced from FDA benchmark documentation. Sensitivity to input variation not formally propagated at MRL 2; qualitative assessment indicates low sensitivity for primary QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization not required at MRL 2 for fluid-only simulation.",
      "rationale": "Blood analog fluid (glycerol-water) used in FDA benchmark; no biological sample variability applies. Test sample factor scoped to not-assessed as fluid properties are well-characterized and not subject to batch variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency of input parameters between validation and use conditions not required at MRL 2.",
      "rationale": "Operating conditions in validation span the CPB clinical range. Formal equivalency mapping not required at MRL 2; qualitative overlap between validation envelope and intended operating range documented in the simulation report."
    }
  ],
