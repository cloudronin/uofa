  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, unit tests, and a traceable build process consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is a commercially validated code with documented QA processes. Version control and regression test records were reviewed and found compliant with MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be solved to confirm correct implementation of governing equations at MRL 2.",
      "rationale": "Code verification was performed against the lid-driven cavity and Poiseuille flow benchmarks. Observed order of convergence matched theoretical second-order accuracy, confirming correct numerical implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A mesh refinement study must demonstrate that the hemolysis index QoI changes by less than 5% between medium and fine mesh solutions.",
      "rationale": "Three mesh densities (2.1M, 4.8M, 9.6M elements) were evaluated. Richardson extrapolation yielded a GCI of 3.1% between medium and fine meshes for the hemolysis index, meeting the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to reproduce boundary conditions in simulation, including flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA benchmark experimental data provided flow rates (2–7 L/min) and rotational speeds (2000–3500 RPM) with documented fluid properties. Boundary conditions were reproduced in simulation within stated measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bands.",
      "rationale": "Predicted hemolysis index values across all operating points fell within ±15% of experimental measurements, within the combined uncertainty band. Agreement is deemed sufficient for MRL 2 worst-case identification purposes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index QoI must be directly linked to the device safety claim and must be measurable in both simulation and experiment.",
      "rationale": "The normalized index of hemolysis (NIH) is the regulatory-accepted metric for CPB device hemolysis characterization. It is directly computable from CFD shear stress fields and measurable in vitro, confirming QoI relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and operating envelope as the intended use scenario to ensure relevance to worst-case hemolysis identification.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry under the same flow and speed ranges as the intended CPB operating envelope. The validation scenario is judged sufficiently representative for MRL 2 credibility."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative solver convergence to residuals below 1e-5 for all equations is required; round-off error assessment is not required at MRL 2.",
      "rationale": "At MRL 2, detailed solver error quantification beyond residual monitoring is not required. Residuals were monitored and confirmed below 1e-5 for all runs; no further assessment is scoped."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required; standard analyst review of simulation setup is sufficient.",
      "rationale": "MRL 2 does not mandate formal use error assessment. Simulation setup was reviewed by a second analyst; no setup errors were identified. Formal use error quantification is not scoped at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty need not be formally quantified; selection of constitutive relations must be documented with literature justification.",
      "rationale": "The power-law hemolysis damage model (Giersiepen-Wurzinger) was selected based on published literature for CPB applications. Formal model form uncertainty quantification is not required at MRL 2 and is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters must be sourced from published literature or direct measurement; sensitivity analysis is not required at MRL 2.",
      "rationale": "Blood viscosity, density, and hemolysis model coefficients were sourced from peer-reviewed literature. At MRL 2, formal sensitivity or uncertainty analysis of model inputs is not required and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be documented; statistical characterization of sample variability is not required at MRL 2.",
      "rationale": "FDA benchmark data was generated using bovine blood with documented hematocrit. Sample-to-sample variability characterization is not required at MRL 2 and has not been assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, equivalency between simulation inputs and experimental conditions must be qualitatively confirmed; quantitative matching is not required.",
      "rationale": "Simulation boundary conditions were set to match nominal experimental values. Quantitative equivalency analysis is not required at MRL 2; qualitative confirmation is sufficient and has been performed."
    }
  ],
