  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance procedures documented and applied; version control and testing records available.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is commercial software with documented QA procedures. Version control logs and regression test suites were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities demonstrate correct implementation of governing equations for relevant flow regimes.",
      "rationale": "Order-of-accuracy studies using manufactured solutions confirmed second-order spatial convergence for the incompressible Navier-Stokes solver. Taylor-Couette and lid-driven cavity benchmarks were reproduced within 1% of analytical solutions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed; discretization error estimated and within acceptable bounds for QoI.",
      "rationale": "Three-level mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.2M cells) performed. Richardson extrapolation yielded GCI < 3.2% for shear stress QoI. Medium mesh selected for production runs, achieving balance between accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions sufficiently documented and representative of computational boundary conditions.",
      "rationale": "FDA benchmark experimental data includes documented flow rates (2.5–7.0 L/min), rotational speeds (2000–3500 RPM), and fluid properties (glycerol-water blood analog). Boundary conditions mapped directly to CFD inlet/outlet specifications."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics applied between simulation outputs and experimental measurements.",
      "rationale": "Pressure-flow curves compared across 15 operating points; mean absolute error of 4.1% observed. Velocity profiles at three measurement planes compared using PIV data; average normalized RMSE of 6.8%. Both within MRL 2 acceptance thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI selected for validation are directly relevant to the hemolysis prediction objective.",
      "rationale": "Primary QoI is scalar stress exposure index (SEI) derived from Lagrangian particle tracking. Secondary QoI includes area-averaged wall shear stress and volume-averaged turbulent dissipation rate. All QoI directly feed the hemolysis power-law model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed under conditions sufficiently similar to intended use conditions.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry under CPB-representative flow conditions. Blood analog fluid properties match physiological range. Rotational speed sweep covers clinical operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver error characterization not required at MRL 2 for this factor.",
      "rationale": "At MRL 2, formal solver error quantification beyond code verification is not required. Commercial solver iterative convergence criteria (residuals < 1e-5) applied consistently."
    },
