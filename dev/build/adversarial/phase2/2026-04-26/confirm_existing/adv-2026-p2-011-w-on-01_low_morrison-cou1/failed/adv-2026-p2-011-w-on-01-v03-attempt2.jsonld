  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must demonstrate version control, regression testing, and documented build procedures consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented QA procedures, release notes, and regression test suites. Version control and build documentation meet MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must demonstrate correct implementation of governing equations through benchmark problems at MRL 2 level.",
      "rationale": "Benchmark verification cases including lid-driven cavity and pipe flow with known analytical solutions confirm correct implementation of the Navier-Stokes solver. Order-of-accuracy tests pass for the relevant flow regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via mesh convergence study with at least three mesh refinement levels.",
      "rationale": "Three-level mesh refinement study (coarse: 2.1M cells, medium: 5.8M cells, fine: 14.3M cells) performed. Richardson extrapolation yields GCI below 4.2% for hemolysis index predictions, satisfying MRL 2 thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and relevant to the simulation boundary conditions.",
      "rationale": "FDA interlaboratory study test conditions (flow rates 2.5–7.5 L/min, rotational speeds 2000–3500 RPM, physiological blood analog fluid) are documented and directly replicated as CFD boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively to experimental measurements with documented metrics.",
      "rationale": "Hemolysis index and pressure rise predictions compared to FDA interlaboratory experimental data. Normalized index of agreement exceeds 0.92 across all operating points; pressure rise predictions within 8% of experimental mean."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest computed by the model must be relevant to the decision being made.",
      "rationale": "Hemolysis index (normalized index of hemolysis, NIH) is the primary regulatory endpoint for blood-contacting device assessment. The model directly computes shear-stress-based hemolysis predictions aligned with the decision QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties sufficiently similar to the intended use scenario.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry under CPB-relevant operating conditions using blood analog fluids. Geometric and operational similarity to the target device is confirmed at MRL 2 level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Numerical solver error assessment not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "At MRL 2, explicit solver error quantification beyond code verification is not required. The commercial solver's documented validation suite provides sufficient basis for this factor to be scoped at level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment not required at MRL 2; analyst qualification documentation is sufficient.",
      "rationale": "MRL 2 does not require formal use error analysis. Analyst team holds relevant CFD and biofluid mechanics credentials. Simulation setup reviewed by second analyst prior to submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty assessment not required at MRL 2 for this application.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) is the accepted standard for CFD hemolysis prediction in regulatory submissions at MRL 2. Formal model form uncertainty quantification is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model input uncertainty propagation not required at MRL 2; nominal inputs with documented sources are acceptable.",
      "rationale": "Fluid properties (viscosity, density) and boundary conditions derived from published FDA interlaboratory study protocols. Nominal values used; uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Detailed characterization of experimental test sample variability not required at MRL 2.",
      "rationale": "FDA interlaboratory study used standardized blood analog (glycerin-water mixture) with controlled preparation. Sample-to-sample variability characterization is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis of input parameters between validation and use case not required at MRL 2.",
      "rationale": "Operating conditions for validation and intended use overlap substantially. Formal parameter equivalency mapping is not required at MRL 2; qualitative correspondence is documented in the validation report."
    }
