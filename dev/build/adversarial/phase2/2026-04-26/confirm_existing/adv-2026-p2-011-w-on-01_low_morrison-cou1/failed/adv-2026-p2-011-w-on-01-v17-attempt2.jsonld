  "signature": "ed25519:b2c4d6e8f0a1b3c5d7e9f1a3b5c7d9e1f3a5b7c9d1e3f5a7b9c1d3e5f7a9b1c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release qualification records consistent with MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used with documented release notes, regression test suite results, and version-locked configuration files. All SQA artifacts meet Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via manufactured solution or benchmark comparison at MRL 2.",
      "rationale": "Code verification confirmed through published FDA benchmark challenge results (Hariharan et al. 2011) and internal manufactured-solution tests for the k-omega SST turbulence model. Residuals converged to below 1e-5 in all cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; GCI < 5% acceptable at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (coarse 2.1M, medium 5.4M, fine 11.8M cells). GCI for normalized index of hemolysis = 3.2%, within the 5% threshold. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with sufficient fidelity to reproduce in simulation; uncertainty in inlet flow and rotational speed < 5%.",
      "rationale": "FDA experimental data includes measured inlet flow rates (±2.1%), rotational speeds (±0.8%), and fluid properties (bovine blood, hematocrit 33±1%). Boundary conditions applied directly from published dataset with documented uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bands.",
      "rationale": "Predicted normalized index of hemolysis agreed with experimental values within 12% across 6 operating conditions, within combined uncertainty (simulation GCI 3.2% + experimental 8.4%). Worst-case operating point correctly identified at 3500 RPM, 5 L/min."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (normalized index of hemolysis, shear stress distribution) must be directly linked to the device safety claim.",
      "rationale": "Normalized index of hemolysis (NIH) and area-weighted mean shear stress are the primary QoIs. Both are directly used in the Class II CPB device safety submission and map to the worst-case hemolysis claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, fluid, and operating envelope as the intended regulatory submission.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under bovine blood conditions spanning the full CPB operating envelope (2000–5000 RPM, 2–8 L/min). Geometry and fluid match the device submission scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Acceptable at MRL 2 without formal round-off and iterative convergence error quantification beyond standard residual monitoring.",
      "rationale": "At MRL 2, solver error beyond residual convergence monitoring is not required. Residuals converged to 1e-5; no additional round-off error analysis performed. Scoped out per MRL 2 requirements table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use-error analysis not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at Model Risk Level 2. Standard analyst training records and simulation SOPs are on file but formal use-error FMEA was not conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model-form uncertainty quantification not required at MRL 2.",
      "rationale": "The k-omega SST turbulence model was selected based on published literature for blood pump CFD. Formal model-form uncertainty quantification (e.g., multiple turbulence model comparison with UQ) is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal sensitivity analysis of model inputs not required at MRL 2.",
      "rationale": "Nominal blood viscosity and density values from published literature were used. Formal parametric sensitivity analysis of input uncertainty propagation is not required at MRL 2 and was deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2.",
      "rationale": "FDA benchmark dataset uses a single pump specimen. Sample-to-sample variability assessment is not required at MRL 2. Single-specimen validation is acceptable for this credibility level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation and deployment input spaces not required at MRL 2.",
      "rationale": "The validation and deployment operating envelopes overlap substantially. Formal equivalency analysis is not required at MRL 2; qualitative overlap assessment was documented in the simulation plan."
    }
  ],
