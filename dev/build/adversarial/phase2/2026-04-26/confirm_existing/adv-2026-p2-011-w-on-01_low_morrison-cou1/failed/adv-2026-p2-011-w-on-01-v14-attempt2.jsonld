      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization documented at Gradation 1 for MRL 2.",
      "rationale": "Blood analogue fluid (glycerol-water mixture) composition was documented with viscosity measurements. Statistical characterization of sample variability was not performed; acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
