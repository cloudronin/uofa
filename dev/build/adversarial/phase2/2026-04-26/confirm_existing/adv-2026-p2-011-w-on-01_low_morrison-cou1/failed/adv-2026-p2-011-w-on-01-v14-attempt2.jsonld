  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a documented QA plan including version-controlled source, regression test suite, and release notes review. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via benchmark test cases at Gradation 2.",
      "rationale": "Benchmark cases from the ASME V&V 20 suite and FDA nozzle benchmark were reproduced within published tolerances, confirming correct numerical implementation of the incompressible Navier-Stokes solver."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence must be demonstrated with at least three systematically refined meshes and GCI reported at Gradation 2.",
      "rationale": "Three mesh refinement levels (3.2M, 8.7M, 22.1M cells) were evaluated. GCI for hemolysis index QoI was 4.1% on the medium mesh, satisfying the Gradation 2 threshold. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty quantification at Gradation 2.",
      "rationale": "PIV and hemolysis experiments were conducted at 2.5 L/min and 5.0 L/min flow rates matching the CPB operating envelope. Inlet flow rate uncertainty was ±1.8%, pressure uncertainty ±0.5 mmHg, both within Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoIs must be compared to experimental data with quantitative metrics at Gradation 2.",
      "rationale": "Normalized index of hemolysis predictions agreed with experimental measurements within 12% across all operating points. Velocity field comparison via PIV showed mean error below 8% in the rotor passage, satisfying Gradation 2 output comparison requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation must be directly linked to the clinical question of hemolysis risk at Gradation 2.",
      "rationale": "Normalized index of hemolysis and peak shear stress in the rotor passage were selected as primary QoIs. Both are directly linked to red blood cell damage mechanisms and regulatory guidance for CPB device assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must reflect the physics and geometry of the intended use scenario at Gradation 2.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal blood pump geometry under flow conditions representative of CPB operation. Fluid properties matched clinical blood analogue specifications, supporting relevance to the intended use scenario."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error characterization required only at Gradation 1 for MRL 2.",
      "rationale": "At MRL 2, Gradation 1 for numerical solver error is acceptable. Residual convergence to 1e-5 was confirmed for all simulations; formal round-off error quantification was not performed and is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Operator error assessment required only at Gradation 1 for MRL 2.",
      "rationale": "Simulation setup was reviewed by a second analyst for boundary condition and material property consistency. Formal use-error protocol was not applied; this is acceptable at MRL 2 Gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model and constitutive law selection documented at Gradation 1 for MRL 2.",
      "rationale": "SST k-omega turbulence model and power-law hemolysis model were selected based on published literature for centrifugal pump hemolysis prediction. Formal model-form uncertainty quantification was not performed; acceptable at MRL 2."
    },
    {
