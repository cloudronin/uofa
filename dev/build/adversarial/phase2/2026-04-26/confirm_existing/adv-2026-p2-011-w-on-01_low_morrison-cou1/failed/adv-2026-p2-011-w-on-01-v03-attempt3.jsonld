  "signature": "ed25519:b7d3e1f4a2c6d8e0b1c3d5e7f9a2b4c6d8e0f2a4b6c8d0e2f4a6b8c0d2e4f6a8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is covered by a documented software quality assurance plan including version control, regression testing, and release validation reports. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent benchmark comparisons.",
      "rationale": "Code verification was performed via method-of-manufactured-solutions for the incompressible Navier-Stokes solver and the scalar transport equation used for hemolysis index accumulation. Results confirm second-order spatial accuracy consistent with the discretization scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A mesh convergence study must be performed demonstrating that the discretization error in the primary QoI (hemolysis index) is within an acceptable tolerance for MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA generic centrifugal pump geometry. The hemolysis index exhibited monotonic convergence with a GCI of less than 4% on the fine mesh, satisfying MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to allow assessment of their relevance to the simulation boundary conditions.",
      "rationale": "FDA benchmark experimental data were collected under controlled laboratory conditions at flow rates of 2.5 and 5.0 L/min and rotational speeds of 2500 and 3500 RPM. Temperature, fluid viscosity, and hematocrit were documented. Conditions are representative of CPB operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between simulation outputs and experimental measurements must be performed using an appropriate validation metric.",
      "rationale": "Hemolysis index predictions were compared against FDA experimental measurements using the normalized root-mean-square error metric. NRMSE of 8.3% was obtained across all tested operating points, within the acceptance threshold of 15% for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest computed by the simulation must be directly relevant to the clinical or regulatory decision being supported.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the standard regulatory metric for blood pump hemolytic performance. Secondary QoIs include wall shear stress distribution and scalar stress exposure time, both mechanistically linked to red blood cell damage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed under conditions sufficiently similar to the intended use scenario to support credibility claims for MRL 2.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump, which shares the same impeller geometry class as the device under evaluation. Operating conditions span the CPB clinical range. Validation activities are judged relevant to the intended regulatory submission context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative solver convergence must be demonstrated to a level consistent with MRL 2 requirements; formal error quantification not required at MRL 2.",
      "rationale": "Solver residuals were monitored and confirmed to reach steady-state convergence below 1e-5 for all equations. Formal numerical solver error quantification beyond residual monitoring is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required; basic simulation setup review is sufficient.",
      "rationale": "Simulation setup was reviewed by a senior analyst independent of the primary modeler. No use errors were identified. Formal use error quantification is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty need not be formally quantified; selection of governing equations must be documented.",
      "rationale": "The Reynolds-averaged Navier-Stokes equations with the SST k-omega turbulence closure and the power-law hemolysis damage accumulation model (Giersiepen-Wurzinger) were selected based on literature precedent for blood pump CFD. Formal model form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters must be documented; formal sensitivity analysis is not required at MRL 2.",
      "rationale": "All model inputs including fluid density, viscosity, hematocrit, rotational speed, and inlet flow rate were documented with nominal values and sources. Formal input uncertainty propagation is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, the number and selection of experimental test samples need not be formally justified through statistical power analysis.",
      "rationale": "FDA benchmark data include measurements from multiple experimental runs across four operating points. Sample adequacy for MRL 2 is satisfied by the availability of replicate measurements. Formal statistical sample size justification is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a qualitative assessment of the equivalency between simulation inputs and experimental conditions is sufficient.",
      "rationale": "Simulation boundary conditions were set to match the nominal experimental conditions reported in the FDA benchmark dataset. Qualitative equivalency between simulation inputs and test conditions was confirmed by the assessment team. Formal equivalency quantification is not required at MRL 2."
    }
  ],
