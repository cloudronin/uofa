  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a quality management system with documented version control and testing records.",
      "rationale": "ANSYS Fluent v19.2 employed under an ISO 9001-compliant QMS. Version control, regression test suite, and release notes reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases with documented order-of-accuracy results.",
      "rationale": "Fluent v19.2 verified against ASME V&V 20 benchmark cases including lid-driven cavity and backward-facing step. Second-order spatial accuracy confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index and pressure rise; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed (1.2M, 4.8M, 19.2M cells). GCI for normalized index of hemolysis = 3.1% and for pressure rise = 2.7% on the fine mesh, satisfying the acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with measured boundary conditions and fluid properties matching simulation inputs within stated uncertainty bounds.",
      "rationale": "FDA benchmark experimental conditions (flow rate 2.5–7 L/min, rotational speed 2000–3500 RPM, bovine blood analog) are fully documented. Measured inlet/outlet pressures and viscosity values provided as boundary conditions in the CFD model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized hemolysis index, pressure-flow curve) must show agreement within ±20% of experimental values across the operating envelope.",
      "rationale": "Predicted normalized index of hemolysis agreed within 15% of experimental measurements across all 19 operating points. Pressure-flow curves matched within 8%. Comparison methodology follows ASME V&V 20 uncertainty analysis framework."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest computed by the model must directly correspond to the clinical or regulatory decision metrics for CPB hemolysis assessment.",
      "rationale": "Normalized index of hemolysis (NIH) and modified index of hemolysis (MIH) are the primary regulatory metrics for CPB device hemolysis per FDA guidance. Model outputs map directly to these quantities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, representative flow regimes, and equivalent fluid properties as the intended clinical use scenario.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry under CPB-representative flow rates and rotational speeds. Bovine blood analog with matched viscosity used. Geometry, boundary conditions, and flow regime are sufficiently representative of CPB clinical use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and round-off error characterization not required at MRL 2 for this factor.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond standard residual monitoring is not required. Residuals confirmed below 1e-5 for all equations; factor scoped out per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user error assessment not required at MRL 2 for this application.",
      "rationale": "MRL 2 does not mandate a formal use error analysis. Simulation setup reviewed by a second analyst; standard operating procedures followed. Factor not assessed per approved assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification not required at MRL 2.",
      "rationale": "RANS k-omega SST turbulence model selected based on literature consensus for rotating blood pump flows. Formal model form uncertainty quantification deferred; not required at MRL 2 per assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Parametric sensitivity analysis of model inputs not required at MRL 2 for this factor.",
      "rationale": "Nominal input values sourced from FDA benchmark dataset and published material properties. Sensitivity analysis not required at MRL 2; factor not assessed per approved assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability not required at MRL 2.",
      "rationale": "FDA benchmark experimental data used as provided. Sample-to-sample variability characterization not required at MRL 2. Factor not assessed per approved assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between experimental and simulation input parameters not required at MRL 2.",
      "rationale": "Experimental and simulation boundary conditions aligned to the extent documented in the FDA benchmark dataset. Formal equivalency analysis not required at MRL 2; factor not assessed per approved assessment plan."
    }
