      "name": "CFD hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr02",
      "type": "ValidationResult",
      "name": "Pressure-flow curve validation at nominal CPB operating conditions"
    }
  ],
