  "signature": "ed25519:9b1c3d5e7f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA process consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is covered by a vendor-supplied QA plan including regression test suite and version-controlled release notes. Internal usage follows a documented SOP."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must demonstrate solver correctness for relevant flow regimes at MRL 2.",
      "rationale": "Code verification performed using Taylor-Couette flow and lid-driven cavity benchmarks. Numerical solutions converge to analytical results within expected truncation error bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating discretization error below 5% for hemolysis index QoI at MRL 2.",
      "rationale": "Three-level mesh refinement study conducted (coarse 2.1M, medium 4.7M, fine 9.8M elements). Richardson extrapolation yields GCI of 1.8% for hemolysis index; discretization error is well controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to the simulation boundary conditions.",
      "rationale": "FDA benchmark experimental data collected at 2500 and 3500 RPM with flow rates 2–8 L/min. Boundary conditions applied in CFD match reported experimental values within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized index of agreement) between CFD and experimental hemolysis index must meet MRL 2 threshold.",
      "rationale": "Normalized hemolysis index predictions agree with experimental measurements within 15% across all operating points. Systematic bias is below 8%, consistent with MRL 2 acceptance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation must be directly linked to the device safety claim (hemolysis prediction).",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) computed via the power-law hemolysis model. NIH directly supports the device safety claim regarding acceptable blood trauma in CPB use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be sufficiently similar in geometry, fluid properties, and operating regime to the intended use scenario.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under porcine blood-analog conditions. Operating range spans the intended CPB flow and pressure envelope, supporting adequate relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default level 1 accepted.",
      "rationale": "At MRL 2, explicit iterative solver error quantification beyond residual monitoring is not mandated. Residuals converged to 1e-5 for all equations; no further action required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; operator error assessment deferred.",
      "rationale": "MRL 2 does not require formal use-error analysis. Simulation performed by trained analysts following internal SOP; no additional assessment conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model-form uncertainty quantification not required at MRL 2.",
      "rationale": "The k-omega SST turbulence model and power-law hemolysis constitutive model are accepted for this class of blood pump simulation at MRL 2 without formal model-form uncertainty bounding."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal input uncertainty propagation not required at MRL 2.",
      "rationale": "Nominal blood viscosity and density values from literature are applied. Sensitivity to input variability not formally quantified; consistent with MRL 2 scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2.",
      "rationale": "FDA benchmark dataset uses pooled porcine blood from multiple donors. Sample-to-sample variability acknowledged but not statistically characterized; acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between experimental and simulation input parameters not required at MRL 2.",
      "rationale": "Simulation inputs set to match nominal experimental conditions. Formal equivalency assessment deferred; consistent with MRL 2 requirements."
    }
  ],
