      "acceptanceCriteria": "Solver must have documented verification test suite and version control consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 used with documented QA procedures, regression test suite, and controlled release versioning. Meets MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification through method of manufactured solutions or benchmark comparison at MRL 2 level.",
      "rationale": "Fluent Navier-Stokes solver verified against lid-driven cavity and Poiseuille flow benchmarks. Order of accuracy confirmed at 2nd order for velocity and pressure fields."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed on at least three mesh refinement levels with GCI < 5% on QoI.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 8.7 M, 17.1 M cells). GCI on hemolysis index = 3.8%, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with traceable measurement uncertainty at MRL 2.",
      "rationale": "FDA experimental dataset provides fully documented flow rates (2–8 L/min), pressure heads (50–270 mmHg), and fluid properties. Measurement uncertainties reported per ASME PTC 19.1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE) between simulation and experimental QoI within accepted tolerance.",
      "rationale": "Normalized RMSE on hemolysis index = 12.4% across 18 operating points. Pressure-flow curve NRMSE = 4.1%. Both within MRL 2 tolerance bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
