  "signature": "ed25519:b2e4f6a8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2b4c6d8e0f2a4b6c8d0e2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented quality management system with version control and regression testing.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is developed under ISO 9001-compliant QMS. Version control, release notes, and regression test suite documentation were reviewed and found sufficient for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must demonstrate correct implementation of governing equations through method of manufactured solutions or equivalent benchmark comparisons.",
      "rationale": "Code verification completed via method of manufactured solutions for the Navier-Stokes solver. Benchmark comparisons against ASME V&V 20 lid-driven cavity and backward-facing step cases confirm correct implementation at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be estimated and shown to be acceptable relative to the quantity of interest tolerance for hemolysis index prediction.",
      "rationale": "Systematic mesh refinement study conducted over three mesh levels (coarse: 2.1M, medium: 6.8M, fine: 18.4M cells). Richardson extrapolation yields GCI < 3.2% for shear stress distribution. Achieved level exceeds requirement, providing additional confidence margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to reproduce boundary conditions in the computational model.",
      "rationale": "FDA benchmark experimental conditions are fully documented in published literature. Flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), and fluid properties (bovine blood, 37°C) are specified with measurement uncertainties reported."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be quantitatively compared to experimental measurements using an appropriate metric that accounts for experimental uncertainty.",
      "rationale": "Hemolysis index (HI) predictions compared against FDA benchmark experimental data. Validation metric E = |HI_sim - HI_exp| / HI_exp < 15% across all operating points. Comparison accounts for reported experimental uncertainty of ±8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest in the validation activity must be directly relevant to the clinical decision question regarding worst-case hemolysis identification.",
      "rationale": "Hemolysis index and shear stress distribution are the primary quantities of interest, directly mapping to the device performance metric used in regulatory submission. The scalar HI is the accepted surrogate for red blood cell damage in CPB assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must reflect conditions sufficiently similar to the intended use scenario to support extrapolation of credibility conclusions.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry under CPB-representative operating conditions. Geometric and hemodynamic similarity to the device under assessment is documented. Extrapolation distance is judged acceptable for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off errors are not required to be formally quantified at MRL 2 for this factor.",
      "rationale": "Per MRL 2 requirements, formal quantification of numerical solver error beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations; no further assessment scoped at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis is not required at MRL 2 for Class II device assessment at this credibility level.",
      "rationale": "MRL 2 does not mandate formal use error quantification. Analyst training records and simulation protocol adherence are documented in the quality management file but not formally scored."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification is not required at MRL 2 for this application.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) is an accepted industry standard for CPB hemolysis prediction. Formal model form uncertainty analysis is deferred as not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis on model inputs is not required at MRL 2 for this credibility assessment.",
      "rationale": "Input parameters (viscosity, density, hemolysis model constants) are taken from published literature values. Formal sensitivity or uncertainty propagation analysis is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability is not required at MRL 2.",
      "rationale": "FDA benchmark data uses bovine blood from a single source with controlled hematocrit (35%). Sample-to-sample variability characterization is not required at MRL 2 and is not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency assessment between validation and deployment input parameters is not required at MRL 2.",
      "rationale": "Qualitative review of input parameter equivalency between validation scenario and deployment conditions was performed. Formal quantitative equivalency assessment is not required at MRL 2 and has not been conducted."
    }
  ],
