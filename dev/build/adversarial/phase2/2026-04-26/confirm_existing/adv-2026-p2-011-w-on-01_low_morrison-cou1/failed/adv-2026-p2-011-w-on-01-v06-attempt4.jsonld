      "id": "https://uofa.net/synth/validation/cpb-hemolysis-val-result-001",
      "type": "ValidationResult",
      "name": "CFD hemolysis prediction validation against FDA benchmark data"
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-val-result-002",
      "type": "ValidationResult",
      "name": "Worst-case operating point identification validation result"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043478",
