  "signature": "ed25519:b4e2d1f3a6c8095712b4e2d1f3a6c8095712b4e2d1f3a6c8095712b4e2d1f3a6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must demonstrate version control, documented test suite, and traceable build environment consistent with MRL 2 requirements.",
      "rationale": "OpenFOAM v8 with documented version pinning and regression test suite was used. All solver modules relevant to hemolysis computation passed unit and integration tests. SQA documentation archived in project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations via method of manufactured solutions or equivalent benchmark comparison at MRL 2.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver. Observed order of accuracy matched theoretical order for spatial and temporal discretization schemes employed in the hemolysis model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index or equivalent Richardson extrapolation must be reported for primary quantities of interest at MRL 2.",
      "rationale": "Three-level mesh refinement study performed on the FDA generic centrifugal pump geometry. GCI for normalized index of hemolysis was below 5% on the medium mesh selected for production runs, satisfying MRL 2 discretization requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds and shown to bracket the intended operating envelope.",
      "rationale": "FDA benchmark experimental data collected at flow rates of 2.5 and 5.0 L/min with rotational speeds of 2500 and 3500 RPM. Conditions span the CPB operating range. Measurement uncertainties documented per ASME PTC 19.1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric between simulation output and experimental data must be reported with uncertainty propagation at MRL 2.",
      "rationale": "Normalized index of hemolysis compared against experimental measurements using area validation metric. Model predictions fell within experimental uncertainty bounds at all four operating points. Achieved level exceeds requirement due to additional uncertainty quantification performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly traceable to the device safety question and the regulatory decision at MRL 2.",
      "rationale": "Normalized index of hemolysis is the primary QoI and maps directly to the regulatory safety endpoint for CPB devices. Traceability matrix linking simulation outputs to 510(k) submission requirements was established and reviewed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties sufficiently similar to the intended COU to support extrapolation at MRL 2.",
      "rationale": "FDA generic centrifugal pump geometry is representative of the device class. Porcine blood analog used in experiments provides acceptable rheological similarity to human blood under CPB conditions. Relevance documented via similarity assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, numerical solver error beyond discretization error need not be separately quantified if standard iterative convergence criteria are met.",
      "rationale": "Residual convergence to 1e-6 achieved for all equations. Separate solver error quantification not required at MRL 2 and was scoped out of this assessment per ASME V&V 40 Table 1 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use error assessment is not required provided simulation was conducted by qualified personnel following documented procedures.",
      "rationale": "Simulation conducted by personnel with documented CFD training and competency records. Formal use error analysis not required at MRL 2 per ASME V&V 40 credibility factor table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty need not be formally quantified provided the selected constitutive models are consistent with published practice for similar applications.",
      "rationale": "k-omega SST turbulence model and Giersiepen-Wurzinger hemolysis power-law model selected based on published FDA benchmark literature. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model input uncertainty need not be formally propagated provided nominal inputs are traceable to documented sources.",
      "rationale": "Blood viscosity, density, and hemolysis model constants sourced from peer-reviewed literature with documented values. Formal sensitivity analysis not required at MRL 2 per credibility factor table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required provided experimental data source is documented.",
      "rationale": "FDA benchmark experimental data from published inter-laboratory study used. Sample characterization beyond source documentation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency analysis between simulation inputs and experimental conditions is not required provided qualitative consistency is documented.",
      "rationale": "Simulation boundary conditions set to match nominal experimental operating points. Qualitative consistency between simulation and experimental inputs confirmed. Formal equivalency analysis not required at MRL 2."
    }
  ],
