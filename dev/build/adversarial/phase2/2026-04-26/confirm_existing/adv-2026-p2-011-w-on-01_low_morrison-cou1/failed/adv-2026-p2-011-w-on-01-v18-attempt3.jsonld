      "name": "CFD hemolysis prediction validation against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr-002",
      "type": "ValidationResult",
      "name": "Worst-case operating condition identification validation result"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034998",
