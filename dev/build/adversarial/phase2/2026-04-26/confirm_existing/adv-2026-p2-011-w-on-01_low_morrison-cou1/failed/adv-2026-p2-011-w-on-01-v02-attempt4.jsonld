  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control and regression testing documented for the CFD solver used in hemolysis simulations.",
      "rationale": "ANSYS Fluent 2022 R2 employed with documented version control, regression test suite results archived, and QA procedures conforming to ISO 9001 requirements for Class II device simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via method of manufactured solutions or benchmark problems demonstrating correct implementation of governing equations.",
      "rationale": "Solver verified against ASME V&V 20 benchmark cases for incompressible Navier-Stokes; manufactured solution tests confirm spatial and temporal order of accuracy within expected bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; discretization error bounded below 5% of reported quantity.",
      "rationale": "Three-level mesh refinement study conducted on the FDA centrifugal pump geometry; GCI for hemolysis index QoI is 3.2%, satisfying the MRL 2 discretization error threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented and traceable to calibrated instrumentation.",
      "rationale": "FDA benchmark experimental conditions at 2500 RPM and 5 L/min flow rate reproduced; blood analog viscosity and density measured with calibrated instruments, uncertainty quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) between simulation and experimental hemolysis index within acceptable tolerance.",
      "rationale": "Normalized RMS error for hemolysis index is 8.4% across five operating conditions; pressure-flow characteristic agreement within 4.1%. Both metrics exceed MRL 2 requirements, achieving MRL 3 output comparison standard."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) directly linked to clinical endpoint of red blood cell damage in CPB device.",
      "rationale": "Hemolysis index and volume-averaged scalar shear stress are established surrogates for RBC damage; direct linkage to 510(k) biocompatibility endpoint documented in device risk analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at flow conditions and geometries sufficiently representative of the intended CPB operating envelope.",
      "rationale": "FDA generic centrifugal pump geometry and CPB-range operating conditions (2000–3500 RPM, 3–7 L/min) used in validation; conditions span the intended clinical operating envelope for adult CPB."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iteration convergence residuals reported; not required to be independently characterized at MRL 2 for this factor.",
      "rationale": "At MRL 2, independent characterization of numerical solver error beyond standard residual monitoring is not required. Residuals converged to 1e-6 for all simulations; factor scoped to not-assessed per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment not required at MRL 2 for Class II device with Medium assurance level.",
      "rationale": "MRL 2 assessment does not require formal use error analysis. Simulation workflow reviewed by senior analyst; standard operating procedures followed. Formal use error characterization deferred to MRL 3 if risk level is elevated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty assessment not required at MRL 2; turbulence model selection documented.",
      "rationale": "SST k-omega turbulence model selected based on published literature for rotating blood-contacting devices. Formal model form uncertainty quantification not required at MRL 2; selection rationale documented in simulation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs (fluid properties, boundary conditions) documented with sources; formal sensitivity analysis not required at MRL 2.",
      "rationale": "Blood analog properties sourced from ASTM F1841; boundary conditions derived from calibrated flow loop measurements. Input documentation meets MRL 2 standard without formal probabilistic sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample characterization not required at MRL 2 for computational benchmark comparison using standardized FDA geometry.",
      "rationale": "FDA generic centrifugal pump is a standardized reference geometry; physical sample variability characterization not applicable to benchmark validation activity. Factor not assessed per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment and clinical use not required at MRL 2.",
      "rationale": "Operating conditions in validation experiments are directly matched to simulation inputs; formal equivalency analysis beyond parameter matching not required at MRL 2. Parameter correspondence table documented in technical report."
    }
