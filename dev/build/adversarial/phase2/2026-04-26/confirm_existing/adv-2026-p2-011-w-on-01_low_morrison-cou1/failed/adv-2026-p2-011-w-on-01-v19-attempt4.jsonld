  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression testing suite, and documented QA procedures verified for ANSYS Fluent 2023 R1.",
      "rationale": "The CFD solver used (ANSYS Fluent 2023 R1) operates under an ISO 9001-certified QA framework. Regression test suite covering 47 benchmark cases was reviewed and all cases passed within tolerance. Version control logs confirmed no mid-study solver updates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing on canonical flows demonstrates solver convergence consistent with stated discretization scheme.",
      "rationale": "Order-of-accuracy tests on lid-driven cavity and pipe flow benchmarks confirmed second-order spatial accuracy for the pressure-velocity coupling scheme. Results are consistent with published solver documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI is below 5% on the fine-grid solution.",
      "rationale": "Three-level mesh refinement study performed (coarse: 4.2 M cells, medium: 11.7 M cells, fine: 31.4 M cells). GCI for the normalized index of hemolysis was 3.1% between medium and fine grids. Fine-grid solution adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, inlet pressure, fluid temperature, hematocrit) are documented and match simulation inputs within stated uncertainty bands.",
      "rationale": "FDA benchmark experimental conditions (flow rates 2.5–7 L/min, rotational speeds 2000–3500 RPM, bovine blood at 37°C, Hct 33±2%) are fully documented in the experimental protocol. Simulation boundary conditions were set to match these values within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) agrees with experimental measurements within a factor of 2 across all operating points.",
      "rationale": "Predicted NIH values compared against five experimental operating points. Mean absolute relative error was 28%, with all predictions within a factor of 1.8 of experimental measurements. Pressure-rise predictions agreed within 6% across the full flow-rate range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis) is directly linked to the device safety endpoint used in regulatory submission.",
      "rationale": "NIH is the clinically accepted metric for blood trauma in CPB devices and maps directly to the ISO 10993-4 biocompatibility endpoint. The QoI selection is consistent with FDA guidance on hemolysis testing for blood-contacting devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry, fluid analogue, and operating envelope as the intended simulation use.",
      "rationale": "Validation data were collected on the FDA generic centrifugal blood pump — the identical geometry used in production simulations. Bovine blood at physiological hematocrit was used, consistent with the intended CPB operating conditions. The operating envelope spans the full clinical flow range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "At Model Risk Level 2, explicit iterative solver error quantification beyond residual monitoring is not mandated. Residuals converged to 1e-5 for all equations; this is deemed sufficient for MRL 2."
    },
