  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must demonstrate version control, documented testing, and traceable build records consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented QA procedures, version control, and regression test suites. SQA level 2 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or established benchmarks for relevant flow regimes at the required gradation level.",
      "rationale": "Code verification performed using Taylor-Green vortex and lid-driven cavity benchmarks. Convergence to analytical solutions confirmed. Gradation 2 achieved for incompressible viscous flow."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via systematic mesh refinement study with GCI or equivalent metric, meeting MRL 2 threshold.",
      "rationale": "Three-level mesh refinement study conducted (coarse: 2.1M, medium: 6.8M, fine: 18.4M cells). GCI computed at 1.4% for hemolysis index QoI. Achieves gradation 3, exceeding requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to enable replication and must span the operating envelope relevant to the model.",
      "rationale": "FDA generic pump experimental data collected at flow rates 2.5–7.5 LPM and rotational speeds 2500–4500 RPM. Test conditions documented in FDA benchmark protocol with uncertainty quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model outputs must be compared quantitatively to experimental measurements using appropriate metrics, with agreement within defined tolerance at required gradation.",
      "rationale": "Hemolysis index predictions compared to FDA experimental measurements across 9 operating points. Mean absolute error of 12% within the accepted tolerance for MRL 2. Pressure-flow characteristic agreement within 8%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the clinical decision being supported and must be traceable to the device risk assessment.",
      "rationale": "Hemolysis index (normalized index of hemolysis, NIH) is the primary QoI, directly linked to red blood cell damage risk in CPB applications. QoI relevance confirmed by clinical advisory review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the intended use environment to support extrapolation of credibility evidence.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry under blood-analog fluid conditions spanning CPB operating range. Geometric and fluid similarity to clinical CPB application confirmed at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Numerical solver error assessment not required at MRL 2 for this factor; default gradation 1 accepted per ASME V&V 40 Table 4.",
      "rationale": "Per ASME V&V 40 MRL 2 requirements, formal numerical solver error quantification beyond residual convergence monitoring is not required. Residuals converged to 1e-5 for all equations. Factor scoped to gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment not required at MRL 2; analyst training records and simulation setup checklists are sufficient at this risk level.",
      "rationale": "Analyst training records on file. Simulation setup followed documented SOPs with independent review of boundary condition inputs. Formal use error quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty assessment not required at MRL 2; selection of k-omega SST turbulence model with power-law hemolysis model is documented and justified.",
      "rationale": "k-omega SST turbulence model selected based on published literature for rotating machinery. Power-law hemolysis model (Giersiepen correlation) applied. Model form assessment deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model input uncertainty propagation not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and pump geometry sourced from FDA benchmark documentation. Nominal values used without formal uncertainty propagation per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization at gradation 1 requires only that sample provenance and basic properties are documented.",
      "rationale": "FDA benchmark experimental data obtained from published FDA interlaboratory study. Sample provenance documented. Detailed sample-to-sample variability analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency of input parameters between validation and use conditions assessed at gradation 1 by qualitative mapping of boundary conditions.",
      "rationale": "Qualitative mapping of validation boundary conditions to CPB operating envelope completed. Inlet flow rates and rotational speeds within validation domain. Formal equivalency metric not required at MRL 2."
    }
  ],
