  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2f4a6b8d0f2a4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 or equivalent QMS certification covering version control, regression testing, and release documentation.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under a documented QMS with traceable version control and automated regression suite; achieved level meets required level 2 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass published benchmark verification cases (lid-driven cavity, Taylor-Green vortex) at second-order convergence.",
      "rationale": "ANSYS Fluent verification suite confirms second-order spatial accuracy on all relevant benchmark problems; requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for shear stress QOI must be below 5% on the fine-grid solution.",
      "rationale": "Three-level mesh refinement study yielded GCI of 3.2% for wall shear stress at the impeller tip; discretization error within acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench test flow rates and rotational speeds must bracket the intended CPB operating envelope (3–6 L/min, 2000–3500 RPM).",
      "rationale": "FDA bench experiments covered 2.5–6.5 L/min at 1800–3600 RPM, fully enclosing the target operating envelope; test conditions requirement met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with bench measurements within 20% across all test points.",
      "rationale": "Model NIH predictions fell within 12% of measured values across all 18 test conditions; achieved level exceeds minimum requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs (NIH, scalar stress exposure) must be directly linked to the hemolysis failure mode identified in the device risk analysis.",
      "rationale": "NIH and cumulative scalar stress are the primary hemolysis metrics cited in the device FMEA; QOI relevance confirmed at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analogue fluid as the intended clinical configuration.",
      "rationale": "FDA bench tests used the identical generic centrifugal pump CAD geometry and a glycerol-water blood analogue at matched viscosity; validation relevance established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual below 1e-5 for all transport equations is sufficient at MRL 2; formal solver error quantification not required.",
      "rationale": "At MRL 2 the required level is 1; residual monitoring logs confirm convergence to 1e-6; formal solver error bounding not performed and not required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Standard operating procedure for simulation setup reviewed by one independent analyst; formal use-error study not required at MRL 2.",
      "rationale": "SOP review completed by independent CFD analyst; full use-error quantification not required at MRL 2 and not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Selection of turbulence closure (SST k-omega) and hemolysis power-law model must be documented with literature justification; formal sensitivity not required at MRL 2.",
      "rationale": "Model form choices documented with reference to Giersiepen power-law and Menter SST literature; formal model-form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions (inlet velocity, outlet pressure) must be traceable to bench test measurements; formal input uncertainty propagation not required at MRL 2.",
      "rationale": "Inlet and outlet BCs sourced directly from bench measurement reports with traceability; propagation of input uncertainty not required at MRL 2 and not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At least one lot of blood analogue with documented viscosity characterization; statistical sample-size analysis not required at MRL 2.",
      "rationale": "Single lot glycerol-water analogue with viscometry report used; sample-size statistical analysis not required at MRL 2 and not conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional similarity (Reynolds number matching) between bench and simulation must be documented; formal equivalency study not required at MRL 2.",
      "rationale": "Reynolds number correspondence between bench and CFD configurations documented in the simulation report; formal equivalency analysis not required at MRL 2."
