      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA process consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is operated under a documented software QA plan including version control, regression testing, and configuration management. Achieved level meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must demonstrate correct implementation of governing equations through benchmark problems at MRL 2.",
      "rationale": "Code verification performed using Method of Manufactured Solutions on canonical pipe flow and rotating cavity benchmarks. Observed convergence rates consistent with theoretical order of accuracy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrating discretization error within acceptable bounds for hemolysis QoI at MRL 2.",
      "rationale": "Richardson extrapolation-based grid convergence index computed across three mesh refinement levels. GCI for hemolysis index QoI is 3.2%, within the MRL 2 threshold of 5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to relevant operating regimes.",
      "rationale": "FDA benchmark pump experiments conducted at 2500 RPM and 5 L/min flow rate under controlled laboratory conditions. Test conditions are fully documented and traceable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric between simulation outputs and experimental data must demonstrate acceptable agreement at MRL 2.",
      "rationale": "Normalized RMS error between predicted and measured hemolysis index is 8.4% across five operating points. Pressure-flow curve agreement within experimental uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the decision question at MRL 2.",
      "rationale": "Hemolysis index and shear stress distribution are the primary QoIs, directly linked to the device safety decision question of identifying worst-case hemolysis operating conditions."
