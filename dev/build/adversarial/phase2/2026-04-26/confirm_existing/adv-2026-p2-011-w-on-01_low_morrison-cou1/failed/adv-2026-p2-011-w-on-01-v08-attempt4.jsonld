  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is operated under a documented software QA plan including version control, regression testing, and release validation records. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations at MRL 2 through benchmark problems.",
      "rationale": "Numerical code verification performed using standard CFD benchmark cases including lid-driven cavity and pipe flow. Order-of-accuracy studies confirm correct discretization implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified and shown to be within acceptable bounds for MRL 2 hemolysis prediction.",
      "rationale": "Mesh convergence study performed across three mesh refinement levels (4.2M, 8.7M, 16.1M elements). Richardson extrapolation applied; GCI values below 3.2% for shear stress and velocity fields. Achieved level exceeds required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to allow comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark experimental conditions are fully documented including flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), and blood analog fluid properties. Boundary conditions mapped directly from experimental protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively against experimental measurements with documented metrics.",
      "rationale": "Pressure rise and hemolysis index (normalized index of hemolysis, NIH) compared against published FDA benchmark data. Mean absolute error for pressure rise is 4.1%; NIH predictions within 18% of experimental values across operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be directly relevant to the hemolysis safety decision for the CPB device.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH), which is the regulatory-accepted metric for blood damage assessment in CPB devices. Secondary QoI includes shear stress distribution and exposure time, both directly linked to hemolysis mechanisms."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently representative of the intended use conditions to support the credibility claim.",
      "rationale": "Validation performed using FDA generic centrifugal blood pump geometry under flow and speed conditions spanning the intended CPB operating envelope. Fluid properties representative of clinical blood analogs used in regulatory submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed numerical solver error quantification beyond code verification is not required; default level 1 is acceptable.",
      "rationale": "Numerical solver error factor scoped to not-assessed at MRL 2. Iterative convergence monitored via residual norms (below 1e-5 for all equations); no additional solver error characterization required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment not required at MRL 2 for this device class.",
      "rationale": "Use error factor not assessed at MRL 2. Simulation workflow is executed by trained CFD engineers following documented simulation plan; operator error controls are addressed through QA procedures captured under software quality assurance factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification not required at MRL 2; selection of turbulence and hemolysis models documented.",
      "rationale": "Model form factor not assessed at MRL 2. SST k-omega turbulence model selected based on published literature for rotating machinery hemolysis prediction. Giersiepen-Wurzinger hemolysis power law model applied consistently with prior FDA submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Detailed model input uncertainty propagation not required at MRL 2; nominal input values must be documented.",
      "rationale": "Model inputs factor not assessed at MRL 2. All material properties (blood analog viscosity, density) and geometric parameters sourced from FDA benchmark documentation and recorded in the simulation plan. Sensitivity to input variation not quantified at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Detailed test sample characterization not required at MRL 2 for computational validation using published benchmark data.",
      "rationale": "Test samples factor not assessed at MRL 2. FDA benchmark experimental data used as published; sample-level variability characterization not available from the public dataset and not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis of simulation inputs to experimental conditions not required at MRL 2.",
      "rationale": "Equivalency of input parameters not formally assessed at MRL 2. Simulation boundary conditions are directly mapped from published experimental protocols; qualitative equivalency confirmed by engineering review without formal uncertainty-based equivalency analysis."
    }
  ],
