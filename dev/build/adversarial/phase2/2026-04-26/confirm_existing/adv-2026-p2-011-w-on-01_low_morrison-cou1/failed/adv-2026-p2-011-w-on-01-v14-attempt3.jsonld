      "type": "ValidationResult",
      "name": "CFD hemolysis index vs. experimental NIH measurement"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-rise-comparison-001",
      "type": "ValidationResult",
      "name": "Pump pressure-rise characteristic validation against bench data"
    }
  ],
