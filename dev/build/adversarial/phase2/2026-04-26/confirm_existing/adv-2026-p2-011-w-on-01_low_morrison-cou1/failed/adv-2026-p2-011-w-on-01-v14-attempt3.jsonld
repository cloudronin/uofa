  "signature": "ed25519:9c4a2f1e8b3d6a7c0f5e2b9d4a1c8f3e6b0d7a4c1f8e5b2d9a6c3f0e7b4d1a8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD analysis must be verified under a documented QA plan with version control and regression testing.",
      "rationale": "ANSYS Fluent 2022 R2 was employed under an ISO 9001-compliant QA framework with documented version control, regression test suite, and release notes reviewed by the analysis team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via manufactured solutions or benchmark problems.",
      "rationale": "Code verification was confirmed through published ASME V&V 20 benchmark results for laminar and turbulent pipe flow; solver passed all benchmark cases within specified tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (hemolysis index) and must be below 5%.",
      "rationale": "Three-level mesh refinement study conducted on 4.2M, 8.7M, and 17.1M cell meshes. GCI for hemolysis index was 3.1%, satisfying the acceptance criterion. Medium mesh (8.7M) selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must be documented and traceable to calibrated measurement equipment.",
      "rationale": "Flow rate, rotational speed, and inlet pressure were measured with calibrated instruments (NIST-traceable) during FDA pump bench testing. Uncertainty bounds reported and applied as CFD boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized index of agreement) must exceed 0.85 for hemolysis index across all tested operating points.",
      "rationale": "Normalized index of agreement of 0.91 achieved across 12 operating points spanning 2–6 L/min and 2500–4500 RPM. CFD predictions fell within experimental uncertainty bounds at 10 of 12 points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress distribution) must be the same quantities used in the device risk decision.",
      "rationale": "Normalized index of hemolysis (NIH) and volume-averaged scalar shear stress were selected as primary QoIs, directly corresponding to the regulatory submission metrics for blood damage assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope of the intended CPB use (2–6 L/min, 2500–4500 RPM).",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry under the same flow and speed conditions as the target CPB operating envelope, providing direct relevance to the device assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must be below 1e-5 for all transport equations.",
      "rationale": "At MRL 2, detailed solver error quantification beyond standard residual monitoring is not required. Residuals were monitored and confirmed below 1e-5 as a baseline practice."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst training and simulation workflow review sufficient for MRL 2.",
      "rationale": "At MRL 2, formal use-error analysis is not required. Analysts hold relevant CFD credentials and followed documented simulation protocols."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification not required at MRL 2; turbulence model selection must be documented.",
      "rationale": "SST k-omega turbulence model selected based on published literature for rotating blood pump flows. Formal model-form uncertainty quantification deferred as not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters (viscosity, density) must be documented; sensitivity analysis not required at MRL 2.",
      "rationale": "Blood analog fluid properties (density 1056 kg/m³, dynamic viscosity 0.0035 Pa·s) taken from published standards. Parametric sensitivity not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample characterization sufficient to confirm fluid property consistency; statistical sampling not required at MRL 2.",
      "rationale": "Blood analog (glycerol-water mixture) was prepared per published protocol. Batch consistency verified by viscometry. Statistical sample-size analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation inputs and experimental conditions must be documented; formal equivalency mapping not required at MRL 2.",
      "rationale": "Simulation boundary conditions were set to match nominal experimental values. Formal equivalency uncertainty propagation not required at MRL 2; correspondence documented in the simulation report."
    }
