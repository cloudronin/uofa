      "rationale": "ANSYS Fluent 2023R1 used with documented version control, regression test suite, and ISO 9001-compliant QA procedures. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
