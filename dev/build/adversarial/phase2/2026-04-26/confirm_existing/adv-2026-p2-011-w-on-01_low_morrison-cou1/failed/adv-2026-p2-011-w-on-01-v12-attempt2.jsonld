      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is verified under a documented QA plan including version control, regression testing, and traceability to solver release notes.",
      "rationale": "ANSYS Fluent 2023R1 is used under an ISO 9001-compliant QA framework. Regression test suite covers all turbulence models and boundary condition types employed in this study. Version control logs confirm consistent solver version throughout the analysis campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark cases relevant to rotating-frame turbulent flow, demonstrating correct implementation of governing equations.",
      "rationale": "ANSYS Fluent has been verified against ASME V&V 20 benchmark cases for internal turbulent flow and rotating-reference-frame problems. Published verification reports confirm second-order spatial accuracy for the pressure-velocity coupling scheme used."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "Three mesh levels (4.2M, 9.8M, 21.4M elements) were evaluated using Richardson extrapolation. GCI for normalized hemolysis index is 3.1% between medium and fine meshes. Medium mesh selected for production runs balancing accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) are documented with measurement uncertainty and replicated in the CFD model within stated tolerances.",
      "rationale": "FDA experimental dataset specifies inlet flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), and blood analog fluid properties with calibrated measurement uncertainty. CFD boundary conditions are set to match experimental nominal values; sensitivity to boundary condition uncertainty is quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure-flow characteristics agree with experimental data within combined simulation and experimental uncertainty bands.",
      "rationale": "Normalized index of hemolysis (NIH) predictions fall within ±18% of experimental measurements across all tested operating points, consistent with inter-laboratory variability reported in FDA round-robin studies. Pressure-flow curves match within 5% at design-point conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, scalar shear stress distribution, exposure time) are directly linked to hemolysis prediction and worst-case operating condition identification.",
      "rationale": "NIH is the regulatory-accepted metric for blood trauma assessment. Scalar shear stress and exposure time feed directly into the power-law hemolysis model. These QoIs are standard in FDA guidance for CFD assessment of blood-contacting devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same FDA generic pump geometry, comparable operating envelope, and blood analog fluid, providing direct applicability to the COU.",
      "rationale": "Validation uses the FDA benchmark centrifugal pump geometry under the same operating envelope as the CPB application scenario. Blood analog (glycerin-water) properties are matched to physiological blood viscosity. The validation scenario is judged directly relevant to the intended decision context."
    },
    {
      "type": "CredibilityFactor",
