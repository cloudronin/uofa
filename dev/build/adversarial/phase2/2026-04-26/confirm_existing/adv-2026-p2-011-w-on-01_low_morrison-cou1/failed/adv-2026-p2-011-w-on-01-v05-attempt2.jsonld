      "name": "CFD hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr-002",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic validation across operating envelope"
    }
  ],
