  "signature": "ed25519:b4e2d1f3a6c8b0e5d2f7a4c1b8e3d6f9a2c5b0e7d4f1a8c3b6e9d2f5a0c7b4e1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented QA procedures and regression test suite.",
      "rationale": "OpenFOAM v8 used with institutional version control, documented build environment, and automated regression tests covering relevant turbulence and scalar transport cases. QA procedures satisfy MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via method of manufactured solutions or equivalent for governing equations relevant to hemolysis prediction.",
      "rationale": "Method of manufactured solutions applied to incompressible Navier-Stokes and passive scalar transport equations. Observed convergence rates consistent with second-order spatial discretization. No code defects identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with at least three systematically refined meshes; GCI reported for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study conducted (6.2M, 14.7M, 31.4M cells). Richardson extrapolation applied; GCI for normalized index of hemolysis at worst-case operating point is 3.8%, within acceptable threshold. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with sufficient detail to enable replication; boundary conditions traceable to physical measurements.",
      "rationale": "FDA benchmark experimental conditions fully documented per ASTM F1841. Inlet flow rates, rotational speeds, and blood analog fluid properties recorded with calibrated instrumentation. Boundary conditions directly derived from reported measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined and applied between simulation outputs and experimental measurements for primary QoI.",
      "rationale": "Normalized index of hemolysis compared using E_rel metric across five operating conditions. Mean relative error of 12.4% observed, consistent with inter-laboratory variability reported in FDA benchmark study. Comparison deemed adequate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the decision-relevant outputs of the model.",
      "rationale": "Normalized index of hemolysis and pressure-head are the primary regulatory QoIs for CPB device assessment. Both are directly computed from the CFD solution and compared against experimental measurements. Relevance established by clinical literature and FDA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must reflect geometry, flow regime, and fluid properties representative of the intended use scenario.",
      "rationale": "FDA generic centrifugal pump geometry used in validation is representative of the device class. Blood analog fluid (glycerol-water, matched viscosity) and operating envelope (2–8 L/min, 2500–3500 RPM) cover CPB clinical range. Validation activities judged sufficiently relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iterative convergence documented to level consistent with MRL 1 expectation.",
      "rationale": "At MRL 2, explicit quantification of numerical solver error beyond residual monitoring is not required. Residuals reduced by six orders of magnitude in all simulations; no further assessment warranted at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment not required at MRL 2 for this factor.",
      "rationale": "MRL 2 does not mandate formal use error analysis. Simulation setup reviewed by independent analyst; no use errors identified. Factor scoped out per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty acknowledgment sufficient at MRL 2.",
      "rationale": "SST k-omega turbulence model selected based on published literature for rotating machinery hemolysis prediction. Formal model form uncertainty quantification not required at MRL 2. Selection rationale documented in simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs identified and nominal values documented; sensitivity analysis not required at MRL 2.",
      "rationale": "Fluid density, viscosity, and power-law hemolysis model constants identified as primary inputs. Nominal values sourced from peer-reviewed literature. Formal sensitivity analysis deferred per MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization documented at level consistent with MRL 2.",
      "rationale": "Blood analog fluid preparation documented per ASTM F1841. Sample variability not formally characterized; sufficient for MRL 2. Factor acknowledged as not-assessed per assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental and simulation input parameters documented at MRL 2 level.",
      "rationale": "Operating conditions in simulation match reported experimental values within measurement uncertainty. Formal equivalency analysis not required at MRL 2. Correspondence table provided in technical report appendix."
    }
  ],
