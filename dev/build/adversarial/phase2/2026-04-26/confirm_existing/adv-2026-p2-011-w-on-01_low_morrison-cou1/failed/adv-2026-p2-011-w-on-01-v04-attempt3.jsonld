  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented SQA plan consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent) was operated under a documented SQA plan including version control, regression testing, and user qualification records. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against known analytical solutions or benchmark problems to confirm correct implementation of governing equations.",
      "rationale": "The solver was verified against canonical benchmark cases including lid-driven cavity and Poiseuille flow. Order-of-accuracy testing confirmed correct discretization of the Navier-Stokes equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via mesh refinement study; GCI or equivalent metric must be reported and within acceptable bounds for MRL 2.",
      "rationale": "A three-level mesh refinement study was performed on the FDA centrifugal pump geometry. GCI values for hemolysis index were below 5%, confirming discretization error is adequately controlled at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and sufficiently characterized to allow comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark experimental conditions (flow rate, rotational speed, fluid properties) were fully documented in the published dataset. Boundary conditions in the CFD model were set to match experimental values within reported tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively to experimental measurements; agreement metric must be defined and reported.",
      "rationale": "Hemolysis index predictions were compared to FDA experimental measurements at five operating points. Mean absolute error was 8.3%, within the acceptance threshold of 15% established for MRL 2 comparative assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (QoI) computed by the model must be relevant to the device safety and performance question being addressed.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the accepted metric for blood damage in CPB devices per ASTM F1841. This QoI directly supports the worst-case operating condition identification objective."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently relevant to the intended use conditions to support credibility of model predictions within the COU.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry under flow and rotational speed conditions spanning the CPB operating envelope. The validation domain overlaps substantially with the intended simulation conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off errors are acknowledged; formal quantification not required at MRL 2 for this factor.",
      "rationale": "At MRL 2, formal quantification of numerical solver error beyond residual monitoring is not required. Residuals were converged to 1e-5 for all equations, satisfying the minimum expectation at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User error assessment not required at MRL 2; basic documentation of analyst qualifications is sufficient.",
      "rationale": "Analyst qualifications were documented under the SQA plan. Formal use-error assessment is scoped out at MRL 2 per the ASME V&V 40 credibility factor table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty need not be formally quantified at MRL 2; selection of turbulence model and hemolysis model must be documented.",
      "rationale": "The SST k-omega turbulence model and the Giersiepen-Wurzinger hemolysis power-law model were selected based on published literature for similar pump geometries. Formal model-form uncertainty quantification is not required at MRL 2."
    },
