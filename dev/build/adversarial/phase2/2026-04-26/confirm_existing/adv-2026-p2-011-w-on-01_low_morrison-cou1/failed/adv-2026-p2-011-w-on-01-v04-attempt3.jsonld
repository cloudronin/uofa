      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of test samples used in validation experiments must be documented; statistical sampling requirements are minimal at MRL 2.",
      "rationale": "The FDA benchmark dataset documents the use of porcine blood analog fluid. Sample characterization data are available in the published experimental record. No additional sample characterization is required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
