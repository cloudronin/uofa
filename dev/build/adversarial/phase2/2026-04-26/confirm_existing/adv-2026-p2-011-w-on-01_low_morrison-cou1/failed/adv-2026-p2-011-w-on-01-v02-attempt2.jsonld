  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented quality management system consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is operated under a documented SQA plan including version control, regression testing, and change management. All SQA records are archived and traceable. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical or manufactured solutions to confirm correct implementation of governing equations at MRL 2.",
      "rationale": "Code verification performed using method of manufactured solutions for the Navier-Stokes solver and the hemolysis power-law model. Results confirm correct numerical implementation within expected tolerances. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be estimated using a systematic mesh refinement study with at least three mesh densities at MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA generic centrifugal pump geometry. Richardson extrapolation applied; grid convergence index (GCI) for hemolysis index QoI is below 5% on the medium mesh selected for production runs. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to reproduce the boundary conditions in the simulation at MRL 2.",
      "rationale": "FDA benchmark experimental conditions (flow rates 2.5–7.5 L/min, rotational speeds 2000–3500 RPM, blood analog fluid properties) are fully documented in the published protocol. Simulation boundary conditions are set to match experimental conditions with documented uncertainty bounds. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be quantitatively compared to experimental measurements using defined metrics at MRL 2.",
      "rationale": "Hemolysis index predictions compared to FDA benchmark experimental measurements across six operating conditions. Mean absolute error of 12% with no systematic bias detected. Comparison metrics include normalized index of agreement and root mean square error. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest computed by the model must be relevant to the clinical or engineering decision being supported at MRL 2.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the accepted clinical metric for blood damage in CPB devices per ISO 10993-4 and FDA guidance. Secondary QoIs include wall shear stress and exposure time distributions. All QoIs are directly relevant to hemolysis risk assessment. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently representative of the intended use conditions to support the credibility claim at MRL 2.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under flow and rotational speed conditions spanning the intended CPB operating envelope. Blood analog fluid used in experiments has documented rheological similarity to human blood. Validation activities are judged sufficiently relevant to support MRL 2 credibility. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Numerical solver error assessment not required at MRL 2 beyond code verification activities already completed.",
      "rationale": "At MRL 2, separate numerical solver error quantification beyond the code verification and discretization error assessments already performed is not required. This factor is scoped to the minimum level and is acceptable for the current model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error assessment not required at MRL 2.",
      "rationale": "At MRL 2, a formal use error analysis is not required. Simulation execution is performed by trained engineers following documented standard operating procedures. This factor is acceptable at the minimum level for the current model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification not required at MRL 2 beyond the validation comparison already performed.",
      "rationale": "At MRL 2, explicit model form uncertainty quantification beyond what is captured in the output comparison is not required. The power-law hemolysis model is the accepted standard for this application. This factor is acceptable at the minimum level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model input uncertainty propagation not required at MRL 2.",
      "rationale": "At MRL 2, formal uncertainty propagation of model inputs is not required. Input parameters (fluid viscosity, density, hemolysis model coefficients) are taken from published literature values with documented provenance. This factor is acceptable at the minimum level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Detailed characterization of test sample variability not required at MRL 2.",
      "rationale": "At MRL 2, detailed characterization of test sample biological variability is not required. The FDA benchmark used a standardized blood analog fluid, minimizing sample variability concerns. This factor is acceptable at the minimum level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis of simulation input parameters to experimental conditions not required at MRL 2 beyond documented boundary condition matching.",
      "rationale": "At MRL 2, a formal equivalency analysis beyond the documented matching of simulation boundary conditions to experimental test conditions is not required. Boundary conditions are set to match experimental values within documented tolerances. This factor is acceptable at the minimum level."
    }
  ],
