      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark verification cases relevant to rotating machinery flows.",
      "rationale": "Code verification performed against Taylor-Couette and lid-driven cavity benchmarks; residuals and convergence behavior consistent with published reference solutions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and demonstrate acceptable discretization error for hemolysis-relevant quantities.",
      "rationale": "Three-level mesh refinement study conducted; GCI for scalar stress index < 4% on finest mesh, satisfying MRL 2 discretization error requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to permit comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark experimental data provides full documentation of flow rates, rotational speeds, and fluid properties used in validation testing."
    },
