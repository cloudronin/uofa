      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release validation records consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) maintains a documented QA process including automated regression test suites and release notes. Version control records confirmed. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems at MRL 2 level.",
      "rationale": "Code verification confirmed via standard benchmark cases including lid-driven cavity and backward-facing step. Results match published reference solutions within accepted tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating discretization error below 5% for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed on the FDA generic centrifugal pump geometry. Richardson extrapolation applied; discretization error estimated at 3.2% for hemolysis index, meeting the 5% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to replicate boundary conditions in the CFD model.",
      "rationale": "FDA benchmark experimental data includes documented flow rates (2–7 L/min), rotational speeds (2000–3500 RPM), and fluid properties. Boundary conditions in the CFD model are directly mapped from experimental records."
    },
