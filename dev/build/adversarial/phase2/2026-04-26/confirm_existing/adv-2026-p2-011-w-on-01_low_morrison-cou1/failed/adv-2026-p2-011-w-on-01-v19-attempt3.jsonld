      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., GCI, RMSE) between model predictions and experimental hemolysis index must be reported.",
      "rationale": "Model predictions compared against FDA experimental hemolysis index measurements. RMSE of 0.018 g/100 L reported across operating envelope. GCI-based uncertainty bounds overlap experimental measurement uncertainty."
    },
    {
