  "signature": "ed25519:b2e5a8d4f1c7930e6b4d2a9f3c0e8b5d1f7a4c2e9b6d3f0a8c5e2b9d7f4a1c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, regression testing, and documentation must meet MRL 2 requirements.",
      "rationale": "CFD solver (ANSYS Fluent 2023 R2) is a commercial code with documented QA procedures, version control, and regression test suite. All SQA requirements for MRL 2 are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be reproduced within acceptable tolerance for MRL 2.",
      "rationale": "The solver has been verified against standard CFD benchmark cases including lid-driven cavity and backward-facing step flows. Results agree with analytical and reference solutions within 1% for relevant flow regimes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with at least three mesh refinement levels demonstrating monotonic convergence for MRL 2.",
      "rationale": "Three-level mesh refinement study performed (coarse: 1.2M, medium: 3.8M, fine: 11.4M cells). Grid convergence index (GCI) for hemolysis index is 4.2%, within acceptable bounds for MRL 2. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be sufficiently characterized and documented to support comparison with simulation inputs.",
      "rationale": "FDA generic centrifugal blood pump experimental data includes flow rate, rotational speed, inlet pressure, hematocrit, and temperature. Measurement uncertainties are reported. Conditions span the operating envelope relevant to CPB use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics between simulation outputs and experimental data must be defined and evaluated.",
      "rationale": "Normalized index of hemolysis (NIH) and modified index of hemolysis (MIH) compared between CFD predictions and experimental measurements across 8 operating conditions. Mean absolute error is 12.3%, within the MRL 2 acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly relevant to the clinical decision being supported.",
      "rationale": "Hemolysis index (NIH/MIH) is the primary clinical safety metric for CPB devices. The QoIs computed in the CFD model map directly to the quantities measured experimentally and to the regulatory acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the intended use to support credibility claims.",
      "rationale": "Validation experiments used the same FDA generic pump geometry, blood analog fluid (PRBC in saline), and operating ranges (2–6 L/min, 2500–4500 RPM) as the intended CPB application. Physiological relevance is high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error characterization required only at MRL 3 and above.",
      "rationale": "At MRL 2, detailed numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-5 for all equations; no further assessment needed at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification and error prevention measures required only at MRL 3 and above.",
      "rationale": "Formal use error analysis is not required at MRL 2. Simulation was performed by qualified CFD engineers following documented standard operating procedures."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification required only at MRL 3 and above.",
      "rationale": "At MRL 2, selection of turbulence model (SST k-omega) and hemolysis power-law model is documented with engineering justification. Formal model form uncertainty analysis is deferred to higher MRL assessments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty propagation for model inputs required only at MRL 3 and above.",
      "rationale": "Input parameters (viscosity, density, hemolysis model coefficients) are taken from literature with documented sources. Formal sensitivity analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability required only at MRL 3 and above.",
      "rationale": "FDA experimental dataset uses standardized blood analog preparation. Sample-to-sample variability characterization is not required at MRL 2; reported experimental uncertainty bands are accepted as sufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation and COU input parameters required only at MRL 3 and above.",
      "rationale": "Input parameters used in validation experiments are closely matched to CPB operating conditions. Formal equivalency analysis is not required at MRL 2; qualitative correspondence is documented."
    }
  ],
