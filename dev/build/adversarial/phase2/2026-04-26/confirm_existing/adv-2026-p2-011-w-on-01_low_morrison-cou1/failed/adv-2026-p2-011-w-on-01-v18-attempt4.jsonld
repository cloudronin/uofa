      "name": "CFD hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-hemolysis-vr-002",
      "type": "ValidationResult",
      "name": "Worst-case operating point identification validation"
    }
  ],
