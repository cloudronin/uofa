  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2).",
  "bindsRequirement": "https://uofa.net/synth/req/cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/fda-pump-cfd-mesh-v3"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation at nominal CPB flow rates"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4050548",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv-team",
