  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented QA procedures including version control, regression testing, and release notes. Software quality meets MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Order-of-accuracy testing was performed on canonical benchmark cases (lid-driven cavity, Poiseuille flow) confirming second-order spatial convergence. Code verification is documented in the solver verification report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA centrifugal pump geometry. Richardson extrapolation yielded a GCI of less than 3% on hemolysis index, confirming acceptable discretization error at the medium mesh density used for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental test conditions from the FDA inter-laboratory study (flow rate 2.5–7 L/min, rotational speed 2500–3500 RPM, hematocrit 33%) are documented and traceable. Boundary conditions in the CFD model match the experimental protocol within stated tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Predicted hemolysis index values agree with experimental measurements within 15% across all tested operating points. Systematic bias is less than 8%. Quantitative comparison metrics are documented in the validation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The primary quantity of interest — normalized index of hemolysis (NIH) — is directly clinically relevant for CPB device safety assessment and is the accepted metric per ASTM F1841. Secondary QoI (wall shear stress, exposure time) are physically linked to red blood cell damage mechanisms."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry under flow and rotational speed conditions spanning the intended CPB operating envelope. The validation scenario closely mirrors the deployment scenario with respect to fluid properties, geometry class, and operating regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default level 1 is acceptable.",
      "rationale": "Numerical solver error beyond discretization is not required to be separately quantified at MRL 2. Iterative convergence was monitored and residuals reduced below 1e-5 for all simulations, providing basic confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default level 1 is acceptable.",
      "rationale": "Formal use error analysis is not required at MRL 2. Simulation setup was reviewed by a second analyst to catch gross input errors; no discrepancies were found."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default level 1 is acceptable.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The k-omega SST turbulence model was selected based on published literature for similar rotating machinery hemolysis simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default level 1 is acceptable.",
      "rationale": "Sensitivity analysis on model inputs is not required at MRL 2. Nominal blood viscosity and density values from published literature were used without parametric variation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default level 1 is acceptable.",
      "rationale": "Statistical characterization of experimental sample variability is not required at MRL 2. The FDA inter-laboratory dataset provides sufficient sample breadth for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default level 1 is acceptable.",
      "rationale": "Formal equivalency mapping between validation and deployment input parameters is not required at MRL 2. Qualitative alignment between experimental and deployment boundary conditions has been confirmed."
    }
  ],
