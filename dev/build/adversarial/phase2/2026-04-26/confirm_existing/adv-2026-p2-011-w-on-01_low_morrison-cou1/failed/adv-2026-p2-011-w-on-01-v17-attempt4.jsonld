  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control and regression testing.",
      "rationale": "ANSYS Fluent 2022 R1 was used under an ISO 9001-compliant QA framework. Version control logs, regression test reports, and release notes were reviewed and found satisfactory for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions.",
      "rationale": "Code verification performed against Poiseuille flow and lid-driven cavity benchmarks. Observed convergence rates matched theoretical expectations, confirming correct equation implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed using at least three systematically refined meshes; GCI on hemolysis index must be below 5%.",
      "rationale": "Three mesh levels (2.1M, 5.8M, 14.2M cells) were evaluated. Richardson extrapolation yielded GCI of 3.2% on the scalar stress-based hemolysis index, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must be documented with uncertainty bounds and must span the intended operating envelope.",
      "rationale": "FDA pump test conditions (flow rates 2.5–7.5 L/min, rotational speeds 2000–3500 RPM) are documented with measurement uncertainties. Conditions bracket the CPB operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure rise must agree with experimental measurements within combined simulation and experimental uncertainty at all validation points.",
      "rationale": "Predicted hemolysis index agreed with experimental values within 12% across all operating points, within the combined uncertainty band. Pressure rise predictions fell within 8% of measured values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The scalar stress-based hemolysis index must be demonstrated to be a relevant surrogate for red blood cell damage in centrifugal pump flows.",
      "rationale": "Literature review confirms the Giersiepen-Wurzinger power-law hemolysis model is widely accepted for centrifugal pump assessment. The QoI directly maps to the clinical endpoint of hemolysis risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and fluid properties as the clinical use scenario, or documented similarity arguments must be provided.",
      "rationale": "Validation performed on the FDA generic centrifugal pump with bovine blood analog (40% glycerin-water). Rheological similarity to human blood at CPB hematocrit levels is documented via viscosity matching."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 is sufficient at MRL 2; formal solver error quantification not required.",
      "rationale": "At MRL 2, iterative residual monitoring to 1e-5 is accepted in lieu of formal solver error quantification. Residuals were monitored and confirmed converged for all simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documented analyst training records are sufficient; formal use error study not required.",
      "rationale": "Analysts hold documented CFD training credentials. Formal use error quantification is scoped out at MRL 2 per ASME V&V 40 Table 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Selection of turbulence model must be justified by literature precedent; formal model form uncertainty quantification not required at MRL 2.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark performance for rotating machinery flows. Model form uncertainty quantification deferred per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal material properties and boundary conditions must be documented; sensitivity analysis not required at MRL 2.",
      "rationale": "Blood analog viscosity, density, and inlet flow profiles are documented from experimental sources. Parametric sensitivity analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "FDA pump geometry used in validation must be traceable to published specifications; sample-to-sample variability study not required at MRL 2.",
      "rationale": "FDA generic centrifugal pump geometry sourced from published FDA benchmark dataset. Manufacturing variability assessment is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative mapping between validation experiment inputs and clinical use inputs must be documented; quantitative equivalency analysis not required at MRL 2.",
      "rationale": "Qualitative mapping of flow rate, rotational speed, and fluid rheology between validation and clinical scenarios is documented. Formal equivalency quantification is deferred per MRL 2 scoping."
    }
  ],
