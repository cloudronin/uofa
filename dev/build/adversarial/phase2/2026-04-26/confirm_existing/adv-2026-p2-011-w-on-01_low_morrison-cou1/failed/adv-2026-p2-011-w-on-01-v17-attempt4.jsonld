      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/morrison/validation/pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure rise validation across operating range"
    }
  ],
