      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 25% of experimental measurements across all tested operating points; pressure rise within 10%.",
      "rationale": "Mean hemolysis index prediction error of 18% across 12 operating points; pressure rise error below 6% at all conditions. Both metrics satisfy MRL 2 acceptance thresholds."
