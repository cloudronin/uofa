      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes at least two canonical verification benchmarks relevant to rotating machinery flow.",
      "rationale": "Lid-driven cavity and Taylor-Couette flow benchmarks reproduced within 0.5% of analytical solutions, confirming code correctness at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index and pressure rise at nominal operating point.",
      "rationale": "Three-level mesh refinement study (2.1 M, 5.8 M, 14.2 M cells) yielded GCI of 3.2% for hemolysis index and 1.8% for pressure rise; discretization error within MRL 2 tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented with measurement uncertainty quantification.",
      "rationale": "FDA benchmark dataset provides inlet flow rates 2.5–7.0 L/min and rotational speeds 2500–3500 RPM with stated uncertainties; glycerol-water analog fluid properties measured at test temperature."
    },
