      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not-assessed is acceptable at MRL 2 for this factor.",
      "rationale": "Input parameter uncertainty (fluid viscosity, pump geometry tolerances) is not formally quantified via sensitivity analysis or UQ methods. Nominal values are taken from published FDA interlaboratory study specifications."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not-assessed is acceptable at MRL 2 for this factor.",
      "rationale": "Variability across experimental test specimens (pump units) is not explicitly characterized. The FDA interlaboratory study used a single reference pump geometry, limiting inter-unit variability assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not-assessed is acceptable at MRL 2 for this factor.",
      "rationale": "Formal mapping between experimental and simulation input parameters beyond boundary conditions is not documented at this MRL. Key parameters (fluid properties, rotational speed) are matched by inspection."
