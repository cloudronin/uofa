  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is commercial software with documented QA processes including regression test suites and version-controlled release notes. Software version and license records are archived in the simulation project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Manufacturer-supplied verification benchmarks for rotating machinery and viscous flow were reviewed. Results confirm solver correctness for the relevant physics regime including rotating reference frame formulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "A three-level mesh refinement study was performed on the FDA generic centrifugal pump geometry. Richardson extrapolation yielded a grid convergence index below 3% for the hemolysis index QoI, confirming adequate spatial resolution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental boundary conditions (inlet flow rates 2.5–6 L/min, rotational speeds 2500–3500 RPM, fluid viscosity 0.0035 Pa·s) are documented from FDA interlaboratory study protocols and replicated in the simulation setup."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Simulated pressure-flow curves and normalized index of hemolysis are compared quantitatively to FDA interlaboratory experimental means. Relative errors remain within 15% across all evaluated operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The primary QoI (normalized index of hemolysis) directly maps to the clinical harm metric for red blood cell damage in CPB circuits. Secondary QoIs (wall shear stress, scalar stress exposure) are mechanistically linked to the hemolysis power-law model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Validation experiments use the same FDA generic pump geometry, blood analog fluid, and overlapping operating envelope as the intended simulation use. Geometric and physiological fidelity of the validation scenario to the deployment scenario is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not-assessed is acceptable at MRL 2 for this factor when solver is commercial and code verification is addressed separately.",
      "rationale": "Solver floating-point and round-off errors are not explicitly quantified. At MRL 2 this factor is accepted as not-assessed given the commercial solver pedigree addressed under numerical code verification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not-assessed is acceptable at MRL 2 for this factor.",
      "rationale": "Potential errors arising from analyst misapplication of the solver are not formally quantified. Standard operating procedures and peer review of simulation setup files are in place as informal controls."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not-assessed is acceptable at MRL 2 for this factor.",
      "rationale": "Uncertainty in the choice of turbulence closure (SST k-omega) and hemolysis power-law exponents is acknowledged but not formally propagated. A qualitative sensitivity discussion is provided in the simulation report."
    },
