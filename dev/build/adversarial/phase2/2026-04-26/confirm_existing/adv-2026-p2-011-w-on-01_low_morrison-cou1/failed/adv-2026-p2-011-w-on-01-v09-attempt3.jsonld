      "name": "Hemolysis index and pressure-flow curve validation against FDA pump bench data"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-val-001",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements at nominal CPB operating point"
    }
  ],
