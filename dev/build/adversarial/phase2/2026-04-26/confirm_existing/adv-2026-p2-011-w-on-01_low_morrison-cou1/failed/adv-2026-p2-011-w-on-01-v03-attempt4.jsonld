  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must demonstrate documented QA procedures including version control, regression testing, and peer-reviewed solver validation at MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 used with documented QA procedures. Version-controlled case files maintained in institutional repository. Solver regression suite confirms consistent results across patch versions. Achieved level 2 satisfies MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate that the numerical implementation correctly solves the governing equations, with at least order-of-accuracy testing for relevant flow regimes at MRL 2.",
      "rationale": "Order-of-accuracy verification performed using manufactured solutions for incompressible Navier-Stokes with scalar transport. Observed convergence rates consistent with second-order spatial discretization. Code verification satisfies MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must be performed with at least three mesh refinement levels; GCI reported for hemolysis index QoI at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (coarse 2.1M, medium 5.8M, fine 14.2M elements). GCI for normalized hemolysis index is 3.2% on medium mesh. Richardson extrapolation confirms asymptotic convergence. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to enable faithful reproduction in the simulation boundary conditions at MRL 2.",
      "rationale": "FDA benchmark experimental conditions fully documented: flow rates 2.5–7 L/min, rotational speeds 2000–3500 RPM, bovine blood at 37°C, hematocrit 33±2%. Boundary conditions in CFD model replicate experimental setup with documented mapping procedure."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics between simulation outputs and experimental data must be reported; agreement within 20% for normalized hemolysis index at MRL 2.",
      "rationale": "Normalized index of hemolysis (NIH) compared across 12 operating points. Mean absolute relative error is 11.4%; maximum deviation 18.7% at lowest flow condition. All comparisons within the 20% acceptance threshold. Validation metric satisfies MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest predicted by the model must be directly linked to the clinical or engineering decision being supported at MRL 2.",
      "rationale": "Primary QoI is normalized index of hemolysis (NIH), directly used in FDA 510(k) submissions for CPB device evaluation. Secondary QoIs (shear stress distribution, exposure time) mechanistically support NIH prediction. QoI relevance confirmed by clinical advisory review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must represent conditions sufficiently similar to the intended use conditions to support extrapolation of validation evidence at MRL 2.",
      "rationale": "FDA generic centrifugal pump benchmark geometry and operating conditions span the intended CPB operating envelope. Validation dataset covers flow rates and rotational speeds representative of clinical CPB use. Relevance assessment documented by engineering team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed numerical solver error quantification beyond code verification is not required; basic convergence monitoring is sufficient.",
      "rationale": "Residual convergence monitored to 1e-5 for all equations. Solver error assessment beyond convergence monitoring not required at MRL 2; factor scoped to level 1 per MRL 2 requirements table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis not required at MRL 2; basic user qualification documentation is sufficient.",
      "rationale": "CFD analysts hold relevant engineering qualifications. Formal use error analysis not required at MRL 2 per ASME V&V 40 Table 4. Factor assessed at minimum required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty including turbulence model selection and hemolysis constitutive model must be evaluated at MRL 2.",
      "rationale": "Model form assessment for turbulence model and Giersiepen-Wurzinger hemolysis power-law not completed within current assessment scope. Identified as gap; accepted at MRL 2 with acknowledgment that SST k-omega is standard for rotating machinery flows. Full model form study deferred to MRL 3 activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs including blood viscosity, density, and hemolysis model constants must be documented with sources and uncertainty ranges at MRL 2.",
      "rationale": "Material properties sourced from published literature: blood density 1060 kg/m3, dynamic viscosity Carreau-Yasuda model with published constants. Hemolysis model constants from Giersiepen et al. 1990. Input uncertainty ranges documented. Formal sensitivity analysis deferred; documentation satisfies MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed characterization of experimental test sample variability is not required beyond basic documentation of blood source and preparation.",
      "rationale": "FDA benchmark used bovine blood from certified supplier with documented preparation protocol. Detailed sample-to-sample variability characterization not required at MRL 2. Factor assessed at minimum level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency analysis between validation experiment inputs and COU inputs is not required; qualitative assessment is sufficient.",
      "rationale": "Qualitative assessment confirms that validation experiment operating conditions are representative of CPB clinical use envelope. Formal equivalency analysis not required at MRL 2. Factor assessed at minimum required level per MRL 2 requirements table."
    }
  ],
