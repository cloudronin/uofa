    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-val-001",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA GCBP experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pressure-rise-val-002",
      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation across operating flow rates"
    }
  ],
