  "hash": "sha256:a3f7c2e1d09b4856f2a1cc3e7d5b0984f1e6a2d3c8b7f4e0a9d2c5b8e1f3a6c9",
  "signature": "ed25519:b1d4e7a2f0c3958e6b2d1a4f7c0e3b6d9a2f5c8e1b4d7a0f3c6e9b2d5a8f1c4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent documented QA process covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO 9001-certified QA framework. Regression test suite covers 98% of solver modules relevant to rotating-frame turbulent flow. Version control logs and release notes archived in the project repository. Achieved level 2 meets the required level 2 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks must demonstrate convergence consistent with the nominal scheme order.",
      "rationale": "Method-of-manufactured-solutions (MMS) tests on a rotating annulus benchmark confirm second-order spatial convergence for velocity and pressure fields. Results documented in the solver verification report appended to this package. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine mesh.",
      "rationale": "Three-level mesh refinement study (coarse 3.2 M cells, medium 7.8 M cells, fine 18.4 M cells) yields GCI of 3.1% for the hemolysis index on the fine mesh, satisfying the 5% threshold. Richardson extrapolation applied per ASME V&V 20. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be documented with uncertainty bounds and matched in the simulation boundary conditions.",
      "rationale": "FDA GCBP experimental data report provides flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), temperature (37 ± 0.5 °C), and hematocrit (33 ± 2%). All boundary conditions in the CFD model are set to experimental nominal values; uncertainties propagated via sensitivity analysis. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bands for at least 80% of operating points.",
      "rationale": "Predicted hemolysis index falls within combined uncertainty bands at 9 of 10 operating points (90%). Maximum normalized error is 4.2% at the 2 L/min, 3500 RPM condition, attributable to flow unsteadiness not captured by steady-state RANS. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (hemolysis index) must be directly linked to the device safety claim and computed from model outputs without unvalidated post-processing transformations.",
      "rationale": "Hemolysis index is computed via the Giersiepen-Wurzinger power-law model applied directly to CFD shear stress and exposure time fields, consistent with the regulatory safety claim on red blood cell damage. The QoI is traceable to the device performance specification. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating envelope as the intended computational use.",
      "rationale": "Validation experiments use the FDA GCBP geometry identical to the simulation domain. Bovine blood at physiological hematocrit is used in both experiments and model calibration. Operating conditions span the CPB clinical flow range. Validation activities are therefore directly relevant to the computational use. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations is sufficient at MRL 2 without formal solver error quantification.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. All simulations converged to residuals below 1e-5. Factor scoped to level 1; not-assessed status is acceptable per ASME V&V 40 Table 1 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a documented simulation execution checklist reviewed by a second analyst is sufficient; formal use-error quantification is not required.",
      "rationale": "Simulation setup was reviewed by a second CFD engineer using a structured checklist. No formal use-error quantification is required at MRL 2. Factor not-assessed at level 1 is acceptable per ASME V&V 40 for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, selection of turbulence and hemolysis sub-models with documented literature justification is sufficient; formal model-form uncertainty quantification is not required.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis model selected based on peer-reviewed literature for blood pump applications. Formal model-form UQ not required at MRL 2. Not-assessed at level 1 is acceptable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; probabilistic input uncertainty propagation is not required.",
      "rationale": "Blood viscosity, density, and hemolysis model coefficients taken from published literature with documented sources. Sensitivity analysis performed informally. Probabilistic UQ not required at MRL 2. Not-assessed at level 1 is acceptable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use of a single well-characterized blood sample lot with documented provenance is acceptable without inter-lot variability analysis.",
      "rationale": "FDA GCBP experimental data used a single bovine blood lot with documented hematocrit and storage conditions. Inter-lot variability analysis not required at MRL 2. Not-assessed at level 1 is acceptable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative confirmation that simulation input parameters map to experimental conditions is sufficient without formal equivalency metrics.",
      "rationale": "Simulation boundary conditions are set directly from experimental nominal values. Qualitative mapping confirmed by the simulation team. Formal equivalency metrics not required at MRL 2. Not-assessed at level 1 is acceptable."
    }
  ],
