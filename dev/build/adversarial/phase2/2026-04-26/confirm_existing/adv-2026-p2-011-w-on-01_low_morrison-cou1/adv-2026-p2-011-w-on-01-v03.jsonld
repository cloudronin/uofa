      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially licensed code with documented QA procedures, version control, and regression test suites. Software QA documentation reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems.",
      "rationale": "Standard benchmark cases (lid-driven cavity, Poiseuille flow) were executed and results compared against analytical solutions. Errors within accepted tolerances for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and within acceptable bounds for the primary QoI.",
      "rationale": "Three-level mesh refinement study performed on the FDA generic centrifugal pump geometry. GCI for hemolysis index QoI is 3.1%, satisfying MRL 2 discretization error requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and traceable to the validation dataset.",
      "rationale": "FDA benchmark experimental conditions (flow rate, rotational speed, fluid properties) are fully documented in the published dataset. Traceability confirmed between simulation boundary conditions and experimental setup."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error) must be reported for primary QoI.",
      "rationale": "Hemolysis index predictions compared against experimental measurements across five operating points. Normalized RMS error of 8.4% reported, within MRL 2 acceptance threshold of 15%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the device safety endpoint.",
      "rationale": "Hemolysis index (normalized index of hemolysis, NIH) is the primary QoI and is directly linked to the blood damage safety endpoint for CPB devices per FDA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope relevant to the intended use.",
      "rationale": "FDA generic centrifugal pump validation experiments span flow rates from 2 to 7 L/min and rotational speeds from 2000 to 3500 RPM, encompassing the nominal CPB operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default level accepted.",
      "rationale": "Numerical solver error beyond discretization is not required to be separately quantified at MRL 2. Residual convergence criteria of 1e-5 applied consistently across all simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; operator qualification records sufficient.",
      "rationale": "Use error assessment not required at MRL 2. Simulations performed by qualified engineers with documented training records. No independent use-error study conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty not required to be formally quantified at MRL 2.",
      "rationale": "The k-omega SST turbulence model and Giersiepen-Wurzinger hemolysis power-law model are established choices for CPB hemolysis prediction. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
