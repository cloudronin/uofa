      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input uncertainty propagation not required at MRL 2.",
      "rationale": "Blood viscosity and density are treated as deterministic inputs at nominal values. Formal uncertainty propagation of model inputs is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2.",
      "rationale": "FDA benchmark dataset uses bovine blood with reported hematocrit range. Sample-to-sample variability characterization is not required at MRL 2; mean experimental values used for comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation and deployment inputs not required at MRL 2.",
      "rationale": "Simulation input parameters are set to match published FDA benchmark experimental conditions. Formal equivalency analysis between validation and deployment parameter spaces is not required at MRL 2."
    }
