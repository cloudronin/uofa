  "signature": "ed25519:b1d3f5a7c9e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is verified under a quality management system with documented version control and regression testing.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is used under an ISO 9001-compliant QMS with documented regression test suite and version-locked configuration files. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions demonstrate correct implementation of governing equations for rotating turbomachinery flows.",
      "rationale": "Taylor-Couette flow and lid-driven cavity benchmarks confirm correct implementation of the incompressible Navier-Stokes equations and the multiple reference frame (MRF) rotating zone formulation. Errors within 1% of analytical solutions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed for hemolysis index QOI; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 8.7M, 17.1M cells). GCI for normalized index of hemolysis (NIH) is 3.8% on the medium grid and 1.9% on the fine grid. Medium grid selected for production runs as cost-accuracy compromise."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented with measurement uncertainty and match simulation boundary conditions within stated tolerances.",
      "rationale": "FDA pump experimental data report flow rates of 2.5 and 5.0 L/min at 2500 and 3500 RPM with bovine blood analogue. Simulation boundary conditions set to match within ±2% of reported values. Temperature and viscosity uncertainties documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values compared against experimental measurements; normalized RMS error < 15% across operating envelope.",
      "rationale": "Predicted NIH values at four operating points compared against Herbertson et al. experimental data. Normalized RMS error is 11.4%, meeting the acceptance threshold. Systematic over-prediction at high RPM noted and attributed to power-law hemolysis model limitations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOIs used in validation (NIH, pressure rise, flow uniformity) are the same quantities used to evaluate device safety in the intended regulatory submission.",
      "rationale": "NIH is the primary regulatory QOI per FDA guidance on blood-contacting devices. Pressure-flow characteristics and shear stress distributions are secondary QOIs directly relevant to device performance characterization. Full alignment confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the range of operating conditions (flow rate, speed) that bound the intended clinical CPB operating envelope.",
      "rationale": "Clinical CPB operating range (2–6 L/min, 2000–4000 RPM) is bracketed by the validation dataset. Extrapolation beyond validated range is not required for the current decision. Validation relevance is judged adequate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and mass balance errors documented; not required at MRL 2 beyond basic monitoring.",
      "rationale": "Residuals monitored to 1e-5 for continuity and momentum; mass imbalance < 0.01%. Formal solver error quantification not required at MRL 2; basic monitoring sufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error assessment not required at MRL 2 for this factor.",
      "rationale": "At MRL 2, formal use error assessment is not mandated. Simulation setup reviewed by a second analyst for input consistency. No structured use error study performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty assessment not required at MRL 2; turbulence model selection documented.",
      "rationale": "SST k-omega turbulence model selected based on literature precedent for internal rotating flows. Formal model form uncertainty quantification not required at MRL 2; selection rationale documented in simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter uncertainty propagation not required at MRL 2; nominal input values documented with sources.",
      "rationale": "Blood viscosity, density, and hemolysis model constants taken from published literature with sources cited. Formal uncertainty propagation not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample characterization not required at MRL 2 beyond confirming fluid analogue properties.",
      "rationale": "Bovine blood analogue properties (viscosity, density) confirmed consistent with reported experimental values. Formal sample characterization study not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency assessment between validation experiment and COU inputs not required at MRL 2.",
      "rationale": "Simulation inputs for validation cases match experimental conditions as documented in the test conditions factor. Formal equivalency mapping to the COU is not required at MRL 2; qualitative alignment confirmed."
    }
  ],
