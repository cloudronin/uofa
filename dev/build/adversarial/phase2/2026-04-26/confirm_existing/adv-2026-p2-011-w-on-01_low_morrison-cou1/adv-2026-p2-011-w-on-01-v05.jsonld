      "id": "https://uofa.net/morrison/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements at design operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041497",
