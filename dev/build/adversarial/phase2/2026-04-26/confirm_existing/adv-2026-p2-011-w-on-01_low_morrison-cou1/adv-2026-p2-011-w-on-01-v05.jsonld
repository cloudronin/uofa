  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified against established benchmark cases and version-controlled with documented release notes.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional software QA protocol; solver benchmarked against lid-driven cavity and pipe-flow cases; version control and release documentation confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test or method-of-manufactured-solutions demonstrates correct numerical implementation for the governing equations employed.",
      "rationale": "Richardson extrapolation applied to laminar pipe-flow benchmark confirms second-order spatial accuracy consistent with solver documentation; no code modifications were made."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (hemolysis index) with GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed (3.2 M, 7.8 M, 18.4 M cells); GCI for hemolysis index is 3.1% between medium and fine grids; fine grid selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, inlet pressure) match simulation inputs within stated uncertainty bounds.",
      "rationale": "FDA benchmark test conditions (2.5 L/min, 3500 RPM, 60 mmHg pressure rise) reproduced in simulation; inlet velocity profile derived from measured data; fluid temperature maintained at 37 °C in both experiment and model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 25% of experimental mean across all tested operating points.",
      "rationale": "Predicted normalized index of hemolysis deviates 14.8% from experimental mean across five operating points; all individual point errors within acceptance criterion; systematic under-prediction trend noted and documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) are directly linked to the clinical safety endpoint of red blood cell damage.",
      "rationale": "Hemolysis index and volume-averaged scalar shear stress are established surrogate endpoints for RBC damage; both are directly traceable to the device safety requirement; no surrogate substitution without justification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic centrifugal pump geometry under overlapping operating conditions.",
      "rationale": "FDA benchmark geometry used for both simulation and validation experiments; operating envelope of validation (1.5–5 L/min, 2500–4500 RPM) spans the intended operating range; fluid (bovine blood analog) is accepted surrogate for human blood in hemolysis studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "At Model Risk Level 2, explicit quantification of numerical solver round-off and iterative convergence error beyond residual monitoring is not mandated; residuals converged to 1e-5 for all equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records reviewed informally.",
      "rationale": "Formal use-error analysis not required at MRL 2; simulation performed by PhD-level analyst with five years CFD experience on rotary blood pumps; peer review of setup conducted internally."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection documented with literature support.",
      "rationale": "k-omega SST turbulence model selected based on published CFD blood pump literature; formal model-form uncertainty quantification not required at MRL 2 but model selection rationale is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input values sourced from peer-reviewed literature.",
      "rationale": "Blood viscosity (0.0035 Pa·s) and density (1060 kg/m³) taken from published standards; power-law hemolysis model constants from Giersiepen et al. 1990; sensitivity analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample provenance documented in FDA benchmark report.",
      "rationale": "FDA benchmark experimental data used as-is; sample characterization (bovine blood, hematocrit 33%) documented in original FDA study; independent sample qualification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; dimensional equivalency between experiment and simulation confirmed by inspection.",
      "rationale": "Simulation input parameters (geometry, boundary conditions, fluid properties) confirmed equivalent to experimental conditions by direct inspection of FDA benchmark protocol; formal equivalency analysis not required at MRL 2."
    }
  ],
