  "signature": "ed25519:7b3e1f9a2c5d8e0b4f7a1c3e6d9b2f5a8c1e4b7d0f3a6c9e2b5f8a1d4c7e0b3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software version control, documented build and test procedures, and regression test suite must be in place for the CFD solver.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under version control with a documented release process. Regression tests covering relevant flow regimes are executed prior to each analysis run. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via method of manufactured solutions or equivalent benchmark problems for incompressible viscous flow.",
      "rationale": "The solver has been verified against the lid-driven cavity benchmark (Re=1000) and a Poiseuille flow manufactured solution. Observed convergence rates are consistent with second-order spatial accuracy. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A mesh convergence study must be performed using at least three mesh densities; the grid convergence index (GCI) for the hemolysis index QoI must be reported.",
      "rationale": "Three mesh densities (coarse: 2.1M, medium: 5.8M, fine: 14.2M cells) were evaluated. GCI for the normalized hemolysis index is 3.4% on the fine mesh, within acceptable bounds for MRL 2. The medium mesh was selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with measured boundary conditions and uncertainty estimates for flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA benchmark experimental data includes documented flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), and fluid properties for the blood analog. Measurement uncertainties are reported at 95% confidence. Conditions are sufficiently characterized for MRL 2 validation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric U_val) must be computed between model predictions and experimental data for the primary QoI.",
      "rationale": "The normalized hemolysis index predicted by the CFD model agrees with FDA benchmark experimental measurements within 18% across all tested operating points, with a validation metric U_val of 0.21. This satisfies the acceptance threshold for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs selected for validation (normalized hemolysis index, pressure rise) must be directly linked to the device safety claim.",
      "rationale": "The normalized hemolysis index (NIH) and pump pressure rise are the primary QoIs. NIH is the regulatory metric for blood damage in CPB devices and is directly linked to the device safety claim. Pressure rise governs pump adequacy for CPB flow support. Both QoIs are appropriate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and fluid analog as the intended computational model, with operating conditions spanning the intended use range.",
      "rationale": "Validation activities used the FDA generic centrifugal blood pump geometry with a glycerol-water blood analog. Operating conditions span 2–8 L/min flow and 2000–3500 RPM, encompassing the worst-case hemolysis operating envelope. Relevance to the computational model is confirmed for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must be documented; not required to be formally assessed at MRL 2 beyond basic reporting.",
      "rationale": "Numerical solver error is not formally assessed at MRL 2 for this analysis. Residuals are monitored and reported to confirm solution convergence, but a formal solver error quantification is scoped to higher MRL assessments. Acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error assessment not required at MRL 2; analyst qualification and peer review are sufficient.",
      "rationale": "Use error is not formally assessed at MRL 2. The analysis was performed by qualified CFD engineers with relevant domain experience and was subject to internal peer review. This is acceptable for the current model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty need not be formally quantified at MRL 2; selection rationale for turbulence and hemolysis sub-models must be documented.",
      "rationale": "Model form uncertainty is not formally assessed at MRL 2. The SST k-omega turbulence model and the Giersiepen-Wurzinger hemolysis power-law model were selected based on published literature for similar blood pump CFD analyses. Selection rationale is documented in the analysis report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter sensitivity analysis not required at MRL 2; nominal input values and sources must be documented.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Nominal values for blood analog viscosity, density, and hemolysis model constants are taken from published FDA benchmark documentation and are recorded in the analysis inputs log."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability not required at MRL 2; sample descriptions must be documented.",
      "rationale": "Test sample characterization is not formally assessed at MRL 2. The FDA benchmark experimental dataset uses a single nominal pump geometry with a standardized blood analog formulation. Sample descriptions are available in the FDA benchmark documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and simulation inputs not required at MRL 2; qualitative correspondence must be noted.",
      "rationale": "Formal equivalency assessment is not required at MRL 2. Qualitative correspondence between experimental boundary conditions and simulation inputs has been confirmed: rotational speed, inlet flow rate, and fluid properties used in simulation match the documented experimental values within stated measurement uncertainty."
    }
  ],
