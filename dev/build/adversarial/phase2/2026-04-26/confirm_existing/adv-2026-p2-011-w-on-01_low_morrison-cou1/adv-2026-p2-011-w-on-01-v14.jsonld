      "type": "ValidationResult",
      "name": "CFD hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-vr-002",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic validation at nominal CPB operating conditions"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037163",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
