  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite and change-control procedures meeting MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is under full version control with a regression test suite of 412 cases. Change-control procedures and release notes were reviewed and found compliant with the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent applied to governing equations with documented order-of-accuracy confirmation.",
      "rationale": "MMS verification was performed on the Navier-Stokes solver and the hemolysis transport equation. Second-order spatial accuracy was confirmed across three mesh refinement levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for all quantities of interest with extrapolated error below 5% on at least three systematically refined meshes.",
      "rationale": "A two-level mesh refinement study was completed using medium (8.2 M cells) and fine (21.4 M cells) grids. GCI values for hemolysis index ranged from 6.8% to 12.3% across operating points, which exceeds the 5% threshold. Resource constraints precluded generation of the required third (extra-fine) mesh level needed to establish asymptotic convergence. Engineering judgment based on the observed monotonic trend and conservative hemolysis thresholds was applied to support the overall acceptance decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty characterisation; fluid properties matched to within ±5% of simulation inputs.",
      "rationale": "Bench test conditions were logged at 1 Hz; inlet flow rates were controlled to ±1.2% of target. Blood analogue viscosity and density were measured pre- and post-test and matched simulation inputs within 3.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms or validation uncertainty) reported for each QoI with statistical comparison against experimental uncertainty band.",
      "rationale": "RMS error for hemolysis index across five operating points was 9.4%; all predictions fell within the combined experimental and numerical uncertainty band at 95% confidence. Velocity profile E_rms was 7.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical decision metric (absolute hemolysis index) with documented traceability.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) in mg/dL, which maps directly to the clinical threshold used for regulatory decision-making. Traceability matrix links each simulation output to the corresponding acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at COU-representative flow rates, rotational speeds, and fluid properties.",
      "rationale": "All five validation experiments were conducted at the exact flow-speed combinations specified in the COU. The FDA generic pump geometry was used without modification. Fluid properties matched physiological blood analogue specifications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated with residuals below 1e-5 and monitored QoI variation below 0.1% over final 500 iterations.",
      "rationale": "All simulations converged to residuals below 1e-6. Hemolysis index variation over the final 1000 iterations was less than 0.05% for all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition inputs verified against test data log.",
      "rationale": "An independent CFD analyst reviewed the simulation setup, boundary conditions, and post-processing scripts. No discrepancies were identified between the logged test conditions and the simulation inputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis constitutive model validated against multiple independent datasets spanning the COU operating envelope; model-form uncertainty quantified and incorporated into prediction intervals.",
      "rationale": "The power-law hemolysis model (Giersiepen correlation) was calibrated against the FDA pump dataset used in this study. Validation against a single dataset is consistent with standard practice for this class of model, and the Monte Carlo UQ propagates parametric uncertainty through the hemolysis model. The team noted that broader multi-dataset validation would be desirable but considered the existing evidence sufficient given the conservative clinical threshold margins observed in the output comparison results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters identified, distributions characterised, and propagated through Monte Carlo UQ with documented sensitivity ranking.",
      "rationale": "Twelve uncertain input parameters (viscosity, density, rotational speed, inlet flow rate, hemolysis model coefficients) were identified. Log-normal and uniform distributions were assigned based on measurement data. 10,000 Monte Carlo samples were propagated; Sobol sensitivity indices identified hemolysis model exponent as the dominant contributor (S_i = 0.61)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test fluid properties characterised with documented lot-to-lot variability; sample preparation protocol recorded.",
      "rationale": "Blood analogue preparation protocol was documented with lot traceability. Viscosity measurements from three independent batches showed coefficient of variation of 2.3%, within acceptable bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions shown to be equivalent to experimental inputs within stated tolerances.",
      "rationale": "A parameter equivalency table was produced mapping each experimental measurement to its simulation counterpart. All parameters were within stated tolerances; no systematic offsets were identified."
    }
  ],
