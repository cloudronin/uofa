  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen factors and determined that the overall evidence package provides sufficient assurance for regulatory submission. Eleven of thirteen factors achieved their required credibility levels. The two factors with noted engineering caveats — discretization convergence and constitutive model breadth — were reviewed in the context of the full evidence body. The Monte Carlo uncertainty quantification bounds hemolysis predictions conservatively, and the observed margin between predicted hemolysis index values and the clinical threshold (mean margin 38% across operating points) was judged to provide adequate safety buffer. The assessment team concluded that the combined weight of evidence, including PIV velocity validation, bench-test hemolysis correlation, and UQ results, supports acceptance of the model for the stated COU.",
