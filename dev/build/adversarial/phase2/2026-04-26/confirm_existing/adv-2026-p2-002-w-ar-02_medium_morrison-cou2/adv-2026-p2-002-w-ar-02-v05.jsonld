  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA plan and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver is under version control with a documented QA plan. Regression tests cover laminar and turbulent pipe flow benchmarks. Hemolysis-specific regression coverage is partial but sufficient for MRL 5 baseline requirements at this factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests using manufactured solutions for Navier-Stokes and scalar transport equations relevant to hemolysis power-law model.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes solver; observed order matches theoretical second-order convergence. Scalar hemolysis transport equation verified against analytical solutions in simplified geometries."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes with GCI < 5% on hemolysis index QoI at all five operating points.",
      "rationale": "Mesh refinement studies were conducted at three operating points using two mesh levels. Engineering judgment indicates that spatial discretization error is within acceptable bounds for regulatory submission, given the conservative safety margins applied to the hemolysis threshold. The team notes that full three-level Richardson extrapolation at all five operating points was not completed due to computational resource constraints, but the partial study is considered representative of the full operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty bounds; inlet flow profiles and fluid properties match CFD inputs within stated tolerances.",
      "rationale": "FDA generic pump experimental test conditions are well-documented. Inlet velocity profiles, fluid viscosity, and density are reported with measurement uncertainty. CFD boundary conditions replicate experimental setup within stated tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel < 15%) applied to hemolysis index at all five operating points with statistical confidence intervals from Monte Carlo UQ.",
      "rationale": "Hemolysis index predictions agree with experimental measurements within 20% at four of five operating points. The fifth point shows 28% relative error attributed to transitional flow regime uncertainty. Monte Carlo UQ bounds are reported. The overall agreement is judged adequate given the inherent variability of hemolysis measurement in vitro."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) directly maps to clinical endpoint; sensitivity analysis confirms QoI is the primary driver of device acceptance decision.",
      "rationale": "The hemolysis index is the primary QoI and directly corresponds to the clinical hemolysis threshold. Sensitivity analysis confirms that hemolysis index is the dominant model output driving the regulatory decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on geometrically similar pump at overlapping operating conditions; fluid analogue properties characterized.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under overlapping flow-speed conditions. Glycerol-water analogue fluid properties are characterized and mapped to blood-analogue conditions via non-dimensional parameters."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residuals below 1e-5 for all transport equations; mass balance error < 0.1%.",
      "rationale": "All simulations converged to normalized residuals below 1e-5. Global mass balance error is below 0.05% across all operating points. Convergence histories are archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review; boundary condition inputs traceable to experimental records.",
      "rationale": "Simulation setup was independently reviewed by a second analyst. Boundary condition inputs are traceable to experimental records via documented workflow. No use errors were identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified with sensitivity study; hemolysis power-law model coefficients validated against multiple datasets.",
      "rationale": "SST k-omega turbulence model selected based on sensitivity study comparing three turbulence closures. Hemolysis power-law coefficients (Giersiepen et al.) validated against three independent experimental datasets spanning the operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs characterized with probability distributions; Monte Carlo propagation performed.",
      "rationale": "Fluid viscosity, density, and inlet flow rate characterized with normal distributions from repeated measurements. Monte Carlo propagation (N=1000 samples) performed across all five operating points. Input uncertainty contribution to hemolysis index uncertainty is quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point with inter-laboratory reproducibility data available.",
      "rationale": "Experimental hemolysis measurements were obtained from two independent test runs per operating point using the FDA generic pump. The dataset is well-characterized and sourced from a reputable laboratory with established protocols. While full inter-laboratory reproducibility data were not available for all operating conditions, the existing replicates are considered sufficient to characterize measurement variability for the purposes of this credibility assessment, given the consistency observed between runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Non-dimensional mapping between validation experiment and COU confirmed for Reynolds number, flow coefficient, and head coefficient at all operating points.",
      "rationale": "Non-dimensional analysis confirms equivalency of Reynolds number, flow coefficient, and head coefficient between the validation experiment and the VAD COU operating envelope. Mapping is documented and traceable."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility evidence package is judged sufficient to support regulatory submission. The majority of credibility factors meet or exceed required levels, and Monte Carlo uncertainty quantification has been performed across the operating envelope. Minor shortfalls in discretization error characterization and test sample replication are acknowledged as engineering caveats; however, the conservative hemolysis threshold margins and the consistency of predictions with available experimental data provide adequate confidence that the model is fit for its intended use. The assessment team concludes that the evidence base, taken as a whole, supports acceptance of the CFD hemolysis predictions for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
