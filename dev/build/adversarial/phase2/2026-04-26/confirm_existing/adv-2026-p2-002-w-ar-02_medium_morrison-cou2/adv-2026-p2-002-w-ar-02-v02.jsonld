  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite and regression coverage consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is under formal version control. A regression test suite covering 42 canonical cases was executed with zero failures. Software quality assurance is fully satisfied at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent analytical benchmarks demonstrating correct implementation of governing equations.",
      "rationale": "MMS verification was completed for the incompressible Navier-Stokes solver and the scalar hemolysis transport equation. Observed convergence rates matched theoretical expectations. Code verification is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or Richardson extrapolation demonstrating discretization uncertainty below 5% of the hemolysis index QoI at all five operating points, with formal order-of-accuracy confirmation.",
      "rationale": "A three-level mesh refinement study was performed on the baseline operating point (5 L/min, 3500 RPM). The coarse-to-medium refinement showed acceptable hemolysis index variation within engineering tolerances. Given that predictions remained below the clinical threshold across all nominal conditions and that the Monte Carlo sweep captured parametric variability, the team concluded that the overall evidence is sufficient to support device acceptance. Residual mesh sensitivity at off-design points is considered a secondary contributor relative to model-form uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; fluid properties and boundary conditions match COU operating envelope.",
      "rationale": "Bench experiments used bovine blood at 37 °C with hematocrit 35 ± 2%. Flow rates and rotational speeds were controlled to within ±1% of target values. Test conditions are well-characterized and consistent with the COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) computed between CFD-predicted and experimentally measured hemolysis index at all five operating points, with statistical uncertainty bounds.",
      "rationale": "Mean relative error across five operating points was 11.4% with a 95% confidence interval of ±6.2%. All predictions fell on the conservative (over-predicting) side of the clinical threshold. Output comparison is assessed as satisfactory."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis, NIH) directly maps to the regulatory acceptance criterion without intermediate transformation that introduces unquantified error.",
      "rationale": "The NIH computed from CFD shear stress history directly corresponds to the regulatory metric specified in FDA guidance. No intermediate transformation is required. QoI relevance is fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry and fluid system as the COU; operating conditions span the full COU envelope.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump geometry under the same five flow-speed combinations specified in the COU. Fluid system and boundary conditions are directly representative. Validation relevance is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual reduction of at least 5 orders of magnitude and QoI change below 0.1% over the final 500 iterations.",
      "rationale": "All simulations achieved mass and momentum residuals below 1×10⁻⁶. The hemolysis index QoI varied by less than 0.05% over the final 1000 iterations. Solver error is well controlled."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary condition setup and post-processing scripts.",
      "rationale": "An independent analyst reviewed boundary condition assignments and post-processing scripts against the documented simulation protocol. No discrepancies were identified. Use error controls are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence closure and hemolysis constitutive model alternatives with sensitivity analysis demonstrating that model-form choices do not alter the accept/reject conclusion.",
      "rationale": "Three turbulence models (SST k-ω, realizable k-ε, and RSM) were evaluated at the design operating point. Hemolysis index predictions varied by up to 18% across turbulence model choices. The power-law hemolysis model (Giersiepen correlation) was used without evaluation of the Taskin or Zhang alternatives. While the selected model produced conservative predictions at nominal conditions, the team noted that engineering judgment and the observed margin to the clinical threshold provide adequate confidence. The broader Monte Carlo analysis captured parametric uncertainty, and the overall evidence package was considered sufficient for regulatory submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs characterized with probability distributions; Monte Carlo propagation performed with at least 500 samples.",
      "rationale": "Blood viscosity, density, and inlet velocity profiles were characterized with normal distributions derived from literature and experimental data. Monte Carlo propagation used 1000 samples. Input uncertainty is adequately characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point with inter-replicate variability quantified.",
      "rationale": "Five independent experimental replicates were performed at each of the five operating points. Inter-replicate coefficient of variation for NIH was below 8% at all conditions. Sample adequacy is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that CFD boundary conditions are equivalent to experimental inlet/outlet conditions within measurement uncertainty.",
      "rationale": "Inlet velocity profiles applied in CFD were derived from LDV measurements at the pump inlet plane. Pressure boundary conditions matched transducer readings to within 2%. Equivalency of input parameters is satisfied."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of the thirteen credibility factor assessments, the team determined that the CFD hemolysis model provides sufficient credibility to support regulatory submission for the Class III VAD device. Hemolysis index predictions remained below the absolute clinical threshold at all five operating points, including the upper bound of the Monte Carlo uncertainty interval. Turbulence model sensitivity and mesh refinement analyses were conducted and the results, while indicating some variability, did not alter the directional conclusion that the device meets the hemolysis criterion. The overall body of evidence — including PIV velocity validation, replicated bench experiments, and quantified input uncertainty — is judged adequate for the intended regulatory decision. Remaining engineering caveats regarding constitutive model selection and off-design mesh sensitivity are considered acceptable given the conservative margin observed between predicted hemolysis levels and the clinical threshold.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
