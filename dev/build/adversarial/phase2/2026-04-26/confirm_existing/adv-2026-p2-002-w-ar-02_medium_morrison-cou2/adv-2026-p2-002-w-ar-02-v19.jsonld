  "signature": "ed25519:9b2e4f1a3c5d7e8f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented, version-controlled, with independent review of solver modules and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "A formal SQA plan is in place and version control is enforced throughout the development cycle. Regression tests cover the primary turbulence and hemolysis sub-models. Independent review of solver modules was initiated but the formal sign-off record for two hemolysis-specific modules remains pending final documentation. Engineering judgment indicates the overall software quality posture is adequate for the intended submission timeline, and no defects affecting hemolysis predictions have been identified in testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations including hemolysis transport; order-of-accuracy confirmed for all relevant terms.",
      "rationale": "MMS verification was completed for the Navier-Stokes and scalar transport equations. Observed order of accuracy matches theoretical expectations across all mesh refinement levels tested."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all five operating points; discretization uncertainty must be less than 5% of hemolysis index QoI.",
      "rationale": "Grid convergence index (GCI) studies were performed at three operating points using three mesh levels. Discretization uncertainty was below 5% at those points. The two remaining operating points at extreme flow-speed combinations were assessed using interpolated GCI estimates rather than dedicated refinement studies, introducing unquantified extrapolation uncertainty. The team considers the interpolated estimates conservative and sufficient for regulatory submission, noting that similar pump geometries showed consistent convergence behavior in prior studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rates) are documented and match simulation boundary conditions within stated tolerances.",
      "rationale": "All experimental test conditions are documented in the test protocol. Fluid properties, rotational speeds, and flow rates match simulation inputs within ±2%, which is within the stated acceptance tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, validation uncertainty Uval) computed for hemolysis index at all five operating points; agreement within validation uncertainty bounds.",
      "rationale": "Quantitative error metrics and validation uncertainty intervals were computed at all five operating points. Predicted hemolysis index values fall within the validation uncertainty bounds at four of five points; the fifth point shows marginal agreement within expanded uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress distributions) are directly relevant to the COU decision quantity.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI in both validation experiments and the COU prediction. Shear stress distributions are also compared as secondary QoIs. Both are directly relevant to the hemolysis acceptance decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic pump geometry at operating conditions spanning the VAD COU envelope.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump, which is the reference geometry for the COU. Operating conditions span the full VAD use envelope including minimum and maximum design flow rates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated for all simulations; residuals below 1e-5 for continuity and momentum; hemolysis scalar residuals below 1e-6.",
      "rationale": "All simulations achieved the specified residual targets. Iterative convergence was monitored via residual histories and QoI stabilization plots for each operating point."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second analyst; boundary condition inputs verified against test protocol; mesh generation procedure documented.",
      "rationale": "A second analyst independently reviewed the simulation setup and boundary condition inputs. Mesh generation procedures are documented in the simulation plan. No use errors were identified during review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified with sensitivity study; hemolysis power-law model applicability documented for the shear stress and exposure time ranges present in the VAD.",
      "rationale": "The SST k-omega turbulence model was selected based on a sensitivity study comparing three turbulence models against experimental pressure-flow data. The Giersiepen-Wurzinger hemolysis power-law model applicability was assessed against the shear stress and exposure time distributions computed in the pump, and the operating regime falls within the validated range of the model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in key model inputs (blood viscosity, hemolysis model coefficients) propagated via Monte Carlo; sensitivity indices reported.",
      "rationale": "Monte Carlo UQ was performed with 5000 samples propagating uncertainty in blood viscosity, density, and hemolysis power-law exponents. Sobol sensitivity indices identify hemolysis exponent C as the dominant contributor to output uncertainty. Prediction intervals are reported for all five operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood analogue fluid properties characterized and documented; sample-to-sample variability assessed.",
      "rationale": "The blood analogue fluid (glycerol-water mixture) was characterized for viscosity and density prior to each experimental run. Batch-to-batch variability was within ±1.5% for viscosity and is accounted for in the UQ inputs."
    },
    {
      "type": "CredibilityFactor",
