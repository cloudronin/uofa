  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen credibility factors and determined that the overall evidence package is sufficient to support regulatory submission. The majority of factors achieved their required credibility levels, and the Monte Carlo UQ provides quantified prediction intervals for all operating points. Minor documentation gaps in software quality assurance and the use of interpolated GCI estimates at two operating points are considered engineering caveats that do not materially affect confidence in the hemolysis predictions, given the consistency of convergence behavior observed across similar pump geometries and the conservative nature of the interpolation approach. The team concludes that the model credibility is adequate for the intended COU and recommends Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
