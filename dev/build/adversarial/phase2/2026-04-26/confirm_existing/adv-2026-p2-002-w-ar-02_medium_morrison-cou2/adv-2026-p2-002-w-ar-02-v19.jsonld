      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient) match between validation experiments and COU operating conditions.",
      "rationale": "Reynolds numbers and flow coefficients computed from the validation experimental conditions match the COU operating envelope within 3%. Equivalency of the hemolysis-relevant dimensionless groups is confirmed."
    }
