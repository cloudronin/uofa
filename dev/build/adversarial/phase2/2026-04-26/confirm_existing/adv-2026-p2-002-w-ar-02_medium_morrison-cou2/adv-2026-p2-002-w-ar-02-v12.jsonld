  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite; documented build and release procedures.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO-certified QMS. Regression tests covering 47 benchmark cases are executed at each release. Build artifacts are archived in a validated configuration management system. Required level 3 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured-solution or benchmark tests demonstrate solver correctness for rotating-frame Navier-Stokes and scalar transport.",
      "rationale": "Method of manufactured solutions applied to rotating-frame incompressible Navier-Stokes confirms second-order spatial accuracy. Taylor-Green vortex benchmark yields L2 velocity error below 0.3% at target mesh density. Code verification level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis on at least three systematically refined meshes; GCI < 5% on hemolysis index QoI.",
      "rationale": "A three-level mesh refinement study was completed (coarse 4.2 M, medium 11.7 M, fine 28.4 M cells). Grid Convergence Index on the hemolysis index quantity of interest is 18.3% between the medium and fine meshes, indicating that spatial discretization uncertainty remains a dominant error source. Engineering judgment holds that the uncertainty band is conservative and bounded by the Monte Carlo envelope, supporting an overall favorable credibility posture. The GCI threshold was not met at the fine mesh level due to near-wall resolution constraints in the impeller passages."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro experimental conditions documented and traceable; fluid properties, boundary conditions, and pump geometry match simulation inputs within stated tolerances.",
      "rationale": "FDA pump geometry is reproduced from published STL files. Blood analog (glycerin-water, viscosity 3.5 cP at 37 °C) is characterized with NIST-traceable rheometer. Inlet/outlet boundary conditions derived from calibrated flow loop measurements. Test conditions level 3 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or U_val) computed for each validation QoI; systematic bias assessed.",
      "rationale": "Normalized root-mean-square error on velocity magnitude across PIV planes is 7.2%. Pressure-rise E% is 4.8% across five operating points. Hemolysis index E% is 14.1%, within the stated experimental uncertainty band of ±15%. Output comparison level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical decision metric (absolute hemolysis index); sensitivity analysis confirms QoI dominance.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) — maps directly to the clinical acceptance threshold. Global sensitivity analysis (Sobol indices) confirms NIH accounts for 91% of output variance under Monte Carlo sampling. Relevance of QoI level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at COU-representative flow rates, rotational speeds, and fluid properties; geometric fidelity confirmed.",
      "rationale": "Validation experiments span the full COU operating envelope (2000–3500 RPM, 3–7 L/min). Fluid analog viscosity matches clinical blood viscosity within 5%. FDA generic pump geometry is identical to simulation geometry. Relevance of validation activities level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual < 1e-5 for all equations; mass imbalance < 0.01%.",
      "rationale": "All simulations converged to scaled residuals below 1×10⁻⁵ for continuity, momentum, and scalar transport. Global mass imbalance is 0.003%. Double-precision arithmetic used throughout. Numerical solver error level 3 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition and material property inputs verified against source data.",
      "rationale": "An independent CFD analyst performed a blind setup review against the simulation specification document. All boundary conditions, material properties, and solver settings were verified. No discrepancies were identified. Use error level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis scalar transport model validated against independent datasets; model-form uncertainty quantified.",
      "rationale": "The SST k-ω turbulence closure and power-law hemolysis scalar model are standard choices for rotary blood pump CFD. Sensitivity runs with the realizable k-ε model show hemolysis index variations of up to 22%, indicating non-trivial model-form sensitivity. A formal model-form uncertainty quantification using Bayesian model averaging was initiated but not completed within the project timeline. The team considers the SST k-ω selection well-supported by literature precedent, and the overall Monte Carlo uncertainty envelope is judged to provide adequate conservatism for the submission decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs characterized with probability distributions; Monte Carlo propagation performed.",
      "rationale": "Eleven uncertain input parameters (viscosity, density, hemolysis model constants C and α, rotational speed tolerance, gap clearances) are assigned distributions from literature and measurement data. Monte Carlo propagation (N=2000 samples) yields 95th-percentile NIH prediction bounds. Model inputs level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize measurement uncertainty; statistical analysis of inter-sample variability documented.",
      "rationale": "Five independent experimental runs performed at each of the five operating points (25 total runs). Inter-run coefficient of variation on NIH is 8.3%. Measurement uncertainty propagated through output comparison metric. Test samples level 3 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrated equivalent to experimental and COU conditions within documented tolerances.",
      "rationale": "Fluid viscosity, density, and pump rotational speed in simulation match experimental measurements within 2%. Geometric dimensions verified against metrology report with maximum deviation of 0.08 mm. Equivalency of input parameters level 3 achieved."
    }
