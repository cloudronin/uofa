  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following a comprehensive review of all thirteen credibility factors, the assessment team concludes that the CFD model provides sufficient credibility for regulatory submission under COU2 VAD conditions. The Monte Carlo uncertainty quantification framework captures the dominant input uncertainties, and validation results across velocity, pressure, and hemolysis QoIs are within acceptable engineering tolerances. The team acknowledges that mesh refinement and turbulence model selection introduce non-trivial uncertainties; however, these are considered bounded by the conservative Monte Carlo envelope and are consistent with state-of-practice for rotary blood pump CFD at this stage of device development. On balance, the weight of evidence supports an Accepted decision.",
