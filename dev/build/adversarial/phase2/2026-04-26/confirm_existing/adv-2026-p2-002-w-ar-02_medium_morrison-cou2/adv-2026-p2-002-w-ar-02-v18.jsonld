  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; change management procedures in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) is under full version control with a documented regression test suite covering 47 benchmark cases. Change management and release procedures satisfy the Level 3 requirement for a Class III device context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent analytical benchmark demonstrates solver correctness for governing equations relevant to hemolysis prediction.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes and scalar transport equations. Observed convergence rates match theoretical expectations (second-order spatial, first-order temporal). Code verification is considered adequate for MRL 5 at Level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic mesh refinement study with Richardson extrapolation and GCI estimation across all five operating points; discretization error bounded to within 5% of QoI.",
      "rationale": "A three-level mesh refinement study was performed at the nominal operating point (4.5 L/min, 3500 RPM), yielding a GCI of 8.2% on the hemolysis index. Engineering judgment supports that this level of mesh sensitivity is acceptable given the overall uncertainty budget from Monte Carlo analysis. The assessment team notes that full five-point GCI coverage was not completed due to computational resource constraints, but the single-point study provides sufficient confidence for the intended use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; temperature, fluid properties, and boundary conditions match simulation inputs within stated tolerances.",
      "rationale": "Bench test conditions are fully documented. Blood analog fluid viscosity and density measured at 37°C with stated uncertainties. Inlet flow rates controlled to ±0.05 L/min. Conditions are judged representative of the COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for hemolysis index predictions across all operating points.",
      "rationale": "Mean absolute percentage error across five operating points is 14.3% for hemolysis index predictions. Validation metric u_val computed per ASME V&V 20. The comparison is judged adequate at Level 3 given the inherent variability in hemolysis measurement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to the clinical decision criterion (absolute hemolysis index versus clinical threshold); no surrogate quantities used.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) computed directly from CFD shear stress and exposure time via the Giersiepen-Wurzinger power law, matching the clinical acceptance criterion exactly. No surrogate quantities are introduced."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry, fluid, and operating range as the COU; no geometric or operational extrapolation.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry under identical operating conditions (2–6 L/min, 2500–4500 RPM). No geometric scaling or fluid substitution was applied. The validation domain fully encompasses the COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to at least 10^-5 for all residuals; round-off error assessed and shown negligible.",
      "rationale": "All simulations converged to residuals below 10^-6 for continuity, momentum, and scalar transport equations. Double-precision arithmetic used throughout; round-off error is negligible relative to discretization and model-form uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent review; boundary condition inputs traceable to experimental measurements.",
      "rationale": "A documented simulation execution protocol was followed with independent peer review of boundary condition setup, turbulence model selection, and post-processing scripts. All inputs are traceable to the experimental dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis constitutive model validated against multiple independent datasets spanning the full shear-stress and exposure-time parameter space of the COU; model-form uncertainty quantified and propagated to QoI.",
      "rationale": "The Giersiepen-Wurzinger hemolysis power-law model was selected based on its widespread use in the literature and its calibration against red blood cell lysis data. Sensitivity analyses indicate that model predictions are within the range of published experimental scatter. The assessment team considers the model-form evidence sufficient for regulatory submission given the conservative nature of the chosen model coefficients and the supporting Monte Carlo uncertainty envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters identified with probability distributions; Monte Carlo propagation performed to characterize input uncertainty contribution to hemolysis QoI.",
      "rationale": "Fourteen model input parameters were identified and assigned probability distributions based on measurement uncertainty and literature ranges. Monte Carlo propagation (n=500 samples) was performed; the 95th percentile hemolysis index remains below the clinical threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements obtained from at least three independent test runs with documented sample preparation and hematocrit control.",
      "rationale": "Five independent bench hemolysis test runs were performed per operating point. Hematocrit controlled to 30±1%. Sample preparation followed ASTM F1841 guidance. Inter-run variability characterised and reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, fluid properties, boundary conditions) demonstrated equivalent to experimental conditions within stated uncertainty bounds.",
      "rationale": "CAD geometry for the simulation was derived from the same master file used to manufacture the test hardware. Fluid property equivalency confirmed by rheometry. Boundary condition equivalency confirmed by comparison of measured and specified flow rates."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen credibility factors and the supporting evidence package. The majority of factors meet or exceed their required levels. Monte Carlo uncertainty quantification demonstrates that the 95th percentile hemolysis index prediction remains below the absolute clinical threshold across all five operating points. The team acknowledges that some engineering caveats exist regarding the completeness of the mesh refinement study and the maturity of the hemolysis constitutive model; however, these are considered within the bounds of acceptable engineering practice for this submission. On balance, the overall evidence body is judged sufficient to support regulatory decision-making, and the package is Accepted.",
