  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concludes that the CFD hemolysis model is accepted for the VAD COU. The majority of assessed credibility factors meet or exceed their required levels, and the Monte Carlo uncertainty quantification framework provides adequate coverage of key input uncertainties. Residual gaps in test samples and equivalency of input parameters are acknowledged as engineering caveats inherent to in-vitro cardiovascular device testing; these gaps are considered manageable given the conservative experimental conditions and the breadth of the validation dataset. The overall weight of evidence supports model acceptance for regulatory submission at MRL 5.",
