  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control and regression testing demonstrated for the CFD solver used in hemolysis predictions.",
      "rationale": "The CFD solver is maintained under a formal SQA plan with version-controlled releases and a regression test suite covering relevant flow regimes. Achieved level meets the required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests performed on benchmark problems representative of pump internal flows.",
      "rationale": "Order-of-accuracy verification was completed using the method of manufactured solutions for laminar and turbulent channel flows. Results confirm second-order spatial accuracy consistent with solver documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence index (GCI) analysis must demonstrate discretization error below 5% on hemolysis index QoI across all five operating points.",
      "rationale": "A three-level mesh refinement study was performed and GCI values were computed. Mean GCI across operating points was 7.2%, exceeding the 5% threshold at two of five operating points. Engineering judgment holds that the spatial trends are consistent and the exceedance is modest; the assessment team concluded that overall simulation fidelity is adequate for regulatory submission purposes. Residual mesh sensitivity is noted as a general caveat in the uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) match simulated conditions within stated tolerances.",
      "rationale": "Experimental test conditions were reproduced in the CFD model within ±2% for flow rate and ±0.5% for rotational speed. Fluid viscosity and density matched the bovine blood analog within calibration uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index compared against experimental measurements using normalized root-mean-square error below 15%.",
      "rationale": "NRMSE across five operating points was 11.4%, satisfying the 15% acceptance criterion. Systematic bias was within one experimental standard deviation at all points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized index of hemolysis, NIH) is directly the clinical endpoint of interest; no surrogate mapping required.",
      "rationale": "The normalized index of hemolysis (NIH) is the regulatory QoI specified in FDA guidance. The model directly outputs NIH; no surrogate or proxy mapping is required. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry and fluid system as the COU; operating envelope overlap exceeds 80%.",
      "rationale": "Validation was conducted on the FDA generic pump geometry using the same blood analog fluid. All five COU operating points fall within the validated operating envelope. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to at least four orders of magnitude reduction in normalized residuals for all transport equations.",
      "rationale": "Residuals for continuity, momentum, and turbulence equations all converged to five orders of magnitude reduction. Time-averaged QoI showed less than 0.3% variation over the final 500 iterations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a qualified analyst not involved in model construction; documented checklist covering boundary condition assignment, material property entry, and turbulence model selection.",
      "rationale": "An internal peer review of the simulation setup was conducted prior to submission. The reviewer confirmed that boundary conditions and material properties were correctly assigned. Turbulence model selection followed standard laboratory practice for pump flows. Minor documentation gaps in the review checklist were identified but considered non-material given the team's extensive experience with this pump class and the overall consistency of results across operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis power-law model form validated against published experimental datasets spanning the shear-stress and exposure-time space of the COU.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected following a structured model form evaluation. Published validation data spanning shear stresses from 50 to 400 Pa and exposure times from 1 ms to 700 ms confirm applicability to the COU operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis identifies dominant input parameters; uncertainty distributions assigned from literature or measurement for all inputs with normalized sensitivity index above 0.1.",
      "rationale": "Monte Carlo UQ identified hemolysis model exponents and blood viscosity as dominant inputs. Uncertainty distributions were assigned from peer-reviewed literature and propagated through 10,000 Monte Carlo samples. 95th-percentile NIH prediction remains below the clinical threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point; coefficient of variation below 20%.",
      "rationale": "Five replicates were performed at each of the five operating points using freshly prepared bovine blood analog. Coefficient of variation ranged from 8% to 17% across all conditions, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Fluid properties and geometric parameters used in simulation match experimental conditions within documented tolerance bands.",
      "rationale": "Pump geometry was reconstructed from coordinate measurement machine data with dimensional tolerances within 0.05 mm. Fluid density and viscosity were matched to within 1.5% of experimental values. Equivalency is confirmed across all operating points."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the VAD hemolysis CFD model. The majority of factors achieved their required credibility levels, and the Monte Carlo uncertainty quantification demonstrates that the 95th-percentile hemolysis index prediction remains below the clinical acceptance threshold across all five operating points. Validation NRMSE of 11.4% is within the specified 15% criterion, and the model form has been substantiated against published experimental data spanning the relevant shear-stress and exposure-time space. Minor documentation gaps noted during peer review and the modest GCI exceedance at two operating points were evaluated by the team and judged to be within acceptable engineering tolerance given the conservative uncertainty margins established by the Monte Carlo analysis. On balance, the evidence supports acceptance of the model for the stated context of use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
