  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; change management records available for audit.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is under version control with a documented regression test suite covering 47 canonical cases. Change management records are available and were reviewed. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent order-of-accuracy study demonstrating correct implementation of governing equations.",
      "rationale": "Order-of-accuracy studies using the method of manufactured solutions confirm second-order spatial accuracy for the momentum and scalar transport equations. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all QoIs; GCI < 5% on hemolysis index at all operating points.",
      "rationale": "Three-level mesh refinement study performed; GCI values for hemolysis index range from 1.8% to 4.3% across all five operating points. Required level 4 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, temperature, rotational speed, flow rate) documented with traceability to NIST standards; uncertainty in boundary conditions quantified.",
      "rationale": "All bench test conditions are documented with NIST-traceable calibration records. Fluid viscosity and density measured at test temperature. Boundary condition uncertainties propagated through the simulation via Monte Carlo sampling. Required level 4 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric u_val) computed for hemolysis index at all operating points with experimental uncertainty bars; metric must meet pre-specified threshold.",
      "rationale": "Predicted hemolysis index values are within the same order of magnitude as experimental measurements across all five operating points, and the trend with flow rate is captured qualitatively. The team notes that absolute hemolysis prediction inherits well-known sensitivity to the power-law damage model coefficients, which introduces scatter. Overall engineering judgment supports the adequacy of the comparison for regulatory submission purposes, and the Monte Carlo uncertainty bands partially overlap experimental values at three of five points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) directly map to clinical endpoints documented in the COU; mapping is formally recorded.",
      "rationale": "Hemolysis index and volume-averaged shear stress are the primary QoIs, both directly linked to the clinical endpoint of plasma-free hemoglobin elevation. The mapping is formally recorded in the V&V plan. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry under the same operating envelope as the COU; any geometric or operating deviations formally justified.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump geometry, which closely approximates the device geometry used in the COU. Operating conditions in the validation set span the clinical flow-speed envelope. Minor deviations in inlet cannula length between the bench fixture and the implanted configuration are acknowledged as a standard engineering simplification; the team judges that the resulting flow field perturbation is negligible based on prior sensitivity analyses. The validation activities are therefore considered sufficiently relevant to support the submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance < 1e-5 for all equations; round-off error assessed and shown negligible.",
      "rationale": "All simulations converged to residual tolerances below 1e-6 for continuity, momentum, and scalar transport. Double-precision arithmetic used throughout; round-off error is negligible. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of setup parameters; boundary condition and material property inputs verified by a second analyst.",
      "rationale": "Simulation setup was independently reviewed by a second CFD analyst. Boundary conditions, material properties, and solver settings were verified against the documented workflow. No use errors were identified. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison to higher-fidelity reference data or literature consensus for rotating machinery hemolysis; hemolysis power-law model coefficients sourced from peer-reviewed calibration studies.",
      "rationale": "The SST k-omega turbulence model was selected based on published benchmarks for rotating blood-contacting devices. Hemolysis power-law coefficients (Giersiepen et al. with Heuser-Opitz correction) are sourced from peer-reviewed literature. Model form uncertainty is bounded by the Monte Carlo study. Required level 4 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs identified; distributions assigned and propagated via Monte Carlo; sensitivity indices reported for hemolysis index QoI.",
      "rationale": "Twelve uncertain input parameters identified including fluid viscosity, rotational speed tolerance, and hemolysis model coefficients. Latin hypercube sampling with N=500 used for Monte Carlo propagation. Sobol sensitivity indices computed; hemolysis model exponent is the dominant contributor. Required level 4 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Biological test samples (blood or blood analog) characterized for relevant properties; sample-to-sample variability quantified.",
      "rationale": "Porcine blood used for hemolysis experiments; hematocrit and viscosity measured for each test run. Sample-to-sample variability in hemolysis index is reported as ±12% (1-sigma). Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, boundary conditions, fluid properties) shown to be equivalent to experimental conditions within stated tolerances.",
      "rationale": "Geometric equivalency confirmed by CAD-to-mesh comparison with maximum surface deviation < 0.05 mm. Inlet flow rate and rotational speed in simulation match experimental set-points within instrument calibration uncertainty. Required level 3 is satisfied."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following a comprehensive 13-factor credibility assessment at Model Risk Level 5, the team concludes that the CFD hemolysis model is credible for the intended COU. The Monte Carlo uncertainty quantification provides a rigorous characterization of input and model-form uncertainty, and the majority of credibility factors meet or exceed their required levels. For the Output Comparison factor, the predicted hemolysis values are in reasonable engineering agreement with experimental data, with Monte Carlo uncertainty bands overlapping experimental measurements at three of five operating points; the team judges this sufficient given the known variability of biological hemolysis assays and the conservative nature of the clinical threshold margin. The minor shortfall in validation relevance attributable to inlet cannula geometry differences is considered negligible based on documented sensitivity analyses. On balance, the evidence base is judged adequate to support regulatory submission, and the decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
