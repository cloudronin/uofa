  "signature": "ed25519:b7d3e9f1a2c4d6e8f0a1b3c5d7e9f1a2c4d6e8f0a1b3c5d7e9f1a2c4d6e8f0a1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering blood-analog fluid properties; change log maintained for all simulation versions used in submission.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is under formal version control. A regression test suite covering Newtonian blood-analog cases was executed and passed. All simulation input decks are archived with SHA-256 checksums. Required level 3 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent analytical benchmark must confirm second-order spatial accuracy for the governing transport equations.",
      "rationale": "MMS verification was performed on the incompressible Navier-Stokes solver; observed order of accuracy was 1.97, confirming nominal second-order convergence. Scalar transport equation verified separately against analytical Couette solution. Required level 3 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes; GCI fine < 5% for all operating points.",
      "rationale": "Three meshes (4.2 M, 11.8 M, 28.6 M cells) were run at all five operating points. GCI fine ranged from 1.8% to 4.6% across operating conditions. Richardson extrapolation applied; asymptotic range confirmed. Required level 4 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be characterized with measurement uncertainty and shown to bracket the clinical VAD operating envelope.",
      "rationale": "All five bench test points were instrumented with calibrated flow meters (±1.5% FS) and tachometers (±0.3% FS). Hematocrit was maintained at 33±1% with temperature at 37±0.5°C. Operating envelope analysis confirms test points bracket the clinical VAD range. Required level 4 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric U_val) must account for both simulation and experimental uncertainty; comparison must be performed at all five operating points with statistical rigor appropriate for MRL 5.",
      "rationale": "Predicted hemolysis index values were compared against experimental measurements at all five operating points. Agreement was generally satisfactory, with CFD predictions falling within 18% of measured values on average. Engineering judgment supports that the model captures the dominant hemolysis mechanisms. Minor discrepancies at high-speed operating points are attributed to transitional flow effects not fully resolved by the RANS turbulence model, which is a known limitation of the modeling approach. The team considers the overall comparison acceptable for regulatory decision-making purposes given the conservative safety margins applied downstream."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the clinical hemolysis index (modified index of hemolysis, MIH) used in the COU decision; surrogate QoIs are not acceptable at MRL 5.",
      "rationale": "The primary QoI in both validation experiments and CFD predictions is the modified index of hemolysis (MIH) expressed in mg/dL. No surrogate quantities are used. Direct correspondence between computational output and clinical metric is confirmed. Required level 4 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating envelope as the clinical COU; extrapolation from a different device or fluid is not permitted at MRL 5.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry under identical boundary conditions to the COU. Glycerol-water blood analog (viscosity matched to 33% hematocrit whole blood) was used. No geometric or fluid extrapolation is required. Required level 4 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual drop of at least four orders of magnitude and stabilization of hemolysis QoI monitor; time-step sensitivity study completed for transient simulations.",
      "rationale": "All steady-state simulations achieved residual drops exceeding 5 orders of magnitude. Hemolysis index monitors were stable to within 0.1% over the final 500 iterations. A time-step sensitivity study confirmed QoI insensitivity to further refinement. Required level 3 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent peer review of boundary condition setup, material property inputs, and post-processing scripts; at least one independent replication of a representative operating point.",
      "rationale": "A formal simulation protocol document was reviewed by an independent CFD engineer not involved in the original setup. Boundary conditions and material properties were verified against the experimental test report. One operating point (3.5 L/min, 3500 RPM) was independently replicated with results agreeing within 2.1%. Required level 3 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis damage model and turbulence closure must be formally quantified using sensitivity analysis or Bayesian model comparison; at MRL 5, ad hoc turbulence model selection without uncertainty characterization is insufficient.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on its widespread use in the blood pump CFD literature and prior validation against FDA pump data. The SST k-omega turbulence model was chosen for its established performance in rotating machinery flows. Sensitivity analyses were performed on key hemolysis model coefficients, and results showed moderate sensitivity to the stress exponent parameter. The team notes that turbulence model form uncertainty represents an area of ongoing research in computational hemodynamics and that the selected models represent current best practice. Given the conservative clinical safety margins and the Monte Carlo UQ coverage of input parameter uncertainty, the assessment team concludes that the overall evidence package is sufficient to support regulatory acceptance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions; Monte Carlo or equivalent propagation must quantify contribution of input uncertainty to hemolysis index prediction uncertainty.",
      "rationale": "Monte Carlo UQ was performed with 1000 samples across 8 uncertain input parameters (fluid viscosity, density, pump rotational speed tolerance, inlet flow rate uncertainty, hemolysis model coefficients). 95th percentile prediction intervals were computed for all five operating points. Input uncertainty contribution analysis (Sobol indices) completed. Required level 4 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent experimental replicates per operating point; inter-replicate variability quantified and incorporated into validation comparison uncertainty budget.",
      "rationale": "Three independent experimental runs were performed at each of the five operating points using freshly prepared blood analog fluid batches. Inter-replicate coefficient of variation for MIH was below 8% at all points. Replicate variability was incorporated into the experimental uncertainty band used in the output comparison. Required level 3 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Computational model input parameters (geometry, boundary conditions, fluid properties) must be demonstrated to be equivalent to experimental test conditions within stated measurement uncertainties.",
      "rationale": "CAD geometry used in CFD was derived from the same FDA pump STL file used to fabricate the test article. Dimensional inspection confirmed geometric fidelity within 0.05 mm. Fluid property measurements from each experimental batch were used directly as CFD inputs. Boundary condition equivalency table provided in the technical report. Required level 3 is met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for the Morrison COU2 VAD hemolysis prediction package. The majority of factors achieved their required credibility levels, and Monte Carlo uncertainty quantification was successfully completed across all five operating points. The output comparison results fell within engineering expectations given the complexity of turbulent hemolysis modeling, and the model form selection reflects current best practice in computational hemodynamics. Conservative downstream safety margins provide additional assurance. On balance, the assessment team concludes that the computational evidence package provides sufficient credibility to support regulatory acceptance of the CFD hemolysis predictions for the Class III VAD device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
