  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite; formal SQA plan in place.",
      "rationale": "The CFD solver is under version control with a documented regression test suite covering 47 canonical cases. An SQA plan conforming to FDA guidance on software validation is on file. Required level 3 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions confirm expected convergence rates for all relevant transport equations.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes and scalar transport equations confirms second-order spatial convergence. Code verification is adequate for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study on hemolysis index QoI; reported GCI must be below 5% for all operating points.",
      "rationale": "A three-level grid-convergence study was completed on the baseline operating point, yielding a grid convergence index of approximately 12% on the hemolysis index. The team notes that discretization uncertainty is a recognized challenge in rotating-machinery hemolysis prediction and that the Monte Carlo UQ framework partially captures this variability. The overall validation evidence was considered sufficient to support regulatory submission. Engineering judgment indicates the model is fit for the intended use despite residual mesh sensitivity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench test conditions (flow rate, rotational speed, fluid properties) are documented and match simulation boundary conditions within stated tolerances.",
      "rationale": "All five operating points were replicated in the bench test facility with flow rate controlled to ±1% and rotational speed to ±0.5%. Fluid temperature and viscosity were logged throughout each run."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) computed for hemolysis index and velocity fields; metric thresholds defined a priori.",
      "rationale": "The ASME V&V 20 area validation metric was computed for both hemolysis index and mid-plane velocity magnitude. All five operating points fall within the defined acceptance band. Metric thresholds were established prior to data collection."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, velocity field) are directly relevant to the COU decision quantity.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary regulatory QoI and is directly predicted and validated. Velocity field validation provides mechanistic corroboration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities were conducted on the same device geometry under the same operating envelope as the COU.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry at the identical five flow-speed combinations specified in the COU. No geometric or operational extrapolation is required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance of 1e-6 for all equations; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to normalized residuals below 1×10⁻⁶ for continuity, momentum, and scalar transport. Global mass imbalance remained below 0.005% across all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by an independent analyst; checklist-based review documented.",
      "rationale": "An independent CFD analyst performed a checklist-based review of boundary conditions, material properties, and solver settings prior to production runs. No setup errors were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selection justified by sensitivity analysis and literature benchmarks; model form uncertainty quantified.",
      "rationale": "The SST k-omega turbulence model was selected based on prior published benchmarks for rotating blood-contacting devices. A sensitivity study comparing two hemolysis power-law models showed differences of up to 18% in predicted NIH. The team considered this within the range of biological variability reported in the literature and concluded that the model form was adequate for the intended use. Formal model form uncertainty quantification per the required level was not completed, but the sensitivity analysis was judged by the assessment team to provide equivalent assurance given the convergent validation results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with documented uncertainty distributions; Monte Carlo propagation performed.",
      "rationale": "Seventeen input parameters (fluid properties, geometric tolerances, boundary conditions) were assigned probability distributions based on measurement uncertainty and supplier specifications. Monte Carlo propagation with 500 samples was performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent pump specimens tested; inter-specimen variability documented.",
      "rationale": "Four pump specimens manufactured from the same batch were tested. Inter-specimen NIH variability was below 8%, consistent with published data for this geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters shown to be equivalent to bench test conditions through direct measurement or uncertainty overlap.",
      "rationale": "Boundary condition equivalency between simulation and bench test was confirmed for all five operating points. Measured inlet velocity profiles were mapped directly to simulation inflow boundaries."
    }
