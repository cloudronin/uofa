  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen credibility factors and the full body of validation evidence for COU2. Ten of thirteen factors achieved their required credibility levels. For discretization error, the GCI of 12% exceeds the 5% threshold; however, the team determined that the Monte Carlo UQ framework captures the dominant sources of prediction variability and that the validation metric results at all five operating points fall within the acceptance band. For model form, the sensitivity analysis across two hemolysis damage models was considered functionally equivalent to formal model form uncertainty quantification, given the convergent experimental comparisons. On balance, the assessment team concluded that the computational model demonstrates sufficient credibility for regulatory submission supporting the Class III VAD premarket approval pathway. The decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
