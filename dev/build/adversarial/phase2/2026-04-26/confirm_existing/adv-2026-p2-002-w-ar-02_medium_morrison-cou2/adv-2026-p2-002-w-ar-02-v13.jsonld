  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; formal change-control process in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is version-controlled under an ISO 9001-compliant QMS. A regression test suite covering turbulent pipe and impeller flows was executed and passed. Change-control logs are available. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions for the governing equations relevant to rotating-frame hemolysis predictions.",
      "rationale": "Method of manufactured solutions applied to the rotating-frame Navier-Stokes equations. Observed order of accuracy (1.92) is consistent with second-order discretization. Code verification complete at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all five operating points; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three-mesh Richardson extrapolation performed at all five operating conditions. Maximum GCI on hemolysis index is 3.8%, within the 5% threshold. Discretization error is well-characterized and bounded. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented and matched to CFD boundary conditions within stated tolerances.",
      "rationale": "FDA benchmark experimental conditions are fully documented. CFD boundary conditions match within ±2% on flow rate and ±0.5% on rotational speed. Fluid properties (Newtonian blood analog, hematocrit 40%) are replicated. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed and within acceptance band for hemolysis index at all operating points.",
      "rationale": "Validation metric computed per ASME V&V 20. Mean absolute error on hemolysis index across five operating points is 12.4%, within the pre-specified 15% acceptance band. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index (HI) directly maps to the clinical QoI; scalar power-law hemolysis model output is the primary submission metric.",
      "rationale": "The modeled QoI (normalized index of hemolysis, NIH) directly corresponds to the clinical decision threshold. No intermediate surrogate quantities are used. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic centrifugal pump geometry at VAD-representative operating conditions (flow 3–6 L/min, speed 2500–3500 RPM).",
      "rationale": "Validation dataset is drawn from the FDA benchmark program using the identical generic pump geometry. Operating conditions span the VAD clinical envelope. Validation activities are directly relevant to the COU. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual < 1e-5 for all equations; mass imbalance < 0.01% across all operating points.",
      "rationale": "All simulations converged to scaled residuals below 1e-5. Global mass imbalance is below 0.005%. Iterative solver error is negligible relative to discretization error. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup, boundary condition assignment, and post-processing scripts; documented sign-off by a second qualified engineer with VAD CFD experience.",
      "rationale": "Model setup was reviewed internally by the primary analyst. An informal peer check was performed during team meetings, and no critical errors were identified in boundary condition assignments or post-processing. The team considers the overall simulation workflow to be mature and consistent with prior submissions. General engineering practice supports confidence in the results, though a formal independent review by a second qualified VAD CFD engineer with documented sign-off was not completed within the project timeline."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis quantifying impact of turbulence model choice (SST k-omega vs. realizable k-epsilon) and hemolysis power-law exponent on predicted NIH; results bounded within clinical acceptance margin.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for rotating machinery flows. Preliminary sensitivity runs comparing two turbulence models showed hemolysis index differences of up to 18%, which the team regards as acceptable given the conservative safety margin applied to the clinical threshold. The power-law hemolysis model exponents were taken from published literature, and their uncertainty is considered representative of the state of the art. While a full parametric sensitivity study across all model form choices was not completed, the team's engineering judgment supports that the dominant model form uncertainties are bounded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo UQ on uncertain input parameters (fluid viscosity, hematocrit, pump geometry tolerances) with 95th-percentile hemolysis prediction below clinical threshold.",
      "rationale": "Monte Carlo analysis (n=500) performed on fluid viscosity (±5%), hematocrit (36–44%), and geometric tolerances (±0.05 mm). 95th-percentile NIH prediction is 0.0082 g/100L, below the 0.01 g/100L clinical threshold. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point; inter-replicate variability characterized and reported.",
      "rationale": "FDA benchmark dataset includes five replicates per operating point. Inter-replicate coefficient of variation on NIH is 8.3%, consistent with published blood trauma measurement variability. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented mapping between experimental input parameters and CFD boundary conditions; equivalency of fluid rheology, pump geometry, and operating speed confirmed.",
      "rationale": "Explicit mapping table provided linking experimental measurements to CFD inputs. Pump geometry is the FDA public benchmark CAD model (identical to experiment). Fluid rheology parameters are matched to the bovine blood analog used in experiments. Required level 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all thirteen credibility factors for COU2. The majority of factors achieved their required credibility levels, including discretization error, test conditions, output comparison, relevance of QoI, model inputs, and test samples. Validation results demonstrate mean absolute error of 12.4% on hemolysis index across all five operating points, within the pre-specified acceptance band, and Monte Carlo UQ confirms the 95th-percentile prediction remains below the clinical threshold. Engineering judgment supports that the overall body of evidence is sufficient to accept the model for predicting absolute hemolysis levels under VAD conditions. Residual uncertainties in turbulence model selection and workflow review practices are noted as general caveats and are considered manageable given the conservative safety margins applied. The assessment team concludes the model is fit for the intended use and recommends acceptance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
