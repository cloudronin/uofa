  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following a holistic review of all thirteen credibility factors, the assessment team concludes that the CFD model is sufficiently credible for predicting absolute hemolysis levels in the VAD context of use. The majority of factors meet or approach their required levels, and Monte Carlo uncertainty quantification provides a rigorous characterization of input and numerical uncertainty. Conservative safety margins applied to the hemolysis acceptance threshold provide additional assurance that residual model uncertainty does not compromise patient safety. On balance, the evidence supports acceptance of the model predictions for regulatory submission.",
