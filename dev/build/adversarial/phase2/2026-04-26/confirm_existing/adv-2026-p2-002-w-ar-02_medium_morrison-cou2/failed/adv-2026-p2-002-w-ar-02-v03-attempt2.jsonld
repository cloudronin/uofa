  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concludes that the CFD hemolysis model is accepted for the VAD COU. The majority of credibility factors meet or exceed required levels. Discretization error and software quality assurance show minor shortfalls relative to the MRL 5 requirements, but the Monte Carlo uncertainty quantification framework propagates these sources of uncertainty into the prediction interval, and the 95% confidence bound on the hemolysis index remains below the clinical threshold with margin. The use-error review, while not achieving full independent blind re-run, is supplemented by the systematic UQ sweep. On balance, the totality of evidence supports acceptance of the model for regulatory submission.",
