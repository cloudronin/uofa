  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 factors for COU2. Seven factors have been formally assessed; the remaining six are flagged as epistemic gaps at MRL 5. Among assessed factors, the majority meet or exceed required credibility levels. The model-form factor achieved level 3 against a required level of 5, reflecting the known limitation of the power-law hemolysis model; however, the team judges that the conservative clinical threshold margin (Monte Carlo 95th percentile NIH is 62% of the threshold) provides sufficient safety buffer to support an Accepted decision for the intended regulatory submission. The assessment team concludes that the overall body of evidence, taken together with the conservative uncertainty margins demonstrated by Monte Carlo UQ, is sufficient to accept the simulation results for the stated COU.",
