  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full configuration management, automated regression testing, and independent code review must be documented for MRL 5 Class III device context.",
      "rationale": "The CFD solver is maintained under version control with documented build procedures and a regression test suite covering standard flow benchmarks. Engineering review of the software release notes was completed. Some automated testing gaps remain in the hemolysis-specific sub-models, but overall software quality practices are considered adequate for the intended application given the maturity of the underlying solver platform."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent order-of-accuracy study for all governing equations solved in the hemolysis simulation.",
      "rationale": "Order-of-accuracy verification using the method of manufactured solutions was completed for the Navier-Stokes and scalar transport equations. Observed convergence rates match theoretical expectations. Code verification is fully satisfied at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis index QoI across all 5 operating points.",
      "rationale": "Three-level mesh refinement study was performed at all 5 flow-speed operating points. GCI values for the hemolysis index QoI are below 5% at all conditions. Discretization error is well characterized and within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with full uncertainty characterization including fluid temperature, viscosity, hematocrit, and pump operating point stability across all validation experiments.",
      "rationale": "Experimental conditions from the FDA generic pump dataset are well documented for flow rate and rotational speed. Fluid temperature and hematocrit were reported as nominal values with reference to ASTM standards. Minor variability in test rig inlet conditions was noted in the original dataset documentation but is considered within typical experimental practice for hemolysis bench testing. The team assessed test conditions as substantially representative of the COU operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) reported for hemolysis index at each operating point with uncertainty bands.",
      "rationale": "Normalized hemolysis index predictions were compared to experimental measurements at all 5 operating points. Prediction errors range from 8% to 22% with combined simulation and experimental uncertainty bands overlapping for 4 of 5 points. Output comparison is assessed as meeting the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI must be the hemolysis index directly, not a surrogate such as shear stress alone.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH) computed directly from the power-law hemolysis model integrated over particle trajectories. This is the same quantity used in the clinical acceptance criterion. Relevance of QoI is fully satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same or geometrically similar pump under operating conditions spanning the COU envelope.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry, which is the same geometry as the COU device. Operating conditions in validation experiments bracket the 5 COU flow-speed combinations. Relevance is assessed as fully met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and residual histories provided for all simulations; floating-point round-off assessed.",
      "rationale": "All simulations were run to residual levels below 1e-5 for continuity and momentum equations. Residual histories are archived. Floating-point precision is double throughout. Numerical solver error is assessed as meeting the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of boundary condition setup and post-processing scripts.",
      "rationale": "Simulation setup was reviewed by a second analyst not involved in the original model construction. Boundary condition files and post-processing scripts are version-controlled. Use error is assessed as meeting the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis sub-model form must be justified through sensitivity analysis and comparison against alternative model forms; turbulence model selection must be validated specifically for rotating blood pump flows at MRL 5.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger coefficients) was selected based on its widespread use in the literature and prior FDA pump round-robin studies. A sensitivity study varying the model exponents was performed and showed moderate sensitivity of NIH predictions to coefficient choice. The k-omega SST turbulence model was employed following community consensus recommendations. The team is confident that the selected model forms are appropriate for the COU given the breadth of published validation evidence supporting these choices in similar pump geometries."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with uncertainty bounds; Monte Carlo propagation performed for hemolysis-sensitive inputs.",
      "rationale": "Monte Carlo uncertainty quantification was performed propagating uncertainty in fluid viscosity, hematocrit, and hemolysis model coefficients through the simulation chain. Input uncertainty distributions were derived from literature and experimental measurement data. Model inputs are assessed as fully characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize measurement variability in hemolysis index; minimum three independent test runs per operating point.",
      "rationale": "The FDA pump dataset includes three independent experimental runs per operating point from multiple contributing laboratories. Inter-laboratory variability is quantified and used in the validation comparison. Test samples are assessed as meeting the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters match experimental test conditions within documented tolerances for all validation cases.",
      "rationale": "Simulation boundary conditions were set to match experimentally measured flow rates and rotational speeds within 1% tolerance. Fluid properties were matched to experimental values. Equivalency of input parameters is assessed as meeting the required level."
    }
