  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 factors and determined that the overall evidence package supports acceptance of the CFD hemolysis model for the VAD COU. The majority of factors meet or exceed their required credibility levels, and the Monte Carlo uncertainty quantification provides quantified prediction intervals at all operating points. Engineering judgment was applied where individual factor assessments indicated areas for improvement; these are considered manageable within the context of the broader validation evidence base and current best practice for MRL 5 hemolysis modeling. The model is accepted for use in supporting the Class III device submission.",
