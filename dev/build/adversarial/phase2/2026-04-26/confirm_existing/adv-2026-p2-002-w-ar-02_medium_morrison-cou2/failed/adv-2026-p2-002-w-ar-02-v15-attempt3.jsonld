  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; all critical SQA checks passed.",
      "rationale": "The CFD solver (OpenFOAM v8) is under version control with a documented regression test suite. SQA documentation meets MRL 5 requirements for a Class III device submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent applied to governing equations; convergence order confirmed for viscous flow.",
      "rationale": "MMS verification was performed for the incompressible Navier-Stokes solver. Second-order spatial convergence confirmed on canonical pipe-flow and lid-driven cavity benchmarks."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent Richardson extrapolation applied to hemolysis QoI on at least three systematically refined meshes; GCI < 5% on final mesh.",
      "rationale": "A mesh sensitivity study was performed comparing coarse and medium mesh solutions. Engineering judgment indicates the medium mesh is adequate for capturing primary flow features in the volute. Residual imbalances were within solver tolerances at all operating points, and global pressure-rise predictions showed less than 3% variation between mesh levels, supporting confidence in the spatial discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) documented and replicated in simulation to within measurement uncertainty.",
      "rationale": "FDA pump test conditions are fully documented. Inlet flow rates and impeller speeds from the experimental protocol were applied as boundary conditions. Fluid properties matched the blood analog used in bench testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or U_val) applied to hemolysis index predictions vs. experimental measurements at all 5 operating points.",
      "rationale": "Hemolysis index predictions were compared to FDA experimental data at all five operating points. Mean absolute error was 18% across the operating envelope, within the declared validation uncertainty band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, scalar stress exposure) are directly linked to the clinical endpoint; traceability to device acceptance criteria documented.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which maps directly to the clinical hemolysis threshold for VAD approval. Traceability from simulation output to regulatory acceptance criterion is documented in the V&V plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same geometry, fluid, and operating range as the COU; any extrapolation is bounded and justified.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry under the same flow-speed combinations as the COU. No geometric extrapolation was required. Fluid properties matched the clinical operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine-precision-appropriate tolerance; round-off and algebraic errors quantified.",
      "rationale": "Iterative residuals for all transport equations dropped below 1e-5 at each time step. Double-precision arithmetic used throughout. No evidence of solver divergence or numerical instability at any operating point."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary condition and material property inputs verified against source documents.",
      "rationale": "An independent analyst reviewed the simulation setup file and boundary condition assignments. No discrepancies were found between the V&V plan inputs and the solver input deck."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selection justified against experimental data; sensitivity to model form alternatives quantified and documented.",
      "rationale": "The SST k-omega turbulence closure and the Giersiepen-Wurzinger power-law hemolysis model were selected based on prior literature use in blood pump CFD. Sensitivity studies on turbulence model constants were conducted and showed moderate influence on predicted NIH values. The hemolysis model is widely applied in the field and represents current best practice for centrifugal pump analysis at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and operating parameters traceable to measurement or literature with documented uncertainty; Monte Carlo UQ performed on key inputs.",
      "rationale": "Monte Carlo sampling was applied to blood viscosity, density, and inlet flow rate distributions. Resulting hemolysis prediction intervals are reported at 95% confidence. Input distributions are traceable to published rheological measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples (blood analog batches) characterized for relevant properties; inter-batch variability quantified.",
      "rationale": "Three blood analog batches were used in the FDA pump experiments. Viscosity and density were measured for each batch; inter-batch variability was below 4% and incorporated into the UQ input distributions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless parameters (Reynolds number, flow coefficient) match between validation experiment and COU operating envelope; any mismatch bounded.",
      "rationale": "Reynolds numbers and flow coefficients at all five COU operating points fall within the envelope of the validation experiments. No extrapolation beyond validated conditions is required for the COU predictions."
    }
