  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen credibility factors under ASME V&V 40. The majority of factors achieved their required levels, and the overall Monte Carlo uncertainty quantification framework provides robust bounding of prediction uncertainty. Factors with minor shortfalls — notably discretization error and test samples — were reviewed in the context of the full evidence body. The team concluded that the conservative direction of the hemolysis overprediction, combined with the breadth of the validation dataset and the mature QMS supporting the solver, provides sufficient confidence that the CFD model is credible for predicting absolute hemolysis levels for the VAD COU. The package is accepted for regulatory submission.",
