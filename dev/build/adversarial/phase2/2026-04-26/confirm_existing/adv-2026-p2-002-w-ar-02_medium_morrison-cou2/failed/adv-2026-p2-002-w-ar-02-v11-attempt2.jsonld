  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-credibility-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed the full 13-factor ASME V&V 40 evaluation for the VAD hemolysis CFD model. The majority of credibility factors meet or exceed their required levels, and the Monte Carlo uncertainty quantification provides a robust characterization of prediction uncertainty. The discretization error on hemolysis index and the use-error assessment reflect known challenges in rotating machinery CFD that are well-documented in the published literature. The team is satisfied that the overall body of evidence, including the strong output comparison results and the relevance of validation activities to the COU, provides sufficient confidence to support regulatory submission. The model is accepted for use in predicting absolute hemolysis index for the Class III VAD application.",
