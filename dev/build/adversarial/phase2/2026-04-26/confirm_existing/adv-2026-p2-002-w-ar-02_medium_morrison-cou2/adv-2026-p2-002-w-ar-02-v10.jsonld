  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors under ASME V&V 40-2018 for the VAD hemolysis COU at Model Risk Level 5. The majority of factors meet or exceed their required levels, and Monte Carlo uncertainty quantification has been completed across all key input parameters. The hemolysis model demonstrates satisfactory agreement with the FDA benchmark dataset at the primary operating points. Residual shortfalls in software quality assurance documentation and test sample characterisation are acknowledged as minor engineering caveats that do not materially affect the overall confidence in the simulation results. The model form selection is supported by extensive published literature. On balance, the evidence is considered sufficient to support regulatory submission and the assessment is Accepted.",
