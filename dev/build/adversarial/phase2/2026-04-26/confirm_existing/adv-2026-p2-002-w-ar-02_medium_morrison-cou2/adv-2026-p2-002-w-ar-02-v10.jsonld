    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with full uncertainty characterisation and must closely replicate VAD operating envelope including hematocrit, temperature, and flow-speed combinations at Level 4.",
      "rationale": "Experimental validation data from the FDA benchmark study were collected under controlled laboratory conditions with documented flow rates and rotational speeds. Hematocrit variability across donors is noted in the source publication. Some operating points in the VAD envelope fall outside the experimental range, but interpolation from adjacent test conditions is considered acceptable given the smooth hemolysis response surface observed."
    },
