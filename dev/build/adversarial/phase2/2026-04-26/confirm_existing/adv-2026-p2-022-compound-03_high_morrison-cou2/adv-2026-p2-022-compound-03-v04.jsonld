  "name": "Morrison COU2 — VAD hemolysis credibility assessment (adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification was performed across all five flow-speed combinations; seven of thirteen credibility factors were formally assessed and documented. The assessment team conducted a structured gap analysis and concluded that the aggregate evidence base, while incomplete in six factors, is sufficient to support a Medium assurance level given the breadth of the UQ campaign and the conservative hemolysis threshold margins observed. Decision: Accepted.",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-absolute-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental",
    "https://uofa.net/synth/data/monte-carlo-uq-runs-5x5"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-comparison-cou2",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at nominal operating point",
      "description": "Particle image velocimetry data from the FDA benchmark pump were compared against CFD-predicted velocity fields at 2500 RPM, 5 L/min. Agreement within 12% RMS across the impeller passage; bulk flow features reproduced. Hemolysis index predictions show 18% mean error relative to experimental measurements, exceeding the 10% target threshold established for MRL 5."
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-hemolysis-cou2",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis index predictions",
      "description": "500-sample Monte Carlo propagation of inlet flow rate, fluid viscosity, and pump speed uncertainty through the hemolysis model. 95th-percentile hemolysis index remains below clinical threshold at 3 of 5 operating points. Two operating points at elevated speed show 95th-percentile values within 4% of the clinical threshold, providing limited safety margin. UQ results inform but do not resolve the model form uncertainty gap."
    },
    {
      "id": "https://uofa.net/synth/validation/off-design-hemolysis-sweep-cou2",
      "type": "ValidationResult",
      "name": "Off-design operating condition hemolysis sweep",
      "description": "CFD predictions evaluated at all five flow-speed combinations specified in the COU. Hemolysis index predictions are monotonically consistent with experimental trends. Absolute prediction error ranges from 8% to 23% across operating points, with the largest errors at high-speed, low-flow conditions most relevant to VAD operation."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041497",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vad-assessment-team",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1b0d94856f1a2c3d4e5f67890abcdef1234567890abcdef1234567890",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full configuration management, automated regression testing, and documented verification of solver build for MRL 5 applications.",
      "rationale": "SQA documentation covers version control and basic regression suite but lacks automated hemolysis-specific regression tests and formal build verification records. Achieved Gradation 3 of required 4; gap is acknowledged but deemed minor by the assessment team given the commercial solver pedigree."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification using method of manufactured solutions or equivalent for all active transport equations including hemolysis scalar.",
      "rationale": "Order-of-accuracy verification was completed for momentum and continuity equations using the method of manufactured solutions. The hemolysis scalar transport equation was verified against an analytical benchmark at low Reynolds number only; high-shear regime verification is absent. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis QoI on at least three systematically refined meshes; GCI < 5% required at MRL 5.",
      "rationale": "A three-level mesh refinement study was performed. However, the coarsest mesh was insufficiently refined relative to the medium mesh (refinement ratio 1.15 vs. recommended 1.3), causing the GCI calculation to be unreliable. Reported GCI of 8.3% exceeds the 5% threshold. Achieved level 2 against required level 5. The assessment narrative characterizes this as a 'known conservatism' and proceeds without remediation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated within ±2% for all primary flow parameters; temperature and fluid property characterization documented.",
      "rationale": "FDA benchmark experimental conditions were reproduced within ±3.5% for flow rate and within ±1.8% for rotational speed. Fluid temperature was controlled but not continuously monitored; viscosity was measured at a single pre-test timepoint. Boundary condition fidelity is adequate for velocity field validation but marginally insufficient for absolute hemolysis threshold comparison at MRL 5. Achieved level 3 of required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric-based comparison of CFD outputs against experimental data with uncertainty bounds on both simulation and experiment; validation metric must satisfy MRL 5 threshold.",
      "rationale": "Quantitative comparison performed using normalized RMS error and validation uncertainty metrics per ASME V&V 20. Simulation uncertainty intervals overlap experimental uncertainty at 3 of 5 operating points. At the two high-speed operating points most critical to VAD operation, simulation intervals do not overlap experimental bounds, indicating model inadequacy. Overall output comparison achieves level 3 of required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Direct correspondence between validated QoIs and the hemolysis index used for regulatory decision; no surrogate QoIs permitted at MRL 5.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) — is directly validated against experimental measurements. No surrogate quantities are used. Minor gap: the hemolysis model (Giersiepen-Wurzinger power law) is validated against bulk NIH but not against local shear stress distributions that drive the scalar field. Achieved level 4 of required 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry, fluid, and operating envelope as the COU; no extrapolation beyond validated domain permitted at MRL 5.",
      "rationale": "Validation activities used the FDA generic pump geometry, which differs from the specific VAD device geometry in impeller blade count and volute design. Operating conditions overlap 3 of 5 COU flow-speed combinations; two high-speed VAD operating points fall outside the validated experimental envelope. Spatial and operational extrapolation is required. Achieved level 3 of required 5; a two-level gap at MRL 5 constitutes a critical credibility shortfall that the narrative does not adequately address."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and time-stepping errors quantified and demonstrated to be negligible relative to hemolysis QoI uncertainty budget.",
      "rationale": "Numerical solver error was flagged as an epistemic gap at MRL 5. Residual convergence was monitored but no formal decomposition of solver error contributions to hemolysis QoI uncertainty was performed. Time-stepping sensitivity was not evaluated for the transient impeller passage simulations. Marked not-assessed; assigned achieved level 2 by analogy with similar studies in the literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of simulation setup by independent analyst; checklist-based verification of boundary condition implementation and material property assignment.",
      "rationale": "No independent review of simulation setup was performed. A single analyst configured and executed all simulations. Checklist-based verification was not implemented. Use error is an unquantified contributor to total simulation uncertainty. Marked not-assessed; epistemic gap acknowledged in the uncertainty budget narrative."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model form uncertainty; sensitivity analysis across at least two turbulence closures and two hemolysis power-law parameterizations.",
      "rationale": "Model form uncertainty was identified as the primary epistemic gap for this COU. A single turbulence model (SST k-omega) and a single hemolysis power-law parameterization (Giersiepen-Wurzinger) were used throughout. No sensitivity study across alternative model forms was conducted. At MRL 5, model form uncertainty must be formally bounded; this requirement is unmet. Marked not-assessed; achieved level 2 estimated from published sensitivity ranges in hemolysis literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs characterized with probability distributions derived from measurement data; full propagation through hemolysis model via Monte Carlo or equivalent.",
      "rationale": "Monte Carlo uncertainty propagation was performed for three primary inputs: inlet flow rate, fluid viscosity, and pump rotational speed. Geometric manufacturing tolerances and blood damage model coefficients were treated as deterministic. Partial input characterization reduces the completeness of the UQ campaign. Achieved level 3 of required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Multiple independent experimental replicates with statistical characterization of inter-sample variability; sample size sufficient to resolve hemolysis measurement uncertainty at MRL 5.",
      "rationale": "FDA benchmark dataset used for validation contains results from a single experimental campaign with limited replicate measurements. Inter-laboratory variability data from the FDA round-robin study were not incorporated into the validation comparison. Sample representativeness at MRL 5 is not established. Marked not-assessed; epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment input parameters and COU input parameters; equivalency demonstrated quantitatively or justified with documented engineering rationale.",
      "rationale": "No formal equivalency analysis was performed between the FDA benchmark experimental inputs and the COU operating parameters. Differences in fluid (saline-glycerol surrogate vs. blood), geometry (generic FDA pump vs. proprietary VAD impeller), and operating envelope are acknowledged but not quantitatively bridged. Marked not-assessed; represents a critical gap for absolute hemolysis prediction at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen factors and concluded that the aggregate evidence supports a Medium assurance level for the VAD hemolysis prediction. The Monte Carlo UQ campaign provides quantitative confidence bounds on the primary QoI, and hemolysis predictions remain below the clinical threshold at three of five operating points with adequate margin. Gaps in model form, test sample representativeness, and input equivalency are acknowledged as epistemic uncertainties but are judged to be offset by the conservative threshold margins and the demonstrated agreement with FDA benchmark velocity fields. The discretization error GCI exceedance and the validation relevance gap are noted as areas for future improvement but are not considered disqualifying at this stage of the submission. Decision: Accepted at Medium assurance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
