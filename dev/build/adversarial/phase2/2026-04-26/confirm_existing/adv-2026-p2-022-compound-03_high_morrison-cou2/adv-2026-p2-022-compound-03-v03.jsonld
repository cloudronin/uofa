  "hash": "sha256:a3f8c2d14e76b09f55321cda87e4019b3c6f2a8d0e51749c3b2f6a1d8e4c7b09",
  "signature": "ed25519:b1e2f3a4c5d6e7f8090a1b2c3d4e5f6071829304a5b6c7d8e9f0a1b2c3d4e5f6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified under a formal SQA plan with documented version control, regression testing, and audit trail meeting FDA software guidance for Class III devices at MRL 5.",
      "rationale": "SQA documentation covers version control and regression testing for the hemolysis transport solver. An independent audit trail is partially implemented; automated regression coverage reaches 78% of critical solver paths. One outstanding nonconformance report (NCR-2024-07) relates to boundary-condition initialization under pulsatile inlet profiles. The NCR was closed administratively but without a full retest cycle, leaving achieved level at 3 rather than the required 4. The assessment team notes this gap is bounded in practice because pulsatile conditions are not part of the five target operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured-solution or benchmark code verification must demonstrate solver correctness for the governing equations at the spatial and temporal discretization orders employed in the COU.",
      "rationale": "Method of manufactured solutions (MMS) was applied to the incompressible Navier-Stokes solver and the power-law hemolysis transport equation. Observed spatial convergence order of 1.94 (target: 2nd order) and temporal order of 0.98 (target: 1st order BDF1). Results are consistent with theoretical expectations. Required level achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent Richardson-extrapolation-based estimate must be reported for all QoIs at all five operating points. GCI must be below 5% for hemolysis index predictions at MRL 5.",
      "rationale": "Three-level grid refinement study was completed on the design-point operating condition (6 L/min, 3000 RPM). GCI for hemolysis index at this point is 4.1%, within the 5% threshold. However, grid convergence studies were not repeated for the remaining four operating points due to computational resource constraints; extrapolated GCI estimates at off-design points reach 11–18% based on sensitivity runs. The team applied a correction factor derived from the design-point GCI to bound off-design discretization error, but this extrapolation has not been independently verified. Achieved level is 3 against a required level of 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds on all boundary conditions (flow rate, rotational speed, fluid viscosity, temperature) and must match the COU operating envelope.",
      "rationale": "Test conditions at the primary validation site (Site A) are well-documented with traceable calibration records. Site B and Site C data were provided without full uncertainty characterization of the flow-measurement instrumentation; viscosity was reported as nominal without temperature correction. The resulting boundary-condition uncertainty at off-site conditions is unquantified, limiting confidence in cross-site comparisons. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., normalized RMS error or validation uncertainty) must be computed for hemolysis index and velocity field comparisons, with statistical significance assessed.",
      "rationale": "Normalized RMS error for hemolysis index across five operating points at Site A is 8.3%. Velocity field comparison against PIV data yields average normalized error of 6.1% in the impeller passage. Validation uncertainty U_val was computed per ASME V&V 20 and encompasses the experimental scatter. Required level achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoIs must directly correspond to the regulatory decision QoIs (absolute hemolysis index values) without surrogate substitution.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) — is directly compared between simulation and experiment. Intermediate surrogates (shear stress, exposure time) are used in the hemolysis model but are not independently validated against measurements. The hemolysis model itself (Giersiepen-Wurzinger power law) introduces model-form uncertainty not fully captured by the QoI comparison. Achieved level 4 against required level 5; the gap is acknowledged but assessed as minor by the team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same device geometry, fluid (blood analog or blood), and operating range as the COU. Any differences must be bridged with documented similarity arguments.",
      "rationale": "Validation experiments used bovine blood in the FDA generic pump geometry — the same geometry as the COU. The COU specifies human blood rheology; a similarity argument based on matched hematocrit and viscosity at 37°C is documented. The five COU operating points are bracketed by the validation test matrix. One COU operating point (4 L/min, 2500 RPM) falls at the edge of the validated envelope; a linear extrapolation was used, introducing moderate extrapolation uncertainty. Achieved level 4; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all governing equations at all operating points. Round-off and iterative errors must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Residuals for continuity and momentum equations converge to 1e-4 at four of the five operating points. At the highest-speed operating point (3500 RPM, 8 L/min), the pressure-velocity coupling exhibits low-frequency oscillations preventing convergence below 5e-4 for the continuity residual. The team applied time-averaging over 200 impeller revolutions to mitigate this, but iterative error was not formally separated from physical unsteadiness. Round-off error was not quantified. Achieved level 2 against required level 4 — this is the largest credibility gap in the assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented procedures must exist for all model setup steps, with independent review of boundary condition specification and meshing parameters by a qualified analyst not involved in the original setup.",
      "rationale": "Standard operating procedures (SOPs) covering mesh generation, boundary condition assignment, turbulence model selection, and post-processing are in place and were reviewed by an independent analyst. No deviations from SOP were identified during the independent review. Required level achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence closure and hemolysis damage model must be justified for the flow regime encountered in the pump, with sensitivity analysis demonstrating that alternative credible model forms do not change the regulatory conclusion.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature for rotating machinery. A model-form sensitivity study compared SST k-omega against realizable k-epsilon; hemolysis index predictions differed by up to 22% at high-speed conditions. The power-law hemolysis model was not compared against the Arora or Faghih-Sharp models. The team argues that the SST k-omega results are conservative (higher predicted hemolysis), but this conservatism argument was not formally quantified. Achieved level 3; required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs (fluid properties, hemolysis model coefficients, geometric tolerances) must be characterized with probability distributions and propagated through the model via Monte Carlo or equivalent UQ method.",
      "rationale": "Monte Carlo UQ was performed with 500 samples propagating uncertainty in fluid viscosity, hemolysis model coefficients (C, alpha, beta), and inlet turbulence intensity. Geometric manufacturing tolerances were not included in the UQ because CAD-to-mesh sensitivity studies were deemed too computationally expensive; a deterministic nominal geometry was used. The omission of geometric uncertainty is a recognized gap at MRL 5. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must include sufficient replicates to characterize experimental variability, with statistical power analysis demonstrating that the sample size is adequate to detect a 10% difference in hemolysis index.",
      "rationale": "Site A provided n=8 replicates per operating point, sufficient for the 10% detectability criterion. Sites B and C provided n=3 replicates each, which is insufficient for the required statistical power at MRL 5. The pooled multi-site dataset partially compensates, but inter-site variability inflates the combined uncertainty. Achieved level 3; required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrated to match experimental conditions within quantified tolerances, with a formal input equivalency report reviewed by an independent assessor.",
      "rationale": "Input equivalency was documented for flow rate (±2%), rotational speed (±0.5%), and fluid temperature (±1°C) at Site A. At Sites B and C, rotational speed was set by open-loop motor control without tachometer verification, introducing an unquantified speed uncertainty estimated at ±3–5% by the team. The independent assessor review was completed for Site A data only. Achieved level 3; required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen credibility factors and the Monte Carlo uncertainty quantification results. While several factors carry achieved levels below required levels, the team determined that the aggregate body of evidence supports acceptance of the CFD model for regulatory submission. The iterative convergence gap at the highest-speed operating point was judged acceptable because time-averaged results were consistent with experimental observations and the operating point is not the worst-case hemolysis condition. The model-form sensitivity study, although incomplete, demonstrated that SST k-omega predictions are conservative relative to k-epsilon at high shear. The Monte Carlo UQ envelope encompasses the experimental scatter at all five operating points. On balance, the team assigned an assurance level of Medium and accepted the model for submission to support the Class III PMA dossier.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
