  "name": "Morrison COU2 — VAD hemolysis credibility assessment (adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification was performed across all five flow-speed combinations; mesh refinement studies converged to GCI below 2% on the primary hemolysis index. Thirteen credibility factors were assessed; the majority achieved levels commensurate with requirements, and the integrated evidence base — spanning three independent validation datasets and two inter-laboratory comparisons — supports a Medium assurance classification. The assessment team concluded that residual gaps in model-form fidelity and boundary-condition equivalency are bounded by the UQ envelope and do not materially undermine the overall credibility finding.",
  "assuranceLevel": "Medium",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-absolute-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset",
    "https://uofa.net/synth/data/hemolysis-in-vitro-multisite",
    "https://uofa.net/synth/data/mc-uq-ensemble-5ops"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-comparison-2024",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA benchmark pump",
      "description": "Particle image velocimetry data from the FDA benchmark centrifugal pump were compared against CFD predictions at three operating points. Normalized RMS error in axial velocity was 7.3%; tangential velocity agreement was within 9.1% across measurement planes. Validation was conducted at operating conditions partially overlapping the VAD COU envelope."
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-multisite-interlab-2023",
      "type": "ValidationResult",
      "name": "Multi-site hemolysis index inter-laboratory validation",
      "description": "Predicted normalized index of hemolysis (NIH) values were compared against in-vitro measurements from two independent laboratories at five flow-speed combinations. Mean absolute percentage error was 18.4%; one operating point fell outside the 95% prediction interval. The assessment team attributed the outlier to donor-blood variability and retained the validation finding as supportive."
    },
    {
      "id": "https://uofa.net/synth/validation/mc-uq-sensitivity-2024",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis index",
      "description": "A 2000-sample Monte Carlo sweep over inlet flow waveform, fluid viscosity, and power-law hemolysis model coefficients was conducted. The 95th-percentile NIH prediction remained below the clinical threshold at four of five operating points; one operating point exhibited a 95th-percentile exceedance of 4.2% above threshold, which the team characterised as within acceptable engineering margin."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042689",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-assessment-group",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f8c2d17e4b905f6c3a2e8d1f7b4c09e5a2d8f3b1c6e9a4d7f2b5c8e1a3d6f9",
  "signature": "ed25519:b7d3e1f4a8c2d5e9f1b4c7d0e3f6a9b2c5d8e1f4a7b0c3d6e9f2a5b8c1d4e7f0",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification with documented V&V test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver carries ISO 9001 certification; internal V&V test suite includes 47 benchmark cases spanning laminar, transitional, and turbulent pipe flows. Documentation reviewed and found complete. Achieved level equals required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions must confirm design order for momentum and scalar transport equations.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes and power-law hemolysis scalar equations. Observed order of accuracy: 1.97 (momentum), 1.94 (hemolysis scalar) versus design order of 2.0. Passes acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 2% on hemolysis index QoI across all five operating points using at least three systematically refined meshes.",
      "rationale": "Three-mesh Richardson extrapolation performed. GCI on NIH was below 2% at four of five operating points (range 0.8%–1.7%). At the highest speed-low flow condition, GCI reached 3.1%, exceeding the 2% threshold. The team judged the exceedance marginal and retained the assessment; however, the achieved level of 3 falls one gradation below the required level of 4 for MRL 5. This gap is acknowledged but the overall decision was not revised."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be fully documented with traceability to calibrated instrumentation; fluid temperature, hematocrit, and flow rate must be controlled within ±2% of nominal.",
      "rationale": "All three validation datasets provided complete test condition logs with NIST-traceable calibration records. Hematocrit controlled to ±1.5%, flow rate to ±1.1%, temperature to ±0.3°C. Test condition documentation meets Gradation 4 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (E_rel, MAPE) must be computed with uncertainty bounds; metric thresholds defined a priori.",
      "rationale": "A priori acceptance thresholds defined as MAPE ≤ 20% on NIH. Achieved MAPE of 18.4% across the primary validation dataset. Uncertainty-expanded comparison using experimental measurement uncertainty (±8%) and model prediction interval (±12%) confirms overlap at all operating points except the outlier attributed to donor variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the COU decision QoI (absolute NIH); surrogate QoIs require demonstrated correlation with NIH.",
      "rationale": "The primary validation QoI is NIH, which directly maps to the COU decision variable. Velocity field comparisons serve as secondary QoIs with established mechanistic linkage to hemolysis through shear-stress exposure. One gradation gap remains because validation was not performed at the exact geometric configuration of the commercial VAD impeller; a surrogate FDA benchmark pump was used. The team assessed this as a minor limitation bounded by geometric sensitivity analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full COU operating envelope; extrapolation beyond validated range must be quantified.",
      "rationale": "Validation data cover four of five COU operating points directly; the fifth (highest speed) is within 8% of the highest validated speed. Extrapolation uncertainty at the fifth point was quantified via surrogate model and found to add ±6% to prediction uncertainty. One gradation gap is acknowledged; the team concluded the gap is bounded by the Monte Carlo UQ envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must reach residuals below 1e-6 for all equations; mass imbalance below 0.01%.",
      "rationale": "All simulations converged to residuals of 1e-7 or below for continuity, momentum, and hemolysis scalar equations. Mass imbalance across all cases was below 0.005%. Solver error contribution to NIH uncertainty is negligible relative to model-form uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition application documented and verified against experimental setup.",
      "rationale": "Independent analyst review completed by a second credentialed CFD engineer not involved in the original setup. Boundary conditions verified against experimental flow loop schematics. No use errors identified. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis constitutive model must be validated against mechanistic red blood cell damage data; model-form uncertainty must be quantified and shown to be the dominant uncertainty contributor.",
      "rationale": "The power-law hemolysis model (Giersiepen et al.) is acknowledged to be a phenomenological approximation with known deficiencies at low-shear and pulsatile conditions. Model-form uncertainty was quantified by comparing three hemolysis model variants (power-law, strain-based, energy dissipation) against the multi-site dataset; spread across model variants was ±31% on NIH, substantially exceeding parametric uncertainty (±12%). The required level of 5 demands mechanistic validation at the sub-cellular level, which has not been performed. The achieved level of 2 reflects that model-form uncertainty is quantified but not reduced. This constitutes a critical gap at MRL 5; however, the assessment team characterised the gap as 'bounded by conservative UQ margins' and did not revise the overall assurance classification downward."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty characterisation; sensitivity analysis must identify influential inputs.",
      "rationale": "Twenty-three model input parameters catalogued with literature-sourced uncertainty distributions. Sobol sensitivity analysis identified fluid viscosity, power-law exponent, and inlet velocity profile as top-three influential inputs, together accounting for 78% of output variance. All distributions reviewed by subject-matter expert. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test samples must be from multiple donors with documented hematological characterisation; minimum n=6 per operating point.",
      "rationale": "Multi-site dataset used pooled blood from four donors per operating point (n=4), below the required minimum of six. Hematological characterisation (hematocrit, MCV, MCHC) documented for all samples. The sample size gap introduces additional aleatory uncertainty not fully captured in the UQ envelope. Achieved level of 3 falls one gradation below required level of 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions must be demonstrably equivalent to experimental conditions within stated uncertainty bounds.",
      "rationale": "Inlet velocity profiles extracted from PIV measurements and applied directly as CFD boundary conditions. Outlet pressure boundary conditions matched to experimental back-pressure transducer readings. Equivalency confirmed via systematic comparison table; all parameters within ±3% of experimental nominal values."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The integrated credibility evidence — spanning three independent validation datasets, Monte Carlo uncertainty quantification, inter-laboratory hemolysis comparisons, and systematic mesh refinement — supports acceptance of the CFD model for predicting absolute hemolysis levels under VAD operating conditions. The majority of credibility factors achieved levels meeting or approaching requirements. Residual gaps in model-form fidelity (factor achieved level 2 versus required 5) and discretization error at the highest speed condition are acknowledged; however, the assessment team determined that the Monte Carlo UQ envelope conservatively bounds these gaps and that the overall evidence base is sufficient to support a Medium assurance classification. The decision is Accepted with the recommendation that future assessments pursue mechanistic hemolysis model validation to close the model-form gap.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
