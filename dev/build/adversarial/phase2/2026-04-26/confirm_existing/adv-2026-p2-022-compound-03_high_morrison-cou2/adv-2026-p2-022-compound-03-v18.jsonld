  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-03 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification was performed across all five operating points; mesh convergence was demonstrated on three representative conditions; and independent code verification against the FDA benchmark dataset yielded mean error below 8%. The credibility team judged the collective body of evidence sufficient to declare Medium assurance and accept the model for its intended use, noting that uncertainty bounds remain within the clinically acceptable hemolysis margin. Full 13-factor assessment is reported below.",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-hemolysis-prediction",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-benchmark-piv-dataset",
    "https://uofa.net/synth/data/morrison-vad-monte-carlo-outputs",
    "https://uofa.net/synth/data/morrison-mesh-convergence-study"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-fda-benchmark-comparison",
      "type": "ValidationResult",
      "name": "FDA benchmark PIV velocity comparison — centrifugal pump at 3500 RPM",
      "description": "Simulation velocity fields compared against FDA benchmark PIV measurements at 3500 RPM, 6 L/min. Mean absolute error 7.6% across measurement planes. Turbulence model: SST k-omega. Validation performed on a geometry that approximates but does not replicate the clinical VAD impeller geometry."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against in-vitro loop experiments",
      "description": "Predicted normalized index of hemolysis (NIH) values compared against in-vitro loop measurements for three of five target operating points. Predicted NIH within 22% of measured values at matched conditions. Two operating points at extreme low-flow regimes were not covered by available experimental data and were extrapolated from the validated range."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-mesh-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence index study — three operating conditions",
      "description": "GCI study performed on three mesh refinement levels (4.2M, 11.7M, 28.4M cells) at nominal operating conditions. GCI for velocity magnitude below 3.1%; GCI for wall shear stress below 9.4%. Mesh convergence not demonstrated at off-nominal low-flow conditions where hemolysis risk is highest."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035655",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-simulation-group",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1b849d056f3a1cc72e5b0d934f761a2c3e8490bdf15c7a6e2d0b83f91",
  "signature": "ed25519:b2d4e8f1a7c3950d62b0e4f8a1c5d9e3f7b2a6c0d4e8f2b6a0c4d8e2f6a0b4c8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be validated under a documented QA plan with traceability to ASME V&V 10 requirements; version control, regression testing, and formal release notes required at MRL 5.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is commercially licensed and includes internal regression test suites. However, the project-specific QA plan does not include formal traceability matrices linking solver version to validation cases, and no independent audit of the QA artifacts was performed. Achieved level 3 reflects partial QA documentation without third-party verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems with documented convergence rates; must cover all active physics modules used in the hemolysis simulation.",
      "rationale": "Order-of-accuracy tests were performed for the incompressible Navier-Stokes solver and confirmed second-order spatial convergence. The hemolysis transport scalar equation was not independently verified via manufactured solution; convergence behavior for the power-law damage accumulation model was inferred from vendor documentation only. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI or equivalent Richardson extrapolation must be reported for all quantities of interest including hemolysis index, wall shear stress, and pressure head, across all five operating conditions.",
      "rationale": "GCI was computed for velocity and wall shear stress at three of five operating conditions. Hemolysis index GCI was not directly computed; instead, sensitivity was inferred from velocity GCI assuming linear propagation through the damage model. This indirect approach underestimates discretization uncertainty in the nonlinear hemolysis accumulation regime. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate clinical operating conditions including fluid properties (hematocrit, viscosity), rotational speed range, and inlet flow waveform. All five COU operating points must be covered.",
      "rationale": "In-vitro validation experiments used bovine blood at 35% hematocrit; clinical use involves human blood at variable hematocrit (30–45%). Fluid viscosity and red blood cell mechanical properties differ systematically. Only three of five target operating points were experimentally covered; the two low-flow extremes were not tested. Inlet boundary conditions in experiments used steady flow whereas pulsatile conditions apply in VAD use. Achieved level 2 reflects significant mismatch in test conditions relative to COU requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E_rel, RMSE) must be reported with uncertainty bounds for all primary quantities of interest; statistical significance of agreement must be assessed.",
      "rationale": "Mean absolute percentage error reported for velocity (7.6%) and NIH (22%) at covered operating points. Uncertainty bounds on experimental measurements were propagated into comparison metrics. No formal hypothesis test of agreement was performed; the 22% NIH error was judged acceptable by the team based on engineering judgment rather than a pre-specified acceptance threshold. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities used in validation (velocity, NIH, pressure head) must be directly relevant to the clinical decision quantity (absolute hemolysis below clinical threshold).",
      "rationale": "NIH is the direct regulatory quantity of interest; velocity and wall shear stress are mechanistically linked to hemolysis through the power-law damage model. The mapping from validation QoIs to decision QoI is well-established in the hemolysis modeling literature. Achieved level 4 — full relevance demonstrated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry must match or bound the clinical device geometry; operating conditions must span the full COU envelope; blood analog properties must be physiologically representative.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry, which is a research surrogate not identical to the clinical VAD impeller. Geometric similarity is partial (same pump class, different blade count and volute design). Operating conditions covered 60% of the COU envelope. Blood analog (bovine blood, steady flow) deviates from clinical conditions as noted under Test Conditions. The combination of geometric and operating-condition gaps reduces relevance to achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all equations; mass conservation error must be below 0.1%.",
      "rationale": "Residuals converged to below 1e-6 for continuity and momentum; scalar transport residuals reached 1e-5. Mass imbalance across all interfaces below 0.05%. Achieved level 3 — requirement met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be independently reviewed by a qualified engineer not involved in model development; boundary condition selection must be documented and justified against COU specifications.",
      "rationale": "Boundary conditions were documented in the simulation report and reviewed internally by a senior engineer on the same project team. No independent external review was conducted. Turbulence model selection (SST k-omega) was justified by reference to prior literature but not by a sensitivity study for this specific geometry. Achieved level 2 — internal review without independence does not satisfy MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis damage model form must be justified by mechanistic evidence; model form uncertainty must be quantified by comparison of at least two candidate models; turbulence closure must be validated for rotating machinery with blood-analog fluids.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on historical precedent. A competing model (Arora mechanistic model) was considered but not implemented due to computational cost. Turbulence model sensitivity was not assessed; SST k-omega was applied without comparison to LES or RSM. Model form uncertainty is a dominant contributor to total prediction uncertainty at low-flow conditions but was not formally quantified. Achieved level 2 represents a critical gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (fluid properties, damage model coefficients, geometry tolerances) must be characterized with probability distributions; Monte Carlo propagation must cover all five operating conditions.",
      "rationale": "Monte Carlo UQ was performed on fluid viscosity, density, and damage model exponent and coefficient (C, alpha, beta). Geometry manufacturing tolerances were not included in the UQ due to unavailability of tolerance specifications for the clinical device. UQ covered all five operating conditions for the input parameters that were characterized. Achieved level 3 — incomplete input characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples must be sufficient in number to support statistical characterization of measurement variability; minimum n=5 replicates per operating condition.",
      "rationale": "In-vitro hemolysis measurements were performed with n=3 replicates per condition at the three covered operating points. This is below the minimum n=5 required at MRL 5 for statistical characterization. Measurement variability (CV 12–18%) could not be reliably estimated from three replicates. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrably equivalent to those used in COU predictions; any differences must be bounded and their effect on QoI quantified.",
      "rationale": "Validation simulations used steady rotational speed and steady inlet flow; COU predictions incorporate pulsatile inlet waveforms representative of VAD operating conditions. The effect of pulsatility on time-averaged hemolysis index was not quantified. Fluid property differences (bovine vs. human blood) were acknowledged but their effect on damage accumulation was not bounded analytically or experimentally. Achieved level 2 — substantial unquantified input equivalency gaps."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the full 13-factor assessment and determined that the collective evidence supports Medium assurance for the hemolysis prediction model. Monte Carlo UQ demonstrated that 95th-percentile predicted NIH values remain below the clinical acceptance threshold across all five operating conditions, providing a quantitative safety margin. While several credibility factors achieved levels below their required levels, the team judged that the shortfalls are compensated by the conservative uncertainty bounds established through Monte Carlo propagation and by the favorable comparison against FDA benchmark data. The model is accepted for use in the regulatory submission supporting the VAD premarket approval application.",
    "decidedAt": "2026-04-19T00:00:00Z"
