  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Six factors fully met their required levels; seven exhibited shortfalls of one gradation or less, with the exception of Discretization error (achieved 2, required 4). The team determined that the conservative uncertainty bounds applied in the Monte Carlo UQ step partially compensate for the discretization gap, and that the totality of evidence across validation datasets, solver verification, and sensitivity analyses supports a Medium assurance level. The decision is Accepted with the recommendation that a three-mesh Richardson extrapolation study be completed prior to regulatory submission.",
