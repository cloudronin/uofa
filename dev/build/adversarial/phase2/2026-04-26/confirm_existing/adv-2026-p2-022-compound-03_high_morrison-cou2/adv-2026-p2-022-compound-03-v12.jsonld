  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan must demonstrate version-controlled solver with regression test suite covering hemolysis-relevant flow regimes; independent code review required at MRL 5.",
      "rationale": "The CFD solver is under version control and a regression test suite exists for canonical benchmark cases. However, independent third-party code review has not been completed, and hemolysis-specific regression tests are absent. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions (MMS) verification must be demonstrated for turbulence and hemolysis transport equations at MRL 5.",
      "rationale": "Order-of-accuracy tests were performed for the Navier-Stokes solver on canonical geometries. MMS verification for the hemolysis power-law transport equation has not been conducted. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be reported for hemolysis index QoI on at least three systematically refined meshes; GCI must be below 5% for MRL 5 acceptance.",
      "rationale": "Grid sensitivity was assessed on two mesh refinement levels only; Richardson extrapolation was not performed. Reported GCI values exceed 12% on the hemolysis index quantity of interest, indicating unresolved discretization error. Achieved level 2 against required level 5. This gap is the most significant structural deficiency in the assessment.",
      "note": "W-AR-02 trigger: achievedLevel (2) is materially below requiredLevel (5) yet the package carries an Accepted decision and Medium assurance level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match COU operating envelope within stated uncertainty bands; fluid temperature, hematocrit, and viscosity must be controlled and reported.",
      "rationale": "Experimental test conditions are well-documented for flow rate and rotational speed. Hematocrit variability across test runs was ±3%, slightly exceeding the ±2% tolerance specified for MRL 5. Temperature was controlled. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., validation metric V, NRMSE) must be reported with uncertainty bounds for hemolysis index at all five operating points.",
      "rationale": "NRMSE values were computed for all five operating points and range from 14% to 31%. Uncertainty bounds on experimental hemolysis measurements are reported but asymmetric. The comparison metric does not account for measurement correlation across operating points. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoIs must directly correspond to the clinical decision QoI (absolute hemolysis index); surrogate QoIs require documented traceability to the clinical threshold.",
      "rationale": "Normalized index of hemolysis (NIH) is the primary QoI and maps directly to the clinical threshold. Validation was also performed on velocity field QoIs as surrogates; traceability from velocity error to hemolysis prediction error is qualitative rather than quantitative. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry and operating conditions representative of the COU device; generic pump results must be supplemented by device-specific data at MRL 5.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump, which is geometrically distinct from the target VAD device. Device-specific validation data were not available. The generic pump provides useful baseline evidence but does not fully satisfy MRL 5 relevance requirements. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations; solver round-off and floating-point error must be characterized.",
      "rationale": "Residuals for momentum equations converge to 1e-4; hemolysis transport equation residuals plateau at 5e-4 due to source-term stiffness. Floating-point characterization was not performed. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution protocol with independent peer review of boundary condition setup, turbulence model selection, and hemolysis model parameter inputs.",
      "rationale": "A simulation protocol document exists but was not independently reviewed. Turbulence model selection rationale (SST k-omega) is provided but sensitivity to model choice was not assessed. Hemolysis model constants were taken from literature without uncertainty characterization. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis power-law constitutive model must be quantified; alternative hemolysis models must be evaluated and model-form error bounded.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was employed without comparison to alternative formulations (e.g., Arora, Bludszuweit). Model-form uncertainty was acknowledged in the report but not quantified. At MRL 5, bounding of model-form error is mandatory. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented uncertainty distributions; Monte Carlo propagation must demonstrate sensitivity ranking and contribution to hemolysis index uncertainty.",
      "rationale": "Monte Carlo uncertainty quantification was performed with 1000 samples propagating uncertainty in viscosity, inlet velocity profile, and hemolysis model exponents. Rotational speed uncertainty and geometric tolerance uncertainty were not included in the propagation. Sensitivity ranking is reported. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental dataset must include sufficient replicate measurements to characterize biological and measurement variability; minimum n=5 replicates per operating point at MRL 5.",
      "rationale": "Experimental hemolysis measurements were available for 3 replicates per operating point, below the minimum of 5 required at MRL 5. Statistical power for detecting 10% hemolysis differences is insufficient. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated equivalent to those used in the COU predictions; any differences must be justified and their impact bounded.",
      "rationale": "The validation simulations used bovine blood rheology parameters, while the COU predictions employ human blood parameters. A scaling argument is provided but the impact on hemolysis index predictions has not been quantitatively bounded. Achieved level 2 against required level 3."
    }
