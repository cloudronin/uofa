  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-medium",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all thirteen credibility factors and concluded that the overall evidence base supports a Medium assurance level for the COU2 hemolysis prediction. While individual factor gaps exist — most notably in discretization error characterization and model-form uncertainty — the panel determined that the Monte Carlo uncertainty quantification, the breadth of the validation dataset, and the conservative safety margins applied to the hemolysis threshold collectively provide sufficient confidence for regulatory submission. The panel noted that the FDA generic pump validation data, though not device-specific, is the best publicly available dataset for this class of device and has been accepted in prior submissions. The decision to accept at Medium assurance reflects the panel's integrated expert judgment that residual uncertainties are bounded within the device's intended operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
