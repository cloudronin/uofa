  "assuranceLevel": "Medium",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (adversarial: COMPOUND-03)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification is performed across five flow-speed operating points. Thirteen credibility factors are assessed; the majority achieve their required levels, and the overall evidence base is judged sufficient to support a Medium assurance level with an Accepted decision. Narrative summaries for each factor reflect a thorough and well-documented V&V campaign, including mesh-convergence studies, solver verification benchmarks, and prospective validation against FDA flow-loop hemolysis data. The assurance-level declaration of Medium is presented as consistent with the weight of evidence; however, the Discretization error factor carries an achievedLevel that falls below its requiredLevel, a structural gap that — under ASME V&V 40 rules — constitutes a Critical weakener (W-AR-02) and renders the Medium assurance declaration unsupportable.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-r001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-absolute-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-flowloop-hemolysis-2021",
    "https://uofa.net/synth/data/monte-carlo-uq-ensemble-5op-points",
    "https://uofa.net/synth/data/mesh-convergence-study-r3"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
