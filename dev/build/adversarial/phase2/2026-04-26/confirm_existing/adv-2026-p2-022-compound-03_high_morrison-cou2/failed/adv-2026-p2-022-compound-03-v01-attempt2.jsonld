  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/cdrh-vv-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The review panel determined that the totality of V&V evidence supports a Medium assurance level for the VAD hemolysis prediction use case. Seven of thirteen credibility factors were formally assessed; the six not-assessed factors represent acknowledged epistemic gaps that are partially mitigated by the conservative hemolysis threshold applied in the regulatory decision. The dominant uncertainty source — model form — was characterised via two-model sensitivity analysis, and the 31% inter-model spread was judged bounded by the 40% safety margin built into the clinical threshold. Monte Carlo uncertainty propagation on inlet boundary conditions confirmed that the 95th-percentile NIH prediction remains below the clinical threshold at all five operating points. The panel accepted the submission with the recommendation that model-form uncertainty and inter-specimen variability be addressed in the next design iteration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
