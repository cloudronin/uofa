    "https://uofa.net/synth/data/monte-carlo-uq-ensemble"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 2500 RPM and 5 L/min",
      "description": "Particle image velocimetry data from the FDA benchmark study compared against CFD velocity predictions. Mean absolute error across measurement planes was 4.2% of bulk velocity. Agreement deemed satisfactory for flow topology but not sufficient to validate hemolysis scalar transport at MRL 5."
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-invitro-comparison",
      "type": "ValidationResult",
      "name": "In-vitro hemolysis index validation across 5 operating points",
      "description": "Normalized index of hemolysis (NIH) predicted by the power-law hemolysis model compared to in-vitro measurements using bovine blood. Predictions fell within a factor of 2.1 of measured values at 4 of 5 operating points; one outlier at peak shear condition showed 3.8x overprediction. Validation uncertainty bounds were not formally propagated."
    },
    {
      "id": "https://uofa.net/synth/validation/uq-monte-carlo-summary",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — 500-sample ensemble",
      "description": "Monte Carlo propagation of inlet boundary condition uncertainty and hemolysis model coefficient uncertainty through the CFD solver. 95th-percentile prediction interval for NIH spans 0.8–3.4x nominal prediction, reflecting substantial model-form sensitivity. Ensemble was generated on coarse mesh due to computational cost constraints."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035918",
