  "signature": "ed25519:b1e2d3c4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be under formal configuration management with documented unit and integration tests covering hemolysis transport solver routines at MRL 5.",
      "rationale": "The CFD solver is under version control and a test suite exists for core fluid routines; however, the hemolysis scalar transport module lacks dedicated unit tests and no formal software validation plan was executed. Configuration management procedures are partially documented. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) for all governing equations including hemolysis transport at MRL 5.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver and confirmed second-order spatial accuracy. The hemolysis power-law transport equation was not subjected to MMS verification; only qualitative convergence checks were performed. This gap reduces achieved level to 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal Richardson extrapolation or equivalent grid convergence index (GCI) analysis on hemolysis QoI using at least three systematically refined meshes at MRL 5, with GCI below 5% on primary QoI.",
      "rationale": "A three-level mesh refinement study was initiated but only two mesh levels were completed due to computational resource constraints on the fine mesh (estimated 48M cells). Richardson extrapolation could not be performed. The coarse-mesh GCI for the hemolysis index QoI was estimated at 31%, far exceeding the 5% threshold. The Monte Carlo UQ ensemble was also run on the coarse mesh, compounding discretization uncertainty into the uncertainty quantification results. Despite this, the assessment team concluded that qualitative flow topology convergence was demonstrated and accepted the package. Achieved level 1 against required level 3 — a critical gap that is not reflected in the Medium assurance declaration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit, temperature, and rotor speed tolerances; deviations must be quantified and propagated.",
      "rationale": "In-vitro tests used bovine blood at physiological hematocrit (40%) and temperature (37°C) with rotor speed controlled to ±10 RPM. However, VAD pulsatility effects from cardiac assist were not replicated in steady-state bench testing, representing a systematic deviation from COU conditions. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric U_val) computed with full uncertainty decomposition including experimental, numerical, and input uncertainties at MRL 5.",
      "rationale": "Quantitative comparison was performed using area validation metric; experimental uncertainty was characterized from repeat measurements. Numerical uncertainty from discretization was not formally propagated into the comparison metric because the grid convergence study was incomplete. The comparison metric therefore underestimates total validation uncertainty. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must be the same scalar hemolysis index used in the regulatory submission, measured under conditions representative of the COU operating envelope.",
      "rationale": "Validation activities measured NIH directly, which is the regulatory QoI. Operating points covered 4 of 5 COU flow-speed combinations; the fifth (peak shear, minimum flow) was not included in the validation dataset due to experimental difficulty. Relevance is high but incomplete coverage reduces achieved level to 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on the same pump geometry and blood analogue under conditions spanning the full COU operating envelope, including pulsatile flow representative of VAD assist mode.",
      "rationale": "Validation used the FDA generic pump geometry and bovine blood under steady-flow conditions. The target COU involves a specific commercial VAD geometry under pulsatile assist conditions. Geometric and flow-regime differences reduce relevance; a similarity argument was made but not quantitatively supported. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to solver tolerance below 1e-6 for all equations including scalar transport; residual history must be archived.",
      "rationale": "Momentum and continuity residuals converged to 1e-5. The hemolysis scalar transport equation was run with a relaxed tolerance of 1e-3 due to stiffness near the impeller blade tips. Residual histories were archived for fluid equations but not for the scalar transport equation. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation plan with independent review of boundary condition setup, material property assignment, and post-processing scripts prior to results extraction.",
      "rationale": "A simulation plan was documented and internally reviewed. Independent review by a party outside the simulation team was not performed. Boundary condition setup was verified by the lead analyst only. Post-processing scripts were not version-controlled. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model-form uncertainty quantification comparing at least two turbulence closure models and two hemolysis constitutive models, with sensitivity indices reported.",
      "rationale": "Model-form uncertainty was acknowledged as an epistemic gap at MRL 5. Only a single turbulence model (SST k-omega) and single hemolysis power-law model were used. No alternative model-form comparison was performed. This factor is flagged as not-assessed; the gap was noted in the assessment report but did not prevent the Accepted decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty bounds; sensitivity analysis must identify top-three influential parameters and propagate their uncertainty to QoI.",
      "rationale": "Monte Carlo UQ was performed propagating inlet velocity and hemolysis coefficient uncertainty. Blood viscosity temperature dependence and rotor tip clearance geometry uncertainty were not included in the UQ ensemble. Sensitivity analysis identified hemolysis model exponent as dominant but did not cover geometric inputs. Partially assessed; flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of blood sample variability across donors, storage conditions, and hematocrit ranges; minimum n=10 independent samples required at MRL 5.",
      "rationale": "In-vitro experiments used a single bovine blood batch per operating point. Inter-batch and inter-species variability were not characterized. No statistical sample-size justification was provided. This factor is not-assessed and represents a significant epistemic gap at MRL 5 for a Class III device submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that CFD boundary conditions match in-vitro test conditions within quantified tolerances for all primary inputs at MRL 5.",
      "rationale": "Equivalency between CFD boundary conditions and experimental test conditions was assumed based on nominal setpoints. No formal equivalency analysis quantifying the match between CFD inlet profiles and measured experimental inlet profiles was performed. This factor is not-assessed and constitutes an epistemic gap flagged in the assessment report."
    }
  ],
