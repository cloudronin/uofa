  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen credibility factors and acknowledged that seven were formally assessed and six remain as epistemic gaps consistent with MRL 5 resource constraints. The team concluded that the Monte Carlo UQ ensemble, PIV velocity validation, and in-vitro hemolysis comparison collectively provide Medium assurance that the CFD model is fit for the intended regulatory use. Discretization error was noted as a concern but the team judged that qualitative mesh convergence of flow topology, combined with conservative UQ bounds, was sufficient to support acceptance. The package was accepted for regulatory submission with the recommendation that a full three-level GCI study be completed prior to final PMA filing.",
