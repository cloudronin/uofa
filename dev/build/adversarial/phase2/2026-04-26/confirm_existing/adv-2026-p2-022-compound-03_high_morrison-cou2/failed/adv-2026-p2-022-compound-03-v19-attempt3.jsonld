  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b7d09e6f1a2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4",
  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-piv-comparison-001",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic pump at 3500 RPM",
      "description": "Particle image velocimetry data from the FDA benchmark study compared against CFD-predicted velocity fields at the impeller outlet plane. Agreement within 12% RMS across measured planes; systematic over-prediction of shear stress peaks in blade passage region noted but attributed to turbulence model limitations."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-invitro-002",
      "type": "ValidationResult",
      "name": "In-vitro hemolysis index validation — five operating points",
      "description": "Modified index of hemolysis (MIH) measured in vitro across five flow-speed combinations. CFD predictions within 18% of measured MIH at four of five points; the highest-shear operating condition (6 L/min, 4500 RPM) showed 31% under-prediction. Monte Carlo UQ bounds encompass measured values at all points when 95th-percentile intervals are used, providing statistical coverage despite point-estimate bias."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-mesh-convergence-003",
      "type": "ValidationResult",
      "name": "Mesh convergence study — Richardson extrapolation on hemolysis scalar",
      "description": "Three-level mesh refinement study (4.2M, 11.7M, 28.4M cells) using Richardson extrapolation. Grid convergence index (GCI) for hemolysis index: 8.3% on coarse-to-medium transition, 3.1% on medium-to-fine. Fine mesh adopted as production mesh; residual discretization uncertainty propagated into Monte Carlo ensemble."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression test suite covering hemolysis scalar transport, and documented release qualification required at MRL 5.",
      "rationale": "The commercial CFD solver (ANSYS Fluent 2022R2) carries vendor SQA documentation and a regression suite. However, the user-defined function implementing the hemolysis power-law model was not subjected to independent unit testing or formal code review. Version control for the UDF was maintained in a shared network folder without a tagged release; this falls one gradation short of MRL 5 requirements. Partial credit awarded for vendor SQA coverage of the base solver."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent order-of-accuracy verification for all governing equations including hemolysis transport at MRL 5.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes equations using the FDA pipe-flow benchmark, confirming second-order spatial accuracy. MMS verification was not extended to the hemolysis scalar transport equation or the power-law source term. This gap is documented as a known limitation of the commercial solver's UDF interface, which does not readily admit manufactured-solution forcing. Achieved level capped at 2 accordingly."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% on primary QoI (hemolysis index) with fine-mesh production run and Richardson extrapolation reported at MRL 5.",
      "rationale": "Three-level mesh refinement with Richardson extrapolation performed; GCI on fine-to-medium transition is 3.1%, meeting the threshold. However, the coarse-to-medium GCI of 8.3% indicates non-monotonic convergence behavior at lower refinement levels, and the extrapolated value deviates 4.7% from the fine-mesh result. Full Gradation 4 requires demonstrated asymptotic convergence across all refinement levels; partial achievement at Gradation 3 is warranted given the non-monotonic intermediate behavior."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate COU operating conditions including blood analog rheology, pump geometry tolerances, and inlet flow waveform at MRL 5.",
      "rationale": "In-vitro experiments used a glycerin-water blood analog (matching viscosity at 37°C) with the FDA generic pump geometry. Operating conditions spanned the full COU flow-speed envelope. Inlet boundary conditions were steady-state; the pulsatile VAD operating waveform was not reproduced in the validation experiment due to test-rig limitations. This steady-state approximation is conservative for mean hemolysis but does not capture cycle-averaged shear history effects. Gradation 3 reflects the strong geometric and rheological fidelity offset by the waveform simplification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or validation uncertainty U_val) reported for primary QoI with uncertainty decomposition at MRL 5.",
      "rationale": "Validation metric E% computed for hemolysis index at all five operating points; experimental uncertainty propagated from measurement repeatability (n=5 replicates per point) and blood analog batch variability. Validation uncertainty U_val reported as 95% confidence interval. The 31% under-prediction at the highest-shear point is within the expanded U_val interval, supporting a Gradation 4 outcome for this factor. Full uncertainty decomposition table provided in the V&V report appendix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI must be the same scalar (hemolysis index) used for the regulatory decision, with identical post-processing pathway at MRL 5.",
      "rationale": "The primary validation QoI (modified index of hemolysis, MIH) is directly used in the regulatory submission. Post-processing uses the same power-law integration pathway in both validation and COU predictions. However, the clinical threshold is expressed as normalized index of hemolysis (NIH) rather than MIH; a conversion factor derived from a single literature source is applied. Uncertainty in this conversion is not propagated into the UQ ensemble, introducing a minor but unquantified relevance gap. Gradation 3 assigned."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full COU parameter space including device-specific geometry and patient population operating envelope at MRL 5.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump, which shares impeller topology with the subject VAD but differs in volute geometry and outlet port orientation. The five validation operating points bracket the COU envelope but do not include the minimum-flow, maximum-speed corner condition identified as highest hemolysis risk. Extrapolation to this corner relies on the validated model without direct experimental support. Gradation 3 reflects strong but incomplete coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance < 1e-5 for all equations with demonstration that solution is independent of initial conditions at MRL 5.",
      "rationale": "Residual convergence to 1e-4 was achieved for continuity and momentum equations; the hemolysis scalar transport equation converged to 1e-3 due to stiffness of the power-law source term at high-shear regions. Sensitivity to initial conditions was not formally assessed; a single initialization from a coarser solution was used. These gaps place achieved level at Gradation 2 against the Gradation 3 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation plan, independent peer review of setup, and traceability from boundary conditions to source data required at MRL 5.",
      "rationale": "A simulation plan was documented prior to execution. Boundary conditions were traced to the device IFU and in-vitro test protocol. Independent peer review was conducted by a colleague within the same organization rather than an external reviewer; this internal review does not satisfy the independence criterion for Gradation 3 at MRL 5. An external technical review was planned but deferred pending regulatory feedback."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model must be justified against COU flow regime with sensitivity analysis across plausible model alternatives at MRL 5.",
      "rationale": "The SST k-omega turbulence model was selected based on prior FDA pump benchmark studies. The Giersiepen-Wurzinger power-law hemolysis model was adopted without sensitivity analysis against alternative formulations (e.g., Taskin or Arora models), which are known to produce hemolysis predictions differing by factors of 2-5 in high-shear regions. Model-form uncertainty was acknowledged in the UQ report narrative but was not quantified or included in the Monte Carlo ensemble. This represents a significant gap: the dominant source of prediction uncertainty is excluded from the reported UQ bounds. Achieved level is Gradation 2 against the Gradation 4 requirement.",
      "gap": "achievedLevel below requiredLevel by 2 gradations; model-form uncertainty not propagated"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters identified, characterized with probability distributions, and propagated through Monte Carlo UQ at MRL 5.",
      "rationale": "Monte Carlo UQ was performed with 500 Latin hypercube samples across eight uncertain input parameters (viscosity, density, inlet flow rate, rotational speed, power-law exponent, power-law coefficient, wall roughness, and inlet turbulence intensity). Parameter distributions were derived from literature and device specifications. The power-law constitutive coefficients were varied within manufacturer-reported ranges; however, inter-parameter correlations between the exponent and coefficient (known from regression of experimental data) were not modeled, potentially underestimating joint uncertainty. Gradation 3 awarded for comprehensive but partially uncorrelated UQ."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use sufficient replicates to characterize experimental variability; sample size justification required at MRL 5.",
      "rationale": "Five replicates were performed at each of the five operating points using a single pump unit. No between-unit variability was characterized; manufacturing tolerances in impeller geometry (known to affect hemolysis by up to 15% in published studies) were not sampled. A formal power analysis was not conducted to justify n=5 as sufficient to detect the expected effect size. The single-unit, single-batch design limits the generalizability of the experimental uncertainty estimate. Achieved level is Gradation 1 against the Gradation 3 requirement.",
      "gap": "achievedLevel below requiredLevel by 2 gradations; between-unit variability not characterized"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions must be demonstrably equivalent to experimental conditions with quantified mapping uncertainty at MRL 5.",
      "rationale": "Inlet velocity profiles for the CFD model were derived from PIV measurements at the pump inlet plane, providing high-fidelity boundary condition equivalency for the velocity field. Fluid temperature was controlled to ±0.5°C in the experiment and matched in the simulation via temperature-dependent viscosity. Outlet pressure boundary condition was set from transducer measurements with ±2% accuracy. The equivalency gap arises from unmeasured inlet turbulence intensity, which was estimated from empirical correlations rather than measured directly. This introduces a Gradation 3 equivalency level against the Gradation 4 requirement."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-mrl5-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team determined that the cumulative evidence — comprising three independent validation activities, a 500-sample Monte Carlo UQ campaign, three-level mesh convergence study, and systematic factor-by-factor credibility evaluation — supports a Medium assurance level for the hemolysis prediction. While individual factors show gaps relative to MRL 5 requirements, the conservative clinical margin (predictions remain 22% below the absolute hemolysis threshold at the 95th UQ percentile) and the breadth of the validation program are judged sufficient to accept the model for the stated COU. Conditions: (1) model-form sensitivity analysis to be completed prior to final regulatory submission; (2) additional pump units to be tested in a follow-on in-vitro study.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
