  "signature": "ed25519:9b2e4f1a7c3d0e6b8a5f2c9d1e4b7a0c3f6d2e8b1a5c9f4d7b0e3a6c2f8d1b4",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/fda-pump-bench-hemolysis",
      "type": "ValidationResult",
      "name": "FDA generic pump bench hemolysis validation — 5 operating points",
      "description": "CFD predictions of normalized index of hemolysis (NIH) compared against in-vitro measurements at 5 flow-speed combinations. Mean absolute error 18.4%; model systematically under-predicts at high shear conditions. Validation scope limited to a single pump geometry; no patient-specific anatomy included."
    },
    {
      "id": "https://uofa.net/synth/validation/montecarlo-uq-hemolysis",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ sweep — hemolysis index sensitivity",
      "description": "1 000-sample Monte Carlo propagation of inlet flow waveform and fluid viscosity uncertainty through the hemolysis model. 95th-percentile prediction interval spans ±32% of nominal NIH. Interval does not account for turbulence model form uncertainty, which is treated as an epistemic gap."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-independence-vad",
      "type": "ValidationResult",
      "name": "Mesh independence study — centrifugal pump impeller",
      "description": "Three mesh refinement levels (2.1 M, 6.4 M, 14.8 M cells). Richardson extrapolation yields GCI < 3.2% for velocity magnitude; NIH GCI 8.7% on finest mesh, exceeding the 5% target for MRL 5 but accepted by the team as within engineering tolerance given resource constraints."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full QA plan with version-controlled solver, regression test suite covering hemolysis sub-models, and documented release notes for each solver version used.",
      "rationale": "Version control and regression testing are in place for the core CFD solver. However, the hemolysis damage accumulation sub-model lacks a dedicated regression suite; one solver patch was applied mid-study without re-running the full test matrix. Achieved level 3 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent order-of-accuracy test for all governing equations including the hemolysis transport equation.",
      "rationale": "MMS verification completed for Navier-Stokes equations demonstrating second-order spatial convergence. The hemolysis scalar transport equation was verified only via comparison with an analytical 1-D solution; full MMS for the 3-D hemolysis equation was not performed. Gap acknowledged; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 2% for all quantities of interest including NIH at MRL 5.",
      "rationale": "Mesh refinement study shows GCI of 8.7% for NIH on the finest practical mesh (14.8 M cells). Computational cost precluded further refinement. The team accepted this gap as an acknowledged epistemic limitation, but the achieved level of 3 falls two gradations below the required level of 5. This gap is the single most significant structural deficiency in the assessment and constitutes a critical shortfall relative to MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicate physiological VAD operating range; temperature, hematocrit, and anticoagulation state documented and matched.",
      "rationale": "In-vitro experiments used bovine blood at 37 °C with hematocrit 33–35%, consistent with clinical range. Anticoagulation protocol documented. However, pulsatile inlet waveform was simplified to a steady mean flow for the validation experiments, introducing a mismatch with the pulsatile COU. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E_rel) with uncertainty bounds for NIH at all 5 operating points; systematic bias characterised.",
      "rationale": "Relative error computed at all 5 operating points; mean 18.4%, maximum 27.1% at highest shear condition. Systematic under-prediction at high shear is attributed to turbulence model limitations. Bias not corrected in predictions. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to the regulatory decision metric (absolute NIH threshold); traceability documented.",
      "rationale": "NIH is the primary regulatory QoI; the model outputs NIH directly, and the acceptance threshold is defined in absolute terms consistent with the COU. Full traceability from model output to regulatory criterion is documented. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry under physiologically representative pulsatile conditions spanning the full COU operating envelope.",
      "rationale": "Validation used the FDA generic pump geometry, which matches the COU device. Operating envelope coverage is partial: 5 of 9 intended operating points were tested experimentally due to rig limitations. Pulsatile conditions not replicated in validation (see Test Conditions). Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual < 1e-5 for all equations; mass balance error < 0.01%.",
      "rationale": "All simulations converged to residuals below 1e-5; global mass balance error < 0.005%. Solver error contribution is negligible relative to discretization and model form uncertainties. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation setup checklist with independent review of boundary condition assignments, material properties, and solver settings prior to each production run.",
      "rationale": "A simulation setup checklist exists and was applied. Independent review was performed for 3 of 5 operating points; the remaining 2 were self-reviewed by the analyst due to schedule constraints. One boundary condition error was identified and corrected during internal review; no post-hoc audit was performed to confirm no residual errors remain. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model form uncertainty quantified via multi-model ensemble; hemolysis constitutive law uncertainty bounded by sensitivity study across published power-law exponents.",
      "rationale": "A single turbulence model (SST k-omega) was used without ensemble comparison. Sensitivity of NIH to the hemolysis power-law exponent (C, alpha, beta) was explored via a 3-level factorial design, revealing a 40% variation in predicted NIH across published parameter sets. No formal model-form uncertainty bound was propagated into the final prediction interval. The gap between achieved level 2 and required level 5 represents a three-gradation shortfall and is an unresolved epistemic risk at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs characterised with probability distributions; distributions validated against patient population data; propagated via Monte Carlo.",
      "rationale": "Monte Carlo UQ performed for inlet flow waveform amplitude and fluid viscosity. Blood viscosity distribution derived from published donor population data. Inlet pressure waveform shape uncertainty not included; pump speed uncertainty treated as negligible without justification. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum 3 independent experimental replicates per operating point with inter-laboratory reproducibility demonstrated for at least one condition.",
      "rationale": "Two replicates were performed at each of 5 operating points using a single laboratory and single blood lot. No inter-laboratory comparison was conducted. Sample-to-sample variability was 12–19% CV for NIH, indicating substantial biological variability that is not fully characterised. Achieved level 2 against required level 4 is a significant gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, boundary conditions, fluid properties) demonstrated equivalent to experimental conditions via documented parameter mapping table with tolerances.",
      "rationale": "Parameter mapping table completed for geometry (CAD-to-mesh fidelity verified), flow rates (±2% of target), and fluid properties. Impeller surface roughness was not measured experimentally and was assumed smooth in the CFD model; roughness effects on hemolysis are unquantified. Achieved level 3."
    }
  ],
