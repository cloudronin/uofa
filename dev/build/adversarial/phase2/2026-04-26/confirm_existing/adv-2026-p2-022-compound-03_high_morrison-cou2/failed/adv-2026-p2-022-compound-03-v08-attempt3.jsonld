  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-03 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification was performed across five flow-speed operating points. Thirteen credibility factors were assessed; the review team concluded that the weight of evidence, taken holistically, supports a Medium assurance level given the breadth of validation activities, the rigour of the uncertainty quantification workflow, and the conservative clinical safety margins applied. The decision record reflects acceptance with medium confidence. NOTE (adversarial): the declared assurance level is inconsistent with at least one factor whose achievedLevel falls below requiredLevel while the decision outcome is Accepted — triggering COMPOUND-03.",
  "assuranceLevel": "Medium",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-absolute-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-absolute-cou2",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-blood-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-piv-dataset",
    "https://uofa.net/synth/data/hemolysis-in-vitro-mrl5-validation-set",
    "https://uofa.net/synth/data/monte-carlo-uq-samples-5op"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/piv-flow-field-comparison-cou2",
      "type": "ValidationResult",
      "name": "PIV flow-field comparison — FDA generic centrifugal pump (5 operating points)",
      "description": "Particle image velocimetry measurements at five flow-speed combinations compared against CFD velocity fields. Mean velocity magnitude agreement within 12% at design point; larger deviations observed near volute tongue at off-design conditions. Validation activity covers the primary flow regime but does not capture shear-layer transients implicated in hemolysis."
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-bench-comparison-cou2",
      "type": "ValidationResult",
      "name": "Hemolysis index bench test comparison — absolute NIH values",
      "description": "Normalised index of haemolysis (NIH) values from modified index of haemolysis (MIH) bench experiments compared to CFD-predicted power-law hemolysis accumulation. Model over-predicts NIH by 18–34% across the operating envelope. Conservative bias is acknowledged but not fully characterised; uncertainty intervals overlap clinical threshold at two operating points."
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-report-cou2",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis prediction spread",
      "description": "512-sample Monte Carlo propagation of inlet velocity, fluid viscosity, and power-law exponent uncertainties. 95th-percentile hemolysis index remains below the absolute clinical threshold at the design operating point. Two off-design points exhibit 95th-percentile values within 8% of threshold. UQ workflow is documented and repeatable; however, model-form uncertainty is not included in the propagation."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042689",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b7d09e5f2a1c3b8d6e0f4a7c2b5d9e1f3a6c0b4d8e2f5a9c3b7d1e4f",
  "signature": "ed25519:9b2e4f1a7c3d0e6b8f2a5c9d1e3f7b4a6c0d2e8f1b5a3c7d9e2f4b6a0c8d3e5f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering hemolysis-relevant flow regimes; documented change-control process; independent code review at MRL 5.",
      "rationale": "The CFD solver (OpenFOAM 9) is version-controlled and a regression suite of 47 canonical cases is maintained. Independent third-party code review was initiated but not completed at the time of submission; the review covers only the blood rheology sub-model. Change-control documentation exists for solver configuration but not for post-processing scripts used in hemolysis accumulation. Achieved level 3 falls one gradation below the MRL-5 requirement of level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent applied to all governing equations including the hemolysis transport scalar; observed order of accuracy documented.",
      "rationale": "MMS verification was applied to the Navier-Stokes solver and confirmed second-order spatial accuracy. The hemolysis power-law scalar transport equation was verified using a simplified 1-D manufactured solution only; full 3-D MMS for the scalar was not performed. Temporal discretisation verification was conducted for steady-state runs only. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for hemolysis QoI on at least three systematically refined meshes; GCI < 5% on fine mesh.",
      "rationale": "Three mesh levels (6.2 M, 14.1 M, 31.8 M cells) were used. GCI for velocity magnitude at the design point is 3.1% (fine mesh). GCI for the hemolysis index QoI is 9.4% on the fine mesh, exceeding the 5% acceptance threshold. The team notes that near-wall prism layer refinement was not systematically varied. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, haematocrit) documented with traceability to NIST-traceable calibration; uncertainty in test conditions quantified.",
      "rationale": "All five operating-point bench tests were conducted with NIST-traceable flow meters (±0.5%) and temperature control (±0.2 °C). Haematocrit was verified pre- and post-test; variation was less than 1.5%. Inlet velocity profiles were measured with LDV and imposed as boundary conditions in CFD. Test condition uncertainty is fully propagated into the Monte Carlo UQ. Achieved level 4 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric u_val) applied to hemolysis QoI; metric accounts for both experimental and numerical uncertainty.",
      "rationale": "A validation metric based on the ASME V&V 20 framework was computed. The metric accounts for experimental measurement uncertainty and numerical discretisation error (GCI-based). Model-form uncertainty is excluded from the metric denominator, which inflates the apparent agreement. At two off-design operating points the validation metric exceeds the acceptance threshold of 1.0, indicating the model is not validated at those conditions. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH) is identical to the QoI used in the regulatory decision; no surrogate or intermediate quantities are used as proxies.",
      "rationale": "The primary QoI is the normalised index of haemolysis (NIH) computed by the power-law model, which is the same metric used in the regulatory submission. However, the bench-test NIH is derived from plasma-free haemoglobin measurements using the modified index of haemolysis protocol, which introduces a conversion factor with documented variability of ±11%. This conversion uncertainty is not fully reflected in the UQ. Achieved level 4, one below requirement of 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the identical device geometry under COU operating conditions; fluid properties match clinical blood properties within documented tolerance.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry, which matches the COU device geometry. However, experiments used a blood analogue fluid (glycerol-water, 36% haematocrit equivalent) rather than porcine or human blood. The power-law hemolysis coefficients were calibrated on bovine blood; species-dependent coefficient uncertainty is not quantified. Operating conditions span the COU envelope but exclude the highest-speed point (3600 RPM) due to rig limitations. Achieved level 3, two below requirement of 5.",
      "note": "W-AR-02 trigger: achievedLevel (3) < requiredLevel (5) with Accepted decision outcome."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual levels below 1e-6 for all equations; solution monitors for hemolysis QoI show flat convergence over final 500 iterations.",
      "rationale": "Continuity and momentum residuals converge to 1e-5; the hemolysis scalar residual reaches 8e-5, above the 1e-6 criterion. QoI monitors show variation of ±2.1% over the final 500 iterations at the highest-speed operating point, indicating incomplete iterative convergence. The team applied a moving-average smoothing to the QoI monitor and declared convergence, but the underlying oscillation is not resolved. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation execution checklist completed and independently reviewed; boundary condition setup verified against test-condition records by a second analyst.",
      "rationale": "A 47-item simulation execution checklist was completed for each of the five operating points. An independent analyst verified boundary condition values against the test-condition records. No discrepancies were identified. Post-processing scripts are version-controlled and peer-reviewed. Achieved level 4 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty quantified for the hemolysis power-law constitutive model; sensitivity to power-law exponents demonstrated; alternative model forms evaluated.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is used without evaluation of alternative model forms (e.g., Arora, Taskin, or strain-based models). Sensitivity analysis on the power-law exponents (C, alpha, beta) was conducted via one-at-a-time perturbation only; interaction effects are not characterised. No Bayesian model-form uncertainty quantification was performed. The team acknowledges that model-form uncertainty is the dominant source of prediction uncertainty but does not include it in the UQ propagation. Achieved level 2, three below requirement of 5.",
      "note": "Additional W-AR-02 instance: achievedLevel (2) << requiredLevel (5) with Accepted decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters identified; uncertainty distributions assigned based on experimental data or literature; full set of inputs included in Monte Carlo propagation.",
      "rationale": "Fourteen model input parameters were identified. Uncertainty distributions were assigned to six parameters (inlet velocity components, viscosity, density, haematocrit) based on experimental measurements. Eight parameters (power-law exponents, turbulence model constants, wall roughness) were held fixed at nominal values and excluded from Monte Carlo propagation. The team justifies exclusion by citing literature consensus values, but no sensitivity screening (e.g., Morris method) was performed to verify that excluded parameters are non-influential. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient replicate experiments to characterise inter-sample variability; statistical power analysis documented; outlier treatment protocol applied.",
      "rationale": "Six replicate hemolysis experiments were conducted at each of the five operating points (30 total runs). Statistical power analysis confirmed that six replicates provide 80% power to detect a 15% difference in NIH at alpha=0.05. One outlier (NIH > 3 sigma from mean) was identified at operating point 3 and excluded per the pre-specified outlier protocol. Achieved level 4 meets requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Computational model boundary conditions demonstrated to be equivalent to experimental conditions within quantified tolerance; any differences documented and their impact on QoI assessed.",
      "rationale": "Inlet velocity profiles from LDV measurements were mapped directly onto the CFD inlet boundary. Pump rotational speed was matched to within 0.3 RPM. Fluid temperature equivalency was confirmed. However, the outlet boundary condition (constant pressure) differs from the experimental configuration (flexible tube with compliance), and the impact of this difference on hemolysis accumulation was not assessed via sensitivity analysis. Achieved level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen credibility factors and the supporting validation evidence. The team notes that while several factors achieved levels below MRL-5 requirements, the overall body of evidence — including three independent validation activities, a 512-sample Monte Carlo UQ, and conservative clinical safety margins — provides sufficient confidence to support regulatory submission. The declared assurance level of Medium reflects the team's holistic judgement that the model is fit for the intended use with acknowledged limitations. The Monte Carlo analysis demonstrates that the 95th-percentile hemolysis prediction remains below the absolute clinical threshold at the design operating point, and the conservative over-prediction bias at off-design points is considered a protective factor. The decision is Accepted with Medium assurance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
