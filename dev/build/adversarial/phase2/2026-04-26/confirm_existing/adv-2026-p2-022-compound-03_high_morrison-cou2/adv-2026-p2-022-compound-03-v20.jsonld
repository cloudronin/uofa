  "assuranceLevel": "Medium",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (adversarial: COMPOUND-03)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. This package evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. A comprehensive 13-factor assessment was conducted; Monte Carlo uncertainty quantification was performed across all five flow-speed operating points, and a structured validation campaign against in-vitro hemolysis measurements was completed. The assessment team concluded that the accumulated validation evidence, combined with the uncertainty quantification campaign and the conservative hemolysis threshold margin, collectively supports a Medium assurance level. The decision record reflects an Accepted outcome based on the totality of evidence. NOTE (adversarial): the Model Form factor carries achievedLevel 2 against requiredLevel 4, a gap that individually constitutes a Critical deficiency (W-AR-02) and renders the Medium assurance declaration unsupported — triggering COMPOUND-03.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-absolute-vad",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-invitro-hemolysis-dataset",
    "https://uofa.net/synth/data/monte-carlo-uq-results-vad",
    "https://uofa.net/synth/data/grid-convergence-study-pump"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/invitro-hemolysis-5op-points",
      "type": "ValidationResult",
      "name": "In-vitro hemolysis validation across 5 operating points — FDA generic centrifugal pump",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against in-vitro measurements at five flow-speed combinations (3–6 L/min, 2000–3500 RPM). Mean absolute error 18.3%; predictions systematically underestimate hemolysis at high shear operating points. Validation domain partially overlaps COU but does not cover the highest-stress VAD operating envelope."
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-hemolysis",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis index sensitivity",
      "description": "1 000-sample Monte Carlo propagation of inlet boundary condition and viscosity uncertainties through the CFD hemolysis model. 95th-percentile NIH prediction remains below clinical threshold with a margin of 12%. Sensitivity analysis identifies power-law hemolysis exponent as the dominant uncertainty contributor (Sobol index 0.61), highlighting model-form sensitivity that is not resolved by the UQ campaign alone."
    },
    {
      "id": "https://uofa.net/synth/validation/grid-convergence-mrl5",
      "type": "ValidationResult",
      "name": "Grid convergence index study — pump impeller and volute",
      "description": "Three-level Richardson extrapolation GCI study on impeller passage and volute meshes (6.2 M, 14.7 M, 31.4 M cells). GCI for wall shear stress QoI: 4.1% on fine mesh. GCI for NIH: 6.8%. Discretization error is quantified and within acceptable bounds for MRL 5 per the required level of 3; achieved level assessed at 3."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
