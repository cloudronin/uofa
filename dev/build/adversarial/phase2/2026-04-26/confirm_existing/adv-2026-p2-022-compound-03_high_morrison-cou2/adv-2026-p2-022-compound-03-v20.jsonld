  "hash": "sha256:a3f7c2e1b09d4f56e8a1c3d7b2f0e9a4c6d8b1f3e5a7c9d2b4f6e8a0c2d4f6e8",
  "signature": "ed25519:b1d3f5a7c9e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be validated under an ISO 9001-compliant QMS with version-controlled test suite covering hemolysis-relevant flow regimes; all critical code paths exercised.",
      "rationale": "The CFD solver operates under a documented QMS with version control and automated regression testing. However, the hemolysis sub-model power-law implementation lacks an independent unit test suite, and one regression test covering rotating-frame source terms was disabled in the current release branch. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations including rotating-frame momentum and scalar hemolysis transport; order-of-accuracy confirmed.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver in a stationary frame and confirmed second-order spatial accuracy. The rotating-frame body-force terms and the hemolysis scalar transport equation were not included in the MMS campaign. Code verification is therefore incomplete for the hemolysis QoI, yielding achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI study with three systematically refined meshes; GCI on primary hemolysis QoI below 10% on the fine mesh.",
      "rationale": "Three-level GCI study completed on impeller passage and volute. GCI for NIH on fine mesh (31.4 M cells) is 6.8%, within the 10% threshold. Achieved level equals required level 3. This factor does not contribute a gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions (fluid temperature, hematocrit, anticoagulant protocol, inlet waveform) must match COU operating envelope within specified tolerances; traceability documented.",
      "rationale": "In-vitro experiments used bovine blood at 37 °C and 35% hematocrit under steady-state flow. VAD clinical use involves pulsatile flow and patient hematocrit variability (30–45%). The steady-state experimental protocol does not fully represent pulsatile VAD operating conditions, reducing test-condition fidelity. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric or equivalent) applied to NIH predictions versus measurements; systematic and random errors separated; validation uncertainty reported.",
      "rationale": "Quantitative comparison was performed using a normalized error metric. Mean absolute error is 18.3% across five operating points, with systematic underestimation at high-shear conditions. Validation uncertainty was estimated but experimental uncertainty bands are wide due to batch-to-batch blood variability. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs (NIH, wall shear stress distributions) must directly map to the COU decision QoI (absolute hemolysis index for regulatory submission); no surrogate QoIs accepted at MRL 5.",
      "rationale": "NIH is the primary validation QoI and directly corresponds to the COU decision QoI. However, the validation campaign also relied on qualitative flow visualization for internal flow structure, which is a surrogate indicator. The primary NIH comparison is direct, but the supplemental reliance on surrogate QoIs for model confidence limits achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the geometry, operating range, and fluid properties representative of the VAD COU; extrapolation beyond validated envelope must be justified.",
      "rationale": "Validation was conducted on the FDA generic pump geometry, which is representative but not identical to the patient-specific VAD geometry in the COU. Operating range coverage is partial (steady-state only). The assessment team judged the validation activities substantially relevant but noted the geometry and pulsatility gap, yielding achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and parallel decomposition sensitivity must be quantified for the hemolysis scalar transport equation under rotating-frame conditions.",
      "rationale": "Iterative convergence monitoring was performed for velocity and pressure residuals only. The hemolysis scalar transport equation convergence was not independently monitored; no parallel decomposition sensitivity study was conducted. This factor was flagged as an epistemic gap at MRL 5. Not assessed; gap of 2 levels retained."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent peer review of boundary condition setup, solver settings, and post-processing scripts; traceability to COU requirements.",
      "rationale": "A simulation protocol document exists but was not subject to independent peer review. Post-processing scripts for NIH integration were not version-controlled at the time of submission. Use-error controls are partially implemented but fall short of MRL 5 requirements. Not assessed as a complete factor; achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified through comparison of multiple constitutive model candidates against experimental data; sensitivity of NIH prediction to model-form choice must be quantified and shown to be within acceptable bounds for MRL 5 regulatory use.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was adopted without systematic comparison against alternative model forms (e.g., Arora, Taskin, or mechanistic red-cell damage models). A single-model approach was used throughout the validation campaign. Model-form sensitivity was identified as the dominant uncertainty contributor in the Monte Carlo study (Sobol index 0.61) but was not addressed through model-form selection or bounding analysis. At MRL 5 with High decision consequence, this constitutes a critical gap: achievedLevel 2 against requiredLevel 4, a two-level shortfall that individually satisfies the W-AR-02 Critical weakener criterion. The prose narrative of the broader assessment package obscures this gap by emphasizing the successful Monte Carlo campaign and the NIH threshold margin."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters (viscosity, density, hemolysis exponents, inlet velocity profiles) must be characterized with uncertainty bounds traceable to patient-population data; epistemic and aleatory uncertainties separated.",
      "rationale": "Inlet boundary conditions were derived from a single literature source for steady-flow conditions. Patient-population variability in blood rheology and pump inlet profiles was not incorporated. Hemolysis power-law exponents (C, α, β) were taken from the original Giersiepen-Wurzinger fit without uncertainty bounds. This factor was flagged as a major epistemic gap. Not assessed; achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be characterized for hematocrit, blood age, and anticoagulant type; repeatability demonstrated across at least three independent runs per operating point.",
      "rationale": "In-vitro hemolysis data were collected from a single experimental campaign with two replicates per operating point. Blood sample characterization records are incomplete; hematocrit was reported as nominal (35%) without measured confirmation per sample. Insufficient replication and incomplete sample characterization preclude full assessment. Not assessed; achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters must be shown to be equivalent to experimental conditions through independent measurement or sensitivity analysis; any discrepancies must be bounded and their impact on NIH quantified.",
      "rationale": "Equivalency between simulation inputs and experimental conditions was assumed rather than verified. Inlet velocity profiles in simulation were taken from an idealized parabolic approximation; experimental inlet conditions were not measured. No sensitivity study was performed to bound the impact of input discrepancies on the NIH comparison. Not assessed; achieved level 2 against required level 4."
    }
  ],
