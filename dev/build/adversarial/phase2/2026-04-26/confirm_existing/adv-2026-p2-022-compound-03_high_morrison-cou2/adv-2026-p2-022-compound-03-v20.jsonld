  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team concluded that the totality of evidence supports acceptance. The Monte Carlo uncertainty quantification campaign demonstrated a 12% margin below the clinical hemolysis threshold at the 95th percentile. The GCI study confirmed discretization error is within acceptable bounds. The validation campaign against in-vitro data, while conducted under steady-state conditions, is judged sufficiently representative given the conservative threshold margin. Several credibility factors carry achieved levels below required levels, but the team considered the cumulative evidence — particularly the UQ margin and the breadth of the validation dataset — to collectively support a Medium assurance level and an Accepted decision. The model-form gap (achievedLevel 2, requiredLevel 4) was noted in the risk register but was assessed as mitigated by the conservative hemolysis threshold margin identified in the Monte Carlo campaign.",
