  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen credibility factors. Seven factors were formally assessed; nine reached or exceeded required levels. The discretization error factor achieved level 3 against a required level of 4, but the team considered the Monte Carlo UQ campaign sufficient to bound the residual grid uncertainty at the high-speed low-flow condition. Six factors were not-assessed due to epistemic gaps at MRL 5; these were documented in the risk register. On balance, the team concluded the evidence supported a Medium assurance level and an Accepted decision for regulatory submission, subject to post-market surveillance commitments.",
