  "assuranceLevel": "Medium",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-03 adversarial sample)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Monte Carlo uncertainty quantification was performed across all five flow-speed operating points, and the assessment team conducted an extensive 13-factor review spanning verification, validation, and uncertainty quantification activities. Six of the thirteen factors were assessed at or near their required credibility levels following targeted remediation activities completed in Q3 2025; the remaining seven were assessed with minor shortfalls judged by the team to be acceptable given the robustness of the uncertainty quantification framework. The assurance level is declared Medium based on the team's holistic judgment that the aggregated evidence, while not uniformly satisfying every individual required level, collectively provides sufficient confidence for the intended regulatory submission. Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-hemolysis-absolute-threshold",
  "bindsModel": "https://uofa.net/synth/model/fda-centrifugal-pump-cfd-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-experimental-2024",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-2024",
    "https://uofa.net/synth/data/morrison-monte-carlo-uq-runs-2025"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-piv-comparison-2024",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA centrifugal pump, 5 operating points",
      "description": "Particle image velocimetry data acquired at the FDA benchmark facility for all five flow-speed combinations. CFD velocity predictions compared against PIV measurements using GCI-corrected fine-grid solutions. Mean absolute error across operating points: 7.3%. Turbulence intensity predictions show systematic underprediction at impeller exit plane, attributed to RANS closure limitations under high-shear rotating conditions. Validation activities were conducted on a geometrically identical pump under matched Reynolds number conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-bench-2024",
      "type": "ValidationResult",
      "name": "Hemolysis index bench validation — lactate dehydrogenase assay",
      "description": "In-vitro hemolysis measurements using LDH assay protocol per ASTM F1841. CFD-predicted normalized index of hemolysis (NIH) compared to measured NIH at three of five operating points (two points excluded due to clotting artifacts in test loop). Predicted NIH falls within expanded uncertainty band (k=2) at two of three points; the third point exhibits a 23% overprediction of hemolysis, which the team attributed to secondary flow structures not captured by the Giersiepen power-law damage accumulation model. The team notes this overprediction is conservative with respect to patient safety."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-monte-carlo-uq-2025",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — 2500-sample hemolysis prediction ensemble",
      "description": "2500-sample Monte Carlo ensemble propagating uncertainty in inlet boundary conditions, blood viscosity (patient population variability), and hemolysis model coefficients. 95th-percentile predicted NIH remains below clinical threshold at four of five operating points. At the highest-speed operating point (6000 RPM, 3 L/min), the 95th-percentile NIH prediction marginally exceeds the threshold by 4.1%, which the team judged acceptable given conservative assumptions on model coefficient uncertainty distributions."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
