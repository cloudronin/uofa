  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software QA plan documented; version control, regression testing, and change-control procedures in place consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (OpenFOAM v9) is governed by a documented QA plan including version-controlled source, automated regression test suite (482 test cases), and formal change-control log. All three MRL-5 QA requirements are satisfied. achievedLevel equals requiredLevel; this factor does not contribute to a gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification using manufactured solutions or benchmark problems demonstrating expected spatial and temporal convergence rates.",
      "rationale": "Code verification was performed using the lid-driven cavity and backward-facing step benchmarks. Observed spatial convergence order was 1.7 (expected 2.0 for the second-order scheme), attributed to boundary-condition implementation near curved walls. Temporal convergence was not formally verified for the transient hemolysis transport equation. The achieved level of 2 falls below the required level of 3; a gap exists but the assessment team considered it partially mitigated by the mesh-refinement study results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or Richardson extrapolation applied to primary QoI on at least three systematically refined meshes; GCI < 5% on finest mesh for hemolysis index prediction.",
      "rationale": "A three-level mesh refinement study was performed (coarse: 2.1M cells, medium: 6.8M cells, fine: 18.4M cells). The observed convergence ratio was non-monotonic between coarse and medium meshes, violating the GCI applicability condition. Richardson extrapolation was applied only between medium and fine meshes, yielding an apparent GCI of 14.7% for the NIH prediction — substantially above the 5% acceptance threshold. The assessment team noted that the near-impeller region remains under-resolved even on the fine mesh due to tight geometric tolerances. achievedLevel 2 against requiredLevel 4 constitutes a two-grade gap and is the primary Critical weakener (W-AR-02) in this package. Despite this gap, the team accepted the package on the basis that Monte Carlo UQ bounds envelope the discretization error contribution.",
      "isCriticalGap": true
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, boundary conditions, operating speed and flow rate) match COU operating envelope within specified tolerances; deviations documented and impact assessed.",
      "rationale": "The FDA PIV dataset was acquired using a blood-analog fluid (water-glycerin mixture) rather than human blood. Viscosity was matched at 37°C to within 4%, but the non-Newtonian shear-thinning behavior of blood at low shear rates is not replicated. Operating points in the PIV dataset cover 2500–3500 RPM and 3–7 LPM, partially overlapping the VAD COU envelope (2000–4500 RPM, 2–8 LPM). Two of five COU operating points fall outside the validated range. achievedLevel 2 is below requiredLevel 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, NRMSE) computed for all primary QoIs; statistical significance of agreement assessed; systematic bias identified and characterized.",
      "rationale": "Quantitative comparison metrics were computed for velocity magnitude (NRMSE 8.3%), wall shear stress (NRMSE 21.4%), and hemolysis index (factor-of-1.8 to 3.2 range). Systematic underprediction of wall shear stress in the volute region is documented. Bias characterization is qualitative rather than statistically rigorous; no hypothesis test for agreement is reported. achievedLevel 3 against requiredLevel 4 represents a one-grade gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs directly correspond to decision-critical outputs (absolute NIH); surrogate QoIs justified with sensitivity analysis linking them to primary decision QoI.",
      "rationale": "Velocity field and wall shear stress are used as surrogate validation QoIs. Sensitivity analysis (Sobol indices) demonstrates that hemolysis index is strongly driven by the constitutive model coefficient rather than by the velocity field accuracy, weakening the linkage between the surrogate QoIs and the primary decision QoI. The direct hemolysis comparison provides partial but incomplete coverage. achievedLevel 3 below requiredLevel 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, flow regime, and fluid representative of the COU; any differences systematically characterized and their impact on prediction credibility assessed.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which shares the centrifugal design class with the subject VAD but differs in impeller diameter, blade count, and volute geometry. Flow regime (Reynolds number range) overlaps partially. The generic pump is not the device-under-assessment; a formal similarity analysis quantifying the impact of geometric differences on hemolysis prediction has not been performed. achievedLevel 3 against requiredLevel 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to levels consistent with MRL 5 requirements; floating-point round-off and linearization errors characterized.",
      "rationale": "Solver error was not formally assessed. Residual convergence plots were reviewed qualitatively and deemed acceptable by the analyst, but no quantitative convergence criterion was applied and no round-off or linearization error characterization was performed. Flagged as an epistemic gap at MRL 5. achievedLevel 1 against requiredLevel 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of analyst setup choices (boundary condition selection, turbulence model selection, mesh topology) by an independent reviewer with documented findings.",
      "rationale": "No independent review of analyst setup choices was performed. Turbulence model selection (SST k-omega) and near-wall treatment were made by the primary analyst without peer review. Use error is flagged as an epistemic gap. achievedLevel 1 against requiredLevel 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis constitutive model formally quantified; alternative model forms evaluated; epistemic uncertainty bounds on NIH attributable to model form reported.",
      "rationale": "Model form uncertainty for the Giersiepen-Wurzinger power-law hemolysis model was not formally assessed. The Sobol analysis identifies this as the dominant uncertainty source (S1 = 0.61), yet no alternative model forms (e.g., Taskin, Arora) were evaluated and no formal model-form uncertainty bound was computed. Flagged as a critical epistemic gap at MRL 5. achievedLevel 1 against requiredLevel 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterized with probability distributions or confidence intervals; sources of input uncertainty documented; Monte Carlo propagation covers all significant input uncertainties.",
      "rationale": "Six hemolysis model coefficients, inlet velocity profile, and fluid viscosity were characterized with uniform or normal distributions and propagated via Monte Carlo. However, turbulence boundary conditions (inlet turbulent intensity and length scale) were held fixed at nominal values and not included in the UQ campaign despite known sensitivity. Blood rheology parameters were not varied. achievedLevel 2 against requiredLevel 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples (blood-analog fluid batches, pump specimens) characterized for material properties and manufacturing variability; sample-to-sample variability quantified.",
      "rationale": "Test sample characterization was not performed. The FDA PIV dataset does not report fluid batch properties or pump specimen dimensional measurements. Manufacturing variability of the FDA generic pump geometry is unknown. Flagged as an epistemic gap. achievedLevel 1 against requiredLevel 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis demonstrating that input parameters used in the validation activity are representative of COU inputs; any non-equivalencies quantified and their impact on prediction credibility bounded.",
      "rationale": "No formal equivalency analysis was performed between validation inputs (FDA generic pump, blood-analog fluid, laboratory operating conditions) and COU inputs (subject VAD device, human blood, clinical operating envelope). Differences in geometry, fluid, and operating range are acknowledged qualitatively but not quantitatively bounded. Flagged as an epistemic gap at MRL 5. achievedLevel 1 against requiredLevel 3."
    }
