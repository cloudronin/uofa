  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package at Medium assurance level on the basis that the Monte Carlo UQ campaign (5000-sample LHC) provides broad uncertainty bounds that nominally envelope the identified discretization and model-form gaps, and that the FDA generic pump validation dataset represents the best available experimental evidence for centrifugal blood pump hemolysis prediction. The team judged that the combination of documented software QA, partial mesh-refinement evidence, and Monte Carlo UQ collectively supports a Medium assurance declaration sufficient for regulatory submission. Residual gaps in discretization error (GCI 14.7% vs. 5% threshold), model form uncertainty, and equivalency of input parameters are acknowledged in the technical report but were not considered disqualifying given the conservative UQ bounds. NOTE (adversarial): this acceptance decision is structurally inconsistent with the Discretization error factor gap (achievedLevel 2, requiredLevel 4), which constitutes a Critical W-AR-02 weakener, and with the Medium assurance declaration, which together fire COMPOUND-03.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
