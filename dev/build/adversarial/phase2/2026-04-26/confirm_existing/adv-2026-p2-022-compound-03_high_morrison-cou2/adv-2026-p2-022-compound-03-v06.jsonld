    "https://uofa.net/synth/data/monte-carlo-uq-sample-set-5000"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/fda-pump-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic pump at 2500 RPM / 5 LPM",
      "description": "Computational velocity fields compared against FDA-published PIV measurements at the mid-plane of the FDA generic centrifugal pump. Normalized RMS error of 8.3% across the measurement domain. Good agreement in bulk flow regions; elevated discrepancy near volute tongue where shear stress gradients are highest and hemolysis contribution is significant."
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-invitro-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against in-vitro measurements — 5 operating points",
      "description": "Predicted normalized index of hemolysis (NIH) compared to in-vitro measurements at five flow-speed operating points. Predictions fall within a factor of 1.8 of measured values at three points; two operating points show factor-of-3.2 overprediction attributed to unresolved near-wall hemolysis contributions. The hemolysis constitutive model (power-law Giersiepen-Wurzinger) is acknowledged to carry substantial epistemic uncertainty at shear rates above 500 Pa."
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-sensitivity",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ sensitivity analysis — 5000-sample Latin hypercube",
      "description": "A 5000-sample Latin hypercube Monte Carlo campaign was executed to propagate uncertainty in six hemolysis model coefficients, inlet boundary conditions, and fluid viscosity. The 95th-percentile prediction interval spans a factor of 4.1 around the median NIH estimate. Sobol sensitivity indices identify the hemolysis power-law exponent as the dominant source of output variance (S1 = 0.61), confirming that model-form uncertainty — not numerical error — governs prediction uncertainty at MRL 5."
    }
  ],
