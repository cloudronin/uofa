  "signature": "ed25519:b1d4e7f2a09c3e6b8d1f4a7c0e3b6d9f2a5c8e1b4d7f0a3c6e9b2d5f8a1c4e7",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; all regression tests pass.",
      "rationale": "ANSYS Fluent 2022 R2 used under a validated SQA plan. Full regression test suite executed; no failures. SQA documentation reviewed and found compliant with MRL 5 requirements. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or equivalent analytical benchmark demonstrates correct implementation of governing equations for rotating-frame turbulent flow.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes implementation. Second-order spatial convergence confirmed. Code verification judged complete at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI below 5% for all quantities of interest including wall shear stress; Richardson extrapolation performed on at least three mesh levels.",
      "rationale": "Three-level GCI study completed. Velocity GCI below 3% but wall shear stress GCI reached 9.8% on finest mesh. Richardson extrapolation applied; extrapolated values used in hemolysis calculation. Assessment team accepted this as sufficiently controlled given conservative safety factors, but achieved level remains one grade below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match COU operating envelope within specified tolerances; inlet turbulence intensity and fluid temperature characterised.",
      "rationale": "FDA pump experimental conditions replicated at 4 of 5 operating points. Fifth operating point (highest speed, lowest flow) lacked characterised inlet turbulence data; assumed fully-developed turbulence profile applied. Temperature control verified within ±0.5°C. Minor gap acknowledged but assessed team judged impact low."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., NRMSE, bias) reported for all QoIs; uncertainty in experimental measurements propagated into comparison.",
      "rationale": "nIH predictions compared against experimental data with experimental uncertainty bars propagated. Mean absolute error 18%; systematic bias at extreme operating points. Assessment team noted that conservative over-prediction provides safety margin and accepted the comparison as adequate for regulatory purposes, though quantitative agreement falls below the Gradation 4 threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical hemolysis endpoints; mapping from nIH to plasma-free haemoglobin documented.",
      "rationale": "Normalized index of hemolysis directly maps to plasma-free haemoglobin via validated power-law relationship. QoIs reviewed by clinical advisory board and confirmed as directly relevant to patient safety endpoints. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry and fluid (blood analogue) as the COU; operating conditions span the full COU envelope.",
      "rationale": "FDA generic pump geometry used in validation matches COU geometry. Blood analogue (glycerol-water) used in experiments rather than porcine blood; rheological similarity confirmed by viscosity matching. Full operating envelope covered at 4 of 5 points. Relevance is high but not complete due to fluid substitution; achieved level one grade below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to at least 10^-5 for all residuals; round-off error assessed as negligible relative to discretization error.",
      "rationale": "All simulations converged to residual tolerance of 10^-6. Double-precision arithmetic used throughout. Round-off error assessed as three orders of magnitude below discretization error. Solver error factor fully met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup independently reviewed by a second analyst; setup checklist completed and archived.",
      "rationale": "Internal peer review of simulation setup conducted by a senior analyst. Independent external review was planned but not completed prior to submission deadline. Setup checklist partially completed; turbulence model selection and near-wall treatment sections not independently verified. Achieved level below required; gap acknowledged in assessment report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty quantified for the hemolysis damage model and turbulence closure; alternative model forms evaluated and sensitivity documented.",
      "rationale": "The power-law Giersiepen-Wurzinger hemolysis damage model was applied without evaluation of alternative formulations (e.g., Arora, Taskin, or strain-based models). Turbulence closure sensitivity study was scoped to k-omega SST only; no comparison against LES or RSM performed. Model form uncertainty was acknowledged in the UQ campaign narrative but not formally quantified as a separate contribution. The assessment team judged the power-law model as industry-standard and sufficient, citing its widespread regulatory acceptance. However, the achieved level of 2 against a required level of 4 represents a two-grade deficit — the largest single gap in this assessment and the primary structural weakness in the credibility argument. This gap is noted in the assessment report but characterised as a known limitation of the state of the art rather than a disqualifying deficiency, which the team used to justify proceeding with a Medium assurance declaration.",
      "note": "ADVERSARIAL TRIGGER — W-AR-02: achievedLevel (2) < requiredLevel (4) with Accepted decision and Medium assuranceLevel declared. This Critical weakener, combined with the Medium assuranceLevel on the UnitOfAssurance, fires COMPOUND-03."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions characterised with documented uncertainty; sensitivity analysis identifies dominant inputs.",
      "rationale": "Fluid viscosity, density, and pump speed characterised with documented uncertainty distributions. Monte Carlo propagation identifies pump speed and inlet flow rate as dominant contributors to hemolysis prediction uncertainty. Blood damage coefficients (C, alpha, beta in power-law model) assigned literature-derived point estimates without uncertainty bounds — a recognised gap. Achieved level one grade below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point; sample-to-sample variability quantified.",
      "rationale": "Two replicates available for three of five operating points; single measurement at two operating points due to experimental resource constraints. Sample variability could not be fully characterised. Assessment team accepted this as the best available data given the experimental programme scope. Achieved level below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrably equivalent to COU device and operating conditions; any differences formally justified.",
      "rationale": "Pump geometry, rotational speed, and flow rates matched to COU specification. Blood analogue substitution formally justified via viscosity equivalency argument. Haematocrit effects not modelled (single-phase assumption); equivalency argument provided but not experimentally validated. Achieved level one grade below required."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors and the Monte Carlo uncertainty quantification campaign. While several factors exhibit gaps between achieved and required levels, the team concluded that the conservative nature of the hemolysis predictions (systematic over-prediction provides patient safety margin), the breadth of the validation dataset, and the comprehensive UQ campaign collectively support acceptance of the simulation results for regulatory submission. The model form gap was characterised as a state-of-the-art limitation applicable to all hemolysis CFD submissions and not specific to this assessment. The team declared a Medium assurance level reflecting moderate confidence in the predictive capability, consistent with the overall evidence base as holistically interpreted. The decision to accept was made with the understanding that additional model form sensitivity studies will be conducted in a future assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
