  "assuranceLevel": "Medium",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-03 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. A comprehensive 13-factor assessment was conducted; the majority of factors achieved levels at or near the required thresholds, and Monte Carlo uncertainty quantification was performed across all five flow-speed combinations. The assessment team concluded that the overall body of evidence, taken holistically, supports a Medium assurance classification and an Accepted decision. Residual gaps in two lower-weight factors were judged manageable given the depth of validation activity and the robustness of the uncertainty propagation methodology. Note: one factor (Model form) carries an achieved level below its required level, which the team characterised as a bounded limitation rather than a disqualifying deficiency.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-vad-hemolysis-req",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-vad-hemolysis-claim",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-centrifugal-pump-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-generic-pump-piv-dataset",
    "https://uofa.net/synth/data/morrison-hemolysis-experimental-dataset",
    "https://uofa.net/synth/data/monte-carlo-uq-samples-5000"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-piv-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA generic pump, 5 operating points",
      "description": "Particle image velocimetry measurements acquired at 5 flow-speed combinations were compared against CFD velocity predictions. Mean absolute error across all planes was 6.2 % of bulk velocity, within the pre-specified 8 % acceptance band. Turbulence intensity predictions showed acceptable agreement at design flow; minor deviations observed at off-design conditions were within Monte Carlo 95th-percentile uncertainty bounds."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison — modified index of hemolysis (MIH)",
      "description": "Predicted modified index of hemolysis values were compared against in-vitro measurements from three independent test runs. CFD predictions fell within ±18 % of mean experimental values at 4 of 5 operating points. The fifth operating point (high-speed, low-flow) showed a 27 % over-prediction, attributed to recirculation-driven shear stress amplification not fully captured by the Eulerian hemolysis sub-model. The team accepted this deviation as conservative."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-mesh-convergence",
      "type": "ValidationResult",
      "name": "Grid convergence study — Richardson extrapolation on hemolysis index",
      "description": "Three systematically refined meshes (4.2 M, 11.7 M, 28.4 M cells) were used in a Richardson extrapolation study. Grid convergence index (GCI) on the hemolysis index was 3.1 % on the fine mesh, satisfying the pre-specified GCI < 5 % criterion. Asymptotic convergence ratio of 0.97 confirmed the solution was within the asymptotic range."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-uq-monte-carlo",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — 5 000-sample propagation",
      "description": "A 5 000-sample Monte Carlo propagation was performed on 14 uncertain input parameters (fluid viscosity, density, pump speed tolerance, inlet flow rate uncertainty, hemolysis model constants). The 95th-percentile hemolysis index prediction remained below the clinical threshold at 4 of 5 operating points. At the high-speed low-flow condition, the 95th-percentile prediction exceeded the threshold by 4 %, which the team judged acceptable given the conservative nature of the hemolysis model at that operating point."
    }
  ],
