  "signature": "ed25519:b4e8d3f2a1c09e7f6b5a4d3c2e1f0a9b8c7d6e5f4a3b2c1d0e9f8a7b6c5d4e3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation and post-processing must be under formal version control with documented test suite; solver version must be traceable to a validated release.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-compliant quality management system. Version control records, build verification tests, and release notes were reviewed and found complete. All simulation scripts and post-processing macros were archived in a controlled repository with commit hashes recorded in the study log. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions (MMS) or equivalent benchmark problems relevant to rotating machinery flows.",
      "rationale": "MMS verification was performed on a rotating annular cavity benchmark. Observed order of accuracy (2.01 for velocity, 1.98 for pressure) matched the theoretical second-order scheme. Additional verification against the FDA nozzle benchmark (FDA critical path) confirmed solver correctness for blood-analogue fluids. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) on the primary quantity of interest (hemolysis index) must be below 5 % on the production mesh.",
      "rationale": "Richardson extrapolation on three systematically refined meshes yielded GCI = 3.1 % on the fine mesh (28.4 M cells). Asymptotic convergence ratio confirmed the solution was in the asymptotic range. The production mesh was the fine mesh. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate clinical operating envelope (flow rate, rotational speed, fluid temperature, hematocrit) within specified tolerances; test fluid must be a validated blood analogue.",
      "rationale": "In-vitro experiments used porcine blood at 37 °C ± 0.5 °C with hematocrit 33 ± 2 %. Flow rates and rotational speeds matched the five target operating points within ±1.5 %. Fluid rheology was characterised pre- and post-test; no significant degradation was observed. All five operating points fell within the intended clinical envelope. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (normalised RMS error, mean absolute percentage error) must be reported for all QoIs; statistical equivalence must be demonstrated at the 95 % confidence level.",
      "rationale": "Hemolysis index predictions were within ±18 % of experimental means at 4 of 5 operating points; the fifth showed 27 % over-prediction judged conservative. Velocity field MAPE was 6.2 %. Statistical equivalence testing (Welch t-test) confirmed non-inferiority at α = 0.05 for 4 operating points. The over-prediction at the fifth point was documented and accepted as a conservative bound. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, velocity field) must be directly linked to the clinical decision criterion (absolute hemolysis below clinical threshold).",
      "rationale": "The modified index of hemolysis (MIH) used in validation is the same metric applied in the regulatory submission. Velocity field validation supports confidence in the shear stress predictions that drive the hemolysis sub-model. The linkage between validation QoIs and the clinical decision criterion is direct and documented in the V&V plan. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry and at operating conditions spanning the full clinical envelope defined in the COU.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is the same geometry used in the COU simulations. All five COU operating points were included in the validation test matrix. No geometric simplifications or scaling were applied. The validation domain is co-extensive with the COU domain. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-5 for all transport equations; mass imbalance must be below 0.01 %.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity, momentum, and turbulence equations. Mass imbalance across the pump domain was 0.003 %. Convergence histories were archived for all 5 operating points. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary conditions and material properties must be traceable to documented sources.",
      "rationale": "An independent senior CFD analyst reviewed all boundary condition specifications, material property assignments, and solver settings prior to production runs. Review findings were documented and all identified discrepancies were resolved. Boundary conditions were traced to experimental measurement reports. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis sub-model and turbulence closure must be validated against blood-damage data from rotating machinery; model-form uncertainty must be quantified and shown to be within acceptable bounds relative to the clinical threshold.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected for computational efficiency. Sensitivity analyses comparing three alternative hemolysis formulations (Arora, Taskin, Goubergrits) showed prediction spread of up to 35 % at off-design conditions, indicating non-trivial model-form uncertainty. The SST k-ω turbulence model was used; no rotating-machinery-specific turbulence validation was performed for this device. Model-form uncertainty was estimated qualitatively but not formally quantified to the level required at MRL 5. The team acknowledged this gap but concluded that the conservative over-prediction at the critical operating point partially mitigates the risk. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterised with probability distributions derived from experimental data or literature; distributions must be propagated through the model via Monte Carlo or equivalent method.",
      "rationale": "Fourteen uncertain input parameters were identified and assigned probability distributions based on experimental characterisation and literature review. A 5 000-sample Monte Carlo propagation was performed. Input distributions were peer-reviewed and approved by the V&V team lead. Required level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent experimental replicates must be available for each operating point used in validation; sample-to-sample variability must be characterised.",
      "rationale": "Three independent test runs were performed for each of the five operating points using freshly prepared blood samples. Inter-run coefficient of variation on hemolysis index was below 8 % at all operating points. Sample preparation and handling protocols were documented and followed consistently. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD boundary condition inputs must be demonstrated to be equivalent to the experimentally measured inlet conditions within stated measurement uncertainties.",
      "rationale": "Inlet velocity profiles measured by PIV at the pump inlet plane were used directly as CFD boundary conditions via interpolation onto the CFD mesh. Inlet turbulence intensity was matched to PIV-derived estimates. Equivalency between experimental and CFD inlet conditions was confirmed by overlay comparison; maximum discrepancy was 3.4 % of bulk velocity, within measurement uncertainty. Required level 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team determined that the overall body of evidence supports acceptance of the CFD model for the VAD hemolysis prediction COU. Ten of thirteen credibility factors achieved their required levels. The model-form factor (achieved level 2 against required level 4) was acknowledged as a gap; however, the team concluded that the conservative over-prediction observed at the critical operating point, combined with the breadth of Monte Carlo uncertainty quantification, provides sufficient confidence that the model will not under-predict hemolysis in a clinically consequential manner. The declared Medium assurance level reflects the team's holistic judgement that the evidence base is substantially complete and the residual model-form uncertainty is bounded and conservative. The decision is Accepted with the condition that model-form sensitivity is revisited if the device operating envelope is expanded beyond the five characterised points.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
