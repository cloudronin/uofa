  "signature": "ed25519:b7e2a1c4f8d305a96e1b2c7f4d8a3e06b1c5f9d2a7e4b8c3f1d6a9e2b5c8f0d3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all tests passing for the hemolysis-enabled build.",
      "rationale": "The CFD solver (OpenFOAM v9, hemolysis branch) is maintained under git version control with a 47-case regression suite. All regression tests pass for the build used in this study. SQA documentation is complete and traceable to the submitted binary. Required level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to Navier-Stokes and hemolysis transport equations; observed order of accuracy within 10% of theoretical.",
      "rationale": "MMS verification was performed for both the incompressible Navier-Stokes solver and the scalar hemolysis damage transport equation. Observed spatial order of accuracy is 1.92 (theoretical 2.0) for momentum and 1.87 for the damage scalar, both within the 10% tolerance. Code verification is satisfactory at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; GCI < 5% for hemolysis index QoI at all operating points.",
      "rationale": "Richardson extrapolation was performed on meshes of 4.2M, 11.8M, and 31.5M cells. Grid convergence index for NIH is below 5% at three of five operating points. At the two high-speed operating points (6000 RPM, 7 L/min and 6000 RPM, 9 L/min), GCI reaches 8.3% and 9.1% respectively, exceeding the acceptance threshold. Achieved level is assessed as 3 against a required level of 4. The gap is noted but the decision record accepts the submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, hematocrit) match COU operating envelope within stated measurement uncertainty.",
      "rationale": "Bench test conditions were controlled to match all five COU operating points. Inlet flow rates verified with ultrasonic flow meters (±1.5% accuracy). Fluid temperature maintained at 37 ± 0.5 °C. Hematocrit confirmed at 33 ± 1% for all test runs. Test conditions satisfy required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E_rms or similar) computed with uncertainty bounds for all QoIs at all COU operating points; metric within acceptance band.",
      "rationale": "Quantitative output comparison metrics were computed for velocity field and hemolysis index at three of five operating points. At the remaining two operating points, experimental hemolysis data were unavailable; qualitative flow-field comparisons were substituted. The absence of quantitative hemolysis comparison at 40% of the operating envelope reduces the achieved level to 3 against a required level of 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs are the same scalar quantities (NIH, volume-averaged shear stress) used in the regulatory decision; no surrogate QoIs substituted.",
      "rationale": "The primary validation QoI is the normalized index of hemolysis, which is identical to the regulatory decision quantity. Volume-averaged shear stress is a secondary QoI used for mechanistic interpretation. No surrogate quantities were substituted. Relevance of QoIs is fully satisfied at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry and fluid under COU-representative operating conditions; no geometric or fluid surrogates used.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry identical to the COU device. Blood analogue fluid (glycerol-water with bovine red blood cells) was used rather than human blood, introducing a recognized surrogate. Rheological properties were matched to within 8% of target hematocrit-adjusted viscosity. The use of a bovine blood analogue rather than human blood limits the achieved level to 3 against a required level of 4 for this MRL 5 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to at least 10^-5 for all residuals; double-precision arithmetic confirmed.",
      "rationale": "All simulations converged to residual norms below 10^-6 for continuity and momentum equations and below 10^-7 for the hemolysis damage scalar. Double-precision arithmetic is confirmed in the solver build configuration. Numerical solver error is satisfactorily controlled at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second qualified analyst; documented checklist of boundary condition and material property inputs.",
      "rationale": "A simulation setup checklist was completed by the primary analyst. An independent review was initiated but not finalized prior to the submission deadline; the reviewer signed off on boundary conditions and mesh topology but did not verify the hemolysis model constants against the source literature. The incomplete independent review limits the achieved level to 2 against a required level of 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two alternative hemolysis model forms evaluated; model-form uncertainty bounded and incorporated into UQ; sensitivity of regulatory conclusion to model-form choice demonstrated.",
      "rationale": "The power-law hemolysis damage accumulation model (Giersiepen-Wurzinger) was selected without evaluation of alternative model forms such as the Arora or Taskin models. Model-form uncertainty was acknowledged in the UQ report narrative but was not propagated through the Monte Carlo analysis; only parametric uncertainty in the power-law coefficients was sampled. No sensitivity analysis comparing regulatory conclusions across model forms was performed. The achieved level of 2 falls substantially below the required level of 5 for this MRL 5, Class III device assessment. This gap represents the most significant credibility deficit in the package.",
      "achievedVsRequired": "achievedLevel 2 < requiredLevel 5 — Critical gap; W-AR-02 condition satisfied"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs traceable to primary sources with stated uncertainty; no assumed values without justification.",
      "rationale": "Blood viscosity parameters sourced from Merrill et al. with documented uncertainty bounds. Pump geometry dimensions traceable to FDA benchmark CAD files. Inlet velocity profiles derived from measured flow rates with propagated uncertainty. All inputs are documented in the UQ input deck with primary source citations. Model inputs satisfy required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating point; inter-replicate variability characterized and reported.",
      "rationale": "Experimental hemolysis measurements were obtained from two independent test runs per operating point at the three points where bench data were available. A third replicate was planned but could not be completed due to pump seal failure during the final test campaign. Inter-replicate variability was characterized from the two available runs. The absence of a third replicate limits the achieved level to 2 against a required level of 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that validation experiment input parameters are equivalent to COU input parameters within stated tolerances for all five operating points.",
      "rationale": "Input parameter equivalency was formally demonstrated for flow rate, rotational speed, and fluid temperature at all five operating points. Hematocrit equivalency was demonstrated at three operating points; at the two high-speed points, hematocrit deviated by up to 3 percentage points from the COU target due to red cell fragility at elevated shear. The partial hematocrit equivalency gap limits the achieved level to 3 against a required level of 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-dr-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the full thirteen-factor evidence package and concluded that the submission provides Medium assurance for the intended regulatory use. The Monte Carlo UQ report demonstrates that 95th-percentile NIH predictions remain below the absolute clinical threshold across all five operating points, providing a quantitative safety margin. The flow-field validation against FDA PIV data and the partial hemolysis bench validation are judged to collectively support confidence in the model's predictive capability. Identified gaps in discretization error, output comparison, test samples, and equivalency of input parameters are acknowledged; the team judged these gaps to be individually manageable given the conservative UQ margins demonstrated. The model-form gap (achieved level 2 vs. required level 5) was noted in the UQ report narrative and was considered partially mitigated by the parametric uncertainty bounding of the power-law coefficients. On balance, the team concluded that the totality of evidence supports acceptance at Medium assurance, consistent with the submission's overall documentation quality and the rigor of the UQ methodology.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
