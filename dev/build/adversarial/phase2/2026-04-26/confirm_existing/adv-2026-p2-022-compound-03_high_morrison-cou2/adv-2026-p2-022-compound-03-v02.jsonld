  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-vr-flow-field-2023",
      "type": "ValidationResult",
      "name": "Flow field validation against FDA PIV benchmark — five operating points",
      "description": "Velocity magnitude and shear-rate distributions compared against FDA particle image velocimetry data at all five flow-speed combinations. Mean absolute error in shear-rate magnitude within 12% across operating envelope. Supports confidence in resolved fluid mechanics but does not directly validate hemolysis sub-model predictions."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-vr-hemolysis-bench-2023",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against in-vitro bench measurements",
      "description": "Predicted normalized index of hemolysis (NIH) compared against standardized in-vitro measurements at three of five operating points. Predicted NIH values fall within ±25% of measured values. Validation coverage is partial; two high-speed operating points lacked experimental hemolysis data at the time of submission, representing an unresolved gap at MRL 5."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-vr-uq-report-2024",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ propagation report — 1000-sample Latin hypercube",
      "description": "A 1000-sample Latin hypercube Monte Carlo study propagated uncertainties in blood viscosity, pump inlet pressure, and hemolysis power-law exponent through the CFD model. 95th-percentile NIH predictions remain below the absolute clinical threshold at all five operating points. The UQ report was prepared by an independent analyst and reviewed by the credibility assessment team. Despite the thoroughness of the UQ effort, model-form uncertainty in the power-law hemolysis damage accumulation model was not bounded, as no alternative model-form candidates were evaluated."
    }
  ],
