  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all test cases passing at release commit.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-certified QMS. Full regression suite (847 test cases) passed at the release commit used for this study. Software version and license records archived in the project QMS dossier. Required and achieved levels are equal; factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes method-of-manufactured-solutions (MMS) tests for incompressible Navier-Stokes with demonstrated second-order spatial convergence.",
      "rationale": "MMS verification was performed for the incompressible RANS solver on a canonical lid-driven cavity. Observed order of accuracy was 1.97 ± 0.04, consistent with the nominal second-order scheme. Results archived and independently reviewed. Factor satisfied at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI < 5% for hemolysis-relevant quantities on production mesh.",
      "rationale": "Three-level GCI study yielded GCI of 3.2% for volume-averaged shear stress and 4.7% for NIH on the medium-to-fine grid transition. Both values are below the 5% threshold. Production mesh (22M cells) selected. Factor satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity, temperature) match COU operating envelope within ±5%; full traceability to NIST-traceable standards documented.",
      "rationale": "In-vitro test conditions were controlled to within ±3% for flow rate and ±1% for rotational speed. Fluid viscosity was matched using a glycerol-water surrogate calibrated at 37°C. However, temperature traceability documentation for the hemolysis assay reagents was incomplete for two of five operating points, and the uncertainty in reagent-dependent NIH conversion factors was not formally propagated. This gap reduces traceability confidence below the Gradation 4 threshold. Achieved level 3 against required level 4 — factor not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH within ±25% of measured NIH at all five operating points; Monte Carlo 90% prediction interval brackets measured value at all points.",
      "rationale": "At four of five operating points, predicted NIH fell within the ±25% acceptance band and Monte Carlo intervals bracketed measured values. At the 6 L/min, 3500 RPM operating point — which corresponds to the upper bound of the clinical operating envelope — predicted NIH underestimated measured NIH by 38%, and the 5th–95th percentile Monte Carlo interval did not bracket the measured value. The pre-specified acceptance criterion explicitly requires all five operating points to satisfy the band. Because the most clinically demanding condition fails the quantitative criterion, the achieved level is 2. Required level is 4. This gap is the primary driver of credibility deficit in this assessment.",
      "note": "W-AR-02 trigger: achievedLevel (2) < requiredLevel (4) with decision Accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (NIH, velocity field) directly correspond to regulatory submission QoI; no surrogate metrics used.",
      "rationale": "The primary QoI in both validation activities and the regulatory submission is the Normalized Index of Hemolysis (NIH) and the volumetric velocity field. No surrogate metrics were substituted. The hemolysis power-law model parameters were taken from the literature values applied in the regulatory context. Factor satisfied at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions span the full COU envelope including worst-case operating point.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is the same geometry used in the COU. Operating conditions spanned four of five COU operating points in the experimental dataset; the fifth (highest flow-speed) point was interpolated from adjacent measurements rather than directly tested. The interpolation introduces additional uncertainty not captured in the formal UQ. Achieved level 3 against required level 4 — factor not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual < 1e-5 for all governing equations; round-off error bounded.",
      "rationale": "Residuals for continuity and momentum equations converged to below 1e-4 for all operating points; however, the pre-specified criterion required 1e-5. At the highest rotational speed, oscillatory residual behavior was observed and the simulation was terminated after 5000 iterations without achieving the tighter criterion. Round-off error analysis was not formally documented. Achieved level 2 against required level 3 — factor not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup independently reviewed by a second analyst; boundary condition inputs verified against experimental records.",
      "rationale": "An internal peer review of the simulation setup was performed, but the reviewer was a member of the same modeling team rather than an independent analyst. Boundary condition inputs were verified against experimental records for three of five operating points; the remaining two were verified only against the simulation input deck without cross-checking the primary experimental log. These gaps preclude achieving the required independence level. Achieved level 2 against required level 3 — factor not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by sensitivity study; hemolysis constitutive model validated against blood-analogue data; model form uncertainty formally quantified.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature recommendations for rotating machinery, but no formal sensitivity study comparing alternative turbulence models (e.g., RSM, LES) was performed for this specific geometry and operating range. The Giersiepen hemolysis power-law model was used without re-calibration to the specific blood analogue fluid used in the in-vitro tests. Model form uncertainty was not formally quantified; only parametric uncertainty in power-law coefficients was propagated via Monte Carlo. The absence of model form uncertainty quantification is a significant gap at MRL 5. Achieved level 2 against required level 4 — factor not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterized with probability distributions; sensitivity analysis identifies dominant inputs; distributions traceable to experimental measurements.",
      "rationale": "Monte Carlo UQ was performed with probability distributions assigned to fluid viscosity, power-law model coefficients, and inlet velocity profile. Sensitivity analysis (Sobol indices) identified power-law exponent as the dominant uncertainty contributor. However, geometric tolerances on the pump impeller were not included as uncertain inputs, and wall roughness was treated as deterministic. These omissions limit the completeness of the input characterization. Achieved level 3 against required level 4 — factor not fully met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point; sample-to-sample variability characterized and reported.",
      "rationale": "In-vitro hemolysis measurements were performed in duplicate (n=2) at each operating point rather than the required triplicate (n=3). Sample-to-sample variability was reported as a range rather than a formal statistical characterization with confidence intervals. The reduced replicate count limits the ability to distinguish model prediction error from experimental variability. Achieved level 2 against required level 3 — factor not met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Correspondence between experimental and simulation input parameters demonstrated quantitatively for all primary boundary conditions.",
      "rationale": "Quantitative correspondence was demonstrated for flow rate and rotational speed. Inlet velocity profiles were derived from the experimental PIV data and mapped to simulation boundary conditions. However, the turbulent intensity and length scale at the inlet were estimated from empirical correlations rather than measured, introducing unquantified discrepancy between experimental and simulation boundary conditions. Achieved level 2 against required level 3 — factor not met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-mrl5-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were formally assessed; six were flagged as epistemic gaps consistent with MRL 5 practice. The team noted that while several factors did not achieve their required levels, the overall body of evidence — including the comprehensive Monte Carlo UQ, the strong agreement at four of five operating points, and the thorough software QA documentation — was judged sufficient to support regulatory submission. The single operating point where the output comparison criterion was not met was adjudged by the clinical team to represent a transient-dominated regime outside the primary clinical operating window. On this basis, the assessment team declared a Medium assurance level and accepted the package for submission. The declared Medium assurance level is considered commensurate with the weight of positive evidence despite the individual factor gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
