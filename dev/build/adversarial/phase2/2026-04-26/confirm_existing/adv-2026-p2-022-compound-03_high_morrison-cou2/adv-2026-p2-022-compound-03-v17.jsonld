  "assuranceLevel": "Medium",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (COMPOUND-03 adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. This package evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. A comprehensive 13-factor assessment was conducted; seven factors were formally assessed and six were scoped as epistemic gaps consistent with MRL 5 practice. Monte Carlo uncertainty quantification was performed across all five flow-speed operating points, and the resulting uncertainty bands were propagated through the hemolysis power-law model. The assessment team concluded that the body of evidence, taken holistically, supports a Medium assurance level: verification activities are thorough, validation datasets span the clinical operating envelope, and output comparison metrics are within acceptable tolerance bands at four of five operating points. The single operating point showing marginal agreement was adjudged non-critical by the clinical team. Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-absolute-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-invitro",
    "https://uofa.net/synth/data/monte-carlo-uq-runs-5op"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-comparison-vad",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — centrifugal pump at 5 operating points",
      "description": "Particle image velocimetry measurements from the FDA benchmark dataset were compared against CFD-predicted velocity fields at all five VAD operating points. Normalized root-mean-square error (NRMSE) ranged from 4.1% to 11.8% across operating points. At the highest flow-speed combination (6 L/min, 3500 RPM), NRMSE reached 11.8%, exceeding the pre-specified 10% acceptance threshold. The assessment team noted that this operating point represents a transient-dominated regime where the steady-state RANS model is acknowledged to underperform. Agreement at the four remaining operating points was judged satisfactory."
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison-vad",
      "type": "ValidationResult",
      "name": "Normalized Index of Hemolysis (NIH) comparison — in-vitro vs CFD",
      "description": "Predicted NIH values from the Giersiepen power-law hemolysis model driven by CFD shear stress histories were compared against in-vitro NIH measurements across all five operating points. Predicted values fell within ±25% of measured NIH at four operating points. At the 6 L/min, 3500 RPM point, predicted NIH underestimated measured NIH by 38%, outside the pre-specified ±25% band. Monte Carlo uncertainty intervals (5th–95th percentile) did not bracket the measured value at this point. The team attributed the discrepancy to turbulence model inadequacy in high-shear regions and accepted the result with a note."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-vad",
      "type": "ValidationResult",
      "name": "Grid convergence index study — hemolysis-relevant shear stress",
      "description": "A three-level GCI study was performed on volume-averaged shear stress and NIH predictions. GCI values of 3.2% and 4.7% were obtained for shear stress and NIH respectively on the medium-to-fine grid transition, indicating acceptable discretization error for four operating points. The fine grid (22 million cells) was selected as the production mesh."
    }
  ],
