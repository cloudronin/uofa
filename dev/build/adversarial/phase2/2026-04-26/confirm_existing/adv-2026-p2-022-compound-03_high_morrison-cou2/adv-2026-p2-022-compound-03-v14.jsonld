  "assuranceLevel": "Medium",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (synthetic adversarial)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. A comprehensive 13-factor assessment was performed; the assessment team concluded that the accumulated body of verification and validation evidence, together with Monte Carlo uncertainty quantification across all five flow-speed operating points, supports a Medium assurance level. Discretization error studies, solver verification exercises, and multi-site validation data collectively demonstrate that model predictions remain within clinically acceptable bounds. The assessment team notes that while individual factor gaps exist, the integrated weight of evidence is judged sufficient to support regulatory submission at Medium assurance. Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-absolute-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset",
    "https://uofa.net/synth/data/hemolysis-in-vitro-multisite",
    "https://uofa.net/synth/data/monte-carlo-uq-outputs"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA benchmark pump",
      "description": "Particle image velocimetry measurements from the FDA benchmark centrifugal pump were compared against CFD-predicted velocity fields at three operating points. Agreement within 12% on mean velocity magnitude across the impeller sweep region was observed. Turbulent kinetic energy predictions showed larger deviations (up to 28%) near the volute cutwater, attributed to turbulence model limitations."
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-multisite",
      "type": "ValidationResult",
      "name": "Multi-site in-vitro hemolysis index validation",
      "description": "Normalized index of hemolysis (NIH) measurements from three independent laboratories were compared to model predictions across five flow-speed combinations. Model predictions fell within the inter-laboratory variability band (±35%) for four of five operating points. The fifth operating point (high speed, low flow) showed model underprediction of NIH by 47%, outside the acceptance band. The assessment team characterised this as an isolated outlier attributable to secondary recirculation not captured by the RANS turbulence closure."
    },
    {
      "id": "https://uofa.net/synth/validation/uq-monte-carlo",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis predictions",
      "description": "A 2000-sample Monte Carlo propagation of inlet boundary condition uncertainty, fluid rheology parameters, and pump geometry tolerances was performed. The 95th-percentile hemolysis index prediction remained below the absolute clinical threshold at four of five operating points. The high-speed low-flow condition showed the 95th-percentile prediction marginally exceeding the threshold, a finding noted in the body of the report but not reflected in the summary conclusion."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4023282",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-cardiovascular-sim-group",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1b04d958f763a1e2c4b5d6f7890abcdef1234567890abcdef12345678",
  "signature": "ed25519:b1e2f3a4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Configuration management, regression testing, and documented build verification must meet FDA software guidance expectations for Class III device simulation at MRL 5. Required level 4 mandates independent code audit trail.",
      "rationale": "The simulation software (OpenFOAM v8 with custom hemolysis damage integral) operates under a documented QMS with version control and regression test suite covering 47 canonical cases. An independent third-party audit of the hemolysis sub-model source code was not completed; internal review only. Achieved level 3 reflects the absence of independent audit, falling one gradation below the required level 4 for MRL 5 Class III applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) must be demonstrated for the hemolysis transport equation and the Navier-Stokes solver kernel at required level 4.",
      "rationale": "MMS verification was completed for the incompressible Navier-Stokes solver, confirming second-order spatial accuracy. The hemolysis damage integral transport equation was verified using a simplified analytic solution rather than full MMS, which satisfies level 3 but not level 4 criteria. The gap is acknowledged in the technical report appendix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At MRL 5 for a Class III device, a formal grid convergence index (GCI) study with at least three systematically refined meshes and Richardson extrapolation must be performed for all quantities of interest, with GCI below 5% on hemolysis index. Required level 5.",
      "rationale": "A three-mesh GCI study was performed on the baseline operating point (3.5 L/min, 3000 rpm). GCI values for hemolysis index ranged from 11% to 23% across the five operating conditions, substantially exceeding the 5% threshold. Mesh refinement was limited by computational resource constraints; the finest mesh contained 18 million cells, insufficient to resolve near-wall shear layers in the impeller gap region. The team judged that the UQ envelope partially compensates for discretization uncertainty, but the formal GCI criterion is not met. Achieved level 2 reflects that convergence was demonstrated only qualitatively."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with traceability to COU operating conditions, including fluid temperature, hematocrit, and pump rotational speed tolerances. Required level 4 mandates uncertainty characterisation of all test boundary conditions.",
      "rationale": "In-vitro test conditions were documented with hematocrit (40±2%), temperature (37±0.5°C), and speed (±15 rpm) reported. Inlet flow waveform uncertainty was not formally characterised; only nominal values were reported by the testing laboratory. This omission prevents full level 4 compliance. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., validation uncertainty, U_val) must be computed and compared against model prediction interval for all five operating points. Required level 4 mandates that comparison accounts for both experimental and numerical uncertainty.",
      "rationale": "Validation uncertainty was computed for four of five operating points using the ASME V&V 20 framework. The fifth operating point (high-speed, low-flow) lacked replicate experimental measurements, preventing formal U_val calculation. The assessment team applied a conservative bounding estimate for this point. Achieved level 3 reflects the incomplete coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation quantities of interest must directly correspond to the COU decision quantity (absolute NIH). Required level 4 mandates that the primary QoI used in validation is identical to the regulatory submission QoI.",
      "rationale": "Validation was performed directly on the normalized index of hemolysis (NIH g/100L), which is the identical metric used for regulatory acceptance. No surrogate QoIs were employed. Achieved level 4 is fully supported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be performed on the same pump geometry and at operating conditions spanning the full COU envelope. Required level 4 mandates geometric identity and full operating envelope coverage.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry, which is identical to the COU device geometry. Operating conditions covered four of five COU flow-speed combinations; the extreme high-speed low-flow condition was represented only by a single legacy dataset from a different laboratory with a geometrically similar but not identical pump. Achieved level 3 due to partial operating envelope coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to solver tolerance levels consistent with MRL 5 requirements; residual norms and mass conservation errors must be reported for all operating points.",
      "rationale": "Residual norms for momentum and continuity equations were reduced to 1e-5 for all steady-state operating points. The hemolysis transport equation exhibited residual stagnation at 5e-4 for the high-speed low-flow condition, above the 1e-5 target. Mass conservation error was below 0.01% for all cases. Achieved level 3 due to the transport equation convergence deficiency at one operating point."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution procedures, boundary condition setup checklists, and independent review of model setup must be in place. Required level 3 for MRL 5.",
      "rationale": "Simulation setup procedures are documented in a standard operating procedure (SOP-CFD-007). Boundary condition setup was reviewed internally by a senior engineer. Independent external review of model setup was not performed. The SOP does not cover the hemolysis damage model parameter selection procedure, which was performed ad hoc. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At MRL 5, the selection of turbulence closure, hemolysis damage model form, and non-Newtonian blood rheology model must be justified through sensitivity analysis and literature benchmarking. Required level 5 mandates quantified model form uncertainty contribution to total prediction uncertainty.",
      "rationale": "The k-omega SST turbulence model was selected based on prior FDA benchmark studies. The Giersiepen-Wurzinger hemolysis power-law model was used without evaluation of alternative damage integral formulations (e.g., Arora, Faghih-Sharp). A sensitivity study comparing two turbulence models (k-omega SST vs. realizable k-epsilon) was performed at one operating point, showing up to 31% difference in predicted NIH. Model form uncertainty was not formally quantified or propagated into the total uncertainty budget. The assessment narrative characterises this gap as 'within expected engineering judgement bounds' without quantitative support. Achieved level 2 reflects the absence of formal model form uncertainty quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterised with probability distributions or uncertainty bounds traceable to measurements or literature. Required level 4 mandates that input uncertainty distributions are validated against physical measurements.",
      "rationale": "Monte Carlo UQ was performed with distributions assigned to inlet flow rate (normal, CV=3%), rotational speed (normal, CV=0.5%), and blood viscosity (log-normal based on literature). Pump clearance gap geometry was treated as deterministic despite manufacturing tolerance data being available. The omission of geometric uncertainty from the UQ was flagged in an internal review comment but not addressed prior to submission. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterised for biological variability; for hemolysis, donor variability in red blood cell fragility must be documented and accounted for. Required level 4 mandates at least three independent donor blood pools with fragility characterisation.",
      "rationale": "In-vitro hemolysis experiments were performed using a single pooled bovine blood preparation per laboratory. Human donor blood variability was not characterised; red blood cell fragility indices were not measured. The use of bovine blood introduces a known species-specific difference in RBC membrane properties relative to human blood, which the model does not account for. Achieved level 2 reflects the absence of donor variability characterisation and the species substitution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions applied in the simulation must be demonstrably equivalent to those present in the validation experiments, with documented traceability. Required level 4 mandates quantitative equivalency metrics for all primary boundary conditions.",
      "rationale": "Inlet velocity profiles applied in the simulation were derived from PIV measurements at the pump inlet plane, providing good traceability for the primary boundary condition. Outlet pressure boundary conditions were set to match laboratory circuit resistance curves using a 1D lumped parameter model; equivalency was demonstrated qualitatively but not through direct pressure measurement comparison. Achieved level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors and the associated validation evidence. While several factors achieved levels below their required levels — most notably discretization error (achieved 2, required 5), model form (achieved 2, required 5), and test samples (achieved 2, required 4) — the team concluded that the integrated weight of evidence, including the Monte Carlo uncertainty quantification, multi-site validation agreement at four of five operating points, and direct QoI alignment, collectively supports a Medium assurance level sufficient for regulatory submission. The team judged that the UQ envelope conservatively bounds the discretization and model form gaps, and that the bovine blood substitution introduces negligible systematic bias based on published comparative hemolysis data. The package is therefore accepted at Medium assurance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
