  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed; six remain as epistemic gaps. Despite achieved levels falling below required levels across all assessed factors, the assessment team accepted the package on the basis that Monte Carlo uncertainty quantification was completed and hemolysis predictions remained below the absolute clinical threshold at the three validated operating points. The absence of a defined operating envelope or applicability constraint was not flagged during review.",
