  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression test suite, and release validation at MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v8) is under formal version control with a regression test suite covering 42 canonical flow cases. Release validation documentation is complete and archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) for the governing equations used in the hemolysis model.",
      "rationale": "MMS verification confirms second-order spatial accuracy for the Navier-Stokes solver and first-order accuracy for the power-law hemolysis transport equation. Results are within expected theoretical bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be computed on at least three systematically refined meshes; GCI on hemolysis index must be below 5%.",
      "rationale": "Three mesh levels (3.2M, 9.6M, 28.8M cells) yield a GCI of 3.1% on the hemolysis index at the design operating point, satisfying the 5% threshold. Asymptotic convergence ratio confirmed at 1.02."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) must be documented with measurement uncertainty and match CFD boundary conditions within stated tolerances.",
      "rationale": "All five flow-speed combinations were tested under controlled conditions with calibrated flow meters (±1.5%) and tachometers (±0.5%). Fluid viscosity and density measured at test temperature and applied directly as CFD boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalised RMSE or validation metric u_val) must be computed including experimental and numerical uncertainty; metric must demonstrate adequate agreement at the clinical threshold.",
      "rationale": "Normalised RMSE across five operating points is 8.2%, within the acceptance band of 15% when combined measurement and simulation uncertainty (u_val = 11.4%) is accounted for. All predictions lie within ±2 sigma of experimental mean."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalised index of hemolysis, NIH) used in validation must be the same scalar quantity used in the clinical acceptance criterion.",
      "rationale": "Both validation experiments and clinical acceptance use the normalised index of hemolysis (NIH) computed from the same ASTM F1841 protocol. No surrogate or proxy QoI is employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same FDA generic pump geometry and cover the full range of flow-speed combinations specified in the COU.",
      "rationale": "Validation was performed on the FDA benchmark centrifugal pump geometry (identical CAD to simulation) at all five COU-specified operating points. No geometry simplifications were introduced between validation and COU model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated by residual reduction of at least 4 orders of magnitude and monitored QoI stabilisation over final 500 iterations.",
      "rationale": "All simulations achieve residual reduction of 5–6 orders of magnitude. NIH values vary by less than 0.3% over the final 500 iterations, confirming iterative convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented peer review of simulation setup, boundary conditions, and post-processing scripts must be completed by an independent analyst.",
      "rationale": "An independent CFD analyst reviewed all boundary condition files, turbulence model settings, and NIH post-processing scripts. Two minor discrepancies were identified and corrected prior to final results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis must quantify the contribution of turbulence model choice and hemolysis constitutive law to total NIH prediction uncertainty.",
      "rationale": "Four turbulence models (k-omega SST, k-epsilon realizable, RSM, LES) and two hemolysis laws (Giersiepen-Wurzinger, Heuser-Opitz) were compared. Turbulence model contributes 18% and hemolysis law contributes 31% of total NIH variance; both are included in the Monte Carlo UQ budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain input parameters must be specified and propagated via Monte Carlo with at least 500 samples; 95th-percentile NIH must remain below clinical threshold.",
      "rationale": "Monte Carlo UQ with 1000 Latin hypercube samples propagates uncertainty in viscosity, hemolysis model coefficients, and inlet velocity profile. 95th-percentile NIH is 0.0031 g/100 L, below the clinical threshold of 0.01 g/100 L."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must be replicated at least three times per operating point using fresh blood samples meeting ASTM F1841 quality criteria.",
      "rationale": "Five replicates per operating point were performed using bovine blood meeting ASTM F1841 baseline hemolysis criteria. Inter-replicate coefficient of variation was below 8% at all five points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Fluid properties and pump geometry used in CFD must be demonstrably equivalent to those used in the validation experiments, with documented traceability.",
      "rationale": "Pump geometry was digitised from the same physical test article used in experiments via structured-light scanning (±0.05 mm). Fluid properties were measured from each blood batch and matched to CFD inputs within 2% for viscosity and 0.5% for density."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed with achieved levels meeting or exceeding required levels for MRL 5. Monte Carlo UQ confirms that the 95th-percentile NIH prediction remains below the clinical threshold across all five COU operating points. The assessment team accepts the CFD model as adequately credible for predicting absolute hemolysis in the Class III VAD COU. Note: the ContextOfUse does not specify an applicability constraint or operating envelope; the boundaries of valid model use beyond the five assessed operating points are therefore uncharacterised.",
