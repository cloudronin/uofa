      "name": "Bench-scale hemolysis index validation against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-vad-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study for centrifugal pump CFD discretization error"
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-vad-uq-monte-carlo",
