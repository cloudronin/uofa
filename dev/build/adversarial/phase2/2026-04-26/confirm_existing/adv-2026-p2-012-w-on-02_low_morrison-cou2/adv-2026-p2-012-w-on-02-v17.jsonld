      "factorStatus": "assessed",
      "acceptanceCriteria": "Software development lifecycle documentation, version control, and regression test suite covering hemolysis solver routines must satisfy MRL 5 requirements.",
      "rationale": "Version control and unit tests are present but the regression suite covers only 60% of hemolysis-relevant code paths. SQA plan does not address turbulence-model plug-in validation, leaving a gap at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests using manufactured solutions must confirm solver convergence rates for velocity and scalar hemolysis transport equations.",
      "rationale": "Manufactured-solution tests confirm second-order convergence for momentum equations; however, the scalar hemolysis transport equation shows only first-order convergence, falling one gradation below the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be reported for hemolysis index QoI on at least three systematically refined meshes.",
      "rationale": "GCI is reported on three meshes for pressure and velocity QoIs; hemolysis index GCI is reported only on two mesh levels, preventing a fully reliable extrapolated estimate and leaving the factor one level below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid viscosity, hematocrit, temperature, inlet waveform) must match VAD operating conditions within stated uncertainty bounds.",
      "rationale": "FDA pump experiments used bovine blood at 37°C matching VAD fluid properties; however, inlet flow waveform in bench tests is steady-state, whereas clinical VAD operation involves pulsatile inflow, introducing a systematic mismatch."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalised RMS error) between predicted and measured hemolysis index must be reported with uncertainty intervals.",
      "rationale": "Normalised RMS error is reported for pressure-flow curves but only qualitative agreement is shown for hemolysis index. Absence of uncertainty-weighted quantitative hemolysis comparison prevents achieving the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress exposure) must directly correspond to the clinical decision metric (absolute hemolysis below threshold).",
      "rationale": "Hemolysis index is the primary QoI and maps directly to the clinical threshold; however, the power-law hemolysis model parameters were calibrated on a different pump geometry, introducing an unquantified model-form contribution to QoI relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at rotational speeds and flow rates spanning the full VAD operating envelope specified in the COU.",
      "rationale": "Validation covers 4 of 5 target flow-speed combinations; the highest-speed, lowest-flow operating point (highest hemolysis risk) was not experimentally tested due to pump cavitation constraints in the bench setup."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and floating-point round-off analysis must be documented for all hemolysis simulation runs.",
      "rationale": "Solver residual logs were not archived for the production hemolysis runs; only summary convergence flags are available. This epistemic gap is flagged as unresolved at MRL 5."
    },
