      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification records and simulation execution checklists must demonstrate controlled, repeatable model setup procedures.",
      "rationale": "No formal user qualification or execution checklist programme was in place during the simulation campaign. Use error is an unresolved epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing alternative turbulence and hemolysis constitutive models must bound model-form uncertainty for absolute hemolysis predictions.",
      "rationale": "Only the standard k-ω SST turbulence model and the Giersiepen power-law hemolysis model were used. No alternative model-form comparison was performed; model-form uncertainty is unquantified and flagged as a critical epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain model inputs (blood viscosity, hematocrit, power-law exponents) must be characterised and propagated via Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was initiated but input distributions for power-law hemolysis model coefficients (α, β) were drawn from a single literature source without inter-laboratory variability. Full input characterisation is incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification and batch-to-batch variability data for bovine blood used in bench experiments must be documented.",
      "rationale": "Experimental hemolysis measurements were performed on a single blood batch from one animal. Inter-batch and inter-species variability are uncharacterised, constituting an epistemic gap at MRL 5."
