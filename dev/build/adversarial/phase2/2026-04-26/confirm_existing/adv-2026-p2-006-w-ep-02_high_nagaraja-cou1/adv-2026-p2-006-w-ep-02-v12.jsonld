  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software under documented quality management system with version control and regression testing.",
      "rationale": "All three FEA implementations (FDA, Ansys Mechanical 2022 R2, DePuy Synthes proprietary v4.1) operate under ISO 9001-compliant QMS with documented version control. Ansys Mechanical carries ASME NQA-1 software qualification documentation. FDA solver is subject to federal software quality oversight. Regression test suites executed prior to each analysis run; no anomalies reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions solved to within 1% error for linear elastic problems.",
      "rationale": "Each FEA implementation verified against NAFEMS benchmark suite LE1 and LE10. Maximum error in benchmark stress predictions was 0.7%. Patch test passed for all element types used (C3D8R, C3D10). Code verification results documented in standalone verification report archived with submission package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence demonstrated with <5% change in QoI between successive refinements.",
      "rationale": "Three-level mesh refinement study performed on the screw-rod-block assembly. Global element size reduced from 2.0 mm to 1.0 mm to 0.5 mm. QoI (stiffness, yield force, force at 40 mm) changed by <2.1% between the medium and fine meshes. Richardson extrapolation applied; GCI < 3% for all QoIs. Final production mesh uses 1.0 mm global size with 0.25 mm local refinement at screw-rod interface."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals below 1e-6 for all load steps; energy balance error below 0.1%.",
      "rationale": "Implicit nonlinear solver used with full Newton-Raphson iteration. Force residual norm converged to below 1e-8 for all load increments. Energy balance monitored throughout; maximum artificial energy fraction 0.04%, well below 1% threshold. No divergence or unconverged increments in any of the 11 specimen simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst; checklist-based verification of boundary conditions and material assignments.",
      "rationale": "Model setup reviewed independently by a second senior analyst using a 47-item checklist covering geometry import, material property assignment, contact definitions, boundary condition application, and load application. All checklist items confirmed. One minor discrepancy in friction coefficient assignment identified and corrected prior to production runs. No use errors remained at time of final analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics formulation with nonlinear geometry and contact is appropriate for pedicle screw construct under large-displacement bending.",
      "rationale": "Three-dimensional continuum FEA with large-deformation kinematics (NLGEOM on) and surface-to-surface contact between screw shaft and polyaxial head, and between rod and tulip. Titanium alloy modeled as bilinear isotropic hardening (Ti-6Al-4V: E=114 GPa, σ_y=880 MPa, E_t=1.8 GPa). UHMWPE blocks modeled as elastic-perfectly plastic. Model form appropriate for the quasi-static compression-bending regime of F1717; dynamic effects negligible at 25 mm/min."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from traceable measurements with documented uncertainty.",
      "rationale": "Ti-6Al-4V material properties derived from coupon tensile tests (n=5) per ASTM E8. UHMWPE properties from supplier datasheet with independent verification by compression testing (n=3). Screw and rod geometry from CMM measurements of production hardware (tolerance ±0.01 mm). UHMWPE block dimensions measured per F1717 fixture specification. All input uncertainties propagated to QoI uncertainty via Monte Carlo (n=1000 samples)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens representative of production hardware; lot traceability documented.",
      "rationale": "N=11 test constructs assembled from production-representative hardware (same lot as intended commercial product). Screw dimensions verified by CMM prior to testing; all within drawing tolerance. Rod straightness verified by optical profilometry. UHMWPE blocks from same material lot; density and hardness confirmed within specification. Inter-laboratory sample allocation: Lab 1 n=6, Lab 2 n=5, randomized by specimen serial number."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of anticipated clinical loading scenarios.",
      "rationale": "Testing conducted at a single load configuration (compression-bending per F1717 fixture geometry, 5° convergence angle). Clinical loading includes torsion, lateral bending, and axial compression in addition to compression-bending; these modes were not tested. This factor is intentionally below required level and is the identified gap in the credibility assessment. Accepted on the basis that compression-bending is the most critical failure mode per literature and that supplementary analysis (not formal V&V) addresses torsion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs match experimental specimen parameters within measurement uncertainty.",
      "rationale": "Each of the 11 FEA specimen models was individualized using CMM-measured geometry for that specific specimen. Material properties assigned from coupon test results for the same hardware lot. UHMWPE block dimensions from direct measurement of each test block. Friction coefficients at screw-rod interface estimated from tribology literature (μ=0.15±0.05) and sensitivity study confirmed QoI insensitivity (< 1.2% change over ±0.05 range). Input equivalency confirmed for all 11 specimen pairs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all QoIs; percentage difference < 10%.",
      "rationale": "E/uval computed per ASME V&V 40 Eq. 5.3.1 for each QoI and each specimen. All values below 1.96 (range: 0.31–1.74). Percentage differences: stiffness 4.2% mean, yield force 6.8% mean, force at 40 mm 7.1% mean. Comparison plots (predicted vs. measured with uncertainty bands) included in supplementary figures. No systematic bias detected; residuals normally distributed (Shapiro-Wilk p > 0.05)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly correspond to QoIs used in the regulatory submission claim.",
      "rationale": "The three QoIs validated (construct stiffness, yield force, force at 40 mm displacement) are identical to those specified in the COU intended use statement and in the 510(k) substantial equivalence argument. No surrogate QoIs used. The acceptance bounds (<10% difference, E/uval < 1.96) were pre-specified in the validation plan prior to data collection, preventing post-hoc criterion adjustment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario matches COU geometry, loading, and material system.",
      "rationale": "Validation testing performed on the exact device geometry and material system described in the COU (non-cannulated 7.5 mm pedicle screw, Ti-6Al-4V, ASTM F1717 fixture). Loading mode (compression-bending) is the primary regulatory test for pedicle screw constructs. Two-laboratory design increases generalizability of validation evidence. The validation scenario is judged highly relevant to the COU with the noted limitation that only one loading mode was tested (addressed under Test conditions factor)."
    }
