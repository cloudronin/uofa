  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions achieving level 2 against a required level of 3 — reflects the ASTM F1717 protocol constraint to a single quasi-static loading rate and is accepted given the regulatory context and the conservative nature of the quasi-static loading assumption. All three QoIs satisfy the pre-specified acceptance bounds (E/uval < 1.96; percentage difference < 10%) across N=11 constructs from two independent laboratories. The overall credibility evidence is sufficient to support a Medium assurance level conclusion for this Class II device COU.",
