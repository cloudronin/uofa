  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required gradation levels. One factor (Test conditions) achieves Gradation 2 against a required Gradation 3, attributable to the single-condition constraint of ASTM F1717; this gap is accepted because the standard specifies a single quasi-static loading rate representative of clinical implantation loads and no multi-rate clinical evidence exists to justify deviation. All three QoIs pass the pre-specified E/uval < 1.96 acceptance criterion with margin. The overall credibility evidence is sufficient to support a Medium assurance level for the non-cannulated 7.5 mm pedicle screw FEA framework.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
