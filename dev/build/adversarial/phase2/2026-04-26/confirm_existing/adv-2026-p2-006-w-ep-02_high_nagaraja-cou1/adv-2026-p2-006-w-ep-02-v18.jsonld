  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "All three FEA codes used in the ensemble (FDA in-house, Ansys Mechanical 2022R2, DePuy Synthes solver) operate under documented software quality management systems. Ansys and DePuy Synthes solvers hold ISO 9001 certification; the FDA in-house code is maintained under CDRH SQA procedures. Version control, change logs, and regression test suites are documented. Required level 2 (basic SQA documentation) is exceeded by achieved level 3 (formal SQA with regression testing)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Code verification was performed through comparison against analytic solutions for beam bending, contact patch problems, and nonlinear material benchmarks from the NAFEMS suite. All three solvers reproduced analytic solutions within 0.5% for linear cases and within 2% for nonlinear benchmarks. Ensemble agreement across three independent codes provides additional confidence in code correctness."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed on the pedicle screw shank and rod-screw interface using three mesh densities (coarse: 0.8 mm global, medium: 0.4 mm, fine: 0.2 mm at critical features). Richardson extrapolation yielded a grid convergence index (GCI) of 1.3% for stiffness and 2.1% for yield force. Final mesh uses 0.3 mm elements at the screw-rod interface and 0.6 mm elsewhere. Discretization error is included in the validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative convergence was monitored via force and displacement residuals (tolerance 1e-6). All load steps converged within 15 iterations. Direct solver cross-check performed for two representative load cases confirmed iterative solver results within 0.1%. Solver error is considered negligible relative to model input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup and boundary condition application were independently reviewed by a second analyst at each participating organization. Boundary conditions replicate ASTM F1717 fixture geometry: fixed inferior vertebral body block, applied displacement at superior block, lateral constraint per standard. Independent review checklist documented and archived. No discrepancies identified between analyst and reviewer interpretations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Continuum mechanics with nonlinear geometry (large displacement) and bilinear isotropic hardening plasticity for Ti-6Al-4V. Contact modeled with augmented Lagrangian formulation at screw-rod and screw-block interfaces. Model form is well-established for metallic implant constructs and is consistent with FDA guidance on FEA for orthopedic devices. Ensemble of three independent implementations reduces model form uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (elastic modulus, yield strength, tangent modulus) sourced from coupon testing of the same Ti-6Al-4V lot used for test specimens. UHMWPE block properties from supplier datasheet with ±8% uncertainty. Friction coefficient for Ti-Ti contact estimated from published literature (0.2–0.35) and treated as a uniformly distributed uncertain parameter. Geometric inputs derived from CMM measurements of actual test specimens."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested. All specimens from the same manufacturing lot, meeting dimensional acceptance per ASTM F1717. Specimens distributed across two independent laboratories (Lab A: n=6, Lab B: n=5) to assess inter-laboratory variability. CMM measurements confirm dimensional conformance. Sample size consistent with ASTM F1717 requirements and FDA guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing conducted under a single static loading condition (monotonic displacement-controlled compression-bending per ASTM F1717). Cyclic fatigue and dynamic loading conditions were not assessed. The single test condition is a recognized limitation; however, the COU is limited to static compression-bending prediction and the acceptance criterion accounts for this scope. Required level 3 is not achieved; this factor is below required level and is flagged as a gap in the overall credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model inputs were mapped directly to measured specimen properties: geometry from CMM data, material properties from lot-specific coupon tests, fixture geometry from calibrated test machine drawings. Boundary conditions replicate the ASTM F1717 fixture constraints. Equivalency review documented in test-analysis correlation matrix (TACM-2023-0041). No unresolved discrepancies between test and model input parameters."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Three QoIs compared: construct stiffness, yield force, and force at 40 mm displacement. Validation metric E/uval computed for each QoI. All three QoIs satisfy E/uval < 1.96 and percent difference < 10%. Comparison includes uncertainty quantification for both experimental measurements and model predictions. Results presented in tabular and graphical form in validation report VR-2023-0041."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The three QoIs (stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 and are the regulatory submission endpoints for static compression-bending performance. They are clinically relevant surrogates for construct integrity under physiological loading. QoI selection was reviewed and accepted by the FDA project team prior to study initiation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities directly replicate the COU: ASTM F1717 static compression-bending of the non-cannulated 7.5 mm pedicle screw construct. The same screw design, rod diameter, and UHMWPE block geometry are used in both the validation experiments and the intended regulatory submission. The validation domain is congruent with the COU domain. No extrapolation beyond the validated envelope is required for the regulatory decision."
    }
