  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical and in-house FEA code must hold current ISO 9001 and FDA 21 CFR Part 820 software validation documentation.",
      "rationale": "All three FEA codes (FDA, Ansys, DePuy Synthes) carry current software validation certificates. Ansys Mechanical 2022 R2 validated per SVVP-2022-003. In-house FDA code validated per IQ/OQ/PQ protocol SQA-FDA-2021-11. DePuy Synthes code validated per DS-SQA-2022-07. No open defects affecting compression-bending simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification against analytical solutions and benchmark problems must demonstrate < 1% error for linear elastic beam bending and contact patch problems.",
      "rationale": "Each FEA code verified against NAFEMS benchmarks LE1 and LE10. Maximum error across all three codes was 0.6% for linear elastic cantilever bending and 0.9% for Hertzian contact. Verification reports NCV-2022-001 through NCV-2022-003 on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) < 1% for all QoIs at the production mesh density.",
      "rationale": "Mesh convergence study performed with three mesh densities (coarse 142k, medium 312k, fine 487k elements). Richardson extrapolation yielded GCI of 0.78% for stiffness, 0.65% for yield force, and 0.81% for force at 40 mm at the production mesh. All below 1% threshold. Production mesh set at 487k elements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge to < 1e-6 for all load steps; energy balance error < 0.1%.",
      "rationale": "All simulations used direct sparse solver (PARDISO) for linear steps and Newton-Raphson iteration with residual tolerance 1e-7 for nonlinear contact steps. Energy balance errors < 0.05% confirmed in all 11 replicate simulations. No unconverged load steps."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by analyst not involved in original build; documented checklist sign-off.",
      "rationale": "Model setup independently reviewed by a senior FEA analyst per checklist USE-CHK-2023-01. Boundary conditions, material assignments, contact definitions, and load application all verified. No discrepancies found. Review documented in peer review record PR-2023-044."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear elastic model with frictional contact is appropriate for titanium pedicle screw under quasi-static ASTM F1717 loading below yield; bilinear isotropic hardening invoked post-yield.",
      "rationale": "Linear elastic model with bilinear isotropic hardening (tangent modulus 1.1 GPa) used for titanium alloy Ti-6Al-4V ELI. Frictional contact (mu=0.3) between screw and polyethylene block per ASTM F1717. Model form validated against published literature and prior FDA submissions. Appropriate for quasi-static loading regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from lot-matched coupon testing; geometric inputs from calibrated CMM measurements of production screws.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and UTS (950 MPa) from 5 tensile coupons cut from the same Ti-6Al-4V ELI bar stock as production screws (COC lot 2022-TiELI-007). Screw geometry from CMM measurements (n=3 screws per lot, tolerance ±0.01 mm). UHMWPE block properties from supplier datasheet confirmed by 3-point bend testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 test specimens from production-representative lots; specimens traceable to manufacturing records.",
      "rationale": "N=11 constructs assembled from production-representative 7.5 mm non-cannulated pedicle screws (lot 2022-PS-NC-001) and UHMWPE test blocks (lot 2022-PE-F1717-002). All specimens traceable to manufacturing and inspection records. Six specimens tested at Lab 1 (FDA), five at Lab 2 (DePuy Synthes). Sample size exceeds minimum threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate COU loading environment including at minimum two loading rates and both ambient and physiological temperature conditions.",
      "rationale": "Testing performed only at a single quasi-static loading rate (5 mm/min) and ambient temperature (23°C ± 2°C). Physiological temperature (37°C) and alternative loading rates were not evaluated. This represents a gap relative to the required level; the shortfall is acknowledged and accepted given the conservative nature of ambient testing for titanium constructs, but achievedLevel is set to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) must be demonstrably equivalent to physical test specimen parameters within stated tolerances.",
      "rationale": "FEA geometry updated from CMM measurements of each test specimen individually (n=11 models). Material properties from lot-matched coupons applied uniformly. Fixture geometry modeled from engineering drawings of ASTM F1717 fixtures with CMM verification. Boundary condition equivalency documented in report EQP-2023-002."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percentage difference < 10% for all three QoIs; statistical analysis per ASME V&V 40-2018 Appendix D.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy both acceptance criteria. E/uval values: 0.41, 0.68, 0.22 respectively. Percentage differences: 1.7%, 2.0%, 0.7% respectively. Full statistical analysis documented in report OC-2023-007 following ASME V&V 40-2018 Appendix D methodology."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must directly correspond to clinically and mechanically meaningful failure modes and design acceptance criteria for pedicle screw constructs.",
      "rationale": "Construct stiffness governs load sharing with the spine; yield force predicts onset of permanent deformation; force at 40 mm displacement is the ASTM F1717 standard acceptance metric. All three QoIs are directly cited in the 510(k) predicate device testing and FDA guidance for spinal implants. Relevance is well-established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (geometry, loading, boundary conditions, material) must be representative of the COU; any differences must be bounded and justified.",
      "rationale": "Validation scenario directly replicates the COU: same screw design, same ASTM F1717 test configuration, same loading mode (compression-bending), same material lot. The only difference from clinical use is the in vitro test block versus in vivo bone; this is inherent to the ASTM F1717 standard and is the accepted regulatory surrogate. Relevance is high."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-solid-mechanics",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework meets or exceeds the required credibility level for 12 of 13 V&V 40 factors. The single shortfall in Test conditions (achievedLevel 2 vs. requiredLevel 3) is accepted given the conservative nature of ambient-temperature testing for titanium alloy constructs and the strong quantitative agreement across all three QoIs (maximum E/uval 0.68, maximum percentage difference 2.0%). The overall evidence package provides sufficient credibility to support the intended regulatory submission for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
