  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed their required credibility level. The single deficiency — Test conditions assessed at Gradation 2 against a required Gradation 3 — is accepted because the ASTM F1717 single-condition protocol is the regulatory reference standard and the model is not applied outside that condition. All three primary QoIs satisfy both the <10% relative difference criterion and the E/uval < 1.96 threshold. The FEA ensemble demonstrates sufficient credibility to support a Medium assurance level acceptance decision for the non-cannulated 7.5 mm pedicle screw compression-bending COU.",
