  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software used in regulatory submissions must meet at minimum Gradation 2 SQA (documented version control, regression test suite, change management). Gradation 3 requires additionally independent code review and formal anomaly reporting.",
      "rationale": "Ansys Mechanical 2022 R2 and the FDA in-house FEA solver are both subject to formal SQA programs including ISO 9001-compliant change control, automated regression testing against benchmark problems, and documented anomaly tracking. DePuy Synthes employs an IEC 62304-aligned SQA process for its simulation tools. All three solvers exceed the Gradation 2 threshold; independent code audit records for the FDA solver elevate the ensemble to Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations through benchmark comparisons to analytical solutions or accepted reference solutions for at least the element types and material models used in the COU model.",
      "rationale": "Each solver was verified against NAFEMS benchmark LE1 (plane stress plate), LE10 (thick cylinder), and a three-point bending beam with known closed-form solution. All results agreed within 0.5% of analytical values. Contact element verification used a Hertzian contact benchmark. These benchmarks cover the linear elastic solid and contact formulations central to the pedicle screw model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required demonstrating that the QoIs change by less than 5% between successive refinement levels, or Richardson extrapolation applied with reported GCI.",
      "rationale": "A three-level mesh refinement study (coarse 0.8 mm, medium 0.5 mm, fine 0.3 mm global edge length at screw root) was performed. Stiffness QoI changed by 3.1% coarse-to-medium and 0.6% medium-to-fine. Yield force changed by 2.4% and 0.4% respectively. Richardson extrapolation yielded GCI < 1.2% for all QoIs on the fine mesh. The production mesh uses the fine discretization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence tolerances must be documented and shown to produce QoI insensitivity. Force residual norm below 1×10⁻⁴ required.",
      "rationale": "All analyses used a direct sparse solver (PARDISO) for the linear steps and a Newton-Raphson scheme with force residual tolerance 1×10⁻⁵ for nonlinear contact iterations. Solver logs were archived. A tolerance sensitivity study (1×10⁻⁴ vs 1×10⁻⁵) showed QoI differences below 0.1%, confirming solver error is negligible relative to other uncertainty sources."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation execution must follow a documented analysis plan reviewed by an independent analyst. Boundary conditions, load application, and post-processing scripts must be version-controlled.",
      "rationale": "Analysis plan NCA-AP-001 Rev C was peer-reviewed by an analyst not involved in model construction. Boundary condition scripts, load ramp definitions, and post-processing macros are stored in a Git repository with tagged releases corresponding to each submission. An independent re-run of the stiffness analysis by a second analyst produced results within 0.2% of the primary run."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be appropriate for the physical phenomena of interest (elastic-plastic deformation of Ti-6Al-4V, screw-rod and screw-block contact under large displacement bending). Justification by comparison to literature and sensitivity analysis required.",
      "rationale": "A bilinear isotropic hardening model (E=114 GPa, σ_y=880 MPa, E_t=2.1 GPa) was fit to n=8 Ti-6Al-4V coupon tests. Augmented Lagrangian contact with friction coefficient μ=0.2 (literature-supported for Ti-Ti interfaces) was used. Model form sensitivity: replacing bilinear hardening with a Ramberg-Osgood fit changed yield force by 0.9%. The chosen model form is well-established for this material and loading regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measurements on the actual test articles. Uncertainty in inputs must be propagated to QoI uncertainty.",
      "rationale": "Material coupons were machined from the same Ti-6Al-4V bar stock as the test screws. CMM measurements of screw root diameter, thread pitch, and rod diameter were used to define nominal geometry with ±0.05 mm tolerances. A Monte Carlo propagation (n=1000 samples) of geometric and material input uncertainty contributed ±1.4% to stiffness QoI uncertainty, incorporated in the E/uval calculation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test articles must be representative production parts from the same manufacturing lot as the intended device, with dimensional inspection records. N≥10 specimens required for statistical comparison.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screws from production lot NCL-2022-047 were tested (6 at Lab 1, 5 at Lab 2). Dimensional inspection confirmed all screws within drawing tolerances. Certificate of conformance and material certification were archived. The sample size of N=11 supports the two-sided t-test used in the E/uval metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of conditions represented in the COU, or a justified single condition must be shown to be the critical bounding case. Multiple load levels or fixture configurations preferred.",
      "rationale": "Testing was performed at a single load configuration (5° offset, standard ASTM F1717 fixture, quasi-static 1 mm/min crosshead speed). While this represents the standard regulatory test condition, no alternative fixture angles or load rates were evaluated. This single test condition is assessed as Gradation 2; the required level of 3 is not achieved. The deficiency is accepted because the ASTM F1717 protocol is the regulatory reference condition and the model is not extrapolated beyond it."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading must demonstrably replicate the experimental setup. Fixture compliance, load introduction eccentricity, and grip conditions must be addressed.",
      "rationale": "The ASTM F1717 fixture was modeled explicitly including the UHMWPE vertebral body surrogate blocks (modulus 1.1 GPa, Poisson 0.46) and titanium loading arms. Fixture compliance was measured on the test machine (1.3 N/mm) and incorporated as a linear spring in the FEA. Load application point and eccentricity matched the fixture drawings to within 0.1 mm. Grip friction was modeled with μ=0.15 based on fixture material pairing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI comparison must use a quantitative metric that accounts for both model prediction error and combined experimental-numerical uncertainty. E/uval < 1.96 required for all primary QoIs.",
      "rationale": "Three QoIs compared: construct stiffness (E/uval=0.41), yield force (E/uval=0.53), and force at 40 mm displacement (E/uval=0.29). All three satisfy E/uval < 1.96. Combined uncertainty uval incorporates experimental repeatability (pooled SD across N=11), measurement system uncertainty, and FEA numerical uncertainty (mesh, solver, input propagation). Relative differences of 2.3%, 1.8%, and 0.7% all satisfy the <10% bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoIs must be directly linked to the clinical risk and the COU decision. Construct stiffness and failure-related forces must be shown to be the governing mechanical performance indicators.",
      "rationale": "Construct stiffness governs load sharing with the biological fusion mass; yield force is the primary safety metric for avoiding intraoperative fracture; force at 40 mm displacement characterizes post-yield energy absorption relevant to fatigue loading initiation. All three QoIs map directly to the clinical risk of screw fracture leading to revision surgery, consistent with the Medium decision consequence assigned in the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (geometry, material, loading, scale) must be the same as or demonstrably bounding relative to the intended COU scenario.",
      "rationale": "The validation uses production non-cannulated 7.5 mm screws under the regulatory ASTM F1717 compression-bending protocol, which is identical to the COU scenario. No geometric scaling, surrogate materials, or surrogate loading modes are involved. The FEA model validated here is the same model instance that will be used for the COU prediction, with no parameter changes between validation and application runs."
    }
  ],
