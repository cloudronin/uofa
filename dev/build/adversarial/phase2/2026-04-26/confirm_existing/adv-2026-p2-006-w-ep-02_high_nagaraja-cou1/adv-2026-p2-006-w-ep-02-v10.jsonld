  "signature": "ed25519:9b2e4f1a7c3d6e8b5a2f4c7d1e3b6a9f2c5e8d1b4a7f3c6e9d2b5a8f1c4e7d3b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) must be validated against benchmark problems and version-controlled; FDA-recognised QMS procedures must govern solver deployment.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under an ISO 9001-compliant QMS at DePuy Synthes. Software validation records including NAFEMS benchmark comparisons are maintained in the product lifecycle management system. Version control and change-control procedures are documented. Achieved level 3 exceeds the required level 2 for a Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA code must be verified against analytical solutions or published benchmarks for structural problems representative of the COU geometry and loading.",
      "rationale": "Ansys Mechanical code verification was performed using NAFEMS LE1, LE10, and NL1 benchmarks for linear and nonlinear structural analysis. Results agreed with reference solutions within 0.3%. Additional in-house beam-bending and contact patch benchmarks were executed and archived. Achieved level 3 satisfies the requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence must be demonstrated for all QoIs using at least three mesh densities; discretization error must be quantified and shown to be below 1% for primary QoIs.",
      "rationale": "Mesh convergence study performed on three mesh densities (coarse ~120k, medium ~420k, fine ~1.1M second-order tetrahedral elements). Richardson extrapolation yielded discretization errors of 0.4% for stiffness, 0.7% for yield force, and 0.6% for force at 40 mm. The production mesh (420k elements) was selected based on the convergence plateau. Grid convergence index values were all below 0.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must be monitored and shown to converge below 1e-6 for all load steps; contact stabilisation energy must be below 1% of total strain energy.",
      "rationale": "Nonlinear solver (sparse direct with Newton-Raphson) residuals converged to below 1e-7 for all 120 load increments. Contact stabilisation energy was 0.3% of total strain energy across all constructs. No divergence or convergence warnings were recorded in any of the 11 model instances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs, boundary conditions, and post-processing scripts must be reviewed by an independent analyst; a documented simulation plan must precede execution.",
      "rationale": "A simulation plan was approved prior to model execution. An independent senior FEA analyst reviewed boundary condition assignments, material property inputs, and post-processing scripts. Review comments were resolved and documented in the project record. No use errors were identified during independent review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The continuum mechanics formulation must be appropriate for the loading regime; contact and large-deformation effects must be explicitly justified or shown to be negligible.",
      "rationale": "A nonlinear quasi-static structural formulation with large-deformation kinematics (NLGEOM ON) and frictional contact (μ = 0.3, augmented Lagrange) was used. The choice of isotropic linear-elastic material for the Ti-6Al-4V rod and screw shanks was justified by the fact that all QoIs are evaluated at or below the 0.2% offset yield point. Polyethylene UHMW spacer blocks were modelled with a bilinear isotropic hardening plasticity model calibrated from coupon test data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measurements or certified material specifications; uncertainty in key inputs must be characterised.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa, CV 1.8%) and yield strength (880 MPa, CV 2.1%) were sourced from mill certificates for the specific lot used in testing. Screw and rod geometry were measured on a coordinate measuring machine (CMM) with traceable calibration. UHMW-PE properties were characterised by uniaxial tensile coupon testing (n=5). Input uncertainty was propagated via Monte Carlo sampling (n=1000) to quantify QoI sensitivity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be representative of the device design intent; sample size must be sufficient to characterise experimental variability; traceability to production geometry must be established.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production-representative components. CMM measurements confirmed all critical dimensions were within engineering tolerances. Constructs were divided between two independent laboratories (n=6, n=5) to assess inter-laboratory variability. Experimental coefficient of variation for stiffness was 3.2%, confirming adequate reproducibility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate the loading environment specified in ASTM F1717; multiple load levels or configurations should be tested to characterise model behaviour across the COU envelope.",
      "rationale": "Testing was conducted strictly per ASTM F1717 at a single compression-bending load angle (5°) and a single displacement rate (25 mm/min). Only one test condition was evaluated; the COU envelope includes additional load angles relevant to in vivo use. This factor is below the required level 3 and represents a known gap. The shortfall is accepted at Medium assurance level given that the single condition is the most clinically relevant and the E/uval criterion is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental conditions; any differences must be quantified and their effect on QoIs assessed.",
      "rationale": "Fixture compliance was measured experimentally (0.12 mm/kN) and incorporated into the FEA boundary conditions. Material property inputs were derived from the same lot as test specimens. Construct assembly torque was applied as a pre-stress step in the simulation matching the experimental assembly procedure (4 Nm). No unresolved input parameter discrepancies were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI comparisons must use pre-defined acceptance criteria (percentage difference and E/uval); comparison must account for both simulation and experimental uncertainty.",
      "rationale": "Three QoIs were compared: construct stiffness, yield force, and force at 40 mm displacement. Pre-defined acceptance criteria (<10% mean difference, E/uval < 1.96) were established prior to data collection. Combined simulation and experimental uncertainties were propagated using the ASME V&V 20 framework. All three QoIs satisfied both criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to the clinical or regulatory decision; the mapping from simulation output to decision criterion must be explicit.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the regulatory submission acceptance criteria for ASTM F1717 pedicle screw testing. Each QoI maps directly to a failure mode relevant to the clinical decision: stiffness governs load transfer to bone, yield force governs fatigue life initiation, and force at 40 mm governs catastrophic failure risk. The mapping is documented in the design verification plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must match the COU in geometry, loading, boundary conditions, and material; any differences must be justified as conservative or inconsequential.",
      "rationale": "The validation activity directly replicates the COU: the same non-cannulated 7.5 mm pedicle screw design, the same ASTM F1717 test configuration, and the same FEA modelling framework used for the regulatory submission. The validation constructs are production-representative. The only difference is the single test condition (see Test conditions factor); this is accepted given the direct correspondence of all other parameters."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
