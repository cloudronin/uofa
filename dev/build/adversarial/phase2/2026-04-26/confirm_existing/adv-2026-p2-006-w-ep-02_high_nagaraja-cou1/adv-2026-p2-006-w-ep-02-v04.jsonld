    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic material model appropriate for pre-yield loading regime; contact formulation captures screw-rod interface behavior.",
      "rationale": "Ti-6Al-4V modeled as isotropic linear elastic (E=114 GPa, ν=0.34) consistent with ASTM F136 material specification. Loading regime remains predominantly elastic up to yield force QoI. Augmented Lagrange contact with friction (μ=0.22) captures load transfer at screw-rod interface. Model form uncertainty quantified via ensemble spread across three solver implementations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material test reports for production lot; geometric dimensions from CMM measurements of test specimens.",
      "rationale": "Elastic modulus and Poisson ratio sourced from certified material test reports (MTRs) for the specific Ti-6Al-4V production lot used in bench specimens. Screw and rod geometry digitized via CMM at 0.001 mm resolution. Torque preload on set screws measured with calibrated torque wrench and applied as equivalent pretension in FEA. Input uncertainty propagated via Latin hypercube sampling (n=200 runs)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production-representative lot; specimens characterized dimensionally and by hardness prior to testing.",
      "rationale": "N=11 constructs assembled from production-representative 7.5 mm non-cannulated pedicle screws and 5.5 mm titanium rods. All specimens dimensionally characterized by CMM; Rockwell hardness confirmed within ASTM F136 specification. Sample size exceeds minimum and provides sufficient statistical power for E/uval metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of loading rates and environmental conditions relevant to the COU; at minimum two distinct test conditions evaluated.",
      "rationale": "Testing conducted at a single displacement rate (25 mm/min) and ambient laboratory conditions only. ASTM F1717 specifies quasi-static loading; physiological temperature and fluid environment not replicated. This factor achieves level 2 against a required level of 3, representing the identified gap in the credibility assessment. The shortfall is accepted given that static compression-bending is the regulatory submission basis and the single condition is fully specified by the standard."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to physical test specimen and setup parameters.",
      "rationale": "One-to-one correspondence established between FEA inputs and measured specimen parameters. CMM geometry fed directly to CAD/FEA pipeline. Material properties from same lot MTRs. Fixture geometry (UHMWPE blocks, loading nose radius) replicated in FEA boundary conditions. Equivalency matrix documented and reviewed by independent analyst."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for all three QoIs; acceptance bounds pre-specified in validation plan prior to data collection.",
      "rationale": "Acceptance bounds (<10% QoI difference, E/uval <1.96) documented in the pre-registered validation plan (VP-COU1-v2.1, dated 2023-11-08) prior to any experimental data collection. E/uval computed for stiffness (0.41), yield force (0.58), and force at 40 mm (0.72). All three QoIs satisfy both criteria. Output comparison methodology follows ASME V&V 40-2018 Section 5.4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to regulatory submission metrics and clinical failure modes; linkage to COU documented.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in FDA guidance for pedicle screw 510(k) submissions. Each QoI links directly to a clinical failure mode: stiffness to load-sharing with bone, yield force to permanent deformation risk, force at 40 mm to fatigue crack initiation. Relevance traceability matrix included in submission package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
