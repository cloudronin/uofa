  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under formal version control with documented test suite results at Gradation 4.",
      "rationale": "SQA documentation exists but covers only basic unit tests. No formal regression suite or independent code review was performed. Achieved level falls short of MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured solution verification must be demonstrated for all governing equations used in the hemolysis model.",
      "rationale": "Code verification was performed only for the fluid solver. The hemolysis damage integral sub-model was not subject to manufactured solution testing, leaving a gap at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study must be performed on the hemolysis index QoI with at least three systematically refined meshes.",
      "rationale": "Three-mesh convergence study was completed for velocity and pressure fields. Hemolysis index convergence was demonstrated only on two meshes; Richardson extrapolation was not applied to the primary QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match VAD operating envelope including hematocrit, temperature, and anticoagulation state representative of clinical use.",
      "rationale": "Benchmark experiments used bovine blood at fixed hematocrit 35%. Clinical VAD conditions span hematocrit 25–45% with variable anticoagulation. Test condition coverage is partial."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics including normalized RMSE and confidence intervals must be reported for absolute hemolysis index predictions.",
      "rationale": "Qualitative agreement plots provided. Quantitative error metrics were computed only for relative hemolysis trends, not absolute index values required for Class III acceptance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoIs must directly map to the clinical hemolysis index used in the regulatory submission without intermediate transformation.",
      "rationale": "Simulation outputs are shear-stress-weighted exposure time integrated along pathlines. Mapping to plasma-free hemoglobin requires an empirical power-law conversion not itself validated at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on a geometry and flow regime that is representative of the specific VAD device geometry and patient operating range.",
      "rationale": "Validation was conducted on the FDA generic pump benchmark geometry. The actual VAD device geometry differs substantially in impeller blade count and volute design, reducing relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and floating-point round-off contributions to hemolysis index must be quantified and shown to be negligible relative to physical uncertainty.",
      "rationale": "Numerical solver error was not assessed. Residual convergence criteria were reported but no decomposition of solver error contribution to the hemolysis QoI was performed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documentation must demonstrate that simulation setup procedures are sufficiently constrained to prevent operator-induced variability from affecting hemolysis predictions.",
      "rationale": "No formal use-error analysis or inter-analyst reproducibility study was conducted. Setup procedures are described in a methods document but variability across analysts is uncharacterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the turbulence closure and hemolysis constitutive law must be quantified using multi-model ensembles or Bayesian model averaging.",
      "rationale": "A single turbulence model (SST k-omega) and a single hemolysis power-law were used. No model-form uncertainty quantification was performed. This is a critical gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain model inputs including blood viscosity, pump geometry tolerances, and inlet flow waveform must be propagated through the model via Monte Carlo.",
      "rationale": "Monte Carlo UQ was initiated but only three of nine uncertain input parameters were included in the propagation. Blood viscosity temperature dependence and geometric tolerances were excluded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be statistically sufficient in number and donor diversity to characterize inter-sample hemolysis variability.",
      "rationale": "Validation data originated from a single experimental campaign with one blood lot. Sample size and donor variability are insufficient to characterize biological uncertainty at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulations must be demonstrated to be equivalent to those used in the COU simulations within stated tolerances.",
      "rationale": "Equivalency of inlet boundary conditions between validation and COU simulations was not formally assessed. Pump speed and flow rate settings differ between the benchmark and VAD COU without documented justification."
    }
