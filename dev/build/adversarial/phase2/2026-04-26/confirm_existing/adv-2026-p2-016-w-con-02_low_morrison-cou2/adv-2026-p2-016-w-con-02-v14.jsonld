      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) with uncertainty bands reported; systematic bias characterised across all operating points.",
      "rationale": "Relative error computed for 4 of 5 conditions. Bias of +18% observed at low-flow conditions with no correction applied. Uncertainty bands not propagated through hemolysis power-law model. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
