  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must demonstrate version control, regression testing, and documented QA procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has basic version control but lacks formal regression test suite and independent code review required at MRL 5. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Verification against analytical solutions and method of manufactured solutions must be demonstrated for all relevant flow regimes including rotating machinery.",
      "rationale": "Code verification limited to simple pipe flow benchmarks. No method of manufactured solutions applied to rotating reference frame formulation used in centrifugal pump simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study must quantify spatial discretization error with GCI below 5% for hemolysis-relevant shear stress quantities.",
      "rationale": "Three-level grid convergence study performed; GCI for bulk flow quantities is 3.8%. However, near-blade shear stress GCI exceeds 12%, which is the primary driver of hemolysis prediction uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match VAD operating envelope including hematocrit, temperature, and anticoagulant protocol representative of clinical use.",
      "rationale": "FDA pump experiments conducted with bovine blood at fixed hematocrit 33%. Clinical VAD patients exhibit hematocrit range 25-45% with variable anticoagulation. Test condition representativeness is insufficient."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must be computed with uncertainty bounds for hemolysis index predictions against experimental measurements.",
      "rationale": "Hemolysis index predictions compared qualitatively to experimental trends. No formal validation metric computed. Quantitative agreement within factor of 3, but uncertainty bounds overlap experimental scatter."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be identical to the clinical decision QoI. Surrogate QoIs require demonstrated correlation with clinical outcomes.",
      "rationale": "Normalized index of hemolysis (NIH) used in validation matches regulatory submission QoI. However, mapping from CFD shear stress to NIH uses empirical power-law correlation with known limitations at high shear exposure times."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry and operating conditions sufficiently similar to the VAD COU to support extrapolation claims.",
      "rationale": "Validation performed on FDA generic pump geometry. Actual VAD geometry differs in impeller blade count and volute design. Geometric similarity argument is qualitative only; no sensitivity analysis on geometry differences performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver tolerance effects must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Solver error assessment not performed. Residual convergence criteria documented but no formal analysis of iterative error contribution to hemolysis QoI. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic review of analyst-introduced errors in model setup, boundary condition specification, and post-processing must be documented.",
      "rationale": "No formal use error assessment conducted. Single analyst performed all simulations without independent review of setup parameters. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for turbulence model selection and hemolysis constitutive model must include sensitivity analysis across plausible model form alternatives.",
      "rationale": "SST k-omega turbulence model selected without comparative evaluation against LES or RSM alternatives. Giersiepen-Wurzinger hemolysis model used without assessment of Bludszuweit or other competing formulations. Critical gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (viscosity, density, hemolysis model coefficients) must be characterized and propagated through Monte Carlo or equivalent method.",
      "rationale": "Monte Carlo UQ performed on boundary conditions only. Hemolysis model coefficients (power-law exponents) treated as deterministic despite known experimental variability of 20-40%. Input uncertainty assessment incomplete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size and variability of experimental hemolysis measurements must be sufficient to characterize population-level uncertainty in validation data.",
      "rationale": "Experimental dataset comprises n=3 pump specimens tested in triplicate. Statistical power insufficient to characterize inter-specimen variability at MRL 5. No sample size justification provided."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in simulation must be demonstrated equivalent to those characterizing the physical validation experiment, including fluid properties and geometric tolerances.",
      "rationale": "Geometric tolerances of FDA pump test article not reported in experimental reference. CFD geometry derived from nominal CAD; manufacturing variation not accounted for. Equivalency cannot be confirmed."
