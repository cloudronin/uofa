  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite and traceable build environment required at MRL 5.",
      "rationale": "Solver is version-controlled but regression suite covers only 40% of relevant flow regimes; build environment documentation is incomplete. Achieved level falls below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for all governing equations used in hemolysis prediction.",
      "rationale": "Order-of-accuracy demonstrated for Navier-Stokes equations only; the power-law hemolysis transport equation has not been subjected to manufactured-solution verification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all QoIs with GCI < 5% on the fine grid.",
      "rationale": "GCI computed on three systematically refined meshes; fine-grid GCI for hemolysis index is 8.3%, exceeding the 5% threshold. Discretization error is partially characterised but not fully controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match simulation inlet/outlet conditions within ±5% for flow rate and rotational speed.",
      "rationale": "Flow rate agreement is within 3% but rotational speed uncertainty in the experimental rig is ±8 RPM, introducing a boundary condition mismatch beyond the accepted tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel) reported with uncertainty bounds; systematic bias identified and explained.",
      "rationale": "Relative error in normalised index of hemolysis is 31% with no bias correction applied. Uncertainty bounds are reported but overlap with experimental scatter, masking systematic model form error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical decision endpoint (absolute hemolysis level) with sensitivity analysis confirming dominance.",
      "rationale": "Normalised index of hemolysis is used as surrogate QoI; sensitivity analysis not performed to confirm it is the dominant predictor of absolute hemolysis under VAD operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating points spanning the full VAD duty cycle; geometric similarity confirmed.",
      "rationale": "Validation performed at a single design-point flow rate; off-design and peak-demand operating points not covered. Geometric similarity confirmed for the FDA benchmark geometry only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; round-off and floating-point error bounds estimated for double-precision arithmetic.",
      "rationale": "Iterative residuals reported but convergence criteria not formally documented; floating-point error analysis absent. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and checklist-based simulation protocol documented and reviewed.",
      "rationale": "No user qualification records available; simulation protocol exists informally but has not been reviewed or approved. Epistemic gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive law selection justified by comparison with at least two alternative formulations.",
      "rationale": "Single turbulence model (SST k-ω) and single hemolysis power-law exponent set used without comparison to alternatives. Model form uncertainty not quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters; Monte Carlo propagation with N ≥ 1000 samples.",
      "rationale": "Monte Carlo uncertainty quantification initiated but input distributions for blood viscosity and hemolysis model constants are assumed uniform without literature justification. Sample size N=200 is insufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient for statistical characterisation of hemolysis variability; donor variability documented.",
      "rationale": "Experimental dataset uses pooled bovine blood from a single lot; donor-to-donor variability and lot-to-lot variability not characterised. Insufficient for statistical inference."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrated equivalent to experimental conditions via direct measurement or traceability chain.",
      "rationale": "Hematocrit and viscosity values used in simulation taken from nominal literature values rather than measured from the actual experimental blood sample. Equivalency not established."
    }
