  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal SQA plan with version control, issue tracking, and regression test suite covering hemolysis solver routines must be demonstrated.",
      "rationale": "SQA documentation exists but covers only general CFD solver; hemolysis-specific regression tests are absent. Achieved level 2 falls below required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must confirm order-of-accuracy for all governing equations including the hemolysis transport scalar.",
      "rationale": "MMS applied to Navier-Stokes equations only; hemolysis damage accumulation scalar not verified via MMS. Achieved level 2 insufficient for MRL 5 requirement of level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined grids with GCI reported for hemolysis index QoI.",
      "rationale": "Three-grid Richardson extrapolation performed; GCI for hemolysis index is 8.3%, exceeding the 5% target. Achieved level 3 below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match computational inlet/outlet conditions within stated uncertainty bounds; fluid rheology characterised at operating temperature.",
      "rationale": "Inlet velocity profiles interpolated from PIV data at a single flow rate; off-design conditions and temperature sensitivity not characterised. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms) between predicted and measured hemolysis index with uncertainty bands must be within acceptance threshold.",
      "rationale": "Predicted hemolysis index deviates from bench measurements by 31%; combined experimental and numerical uncertainty does not account for the gap. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized index of hemolysis, NIH) must be directly mapped to the clinical decision metric; sensitivity of NIH to model parameters documented.",
      "rationale": "NIH used as primary QoI with documented sensitivity analysis; however, mapping to patient-level clinical endpoints is qualitative only. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use blood-analogue fluid at physiological shear rates in a geometry representative of the target VAD pump; operating point coverage must span the clinical envelope.",
      "rationale": "Validation performed with glycerol-water analogue at a single operating point (6 L/min, 3000 RPM); clinical envelope spans 3–8 L/min and 2500–4500 RPM. Achieved level 2 far below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria, floating-point round-off analysis, and solver tolerance sensitivity study must be documented for the hemolysis scalar transport equation.",
      "rationale": "Solver error analysis not performed for the hemolysis scalar; flagged as epistemic gap at MRL 5. Achieved level 1 by default."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation execution checklist must be on file; independent re-run by a second analyst required at MRL 5.",
      "rationale": "No user qualification or independent re-run documented. Flagged as epistemic gap. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection must be justified with sensitivity studies; alternative model forms evaluated.",
      "rationale": "k-omega SST selected without comparative evaluation of alternative turbulence models; Giersiepen-Wurzinger power-law hemolysis model used without form-uncertainty quantification. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain inputs (viscosity, hematocrit, pump geometry tolerances) must be characterised and propagated via Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ performed for three inputs only; hematocrit variability and manufacturing tolerances not included. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At least three independently fabricated pump specimens tested across the clinical operating envelope; sample-to-sample variability reported.",
      "rationale": "Single pump specimen used for all bench tests; inter-specimen variability unknown. Flagged as epistemic gap. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional analysis confirming dynamic similarity between bench analogue fluid and blood at operating conditions; Womersley and Reynolds number matching documented.",
      "rationale": "Reynolds number matched at design point only; Womersley number and non-Newtonian similarity not addressed. Achieved level 2."
    }
