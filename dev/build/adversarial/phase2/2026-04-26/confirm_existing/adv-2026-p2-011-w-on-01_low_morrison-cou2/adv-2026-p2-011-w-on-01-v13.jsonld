  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/fda-pump-piv-velocity-fields"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA pump bench data"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation via PIV measurements"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035270",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e4b5d6789012345678901234567890abcdef1234567890abcdef123456",
  "signature": "ed25519:b7e2d4f6a1c3e5b7d9f1a3c5e7b9d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented SQA plan with version control, regression testing, and independent code review at Gradation 4.",
      "rationale": "Version control is in place and regression tests exist for canonical benchmark cases, but independent third-party code review has not been performed and the SQA plan lacks formal sign-off. Achieved level falls two gradations below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions and benchmark problems confirm solver correctness at Gradation 4.",
      "rationale": "Order-of-accuracy testing was performed on a 2-D Poiseuille flow manufactured solution and confirmed second-order convergence. However, no manufactured solution test has been executed on the rotating-frame hemolysis solver module, leaving the primary QoI pathway unverified at the required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined grids with GCI reported for all primary QoIs at Gradation 4.",
      "rationale": "Three-level grid refinement study was completed and GCI values computed for velocity magnitude. GCI for hemolysis index specifically was not reported; the coarsest grid showed non-monotonic convergence in the impeller tip region, reducing confidence in the extrapolated value."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are fully characterised and traceable to calibrated instrumentation with uncertainty budgets at Gradation 4.",
      "rationale": "Published FDA pump data provides nominal flow rate and rotational speed, but temperature, hematocrit, and blood viscosity were not reported with measurement uncertainty. Traceability to calibration records is absent, preventing full characterisation of boundary condition uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or u_val) computed with combined simulation and experimental uncertainty at Gradation 4.",
      "rationale": "Hemolysis index predictions are compared to experimental means but no combined uncertainty interval is constructed. The comparison is graphical; no validation metric with statistical confidence bounds is reported, placing the assessment at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical risk metrics (absolute hemolysis index) for Class III VAD at Gradation 5.",
      "rationale": "Hemolysis index is the primary QoI and is clinically relevant. However, sub-lethal shear stress thresholds and platelet activation indices, which are secondary risk metrics for Class III VAD, are not evaluated. The scope of QoI coverage is therefore partial."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate COU geometry, operating conditions, and fluid properties within stated tolerances at Gradation 5.",
      "rationale": "Validation uses the FDA generic pump geometry which is a simplified surrogate, not the actual VAD geometry. Operating pressure head and hematocrit differ from the intended COU envelope. The gap between validation scenario and intended deployment is large."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and residual histories archived for all production runs at Gradation 4.",
      "rationale": "Residual convergence histories were not archived for production runs. It is unknown whether the hemolysis scalar transport equation reached the required convergence tolerance. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification records and simulation execution checklists documented at Gradation 4.",
      "rationale": "No user qualification records or execution checklists are available. The risk of operator-induced input error in the rotating-frame boundary condition setup is unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty quantified via alternative constitutive law comparison and sensitivity analysis at Gradation 5.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is used without comparison to alternative formulations such as the Arora or Faghih-Sharp models. Model form uncertainty is acknowledged but not quantified, leaving a substantial gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full Monte Carlo UQ propagating all uncertain input parameters through the hemolysis model with reported confidence intervals at Gradation 5.",
      "rationale": "Monte Carlo UQ was performed propagating viscosity and power-law exponent uncertainty. However, rotor-stator interface clearance tolerance and blood temperature variation were excluded from the uncertainty space, leaving the input uncertainty characterisation incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification and inter-sample variability characterised for experimental hemolysis measurements at Gradation 4.",
      "rationale": "The number of experimental replicates used in the FDA dataset is not reported in the available literature. Inter-donor blood variability is not characterised. This factor cannot be assessed without access to raw experimental protocols."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between experimental and simulation input parameters formally documented with equivalency justification at Gradation 4.",
      "rationale": "No formal equivalency mapping document exists. Inlet velocity profile in simulation is assumed fully developed while experimental inlet conditions are uncharacterised. The equivalency of boundary conditions between test and simulation remains an open epistemic gap."
    }
  ],
