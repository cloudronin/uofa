  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis-relevant flow regimes; independent code review completed.",
      "rationale": "Solver is version-controlled and unit-tested, but independent third-party code review has not been performed and the test suite does not cover rotating-frame hemolysis regimes. Achieved level falls below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including the hemolysis transport scalar; order-of-accuracy confirmed.",
      "rationale": "MMS was applied to the Navier-Stokes solver but not to the hemolysis scalar transport equation. Observed order of accuracy matches theoretical for momentum but is unconfirmed for the QoI-driving scalar."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI on at least three systematically refined meshes; Richardson extrapolation reported.",
      "rationale": "Three mesh levels were run; GCI for the hemolysis index QoI is 18%, well above the 5% threshold. Richardson extrapolation shows monotonic convergence but the fine-grid solution is not in the asymptotic range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation to within measurement uncertainty; fluid rheology and temperature controlled and documented.",
      "rationale": "Inlet velocity profiles and outlet pressures are matched to published FDA pump experimental conditions. Blood analogue viscosity is documented; however, temperature variation during experiments is not reported, introducing unquantified rheological uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rel) for hemolysis index < 20% across all operating points; statistical comparison accounts for experimental scatter.",
      "rationale": "Mean relative error in hemolysis index is 34% across the five operating points tested. Simulation over-predicts hemolysis at high flow rates. No statistical uncertainty band is provided for the experimental reference values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoI (normalized index of hemolysis, NIH) directly maps to the clinical harm metric used in device labelling; traceability documented.",
      "rationale": "The simulation outputs NIH which is the regulatory QoI, but the mapping from CFD shear-stress history to NIH relies on a power-law model whose coefficients were calibrated on bovine blood, not human blood as required for the VAD indication."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed at rotational speeds and flow rates spanning the full VAD operating envelope; geometric similarity confirmed.",
      "rationale": "Validation data cover only two of the five intended VAD operating points. The highest-risk low-flow / high-speed regime, which produces the greatest hemolysis, has no experimental validation counterpart."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error quantified and shown to be negligible relative to discretization error; floating-point round-off analysis completed.",
      "rationale": "Iterative residuals are reported but no formal quantification of solver error relative to discretization error has been performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification process documented; simulation setup checklist verified by independent analyst; sensitivity to user-controlled parameters quantified.",
      "rationale": "No formal user qualification or independent setup review has been conducted. Sensitivity of hemolysis predictions to user-defined mesh topology choices is unquantified. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model form uncertainty quantified via ensemble of physically plausible model variants; hemolysis constitutive model uncertainty bounded.",
      "rationale": "A single k-omega SST turbulence closure and a single power-law hemolysis model are used. No model-form uncertainty analysis has been performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo or polynomial-chaos UQ propagates uncertainty in all material and geometric input parameters through to NIH QoI; Sobol indices identify dominant inputs.",
      "rationale": "Monte Carlo UQ was initiated but did not converge due to computational cost constraints. Input uncertainty in blood viscosity, hemolysis model exponents, and impeller clearance has not been fully propagated. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Inter-laboratory reproducibility of hemolysis measurements established across at least three independent test sites; sample-to-sample variability characterised.",
      "rationale": "All experimental hemolysis measurements originate from a single laboratory. Inter-laboratory reproducibility has not been established. Sample variability across blood lots is not reported. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment input parameters and intended COU input parameters documented; any surrogates or analogues justified quantitatively.",
      "rationale": "Validation experiments used a bovine blood analogue at 37°C; the intended COU involves human blood across a clinical temperature range. Equivalency of rheological and hemolytic properties has not been formally demonstrated. Flagged as epistemic gap."
    }
  ],
