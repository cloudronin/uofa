  "signature": "ed25519:9b1c3e5a7f2d4b6c8e0a2c4f6b8d0e2f4a6c8b0d2e4f6a8c0b2d4f6a8c0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a documented quality management system with traceability to MRL 5 requirements.",
      "rationale": "SQA documentation exists but covers only version control and basic unit testing; independent audit and formal V&V plan required at MRL 5 are absent. Achieved level falls two gradations below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured solution benchmarks must confirm solver correctness for the hemolysis transport equations.",
      "rationale": "Code verification was performed only for the incompressible Navier-Stokes solver; the hemolysis damage accumulation sub-model has not been subject to manufactured solution testing. Significant gap remains."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must quantify spatial and temporal discretization error with GCI below 5% for hemolysis index QoI.",
      "rationale": "Three-level grid convergence study performed; GCI for hemolysis index is 8.3%, exceeding the 5% threshold. Temporal refinement study not completed for pulsatile operating modes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including physiologic flow rates, hematocrit, and blood analog rheology at body temperature.",
      "rationale": "FDA generic pump experiments used saline-glycerol blood analog at room temperature. Physiologic hematocrit and temperature effects on hemolysis are not captured, creating a substantial condition mismatch at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric-based comparison (e.g., E_rel < 20%) between model predictions and experimental hemolysis index across all operating points.",
      "rationale": "Mean relative error is 34% across the six operating points tested. Systematic over-prediction at high flow rates suggests model form deficiency. Comparison does not meet the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the clinical hemolysis endpoints relevant to VAD patient safety.",
      "rationale": "Normalized index of hemolysis (NIH) is used as QoI; this aligns with ASTM F1841 but does not capture sub-lethal red cell damage accumulation relevant to chronic VAD use. Partial relevance acknowledged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the intended VAD clinical operating environment.",
      "rationale": "All validation activities used the FDA generic pump geometry rather than any patient-specific or production VAD geometry. Operating conditions diverge substantially from clinical COU. Large relevance gap identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off, and linearization errors must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Solver error assessment was scoped out of the current study phase. Residual convergence criteria are documented but no formal error budget separating solver error from discretization error has been constructed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-introduced error in model setup, boundary condition specification, and post-processing must be characterized and mitigated.",
      "rationale": "No formal use error assessment or inter-analyst reproducibility study has been conducted. Single analyst performed all simulations; sensitivity to meshing choices and BC interpretation is unquantified. Epistemic gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Assumptions embedded in the hemolysis power-law damage model and turbulence closure must be assessed for adequacy under VAD shear conditions.",
      "rationale": "Model form uncertainty for the Giersiepen-Wurzinger hemolysis correlation and k-omega SST turbulence model has not been formally assessed. Alternative model forms not evaluated. Critical gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity and uncertainty of model outputs to input parameters (viscosity, density, hemolysis model coefficients) must be quantified via UQ analysis.",
      "rationale": "Monte Carlo UQ was initiated but not completed due to computational resource constraints. Only nominal input values were used in all reported simulations. Input uncertainty propagation is absent. Epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize biological and measurement variability in hemolysis index; statistical power analysis required.",
      "rationale": "FDA pump experimental dataset contains n=3 replicates per operating point. No power analysis performed. Biological variability in blood analog preparation is uncharacterized. Insufficient for MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrably equivalent to those applicable in the clinical VAD deployment context.",
      "rationale": "No formal equivalency mapping between experimental and clinical input parameters has been established. Rheological properties, hematocrit levels, and pump geometry differ between validation and intended use contexts. Epistemic gap at MRL 5."
    }
  ],
