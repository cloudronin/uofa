      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests demonstrate convergence for governing equations used in hemolysis transport.",
      "rationale": "Order-of-accuracy verified for Navier-Stokes but not for the scalar hemolysis transport equation; gap remains."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent on three systematically refined meshes; GCI reported.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI reported at 8.3% for wall shear stress, exceeding the 5% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match CFD inlet/outlet conditions within stated uncertainty bands.",
      "rationale": "Inlet velocity profiles measured by PIV but outlet pressure boundary conditions deviate by up to 12% from experimental values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within ±15% of experimental measurements across all operating points.",
      "rationale": "Hemolysis index predictions deviate by 25–40% from experimental data at off-design flow rates; within range only at design point."
    },
    {
