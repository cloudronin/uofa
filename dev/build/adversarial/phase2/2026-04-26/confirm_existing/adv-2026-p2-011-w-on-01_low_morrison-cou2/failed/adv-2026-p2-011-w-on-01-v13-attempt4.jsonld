      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to clinical hemolysis index used in predicate device submissions.",
      "rationale": "Normalized index of hemolysis (NIH) is the primary QoI and aligns with FDA guidance; minor gap in sub-lethal damage accumulation metric."
    },
    {
