      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis transport; convergence order confirmed.",
      "rationale": "MMS applied to Navier-Stokes equations but not extended to the scalar hemolysis transport equation. Formal order of convergence unconfirmed for the coupled system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined grids; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three-level grid refinement study performed with GCI of 8.3% on hemolysis index. Discretization error is quantified but exceeds the 5% acceptance threshold for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with measurement uncertainty; inlet flow waveform and fluid rheology match intended operating range.",
      "rationale": "FDA pump experiments conducted at steady-state flow; pulsatile VAD operating conditions not replicated. Fluid used was bovine blood with rheology differing from human blood at physiological hematocrit."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rel < 20%) with uncertainty bounds overlapping experimental uncertainty bands for hemolysis index.",
      "rationale": "Mean relative error on hemolysis index is 34% across operating points. Predicted values fall outside experimental uncertainty bands at high flow rates. Quantitative metric computed but threshold not met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index directly maps to clinical endpoint; linkage between QoI and device safety claim documented.",
      "rationale": "Hemolysis index is the primary QoI and is clinically relevant, but the mapping between normalized index of hemolysis (NIH) and patient plasma free hemoglobin thresholds is not formally documented in the evidence package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, flow conditions, and fluid properties representative of the intended COU; similarity rationale documented.",
      "rationale": "Validation performed on FDA generic pump geometry rather than the specific VAD device geometry. Geometric and hydrodynamic similarity rationale is absent. Applicability of validation evidence to the target device is unsubstantiated."
