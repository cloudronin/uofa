      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match VAD operating envelope including flow rate, rotational speed, and hematocrit range; all boundary conditions must be documented with uncertainty.",
      "rationale": "Published FDA pump experiments conducted at limited operating points; hematocrit and temperature deviations from clinical VAD conditions not fully characterized."
    },
