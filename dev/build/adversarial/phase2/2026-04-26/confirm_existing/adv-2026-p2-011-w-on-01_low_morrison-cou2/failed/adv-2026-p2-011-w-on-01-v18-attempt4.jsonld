      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_val with confidence interval) must be computed for hemolysis index and pressure rise across all validation cases.",
