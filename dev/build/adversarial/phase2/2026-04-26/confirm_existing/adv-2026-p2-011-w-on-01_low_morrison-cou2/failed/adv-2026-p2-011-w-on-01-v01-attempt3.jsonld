      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan documented, version-controlled, and independently reviewed per MRL 5 requirements.",
      "rationale": "Version control and unit tests are present but no independent code review or formal SQA plan has been executed. Achieved level falls short of the required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions (MMS) verification completed for all governing equations.",
      "rationale": "Only basic benchmark comparisons were performed. MMS verification was not carried out for the hemolysis transport equation, leaving numerical correctness partially undemonstrated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI computed on at least three systematically refined meshes; GCI below 5% for all QoIs.",
      "rationale": "Three-level mesh refinement study was conducted and GCI reported, but the finest mesh GCI for shear-stress-derived hemolysis index exceeded 5%, indicating residual discretization uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match simulation inlet/outlet conditions within stated uncertainty bounds; fluid properties verified.",
      "rationale": "Inlet flow waveform and fluid viscosity were matched to published FDA pump test conditions, but inlet turbulence intensity and temperature were not characterised, reducing confidence in boundary condition fidelity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms or validation metric u_val) computed and compared against experimental uncertainty; metric passes acceptance threshold.",
      "rationale": "Predicted hemolysis index deviated from experimental measurements by 38% on average. No formal validation metric was computed; comparison was qualitative, falling well below MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinical hemolysis endpoints; traceability from model output to device risk established.",
      "rationale": "The hemolysis index (HI) is used as the primary QoI but its linkage to in-vivo plasma free haemoglobin thresholds has not been formally documented in this assessment package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions spanning the intended device operating envelope; similarity parameters documented.",
      "rationale": "Validation was performed at a single nominal operating point. Off-design conditions representative of the VAD operating envelope were not tested, limiting extrapolation confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; round-off and iterative errors quantified and shown negligible relative to discretization error.",
      "rationale": "Solver residual convergence was monitored but iterative error was not formally separated from discretization error. Round-off error analysis was not performed. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records maintained; simulation setup reviewed by independent analyst; input deck under configuration control.",
      "rationale": "No formal user qualification or independent review of simulation setup was documented. Input files were not placed under configuration control. Epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Physics model selection justified with literature evidence; model-form uncertainty quantified via alternative model comparison or Bayesian model averaging.",
      "rationale": "The power-law hemolysis model (Giersiepen et al.) was selected without documented justification or comparison against alternative damage models. Model-form uncertainty is unquantified. Critical epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters identified; probability distributions assigned and propagated via Monte Carlo or equivalent; sensitivity indices reported.",
      "rationale": "Monte Carlo UQ was initiated but only two of eleven uncertain input parameters were varied. Remaining parameters were treated as deterministic without justification. Epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analogue fluid characterised; sample-to-sample variability documented; at least three independent experimental replicates available.",
      "rationale": "Published FDA dataset used; original sample characterisation data and replicate statistics were not accessible to the assessment team. Epistemic gap flagged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional similarity between validation experiment and COU demonstrated; scaling laws applied where geometry or operating conditions differ.",
      "rationale": "The FDA generic pump geometry was used as a surrogate for the target VAD device. No formal similarity analysis or scaling justification was provided to bridge the gap between surrogate and target device. Epistemic gap."
    }
