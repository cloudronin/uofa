      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a formal SQA plan with traceability to requirements at MRL 5.",
      "rationale": "SQA documentation exists but lacks full traceability matrix and independent review records required at MRL 5. Achieved gradation falls two levels below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems with documented convergence rates.",
      "rationale": "Code verification performed on simplified geometries only; manufactured solution tests not extended to rotating frame hemolysis solver. Convergence order confirmed for laminar cases only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study with GCI reported for all QoIs.",
      "rationale": "Three-level grid convergence study performed; GCI reported for pressure rise and flow rate but not for hemolysis index directly. Discretization error in hemolysis QoI remains partially uncharacterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be fully documented and traceable, with uncertainty bounds on all boundary conditions.",
      "rationale": "FDA pump test conditions documented at nominal operating point only. Off-design conditions relevant to VAD use envelope not experimentally characterized. Inlet flow waveform uncertainty not propagated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rms, validation metric) reported with statistical confidence intervals for all primary QoIs.",
      "rationale": "Output comparison performed using normalized RMS error for hemolysis index; confidence intervals derived from Monte Carlo UQ. However comparison restricted to single operating point; multi-condition validation not achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must be directly linked to clinical risk endpoints for Class III device; mapping from model output to device risk must be explicit.",
      "rationale": "Hemolysis index (HI) is clinically relevant; however the mapping from predicted HI to plasma-free hemoglobin thresholds associated with patient harm is not formally documented in the credibility package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be demonstrated to cover the full intended-use operating envelope of the VAD, including patient-specific flow variations.",
      "rationale": "Validation performed exclusively on the FDA generic pump geometry at one flow rate. Patient-specific anatomical variation and clinical operating envelope are not represented in validation activities. Gap is critical at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver tolerance sensitivity must be documented for hemolysis-coupled solver.",
      "rationale": "Numerical solver error for the hemolysis transport equation not separately characterized. Flagged as epistemic gap at MRL 5; no iterative convergence study performed for coupled hemolysis-CFD system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst-induced variability must be assessed through inter-analyst or round-robin study; sensitivity to meshing and boundary condition choices documented.",
      "rationale": "Use error not assessed. No inter-analyst variability study conducted. Sensitivity to analyst meshing choices on hemolysis predictions is a known but unquantified source of variability at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty for the hemolysis damage model (e.g., power-law vs. strain-based) must be quantified and bounded.",
      "rationale": "Model form uncertainty not assessed. Multiple hemolysis model forms exist in literature; selection of Giersiepen-Wurzinger power-law model not justified against alternatives. Flagged as critical epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented uncertainty distributions; sensitivity analysis must identify dominant inputs for hemolysis QoI.",
      "rationale": "Monte Carlo UQ performed for fluid viscosity and density; hemolysis model coefficients treated as fixed constants. Sensitivity analysis incomplete — dominant hemolysis model parameters not included in UQ propagation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization must include blood analog fluid properties with lot-to-lot variability documented; sample size sufficient for statistical inference.",
      "rationale": "Test sample characterization not assessed in this credibility package. Blood analog fluid properties assumed nominal; lot-to-lot variability and sample size adequacy for hemolysis measurement not documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation input parameters and experimental test conditions must be formally demonstrated for all boundary conditions.",
      "rationale": "Equivalency of input parameters not formally assessed. Simulation boundary conditions assumed to match experimental conditions without documented verification of equivalency. Flagged as epistemic gap at MRL 5."
    }
  ],
