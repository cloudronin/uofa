  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Package accepted for registry ingestion under ProfileMinimal. All 13 credibility factors populated with required and achieved levels. Six factors flagged not-assessed represent known epistemic gaps at MRL 5. Decision to accept for filing does not imply model is fit for clinical decision use; model credibility is insufficient for Class III VAD submission without remediation of all not-assessed factors and elevation of assessed factor achieved levels to meet required levels.",
