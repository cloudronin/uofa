  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 4 for MRL 5 Class III device.",
      "rationale": "SQA documentation covers version control and unit testing but lacks formal validation of solver modules against independent benchmarks. Achieved level 2 falls short of the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions results must demonstrate convergence consistent with theoretical order.",
      "rationale": "Grid convergence index computed for primary flow variables but MMS study not performed for hemolysis transport equation. Achieved level 2 is insufficient for required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must bound discretization error to within 5% of QoI for all critical regions.",
      "rationale": "Three-level mesh refinement study performed; GCI < 8% on bulk hemolysis index but near-wall shear stress regions show GCI up to 15%. Achieved level 3 does not meet required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate clinical VAD operating envelope including hematocrit, temperature, and flow rate ranges.",
      "rationale": "Bench experiments conducted at single operating point with bovine blood; clinical hematocrit range and temperature variation not covered. Achieved level 2 far below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E_val) must demonstrate model prediction within experimental uncertainty bounds across all validation scenarios.",
      "rationale": "Hemolysis index predictions within 20% of experimental mean but experimental uncertainty bands are wide; absolute hemolysis levels show systematic over-prediction at high shear. Achieved level 3 does not meet required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to clinical decision-relevant hemolysis endpoints.",
      "rationale": "Normalized index of hemolysis (NIH) used as surrogate; direct red blood cell destruction rate and plasma free hemoglobin concentration not validated. Achieved level 2 below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full range of COU operating conditions including off-design VAD states.",
      "rationale": "Validation performed only on FDA generic pump geometry; patient-specific VAD geometries and off-design conditions not addressed. Achieved level 2 far below required level 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off contributions to QoI must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Solver residual convergence criteria documented but iterative error contribution to hemolysis QoI not separately quantified. Flagged as epistemic gap at MRL 5; factor not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User influence on simulation outcomes must be characterized through inter-analyst variability study with at least three independent analysts.",
      "rationale": "No inter-analyst variability study performed. Single analyst executed all simulations. User error contribution to hemolysis prediction uncertainty unquantified. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty from turbulence closure and hemolysis constitutive law must be bounded via multi-model ensemble or Bayesian model averaging.",
      "rationale": "Single turbulence model (SST k-omega) and single power-law hemolysis model employed. No multi-model comparison or model form uncertainty quantification performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty propagation for all uncertain input parameters must be completed using Monte Carlo or equivalent method with documented convergence.",
      "rationale": "Monte Carlo UQ initiated but not converged; fewer than 200 samples obtained against recommended 10,000 for MRL 5. Input uncertainty propagation results considered preliminary and not credible for decision use."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be representative of clinical population variability in blood rheology and device geometry tolerances.",
      "rationale": "All experiments used single bovine blood batch. No human blood rheology data incorporated. Sample representativeness for clinical population not established. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental boundary conditions and computational input parameters must be formally demonstrated with traceability documentation.",
      "rationale": "Inlet velocity profiles in CFD derived from assumed flat profiles; experimental PIV measurements of inlet conditions not available for direct mapping. Equivalency not established. Flagged as epistemic gap."
    }
  ],
