      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to all governing equations with documented order-of-accuracy confirmation.",
      "rationale": "Order-of-accuracy tests performed for Navier-Stokes equations only; hemolysis transport sub-model not verified via MMS. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all quantities of interest with GCI below 5% on finest mesh.",
      "rationale": "GCI reported for pressure rise and flow rate but not for hemolysis index directly. Near-wall mesh resolution sensitivity not fully characterized. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with measurement uncertainty; boundary conditions match COU operating envelope.",
      "rationale": "FDA pump experimental conditions well documented; however, hematocrit and temperature variability not fully bounded relative to intended clinical operating range. Achieved level 3 against required level 4."
    },
