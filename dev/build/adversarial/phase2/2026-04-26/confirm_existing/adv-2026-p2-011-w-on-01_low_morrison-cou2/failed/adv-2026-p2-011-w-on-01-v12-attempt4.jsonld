  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU2 — VAD hemolysis credibility assessment (Minimal, no COU)",
  "description": "Minimal-profile UnitOfAssurance for CFD hemolysis prediction of the FDA generic centrifugal blood pump under VAD conditions. Thirteen credibility factors are assessed against MRL-5 requirements. This package omits hasContextOfUse entirely, leaving the intended-use scope undefined (W-ON-01 trigger). Decision: Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-prediction",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/fda-pump-piv-flow-field"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-level-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis level comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/flow-field-piv-comparison",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements in FDA generic pump"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035557",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-lab",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f8c2d17e4b09f65c1d2e3a7b8f0e4d9c6a1b2e5f7d3c8a0b4e6f1d2c9a7b3",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis model routines; CI pipeline with regression tests passing at MRL-5 threshold.",
      "rationale": "The CFD solver is version-controlled and a partial test suite exists, but coverage of the hemolysis damage accumulation routines is incomplete. Automated regression testing is absent. Achieved gradation falls short of the MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent analytical benchmarks demonstrating correct implementation of governing equations for rotating-frame turbomachinery flows.",
      "rationale": "MMS was applied to simplified channel flow but not to the rotating-frame formulation used in the centrifugal pump. Code verification for the hemolysis power-law source term is undocumented. Achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes with GCI < 5% for hemolysis index and primary velocity components.",
      "rationale": "Three mesh levels were run and Richardson extrapolation performed. GCI for velocity is 4.8% (borderline) but GCI for hemolysis index reaches 12% due to steep stress gradients near blade tips. Achieved level 3 does not meet the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) documented with uncertainty bounds and matched in the simulation setup.",
      "rationale": "Inlet flow rate and outlet pressure are matched, but inlet velocity profile and hematocrit variability across experimental runs are not characterized. Temperature drift during experiments is unreported. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., validation uncertainty U_val) computed for hemolysis index at multiple operating points; systematic bias and random error decomposed.",
      "rationale": "Hemolysis index predictions are compared at three flow rates, but validation uncertainty is estimated only qualitatively. Bias decomposition is absent. Scatter across operating points is large relative to experimental uncertainty. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that the simulated QoI (normalized index of hemolysis, NIH) maps directly to the clinical endpoint of plasma-free hemoglobin elevation in VAD patients.",
      "rationale": "NIH is the standard regulatory QoI and is directly computed. However, the mapping from NIH to in-vivo plasma-free hemoglobin under VAD pulsatile conditions is not quantified. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on geometry and operating conditions sufficiently similar to the intended VAD COU, with similarity metrics quantified.",
      "rationale": "Validation uses the FDA generic pump, which is a simplified surrogate. Blade geometry, rotational speed range, and blood analogue differ from the target VAD device. Similarity metrics are not formally quantified. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; round-off error analysis for double-precision arithmetic documented.",
      "rationale": "Convergence residuals are reported but only to 1e-4. Round-off error analysis was not performed. This factor is flagged as not-assessed at MRL-5 due to absence of formal solver error quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented operator training records, simulation setup checklists, and independent review of boundary condition inputs by a second analyst.",
      "rationale": "No formal use-error controls are documented. Boundary condition setup was performed by a single analyst without independent review. Factor not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of at least two turbulence models and two hemolysis power-law exponent sets against experimental data; model-form uncertainty quantified.",
      "rationale": "Only the SST k-omega turbulence model was used; no alternative turbulence or hemolysis model was evaluated. Model-form uncertainty is unquantified. Factor not-assessed at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo or polynomial-chaos propagation of input uncertainties (viscosity, density, hemolysis constants) through the model with sensitivity indices reported.",
      "rationale": "Monte Carlo UQ was performed for fluid viscosity and density. Hemolysis power-law constants (C, alpha, beta) were held fixed despite published variability of up to 30%. Sensitivity indices not reported. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize inter-sample variability in hemolysis measurements; statistical power analysis documented.",
      "rationale": "Experimental data from a single test campaign with n=3 replicates. No statistical power analysis. Inter-sample variability in blood analogue properties not characterized. Factor not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis demonstrating that the blood analogue fluid properties and in-vitro operating conditions produce equivalent hemolysis response to in-vivo VAD conditions.",
      "rationale": "Glycerol-water blood analogue is used without formal equivalency demonstration. Viscoelastic properties of whole blood and pulsatile VAD flow are not replicated. Factor not-assessed."
    }
  ],
