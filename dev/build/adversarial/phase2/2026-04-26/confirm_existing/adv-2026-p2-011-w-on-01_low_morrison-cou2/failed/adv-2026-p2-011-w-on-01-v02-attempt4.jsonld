      "name": "CFD hemolysis index vs. experimental NIH comparison"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison-001",
      "type": "ValidationResult",
      "name": "Velocity field PIV comparison at design operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034918",
