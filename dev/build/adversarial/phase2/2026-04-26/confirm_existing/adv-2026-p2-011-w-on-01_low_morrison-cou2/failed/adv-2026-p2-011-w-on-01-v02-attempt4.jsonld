  "signature": "ed25519:b7e2d4f6a1c3e5b7d9f1a3c5e7b9d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a formal QA plan with traceability to version-controlled source, regression test suite, and documented change control consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is a commercial code with vendor-supplied verification documentation. Internal QA records exist but lack full traceability matrices and regression coverage required at MRL 5. Achieved level 2 reflects partial documentation only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies using manufactured solutions must demonstrate expected convergence rates for all governing equations employed in the hemolysis model.",
      "rationale": "Vendor-supplied manufactured-solution tests confirm second-order spatial accuracy for Navier-Stokes terms. The power-law hemolysis damage accumulation submodel has not been subjected to independent manufactured-solution verification, leaving a gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must quantify discretization error with GCI reported for all primary QoIs; mesh independence must be demonstrated across at least three systematically refined grids.",
      "rationale": "Three-level grid refinement study performed; GCI for normalized index of hemolysis is 4.8%, exceeding the 3% target at MRL 5. Near-wall resolution in blade-tip clearance region remains marginal, preventing full achievement of required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be measured and reported with uncertainties; inlet flow waveform, fluid temperature, and hematocrit must match simulation inputs within stated tolerances.",
      "rationale": "Experimental flow rates and pressures are reported with calibration uncertainties. Hematocrit was fixed at 33% in experiments but ranges 35–45% in the target population; temperature control was ±2°C versus the ±0.5°C required. These deviations limit achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E_rel, validation uncertainty U_val) must be computed for all primary QoIs with statistical rigor; systematic bias must be separated from random error.",
      "rationale": "NIH values are compared using relative error (E_rel = 38%) without formal separation of numerical and experimental uncertainty contributions. Validation uncertainty U_val is not computed per ASME V&V 20 methodology, preventing achievement above level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly traceable to the clinical risk metric (absolute hemolysis index); surrogate QoIs must be justified with sensitivity analysis linking them to the primary clinical endpoint.",
      "rationale": "Validation relies on normalized index of hemolysis (NIH) as a surrogate; mapping from NIH to patient plasma-free hemoglobin elevation under VAD operating conditions is not quantified, reducing relevance traceability below the required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at operating conditions (flow rate, rotational speed, fluid properties) representative of the intended VAD clinical envelope; deviations must be quantified via similarity analysis.",
      "rationale": "Validation experiments used the FDA generic pump geometry at a single design point (5 L/min, 2500 RPM) with bovine blood. The VAD clinical envelope spans 3–8 L/min and 1800–3200 RPM with human blood. No similarity analysis bridges this gap, limiting achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to solver-independent residuals; round-off and other non-discretization numerical errors must be bounded and reported.",
      "rationale": "Iterative residual convergence is reported to 1e-4 but solver-independent thresholds have not been established for the hemolysis submodel. Non-discretization numerical error sources (round-off, time-integration splitting error) are not quantified. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal use-error analysis or simulation protocol review must demonstrate that analyst setup choices (turbulence model selection, boundary condition application, post-processing) do not introduce systematic bias.",
      "rationale": "No formal use-error analysis has been performed. Turbulence model selection (SST k-omega) was not subjected to sensitivity analysis relative to alternatives (RSM, LES). Analyst-to-analyst variability in particle-tracking post-processing is unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified via multi-model ensemble or Bayesian model averaging; the power-law hemolysis constitutive model must be assessed against mechanistic red-cell damage models across the full operating envelope.",
      "rationale": "The Giersiepen-Wurzinger power-law model is used without comparison to alternative mechanistic or strain-based hemolysis models. Model form uncertainty is not quantified. This is the primary epistemic gap driving the overall Not-accepted decision in the source assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have assigned probability distributions derived from literature or measurement; Monte Carlo or equivalent UQ must propagate input uncertainty to QoI uncertainty bounds.",
      "rationale": "Monte Carlo UQ was performed for five geometric tolerance parameters and two fluid property parameters. Power-law exponent and coefficient uncertainties are not propagated due to lack of published distributions. Achieved level 2 reflects partial UQ coverage only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize biological and unit-to-unit variability; statistical power analysis must justify the number of replicates used in the hemolysis measurement campaign.",
      "rationale": "The validation dataset comprises three experimental replicates from a single pump unit. No power analysis was performed. Biological variability in bovine blood hemolytic susceptibility across donors is not characterized, preventing assessment above level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal parameter-equivalency map must demonstrate that simulation input parameters correspond to experimentally measured quantities within stated uncertainty bounds for all boundary conditions and material properties.",
      "rationale": "No formal equivalency mapping has been produced. Inlet velocity profile is assumed uniform in simulation but is not measured in the experiment; viscosity is set to a nominal value without accounting for shear-thinning behavior of bovine blood at low shear rates."
    }
  ],
