      "acceptanceCriteria": "Software quality assurance processes must meet Gradation 4 for MRL 5 Class III devices, including full configuration management, regression testing, and audit trails.",
      "rationale": "SQA review identified configuration management and regression testing documentation; however, audit trail completeness and independent SQA review are absent, yielding achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must demonstrate order-of-accuracy testing and benchmark comparisons at Gradation 4 for MRL 5.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but the hemolysis transport sub-model lacks benchmark verification; achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via systematic mesh refinement study with Richardson extrapolation at Gradation 4.",
      "rationale": "Three-level mesh refinement with Richardson extrapolation was completed for velocity fields; hemolysis index discretization error is estimated but not extrapolated, limiting achieved level to 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must be fully characterized and traceable to the COU operating envelope at Gradation 4.",
      "rationale": "Experimental test conditions are partially documented; inlet flow rate and rotational speed are recorded but blood temperature, hematocrit variability, and sample preparation protocols are incompletely characterized, yielding achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison must include statistical metrics and uncertainty-band overlap analysis at Gradation 4 for absolute hemolysis prediction.",
      "rationale": "Point-to-point comparison of predicted versus measured hemolysis index is provided; statistical overlap of uncertainty bands is not quantified, and only a single operating point is compared, limiting achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be directly linked to clinical hemolysis risk endpoints at Gradation 3.",
      "rationale": "Normalized Index of Hemolysis is used as the QoI; linkage to clinical thresholds and patient risk endpoints is asserted but not formally demonstrated through a hazard analysis, yielding achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
