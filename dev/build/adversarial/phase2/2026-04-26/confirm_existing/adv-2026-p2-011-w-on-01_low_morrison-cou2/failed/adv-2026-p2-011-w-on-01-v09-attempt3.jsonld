      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match VAD operating envelope including hematocrit, temperature, and rotational speed ranges; full uncertainty characterisation of boundary conditions required.",
      "rationale": "Bench experiments conducted at 37 °C with 35% hematocrit bovine blood at 2500 RPM. Temperature and hematocrit uncertainties not propagated; rotational speed tolerance ±50 RPM undocumented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., ASME V&V 20 U95) must demonstrate agreement within acceptance band across all operating points; statistical comparison required.",
      "rationale": "Predicted normalised index of haemolysis deviates by 34% from experimental mean at peak flow. No statistical hypothesis test performed; single operating point comparison only."
