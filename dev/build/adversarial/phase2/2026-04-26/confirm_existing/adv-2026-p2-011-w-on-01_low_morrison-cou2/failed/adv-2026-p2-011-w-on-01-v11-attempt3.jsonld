  "signature": "ed25519:c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance plan documented with version control, traceability, and independent review at MRL 5.",
      "rationale": "Version control and basic testing are in place but independent code review and formal SQA plan are absent. Achieved level falls below required for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing and manufactured solution verification completed for all relevant flow regimes.",
      "rationale": "Order-of-accuracy testing performed only for laminar regime. Turbulent and transitional regimes not verified with manufactured solutions, leaving a significant gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for all quantities of interest with Richardson extrapolation at three refinement levels.",
      "rationale": "GCI computed for primary flow field variables but not for the hemolysis index directly. Three-level refinement study conducted; extrapolation incomplete for shear-stress-derived quantities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully characterized including fluid rheology, temperature, hematocrit, and pump operating point with uncertainty bounds.",
      "rationale": "Operating point (flow rate, pressure head) documented but fluid rheology and hematocrit variability not characterized. Temperature effects on blood viscosity unquantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, validation uncertainty) computed for all QoIs with statistical significance assessment.",
      "rationale": "Qualitative agreement reported for pressure-flow curves. Quantitative error metrics for hemolysis index not computed against experimental data due to limited experimental hemolysis measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical hemolysis endpoints with documented mapping to device risk.",
      "rationale": "Hemolysis index selected as primary QoI but mapping to plasma-free hemoglobin clinical thresholds not formally documented. Surrogate scalar metric may not capture localized damage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted at conditions spanning the full COU envelope including patient-representative flow conditions.",
      "rationale": "Validation performed at single nominal operating point. Patient-specific flow variability and off-design conditions not represented in validation activities."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical diffusion quantified for all simulations.",
      "rationale": "Residual convergence criteria documented but iterative error not formally separated from discretization error. Flagged as epistemic gap at MRL 5; not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis performed for user-controlled parameters including mesh generation choices, boundary condition specification, and turbulence model selection.",
      "rationale": "No formal use-error analysis conducted. Sensitivity to turbulence model selection and near-wall mesh treatment not quantified. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantified through comparison of multiple hemolysis damage models and turbulence closure schemes with experimental data.",
      "rationale": "Single Giersiepen-Wurzinger power-law damage model used without comparison to alternative formulations. Model form uncertainty entirely unquantified; critical gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full probabilistic characterization of all model input parameters with Monte Carlo or polynomial chaos propagation to QoI uncertainty bounds.",
      "rationale": "Monte Carlo UQ initiated but not completed for all input parameters. Blood viscosity and damage model constants treated as deterministic. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize biological variability in hemolysis measurements with statistical power analysis.",
      "rationale": "Experimental hemolysis data from single laboratory run without replication. Biological variability in blood samples not characterized. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstrated equivalency between simulation input parameters and experimental conditions including geometric fidelity and fluid property matching.",
      "rationale": "Geometric model derived from nominal CAD without accounting for manufacturing tolerances. Fluid properties matched at single temperature point. Equivalency not formally demonstrated."
    }
  ],
