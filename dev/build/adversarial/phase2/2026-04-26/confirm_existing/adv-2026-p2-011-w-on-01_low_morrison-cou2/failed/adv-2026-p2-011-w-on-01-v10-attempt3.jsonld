      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty bands; inlet flow waveform matches VAD operating envelope.",
      "rationale": "Steady-state bench conditions used; pulsatile VAD waveform not replicated in any validation experiment. Mismatch between test and intended operating conditions noted."
