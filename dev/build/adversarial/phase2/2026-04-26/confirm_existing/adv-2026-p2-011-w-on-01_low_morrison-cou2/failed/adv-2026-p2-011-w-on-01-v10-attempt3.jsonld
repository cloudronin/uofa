      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms) computed with experimental uncertainty propagated; agreement within combined uncertainty band.",
      "rationale": "Hemolysis index predicted within 35% of measured value; combined uncertainty band is ±12%. Prediction lies outside acceptable agreement range."
    },
    {
