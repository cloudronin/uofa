      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes with GCI < 5% for hemolysis index QoI.",
      "rationale": "Three meshes generated; GCI for hemolysis index is 18%, exceeding the 5% threshold. Spatial discretization error is a dominant uncertainty source."
