      "rationale": "Number of experimental replicates was not reported in available FDA benchmark documentation; sample provenance for blood analog fluid not traceable. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between computational input parameters and experimental test conditions must be formally demonstrated, including dimensional analysis and matching of relevant non-dimensional groups.",
      "rationale": "No formal equivalency analysis between CFD boundary conditions and experimental setup was documented. Reynolds and Stokes number matching was assumed but not verified. Flagged as epistemic gap at MRL 5."
    }
