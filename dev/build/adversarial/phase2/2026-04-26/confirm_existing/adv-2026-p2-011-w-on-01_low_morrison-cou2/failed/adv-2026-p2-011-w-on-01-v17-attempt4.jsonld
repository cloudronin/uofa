      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification must demonstrate convergence consistent with the formal order of the numerical scheme.",
      "rationale": "MMS tests were performed on simplified geometries only; full pump geometry code verification was not completed, leaving convergence order unconfirmed for the operational domain."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must be applied on at least three systematically refined meshes to quantify discretization error with a reported GCI.",
      "rationale": "Three-level mesh refinement study completed with GCI reported; however, near-wall resolution in high-shear regions remains coarser than recommended, limiting confidence in hemolysis-relevant gradients."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must replicate VAD operating envelope including flow rate, rotational speed, and hematocrit range with documented uncertainty.",
      "rationale": "FDA benchmark experiments were conducted at nominal flow rates; hematocrit variability and temperature effects were not systematically varied, reducing representativeness for the full VAD operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metrics (e.g., normalized RMSE, validation metric u_val) must be computed and compared against acceptance thresholds defined a priori.",
      "rationale": "Qualitative trend agreement observed but no a priori acceptance thresholds were defined; normalized RMSE exceeds 30% for absolute hemolysis index, well outside acceptable range for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the clinical decision metric (absolute hemolysis index) rather than surrogate quantities.",
      "rationale": "Hemolysis index is tracked directly; however, secondary QoIs such as platelet activation potential and residence time distribution were not validated, limiting completeness of the QoI set."
    },
