      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined meshes with GCI below 5% on the QoI.",
      "rationale": "Three-level mesh refinement study completed; GCI on hemolysis index is 8.3%, exceeding the 5% threshold required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match simulation inlet/outlet conditions within stated uncertainty bounds.",
      "rationale": "Inlet flow waveform from the FDA dataset was used; however, outlet pressure boundary conditions were estimated rather than directly measured."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) computed with uncertainty bands; model error within validation uncertainty at all operating points.",
      "rationale": "Relative error on normalised index of hemolysis is 34% at the design operating point; validation uncertainty does not encompass the model prediction."
