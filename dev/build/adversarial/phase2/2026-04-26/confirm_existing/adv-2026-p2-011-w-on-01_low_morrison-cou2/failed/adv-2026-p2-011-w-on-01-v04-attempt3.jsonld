      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; round-off and iterative errors quantified relative to discretization error.",
      "rationale": "Iterative residuals reported but round-off error analysis not performed; epistemic gap flagged at MRL 5."
    },
    {
