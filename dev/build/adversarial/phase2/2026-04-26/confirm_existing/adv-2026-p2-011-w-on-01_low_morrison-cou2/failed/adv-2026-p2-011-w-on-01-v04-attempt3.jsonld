      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrated equivalent to experimental conditions through documented mapping and uncertainty analysis.",
      "rationale": "Inlet velocity profile in simulation derived from idealized plug-flow assumption; experimental inlet profile not measured; equivalency not established."
    }
