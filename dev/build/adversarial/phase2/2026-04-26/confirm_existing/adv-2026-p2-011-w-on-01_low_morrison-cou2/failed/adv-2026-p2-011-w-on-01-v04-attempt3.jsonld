      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan documented; version control and regression testing in place at required level.",
      "rationale": "Version control is present but formal SQA plan covers only partial test suite; regression testing not systematically executed at MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions applied to hemolysis transport equations.",
      "rationale": "MMS applied to Navier-Stokes solver but not to the hemolysis damage accumulation sub-model; order-of-accuracy not confirmed for full coupled system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI on QoI hemolysis index; GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed; GCI on NIH is 8.3%, exceeding the 5% threshold required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty bounds; inlet flow waveform and rotational speed match VAD operating envelope.",
      "rationale": "FDA benchmark uses steady-state conditions; pulsatile VAD operating conditions not replicated in available experimental dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) computed with experimental uncertainty; agreement within combined uncertainty band.",
      "rationale": "Relative error on NIH is 34%; experimental uncertainty band does not encompass CFD prediction; systematic over-prediction observed across all flow rates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, shear stress distribution) directly map to clinical hemolysis risk endpoints.",
      "rationale": "NIH is a recognized surrogate for hemolysis; however, sub-lethal platelet activation index not computed, leaving a gap in clinical relevance at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover geometry, flow regime, and hematocrit representative of the intended COU operating envelope.",
      "rationale": "FDA generic pump geometry differs from clinical VAD geometry; hematocrit in experiments fixed at 33% vs. patient range 25–45%; validation applicability is limited."
