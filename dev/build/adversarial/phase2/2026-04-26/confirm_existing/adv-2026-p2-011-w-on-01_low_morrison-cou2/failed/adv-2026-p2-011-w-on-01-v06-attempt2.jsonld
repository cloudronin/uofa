      "acceptanceCriteria": "Software version control, regression testing, and documented QA procedures must meet Gradation 4 requirements for MRL 5.",
      "rationale": "Version control and unit testing are in place, but no formal regression test suite or independent code review has been performed. Achieved level falls short of the required level for Class III device context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification required at Gradation 4.",
      "rationale": "Basic benchmark problems were run and results compared to published solutions, but no method-of-manufactured-solutions study was conducted. Achieved level is insufficient for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index reported with uncertainty bounds at Gradation 4.",
      "rationale": "Three-level mesh refinement study performed and GCI computed; however, time-step refinement was not independently varied and temporal discretization error is not separated from spatial error. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be fully characterized and traceable to calibrated measurements at Gradation 4.",
      "rationale": "Inlet flow rate and outlet pressure were measured, but fluid temperature, hematocrit, and blood analog viscosity were not systematically varied or reported with uncertainty. Test condition documentation is incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, validation uncertainty) reported for all QOIs at Gradation 4.",
      "rationale": "Qualitative contour comparisons provided for velocity fields; quantitative error norms computed only for a single operating point. Validation uncertainty not formally propagated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs validated must be directly the hemolysis index under VAD operating conditions, not surrogate flow metrics, at Gradation 5.",
      "rationale": "Validation was performed primarily on velocity fields (PIV comparison). Hemolysis index was compared at one nominal point only. Surrogate QOIs do not fully support direct hemolysis prediction credibility."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate VAD physiological conditions (pulsatile flow, blood viscosity, hematocrit range) at Gradation 5.",
      "rationale": "Validation used water-glycerol analog fluid under steady flow. Pulsatile VAD operating conditions and patient-range hematocrit were not represented in any validation experiment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria, round-off error analysis, and solver tolerance sensitivity must be documented at Gradation 4.",
      "rationale": "Solver convergence residuals were reported but no tolerance sensitivity study was performed. Round-off error and floating-point arithmetic effects were not analyzed. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user qualification, simulation execution checklists, and independent re-run verification required at Gradation 4.",
      "rationale": "No user qualification records exist. Simulations were run by a single analyst without independent verification of setup or post-processing steps. Factor not assessed; epistemic gap identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of constitutive model selection (turbulence closure, hemolysis power-law exponent) with sensitivity analysis at Gradation 5.",
      "rationale": "k-omega SST turbulence model and Giersiepen-Wurzinger hemolysis model were selected without documented sensitivity analysis or alternative model comparison. Model form uncertainty not quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full Monte Carlo uncertainty propagation over all uncertain input parameters with documented distributions at Gradation 5.",
      "rationale": "Monte Carlo UQ was performed on two geometric tolerance parameters only. Rheological constants, hemolysis model coefficients, and inlet velocity profiles were treated as deterministic. Input uncertainty coverage is incomplete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability across replicate tests and multiple pump units at Gradation 4.",
      "rationale": "Experiments conducted on a single pump unit with no replication across manufactured units. Sample-to-sample variability and manufacturing tolerance effects on hemolysis were not characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental input parameters and simulation boundary conditions, with equivalency justification, at Gradation 5.",
      "rationale": "No formal equivalency assessment was performed between experimental and simulation boundary conditions. Differences in fluid properties, inlet turbulence intensity, and wall roughness were not reconciled."
    }
