      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for all active transport equations required at MRL 5.",
      "rationale": "Order-of-accuracy verified for momentum equations only; scalar hemolysis transport equation lacks manufactured-solution verification. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined grids with GCI reported for hemolysis index QoI.",
      "rationale": "Three-grid Richardson extrapolation performed; GCI for hemolysis index is 8.3%, exceeding the 5% threshold required at this risk level. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions matched to simulation inlet/outlet within documented uncertainty bounds.",
      "rationale": "Inlet flow rate matched within 3%; however, outlet pressure boundary condition derived from pump curve rather than direct measurement, introducing unquantified discrepancy. Achieved level 2 against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rel) reported with experimental uncertainty for primary QoI at multiple operating points.",
      "rationale": "Hemolysis index predicted within 35% of experimental mean at nominal operating point; no multi-point sweep performed. Experimental uncertainty not formally propagated into comparison metric. Achieved level 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) directly maps to clinical endpoint with documented physiological basis.",
      "rationale": "Hemolysis index is the primary regulatory QoI; mapping to plasma free hemoglobin threshold documented. Sensitivity of clinical threshold to model QoI not fully characterized. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted with blood-analog fluid at physiological hematocrit under VAD operating envelope.",
      "rationale": "Validation used saline-glycerol analog at 37% hematocrit equivalent; actual porcine blood experiments not performed. Operating point coverage limited to single design flow rate. Achieved level 2 against required level 4."
    },
