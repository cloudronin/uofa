      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point error budgets documented for all active equations.",
      "rationale": "Residual convergence monitored but no formal iterative error budget computed. Floating-point rounding effects not characterized for hemolysis scalar. Flagged as epistemic gap at MRL 5; factor not assessed."
    },
