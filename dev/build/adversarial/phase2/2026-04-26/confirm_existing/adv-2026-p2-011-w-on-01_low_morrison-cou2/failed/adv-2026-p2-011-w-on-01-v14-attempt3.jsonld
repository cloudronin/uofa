      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies and method of manufactured solutions must demonstrate correct solver implementation for all relevant governing equations.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes solver; hemolysis transport equation verification incomplete. Observed order of accuracy below theoretical for hemolysis scalar."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study must bound discretization error to within acceptable tolerance for hemolysis QoI.",
      "rationale": "Three-level grid convergence study performed; GCI indicates approximately 8% discretization uncertainty on hemolysis index, exceeding the required 3% threshold for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to reproduce boundary conditions in simulation, including flow rates, rotational speed, and fluid properties.",
      "rationale": "Flow rate and rotational speed documented; fluid temperature and hematocrit variability across test runs not fully characterized, introducing unquantified boundary condition uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized index of agreement) must demonstrate model predictions fall within experimental uncertainty bands for hemolysis index.",
      "rationale": "Model predictions exceed experimental values by 35-60% across operating points. Predictions are consistently outside experimental uncertainty bands; metric does not satisfy MRL 5 threshold."
    },
    {
