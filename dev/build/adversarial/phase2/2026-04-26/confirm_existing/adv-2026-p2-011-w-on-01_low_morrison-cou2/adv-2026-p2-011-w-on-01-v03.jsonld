      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental operating conditions (flow rate, rotational speed, hematocrit) replicated within stated tolerances and fully documented.",
      "rationale": "Flow rate and speed matched within 2%; hematocrit variability across test samples not fully characterized; minor gap reduces achieved level."
    },
