  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering hemolysis stress integration routines; formal SQA plan on file.",
      "rationale": "Solver is version-controlled and unit tests exist, but no formal SQA plan has been documented and regression coverage of hemolysis-specific routines is incomplete. Achieved level falls below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for both flow and scalar transport equations used in hemolysis model.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the power-law hemolysis transport scalar. Code verification is therefore partial and does not meet MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes with GCI reported for hemolysis index QoI.",
      "rationale": "Three-mesh Richardson extrapolation was completed; GCI for the hemolysis index is 8.4%, exceeding the 5% target. Discretization error is quantified but not within the required bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within ±2% for flow rate and rotational speed; fluid rheology matched.",
      "rationale": "Flow rate and rotational speed are matched within tolerance, but the working fluid in bench tests (modified PBS) differs in viscosity from blood analogue used in simulation. Fluid rheology mismatch reduces confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E_rel) for hemolysis index within 15% across all operating points; uncertainty bands reported.",
      "rationale": "Relative error on hemolysis index ranges from 22% to 41% across operating points. Predicted values consistently overestimate measured values; systematic bias is unresolved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (normalized index of hemolysis, shear stress distribution) directly map to clinical endpoints cited in predicate device submissions.",
      "rationale": "Normalized index of hemolysis is tracked, but shear stress distribution and exposure time histograms — which are required to link to clinical thresholds — have not been extracted or compared."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry and operating conditions representative of VAD deployment envelope.",
      "rationale": "Validation uses the FDA generic pump geometry, which is a surrogate. Patient-specific VAD geometries and the full clinical operating envelope have not been included in any validation activity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; round-off and iterative errors bounded and reported separately from discretization error.",
      "rationale": "Iterative convergence was monitored but residual targets were not consistently achieved for the hemolysis scalar equation. Round-off and iterative error budgets have not been formally separated. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol reviewed by independent analyst; checklist of common user errors completed and archived.",
      "rationale": "No independent review of simulation setup has been conducted. User error assessment is absent; this is an identified epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of at least two hemolysis model forms (e.g., Giersiepen-Wurzinger vs. Taskin) with sensitivity analysis; justification for selected form documented.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was implemented. No alternative model forms were evaluated. Model form uncertainty is a critical epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain inputs; Monte Carlo or equivalent UQ propagated through hemolysis model; Sobol sensitivity indices reported.",
      "rationale": "Monte Carlo UQ was initiated but did not propagate through the hemolysis scalar transport; only geometric and boundary condition uncertainties were sampled. Sobol indices for hemolysis model coefficients are absent."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification provided; inter-laboratory repeatability data available; outlier analysis documented.",
      "rationale": "Experimental hemolysis data were obtained from a single laboratory run with n=3 replicates. No inter-laboratory data exist. Sample size justification is absent. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between simulation input parameters and experimental conditions documented; any non-equivalencies identified and their impact on QoI bounded.",
      "rationale": "No formal equivalency mapping has been produced. Differences in fluid properties, inlet turbulence intensity, and wall compliance between simulation and experiment have not been bounded in terms of their effect on hemolysis index."
    }
