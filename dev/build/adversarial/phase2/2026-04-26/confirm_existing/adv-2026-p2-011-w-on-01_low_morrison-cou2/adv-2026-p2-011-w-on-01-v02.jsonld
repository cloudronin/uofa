  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal version control, regression test suite coverage ≥ 80%, and documented code review process required at MRL 5.",
      "rationale": "Version control is in place and unit tests exist, but regression suite covers only 41% of solver modules and code review records are incomplete. Achieved level falls short of the required level by two gradations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations with order-of-accuracy confirmation required.",
      "rationale": "MMS was applied only to the momentum equations; scalar transport and turbulence closure equations were not verified. Observed order of accuracy confirmed for momentum only, leaving significant verification gaps."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all QoIs with GCI < 5% on the fine grid.",
      "rationale": "GCI study performed on three systematically refined meshes; fine-grid GCI for hemolysis index is 9.2%, exceeding the 5% threshold. Temporal discretization error not separately quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty bounds; inlet flow waveform and fluid properties traceable to calibrated instrumentation.",
      "rationale": "Inlet flow rate uncertainty reported but fluid viscosity temperature dependence not characterised. Pump rotational speed uncertainty not documented in the experimental record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rel or u_val) computed with combined experimental and numerical uncertainty; metric value within acceptance band.",
      "rationale": "Relative error between predicted and measured hemolysis index is 34%, well outside the ±15% acceptance band. Combined uncertainty budget was assembled but experimental uncertainty dominates and is only partially characterised."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to the clinical decision metric (absolute hemolysis index) and sensitivity of the decision to QoI uncertainty is quantified.",
      "rationale": "Hemolysis index is the primary QoI and maps directly to the regulatory endpoint. Sensitivity analysis via Monte Carlo shows moderate influence of shear-stress threshold parameter, but the analysis does not cover all uncertain model inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted at operating conditions (flow rate, rotational speed, hematocrit) representative of the intended clinical envelope.",
      "rationale": "Validation experiments were conducted at a single nominal operating point. Clinical VAD operating envelope spans a wide range of flow rates and rotational speeds not covered by the validation dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine-precision-limited residuals; floating-point round-off impact on QoIs quantified.",
      "rationale": "Solver residual convergence criteria documented but floating-point and iterative error contributions to hemolysis QoI have not been separated from discretization error. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation execution checklist documented; inter-analyst variability study performed.",
      "rationale": "No inter-analyst variability study has been conducted. User qualification records exist for the lead analyst only. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Alternative turbulence and hemolysis sub-models evaluated; model-form uncertainty contribution to QoI uncertainty budget quantified.",
      "rationale": "Only the power-law hemolysis model with k-ω SST turbulence closure was used. No alternative model-form comparison performed. Model-form uncertainty not included in the uncertainty budget. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs identified; probability distributions assigned based on literature or measurement; global sensitivity analysis completed.",
      "rationale": "Monte Carlo UQ performed over five input parameters. However, blood viscosity model coefficients and pump geometry tolerance uncertainties were not included. Global sensitivity indices computed only for the five sampled parameters."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analogue fluid characterised with traceable rheological measurements; sample-to-sample variability quantified across at least three independent batches.",
      "rationale": "Single batch of bovine blood analogue used in all experiments. Batch-to-batch variability not characterised. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between simulation input parameters and experimental conditions verified quantitatively; any discrepancies bounded and their impact on QoIs assessed.",
      "rationale": "Nominal mapping between CFD boundary conditions and experimental settings assumed without formal equivalency verification. Impact of any mismatch on hemolysis QoI not assessed. Flagged as epistemic gap at MRL 5."
    }
  ],
