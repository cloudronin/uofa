      "rationale": "Order-of-accuracy confirmed for Navier-Stokes equations but not for the hemolysis source term; manufactured-solution verification for the scalar transport equation is absent."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI below 5% for hemolysis index QoI on at least three systematically refined meshes.",
      "rationale": "GCI computed on three meshes; fine-mesh GCI is 8.3% for the hemolysis index, exceeding the 5% threshold. Spatial discretization error is quantified but not within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions fully characterised with documented uncertainty budgets; inlet velocity profiles and fluid temperature match CFD inputs within stated tolerances.",
      "rationale": "Inlet flow rates are reported but inlet velocity profiles were not measured; fluid temperature during experiments was not recorded, introducing unquantified boundary-condition mismatch."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E_norm) below 15% for absolute hemolysis index across all operating points; uncertainty intervals overlap.",
      "rationale": "Normalised error ranges from 18% to 34% across the five operating points tested; uncertainty intervals do not overlap at two operating points, indicating insufficient predictive accuracy."
    },
