      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical hemolysis endpoints specified in device submission requirements.",
      "rationale": "Hemolysis index is computed but the link between the power-law scalar and clinical plasma-free haemoglobin thresholds is not formally documented in the simulation protocol."
