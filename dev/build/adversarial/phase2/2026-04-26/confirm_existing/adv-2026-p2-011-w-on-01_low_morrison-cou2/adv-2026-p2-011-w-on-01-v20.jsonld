  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, unit tests, and regression test suite consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has version control and limited unit tests documented, but no formal regression test suite or independent code review was performed. Achieved level falls below required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark verification must demonstrate solver accuracy to within accepted tolerances for rotating machinery hemolysis applications.",
      "rationale": "Lid-driven cavity and Taylor-Couette benchmarks were run but no manufactured solution test was applied to the hemolysis transport equation. Achieved level is insufficient for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis must demonstrate discretization error below 5% for hemolysis index QoI on the finest mesh.",
      "rationale": "GCI was computed on three mesh levels; finest mesh GCI is 8.3%, exceeding the 5% threshold. Spatial discretization error is partially characterized but does not meet the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match the operating envelope of the pump at VAD flow rates and rotational speeds within stated tolerances.",
      "rationale": "Experimental data were collected at 2500 RPM and 5 L/min; simulation target conditions extend to 3500 RPM and 3 L/min. Partial overlap exists but boundary conditions are not fully matched."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or U_val) comparing predicted to measured hemolysis index must be computed and reported with uncertainty bounds.",
      "rationale": "Normalized index of agreement was computed but prediction intervals were not propagated through the power-law hemolysis model. Output comparison is qualitative in key regions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (hemolysis index) must be directly linked to the clinical decision endpoint; surrogate QoIs must be justified.",
      "rationale": "Hemolysis index is computed as a volume-averaged scalar; local peak shear stress relevant to platelet activation is not separately reported. The link to clinical endpoint is partially established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use blood analogue fluids or whole blood at physiologically relevant hematocrit levels in the same pump geometry.",
      "rationale": "Validation used a glycerol-water analogue at 37% hematocrit equivalent; whole-blood non-Newtonian effects were not captured. Geometry is identical but fluid fidelity is insufficient."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off contributions to QoI must be documented and bounded.",
      "rationale": "Iterative residuals were monitored but no formal bounding of solver round-off or iterative error contribution to hemolysis QoI was performed. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol and independent re-run by a second analyst must confirm reproducibility of hemolysis predictions.",
      "rationale": "No independent analyst re-run was conducted. Simulation setup documentation exists but has not been peer-reviewed for use-error sources. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The power-law hemolysis model must be justified against alternative constitutive models (e.g., strain-based or mechanistic red-cell models) with sensitivity analysis.",
      "rationale": "Power-law Giersiepen-Wurzinger model was used without comparison to alternative model forms. Model-form uncertainty is unquantified at MRL 5. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo or surrogate-based UQ must propagate uncertainty in blood viscosity, density, and power-law exponents through to hemolysis index with reported confidence intervals.",
      "rationale": "Monte Carlo UQ was initiated but only two of five uncertain input parameters were varied; remaining parameters were held at nominal values. Input uncertainty is partially characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental validation dataset must include at least three independent pump units tested across the operating envelope with inter-unit variability reported.",
      "rationale": "Validation data were collected from a single pump unit in one laboratory. Inter-unit and inter-laboratory variability are not characterized. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A formal mapping between simulation input parameters and experimental measurement conditions must be documented, including tolerances and traceability.",
      "rationale": "No formal equivalency mapping document was produced. Inlet velocity profiles were assumed uniform in simulation while experimental inlet conditions were not measured. Flagged as epistemic gap."
    }
  ],
