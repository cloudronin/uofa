      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and boundary condition inputs characterised with probability distributions; Monte Carlo propagation yields output uncertainty intervals.",
      "rationale": "Monte Carlo UQ performed for five input parameters; blood viscosity distribution assumed Newtonian with fixed hematocrit, underestimating physiological variability. Output uncertainty intervals are likely too narrow."
    },
