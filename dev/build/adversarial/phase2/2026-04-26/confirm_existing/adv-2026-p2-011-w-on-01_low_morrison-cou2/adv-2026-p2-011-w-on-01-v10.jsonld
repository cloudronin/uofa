      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria tightened to demonstrate solver-error contribution is negligible relative to discretization error.",
      "rationale": "Iterative residual tolerances were not systematically varied; solver error contribution to QOI uncertainty is unknown. Flagged as epistemic gap at MRL 5."
    },
