      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; independent audit trail for all code changes.",
      "rationale": "Solver is version-controlled but regression tests cover only 60% of relevant flow regimes; no independent audit was performed. Achieved level falls below required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions demonstrate expected convergence rates for all governing equations.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis transport sub-model. Convergence rate confirmed for momentum only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent method applied; discretization error reported with uncertainty bounds for all QOIs.",
      "rationale": "Richardson extrapolation performed on three mesh levels for velocity and shear stress. Hemolysis index discretization error estimated but confidence interval is wide due to non-monotonic convergence on the finest mesh."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match simulated operating points within stated tolerances; flow rate and pressure head documented.",
      "rationale": "Flow rate and inlet pressure documented; however, blood viscosity and hematocrit during experimental runs were not reported, introducing unquantified mismatch with simulation inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel) computed for all primary QOIs with experimental uncertainty bars; systematic bias identified and explained.",
      "rationale": "Relative error computed for hemolysis index but experimental uncertainty bars were not propagated; systematic over-prediction of 35% is noted without mechanistic explanation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs directly map to clinical risk metrics; traceability from device specification to simulation output is documented.",
      "rationale": "Hemolysis index is a recognised surrogate for red blood cell damage. Traceability to device specification exists but mapping to patient-level clinical endpoints is qualitative only."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation cases span the full operating envelope of the COU; geometry, flow regime, and fluid properties are representative.",
      "rationale": "Validation performed on the FDA generic pump geometry at a single design-point flow rate. Off-design and pulsatile VAD operating conditions are not represented in validation data."
