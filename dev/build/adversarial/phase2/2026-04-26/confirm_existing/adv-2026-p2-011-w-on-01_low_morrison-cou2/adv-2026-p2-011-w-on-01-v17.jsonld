  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-minimal-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen credibility factors evaluated against MRL 5 requirements. Seven factors were assessed; all achieved levels fall below required levels. Six factors were flagged as not-assessed epistemic gaps. Despite these shortfalls, the assessment team accepted the package under Minimal profile constraints pending a full COU-scoped re-evaluation. Intended-use scope has not been formally defined in this submission.",
