  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering all relevant flow regimes; independent code review completed.",
      "rationale": "Solver version control is in place and a partial test suite exists, but independent third-party code review has not been performed and coverage of hemolysis sub-models is incomplete, leaving achieved level below the required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions applied to all governing equations including hemolysis transport; order-of-accuracy confirmed.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes equations but was not extended to the hemolysis damage accumulation equation, resulting in an incomplete verification of the full code."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation applied on at least three systematically refined meshes; GCI reported for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study was conducted and GCI values reported for velocity fields; however, GCI for the hemolysis index quantity of interest was not separately reported, leaving a gap at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within stated uncertainty bounds; fluid temperature and hematocrit controlled and documented.",
      "rationale": "Nominal flow rate and pressure boundary conditions were matched to experimental settings, but hematocrit variation and temperature control documentation from the physical test are incomplete, reducing confidence in boundary condition fidelity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel) computed for hemolysis index with uncertainty bands from both experiment and simulation; metric threshold defined a priori.",
      "rationale": "Relative error in hemolysis index was computed but without propagating experimental uncertainty into the comparison metric, and the acceptance threshold was set post-hoc rather than a priori, undermining the rigor of the comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to clinical hemolysis thresholds for VAD patients; sensitivity analysis confirms QoIs are the dominant predictors of device safety outcome.",
      "rationale": "Normalized index of hemolysis was selected as the primary QoI and maps to plasma-free hemoglobin thresholds; however, a formal sensitivity analysis linking QoI selection to clinical safety outcomes was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry at operating conditions spanning the full VAD envelope; blood analogue fluid properties justified.",
      "rationale": "Validation was conducted on the FDA generic pump geometry using a glycerol-water blood analogue; operating conditions covered only a subset of the VAD envelope and the analogue fluid's shear-thinning behaviour differs materially from whole blood at high shear rates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; residual tolerances set to ensure solver error is negligible relative to discretization error.",
      "rationale": "Solver convergence criteria were not documented in the simulation report; residual histories were not archived, making it impossible to confirm that iterative errors are bounded at MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup reviewed by an independent analyst; checklist-based QA process applied to all user-defined parameters.",
      "rationale": "No independent review of simulation setup was performed and no QA checklist was applied; user-defined turbulence model coefficients and hemolysis model constants were not cross-checked, representing an unquantified epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification provided for choice of hemolysis power-law model versus mechanistic red blood cell damage models; sensitivity to model form documented.",
      "rationale": "The power-law Giersiepen-Wurzinger hemolysis model was adopted without documented justification or comparison against alternative mechanistic models; model-form uncertainty is entirely uncharacterised at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty distributions assigned to all material and geometric input parameters; Monte Carlo or equivalent propagation performed and documented.",
      "rationale": "Although Monte Carlo uncertainty quantification is referenced in the study description, input uncertainty distributions for blood viscosity, hematocrit, and pump geometry tolerances were not formally characterised or archived, leaving this factor unassessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to establish statistical confidence in measured hemolysis index; inter-sample variability reported.",
      "rationale": "The number of experimental replicates used in the validation dataset is not reported and inter-sample variability in hemolysis measurements is not documented, precluding statistical assessment of test sample adequacy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrated to be equivalent to experimental conditions within quantified tolerances; any deviations explicitly justified.",
      "rationale": "No formal equivalency analysis between simulation inputs and experimental conditions was performed; discrepancies in rotational speed, inlet turbulence intensity, and fluid temperature between CFD and bench test remain unresolved."
    }
  ],
