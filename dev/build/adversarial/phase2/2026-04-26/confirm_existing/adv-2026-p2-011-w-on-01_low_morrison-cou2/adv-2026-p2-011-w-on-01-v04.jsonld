  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with version-controlled regression tests and formal release process.",
      "rationale": "Commercial CFD solver has basic regression suite but lacks formal medical-device release documentation. Achieved level falls short of MRL-5 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent must demonstrate second-order spatial accuracy for all governing equations.",
      "rationale": "Order-of-accuracy testing performed on simplified geometries only; pump-specific rotating-frame equations not independently verified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be below 5% for hemolysis index QoI on at least three systematically refined meshes.",
      "rationale": "Three-mesh Richardson extrapolation yields GCI of 8.4% for hemolysis index, exceeding the 5% threshold. Spatial discretization error is not fully controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within stated uncertainty bounds.",
      "rationale": "Inlet velocity profiles measured at 3 cm upstream; CFD uses fully-developed profile assumption. Discrepancy in turbulence intensity not quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of agreement for hemolysis index must exceed 0.90 across all tested operating points.",
      "rationale": "Normalized index of agreement is 0.74 across six operating points. Model over-predicts hemolysis at low flow rates and under-predicts at high shear conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be directly traceable to clinical hemolysis endpoint with documented sensitivity analysis.",
      "rationale": "Hemolysis index is a recognized surrogate; however, sensitivity of the power-law damage model exponents to QoI has not been fully characterized for this pump geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the operating envelope defined for the intended use, including hematocrit and viscosity ranges.",
      "rationale": "Validation performed at single hematocrit (40%) and single temperature (37°C). Patient-specific variability in blood rheology not represented in validation dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to reduce residuals by at least four orders of magnitude with no cyclic behavior in QoI.",
      "rationale": "Iterative convergence monitoring not formally documented for hemolysis QoI. Flagged as epistemic gap at MRL 5; assessment deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented user training protocol and simulation execution checklist must be in place for all analysts running production simulations.",
      "rationale": "No formal use-error analysis conducted. Analyst qualification records not available. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model for non-Newtonian blood rheology and hemolysis damage accumulation must be justified against literature benchmarks.",
      "rationale": "Newtonian viscosity assumption adopted for computational tractability. Carreau-Yasuda model sensitivity study performed but not incorporated in production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo UQ must propagate uncertainty in all material and boundary condition inputs through to hemolysis QoI with reported 95% confidence intervals.",
      "rationale": "Monte Carlo UQ initiated but incomplete; only rotational speed and inlet flow rate varied. Damage model coefficients treated as deterministic. Flagged as epistemic gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of three independent blood sample lots with documented donor variability must be used in experimental validation.",
      "rationale": "Single blood lot used in all benchtop experiments. Inter-donor variability not characterized. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument must demonstrate that validation test conditions are representative of intended operating conditions.",
      "rationale": "No formal equivalency mapping between benchtop test conditions and intended VAD operating envelope documented. Flagged as epistemic gap."
