  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all relevant flow regimes; independent code review completed.",
      "rationale": "The CFD solver is version-controlled and has a partial regression suite, but independent third-party review has not been completed. Achieved level 2 falls below required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on benchmark problems demonstrate expected convergence rates for all governing equation terms relevant to hemolysis prediction.",
      "rationale": "Order-of-accuracy testing was performed only on simplified channel flow benchmarks. Rotational body-force terms and turbulence model source terms were not independently verified. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study with GCI < 5% on hemolysis index QoI across at least three systematically refined meshes.",
      "rationale": "Three-level grid convergence study performed; GCI for hemolysis index is 8.3%, exceeding the 5% threshold. Spatial discretization error is quantified but not sufficiently controlled for MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with uncertainty bounds; inlet velocity profiles, fluid rheology, and temperature match simulation inputs within stated tolerances.",
      "rationale": "FDA pump bench tests used bovine blood with documented hematocrit range, but inlet velocity profiles were not measured directly — uniform inlet was assumed. Temperature was controlled to ±1°C. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel or validation uncertainty) computed for hemolysis index and pressure rise; statistical comparison accounts for experimental uncertainty.",
      "rationale": "Relative error on hemolysis index is 31% across five operating points. Pressure rise agreement is better (< 8%), but the primary QoI shows poor agreement. No formal validation uncertainty interval was computed. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation activities (hemolysis index, shear stress distribution) directly correspond to the decision-relevant outputs identified in the credibility assessment plan.",
      "rationale": "Hemolysis index is the primary QoI and is measured experimentally. However, local shear stress distributions — which drive the power-law hemolysis model — are not directly validated against experimental data. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments replicate VAD operating envelope (flow rate, rotational speed, fluid properties) to within defined similarity criteria; any extrapolation is explicitly bounded.",
      "rationale": "FDA generic pump geometry was used as a surrogate; actual VAD geometry and patient-specific operating conditions differ. Similarity arguments are qualitative only. Achieved level 2 due to absence of quantitative similarity metrics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual reduction of at least six orders of magnitude or by QoI stabilization across iterations; floating-point round-off assessed.",
      "rationale": "Iterative residuals were reported at four orders of magnitude reduction; QoI stabilization was not independently confirmed. Floating-point error analysis was not performed. Flagged as epistemic gap at MRL 5; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol with checklist; independent review of simulation setup by qualified analyst not involved in model development.",
      "rationale": "No independent review of simulation setup was conducted. Mesh generation and boundary condition assignment were performed by the same analyst who developed the model. Use error not formally assessed; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of turbulence model and hemolysis constitutive law; sensitivity study comparing at least two model forms for the primary QoI.",
      "rationale": "The k-omega SST turbulence model and Giersiepen power-law hemolysis model were selected without documented comparison against alternative model forms. Model form uncertainty is an identified epistemic gap. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters identified; probability distributions assigned and propagated through Monte Carlo UQ; Sobol sensitivity indices computed for hemolysis index.",
      "rationale": "Monte Carlo UQ was performed for five input parameters (viscosity, hematocrit, power-law exponents, rotational speed). Sobol indices were computed but only first-order indices reported; total-order indices omitted. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize aleatory variability in hemolysis measurements; statistical power analysis justifying sample size.",
      "rationale": "Three replicate experiments were performed per operating point. No statistical power analysis was conducted. Inter-sample variability in blood properties was not characterized. Flagged as epistemic gap; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental input parameters and simulation boundary conditions; discrepancies quantified and their impact on QoI bounded.",
      "rationale": "Experimental and simulation input parameters were matched nominally but no formal equivalency analysis was performed. Differences in blood analog rheology between bench and simulation were acknowledged but not quantified. Achieved level 1."
    }
  ],
