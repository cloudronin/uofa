  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, unit testing, and regression test suite covering hemolysis solver routines must be demonstrated at Gradation 4.",
      "rationale": "Version control and basic regression tests exist, but no formal unit testing framework covers the hemolysis damage accumulation subroutines. Achieved level falls two gradations below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent must confirm solver correctness for the coupled Navier-Stokes and power-law hemolysis model at Gradation 4.",
      "rationale": "Order-of-accuracy testing was performed for the flow solver only; the hemolysis sub-model was not subjected to manufactured-solution verification. Achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes with GCI reported for the hemolysis index QoI at Gradation 4.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI for hemolysis index is 8.4%, which exceeds the 5% threshold required for Gradation 4. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be fully characterised with uncertainty bounds propagated into simulation inputs at Gradation 4.",
      "rationale": "Inlet flow rate and outlet pressure were measured, but rotational speed uncertainty and fluid temperature variation during testing were not quantified. Achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., normalised RMSE) with combined experimental and numerical uncertainty bounds reported for hemolysis index at Gradation 4.",
      "rationale": "Hemolysis index predictions deviate from experimental values by up to 35% across operating points. Uncertainty bounds are not formally combined; achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated direct correspondence between simulated QoIs and clinically relevant hemolysis endpoints at Gradation 4.",
      "rationale": "Normalised index of hemolysis is the primary QoI and maps directly to plasma-free haemoglobin; however, sub-lethal platelet activation is not captured. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate clinical VAD operating envelope (flow rates 3–6 L/min, speeds 2400–3200 rpm) at Gradation 4.",
      "rationale": "Validation data were collected at a single operating point (5 L/min, 2500 rpm); the broader VAD envelope is not covered. Achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point error bounds must be documented and shown to be below discretization error at Gradation 4.",
      "rationale": "Solver convergence residuals were not systematically recorded across all operating points; this factor was flagged as an epistemic gap at MRL 5 and could not be assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification records and simulation execution checklists must be provided at Gradation 4.",
      "rationale": "No formal user qualification or execution checklist documentation was available for review. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic model-form uncertainty quantification comparing power-law and strain-based hemolysis models with experimental data at Gradation 5.",
      "rationale": "Only the Giersiepen-Wurzinger power-law model was used. No alternative model-form comparison was performed. Monte Carlo UQ was applied to model coefficients but not to model form selection. Achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full probabilistic characterisation of all hemolysis model coefficients and fluid rheology parameters with sensitivity indices at Gradation 5.",
      "rationale": "Monte Carlo sampling was applied to the three power-law coefficients; blood viscosity variability and red blood cell fragility distributions were not included. Achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterisation of blood sample donor variability and storage conditions affecting hemolysis baseline at Gradation 4.",
      "rationale": "Donor variability and sample storage data were not provided with the experimental dataset. Flagged as epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstrated equivalence between simulation input parameter distributions and the physical test article parameters at Gradation 4.",
      "rationale": "Pump geometry tolerances and surface roughness measurements from the physical test article were not available; equivalency between nominal CAD geometry and manufactured part could not be established. Flagged as epistemic gap."
    }
  ],
