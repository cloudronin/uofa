  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used in simulations must be version-controlled and validated per internal SOP. Achieved level meets required level.",
      "rationale": "Ansys Mechanical 2022 R1 and FDA in-house FEA code are under configuration management with documented release notes and regression test suites. Version control logs confirm no unauthorized modifications during the analysis period."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be reproduced within 1% for all solvers used.",
      "rationale": "All three FEA codes (FDA, Ansys, DePuy Synthes) were verified against NAFEMS benchmark LE1 and a cantilever beam with known Euler-Bernoulli solution. Maximum deviation was 0.4%, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of less than 2% between the penultimate and final refinement levels.",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw-rod-vertebral body assembly. QoI (stiffness, yield force) changed by less than 1.1% between the medium and fine meshes, confirming discretization error is within acceptable bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; energy balance error must be less than 0.1%.",
      "rationale": "Force and displacement residuals converged to 1e-8 across all 50 load increments. Energy balance error remained below 0.05% throughout. No divergence events were recorded across any of the 11 model instances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "An independent analyst must perform a documented peer review of all model setup files, boundary conditions, and load application prior to result extraction.",
      "rationale": "An independent FDA biomedical engineer reviewed all simulation input decks, confirming correct application of ASTM F1717 boundary conditions (fixed inferior vertebral body, displacement-controlled loading at superior body). No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model selected must be justified by material characterization data and sensitivity analysis demonstrating that alternative model forms change QoI by less than 5%.",
      "rationale": "Ti-6Al-4V alloy was modeled using a bilinear isotropic hardening plasticity law calibrated to tensile coupon data from the same material lot. Sensitivity analysis comparing linear elastic, bilinear, and Ramberg-Osgood forms showed less than 3% QoI variation, supporting the chosen model form."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured data with documented uncertainty estimates. Parametric sensitivity analysis required for all inputs with uncertainty coefficient of variation exceeding 5%.",
      "rationale": "Elastic modulus (114 GPa ± 3%), yield strength (880 MPa ± 4%), and geometry (nominal CAD with ±0.05 mm tolerance) are all traceable to material certificates and CMM reports. Sensitivity analysis confirmed yield force is most sensitive to yield strength, with a 1% change in yield strength producing a 0.9% change in predicted yield force."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be drawn from production-representative lots with documented traceability to device manufacturing records, and sample size must provide 80% power to detect a 10% QoI difference.",
      "rationale": "N=11 constructs were tested across two laboratories. While specimens are production-representative and traceable to manufacturing records, the sample size provides only approximately 65% statistical power to detect a 10% difference in yield force at alpha=0.05, falling short of the 80% power threshold required at Gradation 3. The test samples factor therefore achieves only Gradation 2, below the required Gradation 3 for this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate ASTM F1717 protocol including loading rate, environmental conditions, and fixture geometry. Laboratory-to-laboratory variability must be documented.",
      "rationale": "Both laboratories followed ASTM F1717 protocol with 5 mm/min displacement rate at ambient temperature. Inter-laboratory coefficient of variation for stiffness was 3.2%, within the pre-specified 5% threshold, confirming adequate test condition control."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to those present in the physical test, with documented mapping of each material property and geometric dimension.",
      "rationale": "A parameter equivalency matrix maps each FEA input (modulus, yield strength, screw geometry, rod diameter, set screw torque) to the corresponding measured or specified test parameter. All inputs confirmed equivalent within measurement uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric must be less than 1.96 for all QoIs, and percent difference must be less than 10%.",
      "rationale": "E/uval values were 1.12 (stiffness), 0.87 (yield force), and 1.43 (force at 40 mm), all below the 1.96 threshold. Percent differences were 4.1%, 2.8%, and 6.7% respectively, all within the 10% acceptance bound. Output comparison factor fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the clinical failure mode and the regulatory submission claim, with documented justification.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly correspond to the structural performance claims in the 510(k) submission. Clinical relevance is established through the linkage between construct stiffness and adjacent segment biomechanics documented in the predicate literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must match the COU in terms of loading mode, device configuration, and material system. Any differences must be assessed via sensitivity analysis.",
      "rationale": "Validation activities directly replicate the COU: identical non-cannulated 7.5 mm screw geometry, same Ti-6Al-4V alloy, ASTM F1717 compression-bending loading mode. No extrapolation from a surrogate geometry or loading mode was required, maximizing validation relevance."
    }
  ],
