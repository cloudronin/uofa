  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concludes that the FEA modeling framework achieves High assurance for predicting ASTM F1717 compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct. All three QoIs pass the quantitative validation acceptance criterion (E/uval < 1.96). The majority of credibility factors meet or exceed required levels. Two factors (Test conditions, Model inputs) achieved levels below required levels; however, the team judges that the strong quantitative agreement across all QoIs and the conservative acceptance bounds provide sufficient evidence to support an Accepted decision at High assurance. The shortfalls in Model inputs and Test conditions are considered compensated by the robust output comparison results.",
