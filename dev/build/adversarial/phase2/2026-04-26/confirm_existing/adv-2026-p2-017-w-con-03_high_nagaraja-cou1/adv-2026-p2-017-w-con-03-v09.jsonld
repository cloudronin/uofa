  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented SQA plan with version control, unit testing, and release validation records for Ansys Mechanical 2023 R1.",
      "rationale": "Ansys Mechanical 2023 R1 is a commercially validated FEA solver with ISO 9001-compliant SQA processes. Version control logs and release notes reviewed; no open defects affecting structural contact or nonlinear material response."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS suite reproduced within 1% of analytical solutions for linear elasticity and contact.",
      "rationale": "Three NAFEMS benchmark cases (LE1, LE10, contact patch test) executed in the deployed solver environment; all results within 0.6% of reference solutions, satisfying the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in QoIs between intermediate and fine mesh; Richardson extrapolation GCI < 1%.",
      "rationale": "Four mesh densities evaluated (coarse 0.8 mm, intermediate 0.5 mm, fine 0.3 mm, very fine 0.2 mm). QoI change between fine and very fine meshes: stiffness 0.9%, yield force 1.1%, force at 40 mm 0.8%. GCI < 0.7% for all QoIs. Final model uses fine mesh (0.3 mm element size at screw-rod interface)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force and moment equilibrium residuals < 0.1% at each converged load step; no unconverged increments.",
      "rationale": "Nonlinear solution employed full Newton-Raphson with automatic time stepping. Residual force norm < 0.05% across all 120 load steps in the reference simulation. No divergence or bisection events recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented analyst qualification records and independent peer review of model setup by a second qualified engineer.",
      "rationale": "Primary analyst holds M.S. in mechanical engineering with 6 years FEA experience in orthopedic devices. Model setup independently reviewed by a senior engineer; checklist of 47 items verified. No discrepancies found."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics (nonlinear contact, bilinear isotropic hardening for Ti-6Al-4V, rigid UHMWPE blocks) justified by literature and sensitivity analysis.",
      "rationale": "Nonlinear contact with friction (μ=0.2) at screw-rod interface and screw-block interface. Ti-6Al-4V modeled with bilinear isotropic hardening (E=114 GPa, σy=880 MPa, Et=1.14 GPa) from ASTM F136 coupon data. Sensitivity to friction coefficient (±0.1) showed <3% QoI change. Model form consistent with three published FEA studies of F1717 constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometry sourced from lot-specific coupon testing and CMM measurements; uncertainty propagated through model.",
      "rationale": "Geometry from CMM measurements of three production screws (mean ± 1σ reported). Material properties from tensile testing of five coupons from the same Ti-6Al-4V bar stock. Monte Carlo propagation (N=1000) of input uncertainties yields QoI 95th-percentile uncertainty < 4%, within the 10% acceptance bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs tested; samples traceable to same production lot as FEA geometry source.",
      "rationale": "N=11 constructs tested (Lab A: n=6, Lab B: n=5). All screws and rods from the same production lot (Lot 2023-NC-7.5). Certificate of conformance and dimensional inspection reports reviewed. Sample traceability confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of anticipated clinical loading; at least two load configurations evaluated.",
      "rationale": "Testing performed under a single load configuration (ASTM F1717 standard compression-bending at 10 mm/min crosshead displacement). Clinical loading envelope includes torsion and lateral bending not evaluated here. Achieved level 2 (single standardized condition) vs. required level 3; this shortfall is acknowledged and accepted given the regulatory precedent for F1717 as the primary design verification test."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Boundary conditions, loading, and geometry in FEA match test setup within documented tolerances; fixture compliance accounted for.",
      "rationale": "Test fixture geometry digitized by CMM and replicated in FEA. Applied displacement boundary conditions match crosshead displacement; machine compliance (0.3 mm/kN) subtracted from experimental load-displacement curves before QoI extraction. Grip friction modeled as fixed constraint consistent with experimental observation of no slip."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI percent difference < 10% and E/uval < 1.96 for all three QoIs.",
      "rationale": "Stiffness: 4.2% difference, E/uval=0.87. Yield force: 6.8% difference, E/uval=1.31. Force at 40 mm: 7.1% difference, E/uval=1.44. All three QoIs satisfy both acceptance criteria. Combined validation metric (area validation metric) = 0.94, indicating good agreement across the full load-displacement curve."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission metrics and clinical failure modes (stiffness loss, yielding, large deformation).",
      "rationale": "Three QoIs (construct stiffness, yield force, force at 40 mm displacement) are the standard F1717 reportable metrics required by FDA guidance and directly relate to in vivo failure modes: loss of fixation stiffness, permanent deformation from yielding, and catastrophic bending failure."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, material, and loading are representative of the COU device and use environment.",
      "rationale": "Validation uses production-representative non-cannulated 7.5 mm screws and 5.5 mm rods in the ASTM F1717 standardized UHMWPE block fixture. The COU is FDA 510(k) submission for the same device family under the same test standard. Validation scenario is directly applicable to the COU without extrapolation."
    }
