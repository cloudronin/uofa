  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-nagaraja",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed the required gradation level. One factor (Test conditions) achieves Gradation 2 against a required level of 3, reflecting the use of a single ASTM F1717 test condition. This gap is accepted because: (1) ASTM F1717 is the regulatory standard for this device class; (2) the single condition represents the worst-case loading scenario; and (3) all QoI meet the quantitative acceptance criteria with margin. The overall credibility evidence package is sufficient to support the Medium assurance level claim.",
