  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) operates under documented QMS with version control and regression testing suite covering all element types used in this analysis.",
      "rationale": "Ansys Mechanical 2022 R2 is deployed under ISO 9001-compliant QMS. Regression test suite (1,847 cases) executed at each release; all element types used in the pedicle screw model are covered. Software validation records on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks for nonlinear static structural analysis with contact demonstrate agreement with analytical solutions within 1% for canonical problems.",
      "rationale": "Ansys published verification manual benchmarks for nonlinear contact and large-deformation beam bending show agreement within 0.4–0.9% of analytical solutions. Benchmark suite reviewed and accepted as applicable to this model class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change of less than 2% between medium and fine mesh densities; GCI reported.",
      "rationale": "Three-level mesh refinement study performed on screw shank and pedicle block interface. QoI (stiffness, yield force) changed by 0.9% and 1.3% between medium (1.2M elements) and fine (2.8M elements) meshes. GCI = 0.6% for stiffness QoI. Medium mesh selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria tightened to 1e-5 relative norm; energy criterion monitored each substep.",
      "rationale": "Newton-Raphson iterations converged to residual norm < 1e-5 for all load steps. No divergence events recorded across 11 model runs. Energy criterion satisfied at each substep; no spurious contact penetration detected."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of model setup, boundary conditions, and post-processing scripts prior to result extraction.",
      "rationale": "Simulation workflow documented in controlled procedure FEA-SOP-0042 Rev C. Independent reviewer (senior FEA engineer not involved in model construction) verified boundary condition application, contact pair definitions, material assignments, and load application against ASTM F1717 test setup. No discrepancies identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified by literature and material coupon data; geometric fidelity to manufactured screw confirmed by CMM measurement comparison.",
      "rationale": "Ti-6Al-4V modeled as bilinear isotropic hardening; tangent modulus derived from coupon tensile tests (n=6, same lot as test constructs). CMM measurements of screw geometry confirm CAD-to-part deviation < 15 µm on critical cross-sections. UHMWPE block modeled as linear elastic within the load range of interest (< 5% strain); supported by DMA characterization data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry, and boundary conditions sourced from traceable measurements with uncertainty quantification; sensitivity analysis identifies dominant inputs.",
      "rationale": "Elastic modulus (114 GPa ± 2.1 GPa), yield strength (880 MPa ± 12 MPa), and tangent modulus (2.3 GPa ± 0.4 GPa) measured from same material lot. One-at-a-time sensitivity analysis shows stiffness QoI most sensitive to screw core diameter (±0.05 mm → ±3.1% stiffness). All dominant inputs bounded by measurement uncertainty propagated through model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test constructs manufactured from same design revision and material lot as simulation geometry; dimensional inspection confirms conformance.",
      "rationale": "All 11 test constructs assembled from screws manufactured from Ti-6Al-4V bar stock lot TG-2021-447, same revision level as CAD geometry used in FEA. CMM inspection of 3 randomly selected screws per lab confirmed dimensional conformance to drawing tolerances. UHMWPE blocks sourced from single supplier lot; Shore D hardness verified within specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicated across at least two loading rates or environmental conditions to bound model applicability; FEA boundary conditions match test fixture constraints.",
      "rationale": "Testing performed under a single quasi-static loading rate (25 mm/min) per ASTM F1717. FEA boundary conditions replicate fixture constraints (fixed inferior block, displacement-controlled superior block). Achieved level 2 rather than 3 because only one test condition (loading rate) was evaluated; rate sensitivity not characterized. This shortfall is noted and accepted given quasi-static nature of the application."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters (geometry, material properties, boundary conditions) demonstrably equivalent to experimental test article and setup within quantified tolerances.",
      "rationale": "Direct traceability established between FEA inputs and measured test article properties. Screw geometry: CMM-verified. Material properties: same lot coupon data. Fixture constraints: replicated via rigid body constraints matching measured fixture stiffness (> 50× screw construct stiffness). Equivalency table documented in validation report VR-NAG-2024-01."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (percent difference and E/uval) computed for all three QoIs; all values satisfy pre-specified acceptance bounds.",
      "rationale": "Three QoIs compared: construct stiffness (4.3% difference, E/uval = 0.81), yield force (6.1%, E/uval = 1.14), force at 40 mm displacement (7.8%, E/uval = 1.52). All satisfy pre-specified bounds of < 10% and E/uval < 1.96. Comparison methodology follows ASME V&V 40 Section 5.4 with validation uncertainty computed from experimental repeatability and model input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical risk drivers (construct stiffness relates to adjacent segment load; yield force relates to fatigue life initiation; force at 40 mm relates to gross failure).",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly relevant to the regulatory submission. Stiffness governs load transfer to adjacent spinal segments; yield force is the primary fatigue life predictor; force at 40 mm represents gross structural failure threshold. All three are used in the predicate device comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the same screw design, loading mode, and construct configuration as the COU; inter-laboratory reproducibility demonstrated.",
      "rationale": "Validation performed on the exact non-cannulated 7.5 mm pedicle screw design under ASTM F1717 compression-bending — the identical loading mode and construct configuration as the COU. Two independent laboratories (Lab A: n=6, Lab B: n=5) demonstrate inter-laboratory reproducibility (CV < 4% for all QoIs). No extrapolation beyond validated domain required for the COU."
    }
  ],
