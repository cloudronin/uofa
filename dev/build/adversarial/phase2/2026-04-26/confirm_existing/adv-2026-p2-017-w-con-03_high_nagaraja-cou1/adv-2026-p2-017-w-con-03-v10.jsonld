  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-f1717-cb-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-nagaraja",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "12 of 13 V&V 40 credibility factors meet or exceed the required level. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that the single-condition ASTM F1717 protocol is the regulatory standard for this device class and that the output comparison criterion is satisfied across all three QoIs with margin. Overall model credibility is judged sufficient to support a Medium assurance level regulatory submission for the non-cannulated 7.5 mm pedicle screw construct.",
