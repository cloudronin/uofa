  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software must operate under a documented quality management system with version control and regression testing records.",
      "rationale": "Ansys Mechanical 2023 R1 used under ISO 9001-certified QMS at DePuy Synthes. Version-controlled simulation environment with regression test suite documented in SQA-FEA-2023-011. Achieved level matches required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be solved to confirm correct solver implementation for relevant physics.",
      "rationale": "Cantilever beam and Hertzian contact benchmarks executed against analytical solutions; maximum error 0.3%. Contact formulation verified against NAFEMS benchmark LE10. Code verification documented in report VER-FEA-2023-004."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of less than 5% between successive refinements.",
      "rationale": "Three-level mesh refinement study (coarse 1.2 mm, medium 0.8 mm, fine 0.5 mm element edge at screw-rod interface). Stiffness QoI changed 1.8% from medium to fine; yield force changed 2.1%. Richardson extrapolation applied; GCI < 3%. Final mesh at medium refinement adopted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals must converge to tolerance 1e-6 for each load increment; Newton-Raphson iteration count documented.",
      "rationale": "Implicit nonlinear solver with force residual tolerance 1e-6. Maximum iteration count per increment: 12. No unconverged increments across all 11 model runs. Solver log archived in SIM-LOG-2023-NC-001 through SIM-LOG-2023-NC-011."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation execution must follow a documented procedure with independent review of boundary condition setup and loading definitions.",
      "rationale": "Simulation execution procedure SOP-SIM-003 followed for all runs. Boundary conditions (fixed lower block, displacement-controlled upper block per ASTM F1717 §8) independently reviewed by second engineer. Checklist records archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics must capture dominant load-transfer mechanisms including screw-rod contact, set-screw preload, and cortical block bearing; justification required for any physics omitted.",
      "rationale": "Nonlinear static FEA with frictional contact (μ=0.2 Ti-Ti, μ=0.15 Ti-PEEK) at screw-rod and screw-block interfaces. Set-screw preload applied as bolt pretension. Bone block modeled as rigid per ASTM F1717. Viscoelastic effects omitted — justified by quasi-static loading rate (5 mm/min). Model form assessed at level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured values with uncertainty quantification; sensitivity analysis required for inputs contributing >5% QoI variance.",
      "rationale": "Ti-6Al-4V elastic modulus 114 GPa (measured lot-specific, CV 1.2%), yield strength 880 MPa (lot-specific tensile test). Geometry from CMM-verified CAD. Sensitivity analysis (one-at-a-time ±10%) identified modulus and set-screw torque as dominant inputs; propagated uncertainty incorporated into E/uval calculation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be representative production parts with dimensional verification and material certification traceable to the modeled configuration.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from production lots with full material certs (Ti-6Al-4V per ASTM F136). CMM dimensional inspection confirmed all critical dimensions within ±0.05 mm of nominal CAD. Specimens span two production lots to capture inter-lot variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must replicate the COU loading environment; multiple loading configurations or rates required to reach level 3.",
      "rationale": "Testing performed at a single displacement rate (5 mm/min) and single construct configuration per ASTM F1717. While temperature and humidity controlled, no variation in loading rate or construct geometry was explored. Achieved level 2 due to single test condition — this factor falls below required level 3 and constitutes a known limitation of the current validation activity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs used for validation simulations must match measured specimen properties and test setup parameters; any discrepancies must be quantified.",
      "rationale": "Specimen-specific measured dimensions and lot-specific material properties used as FEA inputs for each of the 11 validation runs. Set-screw torque matched to test protocol value (4 Nm) with torque wrench calibration records. Input equivalency confirmed for all 11 specimen-simulation pairs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) must be computed for all QoIs; E/uval < 1.96 required for acceptance.",
      "rationale": "E/uval computed per ASME V&V 40 §6.5 for stiffness (0.84), yield force (1.12), and force at 40 mm displacement (1.31). All three QoIs satisfy E/uval < 1.96. Percentage differences: stiffness 3.2%, yield force 4.7%, force at 40 mm 1.5%. All within 10% acceptance bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the QoIs required for the COU decision; traceability from COU to validation QoI required.",
      "rationale": "COU requires prediction of construct stiffness, yield force, and force at 40 mm displacement — identical to the three validation QoIs. Traceability matrix QOI-TRACE-2023-001 documents direct correspondence. No surrogate QoIs employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must match the COU in device geometry, loading mode, and regulatory context; deviations must be formally justified.",
      "rationale": "Validation performed on production non-cannulated 7.5 mm pedicle screws under ASTM F1717 compression-bending — identical geometry, loading mode, and test standard as the COU. Two independent laboratories provide cross-site reproducibility evidence. Validation scenario relevance assessed at level 3 with no material deviations from COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is offset by the strength of the multi-laboratory experimental dataset (N=11) and the conservative acceptance bounds applied. All three QoIs satisfy E/uval < 1.96 and the 10% difference criterion. The assessment team accepts the FEA framework as sufficiently credible for the stated COU.",
