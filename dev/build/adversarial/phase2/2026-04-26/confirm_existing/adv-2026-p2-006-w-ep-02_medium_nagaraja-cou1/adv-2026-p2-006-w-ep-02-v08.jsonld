  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3. The single deficient factor (Test conditions, achieved level 2 vs. required level 3) is accepted because the regulatory submission scope is explicitly restricted to the ASTM F1717 standard 50 mm offset configuration, and no extrapolation to other conditions is claimed. All three QoIs satisfy quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%) across the three-institution FEA ensemble and N=11 experimental constructs. The FEA modeling framework is assessed as sufficiently credible to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw system.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
