  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility level. One factor (Test conditions) achieved level 2 against a required level 3, reflecting the single-condition ASTM F1717 test protocol; this gap is accepted given the submission scope is limited to static compression-bending and the remaining factors provide sufficient aggregate credibility for a Medium model risk, Medium decision consequence context. Quantitative validation acceptance criteria (E/uval < 1.96, percent difference < 10%) satisfied for all three primary QoIs across N=11 constructs at two independent laboratories. Overall credibility is sufficient to support regulatory use of FEA predictions for the non-cannulated pedicle screw compression-bending COU.",
