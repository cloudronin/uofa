      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1×10⁻⁶ for all load steps; energy balance checked at each increment.",
      "rationale": "All simulations used direct sparse solvers (PARDISO) with double-precision arithmetic. Force and displacement residuals converged to 1×10⁻⁸ or better at each increment. Energy balance errors below 0.01% throughout loading. Numerical solver error contribution to total uncertainty estimated negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
