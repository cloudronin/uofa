  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software must have documented version control, regression testing, and release notes consistent with Gradation 2 or higher.",
      "rationale": "All three FEA codes (FDA in-house, Ansys Mechanical 2023 R1, DePuy Synthes proprietary v4.2) operate under formal software quality management systems with documented version control, regression test suites, and release qualification records. Ansys and DePuy Synthes codes are commercially validated; FDA in-house code is under ISO 9001-aligned QMS. Achieved level 3 exceeds required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be solved to confirm correct implementation of governing equations.",
      "rationale": "Each FEA code was verified against NAFEMS benchmark problems relevant to structural mechanics (beam bending, contact patch tests). Results matched analytical solutions within 0.5% for all benchmarks. Required and achieved level both 2; criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change less than 2% between successive refinements.",
      "rationale": "Mesh convergence study performed on the pedicle screw construct model across three refinement levels (coarse: ~45k elements, medium: ~120k elements, fine: ~310k elements). QoI change between medium and fine meshes was 0.8% for stiffness, 1.1% for yield force, and 1.4% for force at 40 mm. All below 2% threshold. Medium mesh adopted for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver convergence criteria must be documented and residuals must fall below established thresholds for all production runs.",
      "rationale": "Nonlinear static analyses used Newton-Raphson iteration with force residual tolerance 1e-4 and displacement residual tolerance 1e-5. All 33 production runs (11 constructs × 3 codes) converged within 50 increments. No divergence events recorded. Energy balance checked post-solution; artificial energy below 1% of total internal energy in all cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs and boundary conditions must be reviewed by an independent analyst prior to production runs.",
      "rationale": "Model setup (geometry, material assignments, boundary conditions, loading protocol) was independently reviewed by a second analyst at each participating organization before production runs commenced. Review checklists were retained. No use errors identified during review; one minor boundary condition clarification resolved prior to final runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions must be documented and justified relative to the physics of the COU; sensitivity to key assumptions must be assessed.",
      "rationale": "Model uses continuum solid elements with isotropic linear-elastic titanium alloy properties for the screw and UHMWPE block material for the ASTM F1717 test block surrogate. Geometric nonlinearity enabled to capture large-displacement bending response. Model form assumptions (no plasticity initiation prior to yield force, frictionless screw-block interface) were assessed via sensitivity analyses; yield force QoI changed by less than 1.5% when friction coefficient varied from 0 to 0.2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured values; uncertainty in inputs must be quantified.",
      "rationale": "Titanium alloy (Ti-6Al-4V ELI) elastic modulus and yield strength sourced from coupon tensile tests on production lot material (mean E = 114.2 GPa, CV = 1.3%). UHMWPE block modulus sourced from supplier datasheet with confirmed lot testing. Screw geometry digitized from CMM measurements of production screws. Input uncertainty propagated via Latin hypercube sampling (n=200 runs per code); contribution to QoI uncertainty below 2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the device population; sample size must be sufficient to characterize variability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab 1: n=6, Lab 2: n=5). Screws drawn from production lot with documented traceability. Coefficient of variation for stiffness across all 11 constructs was 3.8%, indicating low manufacturing variability. Sample size sufficient to estimate mean QoIs with 95% confidence interval half-width below 5% of mean."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of conditions represented in the COU; multiple loading rates or configurations should be evaluated.",
      "rationale": "Testing performed under a single quasi-static loading rate (1 mm/min displacement control) per ASTM F1717. The COU is limited to quasi-static compression-bending, so rate variation is not directly required; however, only one test configuration (standard ASTM F1717 block geometry) was used. No variation in block material lot, crosshead speed, or laboratory environmental conditions was systematically explored. Achieved level 2 is below required level 3; this gap is acknowledged and accepted given the prescriptive nature of the ASTM standard and the low sensitivity of titanium constructs to quasi-static rate variation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs must be demonstrably equivalent to experimental conditions; any discrepancies must be quantified and their effect on QoIs assessed.",
      "rationale": "FEA boundary conditions replicated the ASTM F1717 fixture geometry as measured by CMM at each laboratory. Applied displacement matched crosshead displacement records from test data acquisition systems. Block material properties assigned from same lot as tested samples. Discrepancy between simulated and actual fixture compliance estimated at less than 0.3 N/mm; effect on stiffness QoI below 0.2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric must be pre-specified; comparison must account for experimental and simulation uncertainty.",
      "rationale": "Pre-specified acceptance bounds: percent difference between FEA ensemble mean and experimental mean below 10% for each QoI; E/uval ratio below 1.96. Validation uncertainty uval computed per ASME V&V 40 Section 5 combining experimental standard uncertainty and simulation numerical uncertainty. All three QoIs passed both criteria. Maximum percent difference: 3.1% (force at 40 mm). Maximum E/uval: 0.88 (force at 40 mm)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be the same as or directly predictive of QoIs required by the COU.",
      "rationale": "The three validation QoIs (construct stiffness, yield force, force at 40 mm displacement) are identical to the QoIs specified in the COU intended use statement. No surrogate or proxy QoIs used. Direct one-to-one correspondence between validation outputs and decision-relevant model outputs confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must match the COU in terms of device geometry, loading mode, and regulatory context.",
      "rationale": "Validation activities directly replicate the COU scenario: non-cannulated 7.5 mm pedicle screw, ASTM F1717 static compression-bending, production-representative device geometry and material. No extrapolation from a surrogate geometry or loading mode required. Regulatory context (Class II 510(k) submission support) consistent between validation design and COU definition."
    }
