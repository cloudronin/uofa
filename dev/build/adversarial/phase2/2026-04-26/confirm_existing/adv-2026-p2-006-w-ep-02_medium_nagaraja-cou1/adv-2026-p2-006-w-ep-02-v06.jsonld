  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling ensemble meets or exceeds required credibility levels for 12 of 13 V&V 40 factors. The single shortfall in Test conditions (achieved Gradation 2 vs. required Gradation 3) is accepted because the ASTM F1717 compression-bending configuration directly corresponds to the COU loading scenario and no other loading mode is within the scope of the intended use. All six quantitative output comparisons satisfy E/uval < 1.96 and relative error < 10%. The credibility evidence is sufficient to support the regulatory submission decision.",
