    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear-elastic continuum mechanics with frictional contact; model form appropriate for pre-yield compression-bending regime.",
      "rationale": "The construct operates in the pre-yield regime for the primary QoIs (stiffness and yield force). Linear-elastic material models with von Mises yield criterion are well-established for titanium alloy implants in this loading regime. Frictional contact (mu=0.3) at screw-rod interface is consistent with published tribological data for Ti-6Al-4V on Ti-6Al-4V."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from MMPDS-12 and coupon testing; geometric dimensions from CMM measurements of production hardware.",
      "rationale": "Elastic modulus (114 GPa) and yield strength (880 MPa) for Ti-6Al-4V ELI were taken from MMPDS-12 with lot-specific coupon test confirmation. Geometric dimensions were obtained from CMM measurements of three production screws and one rod, with tolerances propagated as uncertainty bounds. Input uncertainty quantified and included in E/uval calculation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production-representative constructs tested; sample traceability documented; no outliers excluded without justification.",
      "rationale": "Eleven constructs assembled from production hardware (same lot as clinical devices) were tested across two laboratories. Full traceability records (lot numbers, assembly torque, dimensional inspection) were maintained. No samples were excluded; the full dataset was used for comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of anticipated clinical loading; at minimum two load levels or boundary condition variants tested.",
      "rationale": "Testing was performed under a single ASTM F1717 load configuration (500 N axial compressive preload, quasi-static ramp). While this condition is the regulatory standard, it does not span the full range of anticipated clinical loading modes. Achieved level is 2 (single condition tested); required level is 3. This gap is acknowledged and accepted given the regulatory context of ASTM F1717 as the reference standard."
    },
