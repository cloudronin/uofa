    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup; documented analysis plan reviewed and signed off by two senior analysts.",
      "rationale": "The FEA model setup was independently reviewed by a second analyst not involved in model construction. Boundary conditions, material assignments, and contact definitions were verified against the documented analysis plan. No discrepancies were identified during the review."
