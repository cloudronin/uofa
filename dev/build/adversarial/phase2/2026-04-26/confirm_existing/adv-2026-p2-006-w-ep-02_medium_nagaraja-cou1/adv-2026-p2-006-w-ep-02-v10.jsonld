  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility levels. One factor (Test conditions) achieved level 2 against a required level of 3, reflecting the single-rate, ambient-temperature test protocol. This gap is accepted because the COU is explicitly scoped to quasi-static FEA prediction under ASTM F1717 conditions, the modeling framework does not claim to represent rate-dependent or thermal effects, and the six validation comparisons all satisfy quantitative acceptance criteria (E/uval < 1.96, percent difference <10%). The overall credibility of the FEA model for the stated COU is judged sufficient to support a Medium assurance level decision. The package is accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
