  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-mrl5-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-engineer",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven of thirteen credibility factors are assessed and meet or approach required levels. The package is accepted for regulatory submission based on the assessed factors demonstrating adequate CFD fidelity for hemolysis prediction. Three factors (Numerical solver error, Use error, Test samples) remain not-assessed; this gap is acknowledged but not formally justified relative to the MRL 5 risk level. Model form factor achieved level 2 against a required level of 3; this shortfall is noted without remediation.",
