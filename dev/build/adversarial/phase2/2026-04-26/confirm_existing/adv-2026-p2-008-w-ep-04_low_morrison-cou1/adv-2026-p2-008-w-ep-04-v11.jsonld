  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022 R2 is used under ISO 9001-certified QMS. Regression tests for rotating machinery and shear-driven hemolysis models are documented and passing. Achieved level meets required level for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions.",
      "rationale": "Code verification performed against Taylor-Couette flow and lid-driven cavity benchmarks. Residuals and error norms confirm correct numerical implementation. Required level achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for shear stress quantities of interest across the operating envelope.",
      "rationale": "Three-level mesh refinement study performed. GCI for wall shear stress and turbulent dissipation rate is below 3.8% at all five operating points. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within documented tolerances for flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA benchmark experimental data collected at 2500 and 3500 RPM across five flow rates. Inlet boundary conditions match experimental measurements within 2% for flow rate and 0.5% for rotational speed. Fluid viscosity matched to bovine blood at 37°C."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) must agree with experimental measurements within 15% across all operating points.",
      "rationale": "RH predictions agree with FDA experimental measurements within 11% at all five flow-speed combinations. Systematic over-prediction of 6% noted at low-flow high-speed conditions, consistent with known turbulence model limitations at high shear."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (RH, peak shear stress, exposure time) must be directly linked to clinical hemolysis endpoints.",
      "rationale": "Relative hemolysis index directly maps to plasma-free hemoglobin levels used in clinical assessment. Peak shear stress and Lagrangian exposure time are established predictors of erythrocyte damage. QoI relevance is well-supported by literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, operating conditions, and fluid properties representative of the CPB COU.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry under CPB-representative flow rates (2–8 L/min) and rotational speeds (2500–3500 RPM). Bovine blood surrogate used with documented rheological equivalence to human blood."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative solver residuals and round-off error contributions to hemolysis QoI must be quantified and shown to be negligible relative to discretization error.",
      "rationale": "Solver convergence was monitored via residual plots but no formal quantification of iterative or round-off error contributions to the hemolysis index was performed. This factor was not assessed prior to package submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-introduced errors in model setup, boundary condition assignment, and post-processing must be evaluated through independent review or cross-check procedures.",
      "rationale": "No independent cross-check or second-analyst review of model setup was conducted. Use error assessment was deferred and not completed before the credibility package was finalized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model must be justified for the flow regimes encountered in the CPB pump.",
      "rationale": "SST k-omega turbulence model selected based on prior literature for rotating machinery. Power-law hemolysis damage model (Giersiepen) applied without sensitivity analysis to model form uncertainty. Achieved level falls below required level, representing a known gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometric parameters, and boundary conditions must be documented with associated uncertainties.",
      "rationale": "Blood viscosity, density, and pump geometry are documented with measurement uncertainties. Inlet flow rate uncertainty of ±2% and rotational speed uncertainty of ±0.5% propagated through sensitivity analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of test fluid samples (bovine blood or surrogate) must confirm rheological properties match target population within specified tolerances across all test replicates.",
      "rationale": "Rheological characterization of the bovine blood batches used in the FDA benchmark experiments was not independently verified by the modeling team. Sample-to-sample variability in hematocrit and viscosity was not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD model input parameters must be demonstrably equivalent to those used in the validation experiments to support transferability of validation evidence to the COU.",
      "rationale": "Geometric equivalency confirmed via CAD comparison with FDA pump drawings. Operating condition equivalency documented in boundary condition mapping table. Fluid property equivalency assessed via viscosity matching at 37°C."
    }
  ],
