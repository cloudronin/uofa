      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and issue tracking consistent with MRL 5 requirements.",
      "rationale": "ANSYS Fluent 2022R2 is used under an established SQA plan including version-controlled input files, regression test suite, and documented bug reports. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via benchmark problems with known analytical solutions.",
      "rationale": "Code verification performed against lid-driven cavity and pipe flow benchmarks. Observed order of convergence matches theoretical order. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (hemolysis index) across at least three mesh refinement levels.",
      "rationale": "Three-level mesh refinement study performed. GCI for normalized hemolysis index is 2.1%, well within the 5% acceptance threshold. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "Experimental test conditions must match simulated operating conditions within stated tolerances for flow rate, rotational speed, and fluid properties.",
      "rationale": "Experimental conditions from FDA benchmark dataset replicated within 1.5% for flow rate and 0.8% for rotational speed. Fluid viscosity and density measured at test temperature. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all five operating points.",
      "rationale": "Mean absolute error across five flow-speed combinations is 9.3%. All individual predictions fall within the 15% acceptance band. Statistical comparison using Bland-Altman analysis shows no systematic bias."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoIs used in validation (normalized hemolysis index, shear stress distribution) must directly correspond to the decision-driving outputs in the COU.",
      "rationale": "Normalized hemolysis index (NIH) and volume-averaged scalar shear stress are the primary validation QoIs and are directly used in the regulatory submission comparison against the predicate device. Full correspondence established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation activities must cover the geometry, flow regime, and fluid properties relevant to the CPB COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under physiologically representative hematocrit and viscosity conditions. Reynolds number range in validation overlaps with COU operating envelope. Validation domain adequately spans the COU."
