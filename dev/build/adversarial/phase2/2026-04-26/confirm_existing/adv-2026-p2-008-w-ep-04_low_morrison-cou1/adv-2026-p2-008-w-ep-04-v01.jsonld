    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental values within 15% across all five operating points.",
      "rationale": "Mean absolute percentage error across the five operating points is 9.4%. All individual predictions fall within the 15% acceptance band. Results documented in validation report VAL-2025-11."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH and relative hemolysis index RH) must be directly traceable to the clinical hemolysis endpoint and the regulatory acceptance criterion RH < 1.",
