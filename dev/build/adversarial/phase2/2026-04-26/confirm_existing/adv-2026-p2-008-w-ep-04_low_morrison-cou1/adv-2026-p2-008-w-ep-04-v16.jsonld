  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software quality plan documented; version control and regression testing in place.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is under formal version control. A software quality assurance plan covering build verification, regression test suites, and change management has been reviewed and approved. Achieved level meets the required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy tests pass for relevant flow regimes; manufacturer verification documentation reviewed.",
      "rationale": "Order-of-accuracy benchmarks for the Navier-Stokes solver were reproduced on canonical Taylor-Green vortex and lid-driven cavity cases. Observed convergence rates match theoretical second-order accuracy. Manufacturer verification documentation for turbulence model implementations was reviewed and found adequate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QOI; Richardson extrapolation applied.",
      "rationale": "Three systematically refined meshes (4.2M, 11.6M, 28.4M cells) were used to compute GCI. The hemolysis index QOI showed GCI of 2.8% between fine and medium meshes, satisfying the acceptance criterion. Richardson extrapolation was applied to estimate the continuum limit. Achieved level exceeds required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental boundary conditions match CFD inlet/outlet conditions within ±5%; fluid temperature and hematocrit documented.",
      "rationale": "Experimental test conditions from the FDA benchmark dataset were reproduced in the CFD model. Inlet flow rates, rotational speeds, and outlet pressures were matched within ±3%. Blood analog fluid properties (viscosity, density, hematocrit 40%) were documented and applied consistently."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Normalized hemolysis index prediction error < 15% across all 5 operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) was compared against experimental measurements at all 5 flow-speed combinations. Maximum prediction error was 11.4%, within the 15% acceptance threshold. Systematic overprediction at high flow rates was noted but remained within bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "QOIs directly map to the regulatory acceptance criterion (RH < 1) and clinical hemolysis endpoints.",
      "rationale": "The primary QOI (relative hemolysis index RH) directly supports the regulatory decision criterion. Secondary QOIs (shear stress distribution, exposure time) are mechanistically linked to red blood cell damage. The mapping from CFD outputs to clinical endpoints is documented in the hemolysis model derivation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation experiments use the same pump geometry, operating range, and blood analog as the COU.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry identical to the COU device. Operating conditions span the full clinical flow-speed envelope. Blood analog properties match COU specifications. The validation hierarchy adequately covers the physics relevant to the hemolysis prediction task."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals < 1e-5 for all equations; mass imbalance < 0.01%.",
      "rationale": "Numerical solver error assessment was not completed prior to submission. Convergence monitoring logs were not archived in a retrievable format, and no formal evaluation of iterative solver error contribution to the hemolysis QOI was performed. This factor is not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary condition assignment, and post-processing scripts by a second analyst.",
      "rationale": "An independent review of model setup and post-processing procedures was planned but not executed within the project timeline. No documentation of use-error checks, such as boundary condition audit trails or post-processing script verification, is available. This factor remains not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of hemolysis predictions to turbulence model selection (SST k-omega vs. RSM) quantified; power-law hemolysis model uncertainty bounded.",
      "rationale": "Model form uncertainty arising from turbulence model selection and the power-law hemolysis damage model was not formally assessed. Alternative turbulence closures were not evaluated, and the sensitivity of the NIH prediction to hemolysis model exponent uncertainty was not quantified. This factor is not-assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Uncertainty in blood rheological properties and pump geometry tolerances propagated to QOI; sensitivity indices documented.",
      "rationale": "Uncertainty in blood viscosity (±8%), density (±1%), and pump clearance dimensions (±0.05 mm) was propagated through the CFD model using a one-at-a-time sensitivity study. The hemolysis index showed greatest sensitivity to impeller tip clearance. Sensitivity indices are documented in the supporting analysis report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Minimum 3 independent experimental replicates per operating point; inter-laboratory variability documented.",
      "rationale": "The FDA benchmark dataset provides 3-5 independent experimental replicates per operating point across two participating laboratories. Inter-laboratory variability was characterized and found acceptable. Sample preparation protocols for the blood analog are documented and traceable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and COU device inputs documented with quantified similarity metrics.",
      "rationale": "A formal equivalency assessment mapping validation experiment input parameters to the COU device operating parameters was not completed. While the same pump geometry was used, differences in blood analog composition between validation and COU conditions were not formally quantified or bounded. This factor is not-assessed."
    }
  ],
