  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Eleven of thirteen factors meet or exceed required levels. Two factors (Discretization error, Test conditions) achieve one gradation below required level; both gaps are documented and accepted given conservative acceptance bounds and the restricted COU scope. All three QoIs satisfy pre-specified acceptance criteria (E/uval < 1.96; percent difference < 10%) across N=11 constructs at two independent laboratories. The FEA modeling framework is accepted as credible for predicting compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 static loading.",
