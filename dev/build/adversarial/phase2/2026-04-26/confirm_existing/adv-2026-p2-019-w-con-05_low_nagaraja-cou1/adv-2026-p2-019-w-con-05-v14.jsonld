  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted given that the single ASTM F1717 load configuration represents the regulatory submission scenario and that all quantitative acceptance criteria (E/uval < 1.96, QoI difference < 10%) are satisfied across all three QoIs. The FEA modeling framework is judged sufficiently credible to support the regulatory decision for the non-cannulated 7.5 mm pedicle screw compression-bending performance claim.",
