  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors met or exceeded the required credibility level. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is acknowledged and bounded by the conservative nature of static testing relative to in vivo dynamic loading. All three QoIs satisfied the pre-established acceptance bounds (E/uval < 1.96 and percent difference < 10%). The overall credibility evidence is sufficient to support the intended regulatory use of the FEA model for the non-cannulated pedicle screw compression-bending COU.",
