    }
  ],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software used in the analysis must be under version control with documented verification tests and a traceable release history.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated FEA solver with ISO 9001-certified QA processes. The FDA in-house code and DePuy Synthes scripts are under git version control with unit tests covering all modules used in this analysis. Release notes and test logs are archived. RequiredLevel 2 achieved; AchievedLevel 3 due to additional inter-laboratory code comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code must pass standard benchmark problems relevant to structural mechanics with documented pass/fail records.",
      "rationale": "All three FEA codes were verified against NAFEMS benchmark LE1 and LE10 linear elasticity problems and a three-point bending beam with known closed-form solution. Maximum deviation from analytical solutions was 0.4%. Verification records are archived in the project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "A mesh convergence study must demonstrate QoI change of less than 2% between successive refinements, or Richardson extrapolation must be applied.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw shank and rod interface regions. QoI (stiffness, yield force) changed by 1.1% between medium and fine meshes. Richardson extrapolation confirmed discretization error contribution to uval is less than 0.8%. Final mesh uses approximately 285,000 elements with quadratic tetrahedral elements in high-stress regions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative solver convergence tolerances and residual norms must be documented and shown to be sufficient for the QoI precision required.",
      "rationale": "Solver convergence tolerances were set to Ansys defaults and were not independently reviewed or documented in the credibility evidence package. No residual norm histories were archived. This factor was not formally assessed prior to submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Analysis inputs and boundary conditions must be independently reviewed by a second qualified analyst.",
      "rationale": "Boundary conditions, material assignments, contact definitions, and load application were independently reviewed by a second FEA engineer not involved in model construction. Discrepancies identified during review were corrected prior to final simulation runs. Review checklist is archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The constitutive model and contact formulation must be appropriate for the expected deformation regime and validated against relevant literature.",
      "rationale": "Bilinear isotropic hardening plasticity (Ti-6Al-4V, E=114 GPa, yield 880 MPa, tangent modulus 1.2 GPa) was selected based on published material characterization data. Augmented Lagrangian contact with friction coefficient 0.2 at screw-rod interface. Model form appropriateness confirmed by comparison to published ASTM F1717 FEA studies in the literature. Sensitivity of QoI to friction coefficient variation (0.1–0.3) was less than 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured data or certified material specifications; uncertainty in inputs must be propagated.",
      "rationale": "Screw and rod geometry digitized from CMM measurements of production parts (tolerances ±0.01 mm). Material properties from certified mill certificates and supplemented by in-house tensile coupon testing (n=5). Uncertainty propagation via Monte Carlo (1000 samples) showed combined input uncertainty contribution to uval of 3.2% for stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Test specimens must be production-representative parts with documented dimensional and material traceability.",
      "rationale": "All 11 test constructs used production-released non-cannulated 7.5 mm pedicle screws and 5.5 mm cobalt-chrome rods from the same lot. Dimensional inspection confirmed parts within drawing tolerances. Material certifications retained. Specimens distributed across two independent laboratories to assess inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Test conditions must replicate the COU loading environment; multiple loading rates or conditions should be evaluated where clinically relevant.",
      "rationale": "Testing performed strictly per ASTM F1717 at a single displacement rate of 5 mm/min in ambient laboratory conditions. Only one test condition evaluated; no variation in loading rate or temperature was explored. AchievedLevel 2 is below RequiredLevel 3; this known gap is documented and accepted given the standardized nature of ASTM F1717 and the static loading COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Model input parameters must demonstrably correspond to the physical test conditions used for validation.",
      "rationale": "FEA boundary conditions were set to match the ASTM F1717 fixture geometry with dimensions taken from calibrated laboratory measurements. Applied displacement rate in quasi-static FEA is equivalent to the 5 mm/min test rate (inertial effects negligible at this rate). Correspondence between physical and model inputs formally documented in a parameter mapping table reviewed by both laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) must be computed for each QoI; E/uval < 1.96 required for all primary QoIs.",
      "rationale": "E/uval computed for all three primary QoIs: stiffness (1.31), yield force (1.44), force at 40 mm (1.18). All values below 1.96 threshold. Experimental uncertainty uval derived from inter-laboratory repeatability and measurement system analysis. Simulation uncertainty usim derived from discretization, input, and numerical contributions combined in quadrature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoIs used for validation must be the same as or directly predictive of the QoIs required for the regulatory decision.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three ASTM F1717 QoIs directly required for 510(k) substantial equivalence demonstration. These are identical to the QoIs predicted by the FEA model. No surrogate or proxy QoIs are used. High relevance confirmed by FDA guidance on spinal implant computational modeling."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The validation scenario must closely replicate the COU geometry, loading, and boundary conditions; any differences must be explicitly justified.",
      "rationale": "Validation activities directly replicate the COU: same device geometry (non-cannulated 7.5 mm screw), same test standard (ASTM F1717), same loading mode (compression-bending), same materials, and same regulatory context (510(k) submission). Inter-laboratory testing at two independent sites increases confidence in result generalizability. No significant differences between validation scenario and COU were identified."
    }
  ],
