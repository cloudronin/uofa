  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "Ansys Mechanical R2023 is a commercially validated solver with documented QA procedures. FDA-internal Abaqus installation is under ISO 13485-compliant software validation. Version control and audit trails confirmed for all three FEA environments used in the ensemble. Achieved Gradation 3: formal QA plan, documented testing, and change control in place."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "Benchmark problems from ASME V&V 10.1 suite (patch test, cantilever beam, Hertzian contact) executed in all three solver environments. Results agree with analytical solutions to within 0.5%. Code verification documented in model development report MDR-NC-001."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "Mesh convergence study performed on screw shank and rod-screw interface regions using Richardson extrapolation. QoI (stiffness, yield force) changed by less than 1.2% between medium and fine meshes. Final mesh contains 187,000 elements (C3D8 and C3D10); discretization error estimated at <2% of QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not evaluated in this submission cycle.",
      "rationale": "Solver convergence tolerances and iterative error accumulation for the nonlinear contact analysis were not formally quantified. The team relied on default solver settings without documenting residual norms or energy balance checks. This factor was deferred to a subsequent analysis cycle and has not been assessed for this package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "Model setup was independently reviewed by a second analyst. Boundary conditions, material assignments, and contact definitions were verified against the model development report. No discrepancies found. Peer review documented in review record RR-NC-003."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "Continuum mechanics with large-deformation kinematics (NLGEOM) and nonlinear contact (penalty method, friction coefficient 0.3) adopted. Titanium alloy (Ti-6Al-4V) modeled as bilinear isotropic hardening; UHMWPE block as elastic-perfectly plastic. Model form justified by comparison to published literature and prior FDA bench-to-FEA correlation studies for spinal implants."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "Material properties sourced from ASTM-certified coupon tests on the same lot of Ti-6Al-4V rod and screw material used in bench testing. Geometric inputs derived from CMM measurements of physical specimens (n=3). Uncertainty in material properties propagated via Latin Hypercube sampling (n=200 simulations); 95th-percentile QoI variation <4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH and DePuy Synthes). Samples drawn from production lots; certificates of conformance provided. Sample size consistent with ASTM F1717 requirements and FDA guidance on bench testing for spinal implants."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "Testing performed under a single loading condition (ASTM F1717 static compression-bending at 5 mm/min displacement rate). No variation in loading rate, temperature, or hydration state was explored. Required Gradation 3 (multiple conditions) not achieved; only Gradation 2 (single standardized condition) demonstrated. This gap is acknowledged and accepted given the standardized nature of the F1717 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "FEA boundary conditions replicate the F1717 fixture geometry (UHMWPE block dimensions, screw offset, rod length) to within CMM measurement uncertainty. Loading application point and constraint definitions verified against physical fixture drawings. Material properties in FEA matched to coupon test data from same production lot as bench specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "Quantitative comparison performed for three QoIs: construct stiffness, yield force, and force at 40 mm displacement. E/uval metric computed per ASME V&V 40 Section 5.3 for each QoI. All E/uval values below 1.96 threshold. Percentage differences below 10% pre-established acceptance bound. Results tabulated in validation report VR-NC-001."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical failure modes of pedicle screw constructs (fatigue fracture, pseudarthrosis) and are the quantities reported in the 510(k) submission. QoI relevance confirmed by clinical literature review and FDA guidance document for spinal implant testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for modelRiskLevel 3.",
      "rationale": "Validation activity directly replicates the COU: same screw design, same construct geometry, same loading protocol (ASTM F1717), same QoIs. Validation domain fully overlaps with COU domain. No extrapolation beyond validated conditions required for the intended regulatory submission."
    }
  ],
