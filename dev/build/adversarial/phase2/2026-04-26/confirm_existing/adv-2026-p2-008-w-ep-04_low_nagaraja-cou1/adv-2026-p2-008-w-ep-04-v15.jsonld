      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R1) used under a validated quality management system with documented version control, regression testing, and change control procedures.",
      "rationale": "All three FEA codes (FDA in-house, Ansys, DePuy Synthes) are operated under ISO 13485-compliant QMS environments. Ansys Mechanical is validated per ASME V&V 10. Regression test suite executed prior to each study run. Achieved level 3 exceeds required level 2 for a medium-risk COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA code verified against analytical solutions for beam bending and contact mechanics benchmark problems prior to pedicle screw application.",
      "rationale": "Ansys Mechanical verified against NAFEMS benchmark set LE1 and LE10 for linear elasticity. Contact patch test performed for rod-screw interface. Results within 1% of analytical solutions, satisfying gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinements; Richardson extrapolation applied to estimate discretization error.",
      "rationale": "Three mesh densities evaluated (coarse ~180k elements, medium ~420k elements, fine ~910k elements). Richardson extrapolation yields discretization error of 0.8% for stiffness QoI and 1.1% for yield force QoI. Grid convergence index (GCI) <3% for all QoIs. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative solver residuals and energy balance monitored; tolerance criteria documented.",
      "rationale": "Numerical solver error was not formally assessed for this submission. Solver convergence logs were not archived in a retrievable format, and no documented tolerance criteria were applied consistently across the three FEA codes in the ensemble. This factor remains unassessed despite the elevated model risk level of 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow, peer review of model setup, and independent re-analysis by a second analyst for at least one configuration.",
      "rationale": "Model setup documented in a controlled simulation plan. Independent peer review performed by FDA reviewer. One configuration independently re-analyzed by DePuy Synthes analyst; results agreed within 2.3% for stiffness. Use error risk judged adequately controlled at gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic material model justified for sub-yield loading regime; contact formulation validated against known interface behavior; geometric nonlinearity assessed.",
      "rationale": "Titanium alloy (Ti-6Al-4V) modeled as linear elastic below yield; material nonlinearity not required for stiffness and yield force QoIs under monotonic loading. Augmented Lagrangian contact at rod-screw interface validated against analytical Hertzian contact solution. Geometric nonlinearity enabled for large-displacement phase. Model form assessed as adequate at gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified material certificates; geometric dimensions from CMM measurements; friction coefficients from literature with sensitivity analysis.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) from certified material certificates for the specific lot used in bench testing. Screw and rod geometry from CMM measurements (±0.01 mm). Friction coefficient 0.2 (Ti-Ti interface) from published tribology literature; sensitivity analysis showed <4% variation in stiffness QoI for friction coefficient range 0.15–0.30."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; specimen dimensions verified by CMM; material certificates provided.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH and DePuy Synthes). All specimens from production lots with certified material properties. CMM verification of screw shank diameter (mean 7.48 mm, SD 0.02 mm) confirms dimensional conformance. Sample size adequate for statistical comparison at gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "ASTM F1717 protocol followed; environmental conditions (temperature, humidity) documented; load application rate verified; multiple test configurations evaluated.",
      "rationale": "ASTM F1717 protocol followed at both laboratories. Temperature (23±2°C) and humidity (50±10% RH) documented. Load rate 25 mm/min per F1717. However, only a single test configuration (compression-bending at standard offset) was evaluated; additional configurations (torsion, tension-bending) were not included. Achieved level 2 falls below required level 3 for this elevated-risk COU, representing a known gap acknowledged in the assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions, loading, and material properties demonstrably equivalent to experimental setup; any deviations documented and sensitivity-analyzed.",
      "rationale": "FEA boundary conditions replicate F1717 fixture geometry to within 0.5 mm. Applied displacement matches crosshead displacement measured by laboratory LVDT. Material properties matched to certified lot data. Deviations: fixture compliance not modeled; sensitivity analysis showed <1.5% effect on stiffness QoI. Equivalency assessed at gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all QoIs; percent difference <10%; statistical validation metric computed per ASME V&V 40 Section 9.",
      "rationale": "For all three QoIs: stiffness E/uval=0.87, yield force E/uval=1.12, force at 40mm E/uval=1.44 — all below 1.96 threshold. Percent differences: stiffness 3.2%, yield force 5.8%, force at 40mm 7.1% — all below 10% acceptance bound. Validation metric computed per ASME V&V 40 Eq. 9-1. Output comparison fully meets gradation 3 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40mm displacement) directly relevant to clinical failure modes and regulatory acceptance criteria for spinal implants.",
      "rationale": "Construct stiffness governs load sharing with bone graft; yield force is the primary structural safety metric; force at 40mm displacement characterizes post-yield behavior relevant to fatigue life. All three QoIs are explicitly required by ASTM F1717 and referenced in FDA guidance for pedicle screw 510(k) submissions. Relevance rated at gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (F1717 compression-bending, non-cannulated 7.5 mm screw) directly matches COU; no significant extrapolation beyond validated domain required.",
      "rationale": "Validation activity is identical to the COU: same device (non-cannulated 7.5 mm pedicle screw), same test standard (ASTM F1717), same loading mode (compression-bending), same QoIs. No extrapolation beyond the validated domain is required for the regulatory submission. Validation relevance rated at gradation 3, fully meeting the required level."
    }
