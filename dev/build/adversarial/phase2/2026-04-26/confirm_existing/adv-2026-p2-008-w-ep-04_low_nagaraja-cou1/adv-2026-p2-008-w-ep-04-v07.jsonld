      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by second analyst; documented modeling decisions.",
      "rationale": "Model setup reviewed independently by a second FEA analyst at FDA. Boundary conditions, contact definitions, and material assignments were cross-checked against ASTM F1717 test protocol. Discrepancies resolved prior to simulation runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form appropriate for static linear elastic regime; geometric nonlinearity accounted for at large displacement.",
      "rationale": "Linear elastic constitutive model appropriate for titanium alloy screw and rod below yield. Geometric nonlinearity (large displacement) enabled for 40 mm displacement loading. Contact modeled with penalty method; friction coefficient 0.2 based on titanium-on-titanium literature values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
