  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA documentation demonstrates version control, regression testing, and configuration management for the CFD solver at the level required for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R1) is a commercial code with documented SQA processes including version-controlled release notes, regression test suites, and configuration management. SQA documentation reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy study or equivalent demonstrates solver correctly implements governing equations to at least nominal order for relevant flow regimes.",
      "rationale": "An order-of-accuracy study using the method of manufactured solutions confirmed second-order spatial convergence for the incompressible Navier-Stokes solver with SST k-omega turbulence model. Observed order of 1.93 meets the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates that discretization error in hemolysis QoI is below 10% for the production mesh.",
      "rationale": "Three-mesh Richardson extrapolation study performed on the FDA pump geometry. Grid convergence index for the hemolysis index QoI was 4.7% on the medium mesh selected for production runs, satisfying the 10% threshold at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions are documented with sufficient detail to reproduce boundary conditions in the CFD model within stated uncertainty bounds.",
      "rationale": "In-vitro test conditions including fluid properties (glycerol-saline blood analog), pump speed, and flow rates were documented to within ±2% measurement uncertainty. Boundary conditions applied in CFD match experimental conditions within this tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index values agree with experimental measurements within 20% across all five operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) compared against experimental measurements at 5 flow-speed combinations. Maximum deviation was 13.4%, mean deviation 8.1%. All comparisons within the 20% acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, RH) are directly relevant to the clinical decision of worst-case hemolysis identification.",
      "rationale": "The relative hemolysis index (RH) and normalized index of hemolysis (NIH) are the standard regulatory QoIs for blood pump hemolysis assessment per FDA guidance. Their direct clinical relevance to red blood cell damage under CPB conditions is well established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities were performed on a geometry and flow regime sufficiently similar to the COU to support extrapolation of credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry under CPB-representative flow conditions (2–6 L/min, 2000–4000 RPM). The validation domain overlaps substantially with the COU operating envelope, supporting credibility extrapolation at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; acknowledged as acceptable gap.",
      "rationale": "Numerical solver error beyond discretization (e.g., iterative convergence tolerances) is not required to be formally assessed at MRL 2. Residual convergence to 1e-5 was achieved in all production runs, providing informal confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification review deemed sufficient.",
      "rationale": "Formal use error assessment is not required at MRL 2. Analysts hold relevant CFD qualifications and performed internal peer review of simulation setup. No formal use error documentation required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection is supported by literature precedent.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis power-law model) is not formally assessed at MRL 2. SST k-omega with Giersiepen hemolysis model is the literature-standard choice for centrifugal blood pump CFD."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input sensitivity review performed informally.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Fluid viscosity and density were verified against manufacturer specifications. Informal sensitivity to inlet velocity profile showed less than 3% variation in NIH."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample documentation reviewed at high level.",
      "rationale": "Formal test sample characterization (e.g., batch-to-batch variability of blood analog fluid) is not required at MRL 2. Experimental partner confirmed standard preparation protocol consistent with ASTM F1841."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency between validation and COU inputs reviewed qualitatively.",
      "rationale": "Formal equivalency assessment between validation test inputs and COU inputs is not required at MRL 2. Qualitative review confirms that the glycerol-saline analog fluid properties bracket the viscosity range of clinical blood at CPB hematocrit levels."
    }
  ],
