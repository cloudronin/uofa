  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent v2022R2 was used with documented version control and regression test suite. Release notes confirm no critical bug fixes affecting hemolysis-relevant flow physics between versions used in study and submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark verification cases for rotating machinery and viscous flow at MRL 2.",
      "rationale": "ANSYS Fluent verification cases including lid-driven cavity and rotating disk benchmark confirm correct implementation of governing equations for the flow regime of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for primary QoI (RH index) with GCI < 5% on fine mesh.",
      "rationale": "Three-level mesh refinement study performed. GCI for RH index on fine mesh (12.4M cells) was 2.1%, exceeding the required threshold. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce boundary conditions in CFD model.",
      "rationale": "FDA benchmark experimental data provides inlet flow rates, rotational speeds, fluid properties (bovine blood, 37°C), and outlet pressure conditions. All boundary conditions mapped to CFD inputs with documented uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) must be reported between CFD predictions and experimental RH measurements.",
      "rationale": "Normalized RMS error between CFD-predicted and experimentally measured RH index across 5 operating conditions was 8.3%, within the acceptable range for MRL 2. Bland-Altman analysis shows no systematic bias."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation (RH index) must be the same or directly derived from the QoI used in the COU decision.",
      "rationale": "The relative hemolysis index (RH) is used both as the validation QoI and the COU acceptance criterion (RH < 1). Direct correspondence confirmed; no intermediate transformation required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the operating envelope (flow rates 2–8 L/min, speeds 2000–3500 RPM) relevant to the CPB COU.",
      "rationale": "Validation experiments span 5 flow-speed combinations within the CPB operating envelope. Device geometry matches the FDA generic pump used as predicate. Fluid properties representative of clinical CPB conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
