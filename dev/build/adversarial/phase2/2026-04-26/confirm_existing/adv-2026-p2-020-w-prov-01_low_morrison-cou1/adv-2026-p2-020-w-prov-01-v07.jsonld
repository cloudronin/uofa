      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 used with documented version control and regression test suite. Software quality documentation reviewed and found compliant with MRL 2 expectations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems at MRL 2 level.",
      "rationale": "Lid-driven cavity and backward-facing step benchmark solutions reproduced within 1% of published reference values, confirming correct solver implementation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and demonstrate discretization error below 5% for quantities of interest.",
      "rationale": "Three-mesh GCI study performed on the impeller passage. GCI for hemolysis index QoI was 2.3%, exceeding the MRL 2 requirement. Medium mesh selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to the COU operating envelope.",
      "rationale": "FDA generic pump bench tests conducted at 2.5 and 5.0 L/min across 2500–3500 RPM. Conditions documented in laboratory records and fall within the CPB COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±20% across all validation operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis agreed with experimental measurements within 14% across all 5 validation operating points, meeting the acceptance criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the clinical endpoint of pump-induced hemolysis.",
      "rationale": "Relative hemolysis index (RH) is the primary QoI and is directly used in the 510(k) substantial equivalence argument. Secondary QoIs include wall shear stress distribution and scalar stress exposure time."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties representative of the CPB COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under blood-analog fluid conditions spanning the CPB operating envelope. Geometric and physiological representativeness confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal iterative convergence reporting is sufficient; round-off error characterization not required.",
      "rationale": "Residuals monitored to 1e-5 for all equations. Solver error factor not formally assessed at MRL 2 per ASME V&V 40 Table 3 guidance."
