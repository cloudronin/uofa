      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, informal review of analyst qualifications is acceptable.",
      "rationale": "Simulation performed by PhD-level CFD analyst with 5 years of cardiovascular device experience. Formal use error assessment not required at MRL 2."
    },
    {
