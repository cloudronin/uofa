      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, selection of turbulence and hemolysis model must be documented with literature justification.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model selected based on published cardiovascular CFD literature. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values must be documented; sensitivity analysis not required.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and inlet flow conditions documented from clinical literature. Input uncertainty propagation not performed at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
