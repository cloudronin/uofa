      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be version-controlled and validated under an SQA plan consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent v2022R2 used under a documented SQA plan. Version control, regression testing, and release notes reviewed. Achieved level meets required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass published benchmark verification cases relevant to rotating machinery internal flow.",
      "rationale": "ANSYS Fluent verified against ASME V&V 20 lid-driven cavity and rotating disk benchmarks. Published verification documentation reviewed and confirmed adequate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; GCI < 5% required.",
      "rationale": "Three-level mesh refinement study performed (coarse 2.1M, medium 4.8M, fine 10.2M cells). GCI for RH index = 2.3%, exceeding the required level. Richardson extrapolation applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented and traceable to the COU operating envelope.",
      "rationale": "FDA generic pump experimental data collected at 2500 and 3500 RPM, 2.5–7.5 L/min flow rates. Conditions documented in Stewart et al. (2012) and confirmed within CPB operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., RMSE or percent error) between CFD and experimental hemolysis index must be reported.",
      "rationale": "Mean absolute percent error of 8.4% reported across all 5 operating points for the relative hemolysis index. Comparison methodology follows ASME V&V 20 standard uncertainty framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) must be directly linked to the clinical decision criterion.",
      "rationale": "RH index is the direct regulatory acceptance criterion per FDA guidance. CFD outputs scalar stress-weighted exposure time which maps directly to RH via the Giersiepen power-law model. QoI relevance confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must share geometry, flow regime, and fluid properties with the COU to a degree appropriate for MRL 2.",
      "rationale": "Validation performed on the identical FDA generic centrifugal pump geometry under overlapping flow-speed conditions. Blood analog fluid (water-glycerol 40% by mass) used in experiments; CFD uses matched viscosity. High scenario relevance confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
