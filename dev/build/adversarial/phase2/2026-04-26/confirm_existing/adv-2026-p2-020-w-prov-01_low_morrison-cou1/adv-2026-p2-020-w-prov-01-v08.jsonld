  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped to not-assessed status consistent with MRL 2 requirements. GCI of 2.3% and MAPE of 8.4% support adequate model credibility for identifying worst-case hemolysis operating conditions. RH < 1 acceptance criterion satisfied across all 5 flow-speed combinations. Assessment team accepts the CFD model as credible for the stated COU.",
