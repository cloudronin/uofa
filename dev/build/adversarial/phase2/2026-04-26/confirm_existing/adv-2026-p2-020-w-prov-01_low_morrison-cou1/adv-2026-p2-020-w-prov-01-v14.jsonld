  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite and version control. Required level 2 for MRL 2.",
      "rationale": "ANSYS Fluent v2022R2 used with documented QA procedures, version-controlled input files, and reproducible run scripts. Solver verification suite results archived and reviewed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark problems (e.g., lid-driven cavity, Poiseuille flow) at required accuracy level.",
      "rationale": "Code verification performed against analytical solutions for laminar pipe flow and rotating disk. Residuals converged below 1e-6 for all benchmark cases. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must demonstrate GCI < 5% for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study conducted (coarse: 2.1M, medium: 5.8M, fine: 14.2M cells). GCI for normalized hemolysis index = 2.3%. Richardson extrapolation applied. Achieved level 3 exceeds required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within specified tolerances for flow rate, rotational speed, and fluid properties.",
      "rationale": "In-vitro tests conducted at 3 L/min and 4500 RPM matching CFD inlet/outlet BCs. Blood analog (water-glycerol) viscosity matched within 2%. Temperature controlled to 37±0.5°C."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted hemolysis index must agree with experimental measurements within validation uncertainty bounds.",
      "rationale": "Normalized index of hemolysis (NIH) predicted by CFD = 0.0041 g/100L; experimental mean = 0.0038 g/100L (n=5, CV=8%). Difference within combined validation uncertainty. RH < 1 criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) must directly correspond to the clinical endpoint of concern and be measurable both computationally and experimentally.",
      "rationale": "NIH and relative hemolysis index (RH) are established QoIs for CPB device assessment per FDA guidance. Both are directly computable from CFD shear stress fields and measurable in vitro."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating range as the COU.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry under CPB flow conditions (2–6 L/min, 3000–5000 RPM). Geometric fidelity confirmed by CMM measurements. Operating envelope covers COU range."
    },
    {
