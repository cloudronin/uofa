  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented and version-controlled with evidence of QA procedures.",
      "rationale": "ANSYS Fluent 19.2 was used with documented version control and institutional QA procedures. Software qualification records confirm the solver is appropriate for turbulent hemolysis simulations at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark test cases.",
      "rationale": "Benchmark verification cases including lid-driven cavity and pipe flow were completed. Results match analytical solutions within 0.5% confirming correct equation implementation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate discretization error below 5% for hemolysis index predictions.",
      "rationale": "Three-level mesh refinement study conducted with 2.1M, 5.8M, and 14.2M cell meshes. Richardson extrapolation yields GCI of 3.2% for the hemolysis index, satisfying the 5% criterion. Final simulations use the 5.8M mesh as the production grid."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulated operating conditions within defined tolerances for flow rate and rotational speed.",
      "rationale": "Five flow-speed operating points (2–6 L/min, 2000–3500 RPM) match FDA benchmark experimental conditions. Inlet boundary conditions set to match measured flow profiles within 2% of target values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RHI must fall within experimental uncertainty bounds across all five operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) compared against FDA experimental data at all five operating points. Mean absolute error of 0.18 mg/dL is within the experimental measurement uncertainty of ±0.25 mg/dL."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model outputs must directly correspond to clinical hemolysis risk metrics used in regulatory decision-making.",
      "rationale": "Primary QoI is the relative hemolysis index (RH) defined per ASTM F1841. RH < 1 acceptance criterion directly maps to predicate device comparison required for 510(k) submission. QoI is clinically relevant and regulatory-accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and operating conditions as the intended COU.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry identical to the COU device. Operating conditions span the full clinical range of CPB flows. Validation activities are directly applicable to the COU without extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must reach steady-state below solver tolerance thresholds.",
      "rationale": "Not assessed at MRL 2. Solver convergence monitored via residual plots; all simulations converged to 1e-5 residual norm. Formal numerical solver error quantification not required at this model risk level."
    },
