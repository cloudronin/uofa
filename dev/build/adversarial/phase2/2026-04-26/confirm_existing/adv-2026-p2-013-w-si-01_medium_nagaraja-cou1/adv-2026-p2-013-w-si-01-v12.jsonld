  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed the required credibility level. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is mitigated by explicitly scoping the COU to quasi-static loading only, consistent with the ASTM F1717 protocol and the intended regulatory submission. The overall evidence body is judged sufficient to support the claim that the FEA framework credibly predicts compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct. This package was processed under the Minimal profile; the digital signature workflow is pending organizational PKI provisioning and will be applied prior to final regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
