  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) must have documented version control, regression testing, and traceable release notes consistent with Gradation 2 requirements.",
      "rationale": "Ansys Mechanical 2022 R2 is used by all three modeling groups. FDA and DePuy Synthes both maintain ISO 9001-compliant SQA procedures including version-locked solver installations, automated regression test suites, and signed release documentation. Achieved level exceeds required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver correctness demonstrated via benchmark problems with known analytical solutions relevant to structural mechanics of metallic implants.",
      "rationale": "Three canonical benchmark problems (Timoshenko beam bending, Hertzian contact, and elastic column buckling) were executed in Ansys Mechanical 2022 R2. Results agreed with analytical solutions within 0.5% for all cases, satisfying the required Gradation 2 level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that QoI change between successive refinements is less than 2% and that Richardson extrapolation GCI is below 5%.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw shank and rod-screw interface regions. QoI (peak von Mises stress and construct stiffness) changed by 1.1% between the medium and fine meshes. Richardson extrapolation yielded GCI values of 1.8% and 2.3% for stiffness and yield force respectively. Required level achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must fall below 1e-6 for all load steps; energy balance error must remain below 0.1%.",
      "rationale": "All nonlinear load steps used a direct sparse solver with force and displacement convergence criteria of 1e-6. Energy balance was monitored throughout; maximum imbalance was 0.04%. No divergence events were recorded across the full displacement-controlled loading protocol to 45 mm."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and material assignments must be documented by a reviewer not involved in model construction.",
      "rationale": "An independent FDA reviewer (not part of the original modeling team) performed a documented review of the Ansys model input files, boundary condition definitions, contact pair settings, and material property assignments. Three minor discrepancies were identified and corrected prior to final simulation runs. Review report archived in the project docket."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and contact formulation must be justified by published literature or prior validation evidence for Ti-6Al-4V implant constructs under quasi-static bending.",
      "rationale": "Bilinear isotropic hardening plasticity (BISO) was selected for Ti-6Al-4V based on published tensile coupon data from ASTM E8 tests on implant-grade bar stock. Augmented Lagrange contact with a friction coefficient of 0.2 was applied at the rod-screw interface, consistent with published tribology data. Model form choices are well-supported for the loading regime and material class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions must be sourced from direct measurements of the tested lot or certified material certificates, with uncertainty quantified.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (1.8 GPa) were derived from tensile coupons machined from the same Ti-6Al-4V bar stock used to manufacture the test constructs. Geometric dimensions were measured by CMM on three representative screws. Coefficient of variation was below 0.8% for all critical dimensions. Uncertainty in material properties propagated through a one-at-a-time sensitivity study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample population must consist of at least 10 constructs from a single manufacturing lot with documented dimensional inspection.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were assembled from a single manufacturing lot. CMM inspection confirmed all critical dimensions within drawing tolerances. Constructs were distributed across two independent laboratories (n=6 and n=5) to assess inter-laboratory variability. Lot traceability documentation is archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span at least two clinically relevant loading rates or configurations to support generalization of validation findings.",
      "rationale": "Testing was conducted at a single crosshead displacement rate of 5 mm/min per ASTM F1717 protocol. No alternative loading rates or configurations were evaluated. This limits the scope of validation to quasi-static conditions only and does not support extrapolation to fatigue or dynamic loading scenarios. Achieved level (2) is below required level (3); this gap is acknowledged and the COU is correspondingly scoped to quasi-static predictions only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to the physical test conditions, with documented mapping between experimental measurements and simulation boundary conditions.",
      "rationale": "A formal input equivalency table was prepared mapping each experimental measurement (grip separation, applied displacement, construct assembly torque) to the corresponding model boundary condition or contact pre-load. Actuator compliance was measured and subtracted from reported displacement data. Torque-preload conversion for the set screw was validated against a separate torque-tension test series. All mappings are documented in the V&V plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval must be below 1.96 for all primary QoIs, and percent difference must be below 10%.",
      "rationale": "Three QoIs were compared: construct stiffness (E/uval=0.87, 4.2% difference), yield force (E/uval=1.31, 6.8% difference), and force at 40 mm displacement (E/uval=1.52, 7.5% difference). All three metrics satisfy both the E/uval<1.96 and <10% difference acceptance criteria. Combined validation uncertainty uval was computed per ASME V&V 20 incorporating experimental repeatability, lab-to-lab variability, and model numerical uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation must be directly linked to the clinical failure modes and decision criteria specified in the COU.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three quantities specified in ASTM F1717 as the primary mechanical performance indicators for spinal implant constructs. Each QoI maps directly to a clinical concern: stiffness governs load sharing with the fusion bed, yield force indicates onset of permanent deformation, and force at 40 mm corresponds to functional failure. The linkage to COU decision criteria is explicit in the V&V plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (geometry, loading, boundary conditions, material) must be representative of the COU scenario with documented similarity argument.",
      "rationale": "The validation activity uses the identical screw geometry, rod diameter, and construct configuration as the COU device. The ASTM F1717 test fixture reproduces the biomechanically relevant loading mode (compression-bending) for lumbar pedicle screw constructs. A formal similarity argument document maps the validation scenario to the COU along five dimensions: geometry, material, loading mode, boundary conditions, and scale. No surrogates or analogues were required."
    }
  ],
