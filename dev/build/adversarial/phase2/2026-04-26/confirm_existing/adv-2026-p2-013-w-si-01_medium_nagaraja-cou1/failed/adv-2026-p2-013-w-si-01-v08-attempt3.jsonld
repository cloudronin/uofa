  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical and FDA in-house FEA code both operate under documented software quality plans with version control, regression testing, and release validation. Required level 2 met.",
      "rationale": "All simulation codes used in the ensemble (Ansys Mechanical 2021 R2, FDA CDRH FEA framework) are maintained under ISO 9001-aligned SQA plans. Version identifiers are recorded in the simulation record; regression test suites confirm consistent solver behavior across versions used in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 and Ansys verification manual exercised; results within 1% of analytical solutions for linear elastic beam bending and contact patch problems representative of the pedicle screw geometry.",
      "rationale": "Code verification was performed using canonical benchmark cases including Hertzian contact, cantilever beam bending, and threaded-interface pull-out analogues. Maximum deviation from analytical solutions was 0.7%, confirming correct implementation of the governing equations for this class of structural problem."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in all three QoIs (stiffness, yield force, force at 40 mm) between medium and fine mesh densities. Richardson extrapolation applied to quantify GCI.",
      "rationale": "A three-level mesh refinement study was conducted on the non-cannulated 7.5 mm geometry. GCI values were 0.8%, 1.1%, and 0.9% for stiffness, yield force, and force at 40 mm respectively, all well below the 2% threshold. Production mesh corresponds to the medium-density level, providing an appropriate balance of accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge to <1e-6 for all load steps; energy balance checked at each increment. No spurious oscillations or divergence events observed across the 11-construct ensemble.",
      "rationale": "Direct sparse solver (PARDISO) was used for linear steps; Newton-Raphson iteration with line search was applied for contact nonlinearity. Force and displacement residuals converged to <1e-7 in all cases. Energy balance error remained below 0.01% across all simulations, confirming numerical solver reliability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs reviewed by independent analyst; boundary condition and loading definitions cross-checked against ASTM F1717 standard. No discrepancies identified.",
      "rationale": "A documented peer-review checklist was applied by a second FEA analyst who independently verified boundary conditions, material assignments, contact definitions, and load application against the ASTM F1717-15 standard protocol. All items passed without revision. Pre-processing scripts are version-controlled to prevent inadvertent modification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum FEA with bilinear isotropic hardening for titanium alloy Ti-6Al-4V; frictional contact (mu=0.2) at screw-rod and screw-vertebral body block interfaces. Model form appropriate for quasi-static compression-bending at the structural scale.",
      "rationale": "The model employs a well-established continuum mechanics formulation with isotropic hardening plasticity, which is appropriate for Ti-6Al-4V under quasi-static monotonic loading. Sensitivity analyses confirmed that model form choices (contact friction coefficient ±50%, plasticity tangent modulus ±20%) produce QoI variations within the experimental uncertainty band, supporting the adequacy of the chosen model form."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon-level tensile testing of the same Ti-6Al-4V lot used in device manufacture. Geometric inputs derived from CMM measurements of production screws. Input uncertainty quantified and propagated.",
      "rationale": "Young's modulus (114 GPa), yield strength (880 MPa), and tangent modulus (2.8 GPa) were determined from lot-specific tensile coupon data (n=5). Screw geometry was verified by CMM at five points per construct. Monte Carlo propagation of input uncertainties (material ±3%, geometry ±1%) confirmed that combined input uncertainty contributes <4% to QoI variability, which is within the 10% acceptance bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production non-cannulated 7.5 mm pedicle screw constructs tested; constructs sourced from the same manufacturing lot as the device under review. Sample size sufficient for statistical comparison per ASME V&V 40 guidance.",
      "rationale": "Eleven constructs were assembled and tested across two independent laboratories (n=6 Lab A, n=5 Lab B) using screws from a single production lot. Dimensional inspection confirmed all constructs within engineering drawing tolerances. The sample size provides adequate statistical power for the E/uval metric at the specified acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "ASTM F1717 specifies testing at a single standardized load configuration. Only one test condition (5° offset compression-bending) was evaluated; multi-angle or multi-load-level characterization was not performed.",
      "rationale": "Testing was conducted strictly per ASTM F1717-15 at the single prescribed 5° offset compression-bending configuration. While this satisfies the regulatory standard, ASME V&V 40 requires a higher gradation for the COU model risk level. The single test condition limits the ability to characterize model behavior across the broader loading envelope relevant to in vivo use. This factor is identified as below required level; residual risk is accepted by the sponsor based on the regulatory adequacy of the F1717 protocol and corroborating clinical evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions) demonstrably equivalent to experimental test article and setup. Differences quantified and shown to be negligible relative to QoI acceptance bounds.",
      "rationale": "A parameter-by-parameter equivalency table was prepared mapping each FEA input to its experimental counterpart. Screw geometry fidelity was confirmed by overlaying FEA mesh with CMM point cloud (max deviation 0.03 mm). Boundary conditions replicate the ASTM F1717 fixture kinematics as verified by rigid-body kinematic analysis. No unresolved equivalency gaps were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using both percent difference (<10%) and the area validation metric E/uval (<1.96) for all three QoIs across both laboratories.",
      "rationale": "For all three QoIs at both laboratories: percent differences ranged from 1.2% to 7.8% (all <10%) and E/uval values ranged from 0.31 to 1.44 (all <1.96). The dual-metric comparison approach satisfies the required output comparison gradation for this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly relevant to the device safety and performance claims submitted in the 510(k). QoIs are identical between validation activity and COU.",
      "rationale": "The three selected QoIs map directly to the performance claims in the predicate device comparison: construct stiffness characterizes load-sharing behavior, yield force characterizes structural integrity under physiological loading, and force at 40 mm characterizes post-yield energy absorption. All three QoIs are used identically in both the validation study and the COU prediction, confirming full relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity uses the same device design, same FEA modeling framework, same loading protocol, and same QoIs as the COU. No extrapolation beyond the validated domain is required.",
      "rationale": "The validation activity was designed specifically to support this COU: the non-cannulated 7.5 mm pedicle screw geometry, Ti-6Al-4V material, ASTM F1717 loading protocol, and the three QoIs are identical between the validation experiments and the COU application. The FEA model used in the COU is the same ensemble validated here. No geometric, material, or loading extrapolation is required, establishing high relevance of the validation activities to the COU."
    }
  ],
