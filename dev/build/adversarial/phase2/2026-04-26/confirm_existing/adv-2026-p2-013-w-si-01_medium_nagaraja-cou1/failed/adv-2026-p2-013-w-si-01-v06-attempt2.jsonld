  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required gradation level. The single gap — Test conditions at Gradation 2 against a required Gradation 3 — is accepted on the basis that quasi-static loading at ambient conditions is conservative for titanium constructs and consistent with ASTM F1717 standard practice. All quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%) satisfied for all three QoIs across both independent laboratories. Overall credibility is sufficient to support the Medium model risk level and Medium decision consequence for this Class II device. Package is submitted under ProfileMinimal; digital signature pending completion of the institutional signature workflow.",
