    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level. Required level 2: independent review of model setup and boundary conditions performed.",
      "rationale": "Model setup independently reviewed by a second analyst not involved in original model construction. Boundary conditions, load application, and material assignments verified against ASTM F1717 test protocol and device drawings. No discrepancies identified. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
