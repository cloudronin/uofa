  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) must have documented version control, validation test suite results, and change management records consistent with Gradation 2 SQA requirements.",
      "rationale": "Ansys Mechanical 2022 R2 is used under a documented SQA plan. Version control logs, regression test suite results, and installation qualification records are on file. SQA level meets Gradation 2 requirements for a medium model risk application."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA code must be verified against at least one benchmark problem with known analytical solution relevant to structural mechanics (beam bending or contact).",
      "rationale": "Ansys Mechanical was verified against NAFEMS benchmark LE1 (plane stress cantilever) and a Hertzian contact patch problem. Results agreed within 0.5% of analytical solutions. Code verification is documented in the modeling report appendix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that QoIs change by less than 5% between the selected mesh and a uniformly refined mesh.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw shank and screw-rod interface regions. Stiffness QoI changed by 1.8% and yield force by 2.3% between the medium and fine mesh. The medium mesh (≈420,000 elements) was selected as the production mesh. Richardson extrapolation confirmed GCI < 3% for all QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence residuals must be below 1×10⁻⁴ for all load steps; energy balance error must be below 0.1%.",
      "rationale": "Nonlinear static analysis used Newton-Raphson iteration with force convergence criterion 1×10⁻⁵. Energy balance error remained below 0.05% across all 120 load increments. No convergence warnings were issued. Solver error is judged negligible relative to other uncertainty sources."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be independently reviewed by a second analyst; boundary conditions, material assignments, and contact definitions must be verified against the modeling protocol.",
      "rationale": "An independent senior analyst reviewed all model inputs, boundary condition definitions, contact pair assignments, and material property tables against the pre-approved modeling protocol. Two discrepancies (incorrect friction coefficient for one contact pair; misassigned cross-section for the titanium rod) were identified and corrected prior to production runs. Final model was re-reviewed and approved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be appropriate for large-deformation elasto-plastic response of titanium alloy implants under quasi-static loading.",
      "rationale": "Ti-6Al-4V material is represented using a bilinear isotropic hardening model with yield stress 880 MPa and tangent modulus 1.2 GPa, consistent with ASTM F136 material data. Augmented Lagrangian contact with friction (μ=0.2) is used at the screw-rod interface. Large-deformation (NLGEOM ON) analysis captures geometric nonlinearity at 40 mm displacement. Model form is judged appropriate for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometric dimensions, and boundary condition parameters must be traceable to measured or certified values with documented uncertainty estimates.",
      "rationale": "Elastic modulus (114 GPa ± 2%), yield stress (880 MPa ± 3%), and hardening slope were derived from tensile coupon testing of the production Ti-6Al-4V lot. Screw geometry was digitized via CT with 0.1 mm voxel resolution. UHMWPE block modulus (1.1 GPa) was taken from ISO 5834-2 certified supplier data. All input uncertainties were propagated via Monte Carlo sampling (n=200) and contributed uval = 4.1% to the total validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test constructs must be assembled from production-representative screws and rods; sample size must be sufficient to estimate mean and variability of each QoI.",
      "rationale": "N=11 constructs assembled from production-lot non-cannulated 7.5 mm pedicle screws and 5.5 mm Ti rods. Six constructs tested at Laboratory 1 (FDA CDRH), five at Laboratory 2 (DePuy Synthes). Coefficient of variation for stiffness was 4.8%, confirming adequate repeatability. Samples are representative of the commercial device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must cover the range of loading conditions relevant to the COU, including at minimum two distinct load levels or configurations.",
      "rationale": "Testing was conducted under a single load configuration (ASTM F1717 standard compression-bending fixture at 5° offset). No variation in load angle, offset distance, or environmental condition (e.g., simulated body fluid) was included. This limits the ability to assess model behavior across the full COU envelope. Factor achieves Gradation 1 only; this is the single factor below the required level and is acknowledged as a limitation of the current validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be set to match the as-tested specimen geometry and material properties; any deviations must be quantified and included in the uncertainty budget.",
      "rationale": "FEA model geometry was matched to the as-built screw dimensions measured by CMM (mean deviation < 0.05 mm). Material properties were matched to the production lot tensile test data used for the test specimens. Torque preload on the set screw was matched to the experimental assembly protocol (4 Nm ± 0.2 Nm). Equivalency is judged to be well-established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Comparison metric must account for both model prediction error and experimental uncertainty; E/uval < 1.96 for all QoIs.",
      "rationale": "Validation metric E/uval computed per ASME V&V 40 Section 5.4. Stiffness: E/uval = 0.84; yield force: E/uval = 1.12; force at 40 mm: E/uval = 0.61. All three QoIs satisfy the pre-established acceptance criterion of E/uval < 1.96. Percent differences (4.2%, 6.8%, 3.1%) all satisfy the <10% bound. Output comparison is satisfactory."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (stiffness, yield force, force at 40 mm displacement) must be directly relevant to the regulatory decision regarding construct mechanical performance.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly inform the regulatory determination of whether the device meets the standard's performance requirements. These QoIs are the same metrics used in the predicate device comparison. Relevance is judged high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activities must use the same device design, loading mode, and boundary conditions as the intended COU; any differences must be justified.",
      "rationale": "Validation activities directly replicate the COU: same non-cannulated 7.5 mm pedicle screw design, same ASTM F1717 compression-bending loading mode, same UHMWPE test block material. The validation spans two independent laboratories, increasing confidence in result generalizability. The sole limitation (single test condition, addressed under Test conditions factor) does not undermine the overall relevance of the validation activities to the COU."
    }
  ],
