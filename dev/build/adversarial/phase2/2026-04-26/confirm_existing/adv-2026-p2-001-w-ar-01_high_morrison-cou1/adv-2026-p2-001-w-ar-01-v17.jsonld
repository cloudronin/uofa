  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control and regression testing suite in place; solver release notes reviewed for hemolysis-relevant physics modules.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated SQA framework. Version control is maintained via institutional GitLab; a regression test suite covering 47 canonical cases is executed at each solver update. Release notes for the 2022R2 cycle were reviewed and no changes to the turbulence or scalar transport modules affecting hemolysis prediction were identified. Gradation 2 is appropriate for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes manufacturer-supplied method-of-manufactured-solutions tests for incompressible Navier-Stokes and scalar transport at Gradation 2 or higher.",
      "rationale": "ANSYS Fluent has been verified against method-of-manufactured solutions benchmarks for incompressible flow and passive scalar transport as documented in the solver theory guide and independent FDA CFD round-robin studies. No bespoke user-defined functions are employed that would require additional code verification. Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Discretization error for the hemolysis scalar field and wall shear stress was quantified using the Grid Convergence Index (GCI) methodology per Celik et al. (2008) across three systematically refined meshes (4.1 M, 11.3 M, and 28.7 M elements). The observed order of convergence was 1.94 for volume-averaged shear stress and 2.11 for the hemolysis power-law integral, both within acceptable bounds for second-order finite-volume schemes. GCI values on the fine-to-medium pair were 1.7% for shear stress and 2.3% for the hemolysis index, both below the 5% threshold established by team consensus during the credibility planning phase. The medium mesh (11.3 M elements) was selected as the production mesh, providing a balance of accuracy and computational cost for the parametric sweep across five operating points. Boundary layer resolution was confirmed with y+ < 1 on all impeller and volute surfaces. The Gradation 3 requirement reflects the elevated sensitivity of hemolysis predictions to near-wall flow gradients and the direct regulatory use of the model output; the team judged that a quantified GCI demonstration — rather than a qualitative refinement study — was necessary to establish sufficient numerical credibility at MRL 2 for a high-consequence decision. All mesh files and convergence tables are archived in the project repository under /mesh/convergence/.",
      "acceptanceCriteria": "GCI < 5% on wall shear stress and hemolysis power-law integral between medium and fine mesh; observed order of convergence between 1.5 and 2.5 for second-order solver."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented with uncertainty bounds; CFD boundary conditions match experimental values within stated uncertainty.",
      "rationale": "Experimental test conditions for the FDA generic pump were sourced from the published dataset (Hariharan et al. 2011). Flow rates and rotational speeds were applied as boundary conditions in CFD with deviations less than 0.5% from nominal values. Blood analog fluid properties (viscosity, density) were matched to the experimental glycerin-water mixture. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 20% of experimental measurements at all five operating points; pressure rise within 10% of measured values.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) was compared against experimental measurements at all five operating points. Maximum deviation was 14.8% at the lowest flow-speed combination (2 L/min, 2000 RPM), with other points within 8%. Pressure rise predictions were within 6% across all conditions. The achieved Gradation 3 reflects the quantitative uncertainty-banded comparison performed, exceeding the Gradation 2 minimum requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, wall shear stress) are the same quantities used in the regulatory submission decision; no surrogate QoIs employed without documented mapping.",
      "rationale": "The primary QoI in both validation and the COU decision is the normalized index of hemolysis (NIH) computed via the power-law model. No surrogate quantities are used. The relative hemolysis index (RH < 1) used in the COU acceptance criterion is a direct ratio of model-predicted NIH values, ensuring full relevance. Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating range overlap with COU geometry and operating envelope; any gaps documented with engineering justification.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which is geometrically similar to the subject CPB device. Operating conditions (2–6 L/min, 2000–3500 RPM) span the COU envelope. Minor geometric differences in impeller blade count are addressed through sensitivity analysis. Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when solver is commercially validated and no UDFs are employed.",
      "rationale": "At MRL 2 for this COU, explicit quantification of iterative solver error beyond residual monitoring is not required. Residual convergence to 1e-5 for all equations was confirmed for each simulation. Factor scoped to Gradation 1 per MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation setup reviewed by second analyst.",
      "rationale": "Independent review of simulation setup files was conducted by a second CFD analyst. No systematic use errors were identified. Gradation 1 is acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified for rotating machinery hemolysis prediction; power-law hemolysis model applicability documented with literature support.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for rotating machinery flows and its use in FDA CFD round-robin studies. The Giersiepen power-law hemolysis model was applied per established literature. Model form uncertainty is acknowledged and bounded by the output comparison results. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions traceable to measurement data or published sources; sensitivity analysis performed on key inputs.",
      "rationale": "Fluid properties, rotational speed, and flow boundary conditions are traceable to experimental records. Sensitivity analysis on viscosity (±5%) showed less than 3% change in NIH. Power-law exponent sensitivity was evaluated per literature ranges. Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental data sourced from published FDA dataset with documented sample provenance.",
      "rationale": "Experimental data from Hariharan et al. (2011) is used; sample characterization details are available in the published record. No additional test sample assessment is required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
