  "signature": "ed25519:9b2e4f1a7c3d8e0b5f6a2c9e3d1b8f4a7c0e5d2b9f6a3c1e8d3f7a1c92e084b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 2 requires documented version control, regression testing suite, and configuration management records for the CFD solver and all pre/post-processing scripts.",
      "rationale": "ANSYS Fluent 2022R2 was used under a validated software environment. Version control logs, regression test results against canonical benchmark cases, and configuration management records were reviewed and found compliant with MRL 2 SQA requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at level 2 requires demonstration of correct implementation of governing equations through order-of-accuracy testing or comparison with analytical solutions for at least one canonical flow relevant to the COU physics.",
      "rationale": "Order-of-accuracy testing was performed using the method of manufactured solutions for the incompressible Navier-Stokes solver. Observed spatial convergence rates matched theoretical second-order accuracy (p = 1.97 ± 0.04). Additionally, the solver was benchmarked against the FDA critical path initiative nozzle model, with velocity profiles agreeing within 5% of PIV measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 2 requires a mesh refinement study with at least two mesh densities and a documented estimate of discretization error on the primary QoI. Level 3 additionally requires Richardson extrapolation or GCI-based error bounds.",
      "rationale": "A three-level mesh refinement study was conducted using structured hexahedral meshes of 2.1M, 6.8M, and 18.4M cells. Grid Convergence Index (GCI) was computed per Celik et al. (2008). The fine-grid GCI for the normalized index of hemolysis (NIH) was 1.3%, well below the 5% threshold. The 6.8M cell mesh was selected as the production mesh, achieving an achieved level of 3 due to the rigorous GCI quantification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 2 requires that experimental test conditions used for validation are documented and that boundary conditions in the simulation are matched to within stated measurement uncertainty of the experimental setup.",
      "rationale": "Experimental test conditions from the Morrison et al. (2019) hemolysis dataset were reproduced in the CFD model. Inlet flow rates were matched to within ±2% of measured values; rotational speed was matched to within ±5 RPM. Fluid properties (bovine blood at 37°C, hematocrit 35%) were set per experimental protocol. All five operating points (2, 3, 4, 5, 6 L/min at 2500 RPM) were simulated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 2 requires quantitative comparison of simulation outputs against experimental measurements using a defined metric, with agreement documented relative to experimental uncertainty.",
      "rationale": "Predicted NIH values were compared against experimentally measured NIH at all five operating points. Agreement was within 15% at four of five points; the 6 L/min point showed 22% deviation, attributed to secondary flow structures at high flow rates. Overall model performance was deemed acceptable for the relative hemolysis index comparison (RH < 1 criterion) given the conservative direction of the deviation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 2 requires documented justification that the simulated QoIs (hemolysis index, wall shear stress distribution) are directly linked to the clinical decision endpoint and that the mapping from model output to decision criterion is explicitly stated.",
      "rationale": "The primary QoI, normalized index of hemolysis (NIH), is directly mapped to the regulatory acceptance criterion of relative hemolysis index RH < 1 relative to the predicate device. The mapping is explicitly documented in the simulation protocol. Secondary QoIs (volume-averaged shear stress, exposure time distribution) support mechanistic interpretation but are not used in the primary acceptance decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Validation activities were conducted using the FDA generic centrifugal blood pump geometry under operating conditions spanning the full clinical range of the target CPB device (2–6 L/min, 2000–3000 RPM). The validation dataset encompasses the worst-case hemolysis operating point identified in the COU, specifically the 3 L/min, 2500 RPM condition which produced the highest measured NIH. The geometric similarity between the validation pump and the target device has been evaluated: both share impeller diameter within 8% and volute geometry within 12%, supporting extrapolation of validation evidence to the COU. The breadth of operating conditions tested, the use of the same blood analog fluid properties, and the direct correspondence between validation QoIs and COU decision criteria collectively establish that the validation activities are highly relevant to the intended use. Regulatory guidance (FDA 2021 guidance on computational modeling) and ASME V&V 40-2018 Table 3 both identify relevance of validation activities as a critical credibility factor at MRL 2, and the assembled evidence satisfies the qualitative descriptors for Gradation 2 without requiring the more extensive cross-geometry extrapolation studies demanded at Gradation 3. The assessment team reviewed the validation relevance argument in detail during the credibility assessment workshop held 2025-11-14 and unanimously concluded that the validation evidence base is fit for purpose for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 1 requires documentation that iterative convergence was monitored and that residuals reached acceptable levels for all governing equations.",
      "rationale": "Residual convergence was monitored for continuity, momentum, and turbulence equations. All residuals dropped below 1e-5 for steady-state cases. Transient simulations used 20 inner iterations per time step with residuals below 1e-4 per step. Mass imbalance across the domain was less than 0.01% in all cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 1 requires that simulation setup was performed by a qualified analyst and that setup parameters were independently reviewed by a second qualified team member.",
      "rationale": "Simulation setup was performed by a CFD analyst with 8 years of cardiovascular device simulation experience. Boundary conditions, material properties, turbulence model selection (SST k-omega), and hemolysis model parameters were independently reviewed by a senior engineer prior to production runs. No discrepancies were identified during the review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 2 requires documented justification for the selection of the turbulence model and hemolysis power-law model, including sensitivity analysis or literature support for the chosen model forms.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for rotating machinery flows and prior validation against PIV data in centrifugal pump geometries. The Giersiepen-Wurzinger power-law hemolysis model was used with coefficients from Heuser and Opitz (1980). Sensitivity to hemolysis model coefficients was assessed by varying C and alpha within published uncertainty ranges; NIH varied by ±18%, which was accounted for in the uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 2 requires that all model inputs are documented with sources and that uncertainty in key inputs (fluid viscosity, hematocrit, rotational speed) is characterized and propagated to the QoI.",
      "rationale": "All model inputs were documented in the simulation protocol. Blood viscosity was set to 0.0035 Pa·s (Newtonian approximation, validated for hematocrit 35% at shear rates > 100 1/s). Sensitivity analyses were performed for viscosity (±10%), hematocrit (30–40%), and rotational speed (±50 RPM). Combined input uncertainty contribution to NIH was estimated at ±12% using one-at-a-time sensitivity analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Level 1 for test samples at MRL 2 requires only that the experimental samples used in validation are documented with sufficient provenance to confirm they are representative of the device population.",
      "rationale": "Test samples factor is not assessed at MRL 2 for this COU as the validation relies on published FDA benchmark data where sample provenance is established in the primary literature. Scoping decision documented in the credibility assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Level 1 requires documentation that input parameters used in the simulation correspond to those used in the validation experiment, or that differences are bounded and their effect on QoI is characterized.",
      "rationale": "Equivalency of input parameters is not separately assessed at MRL 2 for this COU; the assessment is subsumed within the Model Inputs and Test Conditions factor assessments, which collectively address the correspondence between simulation inputs and experimental conditions. This scoping decision is consistent with ASME V&V 40-2018 guidance for MRL 2 assessments."
    }
  ],
