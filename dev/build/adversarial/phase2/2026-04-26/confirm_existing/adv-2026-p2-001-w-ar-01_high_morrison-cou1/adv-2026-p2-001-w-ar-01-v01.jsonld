  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001:2015 certification or equivalent; all simulation scripts version-controlled with documented change history; regression test suite passing rate ≥ 95%.",
      "rationale": "ANSYS Fluent 2022R2 is used under an ISO 9001:2015-certified quality management system. Version control is maintained via Git with tagged releases for each simulation campaign. Regression tests covering benchmark cases (lid-driven cavity, backward-facing step) pass at 100%. At MRL 2 a Gradation 2 SQA level is appropriate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code must reproduce published benchmark solutions (ASME V&V 20 pipe-flow benchmark) to within 1% for velocity profiles and pressure drop under laminar conditions.",
      "rationale": "The solver has been verified against the ASME V&V 20 pipe-flow benchmark. Velocity profiles deviate by less than 0.4% and pressure drop by less than 0.7% from the analytical solution. Formal order-of-accuracy testing confirms second-order spatial convergence on structured hexahedral meshes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) for the scalar hemolysis index must be ≤ 5% on the fine grid; Richardson extrapolation applied across at least three systematically refined meshes with refinement ratio r ≥ 1.3.",
      "rationale": "Three mesh levels (coarse 2.1 M, medium 5.8 M, fine 14.2 M cells) were constructed with refinement ratio r = 1.35. GCI on the fine grid for the normalized index of hemolysis (NIH) is 2.1%, well within the 5% threshold. The achieved level of 3 reflects the formal Richardson extrapolation and documented GCI reporting exceeding the minimum MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope: flow rates 2–6 L/min, rotational speeds 2000–3500 RPM, blood analogue fluid at 37 °C ± 1 °C, hematocrit 33 ± 2%.",
      "rationale": "The Morrison et al. (2016) experimental dataset was collected using a blood analogue (glycerol-water) at 37 °C with hematocrit-equivalent viscosity. Five flow-speed combinations spanning the COU envelope were tested. Minor deviations in fluid temperature (±0.8 °C) are within the specified tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within ±20% across all five operating points; systematic bias must not exceed 10%.",
      "rationale": "Predicted NIH values agree with experimental measurements within 14% across all five operating points. No systematic bias exceeding 8% is observed. Uncertainty quantification using the ASME V&V 20 method confirms the experimental uncertainty bands overlap with simulation predictions at all points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index RH) must be directly derivable from the CFD scalar transport solution and must correlate with clinically measured plasma-free hemoglobin with R² ≥ 0.80 in published literature.",
      "rationale": "The relative hemolysis index RH is computed from the Lagrangian power-law hemolysis model integrated along particle trajectories. Published correlations between NIH and plasma-free hemoglobin in centrifugal pumps demonstrate R² = 0.87. The QoI is therefore directly relevant to the clinical decision endpoint."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The validation activities were conducted using the FDA generic centrifugal blood pump geometry, which is the same geometry class as the device under assessment. Operating conditions in the validation experiments span the full COU envelope (flow rates 2–6 L/min, rotational speeds 2000–3500 RPM). The hemolysis model, turbulence closure (SST k-ω), and boundary condition methodology are identical between the validation and COU simulations. The validation scenario is therefore judged to be highly relevant to the COU, providing strong evidence that the model's predictive capability demonstrated in the validation context transfers directly to the intended use. At Model Risk Level 2, a Gradation 2 relevance assessment requires that the validation geometry, physics regime, and QoI all correspond to the COU — each of these conditions is satisfied here. The assessment team reviewed the validation-to-COU mapping matrix (internal report TR-2024-CPB-07) and concluded that no extrapolation beyond the validated operating envelope is required for any of the five COU operating points. This factor therefore meets the required level without reservation, and the evidence package is considered complete for this factor at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2 for this factor, a Gradation 1 (not assessed) is acceptable. Solver iteration convergence is monitored via residual drop of six orders of magnitude and mass imbalance < 0.01%; no further formal solver error quantification is required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2 for this factor, Gradation 1 (not assessed) is acceptable. Simulation setup checklists and peer review by a second analyst mitigate use error risk sufficiently at this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2 for this factor, Gradation 1 (not assessed) is acceptable. The SST k-ω turbulence model is widely used for internal rotating machinery flows; formal model-form uncertainty quantification is not required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2 for this factor, Gradation 1 (not assessed) is acceptable. Nominal material properties (blood viscosity, density) are taken from ISO 10993-compliant measurements; sensitivity to input variation is addressed qualitatively through the five operating-point sweep."
    },
    {
      "factorStandard": "ASME-VV40-2018",
