  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluid-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six not-assessed factors are appropriately scoped out per ASME V&V 40-2018 Table 4-1 for medium model influence at MRL 2. CFD predictions of the normalized index of hemolysis agree with experimental measurements within 10% across all five COU operating points, satisfying the RH < 1 regulatory acceptance criterion. The model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device.",
