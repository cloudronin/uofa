  "hash": "sha256:a3f7c2e1d9b04856f1e2c3d4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4",
  "signature": "ed25519:b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented; version control and regression test suite in place; all solver executables traceable to verified build artifacts.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under an institutional SQA plan that satisfies Gradation 2 requirements. Version control is enforced via Git with tagged releases; a regression test suite of 12 canonical benchmark cases is executed prior to each production run. Build artifacts are archived with checksums to ensure traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes manufacturer-supplied verification suite; at least one independent benchmark (pipe flow or lid-driven cavity) demonstrates second-order spatial convergence.",
      "rationale": "Code verification was performed using the ANSYS Fluent verification suite (v2022 R2 release notes, Section 4). An independent benchmark against the analytical Hagen-Poiseuille solution for laminar pipe flow confirmed second-order spatial convergence (GCI < 1.2% on the finest mesh). No defects relevant to rotating-frame or viscous-dissipation terms were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for the primary QoI (normalized hemolysis index) across at least three systematically refined meshes; GCI on fine grid < 5%.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA centrifugal pump geometry at the nominal operating point (6 L/min, 3500 RPM). Mesh sizes were 2.1 M, 5.8 M, and 14.2 M hexahedral cells. The Richardson-extrapolated GCI for the normalized index of hemolysis (NIH) on the fine mesh was 2.7%, comfortably below the 5% threshold. The achieved level of 3 reflects the systematic three-mesh approach with formal GCI reporting, exceeding the Gradation 2 minimum."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented and shown to bracket the COU operating envelope; deviations from COU conditions quantified.",
      "rationale": "Bench hemolysis tests were conducted at five flow-speed combinations spanning the COU envelope (4–8 L/min, 2500–4500 RPM). Bovine blood at 35 ± 1°C and 35 ± 2% hematocrit was used. Deviations from clinical conditions (human blood, 37°C, 40% hematocrit) were assessed and found to introduce less than 8% uncertainty in NIH based on published species-correction factors."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation NIH values compared against experimental NIH at all five operating points; agreement within combined experimental and numerical uncertainty bands (U95) at each point.",
      "rationale": "Simulated NIH values were compared against experimental measurements at all five operating points. Agreement was within the combined U95 uncertainty band at four of five points; the fifth point (8 L/min, 4500 RPM) showed a 4.1% over-prediction, within the 6% combined uncertainty. The comparison supports Gradation 2 confidence in predictive fidelity for the COU QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH demonstrated to be a direct surrogate for clinical hemolysis risk; mapping from NIH to relative hemolysis index (RH) documented and accepted by clinical advisors.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI and is directly mapped to the clinical relative hemolysis index (RH = NIH_device / NIH_predicate). The RH < 1 acceptance criterion for the COU was established in consultation with clinical advisors and is consistent with FDA guidance on predicate comparisons for Class II blood-contacting devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The validation activities were designed to directly mirror the COU: the same FDA generic centrifugal pump geometry was used in both simulation and experiment; operating conditions spanned the full COU envelope; and the primary validation QoI (NIH) is identical to the COU QoI. The validation hierarchy progresses from component-level (impeller torque) to system-level (NIH) comparisons, providing layered evidence of model fidelity specifically relevant to worst-case hemolysis prediction under CPB conditions. The experimental protocol followed ASTM F1841-97 (reapproved 2017), which is the recognized standard for hemolysis testing of blood pumps, ensuring that the validation evidence base is directly applicable to the regulatory submission context. Boundary conditions applied in the validation simulations were derived from the same measurement campaign used to characterize COU operating conditions, eliminating input-condition mismatch as a confounding source of validation uncertainty. In aggregate, the validation activities address each of the five operating points in the COU decision space, and the agreement metrics reported under the Output Comparison factor confirm that model predictions are fit for the intended regulatory purpose at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2, Gradation 1 is required for numerical solver error beyond discretization. The commercial solver (ANSYS Fluent) is widely validated for rotating-frame turbomachinery flows; no additional solver-error quantification beyond the code verification benchmark is required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Use error is assessed at Gradation 1 for MRL 2. Simulation inputs were reviewed by a second engineer; boundary conditions and material properties are version-controlled. No additional independent audit is required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis power-law exponents) is acknowledged but formal sensitivity analysis is not required at MRL 2 Gradation 1. The k-omega SST model was selected based on published benchmarks for rotating blood-pump flows."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Input uncertainty propagation is not required at MRL 2 Gradation 1. Nominal input values (viscosity, density, rotational speed) were set to measured means; measurement uncertainties are documented in the test report but formal UQ propagation is deferred."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Three pump units from the same manufacturing lot were tested; sample-to-sample variability was within 3% for NIH. Formal statistical characterization of manufacturing variability is not required at MRL 2 Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Equivalency of simulation input parameters to experimental conditions is addressed qualitatively at Gradation 1. Boundary conditions were matched to measured inlet/outlet conditions within instrumentation uncertainty; no formal equivalency metric is required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. Six factors are appropriately scoped to Gradation 1 and not assessed per MRL 2 guidelines. The CFD model demonstrates sufficient credibility to support the regulatory decision that the device's relative hemolysis index (RH) can be reliably predicted and compared against the predicate device. The assessment is accepted for submission to FDA as supporting evidence for the 510(k) hemolysis comparison.",
