  "signature": "ed25519:b4e7a1f2c5d8e3b6a9c2f5d8e1b4a7c0d3f6a9b2c5e8f1a4b7c0d3e6f9a2b5c8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold a documented QA plan with regression test suite covering laminar and turbulent benchmark cases; all critical bugs resolved prior to simulation campaign.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-certified QA framework. The vendor-supplied validation manual documents passing results for all relevant benchmark cases including lid-driven cavity, backward-facing step, and rotating disk flows. Internal regression tests were executed and passed prior to the simulation campaign. Version control and change logs were reviewed by the project quality engineer."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) must confirm second-order spatial convergence for the incompressible Navier-Stokes discretization used in the pump simulations.",
      "rationale": "MMS verification was performed on a simplified rotating-frame domain using a prescribed analytical solution. Spatial convergence rates of 1.97 (velocity) and 1.94 (pressure) were obtained on successively refined grids, confirming near-second-order accuracy consistent with the finite-volume scheme. Results are documented in the verification report VR-2023-04."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) on the primary hemolysis-relevant QOI (volume-averaged shear stress) must be below 5% on the medium grid used for production runs; Richardson extrapolation must confirm monotonic convergence.",
      "rationale": "A three-level mesh refinement study was conducted using element counts of 4.2M, 8.7M, and 17.1M cells. The GCI on volume-averaged shear stress between the medium and fine grids was 1.8%, well within the 5% threshold. Richardson extrapolation confirmed monotonic convergence with observed order p = 1.93. The medium mesh (8.7M cells) was selected for production simulations, balancing accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, and hematocrit) must match simulation inputs within stated measurement uncertainties; deviations must be documented and bounded.",
      "rationale": "Bench-top experiments were conducted at the FDA laboratory using the generic centrifugal pump geometry. Flow rates were controlled to within ±2% of target values using calibrated Coriolis meters. Rotational speed was maintained to ±0.5 RPM. Bovine blood at 35% hematocrit ±1% was used. All deviations between nominal test conditions and simulation boundary conditions were quantified and found to lie within measurement uncertainty bands, supporting direct comparison of experimental and computational hemolysis indices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within ±30% across all five flow-speed operating points; systematic bias must be less than 15%.",
      "rationale": "NIH predictions were compared against experimental measurements at all five operating points. Agreement ranged from 8% to 27% relative error, with a mean signed error of +11%, indicating a modest positive bias consistent with literature reports for power-law hemolysis models. All points fell within the ±30% acceptance band. The systematic bias of +11% is conservative (over-prediction of hemolysis), which is acceptable for a worst-case identification use case."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The computational QOI (volume-averaged scalar shear stress and Lagrangian hemolysis index) must be directly traceable to the clinical endpoint (plasma-free hemoglobin rise per ASTM F1841) and the regulatory submission metric (normalized index of hemolysis).",
      "rationale": "The primary QOI — the relative hemolysis index RH computed via the Giersiepen-Wurzinger power-law model applied to Lagrangian particle trajectories — is directly linked to the normalized index of hemolysis used in ASTM F1841 and referenced in FDA guidance for blood-contacting device submissions. The mapping from scalar shear stress exposure to plasma-free hemoglobin has been validated in prior published work and is the accepted surrogate for the clinical endpoint in this device class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The validation activities were conducted on the FDA generic centrifugal blood pump geometry — the same geometry used in the COU simulations — operated across the identical five flow-speed combinations specified in the COU. Bovine blood was used as the working fluid, consistent with ASTM F1841 protocols and accepted as physiologically representative for hemolysis index comparisons. The operating envelope (2–6 L/min, 2000–3500 RPM) fully spans the clinical CPB flow range for the intended patient population. The validation dataset therefore provides direct, geometry-matched, condition-matched evidence of predictive adequacy for the COU, and no extrapolation beyond the validated operating space is required. The degree of similarity between validation conditions and COU conditions is assessed as high: identical pump geometry, overlapping Reynolds number range (Re 4,200–18,700 vs. COU range 4,500–17,900), same hemolysis model, and same post-processing workflow. This high relevance rating is consistent with the MRL 2 requirement and reduces residual uncertainty associated with model form and boundary condition representation to a level commensurate with the Medium model influence classification. Independent review by the project biofluid mechanics lead confirmed that no significant unrepresented physics (e.g., non-Newtonian effects at low shear, platelet activation coupling) are expected to materially alter the worst-case ranking of operating conditions, which is the primary decision output of this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; no formal acceptance criterion established.",
      "rationale": "At Model Risk Level 2 with Medium model influence, numerical solver error beyond code verification is scoped out per the ASME V&V 40 MRL matrix. Iterative convergence was monitored (residuals below 1e-5) as a standard practice but no formal solver error quantification is required or performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation team qualifications and peer review of setup files satisfy the minimum expectation.",
      "rationale": "Use error assessment is not mandated at MRL 2 for this COU. The simulation team holds relevant CFD credentials and the simulation setup was independently reviewed by a senior analyst. Boundary condition files and mesh setup were version-controlled and spot-checked against the test protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form uncertainty is partially addressed through the output comparison factor.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The choice of the k-omega SST turbulence model and the Giersiepen-Wurzinger hemolysis model is supported by published literature for centrifugal pump hemolysis prediction. Model form uncertainty is implicitly bounded by the output comparison results, which demonstrate agreement within the stated tolerance across all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values are taken from calibrated measurements and published material properties.",
      "rationale": "Formal sensitivity analysis of model inputs is not required at MRL 2. Fluid properties (density 1050 kg/m3, dynamic viscosity 3.5 mPa·s) are taken from published values for bovine blood at 35% hematocrit and 37°C. Geometric inputs are derived from the FDA-published pump drawings with dimensional tolerances noted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample characterization is documented in the FDA test report.",
      "rationale": "Detailed test sample characterization (blood lot variability, hematocrit distribution) is not required at MRL 2. The FDA experimental report documents blood source, storage conditions, and hematocrit measurements. Sample-to-sample variability is considered bounded by the ±30% output comparison tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; parameter equivalency between validation and COU conditions is addressed qualitatively under the relevance of validation activities factor.",
      "rationale": "Formal equivalency mapping of all input parameters between validation and COU conditions is not required at MRL 2. The qualitative assessment under the relevance of validation activities factor confirms that the operating conditions are sufficiently matched to support the COU decision without additional equivalency analysis."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are appropriately scoped out per the ASME V&V 40 MRL 2 matrix for a Class II device with Medium model influence and High decision consequence. The CFD model is judged credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions. The relative hemolysis index predictions are conservative (positive bias) and fall within the ±30% validation tolerance across all five operating points. The model is accepted for the stated COU.",
