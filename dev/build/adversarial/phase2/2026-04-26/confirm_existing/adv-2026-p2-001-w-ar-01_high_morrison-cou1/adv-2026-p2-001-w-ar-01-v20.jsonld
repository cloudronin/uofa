  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent SQA documentation covering version control, regression testing, and release validation. For MRL 2, vendor-supplied QA documentation with traceable test suite results is sufficient.",
      "rationale": "ANSYS Fluent 2022R2 is used as the CFD solver. The vendor provides a comprehensive Software Quality Assurance plan conforming to ISO 9001:2015 including version-controlled source code, automated regression test suites covering more than 2,000 canonical flow cases, and documented release validation reports. The SQA package was reviewed and confirmed to meet Gradation 2 requirements for MRL 2 devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through at least one published benchmark with known analytical or manufactured solution, achieving observed order of accuracy within 10% of formal order.",
      "rationale": "Code verification was established via the Method of Manufactured Solutions applied to the incompressible Navier-Stokes equations in a rotating reference frame. Observed spatial order of accuracy was 1.94 (formal second order), within acceptable tolerance. Published benchmark results for lid-driven cavity and Taylor-Couette flows further confirm correct equation implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis must be performed across a minimum of three systematically refined meshes. Reported GCI on hemolysis index QoI must be less than 5% for the fine-grid solution to satisfy MRL 2 requirements.",
      "rationale": "A three-level mesh refinement study was conducted using globally refined hexahedral-dominant meshes of approximately 2.1M, 6.8M, and 19.4M cells. Richardson extrapolation yielded a Grid Convergence Index (GCI) of 2.3% on the normalized hemolysis index for the fine mesh, well within the 5% threshold. The medium mesh (6.8M cells) was selected for production runs as it achieves GCI < 4% at substantially reduced computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with traceable uncertainty bounds on inlet flow rate (±3%), rotational speed (±1%), and fluid temperature (±1°C). Boundary conditions in the simulation must fall within the documented experimental uncertainty envelope.",
      "rationale": "The FDA benchmark experimental dataset provides fully documented test conditions including flow rates of 2.5 and 5.0 L/min, rotational speeds of 2000, 2500, and 3500 RPM, and blood analog fluid properties at 37°C. Measurement uncertainties are reported in the original publication. Simulation boundary conditions were set to the nominal experimental values and confirmed to lie within stated uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within combined simulation and experimental uncertainty at a minimum of 4 of 5 operating points. Relative error must not exceed 15% at any individual point.",
      "rationale": "Predicted NIH values were compared against experimental measurements at all five operating points. Agreement was within combined uncertainty at 5 of 5 points, with maximum relative error of 8.7% at the 2000 RPM / 5.0 L/min condition. Validation metric R² = 0.97 across all operating points confirms adequate predictive capability for the intended COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The quantities of interest used in validation (NIH, volume-averaged scalar stress) must be demonstrably linked to the clinical endpoint (in vivo hemolysis) through published literature or regulatory precedent.",
      "rationale": "The normalized index of hemolysis and the volume-averaged scalar shear stress are established surrogate QoIs for pump-induced hemolysis, referenced in FDA guidance on hemolysis testing for blood-contacting devices. Multiple peer-reviewed publications confirm the correlation between CFD-predicted scalar stress and bench-measured NIH for centrifugal pumps, supporting the relevance of these QoIs to the clinical hemolysis endpoint."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The validation activities were conducted on the FDA generic centrifugal blood pump geometry under operating conditions that span the full range of the intended COU (2.5–5.0 L/min, 2000–3500 RPM). The blood analog fluid (glycerin-water solution with matched viscosity and density) provides adequate representation of blood rheology for the shear-rate regimes encountered in CPB operation. The geometric similarity between the validation pump and the CPB device under assessment was confirmed through a dimensional analysis showing all relevant dimensionless groups (Reynolds number, specific speed) within 12% of the COU operating envelope. The validation hierarchy progresses from unit-problem benchmarks through subsystem-level comparisons to the system-level hemolysis assessment, providing a coherent chain of evidence that the model physics are exercised across conditions representative of the COU. Independent sensitivity analyses confirm that the dominant hemolysis-driving mechanisms (tip clearance recirculation, impeller blade loading) are well-represented in both the validation geometry and the device geometry, and that the model responds correctly to perturbations in these parameters. On the basis of this comprehensive evidence chain — spanning geometric similarity, fluid property matching, operating condition overlap, and mechanistic sensitivity confirmation — the validation activities are judged fully relevant to the COU at the required gradation level for MRL 2. No significant gaps between the validation domain and the COU domain were identified that would require additional validation activities or conservative adjustments to the simulation outputs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2; vendor SQA documentation provides sufficient basis for Gradation 1.",
      "rationale": "At MRL 2, numerical solver error is addressed at Gradation 1 through the vendor SQA documentation reviewed under the Software Quality Assurance factor. No additional independent assessment of solver floating-point or round-off error is required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2; analyst training records and simulation plan review provide sufficient basis for Gradation 1.",
      "rationale": "Use error is addressed at Gradation 1 for MRL 2 through documented analyst qualifications (PhD-level CFD experience, >5 years rotating machinery applications) and a peer-reviewed simulation plan. No formal use-error assessment protocol is required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection is justified by literature precedent at Gradation 1.",
      "rationale": "Model form uncertainty (turbulence closure, hemolysis power-law model constants) is addressed at Gradation 1 through literature-justified model selection. The k-omega SST turbulence model is widely validated for confined rotating flows in the Reynolds number range of CPB pumps. The Giersiepen hemolysis power-law model parameters are taken from the FDA-recommended values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values with documented sources are sufficient for Gradation 1.",
      "rationale": "Model inputs including fluid viscosity, density, and pump geometry dimensions are taken from published sources with documented traceability. Sensitivity to input uncertainty is not formally quantified at MRL 2 Gradation 1, consistent with the ASME V&V 40 requirements for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2; FDA benchmark dataset sample size is accepted at Gradation 1 without formal statistical power analysis.",
      "rationale": "The FDA benchmark dataset comprises measurements from a single pump specimen across five operating points, which is accepted at Gradation 1 for MRL 2. No formal sample size or statistical representativeness analysis is required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2; dimensional analysis confirming operating point overlap is sufficient for Gradation 1.",
      "rationale": "Equivalency of input parameters between the validation configuration and the COU configuration is addressed at Gradation 1 through the dimensional analysis documented under the Relevance of Validation Activities factor. No additional formal equivalency assessment is required at MRL 2."
    }
  ],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six not-assessed factors are appropriately scoped at Gradation 1 consistent with ASME V&V 40 Table 1 requirements for a Class II device at MRL 2. The CFD model is judged credible for identifying worst-case hemolysis operating conditions within the defined COU. The relative hemolysis index acceptance criterion (RH < 1) is met at all five operating points. The assessment team accepts the simulation results as sufficient basis for the regulatory submission.",
