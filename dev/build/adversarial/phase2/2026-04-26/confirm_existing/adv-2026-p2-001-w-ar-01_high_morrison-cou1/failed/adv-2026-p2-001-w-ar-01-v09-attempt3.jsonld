  "signature": "ed25519:7a3f1c9e2b5d8a4f0c6e3b1d9a7f2c4e8b0d5a3f1c9e2b5d8a4f0c6e3b1d9a7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation (ANSYS Fluent 2022 R2) must be validated under a documented SQA plan consistent with MRL 2 requirements: version-controlled source, regression test suite with documented pass/fail records, and traceable configuration management. Achieved level confirmed by SQA audit record SQA-2024-007.",
      "rationale": "ANSYS Fluent 2022 R2 is operated under a documented software quality assurance plan. Version control, regression testing, and configuration management records are maintained. SQA audit SQA-2024-007 confirms all MRL 2 obligations are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate that the numerical solver correctly implements the governing Navier-Stokes and scalar transport equations by reproducing at least one analytical or manufactured solution benchmark to within expected truncation-error order. Documentation of benchmark case and convergence order is required.",
      "rationale": "Code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes equations. Observed spatial convergence order of 1.97 (second-order scheme) was confirmed against the analytical solution, satisfying the MRL 2 benchmark requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via a formal grid convergence study using at least three systematically refined meshes. Richardson extrapolation or GCI methodology must be applied. Reported GCI on the primary QoI (scalar stress index) must be below 5% on the medium mesh used for production runs.",
      "rationale": "A three-level mesh refinement study was conducted with coarse (2.1 M cells), medium (6.8 M cells), and fine (21.4 M cells) meshes. Grid Convergence Index (GCI) on the volume-averaged scalar stress index was 3.2% between medium and fine meshes, confirming discretization error is well within the 5% threshold. The medium mesh was selected for all production simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to confirm they bracket the COU operating envelope. Fluid temperature, hematocrit, anticoagulant protocol, and flow/pressure boundary conditions must be recorded and compared against the simulation boundary conditions.",
      "rationale": "Bench-top validation experiments were conducted at 37 °C, 30% hematocrit, with heparinized bovine blood. Five flow-speed operating points (3–6 L/min, 2400–3600 RPM) match the COU envelope. Boundary conditions applied in CFD were taken directly from the experimental measurement records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within ±25% across all five operating points. Systematic bias must be characterized and documented.",
      "rationale": "Predicted NIH values were compared against experimental measurements at all five operating points. Maximum deviation was 18.4%; mean absolute error was 11.2%. No systematic directional bias was identified. Results satisfy the ±25% agreement criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest extracted from the CFD model (scalar stress index, NIH, relative hemolysis index) must be directly traceable to the clinical endpoint (hemolysis) and to the regulatory submission metric (RH < 1 relative to predicate). A documented QoI mapping table is required.",
      "rationale": "The primary QoIs — scalar stress index, normalized index of hemolysis, and relative hemolysis index — are each traceable to the clinical hemolysis endpoint via the Giersiepen power-law damage model. A QoI mapping table (Doc. QoI-MAP-001) links each simulation output to the regulatory RH < 1 criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a geometry and operating regime sufficiently similar to the COU device and conditions. A documented similarity assessment comparing the validation model geometry, fluid properties, and operating envelope to the COU must be on file.",
      "rationale": "Validation activities were performed on the FDA generic centrifugal pump geometry under CPB-representative conditions. A similarity assessment (Doc. SIM-ASSESS-003) confirms that impeller diameter, specific speed, and hemodynamic shear regime are within 15% of the COU device parameters, satisfying MRL 2 relevance requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "At Model Risk Level 2, numerical solver error is required at Gradation 1, meaning iterative convergence of the steady-state solution must be demonstrated to at least three orders of magnitude reduction in residuals for continuity, momentum, and scalar transport. All production simulations achieved residual reductions exceeding 10^-5 for momentum and 10^-6 for continuity, with mass imbalance below 0.01% of inlet mass flow. Iterative convergence was further confirmed by monitoring the volume-averaged scalar stress index over the final 500 iterations of each run; variation was below 0.3% across all five operating points, demonstrating that the solver had reached a stable converged state well before solution extraction. The turbulence kinetic energy and dissipation rate residuals also fell below 10^-5. These convergence metrics are consistent with best-practice guidance in the ASME V&V 20 standard and the FDA CFD guidance document (2022). Given the steady-state, single-phase, incompressible formulation employed, no additional time-stepping or phase-coupling errors are applicable. The achieved level of Gradation 2 reflects the comprehensive convergence monitoring protocol applied beyond the minimum Gradation 1 requirement, providing additional confidence that numerical solver error is not a material contributor to total simulation uncertainty at this MRL. No corrective action or further investigation of solver error is warranted for this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoped out per project credibility plan.",
      "rationale": "Use error is not assessed at MRL 2 for this COU. The credibility plan documents that this factor is below the threshold requiring formal assessment at the current model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoped out per project credibility plan.",
      "rationale": "Model form uncertainty is not formally assessed at MRL 2. The selection of the Giersiepen hemolysis damage model and the k-omega SST turbulence closure is documented in the modeling assumptions report, but quantitative model form error estimation is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoped out per project credibility plan.",
      "rationale": "Formal uncertainty quantification of model inputs (fluid viscosity, density, damage model coefficients) is not required at MRL 2. Nominal values sourced from published literature are documented in the simulation input deck."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoped out per project credibility plan.",
      "rationale": "Statistical characterization of test sample variability (e.g., hematocrit lot-to-lot variation, bovine blood donor variability) is not required at MRL 2. Sample preparation protocols are documented in the experimental report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoped out per project credibility plan.",
      "rationale": "Formal equivalency mapping between validation experiment input parameters and COU simulation inputs is not required at MRL 2. A qualitative comparison is documented in the similarity assessment (Doc. SIM-ASSESS-003)."
    }
  ],
