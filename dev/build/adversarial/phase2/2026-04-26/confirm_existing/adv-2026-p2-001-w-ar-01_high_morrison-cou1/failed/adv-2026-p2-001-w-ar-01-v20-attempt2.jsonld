  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent QMS documentation; regression test suite must cover core hemolysis-relevant physics with documented pass rate ≥ 95%.",
      "rationale": "ANSYS Fluent 2022R2 is employed. The solver vendor maintains ISO 9001 certification and publishes annual verification test suite results. Internal regression testing against 47 canonical flow cases demonstrates a 98.3% pass rate. Version control and change-management records are archived per FDA 21 CFR Part 11 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate order-of-accuracy convergence consistent with nominal scheme order for at least one benchmark problem representative of rotating machinery flow physics.",
      "rationale": "Order-of-accuracy tests were performed using the Method of Manufactured Solutions (MMS) for the incompressible Navier-Stokes equations with rotating frame source terms. Observed spatial convergence order of 1.97 (nominal second-order) was confirmed on three systematically refined grids. Results are consistent with published ANSYS Fluent verification documentation for turbomachinery applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid Convergence Index (GCI) for the primary quantity of interest (normalized hemolysis index NIH) must be less than 5% on the medium mesh used for production runs, computed per Celik et al. (2008) three-grid procedure.",
      "rationale": "A three-level mesh refinement study was conducted using systematically refined grids of 4.2 M, 11.7 M, and 31.4 M hexahedral cells. GCI values for NIH at the five operating points ranged from 1.1% to 3.8%, all below the 5% threshold. The medium mesh (11.7 M cells) was selected for production simulations, providing an acceptable balance between discretization error and computational cost. Wall y+ values were maintained between 30 and 300 for all operating points to ensure appropriate wall-function applicability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must overlap with at least 3 of the 5 COU operating points within ±5% of target flow rate and rotational speed.",
      "rationale": "The FDA benchmark experimental dataset (Hariharan et al., 2011) was acquired under controlled laboratory conditions spanning flow rates of 2.5–7.5 L/min and rotational speeds of 2000–3500 RPM. Four of five COU operating points fall within the experimental envelope with deviations less than 3% in both flow rate and speed. Temperature was maintained at 37°C ± 0.5°C, consistent with physiological CPB conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within ±25% at all validated operating points, assessed using the validation metric of Oberkampf and Barone (2006).",
      "rationale": "Predicted NIH values were compared against experimental measurements at four overlapping operating points. Agreement ranged from 8% to 22% relative error, with all points falling within the ±25% acceptance band. Systematic over-prediction at high rotational speeds is consistent with known turbulence model limitations in strongly swirling flows and is within expected model uncertainty bounds for this class of hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly mappable to the regulatory decision criterion (RH < 1) without intermediate transformation assumptions that introduce unquantified uncertainty.",
      "rationale": "The normalized index of hemolysis (NIH) computed from the CFD power-law hemolysis model (Giersiepen et al.) is directly used to compute the relative hemolysis ratio RH = NIH_device / NIH_predicate. This ratio constitutes the regulatory acceptance criterion. No intermediate transformation assumptions are required beyond the validated power-law exponents, which have published uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The validation activities were designed with direct reference to the COU operating envelope. The FDA generic centrifugal pump geometry used in validation shares the same impeller topology and volute design as the device under assessment, differing only in impeller clearance dimensions within the tolerance band under study. Validation flow conditions span the full COU operating range of 2.5–7.5 L/min at 2000–3500 RPM. Blood analog fluid (aqueous glycerol, 40% by mass) was used in experiments, with viscosity matched to whole blood at 37°C within 4%. The validation hierarchy progresses from unit-problem pipe flow through subsystem impeller channel studies to the full pump assembly, providing a coherent body of evidence that the model physics are appropriately exercised across all relevant scales. The spatial and temporal resolution requirements identified in the discretization error assessment were carried forward into all validation simulations, ensuring that numerical errors do not confound the validation signal. Boundary condition specification in validation simulations mirrors the COU inlet/outlet conditions (pressure-inlet, mass-flow-outlet) with turbulence intensity set to 5% based on upstream piping geometry, consistent with the experimental facility configuration documented in Hariharan et al. (2011). The overall validation evidence base is assessed as sufficient to support a requiredLevel 2 determination for MRL 2 at HIGH decision consequence, consistent with Table 3 of ASME V&V 40-2018.",
      "acceptanceCriteria": "Validation activities must address the full COU operating envelope and use a geometry representative of the device under assessment; the validation hierarchy must include at least subsystem-level experiments with blood-analog fluid at physiological viscosity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver residuals monitored to 1e-5 as standard practice.",
      "rationale": "At MRL 2, numerical solver error beyond discretization error is not required to be formally assessed. Iterative convergence was monitored to residual levels below 1e-5 for all equations, and mass imbalance was confirmed below 0.01% for all operating points. No formal solver error quantification beyond this monitoring is required by the credibility framework at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; standard simulation review checklist applied.",
      "rationale": "Use error assessment is not required at MRL 2. A peer-review checklist covering boundary condition specification, material property assignment, solver settings, and post-processing procedures was completed by a second qualified analyst. No discrepancies were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection must be justified by reference to published literature or sensitivity studies demonstrating that the chosen turbulence closure and hemolysis power-law model are appropriate for the flow regime and shear stress range encountered in CPB pumps.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for rotating machinery flows with adverse pressure gradients. Sensitivity analysis comparing SST k-omega, realizable k-epsilon, and RSM closures showed NIH variations of less than 15% across models, with SST k-omega producing results closest to experimental data. The Giersiepen hemolysis power-law model was selected over the Heuser-Opitz formulation based on a literature review of 12 published CFD hemolysis studies for centrifugal pumps, of which 9 used Giersiepen with reported validation errors in the 10–30% range consistent with the present study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs with sensitivity rank above 10% of total output variance must have documented sources and uncertainty bounds; geometric inputs must be derived from calibrated CMM measurements with traceable uncertainty.",
      "rationale": "A one-at-a-time sensitivity analysis identified impeller clearance gap, blood viscosity, and inlet turbulence intensity as the three inputs with greatest influence on NIH (contributing 41%, 18%, and 12% of output variance respectively). Geometric inputs were derived from CMM measurements with ±5 µm uncertainty. Blood viscosity was set to 0.0035 Pa·s ± 8% based on published whole-blood rheology data. Inlet turbulence intensity was varied ±50% in a sensitivity study, confirming NIH sensitivity below the 15% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal test sample characterization beyond standard blood analog preparation protocols is not required at MRL 2. The FDA benchmark dataset used for validation employed blood analog fluid prepared according to ASTM F1841 procedures, providing adequate confidence in fluid property consistency."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Equivalency of input parameters between validation and COU conditions is not required to be formally assessed at MRL 2. The close correspondence of validation and COU operating conditions (documented under Test Conditions and Relevance of Validation Activities) provides adequate informal assurance of input equivalency."
    }
  ],
