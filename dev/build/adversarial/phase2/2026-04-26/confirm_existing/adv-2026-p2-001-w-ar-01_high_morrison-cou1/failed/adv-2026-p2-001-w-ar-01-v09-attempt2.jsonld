  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented release testing; all simulation scripts checked into a tracked repository with diff history available for audit.",
      "rationale": "ANSYS Fluent 2021R2 is used under institutional license with documented version control. All case files, UDFs, and post-processing scripts are stored in a Git repository with tagged release commits corresponding to each simulation campaign. A software QA checklist was completed prior to each run batch, confirming solver version, license validity, and input file hash integrity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce at least two canonical benchmark cases (e.g., lid-driven cavity, rotating disk) to within 2% of published reference solutions at the mesh density used in the study.",
      "rationale": "ANSYS Fluent has been verified against the ASME V&V 20 standard benchmark suite including lid-driven cavity flow and rotating disk flow. Results for velocity profiles and shear stress distributions agree with published reference solutions to within 1.4% at the mesh density employed in this study. Verification documentation is archived in the project quality file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for the primary QoI (volume-averaged scalar stress) on the fine-to-medium mesh refinement pair; Richardson extrapolation must confirm monotonic convergence.",
      "rationale": "A three-level mesh refinement study was performed using coarse (4.2M cells), medium (9.8M cells), and fine (22.1M cells) meshes. GCI values for the volume-averaged scalar stress were 8.3% (coarse-to-medium) and 2.1% (medium-to-fine), confirming monotonic convergence. The fine mesh was selected as the production mesh. Richardson extrapolation yielded an asymptotic ratio of 1.02, confirming that the solution is within the asymptotic range of convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with measured fluid temperature, hematocrit, and pump operating point (flow rate ± 5%, rotational speed ± 10 RPM) to enable direct comparison with simulation boundary conditions.",
      "rationale": "Experimental validation data from the FDA benchmark hemolysis study were used. Test conditions including fluid temperature (37 °C ± 0.5 °C), hematocrit (30%), and five operating points (flow rates 2.5–6 L/min, speeds 2000–3500 RPM) are fully documented in the published dataset. Boundary conditions in the CFD model were set to match measured values within stated experimental uncertainties."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within the combined experimental uncertainty band (typically ±25% for hemolysis assays) at all five operating points.",
      "rationale": "Predicted NIH values were compared against experimental measurements at all five operating points. Agreement was within 18% at four of five points and 23% at the fifth point (3500 RPM, 2.5 L/min), which falls within the combined experimental uncertainty band of ±25% reported for the reference dataset. The comparison supports adequate predictive capability for relative ranking of operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (NIH or scalar stress proxy) must be mechanistically linked to the COU QoI (relative hemolysis index RH) through a documented power-law damage accumulation model with cited literature support.",
      "rationale": "The primary QoI for validation is the normalized index of hemolysis (NIH), which is directly related to the COU QoI (relative hemolysis index RH) through the Giersiepen-Wurzinger power-law damage model. The mechanistic linkage is documented and the model coefficients are drawn from peer-reviewed literature. Sensitivity of RH rankings to QoI choice was confirmed to be low across the five operating points studied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The validation activities were conducted on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions in the validation campaign span the full range of COU operating points (2.5–6 L/min, 2000–3500 RPM), ensuring that no extrapolation beyond the validated regime is required. The working fluid (bovine blood analog, hematocrit 30%) closely matches the COU fluid properties. The validation dataset includes both low-shear and high-shear operating regimes, providing confidence that the model captures the relevant hemolysis physics across the COU envelope. Furthermore, the experimental apparatus replicated the inlet swirl conditions and outlet pressure boundary conditions specified in the COU, minimising boundary condition discrepancy as a source of validation uncertainty. The assessment team reviewed the validation pedigree against the ASME V&V 40 Table 3 relevance criteria and concluded that all six relevance dimensions — geometry, operating conditions, fluid properties, QoI, boundary conditions, and length/time scales — are adequately matched at Gradation 2. This conclusion is consistent with the MRL 2 determination and the medium model influence classification assigned in the COU. Peer review of the validation relevance assessment was conducted by an independent CFD specialist not involved in the original simulation work, and no material deficiencies were identified. The validation activities are therefore judged to provide adequate evidentiary support for the COU without requiring supplemental validation at additional operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoped out per V&V 40 Table 3.",
      "rationale": "Per ASME V&V 40 Table 3, numerical solver error assessment is not required at Model Risk Level 2 for this device class and model influence combination. The factor is acknowledged but not assessed in this credibility package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; acknowledged per V&V 40 Table 3 scoping.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 per ASME V&V 40 Table 3 for this combination of model influence (Medium) and decision consequence (High). The factor is scoped out of the current assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; scoped out per V&V 40 Table 3.",
      "rationale": "Model form uncertainty quantification is not required at Model Risk Level 2 for this COU. The turbulence model sensitivity study (SST k-omega vs realizable k-epsilon) was performed as a supplemental activity and showed less than 8% variation in NIH predictions; however, formal model form assessment per Gradation 2+ criteria is not required and has not been conducted."
    },
    {
      "type": "CredibilityFactor",
