  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for Model Risk Level 2. Six factors are appropriately not assessed at MRL 2 per ASME V&V 40-2018 Table 1 requirements. The CFD model demonstrates sufficient credibility to support the regulatory decision of identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index criterion (RH < 1) is met across all evaluated operating points with quantified uncertainty. The assessment team accepts the model for its intended use as defined in COU1.",
