  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The CFD solver must be documented under a quality management system consistent with FDA 21 CFR Part 820. Version-controlled code, regression test suite coverage ≥ 80%, and documented release notes are required at MRL 2.",
      "rationale": "STAR-CCM+ v14.06 was employed under Siemens PLM QMS certification. Version control records and regression test documentation were reviewed and confirmed compliant with the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Benchmark verification cases (lid-driven cavity, Poiseuille flow) must be reproduced within 1% of analytical solutions. Order-of-accuracy tests must confirm nominal second-order convergence for the spatial discretization scheme employed.",
      "rationale": "Standard benchmark problems including the lid-driven cavity at Re=1000 and fully developed pipe flow were reproduced within 0.4% of analytical solutions. Observed order of accuracy of 1.97 confirmed nominal second-order spatial convergence for the finite-volume scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed using a minimum of three systematically refined meshes with refinement ratio ≥ 1.3. GCI for the primary QoI (hemolysis index) must not exceed 5% at the finest mesh level.",
      "rationale": "A three-level mesh refinement study was conducted with refinement ratio r = 1.41. GCI values for the normalized index of hemolysis (NIH) ranged from 0.8% to 3.2% across the five operating points, comfortably below the 5% threshold. The achieved level of 3 reflects the systematic Richardson extrapolation applied in addition to standard GCI reporting."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must replicate at least 80% of the COU operating envelope. Fluid temperature, hematocrit, and flow rate must be documented and matched within stated tolerances.",
      "rationale": "FDA generic pump experiments were conducted at 37°C with bovine blood at 30% hematocrit across flow rates of 2–6 L/min and rotational speeds of 2000–3500 RPM, spanning the full CPB operating envelope defined in the COU. All boundary conditions were documented in the experimental protocol and reproduced in simulation inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within ±25% across all five operating points. A quantitative metric (e.g., NRMSE or mean absolute percentage error) must be reported.",
      "rationale": "Predicted NIH values agreed with experimental measurements within 18% across all five flow-speed combinations. Mean absolute percentage error was 11.3%. Scatter plots and tabular comparisons are provided in Appendix C of the V&V report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The primary QoI (NIH and relative hemolysis index RH) must be directly traceable to the clinical endpoint (patient hemolysis risk) and to the regulatory submission metric. A traceability matrix linking simulation outputs to device performance requirements must be present.",
      "rationale": "The NIH and RH index are the standard FDA-recognized metrics for blood pump hemolysis assessment per the FDA Guidance on Computational Fluid Dynamics. A traceability matrix linking these outputs to the 510(k) performance requirement (RH < 1 relative to predicate) is documented in the Design History File."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "rationale": "The validation dataset derives from the FDA generic centrifugal blood pump, which shares geometric and operational similarity with the device under assessment. Operating conditions (flow rates 2–6 L/min, speeds 2000–3500 RPM, blood analogue fluid properties) are representative of the CPB COU envelope. The validation activities were designed specifically to support MRL 2 credibility for hemolysis prediction in rotary blood pumps, and the similarity assessment documented in Section 4.2 of the V&V report confirms that no extrapolation beyond the validated domain is required for the five COU operating points. The power law hemolysis model (Giersiepen et al., modified by Heuser and Opitz) was validated against the same class of turbomachinery flows, and the turbulence model selection (SST k-ω) was justified by its established performance for swirling confined flows with adverse pressure gradients typical of centrifugal pump impeller passages. Boundary condition fidelity was confirmed by comparing inlet velocity profiles from LDV measurements against CFD predictions at three axial stations, yielding maximum deviations of 6.2% in mean velocity and 9.1% in turbulent kinetic energy — both within the MRL 2 tolerances established by the project V&V plan. Taken together, the scope, fidelity, and domain coverage of the validation activities are fully sufficient to support the intended use without additional validation campaigns at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2; inherent solver error controls documented by vendor QMS are accepted as sufficient.",
      "rationale": "At MRL 2, independent assessment of numerical solver error beyond vendor-supplied verification is not required. Solver residual convergence to 1e-5 was confirmed for all simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2; simulation setup review by a second analyst is accepted as the control.",
      "rationale": "Simulation setup was independently reviewed by a second CFD analyst prior to production runs. No use errors were identified. Formal use-error assessment is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
