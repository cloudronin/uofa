  "signature": "ed25519:7c3e1a9f4b2d6e8c0f5a3b7d1e4c9f2a6b8d0e3c5f7a1b4d6e8c2f0a3b5d7e9",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 2 requires documented version control, build reproducibility logs, and regression test suite covering at least core solver routines. Achieved level confirmed by audit of ANSYS Fluent 2022R2 release notes and internal SQA checklist.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated platform with documented software quality assurance processes meeting Gradation 2 requirements under ASME V&V 40. Version control records, release validation reports, and regression test results were reviewed. No defects affecting hemolysis-relevant solver routines were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at level 2 requires demonstration of correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark for at least one canonical flow configuration relevant to the COU.",
      "rationale": "Numerical code verification was performed using the lid-driven cavity benchmark and a rotating channel flow case representative of centrifugal pump internal flow. Results were compared against published analytical solutions and high-fidelity reference data. Observed order of convergence matched theoretical expectations for the second-order spatial discretization scheme employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error assessment at level 2 requires a systematic mesh refinement study with at least three grid levels and application of Richardson extrapolation or GCI to quantify numerical uncertainty on the primary QoI (relative hemolysis index).",
      "rationale": "A three-level mesh refinement study was conducted on the FDA generic centrifugal pump geometry using coarse (2.1M), medium (5.8M), and fine (14.2M) cell counts. Grid Convergence Index (GCI) was computed for the relative hemolysis index at all five operating points. Maximum GCI on the fine grid was 1.8%, well within the 5% threshold. The achieved level of 3 reflects the additional Richardson extrapolation applied to shear-stress-derived hemolysis metrics."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions at level 2 require documented characterization of experimental boundary conditions including inlet flow rate uncertainty, rotational speed tolerance, and fluid temperature, with traceability to calibrated instrumentation.",
      "rationale": "Experimental test conditions were sourced from the FDA benchmark dataset for the generic centrifugal blood pump. Inlet flow rates were controlled to within ±2% using a Coriolis mass flow meter (NIST-traceable calibration). Rotational speed was maintained at ±5 RPM. Fluid temperature was held at 37°C ± 0.5°C using a temperature-controlled bath. All instrumentation calibration records were reviewed and found current."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison at level 2 requires quantitative comparison of model predictions against experimental measurements using a defined metric (e.g., relative error, validation uncertainty) for the primary QoI across all COU-relevant operating conditions.",
      "rationale": "CFD-predicted relative hemolysis index (RHI) was compared against experimental measurements at all five flow-speed operating points. Mean relative error was 8.3% across operating points, with maximum error of 14.1% at the highest flow rate condition. Validation uncertainty was computed following ASME V&V 20 methodology. The comparison supports model adequacy for the intended use of identifying worst-case hemolysis conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The primary quantity of interest, the relative hemolysis index (RHI = NIH_device / NIH_predicate), directly maps to the clinical endpoint of concern — erythrocyte damage under CPB conditions. The RHI is computed from CFD-derived shear stress fields using the Giersiepen-Wurzinger power-law hemolysis model, which has been extensively validated for centrifugal pump geometries in the published literature. The QoI is well-established in FDA guidance for Class II blood-contacting devices and is directly used in the regulatory submission decision. The mapping from computational output to clinical relevance is unambiguous: RHI < 1.0 indicates the device does not exceed predicate hemolysis levels at any evaluated operating condition. The selection of RHI as the sole primary QoI was reviewed by the clinical team and confirmed to capture the full scope of hemolysis risk relevant to the COU. Secondary QoIs including wall shear stress distribution and scalar dissipation rate were monitored for physical plausibility but are not part of the formal acceptance determination. The level 2 requirement for this factor at MRL 2 is consistent with the moderate model influence classification: the CFD results are used in conjunction with confirmatory in vitro testing, which provides an independent check on the model's hemolysis predictions before any regulatory or design decision is finalized. The clinical team's endorsement of RHI as the appropriate QoI, combined with its direct regulatory precedent, provides strong justification that the quantities being predicted are the quantities that matter for patient safety in the CPB context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities at level 2 must address the same physical regime (rotational Reynolds number, hematocrit, shear exposure time) as the COU and use a geometry sufficiently similar to the device of interest to support extrapolation of validation conclusions.",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump, which shares geometric similarity with the Class II CPB device under assessment. Operating conditions in the validation campaign spanned the full range of flow rates and rotational speeds encountered in the COU (2–6 L/min, 2000–3500 RPM). Hematocrit was matched to clinical CPB conditions (33%). The validation geometry differs from the production device only in impeller blade count; a sensitivity study confirmed this difference does not materially affect the hemolysis prediction fidelity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 with medium model influence, numerical solver error beyond discretization error (e.g., iterative convergence, floating-point round-off) is not required to be formally assessed provided residual convergence to 1e-5 is documented.",
      "rationale": "Numerical solver error beyond discretization uncertainty is scoped out at MRL 2 per the ASME V&V 40 credibility factor matrix. Iterative residuals were monitored and confirmed to converge to below 1e-5 for all equations at all operating points, providing adequate assurance that solver error is negligible relative to other uncertainty sources."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment at level 1 requires only that the simulation was executed by a qualified analyst following documented procedures. No independent re-execution or formal human factors analysis is required at MRL 2.",
      "rationale": "Use error is not formally assessed at MRL 2 for this factor. The simulation was executed by a CFD analyst with documented training and experience in cardiovascular device simulation. Standard operating procedures for model setup, boundary condition application, and post-processing were followed and are archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assessment at level 2 requires documented justification of the turbulence model selection and hemolysis constitutive model, including comparison of at least two candidate model forms against experimental data or published benchmarks.",
      "rationale": "The SST k-omega turbulence model was selected based on its established performance for internal rotating flows with adverse pressure gradients. A comparison against the realizable k-epsilon model was performed; SST k-omega produced lower error against experimental velocity profiles in the impeller passage (mean error 6.1% vs 11.4%). The Giersiepen-Wurzinger hemolysis power-law model was selected over the Zhang model based on superior agreement with the FDA benchmark hemolysis dataset. Model form uncertainty is estimated at ±12% on RHI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs at level 2 require documented characterization of principal input parameters (geometry tolerances, fluid rheology, boundary conditions) with uncertainty bounds derived from measurement data or published material property databases.",
      "rationale": "Principal model inputs including impeller geometry (dimensional tolerances ±0.05 mm), blood viscosity (Newtonian approximation at 37°C, 3.5 mPa·s ±5%), and inlet velocity profiles were characterized with uncertainty bounds. A one-at-a-time sensitivity study identified rotational speed and inlet flow rate as the dominant inputs affecting RHI. These were subsequently treated with tighter uncertainty bounds in the formal uncertainty propagation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test samples at level 1 require only that the experimental specimens used in validation are documented as representative of the device population. No statistical sampling plan or inter-unit variability study is required at MRL 2.",
      "rationale": "Test sample characterization is not required beyond level 1 at MRL 2. The FDA generic centrifugal pump used in the validation campaign is a standardized geometry; sample-to-sample variability is not applicable. For the production device, dimensional inspection records confirm the tested units fall within nominal tolerance bands."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Equivalency of input parameters at level 2 requires a documented mapping between validation experiment inputs and COU inputs, with quantitative assessment of any gaps in Reynolds number, geometric similarity, or fluid properties.",
      "rationale": "A structured equivalency assessment was performed comparing validation experiment inputs to COU inputs. Rotational Reynolds number in the validation campaign (Re_rot = 1.2e5 to 3.1e5) fully spans the COU operating range. Geometric similarity between the FDA generic pump and the Class II CPB device was assessed via dimensionless impeller parameters (specific speed, diameter ratio); all parameters fall within 8% of the validation geometry. Fluid property equivalency was confirmed by matching hematocrit and temperature. No material gaps were identified that would invalidate extrapolation of validation conclusions to the COU."
    }
  ],
