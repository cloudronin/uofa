  "signature": "ed25519:b7e2a1f4c903d856e1a2bc4f7d803c1a5e9b2d6f4c0e8a3b1d7f2c5e9a4b801d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be developed and maintained under a documented QA plan with version control, regression testing, and audit trail consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is under ISO 9001-compliant QA with full version control and automated regression test suite. All 47 regression cases pass. Achieved level meets required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) must confirm expected convergence rates for all governing equations used in the hemolysis model.",
      "rationale": "MMS verification confirms second-order spatial convergence for the Navier-Stokes solver and first-order convergence for the scalar hemolysis transport equation. Code verification is complete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be computed on at least three systematically refined meshes; GCI on hemolysis index must be below 5% for all operating points.",
      "rationale": "Three mesh refinement levels (4.2M, 11.8M, 31.4M cells) were evaluated. GCI on hemolysis index ranges from 3.1% to 7.8% depending on operating point. The highest-flow condition exceeds the 5% threshold, yielding achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with measurement uncertainty for inlet flow rate, rotational speed, and fluid temperature. Conditions must bracket the COU operating envelope.",
      "rationale": "FDA pump experiments were conducted at 2500 and 3500 RPM across flow rates 2–8 L/min. Temperature was controlled to 37±0.5°C. All five COU operating points fall within the bracketed experimental envelope. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted vs. measured hemolysis index using normalized index of agreement (NIA) must exceed 0.85 across all validation cases.",
      "rationale": "NIA values range from 0.79 to 0.91 across the validation dataset. Three of seven cases fall below the 0.85 threshold, particularly at high-shear operating points. Achieved level 3 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index, normalized index of hemolysis) must be the same metric used in the COU regulatory submission and must map directly to the clinical threshold.",
      "rationale": "The normalized index of hemolysis (NIH) is used consistently across validation activities and the COU submission. The clinical threshold is expressed in the same units. Full QoI relevance is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a pump geometry and operating regime sufficiently similar to the COU device that extrapolation uncertainty is bounded and documented.",
      "rationale": "Validation was performed on the FDA generic pump, which shares impeller topology with the COU device but differs in volute geometry. Extrapolation uncertainty is partially bounded by sensitivity analysis but not fully characterized at all operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver iterative convergence must be demonstrated to residual levels consistent with MRL 5 practice; floating-point reproducibility must be confirmed across parallel decompositions.",
      "rationale": "The credibility assessment team reviewed solver convergence logs and confirmed residuals meet standard practice thresholds. This factor was reviewed holistically as part of the integrated verification assessment and was judged to contribute positively to the overall acceptance determination."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation plan and independent review process must be in place to detect and prevent analyst-induced errors in boundary condition setup, material property assignment, and post-processing.",
      "rationale": "The credibility assessment team reviewed available documentation and concluded that analyst error controls are in place consistent with general best practice. This factor was considered in the overall credibility determination without assignment of discrete gradation levels."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis constitutive model (power-law damage accumulation) must be validated against at least two independent experimental datasets with documented model-form uncertainty quantification.",
      "rationale": "The Giersiepen-Wurzinger power-law model was validated against the FDA pump dataset and one additional in-vitro dataset. Model-form uncertainty is estimated at ±35% on absolute NIH values. A second independent dataset with full uncertainty characterization was not available, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood rheological properties (viscosity, density) and hemolysis model coefficients must be characterized with documented uncertainty bounds derived from literature or direct measurement.",
      "rationale": "Blood viscosity and density are taken from published literature with documented ranges. Hemolysis model coefficients (alpha, beta) are assigned uncertainty distributions based on Giersiepen et al. and propagated via Monte Carlo. Achieved level meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood analog or bovine blood used in validation experiments must be characterized for hematocrit, osmotic fragility, and storage age; inter-sample variability must be documented.",
      "rationale": "Validation experiments used bovine blood with documented hematocrit (35±2%) but osmotic fragility and storage age were not systematically recorded across all test sessions. Inter-sample variability is estimated from hematocrit alone, which is insufficient for MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, boundary conditions, fluid properties) used in validation must demonstrably correspond to the physical test conditions within documented tolerances.",
      "rationale": "CAD geometry used in simulation was derived from pump drawings rather than direct measurement of the test article. Dimensional correspondence was verified at nominal dimensions only; manufacturing tolerances were not incorporated into the simulation inputs, reducing equivalency confidence."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "After reviewing all thirteen credibility factors, the assessment team determined that the overall body of evidence is sufficient to support model acceptance for the stated COU. The majority of assessed factors achieved their required credibility levels, and the remaining gaps were judged to be adequately mitigated by the Monte Carlo uncertainty quantification and conservative clinical threshold margin. The model is accepted for use in predicting absolute hemolysis index values for the Class III VAD device.",
