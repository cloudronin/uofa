  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must comply with documented version control, regression testing, and change management procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is under version control and regression tests are maintained; however, formal change management documentation is incomplete, leaving achievedLevel at 3 against the required 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies must confirm spatial and temporal convergence rates match theoretical expectations for the governing equations implemented.",
      "rationale": "Spatial convergence was demonstrated on canonical pipe-flow cases; temporal convergence studies are incomplete for rotating-frame formulations, yielding achievedLevel 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must bound discretization error contribution to hemolysis index prediction to within ±10% at all operating points.",
      "rationale": "Richardson extrapolation was applied on three mesh levels; error bounds exceed the ±10% target at two high-speed operating points, limiting achievedLevel to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must reproduce the five target VAD operating points within stated uncertainty bounds for flow rate and rotational speed.",
      "rationale": "Flow rate was matched within ±2%; rotational speed uncertainty at the highest operating point exceeded the allowable bound, reducing achievedLevel to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty at all five operating points.",
      "rationale": "Agreement is within uncertainty bounds at three of five operating points; two points show systematic over-prediction, limiting achievedLevel to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest computed in validation activities must directly correspond to the absolute hemolysis index used in the clinical acceptance criterion.",
      "rationale": "The normalised hemolysis index used in validation differs slightly from the absolute index required clinically; a correction factor is applied but introduces additional uncertainty, holding achievedLevel at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analogue fluid as the COU, operated at clinically representative conditions.",
      "rationale": "Validation used a glycerol-water analogue rather than porcine blood; rheological similarity arguments are provided but do not fully close the gap at MRL 5, yielding achievedLevel 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of the CFD solver must be demonstrated to have negligible effect on hemolysis index predictions relative to other uncertainty sources.",
      "rationale": "The assessment team noted that solver convergence monitoring was performed, but the documentation package did not include quantified residual thresholds or sensitivity runs sufficient to assign formal gradation levels. Factor recorded as assessed pending supplemental evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Procedures must be in place to detect and prevent analyst errors in model setup, boundary condition assignment, and post-processing for hemolysis calculations.",
      "rationale": "The assessment team noted that use-error controls were partially documented, but the documentation package did not include quantified residual thresholds or sensitivity runs sufficient to assign formal gradation levels. Factor recorded as assessed pending supplemental evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis damage model form must be justified against mechanistic understanding of red blood cell lysis under shear stress, with uncertainty in model-form assumptions quantified.",
      "rationale": "The power-law hemolysis model is widely used but is known to have significant model-form uncertainty; Lagrangian path-based corrections are applied but do not raise achievedLevel above 3 against the required 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and boundary condition inputs to the hemolysis model must be characterised with documented uncertainty distributions for use in Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was performed; however, the power-law exponent distribution was assumed uniform rather than derived from experimental data, reducing confidence and capping achievedLevel at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental dataset must include sufficient repeat measurements to characterise biological variability in hemolysis index across operating conditions.",
      "rationale": "Only three biological replicates were available per operating point; statistical power is insufficient to fully characterise inter-sample variability, yielding achievedLevel 2 against required 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be shown to be equivalent to those used in the COU predictions, with any differences bounded and their effect on hemolysis index quantified.",
      "rationale": "Inlet velocity profiles differ between validation and COU due to upstream geometry differences; sensitivity runs show less than 8% effect on hemolysis index, supporting achievedLevel 3 but not 4."
    }
  ],
