      "name": "Bench-scale hemolysis validation against FDA pump experimental data (5 operating points)"
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-hemolysis-2024",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis index predictions across operating envelope"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043671",
