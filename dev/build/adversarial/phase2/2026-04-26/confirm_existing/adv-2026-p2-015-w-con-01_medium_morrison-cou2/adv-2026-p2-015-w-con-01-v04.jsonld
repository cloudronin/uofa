  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be developed under a quality management system with version control, unit testing, and documented release procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is maintained under ISO 9001-aligned QMS with version-controlled releases. Unit and regression test suites cover core flow and transport solvers. Achieved level 3 reflects absence of formal independent code audit; required level 4 is not yet met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies using manufactured solutions must confirm spatial and temporal convergence rates match theoretical expectations for all governing equations.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes and scalar transport equations confirms second-order spatial convergence. Temporal convergence verified for BDF2 scheme. Hemolysis transport sub-model not independently verified; gap drives achieved level to 3 vs required 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; discretization error must be below 5% of QOI at the operating points of interest.",
      "rationale": "Three-level mesh refinement study performed; GCI computed per Roache methodology. Discretization error on bulk flow QOIs is within 3.8%. Near-wall hemolysis prediction shows 7.2% GCI at high-shear regions, exceeding the 5% threshold and preventing achievement of required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match the simulated operating envelope within stated tolerances; fluid properties, rotational speed, and flow rates must be documented and traceable.",
      "rationale": "FDA pump bench tests conducted at 2500 and 3500 RPM across five flow rates. Fluid properties (viscosity, density) measured and reported. Operating conditions replicated in simulation within ±1.5% on flow rate and ±0.5% on rotational speed. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, U_val) must be computed for all primary QOIs; simulation must fall within combined experimental and numerical uncertainty bands at required level.",
      "rationale": "Hemolysis index predictions compared against experimental measurements at all five operating points. Mean absolute error is 18% of measured values. Combined uncertainty analysis shows simulation outside validation uncertainty band at two operating points, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation must be directly traceable to the clinical decision criterion (absolute hemolysis index below threshold); surrogate QOIs must be justified.",
      "rationale": "Primary QOI is the normalized index of hemolysis (NIH) directly compared against the clinical acceptance threshold. No surrogate QOIs introduced. Traceability from simulation output to clinical criterion is documented. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid, and operating range as the COU; validation at surrogate geometries must be formally justified with extrapolation uncertainty quantified.",
      "rationale": "Validation performed on the FDA generic pump geometry, which is a surrogate for the proprietary VAD impeller. Geometric similarity is approximately 85% by blade angle and tip clearance metrics. Extrapolation uncertainty from generic to patient-specific VAD geometry is not quantified, limiting achieved level to 2 against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of the nonlinear solver must be demonstrated to residual tolerances consistent with MRL 5; floating-point reproducibility must be confirmed across platforms.",
      "rationale": "The numerical solver convergence behavior was reviewed as part of the general simulation quality assessment. Residual behavior was considered acceptable by the assessment team based on engineering judgment and prior experience with similar pump geometries."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence must demonstrate that the model is operated within its validated parameter space and that user inputs have been independently reviewed for correctness.",
      "rationale": "The assessment team reviewed use error considerations as part of the overall credibility evaluation. General engineering controls were applied and the team concluded that use error risk was acceptable within the broader assessment framework."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence and hemolysis constitutive models must be justified for high-shear rotating flow; sensitivity of hemolysis predictions to model form assumptions must be quantified.",
      "rationale": "SST k-omega turbulence model selected based on literature for rotating machinery. Power-law hemolysis model (Giersiepen-Wurzinger) used without evaluation of alternative formulations. Model form sensitivity study not performed. Achieved level 2 reflects absence of formal model form uncertainty quantification against required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources, uncertainty characterization, and sensitivity analysis demonstrating impact on hemolysis QOI.",
      "rationale": "Monte Carlo uncertainty quantification performed on 12 input parameters including fluid viscosity, rotational speed, and hemolysis model coefficients. One-at-a-time sensitivity analysis identifies hemolysis exponent as dominant parameter. Full Sobol index analysis not completed, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for material properties and lot-to-lot variability; sample size must support statistical comparison.",
      "rationale": "Validation experiments conducted using bovine blood from a single lot. Inter-lot variability in erythrocyte fragility not characterized. Sample size of n=3 replicates per operating point provides limited statistical power. Achieved level 2 reflects single-lot limitation against required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrably equivalent to those used in the COU simulations; any differences must be bounded and their effect on QOI quantified.",
      "rationale": "Validation simulations used bovine blood viscosity (3.5 mPa·s) while COU targets human blood (3.2–4.0 mPa·s range). Equivalency mapping performed for nominal values only; impact of viscosity range on hemolysis predictions not propagated. Achieved level 2 vs required level 3."
    }
  ],
