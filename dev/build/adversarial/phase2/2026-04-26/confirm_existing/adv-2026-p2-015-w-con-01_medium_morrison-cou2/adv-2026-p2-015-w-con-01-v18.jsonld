  "signature": "ed25519:9b3e1f7a4c2d6b0e5f8a3c7d1b4e9f2a6c0d5b8e3f7a1c4d9b2e6f0a5c8d3b7e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be developed under a documented quality management system with version control, issue tracking, and regression testing consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is developed under ISO 9001-compliant QMS with full version control and regression test suite. However, hemolysis sub-model source code lacks independent peer review, and regression coverage for non-Newtonian rheology paths is incomplete. Achieved level 3 falls short of required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and manufactured solution verification must confirm solver implementation correctness for all active physics modules at MRL 5.",
      "rationale": "Method of manufactured solutions confirms second-order spatial accuracy for momentum and continuity equations. Hemolysis damage integral implementation verified against analytical test cases at low shear. High-shear regime verification is absent, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be reported for all QoIs across at least three systematically refined meshes; GCI must be below 5% for hemolysis index.",
      "rationale": "Three-level mesh refinement study performed; GCI for pressure rise is 2.1%. GCI for hemolysis index reaches 8.3% in high-shear impeller passages, exceeding the 5% threshold. Achieved level 3 rather than required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances; fluid temperature, hematocrit, and flow rate must be controlled and reported.",
      "rationale": "FDA pump bench experiments conducted at 37 °C, hematocrit 30 ± 2%, across five flow-speed points matching the COU envelope. All boundary conditions documented with calibrated instrumentation. Required and achieved levels both at 3; factor met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or NRMSE) must be computed for hemolysis index across all five operating points; systematic bias must be characterised.",
      "rationale": "Normalised root-mean-square error for hemolysis index is 34% across five points, with systematic over-prediction at high speed. Pressure-head agreement is within 4%. Hemolysis output comparison is substantially below required level 4; achieved level 2 recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly traceable to the clinical decision metric (absolute hemolysis index) and must not be surrogate quantities.",
      "rationale": "Normalised index of hemolysis (NIH) is the primary QoI in both simulation and experiment, directly matching the clinical acceptance threshold. No surrogate quantities used. Required and achieved levels both 4; factor met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analogue as the COU device; operating conditions must span the full COU envelope.",
      "rationale": "FDA generic pump geometry used in validation matches COU geometry exactly. Bovine blood analogue differs from human blood in viscosity at high shear; two of five operating points fall outside the validated flow range. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual norms below 1e-5 for all equations; time-step sensitivity documented for transient cases.",
      "rationale": "All steady-state simulations converged to residual norms below 1e-6. Transient impeller passage simulations demonstrate less than 0.5% change in NIH with halved time-step. Solver error factor achieved at required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented user qualification records, simulation execution checklists, and independent review of boundary condition setup must be present for all MRL 5 simulations.",
      "rationale": "Simulation setup performed by a single analyst without independent boundary-condition review. No formal user qualification record on file for the hemolysis sub-model configuration. Checklist used but not signed off by a second reviewer. Achieved level 2 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected constitutive hemolysis model must be justified against alternative model forms and its applicability to the COU shear-rate regime documented.",
      "rationale": "The credibility evidence package was assembled under time constraints and the model form assessment was deferred pending an ongoing literature review of power-law versus strain-based hemolysis models. Levels will be assigned in a subsequent revision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterised with uncertainty bounds; sensitivity analysis must identify influential inputs for hemolysis prediction.",
      "rationale": "Monte Carlo UQ propagates uncertainty in fluid viscosity, hematocrit, and pump clearance gaps. Power-law exponent for the hemolysis damage model is treated as deterministic despite literature spread of ±15%. Sensitivity indices computed via Sobol decomposition. Achieved level 3 versus required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent experimental replicates per operating point must be available; inter-sample variability must be reported.",
      "rationale": "Only two replicates available for three of the five operating points due to limited blood analogue supply. Inter-sample coefficient of variation reaches 18% at the highest speed point. Achieved level 2 versus required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated to be equivalent to those applicable in the COU; any deviations must be quantified.",
      "rationale": "Assessment of input parameter equivalency between the validation configuration and the COU operating envelope has not been formally completed. The responsible engineer noted that this factor overlaps substantially with model inputs and test conditions assessments already recorded; a consolidated level assignment is pending internal review sign-off."
    }
  ],
