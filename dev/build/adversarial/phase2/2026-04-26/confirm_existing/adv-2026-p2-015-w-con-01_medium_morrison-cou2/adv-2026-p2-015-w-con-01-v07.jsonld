  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Software quality plan with version control, regression testing, and documented build procedures must meet Gradation 4 requirements for MRL 5.",
      "rationale": "The CFD solver is under version control and regression tests are maintained, but the formal software quality plan does not fully satisfy Gradation 4 documentation requirements. Achieved level falls one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy testing on canonical flows and manufactured solutions must be demonstrated to Gradation 4 for all active physics modules.",
      "rationale": "Order-of-accuracy tests confirm second-order spatial convergence for the Navier-Stokes solver; however, the hemolysis transport scalar equation was not independently verified via manufactured solution. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis on three systematically refined meshes demonstrating discretization error below 5% on hemolysis index.",
      "rationale": "Three-level mesh refinement study was completed. GCI on pressure rise is 1.8%; GCI on hemolysis index is 8.3%, exceeding the 5% threshold. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty bounds and must span the COU operating envelope to Gradation 3.",
      "rationale": "FDA pump experimental data covers three of five target flow-speed combinations. Boundary conditions are documented but inlet turbulence intensity was not measured, introducing unquantified uncertainty in the validation dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must be computed for hemolysis index and pressure rise with uncertainty bands to Gradation 4.",
      "rationale": "Validation metrics are computed for pressure rise and velocity field; hemolysis index comparison uses a simplified mean-error metric without propagated experimental uncertainty. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, pressure rise) must directly correspond to the clinical decision QoIs to Gradation 4.",
      "rationale": "Hemolysis index and pump pressure rise are the primary clinical QoIs and are directly measured in both validation experiments and COU simulations. Full correspondence is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analogue fluid as the COU to Gradation 4.",
      "rationale": "Validation uses the FDA generic pump geometry, which matches the COU device. However, the blood analogue fluid (glycerol-water) differs from physiological blood in viscosity-shear behaviour, reducing relevance to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be characterized and shown to be negligible relative to discretization error.",
      "rationale": "The credibility assessment team noted that solver residual convergence was monitored but formal documentation of round-off error bounding and iterative tolerance sensitivity was not completed in the current submission cycle. Level assignment is deferred pending supplemental analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of analyst training, simulation input review, and independent result verification must be provided consistent with MRL 5 requirements.",
      "rationale": "The credibility assessment team noted that use-error controls were partially documented. Independent result verification was performed informally; a structured review record was not available at the time of assessment. Level assignment is deferred pending supplemental documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "The chosen turbulence and hemolysis constitutive models must be justified against literature evidence for rotating blood-contacting flows to Gradation 4.",
      "rationale": "The SST k-omega turbulence model is justified by published comparisons on similar pump geometries. The Giersiepen-Wurzinger hemolysis power-law is applied without recalibration to the specific pump geometry, limiting model form credibility to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "All material properties and boundary conditions must be characterised with uncertainty bounds and sensitivity analysis to Gradation 4.",
      "rationale": "Monte Carlo UQ propagates uncertainty in blood viscosity and inlet flow rate. Geometric tolerance uncertainty on impeller blade angles was not included in the UQ, and no sensitivity ranking was performed, limiting achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "The number and variability of physical test samples used in validation must be sufficient to characterise unit-to-unit variability to Gradation 3.",
      "rationale": "Only a single FDA generic pump unit was used in all validation experiments. Unit-to-unit manufacturing variability was not characterised. Achieved level is 1, well below required level of 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "acceptanceCriteria": "Input parameters in validation simulations must be demonstrated equivalent to COU simulation inputs to Gradation 3.",
      "rationale": "Equivalency of input parameters between validation and COU simulations was not formally assessed. Differences in rotational speed range and fluid temperature between experimental and COU conditions were noted but not quantified. Achieved level is 1."
    }
