  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software development lifecycle documentation, version control, and regression testing must meet Gradation 4 under MRL 5 requirements.",
      "rationale": "SQA procedures are documented and version-controlled. Regression test suite covers 87% of solver code paths. Gradation 4 requires formal independent code review which has not been completed; achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing and method-of-manufactured-solutions verification must confirm solver correctness at Gradation 4.",
      "rationale": "Method of manufactured solutions applied to the Navier-Stokes solver confirms second-order spatial accuracy. Temporal accuracy verification is incomplete for the rotating reference frame formulation, limiting achievement to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on three systematically refined meshes; discretization uncertainty must be below 5% of QoI.",
      "rationale": "GCI computed on three mesh levels (2.1M, 6.4M, 18.9M cells). Hemolysis index GCI is 7.2%, exceeding the 5% threshold. Achieved Gradation 3; required Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be replicated in simulation within stated tolerances; inlet flow waveform fidelity must be documented.",
      "rationale": "Experimental flow rates matched to within 3% at four of five operating points. The fifth operating point at 6 L/min shows 8% deviation in inlet velocity profile due to pump curve uncertainty. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index values must be compared against experimental measurements using quantitative metrics including normalized error and uncertainty overlap.",
      "rationale": "Predicted hemolysis index compared against Ding et al. experimental measurements. Mean normalized RMSE is 18% across five operating points. Uncertainty bands overlap at three points; two points show non-overlapping intervals. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (hemolysis index) must directly correspond to the clinical endpoint and regulatory threshold used in device acceptance.",
      "rationale": "The normalized index of hemolysis (NIH) is the direct regulatory QoI per FDA guidance. Simulation outputs NIH directly from integrated shear stress history on tracked particles. Full correspondence confirmed at Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating envelope as the COU; any extrapolation must be bounded.",
      "rationale": "Validation uses the FDA generic pump geometry with glycerol-water blood analog. Operating range covers 3 of 5 COU flow-speed combinations; two high-speed points are extrapolated beyond the validation envelope. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The credibility assessment team reviewed available solver documentation and iterative convergence logs.",
      "rationale": "The assessment team reviewed solver documentation and convergence behavior. Iterative residuals were monitored across all operating points and no systematic solver errors were identified in the available logs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup procedures and boundary condition application must be reviewed for operator-introduced errors.",
      "rationale": "The assessment team reviewed simulation setup procedures and boundary condition application. No operator-introduced errors were identified in the available documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage accumulation model must be justified for rotating machinery blood flow; sensitivity to model form assumptions must be quantified.",
      "rationale": "SST k-omega turbulence model selected. Hemolysis model uses Giersiepen power-law formulation. No sensitivity analysis performed comparing alternative turbulence closures or hemolysis model forms. Gradation 2 achieved against required Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood viscosity, density, and red blood cell mechanical properties must be sourced from peer-reviewed literature with uncertainty ranges documented.",
      "rationale": "Fluid properties sourced from Merrill et al. with documented uncertainty ranges. Blood analog properties verified against manufacturer specifications. Monte Carlo sampling covers viscosity and density distributions. Gradation 3 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must use sufficient sample replication to characterize biological variability; coefficient of variation must be reported.",
      "rationale": "Experimental dataset includes n=3 replicates per operating point. Coefficient of variation ranges from 12% to 31% across conditions. Gradation 3 requires n≥5 replicates; achieved Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental conditions; any differences must be quantified and their impact on QoI bounded.",
      "rationale": "Pump rotational speed matched to ±0.5% of experimental values. Outlet pressure boundary differs by up to 4 mmHg at two operating points due to instrumentation uncertainty. Impact on hemolysis index not formally bounded. Gradation 2 achieved."
    }
  ],
