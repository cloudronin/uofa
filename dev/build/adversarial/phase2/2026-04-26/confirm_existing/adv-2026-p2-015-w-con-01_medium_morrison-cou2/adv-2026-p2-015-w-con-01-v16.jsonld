  "hash": "sha256:a3f1c2e4b7d09e5f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f",
  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan covering version control, regression testing, and change management must be documented and auditable at Gradation 4.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under a documented SQA plan with version control and regression tests covering core fluid solvers. However, the hemolysis sub-model lacks dedicated regression coverage and the SQA audit trail does not extend to user-defined functions implementing the power-law hemolysis model. Achieved level falls one gradation below required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via Method of Manufactured Solutions (MMS) must be demonstrated for all governing equations including turbulence closure at Gradation 4.",
      "rationale": "MMS verification was performed for the incompressible Navier-Stokes solver and k-omega SST turbulence model, confirming second-order spatial accuracy. MMS was not extended to the hemolysis transport scalar, leaving a gap in code verification for the primary QoI. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be reported for hemolysis index QoI on at least three systematically refined meshes at Gradation 4.",
      "rationale": "Three systematically refined meshes (4.2 M, 11.8 M, 31.6 M cells) were generated. GCI analysis yields a discretization uncertainty of 8.3% on the hemolysis index at the design operating point. GCI exceeds the 5% threshold required for Gradation 4, placing the achieved level at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulated operating conditions within stated tolerances; fluid properties must be documented at Gradation 3.",
      "rationale": "In-vitro experiments used a glycerol-water blood analog (viscosity 3.5 mPa·s) rather than porcine blood. Temperature was controlled to ±1°C but flow rate uncertainty is ±4%, exceeding the ±2% tolerance for Gradation 3. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, NRMSE) must be computed for hemolysis index across all 5 operating points with uncertainty bounds at Gradation 4.",
      "rationale": "Hemolysis index predictions overestimate experimental values by 18–42% across the 5 operating points. NRMSE is 0.31. Uncertainty bounds from Monte Carlo UQ do not overlap experimental values at 3 of 5 points. Achieved level 2 due to systematic bias exceeding acceptable thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The predicted QoI (normalized index of hemolysis, NIH) must be directly traceable to the clinical endpoint (plasma free hemoglobin) with documented conversion at Gradation 4.",
      "rationale": "The NIH is the primary QoI and is clinically relevant. Conversion from NIH to plasma free hemoglobin relies on empirical constants with ±25% reported uncertainty in literature, weakening the direct traceability required for Gradation 4. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and operating envelope as the COU; blood analog must be physiologically representative at Gradation 4.",
      "rationale": "Validation used the FDA generic pump geometry, which matches the COU geometry. However, operating conditions cover only 3 of 5 required flow-speed combinations, and the blood analog does not replicate the viscoelastic properties of whole blood. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off must be characterized and shown to be negligible relative to discretization error.",
      "rationale": "The credibility assessment team noted that solver residual convergence and iterative error characterization were reviewed during the assessment cycle. Available documentation was considered sufficient for the purposes of the overall package review, and no additional quantitative level assignment was deemed necessary at the time of submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution protocol and independent review of boundary condition setup must be in place at Gradation 3.",
      "rationale": "A simulation execution protocol exists but was not followed for two of the five operating point runs, where boundary conditions were applied by a junior analyst without independent review. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis constitutive model must be validated against hemolysis data from controlled shear experiments; model form uncertainty must be quantified at Gradation 4.",
      "rationale": "The power-law hemolysis model (Giersiepen et al.) is used without calibration to device-specific data. Model form uncertainty is acknowledged but not quantified. Alternative hemolysis models (Arora, Taskin) were not compared. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions and propagated through Monte Carlo UQ at the required gradation level.",
      "rationale": "Input parameter distributions and Monte Carlo uncertainty propagation were reviewed as part of the package. The assessment team determined that the available documentation adequately captured the scope of input characterization activities, and a specific numerical gradation was not separately recorded for this factor in the submission package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least three independent experimental replicates per operating point must be available to characterize experimental variability at Gradation 3.",
      "rationale": "Only two replicates are available for operating points 4 and 5. Statistical characterization of experimental variability is therefore incomplete for those conditions. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulation must be demonstrably equivalent to those in the COU simulation within documented tolerances at Gradation 3.",
      "rationale": "Rotational speed in validation experiments was set to ±50 RPM of the nominal, while the COU specifies ±10 RPM. This mismatch in boundary condition equivalency reduces confidence in direct applicability of validation results to the COU. Achieved level 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 factors and determined that the overall simulation package provides sufficient evidence to support acceptance of the CFD hemolysis predictions for the VAD COU. Monte Carlo uncertainty quantification was completed and the model outputs are considered adequate for regulatory submission purposes. Minor gaps in individual factors are judged to be within acceptable risk tolerance given the supporting experimental dataset.",
