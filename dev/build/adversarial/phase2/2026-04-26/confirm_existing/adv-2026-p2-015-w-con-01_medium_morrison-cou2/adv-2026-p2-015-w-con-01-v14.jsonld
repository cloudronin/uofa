  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must comply with an SQA plan covering version control, regression testing, and release validation at Gradation 4.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under a documented SQA plan with version-controlled repositories, automated regression test suites covering 120 benchmark cases, and formal release notes. Independent code review was conducted prior to the VAD simulation campaign. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification must confirm solver correctness at Gradation 4 for the relevant flow regime.",
      "rationale": "Method of manufactured solutions confirms second-order spatial accuracy for the incompressible Navier-Stokes solver. However, the hemolysis transport scalar equation was verified only via internal consistency checks rather than a full MMS campaign, limiting the achieved level to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or Richardson extrapolation must be performed on hemolysis index QoI with GCI < 5% at Gradation 4.",
      "rationale": "A three-level mesh refinement study was completed; GCI on hemolysis index ranged from 6.2% to 9.8% across operating points, exceeding the 5% threshold. Velocity field GCI was below 3%. Discretization error is partially controlled but does not reach Gradation 4 for the primary QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used for validation must match simulation inlet/outlet conditions within specified tolerances at Gradation 3.",
      "rationale": "Inlet flow rates and rotational speeds in the FDA pump experiments are reproduced in simulation within 1.5% and 0.3% respectively. Temperature and fluid properties are matched to published experimental values. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rms, validation uncertainty) must include experimental uncertainty and numerical uncertainty at Gradation 4.",
      "rationale": "Hemolysis index predictions are compared to experimental measurements using a validation metric that incorporates numerical uncertainty from GCI and experimental uncertainty from reported measurement error. However, model-form uncertainty is not formally separated, preventing attainment of Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress) must be directly traceable to the clinical decision QoIs at Gradation 4.",
      "rationale": "The normalized index of hemolysis (NIH) computed in simulation maps directly to the clinical hemolysis threshold used in the regulatory submission. Shear-stress-based hemolysis model outputs are the same quantities evaluated experimentally. Full traceability established; Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at conditions spanning the full COU operating envelope at Gradation 4.",
      "rationale": "Validation activities cover 4 of the 5 COU flow-speed combinations. The highest-speed operating point (6000 rpm, 6 L/min) was not included in the validation dataset due to experimental facility limitations, reducing relevance coverage and capping achievement at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels consistent with Gradation 3 requirements, with QoI change < 0.1% over last 500 iterations.",
      "rationale": "All simulations are run to residual convergence with continuity residuals below 1e-6 and momentum residuals below 1e-7. Hemolysis index QoI shows less than 0.05% variation over the final 500 iterations. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution protocol with independent review of setup files and boundary condition assignments must be in place at Gradation 3.",
      "rationale": "Simulation setup was performed by a senior CFD engineer and independently reviewed by a second engineer prior to execution. Boundary condition files and mesh generation scripts are archived in version control. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The appropriateness of the hemolysis constitutive model and turbulence closure must be evaluated against available literature and sensitivity analyses.",
      "rationale": "The credibility assessment team noted that model form uncertainty for the power-law hemolysis damage model and the k-omega SST turbulence closure has not been formally characterized at the required gradation level. This factor was recorded as assessed pending a supplementary model-form sensitivity study; level data will be entered upon study completion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Uncertainty in material properties and hemolysis model coefficients must be propagated through Monte Carlo analysis and documented at the required gradation.",
      "rationale": "The credibility assessment team noted that model form uncertainty for the power-law hemolysis damage model and the k-omega SST turbulence closure has not been formally characterized at the required gradation level. This factor was recorded as assessed pending a supplementary model-form sensitivity study; level data will be entered upon study completion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test samples (blood analogue fluid) must be characterized for relevant rheological properties and documented at Gradation 3.",
      "rationale": "The FDA pump experiments used a well-characterized bovine blood analogue (40% hematocrit, viscosity measured at shear rates 10–1000 s-1). Fluid property documentation is available in the published experimental dataset. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be shown equivalent to experimental conditions within documented tolerances at Gradation 3.",
      "rationale": "Fluid density and viscosity used in simulation are within 2% of experimentally measured values. Pump geometry is reconstructed from FDA-published CAD files with dimensional verification. Equivalency documented and Gradation 3 achieved."
    }
