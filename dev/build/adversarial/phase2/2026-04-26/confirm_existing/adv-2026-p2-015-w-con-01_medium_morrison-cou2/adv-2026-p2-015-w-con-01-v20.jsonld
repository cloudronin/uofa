  "signature": "ed25519:9c2a4f1e7b3d5a0c8e6f2b4d1a3c7e9f0b2d4a6c8e0f1b3d5a7c9e1f3b5d7a9c",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "SQA plan must cover version control, change management, and regression testing consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is under version control and a formal SQA plan exists; however, regression test coverage is incomplete for the hemolysis sub-model, resulting in an achieved level below the required threshold for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy testing on canonical flows must confirm solver implementation is consistent with theoretical convergence rates.",
      "rationale": "Order-of-accuracy studies were conducted on pipe flow and lid-driven cavity benchmarks; convergence rates are slightly below second-order for the hemolysis transport equation, placing the achieved level at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QoI across all five operating points; GCI must be below 5%.",
      "rationale": "GCI was computed on three grid levels; median GCI is 7.2% across operating points, exceeding the 5% target and placing achieved level at 3 rather than the required 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty bounds; blood analogue fluid properties must be fully characterised.",
      "rationale": "Test conditions are documented for four of five operating points; viscosity characterisation of the blood analogue at 37°C is available but shear-thinning parameters have ±12% uncertainty, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed for hemolysis index at all operating points.",
      "rationale": "E% was computed at all five operating points; mean absolute error is 18%, which exceeds the acceptance threshold of 10%, placing the achieved level at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "QoI used in validation must be directly traceable to the clinical endpoint (absolute hemolysis index).",
      "rationale": "The normalised index of hemolysis (NIH) used in validation is directly mapped to the absolute hemolysis index required by the COU; traceability is documented and the achieved level meets the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation activities must cover the geometry, flow regime, and operating envelope representative of VAD clinical use.",
      "rationale": "Validation was performed on the FDA generic pump geometry rather than the actual VAD geometry; while the flow regime is similar, geometric fidelity gaps reduce the relevance score to achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver iterative convergence must be demonstrated to residual norms below 1e-6 for all simulations contributing to the credibility assessment.",
      "rationale": "The credibility assessment team noted that solver convergence logs were not retained for three of the five operating-point simulations. This factor has not been assessed and is flagged as an epistemic gap at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of user qualification and independent review of simulation setup must be provided for all MRL 5 simulations.",
      "rationale": "The credibility assessment team reviewed the available documentation and determined that this factor had been considered during the modelling process. No specific level data were recorded at the time of assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "acceptanceCriteria": "The power-law hemolysis damage model must be justified against alternative model forms; sensitivity to model constants must be quantified.",
      "rationale": "The Giersiepen-Wurzinger power-law model is used without comparison to the modified Bludszuweit or strain-based models; sensitivity to the exponent constants spans ±35%, placing achieved level at 2 against a required level of 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "All model input parameters must have documented sources and uncertainty characterisation consistent with Monte Carlo UQ requirements.",
      "rationale": "Monte Carlo UQ was performed on 8 of 11 identified uncertain inputs; three material property inputs (red blood cell membrane stiffness, viscosity temperature coefficient, and hematocrit distribution) were held at nominal values, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood analogue sample provenance, preparation protocol, and batch-to-batch variability must be documented for all experimental data used in validation.",
      "rationale": "Sample provenance records for the experimental hemolysis data were not available to the assessment team. This factor is flagged as not assessed; however, the overall assessment proceeded given the availability of evidence across the remaining factors."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrably equivalent to those used in the COU simulations.",
      "rationale": "Inlet boundary conditions, rotational speed, and fluid properties used in validation simulations are confirmed equivalent to COU simulation inputs; the achieved level meets the required level."
    }
