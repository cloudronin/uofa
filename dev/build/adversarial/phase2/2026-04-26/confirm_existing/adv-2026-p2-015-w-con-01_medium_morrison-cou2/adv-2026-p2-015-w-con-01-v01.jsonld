  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen credibility factors and determined that the overall body of evidence is sufficient to support regulatory submission. The majority of assessed factors achieved levels consistent with the model risk level requirements, and the Monte Carlo uncertainty quantification provides adequate confidence bounds on the hemolysis index predictions. The team concludes that the CFD model is credible for predicting absolute hemolysis levels for the Class III VAD device under the stated context of use.",
