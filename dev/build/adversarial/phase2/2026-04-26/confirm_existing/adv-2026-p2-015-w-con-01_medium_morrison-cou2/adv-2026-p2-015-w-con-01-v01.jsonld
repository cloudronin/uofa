  "signature": "ed25519:b1d3e5f7a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software development follows a documented quality plan with version control, unit testing, and traceability to requirements; independent code review completed.",
      "rationale": "The CFD solver is maintained under an ISO 9001-aligned quality management system with documented version control and unit test coverage. Independent peer review was completed for the hemolysis sub-model routines. Achieved level 3 reflects partial test coverage; full qualification testing to achieve level 4 was not completed within the assessment window."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent formal verification applied to governing equations; order-of-accuracy confirmed for all primary flow solvers.",
      "rationale": "MMS verification was applied to the Navier-Stokes solver confirming second-order spatial accuracy. The hemolysis transport scalar equation was verified separately against an analytical benchmark. Achieved level 3 because MMS was not extended to the full rotating-frame formulation used in the VAD geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study performed on at least three systematically refined meshes; GCI reported for primary QoI.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA pump geometry. Grid Convergence Index for predicted hemolysis index was 4.2% on the finest mesh, exceeding the 2% target for level 4. Mesh refinement in the volute tongue region was constrained by computational budget, limiting the achievable GCI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with calibrated instrumentation; boundary conditions replicated in simulation to within stated uncertainty bounds.",
      "rationale": "FDA pump experimental conditions were documented with NIST-traceable flow and pressure instrumentation. Inlet velocity profiles were measured with LDV and applied directly as CFD boundary conditions. Achieved level 3 because outlet pressure boundary condition uncertainty was not fully propagated into the simulation boundary specification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_val) computed for primary QoI with uncertainty intervals; systematic bias identified and bounded.",
      "rationale": "Validation error for hemolysis index was computed as E_val = 18% across five operating points, exceeding the 10% acceptance threshold for level 3. Experimental scatter in hemolysis measurements was high (CV ~12%), limiting the discriminating power of the comparison. Achieved level 2 reflects that bias could not be bounded within clinical tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation is the same quantity or a formally justified surrogate for the COU decision QoI; mapping documented.",
      "rationale": "The normalized index of hemolysis (NIH) used in bench validation is the same metric required for regulatory submission. The power-law hemolysis model maps shear stress and exposure time to NIH with documented assumptions. Achieved level 3 because the model was calibrated on bovine blood and species-correction uncertainty to human blood was not fully quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the operating envelope of the COU; any gaps in coverage are identified and their impact bounded.",
      "rationale": "Validation experiments spanned 3 of the 5 COU operating points. The two highest-speed operating points were not included in the experimental dataset due to pump cavitation risk during bench testing. Extrapolation to untested conditions introduces unquantified model-form uncertainty, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and demonstrated; residuals and key integral quantities monitored to confirm solution stationarity.",
      "rationale": "The assessment team reviewed solver convergence logs and confirmed residual drop targets were met. Credibility evidence was compiled and the factor was considered addressed during the internal review cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "User qualification records on file; simulation setup reviewed by independent analyst; input deck version-controlled and traceable to the assessment.",
      "rationale": "The assessment team reviewed user qualification records and confirmed that simulation setup procedures were followed. Credibility evidence was compiled and the factor was considered addressed during the internal review cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selected with documented justification; sensitivity to model-form assumptions quantified.",
      "rationale": "The SST k-omega turbulence model was selected based on prior FDA pump benchmarking studies. Sensitivity analysis comparing SST, realizable k-epsilon, and RSM showed hemolysis index variation of up to 35% across models. The power-law hemolysis exponent was treated as deterministic; Bayesian model-form uncertainty was not performed. Achieved level 2 reflects substantial unresolved model-form uncertainty at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs characterized with uncertainty distributions; Monte Carlo or equivalent propagation performed; sensitivity indices reported.",
      "rationale": "Monte Carlo uncertainty quantification was performed on seven input parameters including viscosity, hemolysis model coefficients, and rotational speed. Sobol sensitivity indices were computed. Achieved level 3 because geometric manufacturing tolerances were not included in the UQ input space, and hematocrit variability was fixed at a nominal value."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood analog or animal blood samples characterized for relevant rheological properties; sample-to-sample variability quantified and propagated.",
      "rationale": "Bovine blood was used in bench experiments with hematocrit controlled to 33±2%. Sample-to-sample variability in hemolysis susceptibility was noted but not formally characterized. Only a single blood batch was used across all five operating-point experiments, precluding between-batch variability estimation. Achieved level 2 reflects insufficient sample characterization for a Class III device at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations are demonstrably equivalent to those in the COU simulations; any differences are documented and their impact bounded.",
      "rationale": "Fluid properties and boundary conditions in the validation simulations were matched to the bench test conditions. The COU simulations use physiological human blood properties which differ from the bovine blood analog. A correction factor was applied but its uncertainty contribution was not formally propagated into the overall credibility assessment, limiting the achieved level to 3."
    }
  ],
