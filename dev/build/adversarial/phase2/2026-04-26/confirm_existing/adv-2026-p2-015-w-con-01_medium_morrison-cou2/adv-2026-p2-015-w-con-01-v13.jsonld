  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan documented, version-controlled, with traceability to test cases and change logs. Independent review required at MRL 5.",
      "rationale": "SQA plan exists and is version-controlled; however, independent third-party review was not completed. Achieved level falls below required level for MRL 5 Class III device context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification using method of manufactured solutions or equivalent. Solver convergence demonstrated for hemolysis-relevant flow regimes.",
      "rationale": "Order-of-accuracy testing was performed for laminar benchmark cases; turbulent regime verification for high-shear pump passages was not completed to the required standard."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence index (GCI) reported for hemolysis index QoI. GCI < 5% required.",
      "rationale": "GCI was computed for pressure and velocity fields; GCI for the hemolysis index scalar was 8.3%, exceeding the 5% threshold. Discretization error not fully controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five target VAD operating points with documented uncertainty in flow rate, rotational speed, and fluid properties.",
      "rationale": "Only three of five target operating points were physically tested. Fluid temperature and viscosity uncertainty were not fully characterized for the remaining two points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE, E_rel) reported for hemolysis index at all operating points. Systematic bias must be characterized.",
      "rationale": "Quantitative error metrics reported for three operating points. Systematic over-prediction of hemolysis index at high-speed conditions observed but not fully explained."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized index of hemolysis, NIH) directly maps to the clinical endpoint. Traceability from model output to patient safety metric documented.",
      "rationale": "NIH is the direct clinical surrogate for hemolysis harm. Traceability chain from CFD shear stress output to NIH to clinical threshold is fully documented and accepted by the assessment team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue fluid, and rotational speed range as the COU. Geometric fidelity and fluid property matching documented.",
      "rationale": "Validation used a glycerol-water blood analogue; actual blood rheology differences at high shear rates introduce a relevance gap. Pump geometry was identical but inlet boundary conditions differed from clinical implant configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The credibility of the numerical solver has been reviewed and found acceptable for the purposes of this assessment.",
      "rationale": "The assessment team reviewed available solver documentation and determined that solver performance is adequate for the intended use. No specific graduated evaluation was performed against the standard factor levels."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of analyst training, simulation protocol adherence, and independent results review. At least one independent re-run of a representative case required.",
      "rationale": "Analyst training records exist; however, independent re-run was not performed. Protocol adherence was self-certified rather than independently verified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of turbulence model, hemolysis damage model, and constitutive assumptions. Sensitivity of NIH to model form choices must be quantified.",
      "rationale": "SST k-omega turbulence model selected with limited justification for transitional flow in the rotor passage. Hemolysis power-law model coefficients sourced from literature without uncertainty bounds. Model form sensitivity not quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameter distributions and sensitivities have been reviewed and are considered sufficient for the purposes of this credibility assessment.",
      "rationale": "The assessment team reviewed the Monte Carlo input distributions used in the UQ study and considers the parameter coverage adequate for the COU. Formal graduated level scoring was not applied to this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sample size, selection rationale, and representativeness of test specimens documented. Statistical power analysis supporting sample count required.",
      "rationale": "Three pump units tested; no statistical power analysis provided to justify sample size. Batch-to-batch manufacturing variation not characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and experimental conditions quantitatively demonstrated. Discrepancies bounded and their effect on QoI estimated.",
      "rationale": "Inlet velocity profiles in simulation were uniform; experimental PIV measurements showed a non-uniform inlet profile. Effect of this discrepancy on NIH was not bounded."
    }
  ],
