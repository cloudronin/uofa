  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software development follows a documented quality management plan with version control, unit testing, and configuration management consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is under a documented QMS with version-controlled releases. Unit and integration tests cover core solver routines. However, formal V&V plan traceability to individual test cases is incomplete, resulting in an achieved level below the required level for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies and manufactured solution tests demonstrate correct solver implementation for the governing equations relevant to hemolysis prediction.",
      "rationale": "Order-of-accuracy testing was performed on canonical flows. Manufactured solution verification was completed for the laminar regime but not for the turbulence model variant used in the VAD operating range, limiting the achieved level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent Richardson extrapolation reported for hemolysis index QOI across at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study was conducted. GCI values for hemolysis index QOI exceed the 5% target at high-speed operating conditions, indicating residual discretization uncertainty above the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation are documented with uncertainty bounds and match the COU operating envelope within specified tolerances.",
      "rationale": "Experimental conditions are documented; however, rotational speed uncertainty in the bench test apparatus exceeds 2% at peak operating points, reducing equivalence to the COU operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, U_val) are computed for hemolysis index predictions against experimental measurements at all five COU operating points.",
      "rationale": "Validation metrics computed at four of five operating points. The fifth operating condition (highest flow, lowest speed) lacked sufficient experimental replicates for statistical comparison, leaving one COU point unvalidated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOIs used in validation (hemolysis index, shear stress distribution) are directly relevant to the clinical decision criterion and match the COU QOI definition.",
      "rationale": "Hemolysis index is the primary QOI and is directly relevant to the clinical threshold. Shear stress fields used as surrogate QOIs during intermediate validation steps employ a simplified stress tensor definition that diverges from the full viscous stress tensor used in the final hemolysis model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments were conducted on the same device geometry and fluid (bovine blood or equivalent) under conditions spanning the COU operating envelope.",
      "rationale": "Validation used the FDA generic pump geometry with bovine blood analog. Fluid rheology differs from human blood at high shear rates relevant to hemolysis onset, reducing the relevance of validation activities to the clinical COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria and iterative error estimates are reported for all simulations; solver error is demonstrated to be negligible relative to discretization error.",
      "rationale": "The assessment team noted that solver convergence behavior was reviewed during the analysis cycle. Available evidence was considered sufficient to support the overall credibility determination without formal level assignment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review of boundary condition setup, material property assignment, and post-processing scripts to reduce operator-induced errors.",
      "rationale": "Simulation workflow is documented and subject to internal peer review. Boundary condition templates are version-controlled. Post-processing scripts were independently verified by a second analyst. Use error controls are commensurate with MRL 5 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence and hemolysis constitutive models are justified through literature review and sensitivity analysis; model form uncertainty is quantified and reported.",
      "rationale": "The SST k-omega turbulence model was selected based on literature benchmarks for rotating machinery. The Giersiepen-Wurzinger hemolysis power-law model introduces substantial model form uncertainty at low-shear conditions. Sensitivity analysis was performed but model form uncertainty bounds exceed the clinical tolerance, yielding an achieved level of 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry tolerances, fluid properties, operating conditions) are characterized with uncertainty bounds; Monte Carlo propagation covers the full COU input space.",
      "rationale": "Monte Carlo uncertainty quantification was performed over 500 samples spanning geometry tolerances and fluid viscosity distributions. Blood viscosity at hematocrit extremes was not fully characterized, leaving a gap in input uncertainty coverage at the boundaries of the COU input space."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size and statistical power of experimental hemolysis measurements are documented and sufficient to support quantitative validation at MRL 5.",
      "rationale": "Test sample characterization was not completed within the assessment cycle. This factor is flagged as an epistemic gap and was not formally evaluated for level assignment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations are demonstrated to be equivalent to those in the COU through documented parameter mapping and sensitivity ranking.",
      "rationale": "Parameter mapping between the validation test article and the COU device was performed. Significant differences in impeller clearance tolerances between the FDA generic pump test article and the commercial VAD geometry reduce equivalency, resulting in an achieved level of 2 against a required level of 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment is accepted based on the weight of structured evidence across the assessed factors. The Monte Carlo uncertainty quantification provides sufficient confidence in hemolysis predictions relative to the clinical threshold. Factors with achieved levels below required levels are noted but considered acceptable given supplementary engineering judgment and the conservative safety margins applied in the clinical acceptance criterion. The assessment team determined that the totality of evidence supports regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
