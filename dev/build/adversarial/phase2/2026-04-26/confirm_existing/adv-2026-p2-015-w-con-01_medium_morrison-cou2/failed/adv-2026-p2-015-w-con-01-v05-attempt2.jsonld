      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation execution checklists must be on file.",
      "rationale": "Use error was identified as an epistemic gap at MRL 5; no structured level evidence is available."
    },
    {
      "id": "https://uofa.net/synth/factor/model-form-cou2",
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence and hemolysis constitutive models must be justified for the flow regime and red cell damage mechanism.",
      "rationale": "The SST k-omega turbulence model is appropriate for rotating machinery; the power-law hemolysis model (Giersiepen-Wurzinger) has known limitations for sub-lethal exposures, constraining achievedLevel to 2."
    },
    {
