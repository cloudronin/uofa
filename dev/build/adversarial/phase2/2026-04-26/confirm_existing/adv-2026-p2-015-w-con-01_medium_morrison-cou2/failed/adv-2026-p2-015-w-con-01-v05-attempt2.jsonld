      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within stated tolerances; fluid temperature, viscosity, and hematocrit must be documented.",
      "rationale": "Test conditions were documented for all five operating points; hematocrit variation across experiments was within 2% but temperature control deviated by up to 1.5°C from the nominal CFD boundary condition, limiting achievedLevel to 3."
    },
    {
      "id": "https://uofa.net/synth/factor/output-comparison-cou2",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 20% across all operating points, with statistical comparison metrics reported.",
      "rationale": "Hemolysis index predictions agreed within 20% at three of five operating points; at two high-speed conditions agreement degraded to 28%, yielding achievedLevel 3 against requiredLevel 4."
    },
    {
      "id": "https://uofa.net/synth/factor/relevance-qoi-cou2",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
