      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan must cover version control, regression testing, and documented release procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has a documented SQA plan with version control and regression testing; however, formal release qualification documentation is incomplete, yielding achievedLevel 3 against a requiredLevel of 4 for Class III MRL 5."
    },
    {
      "id": "https://uofa.net/synth/factor/ncv-cou2",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical flows must demonstrate convergence consistent with the stated numerical scheme.",
      "rationale": "Order-of-accuracy tests were performed on canonical pipe flow and lid-driven cavity cases; convergence was demonstrated at second order for velocity but not for the hemolysis scalar transport equation, leaving achievedLevel at 3."
    },
    {
      "id": "https://uofa.net/synth/factor/disc-error-cou2",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
