  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated code with documented version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 19.2 was used with documented version control. Regression test suite covering laminar and turbulent benchmark cases was executed prior to the study. All tests passed within specified tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order of accuracy of numerical scheme verified against analytic solutions for relevant flow regimes.",
      "rationale": "Code verification performed using manufactured solutions for the incompressible Navier-Stokes equations. Second-order spatial accuracy confirmed. Iterative convergence to residuals below 1e-6 demonstrated for all operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with at least three mesh refinement levels; GCI reported for primary QoI.",
      "rationale": "Three mesh levels (coarse 1.2M, medium 4.8M, fine 19.2M cells) evaluated. Grid Convergence Index for hemolysis index at the worst-case operating condition was 3.1%, within the acceptable range for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulation boundary conditions within documented tolerances.",
      "rationale": "Experimental flow rates and rotational speeds were controlled within ±2% of nominal values. Fluid properties (viscosity, density) measured at test temperature and applied directly to CFD boundary conditions. Inlet turbulence intensity measured via hot-wire anemometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric V) computed for primary QoI; comparison within acceptance band.",
      "rationale": "Relative hemolysis index predictions agreed with experimental measurements within 15% across all 5 operating conditions. PIV velocity comparisons showed mean absolute error below 5% of tip speed. Pressure head predictions within 8% of measured values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI used in validation must be directly relevant to the clinical decision metric (relative hemolysis index).",
      "rationale": "The primary validation QoI is the normalized index of hemolysis (NIH) converted to relative hemolysis index (RH), which is the exact metric used in the regulatory submission acceptance criterion RH < 1. Secondary QoIs (velocity field, pressure head) support model fidelity assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry and at overlapping operating conditions as the COU.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry identical to the COU device. Operating conditions span the full clinical range of 2.5–5.0 L/min and 2000–3500 RPM. Validation and COU geometries are equivalent; no extrapolation required."
    },
    {
