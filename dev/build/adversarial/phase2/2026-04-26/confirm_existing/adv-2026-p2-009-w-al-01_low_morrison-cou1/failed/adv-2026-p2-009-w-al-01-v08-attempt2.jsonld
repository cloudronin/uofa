      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model predictions must agree with experimental measurements within 10% for pressure head and within 15% for relative hemolysis index.",
      "rationale": "Pressure head predictions show mean error of 4.2% across all operating points. Relative hemolysis index predictions show mean error of 9.7%, both within acceptance thresholds."
