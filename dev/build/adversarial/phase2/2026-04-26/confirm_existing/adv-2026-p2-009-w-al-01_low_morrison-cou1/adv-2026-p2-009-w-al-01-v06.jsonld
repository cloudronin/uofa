  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The CFD model demonstrates adequate agreement with bench hemolysis measurements across all 5 operating points. The relative hemolysis index predictions fall within the pre-specified 15% tolerance band. Six factors are not assessed, which is acceptable at MRL 2 given medium model influence and the availability of confirmatory experimental data. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
