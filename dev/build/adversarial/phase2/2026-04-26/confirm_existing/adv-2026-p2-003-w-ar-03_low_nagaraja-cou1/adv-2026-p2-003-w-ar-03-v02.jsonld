  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is offset by the conservative single-condition ASTM F1717 protocol and the corroborating literature survey, which confirmed consistency of the experimental results with seven independent published datasets. All QoI differences remain within the 10% acceptance bound and E/uval ratios are below 1.96. The assessment team judges the overall credibility sufficient to support the regulatory submission decision.",
