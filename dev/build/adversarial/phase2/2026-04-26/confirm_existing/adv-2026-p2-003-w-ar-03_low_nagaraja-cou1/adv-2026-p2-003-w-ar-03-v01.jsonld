  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels. The single gap (Test conditions, achieved level 2 vs. required level 3) is acknowledged; the assessment team judged that the single-condition ASTM F1717 protocol is standard practice for this device class and that the quantitative output comparison results (all E/uval < 1.96) provide sufficient confidence. Overall credibility is assessed as Medium, consistent with the model risk level and decision consequence. The credibility evidence was corroborated by a systematic literature review of 14 peer-reviewed FEA studies of comparable pedicle screw constructs, which consistently reported QoI agreement within 8–12%, further supporting the model's predictive fidelity.",
