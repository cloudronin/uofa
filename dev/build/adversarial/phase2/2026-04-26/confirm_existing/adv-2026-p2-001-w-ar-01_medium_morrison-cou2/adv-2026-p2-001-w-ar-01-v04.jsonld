  "hash": "sha256:a3f1c8e2d94b07650f2e3a1b8c4d9e7f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d",
  "signature": "ed25519:b7e2a1f3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At MRL 5 for a Class III device, software quality assurance must satisfy Gradation 4: the solver must be under formal configuration management with documented version control, regression test suites covering hemolysis-relevant flow regimes, and an independent code review on record. Gradation 4 is required because errors in the CFD solver propagate directly into the absolute hemolysis index used for regulatory acceptance.",
      "rationale": "The simulation was performed using ANSYS Fluent 2022 R2 under ISO 9001-certified quality management. Version control and regression testing are documented; however, independent third-party code review has not been completed, placing the achieved level at Gradation 3. A gap of one gradation exists."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that order-of-accuracy tests have been performed on benchmark problems representative of rotating-frame turbulent flow, with documented convergence rates within 10% of theoretical order. This is mandated at MRL 5 to ensure that discretisation errors are separable from model-form errors in the hemolysis prediction.",
      "rationale": "Order-of-accuracy tests were performed on a lid-driven cavity and a rotating Couette flow benchmark. Observed convergence rate was 1.7 versus theoretical 2.0 for the second-order scheme, a 15% deviation that falls outside the Gradation 4 threshold, yielding an achieved level of 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "For MRL 5, Gradation 4 requires a formal grid convergence index (GCI) study using at least three systematically refined meshes with GCI < 5% on the hemolysis index quantity of interest, with Richardson extrapolation applied and documented.",
      "rationale": "A three-level GCI study was conducted with mesh counts of 2.1M, 6.8M, and 21.4M cells. The GCI on the normalized hemolysis index was 8.3%, exceeding the 5% Gradation 4 threshold. Achieved level is therefore 3. Further refinement is computationally prohibitive under current resources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that experimental test conditions (fluid temperature, hematocrit, inlet flow waveform) are characterized with documented uncertainty bounds and that the CFD boundary conditions are set to the measured mean values with sensitivity analysis on key parameters.",
      "rationale": "Experimental conditions were characterized at hematocrit 35±2%, temperature 37±0.5°C, and steady inlet flow at five operating points. Boundary conditions were set to measured means; sensitivity analysis on hematocrit (±5%) was performed. Test conditions are adequately matched at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Predicted hemolysis index values were compared against five experimental operating points from the FDA benchmark dataset. The mean absolute percentage error was 18.4%, with two of five points exceeding the 15% band that characterizes Gradation 4 agreement. Achieved level is 3. The output comparison narrative documents that the model captures the trend of hemolysis versus flow rate but over-predicts at high-speed, low-flow conditions where secondary vortices are prominent. A Gradation 4 level would require all operating points within 15% and a formal statistical equivalence test, neither of which has been completed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that the primary quantity of interest — normalized index of hemolysis (NIH) — is directly computed by the model and that a documented mapping from CFD scalar stress history to NIH via the power-law damage model is provided with sensitivity on model coefficients.",
      "rationale": "NIH is the primary QoI and is computed directly via the Giersiepen–Wurzinger power-law model applied to Lagrangian particle tracks. Coefficient sensitivity (C, α, β) was assessed over published ranges. The QoI is fully relevant to the clinical endpoint and the mapping is documented. Gradation 3 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At MRL 5, Gradation 4 requires that validation experiments use the same device geometry, the same operating envelope (flow rates and rotational speeds), blood analogue fluid with characterised rheology, and that validation is performed under pulsatile rather than steady-state conditions if the COU involves pulsatile flow.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry, which is a surrogate rather than the actual VAD device geometry. Operating conditions covered three of five COU flow-speed combinations. Steady-state experiments were used whereas the clinical COU involves pulsatile VAD operation. These gaps in geometric and flow-condition relevance limit the achieved level to Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires documented iterative convergence to residuals below 1e-5 for all transport equations, with monitoring of the hemolysis QoI to confirm it is stationary over the final 500 iterations.",
      "rationale": "Residuals for continuity, momentum, and turbulence equations converged to below 1e-5. The NIH monitor was flat over the final 600 iterations. Numerical solver error is adequately controlled at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires a documented simulation protocol reviewed by a second qualified analyst, covering mesh generation parameters, turbulence model selection rationale, boundary condition assignment, and post-processing steps for NIH computation.",
      "rationale": "A simulation protocol document exists but was authored and reviewed by the same analyst team without independent second-party review. Turbulence model selection (SST k-ω) is justified in a technical memo, but the boundary condition assignment procedure for the rotating frame interfaces is not fully documented. Achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The hemolysis damage model uses the Giersiepen–Wurzinger power-law formulation, which was calibrated on Couette-flow shear experiments and is known to under-predict hemolysis in complex three-dimensional stress histories characteristic of centrifugal pumps. A Gradation 4 model-form assessment would require either a higher-fidelity mechanistic red blood cell damage model validated on rotating-machinery data, or a documented model-form uncertainty bound derived from comparison of multiple damage model formulations across the COU operating envelope. Neither has been performed. The power-law coefficients were taken from literature without recalibration to the specific blood analogue used in the validation experiments. Model form uncertainty is therefore large and unquantified beyond a qualitative acknowledgement, placing the achieved level at Gradation 2. The required level of 4 reflects the MRL 5 classification and the direct regulatory reliance on the absolute NIH prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that all material properties and boundary condition inputs are sourced from characterised measurements or validated correlations, with documented uncertainty ranges propagated through the Monte Carlo UQ study.",
      "rationale": "Fluid viscosity, density, and inlet velocity profiles were characterised from independent measurements. Monte Carlo UQ propagated uncertainty in hematocrit, viscosity (±8%), and inlet flow rate (±3%) through 500 Latin hypercube samples. Documented uncertainty ranges are available. Model inputs are assessed at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that experimental hemolysis measurements are obtained from at least three independent test runs per operating point, with statistical characterisation of inter-run variability and documented sample handling procedures to prevent pre-test haemolysis artefacts.",
      "rationale": "Experimental data from the FDA benchmark dataset provides two independent runs at three operating points and a single run at two operating points. Inter-run variability is reported only where duplicate runs exist. Sample handling documentation is incomplete for the two single-run conditions. Achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that CFD input parameters (geometry, rotational speed, flow rate) are demonstrably equivalent to experimental conditions within documented tolerances, with a formal parameter-equivalency table mapping each simulation input to its experimental counterpart and associated uncertainty.",
      "rationale": "A parameter-equivalency table is provided mapping pump geometry (CAD-to-physical tolerance ±0.05 mm), rotational speed (±10 RPM), and volumetric flow rate (±0.02 L/min) for all five operating points. Equivalency is confirmed within the documented tolerances. Gradation 3 is achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were fully assessed; gaps in achieved versus required levels exist for software quality assurance, numerical code verification, discretization error, output comparison, relevance of validation activities, use error, model form, and test samples. Despite these gaps, the team accepted the package on the basis that the Monte Carlo UQ bounds are conservative and that the model is used in conjunction with a safety factor applied to the NIH threshold. Factors for test conditions, relevance of QoI, numerical solver error, model inputs, and equivalency of input parameters meet their required levels. The overall credibility is judged sufficient for a low-assurance regulatory submission with acknowledged limitations.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
