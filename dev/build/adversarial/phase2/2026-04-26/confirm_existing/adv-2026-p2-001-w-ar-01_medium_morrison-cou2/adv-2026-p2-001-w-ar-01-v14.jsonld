  "signature": "ed25519:9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a9f8e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At MRL 5 for a Class III device, SQA must demonstrate version-controlled source code, automated regression testing covering at least 90% of solver modules, and a documented change-control process reviewed by an independent QA engineer. All releases used in this assessment must carry a traceable build hash.",
      "rationale": "The CFD solver (OpenFOAM v9) operates under a documented SQA plan including Git-based version control, nightly regression suite (94% module coverage), and independent QA sign-off for each release. Build hashes are recorded in the simulation manifest. Achieved level 4 satisfies the required level 4 threshold for MRL 5 Class III assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at this risk level requires demonstration of observed order of accuracy within 10% of theoretical order for all governing equations on at least three systematically refined manufactured-solution benchmarks, with results archived in a traceable verification report.",
      "rationale": "Order-of-accuracy testing was performed on three manufactured-solution benchmarks (lid-driven cavity, pipe flow, rotating channel). Observed order reached 1.82 versus theoretical 2.0 for the momentum equations — a 9% shortfall — but the hemolysis transport scalar showed only 1.6 versus 2.0 (20% shortfall), pulling the composite score to gradation 3. The gap is attributed to near-wall limiter activation in high-shear regions relevant to the pump impeller. Achieved level 3 falls below the required level 4; this deficit is noted in the decision record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via Richardson extrapolation on at least three systematically refined meshes, with the grid convergence index (GCI) for the hemolysis index QoI not exceeding 5% on the fine grid. Mesh topology must be documented and independently reviewed.",
      "rationale": "Three meshes (2.1 M, 8.4 M, 33.6 M cells) were generated with systematic refinement ratio r=2. Richardson extrapolation yielded GCI_fine = 3.8% for the normalized hemolysis index across all five operating points. Mesh topology was reviewed by an independent CFD engineer. Achieved level 4 meets the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with calibrated instrumentation (traceable to NIST standards), flow rate uncertainty ≤2%, and rotational speed uncertainty ≤0.5%. At least three replicate runs per operating point are required.",
      "rationale": "FDA generic pump experiments were conducted with NIST-traceable flow meters (±1.4% uncertainty) and optical tachometer (±0.3% uncertainty). Three replicate runs were performed at each of the five operating points. Achieved level 3 meets the required level 3 for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Predicted hemolysis index values were compared against experimental measurements at all five operating points. The mean absolute percentage error was 18.3%, exceeding the target of 15% for gradation 4. Two of five operating points fell within the 15% band; the remaining three showed discrepancies of 17–22%, attributed to uncertainty in the power-law hemolysis damage model constants. Achieved level 3 falls below the required level 4. The required level of 4 was established by the assessment team based on MRL 5 guidance, but the structured rationale for that specific threshold selection is captured in the narrative rather than in a formal acceptance criteria record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (normalized hemolysis index, NIH) must be directly mapped to the clinical endpoint (plasma-free hemoglobin accumulation rate) through a documented physiological linkage argument reviewed by a clinical subject-matter expert.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI and maps directly to plasma-free hemoglobin accumulation, the clinical marker for chronic hemolysis. A clinical SME reviewed and approved the QoI-to-endpoint linkage document. Achieved level 4 meets the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full operating envelope of the COU (all five flow-speed combinations), use the same pump geometry as the device under assessment, and be conducted in blood analog fluid with documented rheological properties matching physiological range.",
      "rationale": "All five operating points in the COU envelope were covered in the validation campaign. The FDA generic pump geometry was used identically in both simulation and experiment. Glycerol-water blood analog with viscosity 3.5 cP at 37°C was used, within the physiological range. Achieved level 4 meets the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated by reduction of all residuals to below 1e-5 for continuity and momentum, and 1e-6 for the hemolysis scalar transport equation, with residual histories archived for each simulation.",
      "rationale": "All simulations achieved continuity and momentum residuals below 5e-6 and hemolysis scalar residuals below 8e-7 within 5000 iterations. Residual histories are archived in the simulation log repository. Achieved level 3 meets the required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution checklist must be followed for each run, with independent peer review of boundary condition setup and post-processing scripts. At least one independent analyst must reproduce one operating point result within 2% before acceptance.",
      "rationale": "A simulation execution checklist was developed and followed for all runs. Boundary conditions were peer-reviewed by a second analyst. However, the independent reproduction exercise was not completed prior to submission — the reproducing analyst was able to match results within 2.1% (marginally exceeding the 2% criterion). Achieved level 2 falls below the required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty must be assessed by comparing at least two turbulence closure models (e.g., SST k-omega and realizable k-epsilon) and two hemolysis damage model formulations (e.g., Giersiepen and Heuser-Opitz), with sensitivity documented relative to the NIH QoI.",
      "rationale": "Two turbulence closures (SST k-omega, realizable k-epsilon) and two hemolysis damage models (Giersiepen, Heuser-Opitz) were compared. NIH predictions varied by up to 24% across model form combinations, indicating substantial model form uncertainty. The assessment team assigned gradation 3 because the spread exceeds the 15% band required for gradation 4. Achieved level 3 falls below the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters with sensitivity rank above 5% contribution to NIH variance (per Monte Carlo analysis) must have documented uncertainty distributions derived from experimental measurement or literature meta-analysis, with traceability to primary sources.",
      "rationale": "Monte Carlo UQ identified six input parameters contributing more than 5% each to NIH variance: fluid viscosity, pump rotational speed, inlet flow rate, damage model exponent alpha, damage model exponent beta, and blood analog density. All six have documented uncertainty distributions derived from experimental measurements or published meta-analyses with full traceability. Achieved level 4 meets the required threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood analog fluid batches must be characterized for viscosity and density before each experimental session, with batch-to-batch variability documented. At least three independent batches must be used across the validation campaign.",
      "rationale": "Four independent glycerol-water batches were prepared and characterized for viscosity (±0.05 cP) and density (±0.3 kg/m³) before each session. Batch-to-batch variability was within 1.2% for viscosity and 0.4% for density. Achieved level 3 meets the required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A parameter equivalency matrix must document the mapping between experimental boundary conditions and CFD model inputs for each operating point, with any deviations from exact equivalency quantified and their impact on NIH predictions bounded.",
      "rationale": "A parameter equivalency matrix was completed for all five operating points. Minor deviations were identified in inlet velocity profile (fully developed assumed in CFD vs. slightly developing in experiment, <3% impact on NIH per sensitivity study) and fluid temperature (37°C nominal ±1°C in experiment, fixed at 37°C in CFD, <1% viscosity impact). All deviations were bounded and documented. Achieved level 3 meets the required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite three credibility factors (Numerical code verification, Output comparison, Model form) achieving levels below their required levels, the assessment team accepted the model for the stated COU based on the following considerations: (1) the shortfalls are bounded and their combined impact on NIH prediction uncertainty is captured within the Monte Carlo UQ envelope; (2) compensating strength in Model inputs (level 4) and Discretization error (level 4) reduces overall prediction uncertainty; (3) a conservative safety margin of 30% below the clinical hemolysis threshold was applied to the acceptance decision, providing buffer against the identified model form uncertainty. The Output comparison factor's required level of 4 was set based on MRL 5 guidance but the formal acceptance criteria document for that threshold was not finalized prior to submission — the rationale exists in narrative form in the assessment report but is not captured as a structured acceptanceCriteria record. The team accepts this gap as a documentation deficiency to be remediated in the next assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
