  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At MRL 5 for a Class III device, software quality assurance must reach Gradation 4: full version control, automated regression testing, and documented V&V plan traceable to requirements. Gradation 4 is required because the model serves as the primary regulatory submission artifact with no predicate device comparison.",
      "rationale": "The CFD solver (OpenFOAM v9) is under version control and regression tests cover 87% of critical flow modules. However, formal IQ/OQ/PQ documentation is incomplete for the hemolysis sub-model library, and automated test coverage for the power-law damage accumulation routine is absent. Achieved level is 3; a gap of one gradation remains."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that all numerical algorithms relevant to the QoI be verified against analytic or manufactured solutions with demonstrated convergence rates. At MRL 5, no algorithmic shortcut is permissible for the damage integral solver.",
      "rationale": "Method of Manufactured Solutions (MMS) was applied to the Navier-Stokes solver confirming second-order spatial accuracy. The hemolysis damage integral is verified against a Couette-flow analytic solution. However, the rotating reference frame implementation lacks an independent MMS check, leaving the achieved level at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "A three-level Grid Convergence Index (GCI) study was conducted on the FDA generic pump geometry using 2.1M, 8.4M, and 33.6M cell meshes. The GCI for the hemolysis index QoI is 4.7% on the fine mesh, which falls short of the Gradation 4 threshold of less than 2% numerical uncertainty. The impeller tip-gap region exhibits non-monotonic convergence at the coarsest level, contributing to elevated discretization uncertainty. Monte Carlo sampling propagates this discretization uncertainty into the final hemolysis distribution, but the structural gap in grid convergence quality prevents achievement of Gradation 4. The required level of 4 is set by MRL 5 protocols demanding near-negligible numerical error for absolute hemolysis predictions used in regulatory submissions without a predicate comparator."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that boundary conditions in the validation experiment match the COU operating envelope within documented tolerances, and that fluid properties are characterised with uncertainty bounds. This level is sufficient at MRL 5 for test conditions because experimental control is independently verified by the testing laboratory.",
      "rationale": "Experimental boundary conditions were set to match the five target flow-speed operating points within ±2% of nominal values. Blood analogue viscosity was measured before each run with uncertainty reported as ±0.8%. Temperature was controlled to 37 ± 0.5 °C. All test conditions are traceable to calibrated instrumentation with NIST-traceable standards. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires a quantitative validation metric (e.g., ASME V&V 20 validation uncertainty) that accounts for both experimental and simulation uncertainty, applied across all COU operating points. At MRL 5 the comparison must be statistically grounded rather than graphical.",
      "rationale": "Hemolysis index predictions were compared to experimental measurements at all five operating points. Normalised RMS error is 9.3%, and the validation uncertainty interval at 95% confidence overlaps experiment at 4 of 5 points. The fifth point (highest speed, lowest flow) shows a 14% over-prediction outside the validation interval. A formal ASME V&V 20 validation uncertainty decomposition was not completed; the comparison relies on ad hoc uncertainty budgeting. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that the QoIs used in validation directly correspond to the clinical decision QoIs, with documented mapping. At MRL 5 this mapping must be explicit in the submission package.",
      "rationale": "The primary QoI is the normalised index of hemolysis (NIH) expressed in mg/100L, which is the same metric used in the regulatory decision threshold. Secondary QoIs (wall shear stress distribution, recirculation zone volume) are mapped to sub-clinical hemolysis risk indicators. The QoI mapping document is included in the submission dossier. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that validation experiments replicate the COU geometry, flow regime, and fluid properties with high fidelity, and that any simplifications are formally justified with sensitivity analyses. At MRL 5 the validation platform must be the actual device geometry, not a simplified surrogate.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump, which is a simplified surrogate geometry rather than the actual VAD device geometry. The impeller blade count, diffuser vane angle, and volute geometry differ from the clinical device. A geometry sensitivity analysis was performed showing that hemolysis index is moderately sensitive to impeller blade angle (±12% variation over ±5° blade sweep). The use of a surrogate geometry rather than the clinical device geometry is the primary driver of the low achieved level of 2, representing a two-gradation gap against the required level of 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that iterative convergence is demonstrated to a level where residuals no longer materially affect the QoI, with documented convergence histories for all operating points.",
      "rationale": "Residuals for continuity and momentum were driven below 1×10⁻⁵ for all five operating points. QoI sensitivity to further tightening of convergence criteria was tested at one operating point and found to be less than 0.3%. Convergence histories are archived in the simulation log database. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Use error assessment covers the risk that analyst choices — mesh topology selection, turbulence model, hemolysis model coefficients, post-processing scripts — introduce undetected errors. At MRL 5 for a Class III device, Gradation 4 is required: independent re-analysis by a second analyst team using the same inputs must reproduce QoI values within a defined tolerance, and all analyst decision points must be logged in a traceable audit trail. An independent re-analysis was not performed; a single analyst team conducted all simulations. Internal peer review covered boundary condition setup and post-processing scripts but did not constitute an independent re-analysis. Audit trail logging is partial — turbulence model selection rationale is documented, but hemolysis model coefficient selection is not formally recorded. These gaps place the achieved level at 2, a two-gradation shortfall. The required level of 4 reflects the MRL 5 mandate that use error be controlled to a near-negligible contribution to total model uncertainty for absolute hemolysis predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that the model form — including turbulence closure, hemolysis damage model, and constitutive relations — be justified through systematic comparison of alternative model forms, with sensitivity of the QoI to model form choices quantified and reported.",
      "rationale": "The SST k-ω turbulence model was selected based on a comparative study against the realizable k-ε and RSM closures at two operating points; SST k-ω produced the lowest validation error. The Giersiepen-Wurzinger power-law hemolysis model was used; sensitivity to the Arora modified coefficients was tested and found to alter NIH predictions by up to 18%. A full systematic multi-model comparison across all five operating points was not conducted, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that all model inputs relevant to the QoI be characterised with probability distributions derived from experimental measurement or literature meta-analysis, and that these distributions be propagated through the model via a formal UQ method.",
      "rationale": "Monte Carlo UQ was performed with 500 samples over inlet velocity profile shape, blood analogue viscosity, and hemolysis model exponent α. Distributions were derived from in-house measurements (viscosity) and literature ranges (α). Geometric tolerances on the impeller and volute were not included in the UQ sweep due to absence of as-built dimensional data for the surrogate pump. This omission limits the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that experimental measurements be repeated across multiple independent test runs to characterise measurement variability, and that the number of replicates is sufficient to estimate a meaningful confidence interval on the hemolysis QoI.",
      "rationale": "Hemolysis measurements were collected from three independent test runs at each operating point. Statistical analysis yields 95% confidence intervals ranging from ±6% to ±11% of the mean NIH value. Gradation 3 requires at least five replicates to support robust confidence interval estimation at MRL 5; only three replicates were available due to blood analogue volume constraints. The insufficient replicate count limits the achieved level to 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Equivalency of input parameters assesses whether the boundary conditions and fluid properties used in the simulation match those in the validation experiment closely enough to support meaningful comparison. Gradation 3 requires quantitative equivalency metrics for all primary inputs, with documented tolerances. Blood viscosity in simulation was set to the experimentally measured mean value without propagating measurement uncertainty into the boundary condition. Inlet velocity profiles were derived from pipe-flow assumptions rather than measured profiles, introducing a potential 8–15% discrepancy in near-wall shear stress in the inlet region. These two gaps — absence of uncertainty-aware BC assignment and unmeasured inlet profile — reduce the achieved level to 2. The required level of 3 is set by MRL 5 protocols requiring that input parameter equivalency be formally demonstrated for all parameters with non-negligible sensitivity on the QoI."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors at MRL 5. Seven factors were fully assessed; six factors exhibit gaps between achieved and required levels. Despite these gaps, the team accepted the assessment package on the basis that (1) the Monte Carlo UQ bounds hemolysis predictions conservatively, (2) the primary QoI comparison is within acceptable error at four of five operating points, and (3) a compensating controls plan has been submitted to address the use-error and validation-relevance shortfalls prior to final regulatory submission. The decision is conditional on completion of the independent re-analysis and acquisition of as-built geometric data for the clinical device geometry within 90 days.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
