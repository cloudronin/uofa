  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under formal version control with documented unit and integration tests; all solver modules must have traceable verification records per ASME V&V 40 Gradation 4 requirements for Class III devices at MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under Git version control with tagged release branches. A formal software quality plan documents unit tests for all hemolysis sub-models. CI pipeline results are archived and traceable to simulation runs submitted for this assessment. Achieved level 4 meets the required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must demonstrate convergence consistent with the formal order of the numerical scheme for all governing equations. At MRL 5, verification must cover both the flow solver and the hemolysis transport equation, with documented Richardson extrapolation results.",
      "rationale": "Order-of-accuracy tests were performed for the Navier-Stokes solver and confirm second-order spatial convergence. However, the power-law hemolysis transport equation was verified only against a single manufactured solution without Richardson extrapolation, yielding an achieved level of 3 rather than the required 4. This gap is noted in the uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study with at least three systematically refined meshes must be conducted, and the grid convergence index (GCI) must be reported for all quantities of interest. Discretization error must be included in the total uncertainty budget.",
      "rationale": "Three structured mesh refinements (coarse: 4.2M cells, medium: 11.8M cells, fine: 31.4M cells) were generated using a refinement ratio of 1.5. GCI values for hemolysis index at all five operating points are below 3.2%, satisfying the Gradation 4 threshold. Discretization error is carried forward into the Monte Carlo uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with measurement uncertainty bounds. Boundary conditions applied in the CFD model must be traceable to the experimental setup, and any deviations must be quantified.",
      "rationale": "FDA generic pump experiments were conducted at five flow-speed operating points matching the intended COU. Inlet flow rates were measured with calibrated ultrasonic flow meters (uncertainty ±1.5%). Rotational speed was controlled to ±5 RPM. CFD boundary conditions are directly mapped from experimental measurements. Achieved level 3 meets the required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Predicted hemolysis index values were compared against experimental measurements at all five operating points. The normalized index of agreement (NIA) exceeded 0.85 for four of five points. At the highest flow-speed combination (6 LPM, 3500 RPM), model predictions exceeded experimental values by 18%, outside the ±10% target band for Gradation 4. The shortfall is attributed to unresolved secondary flow structures near the volute cutwater. A Gradation 3 achievement is recorded for this factor. The required level of 4 was established based on MRL 5 and the absolute (non-comparative) nature of the hemolysis acceptance criterion, consistent with the Morrison credibility scoring framework; however, the structured acceptance criteria document for this determination was not formally captured in the evidence package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (hemolysis index, wall shear stress distribution) must be directly linked to the clinical endpoint (patient hemolysis risk). A formal traceability matrix connecting model outputs to device performance specifications must be documented.",
      "rationale": "The normalized index of hemolysis (NIH) is the primary QoI and is directly specified in the device performance specification as the clinical surrogate for hemolysis risk. A traceability matrix links NIH to ISO 10993-4 hemocompatibility requirements. Wall shear stress is a secondary QoI used to identify high-risk regions. Both QoIs are directly observable in validation experiments. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and at operating conditions that are representative of the COU. For MRL 5, the validation geometry must be the same device or a formally qualified surrogate, and operating conditions must span the full COU envelope.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal pump, which is the same geometry used in the COU. All five COU operating points were included in the validation test matrix. Blood analog fluid (glycerin-water mixture per ASTM F1841) was used, and a correction factor for whole-blood viscosity is documented and validated against limited whole-blood experiments. Achieved level 4 meets required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated for all simulations, with residuals reduced by at least four orders of magnitude. Mass and momentum imbalances must be reported and shown to be negligible relative to the quantities of interest.",
      "rationale": "All steady-state simulations were run to residual convergence of 1e-6 for continuity and momentum equations. Mass imbalance across the pump domain was below 0.01% for all operating points. Transient hemolysis transport simulations were run for 10 impeller revolutions with hemolysis index change below 0.5% over the final 3 revolutions, confirming periodic convergence. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented review process must be in place to identify and mitigate potential user errors in model setup, boundary condition specification, and post-processing. For MRL 5, an independent review by a qualified analyst not involved in the original simulation must be performed.",
      "rationale": "Internal peer review of simulation setup was conducted by a second CFD analyst within the team. However, the reviewer was part of the same project team and had access to the original setup documentation during review, limiting independence. An external independent review was planned but not completed prior to submission. This limits the achieved level to 2 against the required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The mathematical form of the hemolysis model must be justified through comparison of multiple candidate model forms. Sensitivity of predictions to model form assumptions must be quantified and included in the uncertainty budget.",
      "rationale": "Three hemolysis model forms were evaluated: the Giersiepen power-law, the modified Heuser-Opitz formulation, and the Zhang strain-based model. The Giersiepen model was selected based on best agreement with experimental data at the primary operating point. Sensitivity analysis across model forms contributes a ±22% spread in predicted NIH at the highest-risk operating point, which is included in the Monte Carlo uncertainty budget. Full pairwise comparison documentation is incomplete for two of the three candidate pairs, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with associated uncertainty bounds. For MRL 5, a formal uncertainty propagation analysis (e.g., Monte Carlo) must be performed to quantify the contribution of input uncertainty to output uncertainty.",
      "rationale": "All 14 model input parameters (fluid properties, hemolysis model coefficients, boundary condition values) have documented sources and uncertainty distributions. A 10,000-sample Monte Carlo analysis was performed using Latin hypercube sampling. Input uncertainty contributes ±15% to the total NIH prediction uncertainty at the 95th percentile. Full sensitivity indices (Sobol first-order and total-order) are reported for all inputs. Achieved level 4 meets required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for material properties relevant to the QoI. For hemolysis testing, blood analog fluid composition must be documented with batch-to-batch variability quantified.",
      "rationale": "Blood analog fluid was prepared per ASTM F1841 using pharmaceutical-grade glycerin and deionized water. Viscosity was measured for each batch using a cone-and-plate viscometer (uncertainty ±2%). Three batches were used across the validation test campaign; batch-to-batch viscosity variability was 1.8%, which is within the ASTM F1841 tolerance. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the CFD model must be demonstrated to be equivalent to those present in the physical validation experiments. Any differences between computational and experimental inputs must be quantified and their effect on the QoI must be bounded.",
      "rationale": "Fluid viscosity and density were matched between CFD and experiments within measurement uncertainty. However, the surface roughness of the impeller used in experiments was not measured and was assumed smooth in the CFD model. Sensitivity analysis indicates that surface roughness in the range 0.5–5 microns Ra could affect NIH predictions by up to 8%, but this effect was not formally bounded through simulation or measurement. This limits the achieved level to 2 against the required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The aggregate credibility assessment for COU2 yields an overall credibility score sufficient for a Low assurance level determination at MRL 5. Seven of thirteen factors were formally assessed; of these, four achieved their required level and three fell one gradation below required. The six remaining factors were not assessed and are flagged as epistemic gaps. The assessment team determined that the gaps in Output Comparison (factor 5), Use Error, Equivalency of Input Parameters, and Model Form are mitigated by the conservative uncertainty budget from the Monte Carlo UQ sweep, which demonstrates that NIH predictions remain below the absolute clinical threshold even at the 97.5th percentile of the combined uncertainty distribution. The decision to accept is conditional on completion of the independent use-error review prior to device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
