  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At MRL 5 for a Class III device, SQA must demonstrate full version control, automated regression testing covering hemolysis subroutines, documented code review records, and a traceable issue-resolution log. Gradation 4 requires all prior gradation activities plus formal independent code audit. Gradation 3 is achieved: version control and regression suite are in place but independent audit has not been completed.",
      "rationale": "The CFD solver (OpenFOAM v8) is under version control with a documented regression test suite covering 42 hemolysis-relevant test cases. Code review records exist for all hemolysis damage model modifications. However, an independent third-party code audit required at Gradation 4 for MRL 5 has not been completed, leaving the achieved level at 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at Gradation 4 requires formal order-of-accuracy studies demonstrating convergence rates consistent with theoretical expectations for all governing equations, including the hemolysis damage transport equation. Published benchmark solutions must be reproduced within specified tolerances. Gradation 3 is achieved when convergence is demonstrated but formal order-of-accuracy documentation is incomplete.",
      "rationale": "Order-of-accuracy studies were performed for the Navier-Stokes solver and confirmed second-order spatial convergence. The hemolysis damage transport equation shows consistent convergence in mesh refinement studies. However, formal documentation of theoretical convergence rate comparison for the damage model is incomplete, placing the achieved level at Gradation 3 rather than the required Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 2.1M, 8.4M, and 33.6M cells following the Richardson extrapolation methodology prescribed in ASME V&V 20. Grid Convergence Index (GCI) values for hemolysis index predictions range from 4.2% to 11.7% across the five operating points, with the highest uncertainty observed at the 6000 RPM, 6 L/min condition where recirculation zones are prominent. At MRL 5 and Gradation 5, GCI values below 2% are expected with formal uncertainty bound propagation into the hemolysis prediction. The achieved Gradation 3 reflects that the GCI study is complete but values exceed the threshold required for Gradation 5, and formal propagation of discretization uncertainty into the final hemolysis index has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions at Gradation 4 require that experimental boundary conditions match COU operating conditions within defined tolerances for all five flow-speed combinations, with documented uncertainty on all measured inlet/outlet conditions. Fluid rheology must be characterized and matched. Gradation 3 is achieved when primary boundary conditions are matched but rheological characterization is incomplete.",
      "rationale": "Experimental test conditions from the FDA benchmark dataset were replicated in the CFD model with inlet flow rates matched to within 1.5% of target values. Pump rotational speed was controlled to within 0.3% of target RPM. However, the blood analog fluid viscosity was characterized at 37°C only, without temperature sensitivity data required at Gradation 4. The achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison at Gradation 4 requires quantitative metrics (e.g., validation metric V per ASME V&V 20) computed for all primary QoIs including hemolysis index, pressure head, and velocity field statistics, with formal statistical comparison accounting for experimental uncertainty. Gradation 3 is achieved when comparisons are made graphically and with basic error metrics but without formal validation metric computation.",
      "rationale": "CFD predictions of normalized index of hemolysis (nIH) were compared against experimental measurements at all five operating points. Mean absolute error across operating points is 18.3%, with the largest discrepancy at high-flow low-speed conditions. Pressure head predictions agree within 5% at all conditions. PIV velocity comparisons show qualitative agreement in primary flow structures. Formal validation metric V per ASME V&V 20 was not computed, placing the achieved level at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI relevance at Gradation 4 requires that the validated quantities directly correspond to the clinical decision metric (absolute hemolysis index below clinical threshold), with documented traceability from CFD output to patient safety criterion. All five operating points must be addressed.",
      "rationale": "The primary QoI — normalized index of hemolysis (nIH) — directly maps to the clinical hemolysis threshold used in the 510(k) submission pathway for Class III VAD devices. Traceability from CFD output to the ASTM F1841 hemolysis measurement standard is documented. All five COU operating points are included in the validation matrix. The QoI is the same quantity used in the regulatory decision, satisfying Gradation 4 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation relevance at Gradation 5 requires that validation experiments are conducted on the actual device geometry under COU-representative conditions, including patient-representative blood rheology and in-vivo hemodynamic boundary conditions. The validation hierarchy must span from unit to system level. Gradation 2 is achieved when validation uses a surrogate geometry under idealized conditions.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry, which is a surrogate for the specific VAD device under assessment. Experimental conditions used a Newtonian blood analog (glycerol-water) rather than non-Newtonian whole blood. Operating conditions span the COU range but do not include pulsatile inlet conditions representative of in-vivo VAD operation. The large gap between Gradation 2 achieved and Gradation 5 required reflects the fundamental limitation of using a generic benchmark geometry for device-specific regulatory credibility."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Iterative convergence was monitored for all simulations using residual norms for continuity, momentum, and hemolysis damage transport equations. All simulations achieved residuals below 1×10⁻⁵ for continuity and momentum. The hemolysis damage transport residual converged to below 1×10⁻⁴ in four of five operating conditions; at the 4000 RPM, 8 L/min condition, the damage transport residual stabilized at 3×10⁻⁴ due to unsteady vortex shedding in the volute. At MRL 5 with Gradation 4 required, formal quantification of solver error contribution to the total uncertainty budget is expected, including assessment of floating-point round-off and iterative error bounding. This formal error decomposition has not been performed, placing the achieved level at Gradation 3. The rationale for requiring Gradation 4 is that at MRL 5, solver error must be demonstrably negligible relative to the clinical decision margin, which has not been established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Use error at Gradation 3 requires documented simulation setup checklists, peer review of boundary condition assignments, and evidence that all analysts have completed formal training on the hemolysis damage model implementation. Gradation 2 is achieved when checklists exist but formal training records are incomplete.",
      "rationale": "Simulation setup checklists covering mesh import, boundary condition assignment, turbulence model selection, and hemolysis model parameters have been developed and applied for all five operating conditions. Peer review of boundary condition assignments was completed by a senior analyst. However, formal training records demonstrating analyst competency on the specific hemolysis damage model (modified power-law Giersiepen-Wurzinger) are not available for one of the two analysts who performed simulations, placing the achieved level at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The hemolysis damage model employs the modified power-law formulation (Giersiepen-Wurzinger with Zhang et al. coefficients) relating scalar shear stress exposure to red blood cell damage. This model form introduces substantial epistemic uncertainty: (1) the scalar stress assumption collapses the full stress tensor to a single equivalent value, ignoring directional effects on RBC membranes; (2) the power-law coefficients were derived from Couette flow experiments not representative of the complex three-dimensional flow fields in centrifugal pumps; (3) the Lagrangian particle-tracking approach for stress path integration introduces path-dependence sensitivity. At Gradation 5, the model form uncertainty must be formally bounded through comparison of multiple constitutive models and Bayesian model selection. Only a single model form was assessed, and no formal model-form uncertainty quantification was performed, resulting in an achieved level of Gradation 2. The required level of 5 reflects that model form is the dominant uncertainty source for absolute hemolysis prediction at MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs at Gradation 4 require that all uncertain input parameters are characterized with probability distributions derived from experimental measurements or literature, and that Monte Carlo or equivalent uncertainty propagation is performed to quantify input uncertainty contribution to hemolysis index predictions. Gradation 3 is achieved when sensitivity analysis identifies key inputs but full probabilistic characterization is incomplete.",
      "rationale": "A one-at-a-time sensitivity analysis identified fluid viscosity, pump rotational speed, and hemolysis model exponent coefficients as the three most influential input parameters for hemolysis index predictions. Monte Carlo uncertainty quantification was initiated with 500 samples using Latin Hypercube sampling. However, the probability distributions for hemolysis model coefficients were assigned as uniform distributions based on literature ranges rather than experimentally characterized distributions, which does not satisfy the Gradation 4 requirement for experimentally derived distributions. The achieved level is Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples at Gradation 3 require that experimental hemolysis measurements are replicated across at least three independent test runs per operating condition, with statistical characterization of inter-run variability. Gradation 2 is achieved when duplicate measurements are available for some but not all conditions.",
      "rationale": "The FDA benchmark experimental dataset includes duplicate hemolysis measurements for three of the five operating conditions. The remaining two conditions (4000 RPM at 4 L/min and 6000 RPM at 8 L/min) have single measurements only. Statistical characterization of measurement variability is therefore incomplete across the full operating range. The required Gradation 3 cannot be achieved without triplicate measurements at all conditions; the achieved level is Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Equivalency of input parameters assesses the degree to which the validation experiment inputs match the COU inputs. For this assessment, the primary mismatches are: (1) the validation experiments used a Newtonian glycerol-water blood analog (viscosity 3.5 mPa·s) whereas the COU involves whole blood with non-Newtonian shear-thinning behavior; (2) the inlet velocity profile in validation experiments was fully developed pipe flow whereas the COU involves a patient-specific aortic anastomosis connection with disturbed inlet conditions; (3) pump surface roughness in the validation model used a nominal value of 0.8 μm Ra whereas manufactured device roughness ranges from 0.4 to 1.6 μm Ra. At Gradation 4, formal equivalency metrics must be computed for all input parameters with documented justification for any mismatches. At Gradation 2, major mismatches are identified but not formally quantified. The required level of 4 reflects that input equivalency is critical for absolute hemolysis prediction credibility at MRL 5; the two-gradation gap represents a significant credibility deficit."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction at MRL 5 reveals that 11 of 13 factors have achieved levels below required levels, with the most significant gaps in model form (required 5, achieved 2), relevance of validation activities (required 5, achieved 2), and equivalency of input parameters (required 4, achieved 2). Despite these gaps, the overall package is accepted as a complete and transparent credibility evidence package that accurately characterizes the epistemic state of the model. The decision to accept the package as evidence does not imply the model is adequate for regulatory submission; rather, it documents the credibility gaps that must be addressed before the model can support a Class III VAD regulatory decision. The Discretization Error factor carries its required level of 5 without a structured acceptanceCriteria record in the evidence package, as the rationale for that gradation threshold was communicated through the project risk register rather than the credibility evidence system — a gap that should be remediated in the next assessment cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
