  "hash": "sha256:a3f1c9e72b084d56f1a2c3e4d5b6a7f8e9012345678901234567890abcdef1234",
  "signature": "ed25519:b2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan with version control, issue tracking, and regression test suite covering hemolysis model routines; documented SQA audit trail per MRL 5 requirements.",
      "rationale": "At MRL 5, a comprehensive SQA plan is required. The solver (OpenFOAM 8) is under version control and a regression suite covers core fluid routines, but the hemolysis transport subroutines lack dedicated unit tests and the SQA audit trail is incomplete. Achieved level 3 reflects partial compliance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations including hemolysis transport, with convergence order confirmed to within 10% of theoretical rate across at least three refinement levels.",
      "rationale": "MMS verification was performed on the Navier-Stokes solver and confirmed second-order spatial convergence. However, the power-law hemolysis source term was not included in the MMS sweep, leaving code verification for the most safety-critical equation incomplete. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "A three-level mesh refinement study was conducted on the FDA generic centrifugal pump geometry. Richardson extrapolation was applied to the hemolysis index QoI, yielding a grid convergence index (GCI) of 4.8% on the medium mesh. At MRL 5 a GCI below 2% is the operational target, and the required credibility level of 4 corresponds to demonstrated near-asymptotic convergence with formal uncertainty bounding. The achieved level of 3 reflects that GCI is quantified and reported but remains above the target threshold. The rationale for setting requiredLevel at 4 is grounded in the high decision consequence and the absolute (rather than comparative) nature of the hemolysis prediction, which amplifies the impact of discretization bias on patient safety conclusions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental flow conditions (flow rate, impeller speed, fluid viscosity, temperature) match simulation boundary conditions within ±5% for all five operating points.",
      "rationale": "All five operating points used in validation experiments were reproduced in simulation within ±3% on flow rate and ±2% on rotational speed. Fluid properties were matched using the same glycerol-water solution. Test conditions factor is fully satisfied at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index values agree with experimental measurements within the combined experimental and simulation uncertainty interval at all five operating points; statistical coverage probability ≥ 95%.",
      "rationale": "Predicted hemolysis index values fall within experimental uncertainty bounds at three of five operating points. At the two highest-speed conditions, predictions exceed experimental upper bounds by 12–18%, indicating model form or parameter bias at elevated shear. Coverage probability is approximately 60%, below the 95% criterion. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI — normalized hemolysis index (NIH) — is directly mapped to the clinical threshold specified in the device submission; secondary QoIs (wall shear stress, residence time) are explicitly linked to the hemolysis damage model.",
      "rationale": "The normalized index of hemolysis is the regulatory QoI for Class III VAD submissions and is directly computed from the CFD shear-stress field via the Giersiepen-Wurzinger power-law model. Secondary QoIs including volumetric shear stress distributions and Lagrangian residence times are explicitly linked to the damage model parameters. Full traceability from clinical threshold to simulation output is documented. Achieved level 4 meets the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry, at operating conditions spanning the full VAD clinical envelope, with blood-analog fluid whose rheological properties are characterized to within ±10% of clinical blood at relevant shear rates.",
      "rationale": "Validation was performed on the FDA generic pump, which is the same geometry used for the COU. Operating conditions cover three of the five clinical operating points; the two highest-speed VAD conditions were not represented in the validation dataset. Fluid is a glycerol-water analog whose viscosity matches blood at 37°C within 8% but whose viscoelastic properties differ. Achieved level 3 due to incomplete operating condition coverage."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence residuals for all transport equations drop below 1×10⁻⁵ per time step; mass and momentum imbalance across domain boundaries is less than 0.01% of inlet flux.",
      "rationale": "All simulations converged to residuals below 1×10⁻⁶ for continuity and momentum. Mass imbalance at domain boundaries was below 0.005% in all cases. Numerical solver error is well controlled and the factor is satisfied at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer-reviewed setup checklist; independent re-run of at least one operating point by a second analyst to confirm reproducibility; discrepancy in hemolysis index between analysts less than 5%.",
      "rationale": "A simulation setup checklist exists and was applied. However, independent reproduction by a second analyst was not performed due to resource constraints. Without cross-analyst verification, the risk of systematic user-introduced error in boundary condition specification or post-processing cannot be excluded. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing at least two turbulence closure models and two hemolysis damage law formulations; preferred model form selected based on validation evidence with documented justification; model form uncertainty contribution quantified and included in total uncertainty budget.",
      "rationale": "The k-ω SST turbulence model was selected based on prior literature for rotating machinery. A single hemolysis damage law (Giersiepen-Wurzinger) was used without comparison to alternative formulations (e.g., Taskin or Faghih-Sharp). Model form uncertainty was not quantified or included in the Monte Carlo UQ sweep, which addressed only parametric uncertainty. This represents a significant gap at MRL 5. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions characterised with documented uncertainty distributions; Monte Carlo propagation performed across full input space; sensitivity indices (Sobol first-order and total-order) computed for all inputs contributing more than 1% to output variance.",
      "rationale": "Monte Carlo UQ was performed over five input parameters: fluid viscosity, inlet flow rate, rotational speed, and two hemolysis model coefficients. Sobol indices were computed. However, geometric tolerances on the impeller blade profile and surface roughness were treated as deterministic, omitting potentially significant sources of input uncertainty. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independently manufactured pump specimens tested; specimen-to-specimen geometric variation characterised by CMM measurement; inter-specimen variability in hemolysis index reported.",
      "rationale": "Experimental hemolysis measurements were performed on a single pump specimen. Specimen-to-specimen variability in the FDA generic pump has been documented in the literature to contribute up to 15% variation in hemolysis index, but this was not captured in the validation dataset. Achieved level 2 reflects single-specimen testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless similarity parameters (Reynolds number, flow coefficient, head coefficient) match between validation experiment and COU simulations within ±5%; any deviations are corrected by documented scaling arguments.",
      "rationale": "Reynolds number, flow coefficient, and head coefficient were matched within ±2% across all operating points. The glycerol-water analog fluid was selected to reproduce the Reynolds number of clinical blood at 37°C. Equivalency of input parameters is fully satisfied at the required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "After full 13-factor assessment at MRL 5, the aggregate credibility evidence is judged sufficient to support regulatory submission under the Low assurance level designation. Seven factors were formally assessed; six factors (Discretization error, Model form, Output comparison, Use error, Test samples, Relevance of validation activities) did not achieve their required levels. However, the sponsor has accepted residual risk at Low assurance and the decision authority has determined that the documented gaps, in combination with the Monte Carlo UQ results, are adequate for the intended submission context. The package is accepted with the understanding that identified gaps will be addressed in a subsequent COU3 assessment prior to device approval.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
