  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below their required levels — most notably Test Conditions (achieved 3, required 5), Relevance of Validation Activities (achieved 2, required 5), and Model Form (achieved 2, required 4) — the assessment team accepted the package based on the totality of uncertainty quantification evidence and the conservative Monte Carlo prediction intervals. The decision reflects a risk-informed judgement that the identified gaps are bounded by the UQ envelope and that compensating controls (post-market hemolysis monitoring protocol, restricted operating envelope labelling) are in place. Note: the Test Conditions factor carries a requiredLevel of 5 with detailed narrative rationale but no structured acceptanceCriteria field was populated for that factor, representing a documentation gap that should be remediated in the next assessment revision.",
