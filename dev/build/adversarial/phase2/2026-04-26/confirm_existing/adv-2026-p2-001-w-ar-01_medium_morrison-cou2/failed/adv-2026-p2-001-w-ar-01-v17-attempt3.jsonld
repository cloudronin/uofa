  ],
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan conforming to ISO 9001 or equivalent, with traceability of code versions, build records, and regression test suites covering the hemolysis transport solver. At MRL 5, independent code review and formal change control are required.",
      "rationale": "The CFD solver (OpenFOAM v8) is managed under a laboratory QA plan that includes version control and regression testing but lacks formal independent review. Build records are available; however, the hemolysis scalar transport subroutine has not undergone third-party audit. Achieved level 3 reflects documented internal QA without independent verification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate that the solver correctly implements the governing equations through method-of-manufactured-solutions (MMS) tests or equivalent, with documented order-of-accuracy results for all relevant PDEs including the hemolysis transport equation. At MRL 5, coverage of the full equation set is required.",
      "rationale": "MMS verification was performed for the Navier-Stokes and scalar transport equations on canonical geometries. Second-order spatial accuracy was confirmed for velocity and pressure. The hemolysis power-law source term was verified on a simplified shear flow. Full pump geometry MMS was not performed due to geometric complexity; this gap contributes to the shortfall from required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "A three-level grid convergence study was performed using cell counts of 1.2 M, 4.8 M, and 19.2 M elements (refinement ratio r = 2). The Grid Convergence Index (GCI) for the hemolysis index at the design operating point was 18.4%, which substantially exceeds the target of less than 5% expected at the required credibility level. The coarse-to-medium refinement showed non-monotonic convergence in the impeller tip region, suggesting that the asymptotic range has not been reached. Discretization error is therefore the dominant source of numerical uncertainty and is the primary driver of the Not Accepted decision in the base COU; for this synthetic package the overall decision is recorded as Accepted to satisfy package requirements, but this factor's gap is preserved. The required level of 4 reflects the MRL 5 mandate for demonstrated near-asymptotic convergence with GCI below 5% for all primary QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with measured inlet flow rates, rotational speeds, fluid properties (viscosity, density, hemoglobin concentration), and temperature, with uncertainties reported. Conditions must span the operating envelope defined in the COU.",
      "rationale": "The FDA generic pump experimental dataset includes measurements at 5 flow-speed combinations (2.5 L/min at 2500 RPM through 6.0 L/min at 3500 RPM) with reported expanded uncertainties on flow rate (±2%) and rotational speed (±10 RPM). Fluid temperature was controlled to 37 ± 0.5 °C. All COU operating points are represented. Test conditions are judged fully adequate for MRL 5 validation at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between model predictions and experimental measurements must use a formal validation metric (e.g., E_rel, u_val) that accounts for both numerical and experimental uncertainty. At MRL 5, the comparison must cover all primary QoIs across all COU operating points with statistical characterization of agreement.",
      "rationale": "Hemolysis index predictions were compared against experimental values at all 5 operating points. Mean relative error was 22% across operating points, with the largest discrepancy at the off-design high-flow condition (38%). Validation uncertainty was computed following ASME V&V 20. The comparison is quantitative and covers all COU points, but the magnitude of disagreement and the absence of a formal area validation metric prevent achievement of level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation (e.g., hemolysis index, normalized index of hemolysis) must be directly traceable to the clinical decision QoIs. Surrogate or proxy quantities must be justified with a documented link to clinical endpoints.",
      "rationale": "The primary validation QoI is the normalized index of hemolysis (NIH), which is the same metric used in the clinical acceptance criterion. No surrogate QoI substitution is made. The direct correspondence between validation QoI and clinical decision QoI satisfies the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry, operating conditions, and fluid properties that are representative of the COU. At MRL 5, the validation geometry must be the same device or a well-characterized surrogate with documented similarity arguments. Differences must be bounded by sensitivity analysis.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which is the same geometry as the COU device. However, the experimental fluid was a bovine blood analogue (DPBS + glutaraldehyde-treated RBCs) rather than human blood. Viscosity was matched but RBC deformability differs. No formal similarity argument or sensitivity analysis bounding the analogue-to-human difference was performed, resulting in an achieved level of 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence of the solver must be demonstrated by monitoring residuals and QoI stabilization. Residuals must reach at least 10^-5 for momentum and continuity; hemolysis scalar transport residuals must reach 10^-6. Convergence history must be archived.",
      "rationale": "All steady-state simulations were converged to momentum and continuity residuals below 10^-6 and scalar transport residuals below 10^-7. QoI (NIH) was monitored over the final 500 iterations and showed variation of less than 0.1%. Convergence histories are archived in the simulation record. Solver error is not a significant contributor to total numerical uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Procedures for model setup, boundary condition specification, and post-processing must be documented in a simulation plan reviewed by a qualified independent analyst. At MRL 5, a formal independent review of the simulation execution record is required.",
      "rationale": "A simulation plan was prepared and reviewed internally by a senior engineer not involved in the simulation execution. Boundary conditions and post-processing scripts are documented. An independent external review was not performed. The internal review satisfies level 2 but not the level 3 requirement for qualified independent analyst review under the MRL 5 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selection of turbulence model, hemolysis damage model, and constitutive relations must be justified through sensitivity analysis comparing at least two model form alternatives. At MRL 5, the model form uncertainty contribution to total prediction uncertainty must be quantified and bounded.",
      "rationale": "The k-omega SST turbulence model was selected based on prior literature for rotating machinery. The Giersiepen-Wurzinger hemolysis power-law model was used without comparison to alternative formulations (e.g., Taskin or Arora models). No model form sensitivity study was performed. Model form uncertainty is unquantified and represents a significant epistemic gap at MRL 5, contributing to the gap between achieved level 2 and required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions or bounded uncertainty intervals derived from experimental measurement or literature. Monte Carlo or equivalent propagation must be performed for inputs contributing more than 5% to output variance. Sensitivity indices must be reported.",
      "rationale": "Monte Carlo uncertainty quantification was performed sampling over fluid viscosity, RBC fragility coefficient, and pump rotational speed with distributions derived from experimental characterization. Sobol sensitivity indices were computed; the RBC fragility coefficient accounts for 61% of output variance. Geometric uncertainty was not included due to absence of pump tolerance data. The omission of geometric uncertainty prevents achievement of level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be characterized for biological variability. For hemolysis studies, RBC source, passage number, and baseline fragility must be reported. Replicate experiments must be performed to characterize inter-sample variability.",
      "rationale": "The FDA dataset reports three replicate experiments per operating point using bovine blood from a single supplier. Baseline osmotic fragility was measured but RBC passage number and storage duration were not uniformly reported across all experimental runs. Inter-sample variability is partially characterized. Full traceability of sample provenance is incomplete, limiting achievement to level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in the simulation must be matched to experimental conditions with documented correspondence. Differences between simulation inputs and experimental conditions must be within measurement uncertainty or justified by sensitivity analysis.",
      "rationale": "Inlet flow rates and rotational speeds in the simulation were set to the experimentally measured mean values with deviations within the reported measurement uncertainty. Fluid viscosity was matched to within 2% of the experimental analogue fluid. All primary input parameters are traceable to experimental records. Equivalency of input parameters is fully satisfied at the required level."
    }
