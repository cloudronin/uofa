  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At MRL 5, software quality assurance must demonstrate formal configuration management, version control with audit trails, and documented unit/integration testing covering hemolysis model subroutines. Gradation 4 requires traceable test records and independent code review sign-off.",
      "rationale": "The CFD solver (OpenFOAM v8) is under version control with a documented build process, but independent third-party code review has not been completed. Unit tests cover 68% of hemolysis model subroutines. Configuration management procedures are documented but not formally audited. Achieved Gradation 3; required Gradation 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification at MRL 5 requires demonstration of order-of-accuracy convergence for all governing equation discretizations relevant to hemolysis prediction, including turbulence and scalar transport. Gradation 4 demands formal method-of-manufactured-solutions (MMS) verification with published results.",
      "rationale": "Order-of-accuracy tests were performed for momentum and continuity equations and confirmed second-order spatial convergence. MMS verification was applied to the Newtonian flow solver but not extended to the power-law hemolysis scalar transport equation. Achieved Gradation 3; Gradation 4 requires full MMS coverage of all active physics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "rationale": "A three-level mesh refinement study was conducted on the FDA centrifugal pump geometry using 4.2M, 11.7M, and 28.4M cell meshes. Richardson extrapolation yielded a GCI of 3.8% on the hemolysis index at the design operating point. At off-design conditions (low flow, high speed), GCI rose to 8.1%, exceeding the Gradation 5 threshold of 5%. Temporal discretization error was assessed via halved time-step comparison; differences were below 1%. The spatial discretization error at off-design conditions prevents achievement of Gradation 5. Gradation 4 is credited. The requiredLevel of 5 reflects the absolute hemolysis threshold requirement for a Class III device, where even moderate discretization uncertainty could mask a clinically significant prediction error. No structured acceptanceCriteria link has been registered for this factor in the evidence package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions at MRL 5 must replicate physiological blood rheology, temperature, and hematocrit within defined tolerances. Gradation 4 requires that all five COU operating points are represented in experimental validation data with documented uncertainty on flow rate and rotational speed.",
      "rationale": "Experimental hemolysis data from the FDA benchmark study cover 3 of the 5 target operating points. Temperature was maintained at 37±0.5°C and hematocrit at 33±2%. The two missing operating points (highest flow/lowest speed) were not included in the original benchmark campaign. Achieved Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison at MRL 5 must include quantitative metrics (normalized index of agreement, RMSE) applied to hemolysis index predictions across all validated operating points, with statistical confidence intervals reported. Gradation 4 requires that model predictions fall within experimental uncertainty bounds at all validated points.",
      "rationale": "Hemolysis index predictions agree with experimental data within ±15% at 2 of 3 validated operating points. At the third point (5 LPM, 3500 RPM), the model over-predicts by 22%, outside experimental uncertainty. Normalized index of agreement is 0.81. RMSE is 0.0043 g/100L. Achieved Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation (hemolysis index, shear stress exposure time) must be directly mappable to the clinical decision quantity (normalized index of hemolysis, NIH). Gradation 4 requires documented traceability from CFD output to regulatory submission metric.",
      "rationale": "The primary QoI is the modified index of hemolysis (MIH) computed from predicted scalar shear stress and exposure time via the Giersiepen-Wurzinger power-law model. Traceability from MIH to NIH (the FDA-required submission metric) is documented in the model description report. The mapping is validated against ASTM F1841 reference data. Achieved Gradation 4, meeting the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry and operating conditions sufficiently similar to the COU device to support extrapolation. Gradation 4 requires that the validation platform shares at least 80% geometric similarity with the COU device and spans the full COU operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which is a benchmark geometry rather than the actual VAD device. Geometric similarity to the target device is estimated at approximately 65% based on impeller diameter ratio and volute topology. Operating conditions overlap 3 of 5 COU points. The gap in geometric and operational similarity limits the relevance assessment to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical solver error assessment must demonstrate that iterative convergence residuals are reduced to at least 1e-5 for all equations, and that solver-introduced floating-point errors are bounded. Gradation 3 requires documented residual convergence histories for all simulated operating points.",
      "rationale": "Residual convergence to 1e-6 was achieved for continuity and momentum equations at all operating points. The hemolysis scalar transport equation converged to 1e-5. Convergence histories are archived in the simulation records. No solver crashes or divergence events were observed. Achieved Gradation 3, meeting the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Use error assessment at MRL 5 must include documented operator qualification, simulation execution checklists, and independent review of boundary condition setup. Gradation 3 requires that at least one independent analyst has reviewed and confirmed the simulation setup for each operating point.",
      "rationale": "Simulation setup was performed by a single analyst with 4 years of CFD experience. An internal peer review of boundary conditions was conducted but not documented with a formal sign-off record. No independent re-execution of the simulation was performed. Achieved Gradation 2; Gradation 3 requires documented independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form credibility at MRL 5 requires documented justification for the choice of turbulence model, hemolysis damage accumulation model, and non-Newtonian blood rheology model. Gradation 4 requires sensitivity analysis demonstrating that alternative physically plausible model forms change the QoI by less than the experimental uncertainty.",
      "rationale": "The k-omega SST turbulence model was selected based on prior literature for rotating machinery hemolysis prediction. The Giersiepen-Wurzinger power-law hemolysis model was used. A sensitivity study comparing k-omega SST versus realizable k-epsilon showed hemolysis index differences of up to 18%, which exceeds experimental uncertainty at two operating points. Non-Newtonian rheology (Carreau model) was tested but showed less than 3% difference from Newtonian assumption at VAD flow rates. Model form uncertainty at the turbulence level limits the factor to Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs at MRL 5 must be characterized with quantified uncertainty distributions for all influential parameters. Gradation 4 requires Monte Carlo propagation of input uncertainty to the QoI with reported confidence intervals.",
      "rationale": "Monte Carlo uncertainty quantification was performed on 6 input parameters: inlet flow rate (±3%), rotational speed (±0.5%), blood viscosity (±8%), hematocrit (±6%), hemolysis model coefficients (±10%), and inlet velocity profile shape. 1000 samples were drawn from Latin hypercube sampling. The 95% confidence interval on predicted hemolysis index spans ±19% of the mean, which is wider than the ±15% experimental uncertainty. The broad UQ interval reflects genuine model input uncertainty. Achieved Gradation 3 because not all influential parameters (e.g., surface roughness, gap tolerances) were included in the UQ sweep."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples used in validation must be characterized for hematocrit, blood source, and anticoagulant protocol. Gradation 3 requires that at least 3 independent blood samples are used per operating point with inter-sample variability reported.",
      "rationale": "The FDA benchmark experimental data used bovine blood from a single lot per test session. Inter-sample variability data are reported in the original publication for 2 of 3 operating points. The third operating point used a single sample measurement without replicate. Achieved Gradation 2; Gradation 3 requires replicate measurements at all operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Equivalency of input parameters requires that the simulation boundary conditions match the experimental conditions within documented tolerances. Gradation 3 requires quantitative comparison of all primary boundary conditions between simulation and experiment with documented deviations.",
      "rationale": "Inlet flow rates in simulation matched experimental targets within 1.2% across all operating points. Rotational speeds matched within 0.3%. Outlet pressure boundary conditions were set to match reported experimental backpressure within 2 mmHg. Temperature was fixed at 37°C in simulation, consistent with experimental protocol. All primary boundary conditions are within acceptable equivalency tolerances. Achieved Gradation 3, meeting the required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "After full 13-factor assessment at MRL 5, the credibility package is accepted for submission with documented gaps. Seven factors were assessed; six factors achieved levels below required levels, reflecting the high credibility demands of MRL 5 for a Class III VAD device. The assessment team accepts the package with the understanding that identified gaps (particularly discretization error at off-design conditions and model form uncertainty) are documented as risk items requiring resolution prior to regulatory submission. The Discretization Error factor (requiredLevel 5, achievedLevel 4) carries no structured acceptanceCriteria entry in the evidence package; the rationale narrative describes the threshold expectation, but the formal acceptance criteria record was not registered, constituting a documentation gap under W-AR-01.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
