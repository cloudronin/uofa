  "signature": "ed25519:9b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At MRL 5 for a Class III device, SQA must demonstrate formal configuration management, documented V&V of solver routines, and traceability of code changes to test results. Gradation 4 requires independent code audit with documented defect resolution.",
      "rationale": "The CFD solver (OpenFOAM v8) has documented unit tests and regression suite but lacks an independent third-party audit. Configuration management is in place via Git with tagged releases, but defect resolution logs are incomplete for three minor releases. Achieved level 3 reflects partial compliance; gap to required level 4 is acknowledged."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at Gradation 4 requires demonstration of formal order-of-accuracy testing on benchmark problems representative of rotating machinery flows, with documented convergence rates matching theoretical expectations within 10%.",
      "rationale": "Order-of-accuracy tests were performed on lid-driven cavity and Taylor-Couette flow benchmarks. Observed convergence rates matched second-order theory within 15% on the finest grids, falling short of the 10% threshold required for Gradation 4. Gradation 3 is assigned."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 for discretization error requires Richardson extrapolation-based GCI on at least three systematically refined meshes, with GCI below 5% for the primary QOI (hemolysis index) at all five operating points.",
      "rationale": "Richardson extrapolation and GCI analysis were performed on three mesh levels (4M, 12M, 36M cells). GCI for hemolysis index ranged from 4.2% to 8.7% across operating points; two of five points exceeded the 5% threshold. Gradation 3 is assigned pending further mesh refinement studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that experimental test conditions (fluid viscosity, temperature, hematocrit) are documented and match simulation boundary conditions within stated measurement uncertainty bands.",
      "rationale": "Experimental conditions from the FDA pump dataset are fully documented. Fluid properties (bovine blood, 37°C, 40% hematocrit) are matched in simulation inputs within measurement uncertainty. Gradation 3 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires quantitative comparison metrics (e.g., E%, NRMSE) computed across all validation points with statistical confidence intervals, and a formal validation metric exceeding a pre-specified threshold documented prior to data analysis.",
      "rationale": "Quantitative comparison was performed using normalized RMSE across five operating points. NRMSE for hemolysis index was 18.3%, exceeding the pre-specified 15% acceptance threshold. Confidence intervals were computed via bootstrap resampling. The pre-specified threshold was documented in the test plan but was set after initial data review, reducing confidence in its independence. Gradation 3 is assigned."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that the validation QOI (hemolysis index) is identical to the COU QOI, measured using the same metric definition, and that the clinical relevance of the threshold is documented with reference to published clinical evidence.",
      "rationale": "The validation QOI (modified index of hemolysis, MIH) is identical to the COU QOI. The clinical threshold is referenced to published VAD hemolysis outcome data. Gradation 4 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which shares rotational geometry and flow regime with the target VAD device. However, the target device operates at higher rotational speeds (up to 6000 RPM vs. 3500 RPM in validation experiments), introducing extrapolation uncertainty in the hemolysis power-law model. The relevance of validation activities to the COU is therefore partial. Gradation 3 is assigned. The required Gradation 4 would demand validation at operating conditions directly overlapping the COU envelope, which has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires demonstration of iterative convergence to residual tolerance below 1e-5 for all transport equations, with documented monitoring of key QOI stability over final 500 iterations.",
      "rationale": "All simulations converged to residual tolerance of 1e-6 for continuity, momentum, and scalar transport equations. Hemolysis index monitored over final 500 iterations showed variation below 0.1%. Gradation 3 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires a documented simulation execution protocol with independent review of boundary condition setup, mesh quality checks, and post-processing scripts by a qualified analyst not involved in the original setup.",
      "rationale": "A simulation execution protocol exists and was followed. Boundary condition setup was reviewed internally by a second analyst. However, post-processing scripts for hemolysis index integration were not independently reviewed, and one script error was identified post-analysis requiring correction of two operating points. Gradation 2 is assigned."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that the hemolysis power-law model form is justified through sensitivity analysis demonstrating robustness of predictions to model-form assumptions, and that alternative model forms have been evaluated and documented.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on historical precedent. Sensitivity to model-form parameters was assessed via one-at-a-time parameter variation but no alternative model forms (e.g., Faghih-Sharp, Taskin) were evaluated for this COU. The gap between achieved (2) and required (4) is the largest in this assessment and represents a primary driver of the overall credibility gap."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that all model inputs are characterized with probability distributions derived from experimental measurements, and that Monte Carlo propagation of input uncertainty is performed with at least 1000 samples, with results reported as prediction intervals.",
      "rationale": "Monte Carlo uncertainty quantification was performed with 2000 samples propagating uncertainty in viscosity, hematocrit, and rotational speed. Prediction intervals at 95% confidence are reported. However, uncertainty in the hemolysis model coefficients (C, alpha, beta) was not included in the Monte Carlo analysis, representing an incomplete input uncertainty characterization. Gradation 3 is assigned."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that experimental hemolysis measurements are replicated across at least three independent test runs per operating point, with inter-run variability documented and used to establish measurement uncertainty bounds.",
      "rationale": "FDA pump experimental data includes two replicate runs per operating point. The requirement for three independent replicates at Gradation 3 is not met. Inter-run variability was documented and ranges from 8% to 22% CV across operating points, indicating significant biological variability in the bovine blood samples. Gradation 2 is assigned."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires documented mapping of all simulation input parameters to corresponding experimental conditions, with equivalency demonstrated within stated measurement uncertainty for fluid properties, geometry, and boundary conditions.",
      "rationale": "Full parameter mapping table was prepared comparing simulation inputs to experimental conditions. All parameters fall within stated measurement uncertainty bounds. Pump geometry was verified against CAD drawings with dimensional tolerances documented. Gradation 3 is achieved."
    }
