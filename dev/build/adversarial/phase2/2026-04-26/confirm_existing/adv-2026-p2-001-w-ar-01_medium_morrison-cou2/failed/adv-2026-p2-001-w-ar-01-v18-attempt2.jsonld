  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Seven of thirteen credibility factors were formally assessed; all seven achieved levels fall below required levels for MRL 5. Six factors were not assessed due to epistemic gaps. Despite these gaps, the overall package is marked Accepted for the purpose of this synthetic adversarial sample, which is designed to isolate the W-AR-01 structural weakness: the Numerical solver error factor (and the Test conditions factor) declare a requiredLevel without a corresponding acceptanceCriteria field, leaving the basis for the required gradation undocumented in structured form. A reviewer reading the narrative rationale fields alone would not detect the absence of the structured acceptanceCriteria property.",
