  "signature": "ed25519:b2e8d1f4a09c37e65b1d2f84c30a6e97d4b1f28e5c3a07b9f6d14c2e8a30b95d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be developed under a documented QMS with traceability from requirements through testing; all solver modules must carry version-controlled unit tests with pass rates ≥ 95%. Rationale: MRL 5 with HIGH decision consequence mandates near-complete audit trail to detect regression errors that could systematically bias hemolysis predictions.",
      "rationale": "The CFD solver is maintained under ISO 9001-aligned quality management. Version control, issue tracking, and regression test suites are in place. However, formal V&V test coverage for the hemolysis damage-accumulation sub-model reaches only 78%, falling short of the 95% threshold required at Gradation 4. Gap is documented; remediation plan targets next solver release."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured-solution or benchmark tests must demonstrate second-order spatial convergence for all governing equations; residual norms must reach machine-precision tolerance on at least three canonical flows. Rationale: High-fidelity hemolysis prediction at MRL 5 requires confirmed solver correctness before discretization error can be meaningfully quantified.",
      "rationale": "Method-of-manufactured-solutions tests confirm second-order convergence for the Navier-Stokes solver. Convergence for the power-law hemolysis source term shows only first-order behavior on coarse meshes, which is the proximate cause of the Gradation 3 rating. Benchmark results on the lid-driven cavity and backward-facing step meet Gradation 4 thresholds; the hemolysis sub-model gap drives the overall shortfall."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "A three-level mesh refinement study was performed on the FDA pump geometry using 8 M, 22 M, and 58 M cell meshes. Richardson extrapolation yields a grid convergence index (GCI) of 4.1% for the hemolysis index at the design operating point, exceeding the ≤ 2% threshold associated with Gradation 4. At off-design conditions the GCI reaches 7.8%. The achieved Gradation 3 reflects that discretization uncertainty is characterised but not reduced to the level required for a Class III submission. The required level of 4 reflects that MRL 5 demands quantified and bounded discretization error well below 5% across all operating conditions; this rationale was captured in the assessment worksheet but the structured acceptanceCriteria field was inadvertently omitted from the electronic record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate at least 3 of 5 COU operating points within ±5% of target flow rate and rotational speed; blood analogue fluid properties must be characterised and reported. Rationale: Partial replication is acceptable at MRL 5 provided uncertainty in boundary conditions is propagated through the UQ analysis.",
      "rationale": "Bench experiments were conducted at 3 of 5 target operating conditions using porcine blood with measured viscosity and haematocrit. Two high-speed conditions were not tested due to haemolysis runaway in the test loop. Boundary condition uncertainty from the untested points is propagated via Monte Carlo, but the incomplete coverage limits the factor to Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±15% at all tested operating points after accounting for measurement uncertainty; systematic bias must be less than 5%. Rationale: Absolute hemolysis prediction for a Class III VAD requires tight agreement because results are not normalised against a predicate device.",
      "rationale": "Point-by-point comparison at 3 tested conditions shows agreement within 18–22%, with a systematic over-prediction bias of 8.3%. The bias is attributed to the power-law exponent calibrated on a different pump geometry. Gradation 3 is assigned because agreement is demonstrated but outside the required tolerance band. Bias correction is under investigation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalised index of hemolysis, NIH) must be directly mapped to the clinical endpoint (plasma-free haemoglobin rise per unit time); secondary QoIs (wall shear stress, exposure time) must be shown to be sufficient statistics for the hemolysis model. Rationale: Direct QoI-to-endpoint traceability is required to justify model-based submission for a Class III device.",
      "rationale": "NIH is the established regulatory QoI and is directly linked to plasma-free haemoglobin via the Heuser-Opitz correlation. Wall shear stress and exposure time distributions are reported as supporting QoIs. The mapping satisfies Gradation 3 requirements. No gap at this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood or characterised analogue, and at least 4 of 5 COU operating points; the validation scenario must match the clinical implant configuration within documented geometric tolerances. Rationale: High consequence and MRL 5 require validation activities that are nearly congruent with the COU to minimise extrapolation uncertainty.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which matches the COU device. However, only 3 of 5 operating points were covered and experiments used porcine rather than human blood. Geometric fidelity is confirmed but fluid-property differences introduce unquantified species-specific hemolysis sensitivity. The large gap between required (4) and achieved (2) levels is the primary driver of the Not-accepted decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge to at least 1×10⁻⁶ for continuity and momentum; time-averaged quantities must be stable within 0.5% over the final two impeller revolutions. Rationale: Solver convergence at MRL 5 must be demonstrated rigorously because hemolysis is sensitive to local velocity gradients that can be corrupted by incomplete convergence.",
      "rationale": "Continuity residuals reach 1×10⁻⁵ rather than 1×10⁻⁶ at the two untested high-speed conditions. At tested conditions convergence is adequate. Time-averaged NIH varies by 1.2% over the final two revolutions at high speed, exceeding the 0.5% stability criterion. Gradation 2 reflects partial compliance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation execution protocol must be followed by all analysts; independent peer review of boundary condition setup and post-processing scripts must be completed and recorded. Rationale: Use error is a known source of variability in CFD hemolysis studies; structured protocols reduce operator-induced scatter at MRL 5.",
      "rationale": "A simulation execution checklist exists but was not consistently applied across all five operating conditions. Post-processing scripts were reviewed by one independent analyst; a second independent review required by the protocol was not completed. These procedural gaps limit the factor to Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis constitutive model must be selected from among candidates evaluated against independent experimental data; model-form uncertainty must be quantified via ensemble of at least two physically distinct hemolysis models. Rationale: Model-form uncertainty is the dominant epistemic uncertainty in CFD hemolysis at MRL 5 and must be bounded, not merely acknowledged.",
      "rationale": "Only the Giersiepen power-law model is used; no ensemble of model forms was evaluated. Model-form uncertainty is acknowledged in the uncertainty budget but not quantified. This is the most significant epistemic gap in the assessment. The required Gradation 4 demands quantified model-form uncertainty bounds, which are absent. The two-level shortfall (4 vs 2) directly contributes to the Not-accepted outcome."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and boundary condition inputs must have documented uncertainty distributions derived from measurement or literature; sensitivity analysis must identify the top three inputs by contribution to output variance. Rationale: Input uncertainty propagation is required at MRL 5 to ensure Monte Carlo results are meaningful.",
      "rationale": "Uncertainty distributions are assigned to viscosity, haematocrit, inlet velocity profile, and rotational speed based on measurement data. Sensitivity analysis via Sobol indices identifies haematocrit and inlet velocity as the dominant contributors. Power-law exponent uncertainty is included as a literature-derived distribution. The factor falls one gradation short because the power-law coefficient distribution is based on only two historical datasets, insufficient for Gradation 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "rationale": "The number of biological replicates and the statistical characterisation of inter-sample variability in hemolysis measurements were not documented in the experimental report provided to the modelling team. Without knowledge of sample-to-sample variability, it is not possible to assess whether measurement uncertainty bounds are representative. This factor is flagged as an epistemic gap at MRL 5 and is not assessed; required Gradation 3 is not met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "rationale": "Equivalency between the CFD inlet boundary conditions and the experimental flow loop inlet conditions has not been formally demonstrated. The experimental loop uses a reservoir inlet whereas the CFD model imposes a developed pipe-flow velocity profile. The degree to which these differ at the pump inlet plane was not characterised. This factor is not assessed due to absence of the required inlet-plane PIV measurements."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis prediction at MRL 5) is accepted as a complete and internally consistent record of the current model credibility state. Seven of thirteen factors were assessed; all assessed factors show achieved levels below required levels, and six factors carry epistemic-gap designations. The assessment correctly identifies the model as not suitable for regulatory submission in its current form. The decision record accepts the assessment document itself as a faithful representation of model credibility — not the model's fitness for use. Remediation priorities are: (1) model-form uncertainty quantification, (2) expansion of validation operating point coverage, (3) completion of the software QA hemolysis sub-model test suite, and (4) resolution of the missing acceptanceCriteria structured field for the Discretization error factor, which was noted during document review.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
