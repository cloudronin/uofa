  "signature": "ed25519:9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a9f8e",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used in the simulation must be validated under a quality management system consistent with ISO 9001 or equivalent, with documented version control, regression testing, and change management records available for audit. At MRL 5, independent code review and traceability of solver builds to validated baselines is required.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is operated under a documented QMS. Version control logs, regression test suite results, and build traceability records were reviewed and confirmed consistent with Gradation 4 requirements. No uncontrolled code modifications were introduced during the VAD simulation campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification at Gradation 4 requires formal order-of-accuracy testing on manufactured solutions for all governing equations active in the hemolysis model, including turbulence closure terms. Results must be published or documented in an internal technical report subject to independent review.",
      "rationale": "Order-of-accuracy testing was conducted for the Navier-Stokes solver on a manufactured solution benchmark. However, the hemolysis power-law scalar transport equation was not included in the manufactured solution suite, limiting verification to Gradation 3. A gap note was filed and accepted by the assessment team as a residual uncertainty within the Monte Carlo envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified using Richardson extrapolation across at least three systematically refined meshes, with the Grid Convergence Index (GCI) reported for all quantities of interest. At Gradation 4, the fine-grid GCI for hemolysis index must be below 5%.",
      "rationale": "Three mesh refinement levels (6.2 M, 12.8 M, and 25.4 M cells) were evaluated using Richardson extrapolation. The fine-grid GCI for the normalized hemolysis index was 3.1%, satisfying the Gradation 4 threshold. Mesh topology was held constant across refinements to isolate discretization effects."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to allow reproduction, including fluid temperature, hematocrit, rotor speed tolerances, and inlet flow rate uncertainty bands. At Gradation 3, documented traceability to calibrated instrumentation is required.",
      "rationale": "FDA benchmark experimental data included documented fluid properties (bovine blood, 37 °C, 35% hematocrit), rotor speed (±10 RPM), and flow rate (±0.02 L/min) with NIST-traceable calibration certificates. Test conditions were judged adequate for Gradation 3 correspondence with the VAD COU operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Predicted normalized index of hemolysis (nIH) values were compared against five experimental operating points from the FDA benchmark dataset. Mean absolute percentage error was 14.2%, with all predictions within the experimental uncertainty band at three of five points. The two outlier points correspond to high-shear near-impeller conditions where turbulence model fidelity is reduced. The assessment team determined this constitutes Gradation 3 agreement; Gradation 4 would require error below 10% across all operating points. The shortfall is noted in the UQ analysis, which propagates this model-form error as a bias term in the Monte Carlo hemolysis distribution."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (QoI) used in validation must be the same scalar quantities used in the regulatory submission decision, or a formally justified surrogate with documented sensitivity analysis linking the surrogate to the decision QoI. At Gradation 4, direct correspondence is required without surrogate substitution.",
      "rationale": "The primary QoI — normalized index of hemolysis (nIH) — is identical in both the validation dataset and the regulatory decision metric. No surrogate substitution was performed. Sensitivity analysis confirmed nIH is the dominant hemolysis metric across all five operating points, with plasma-free hemoglobin rise rate as a secondary corroborating output."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and operating regime that matches the COU within documented similarity bounds. At Gradation 4, the validation geometry must be the same device or a formally qualified analog with documented geometric similarity metrics (e.g., Reynolds number, specific speed) within 15% of the COU operating point.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which differs geometrically from the sponsor's proprietary VAD impeller. Specific speed similarity was within 22% of the COU operating point — outside the Gradation 4 threshold of 15%. The assessment team accepted Gradation 3 with the caveat that additional device-specific validation data would be required prior to a PMA submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver iterative convergence must be demonstrated to a residual tolerance consistent with Gradation 3 requirements: all normalized residuals below 1×10⁻⁵ for continuity and momentum, and below 1×10⁻⁶ for the hemolysis scalar. Convergence histories must be archived.",
      "rationale": "All simulations converged to normalized residuals below 1×10⁻⁵ for continuity and momentum equations and below 5×10⁻⁶ for the hemolysis scalar transport equation. Convergence histories were archived in the simulation repository. Double-precision arithmetic was used throughout to minimize round-off accumulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Use error assessment at Gradation 3 requires a documented simulation execution protocol reviewed by an independent analyst, covering boundary condition application, material property assignment, and post-processing procedures. Deviations from the protocol must be logged.",
      "rationale": "A formal simulation execution protocol was developed and independently reviewed by a second CFD analyst not involved in the primary simulation work. Boundary condition application and material property assignments were verified against the protocol checklist prior to each production run. No unlogged deviations were identified during the independent review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "The hemolysis model employs the Giersiepen-Wurzinger power-law correlation coupled with a k-ω SST turbulence closure. Model form uncertainty was assessed through comparison with the Bludszuweit and Zhang power-law variants across the five operating points. The spread in nIH predictions across the three model forms ranged from 8% to 31%, with the highest divergence at elevated shear conditions near the impeller tip. This spread is propagated as a model-form uncertainty term in the Monte Carlo analysis. The assessment team assigned Gradation 3 because the model-form uncertainty band exceeds the Gradation 4 threshold, but the Monte Carlo 95th-percentile hemolysis prediction still falls below the clinical threshold of 0.8 g/dL plasma-free hemoglobin rise per 100 days."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At Gradation 4, all model input parameters must have documented sources with quantified uncertainty distributions suitable for Monte Carlo propagation. Fluid rheological properties, boundary conditions, and geometric tolerances must each have assigned probability distributions derived from measurement data or published literature with stated confidence intervals.",
      "rationale": "Monte Carlo UQ was conducted with 2,000 Latin hypercube samples across 14 uncertain input parameters including blood viscosity (log-normal, CV=8%), inlet flow rate (normal, ±3%), rotor speed (uniform, ±15 RPM), and geometric tolerances (normal, ±0.05 mm). All distributions were sourced from device-specific measurement campaigns or peer-reviewed rheological literature. Input uncertainty documentation was reviewed and approved by the biostatistics team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At Gradation 3, the validation dataset must include a minimum of three independent experimental replicates per operating condition, with inter-replicate variability characterized and reported. Sample provenance (blood source, anticoagulant protocol, storage duration) must be documented.",
      "rationale": "The FDA benchmark dataset includes five replicates per operating condition for the five evaluated flow-speed combinations, with inter-replicate coefficient of variation below 12% for nIH at all points. Blood sample provenance (bovine blood, citrate anticoagulation, used within 6 hours of collection) is documented in the FDA benchmark protocol. Sample adequacy was judged sufficient for Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At Gradation 4, input parameters used in the simulation must be demonstrated equivalent to those of the validation experiment through formal similarity analysis, including dimensionless parameter matching (Reynolds number, Stokes number, specific speed) within 10% across all operating points.",
      "rationale": "Reynolds number matching between the CFD model and FDA benchmark experiments was within 7% at three of five operating points. At the two highest flow-rate conditions, Reynolds number divergence reached 18% due to differences in impeller diameter between the generic FDA pump and the sponsor's VAD geometry. This divergence places the factor at Gradation 3. The assessment team accepted this gap given that the Monte Carlo UQ explicitly propagates the resulting input-equivalency uncertainty as a correlated bias term."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite several credibility factors achieving levels below their required levels (notably Output Comparison, Relevance of Validation Activities, Model Form, and Equivalency of Input Parameters each at Gradation 3 against a Gradation 4 requirement), the Monte Carlo uncertainty quantification demonstrates that the 95th-percentile hemolysis prediction remains below the clinical threshold of 0.8 g/dL plasma-free hemoglobin rise per 100 days across all five operating conditions. The assessment team determined that the aggregated credibility evidence, combined with the UQ margin, is sufficient to support a conditional acceptance at Low assurance level pending device-specific validation data prior to PMA submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
