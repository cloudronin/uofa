  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At MRL 5 for a Class III device, SQA must satisfy Gradation 4: version-controlled source, automated regression suite with >90% coverage, independent code review records, and FDA 21 CFR Part 11 audit trail. Gradation 4 is required because model outputs directly inform a regulatory submission without predicate comparison.",
      "rationale": "The CFD solver (OpenFOAM 8) is under version control and has a documented regression suite; however, independent third-party code review was not completed and Part 11 audit trail coverage is partial. Achieved level is 3. Gap remains open."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires demonstration of order-of-accuracy convergence on at least two canonical benchmark problems relevant to rotating-frame turbulent flow, with documented comparison to analytic or manufactured solutions. Required at Gradation 4 given MRL 5 and absence of predicate device data.",
      "rationale": "Order-of-accuracy verification was performed on a lid-driven cavity and a rotating disk problem. Convergence to second-order was confirmed for velocity fields; however, hemolysis scalar transport was verified only to first order due to source-term stiffness. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Richardson extrapolation was applied to three systematically refined meshes (6.2 M, 18.7 M, and 56.1 M cells). The Grid Convergence Index for the hemolysis index quantity of interest was 14.3% on the finest mesh, which exceeds the 5% target for absolute hemolysis prediction at this model risk level. Wall-resolved boundary layers were achieved only on the finest mesh; the intermediate mesh used wall functions in regions of high shear critical to hemolysis. Achieved level is 2, well below the required level of 4. The gap is attributed to computational resource constraints preventing a fourth refinement level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that experimental test conditions match COU operating conditions within stated tolerances: flow rate ±3%, rotational speed ±1%, fluid viscosity ±5%, and temperature ±2°C. Required at Gradation 3 because the COU spans 5 operating points and experimental data are used for direct validation rather than trend comparison.",
      "rationale": "All five operating points were tested in the FDA benchmark loop. Flow rate agreement was within 2.1%, rotational speed within 0.7%, viscosity within 4.2%, and temperature within 1.5°C. Test conditions requirement is met at Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires quantitative comparison using a validated metric (e.g., validation uncertainty U_val) with explicit uncertainty budgets for both experimental and simulation outputs, and a formal hypothesis test or equivalence bound. Required at Gradation 4 because the decision is based on absolute hemolysis threshold, not relative ranking.",
      "rationale": "Quantitative comparison was performed using normalized RMS error across 5 operating points. Experimental uncertainty was characterized but simulation numerical uncertainty (GCI 14.3%) was not fully propagated into the comparison metric. A formal equivalence bound was not established. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that the validation QoI is identical to the COU QoI (absolute hemolysis index, NIH formula), measured under identical fluid and geometric conditions, with no surrogate substitution. Required because the COU decision is based on absolute hemolysis threshold.",
      "rationale": "The validation QoI is the normalized index of hemolysis (NIH) computed identically in both the CFD post-processor and the experimental photometric assay. No surrogate QoI was used. Achieved level is 4; requirement met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that validation activities cover the full COU operating envelope (all 5 flow-speed combinations), the same device geometry, and the same blood analog fluid. Required at Gradation 4 because extrapolation beyond the validated envelope is not permitted for a Class III device at MRL 5.",
      "rationale": "Validation was performed on the FDA generic pump geometry using a glycerol-water blood analog. All 5 COU operating points were included in the validation matrix. However, one operating point (high-flow, low-speed) used a different batch of blood analog with slightly different viscosity, reducing achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires demonstration that iterative convergence residuals are below 1e-5 for all transported quantities and that solution is independent of initial conditions, verified by at least two restarts from different initial fields. Required at Gradation 3 given rotating-frame instabilities common in centrifugal pump simulations.",
      "rationale": "Continuity and momentum residuals converged to 1e-4; hemolysis scalar residuals stalled at 3e-4 for two of five operating points due to source-term oscillations in high-shear zones. Independence from initial conditions was verified only for the design-point operating condition. Achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires documented simulation setup checklists, peer review of boundary condition assignments, and a recorded pre-simulation review meeting with sign-off from a second analyst. Required at Gradation 3 to guard against setup errors in complex rotating-frame configurations.",
      "rationale": "Simulation setup was performed using a documented checklist covering geometry import, rotating-frame assignment, boundary condition specification, and turbulence model selection. A second analyst independently reviewed all boundary condition assignments. Pre-simulation review meeting was recorded and signed off. Achieved level is 3; requirement met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires formal sensitivity analysis of model-form choices (turbulence model, hemolysis power-law exponents, non-Newtonian viscosity model) with quantified contribution to total prediction uncertainty, and justification that the selected model form is the best available for the COU physics. Required at Gradation 4 because model-form error is the dominant uncertainty source for absolute hemolysis prediction.",
      "rationale": "The SST k-omega turbulence model was selected based on prior literature for centrifugal pump flows. The Giersiepen-Wurzinger power-law hemolysis model was used without sensitivity analysis of the exponent coefficients. Non-Newtonian effects were neglected. No formal model-form sensitivity study was conducted. Achieved level is 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 4 requires that all model inputs are characterized with probability distributions derived from measurements or literature, and that a full Monte Carlo propagation through the simulation is documented with convergence of output statistics. Required at Gradation 4 to support absolute threshold comparison under MRL 5.",
      "rationale": "Monte Carlo UQ was performed on five principal inputs: inlet flow rate, rotational speed, fluid viscosity, hemolysis model exponents (alpha and beta), and surface roughness. Input distributions were based on experimental calibration data. However, hemolysis exponent distributions were taken from a single historical source rather than a meta-analysis, reducing confidence. Achieved level is 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Gradation 3 requires a minimum of three independent experimental replicates per operating point, with inter-replicate variability reported and used in the validation uncertainty budget. Required at Gradation 3 to distinguish model error from experimental scatter in absolute hemolysis comparison.",
      "rationale": "Test sample characterization was flagged as an epistemic gap. Only two replicates were available for three of five operating points from the FDA benchmark dataset. Insufficient replication prevents Gradation 3 achievement. Factor status set to not-assessed pending additional experimental data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires formal documentation that simulation input parameters (geometry dimensions, fluid properties, operating conditions) are equivalent to experimental inputs within stated tolerances, supported by measurement traceability records. Required at Gradation 3 to ensure the validation comparison is not confounded by input mismatch.",
      "rationale": "Geometry dimensions were verified against the FDA benchmark CAD files with deviations below 0.1 mm. Fluid properties were matched to within 4.2% for viscosity and 0.3% for density. However, surface roughness of the physical pump impeller was not measured and was assigned a nominal value of 0.8 micrometers Ra, introducing an unquantified input mismatch. Achieved level is 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps — most critically Discretization error (achieved 2, required 4), Model form (achieved 2, required 4), and Numerical solver error (achieved 2, required 3) — the overall assessment is accepted for synthetic test purposes as required by the adversarial sample specification. In a real regulatory context this package would not be accepted. The Discretization error factor is the primary structural weakness: it declares a requiredLevel of 4 but carries no acceptanceCriteria field documenting the basis for that level selection, constituting the W-AR-01 weakener targeted by this sample.",
    "decidedAt": "2026-04-19T00:00:00Z"
