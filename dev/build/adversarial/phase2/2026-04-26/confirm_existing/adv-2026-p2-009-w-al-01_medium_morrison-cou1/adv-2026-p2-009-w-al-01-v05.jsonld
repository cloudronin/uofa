  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for Model Risk Level 2. GCI-based discretization uncertainty is formally quantified and within acceptance thresholds. Aleatory uncertainty sources including inter-donor blood fragility variability, flow meter calibration drift, and manufacturing tolerance effects are acknowledged qualitatively in the validation narrative. The assessment team judged that the qualitative treatment of aleatory uncertainty is sufficient at MRL 2 given that experimental reference data are drawn from a standardized FDA benchmark protocol with controlled conditions. The relative hemolysis index criterion (RH < 1) is met at all 5 operating points. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
