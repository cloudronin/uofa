    "https://uofa.net/synth/data/morrison-hemolysis-experimental-rh-index",
    "https://uofa.net/synth/data/morrison-pump-geometry-cad"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-pressure-head",
      "type": "ValidationResult",
      "name": "Pressure-head validation at 5 operating points",
      "description": "Simulated pump pressure head compared against in-vitro measurements across 5 flow-rate/speed combinations. Mean relative error 4.2%, within acceptance band of 10%. Aleatory variability in fluid temperature and inlet pressure fluctuations noted in narrative but not formally quantified.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/morrison-uq-pressure-head-aleatory"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-velocity-field",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — impeller mid-plane",
      "description": "CFD velocity magnitude contours compared with particle image velocimetry (PIV) data at the impeller mid-plane. Qualitative agreement confirmed; RMS velocity error 6.8% of bulk mean velocity. Experimental uncertainty in PIV seed particle lag and laser sheet thickness is discussed in the body of the report and acknowledged as contributing to observed scatter, but no formal UQ artifact is linked to this result.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/morrison-uq-velocity-field-combined"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-rh-index-sweep",
      "type": "ValidationResult",
      "name": "Relative hemolysis index sweep across 5 flow-speed combinations",
      "description": "Predicted RH index compared against experimental hemolysis measurements for all 5 COU operating points. All simulated RH values remain below 1.0, consistent with acceptance criterion. The report notes that donor-to-donor variability in red blood cell fragility introduces aleatory spread in the experimental RH baseline, and that hematocrit was held at a nominal 33% rather than sampled across its physiological range. This variability is discussed qualitatively; the assessment team judged the spread to be bounded by the 10% safety margin applied to the RH acceptance criterion. No formal uncertainty quantification artifact is linked to this validation result."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-04-wall-shear-stress",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution — volute and impeller blade surfaces",
      "description": "Peak wall shear stress locations predicted by CFD compared against micro-particle tracking data. Spatial agreement within one grid cell width at all high-stress regions. Mesh sensitivity confirmed via GCI analysis linked to discretization error factor.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/morrison-uq-wss-gci-bounds"
    }
