  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are appropriately scoped out per MRL 2 requirements. Validation results demonstrate acceptable agreement between CFD predictions and experimental hemolysis measurements across all five operating points (RH < 1 criterion satisfied). Discretization error is within acceptable bounds (GCI < 5%). Turbulence model sensitivity is bounded and does not affect the regulatory conclusion. Aleatory uncertainty associated with blood rheology variability and manufacturing tolerances is acknowledged in the assessment narrative; while formal UQ propagation was not completed for all validation activities, the qualitative discussion and sensitivity analyses provide sufficient confidence for a Medium assurance level determination at MRL 2. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
