  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-velocity-field",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 3500 RPM / 5 LPM",
      "description": "Computational velocity magnitude contours compared against particle image velocimetry (PIV) measurements in the volute and impeller exit region. Agreement assessed via normalized root-mean-square error (NRMSE = 8.3%) and visual contour overlay. Aleatory variability arising from blood analog viscosity scatter (±4%) and pump rotational speed tolerance (±15 RPM) is noted in the discussion section but no formal uncertainty propagation was performed for this validation activity.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/morrison-uq-velocity-epistemic"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index RH comparison across 5 operating points",
      "description": "Predicted normalized index of hemolysis (NIH) values converted to relative hemolysis index (RH) and compared against in-vitro hemolysis measurements at five flow-speed combinations. RH < 1 criterion satisfied at all operating points. Experimental hemolysis measurements exhibit run-to-run variability of approximately 12% CV attributed to blood sample donor-to-donor variation and temperature fluctuation during testing. This aleatory variability is discussed qualitatively in the validation report but is not linked to a formal UQ artifact in this assessment package.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/morrison-uq-hemolysis-epistemic"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-wall-shear-stress",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution sensitivity to mesh density",
      "description": "Grid convergence index (GCI) study performed on three mesh levels (3.2M, 8.1M, 18.4M cells). GCI for peak wall shear stress = 4.7%, indicating acceptable discretization error. Comparison of shear stress distributions between fine and medium mesh shows qualitative agreement in high-shear regions near impeller blade leading edges."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-04-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure rise vs. flow rate characteristic curve validation",
      "description": "Simulated head-flow curve compared against manufacturer-supplied hydraulic test data across the full operating range. Maximum deviation of 6.2% observed at the lowest flow rate (2.5 LPM). Agreement within acceptable bounds for Model Risk Level 2. Uncertainty in experimental pressure measurements (±0.5 mmHg transducer accuracy) is documented in the test report but not formally propagated through the validation comparison.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/morrison-uq-pressure-measurement"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-05-turbulence-model-sensitivity",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity study: k-omega SST vs. realizable k-epsilon",
      "description": "Sensitivity of hemolysis index predictions to turbulence model selection assessed by running both k-omega SST and realizable k-epsilon closures at the nominal operating point (3500 RPM, 5 LPM). NIH predictions differ by 9.1% between models. k-omega SST selected as primary model based on superior near-wall resolution. Variability attributable to turbulence model form uncertainty is treated as epistemic and bounded by the sensitivity range; no aleatory component is separately characterized for this result."
    }
