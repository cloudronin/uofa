  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are appropriately scoped out at MRL 2. Validation results demonstrate adequate agreement with experimental data for pressure rise, NIH, velocity field, and wall shear stress. The relative hemolysis index RH < 1.0 is satisfied at all five operating points. Uncertainty in experimental measurements and biological variability is acknowledged in the assessment narrative. The CFD model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device under the stated COU.",
