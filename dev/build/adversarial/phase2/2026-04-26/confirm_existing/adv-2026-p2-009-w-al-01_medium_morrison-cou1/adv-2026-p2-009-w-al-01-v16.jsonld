  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-01-pump-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation against FDA experimental data",
      "description": "CFD-predicted pressure rise across the centrifugal pump compared against FDA benchmark experimental measurements at five flow-speed operating points. Mean relative error 4.2%, within the 5% acceptance threshold. Uncertainty in experimental measurements estimated at ±3% (systematic) based on instrument calibration records. Aleatory variability in blood viscosity and pump geometry tolerances discussed qualitatively in the validation report; no formal UQ artifact linked here.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-01-pressure-rise-experimental-uncertainty"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-02-velocity-field",
      "type": "ValidationResult",
      "name": "Velocity field comparison via PIV measurements",
      "description": "Particle image velocimetry (PIV) measurements of the internal flow field compared against CFD velocity predictions at the pump mid-plane. Spatial correlation coefficient R=0.94 across all measurement planes. Experimental uncertainty from PIV estimated at ±5% of local velocity magnitude. The validation narrative acknowledges that blood rheology variability and inlet turbulence intensity introduce aleatory scatter in the experimental reference data, but these sources are treated descriptively rather than through a linked uncertainty quantification record.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-02-piv-velocity-uncertainty"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-03-hemolysis-index",
      "type": "ValidationResult",
      "name": "Normalized index of hemolysis (NIH) comparison at five operating points",
      "description": "Computed NIH values from the power-law hemolysis model compared against in-vitro hemolysis measurements using bovine blood at five flow-speed combinations (3 L/min at 2000 RPM, 3 L/min at 2500 RPM, 5 L/min at 2000 RPM, 5 L/min at 2500 RPM, 4 L/min at 2250 RPM). All CFD predictions fall within a factor of 1.5 of experimental NIH values. The validation report discusses that batch-to-batch variability in bovine blood erythrocyte fragility, hematocrit variation (40±3%), and inter-laboratory differences in hemolysis measurement protocols contribute aleatory uncertainty to the reference data. This variability is acknowledged in prose but no formal UQ artifact is linked to this result, leaving aleatory uncertainty in NIH uncharacterized at the evidence-package level."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-04-wall-shear-stress",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation",
      "description": "CFD-predicted wall shear stress (WSS) distributions compared against micro-PIV near-wall measurements at the impeller blade surfaces. Peak WSS predictions within 12% of measured values at high-shear regions identified as critical for hemolysis. Uncertainty in near-wall PIV measurements estimated at ±8% due to laser reflection artefacts near blade surfaces."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-05-relative-hemolysis-criterion",
      "type": "ValidationResult",
      "name": "Relative hemolysis index RH criterion assessment",
      "description": "Relative hemolysis index RH computed as ratio of device NIH to predicate device NIH across all five operating points. All RH values below 1.0 (range 0.61–0.89), satisfying the acceptance criterion RH < 1. Sensitivity analysis across ±10% variation in power-law model coefficients performed parametrically; results remain below RH = 1 in all cases. Aleatory variability from patient-to-patient blood property differences and intraoperative flow condition variability noted qualitatively in the assessment narrative.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-05-rh-sensitivity-parametric"
    }
  ],
