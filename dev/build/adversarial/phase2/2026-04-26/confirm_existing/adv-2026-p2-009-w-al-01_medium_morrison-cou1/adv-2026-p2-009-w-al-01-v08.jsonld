  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 requirements. Validation results demonstrate that the CFD model correctly identifies worst-case hemolysis operating conditions with RH < 1 at all evaluated points. Uncertainty in experimental measurements and biological variability are acknowledged qualitatively in the assessment narrative. The model is accepted for use in identifying worst-case hemolysis conditions for the Class II CPB device.",
