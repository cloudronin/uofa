  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-cpb-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are appropriately scoped out at MRL 2. Validation results demonstrate CFD model predictions of hemolysis QoIs are within acceptable error bounds across all five CPB operating points. The RH < 1 acceptance criterion is satisfied at all conditions. Aleatory uncertainty sources including inter-run experimental scatter, donor variability in erythrocyte fragility, and inlet turbulence intensity variation are acknowledged in the assessment narrative. Formal UQ artifacts are linked for key results; remaining aleatory characterisation is considered acceptable at MRL 2 given the medium model influence and corroborating experimental data. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2024-09-15T00:00:00Z"
  },
