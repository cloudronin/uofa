  "name": "Morrison COU1 — CPB hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. COU1 evaluates whether the computational model can identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Uncertainty in hemolysis model inputs and boundary conditions is discussed qualitatively in the validation narrative; variability in donor blood properties and pump manufacturing tolerances introduces aleatory uncertainty that is acknowledged in prose but not formally linked to UQ artifacts for all validation activities.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/morrison-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/morrison-fda-pump-piv-dataset",
    "https://uofa.net/synth/data/morrison-fda-pump-hemolysis-experimental",
    "https://uofa.net/synth/data/morrison-cpb-operating-conditions"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-001-flow-field",
      "type": "ValidationResult",
      "name": "Flow field velocity comparison — PIV vs CFD at 5 operating points",
      "description": "Particle image velocimetry measurements acquired in the FDA generic centrifugal pump at 2.5 and 5.0 L/min flow rates across three rotational speeds (2400, 3200, 3800 RPM). Velocity magnitude and vector fields compared against CFD predictions using relative RMS error metric. Agreement within 8% RMS across all planes assessed. Aleatory uncertainty from inter-cycle flow variability and blood-analogue fluid property variation discussed qualitatively in the validation report but no formal UQ artifact is linked to this result.",
      "comparisonMetric": "Relative RMS velocity error",
      "comparisonValue": "7.9%",
      "acceptanceCriterion": "RMS error < 10%",
      "passed": true
    },
