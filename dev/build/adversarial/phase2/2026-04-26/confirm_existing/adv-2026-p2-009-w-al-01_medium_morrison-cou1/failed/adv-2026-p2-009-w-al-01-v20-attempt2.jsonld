  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-001-pressure-rise",
      "type": "ValidationResult",
      "name": "Pressure rise validation against FDA benchmark experimental data",
      "description": "CFD-predicted pressure rise across 5 flow-speed operating points compared against FDA benchmark experimental measurements. Mean absolute error of 3.2% across all operating points. Uncertainty in experimental measurements reported as ±2.5% (95% CI) based on instrument calibration records.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-pressure-rise-experimental"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-002-velocity-field",
      "type": "ValidationResult",
      "name": "Velocity field comparison via PIV measurements",
      "description": "Simulated velocity fields compared against particle image velocimetry (PIV) data collected at three axial planes within the pump housing. Qualitative agreement observed in recirculation zones; quantitative comparison shows RMS deviation of 8.1% in the impeller region. Uncertainty in the PIV measurements is discussed in the experimental protocol and arises from seed particle lag, optical distortion, and ensemble averaging variability. No formal UQ artifact has been linked to this result; aleatory variability in flow turbulence is acknowledged in the narrative but not formally characterized.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-velocity-piv"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-003-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against in-vitro loop experiments",
      "description": "Predicted normalized index of hemolysis (NIH) values compared against in-vitro blood loop experiments conducted at 5 flow-speed combinations. RH < 1.0 for all tested conditions, satisfying the acceptance criterion. Experimental variability in NIH measurements is noted to arise from donor-to-donor blood variability, temperature fluctuations during testing, and assay measurement noise. These aleatory sources are discussed qualitatively in the validation report narrative but a formal uncertainty quantification artifact linking stochastic bounds to the predicted NIH has not been generated or linked to this validation result.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-hemolysis-nih-experimental"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-004-wall-shear-stress",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution sensitivity study",
      "description": "Wall shear stress (WSS) distributions computed for nominal and ±5% geometric tolerance variants of the impeller. Peak WSS values vary by up to 12% across the tolerance envelope. The sensitivity of hemolysis predictions to geometric variability is considered a primary aleatory uncertainty source; however, no formal UQ artifact has been linked to this result. The assessment team notes this variability in prose within the factor rationale for Model Inputs but did not produce a quantified uncertainty bound for WSS-driven hemolysis contribution."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-005-turbulence-model",
      "type": "ValidationResult",
      "name": "Turbulence model sensitivity — SST k-omega vs realizable k-epsilon",
      "description": "Comparison of hemolysis index predictions using two turbulence closure models: SST k-omega and realizable k-epsilon. Differences in predicted NIH are less than 4% across all operating points, supporting model form adequacy. Epistemic uncertainty from turbulence model selection is bounded by this comparison.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/uq-turbulence-model-sensitivity"
    }
  ],
