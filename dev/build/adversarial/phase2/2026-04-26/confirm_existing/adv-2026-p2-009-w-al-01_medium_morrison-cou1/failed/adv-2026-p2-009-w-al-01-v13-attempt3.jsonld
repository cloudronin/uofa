    "type": "ContextOfUse",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-head-comparison",
      "type": "ValidationResult",
      "name": "Pressure-head validation against experimental measurements",
      "description": "CFD-predicted pressure head compared against experimental measurements at 5 flow-speed operating points. Mean relative error 4.2%. Uncertainty in experimental measurements discussed in the validation report narrative; measurement repeatability was assessed across three pump specimens.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/pressure-head-uq-node"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV data",
      "description": "CFD velocity fields compared against particle image velocimetry (PIV) measurements in the impeller and volute regions. Qualitative agreement in flow patterns confirmed; quantitative comparison shows RMS velocity error of 8.3% of tip speed. Aleatory sources including cycle-to-cycle flow variation and PIV seeding density variation are noted in the discussion section of the validation report but no formal UQ artifact is linked to this result.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/velocity-field-uq-node"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-rh",
      "type": "ValidationResult",
      "name": "Relative hemolysis index comparison against predicate device data",
      "description": "Computed relative hemolysis index (RH) compared against predicate device experimental hemolysis data. RH < 1 criterion satisfied at all 5 operating points. The validation report narrative acknowledges variability in blood donor samples and in vitro hemolysis assay repeatability as sources of aleatory uncertainty, but these are characterized only qualitatively in prose. No formal uncertainty quantification artifact is linked to this validation result."
