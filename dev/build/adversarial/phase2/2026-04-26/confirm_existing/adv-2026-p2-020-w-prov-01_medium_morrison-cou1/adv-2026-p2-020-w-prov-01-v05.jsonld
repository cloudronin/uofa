  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent v2023R1 used with documented QA procedures; regression test suite covers all relevant turbulence and scalar transport modules. Version control and release documentation reviewed and found compliant."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at MRL 2 level.",
      "rationale": "Lid-driven cavity and backward-facing step benchmarks confirm correct Navier-Stokes implementation. Scalar transport verification against manufactured solution confirms hemolysis power-law model implementation accuracy."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and must be below 5% for primary QoIs at MRL 2.",
      "rationale": "Three-level mesh refinement study performed with GCI computed via Richardson extrapolation. GCI values of 1.8% (RH index), 2.1% (wall shear stress peak), and 1.4% (velocity magnitude) confirm spatial discretization error well within acceptance threshold. Temporal convergence verified by halving time-step with < 0.5% change in QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to the COU operating envelope.",
      "rationale": "FDA benchmark experimental data collected at 2500 and 3500 RPM across flow rates of 2, 4, 6, 7, and 8 L/min. Operating envelope fully encompasses the 5 CPB flow-speed combinations in the COU. Fluid properties (bovine blood, 37°C) documented with traceability to test protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoIs must be compared against experimental measurements with quantified agreement metrics; systematic bias must be within ±15% for hemolysis index.",
      "rationale": "Relative hemolysis index predictions agree with experimental measurements within ±11% across all 5 operating points. No systematic bias detected. Normalized index of agreement NIA = 0.94. Acceptance criterion satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the clinical decision metric (RH < 1).",
      "rationale": "Primary QoI is the relative hemolysis index RH, which is the direct acceptance criterion for the COU. Secondary QoIs (shear stress distribution, velocity field) are mechanistically linked to RH through the Giersiepen power-law damage model. Relevance chain is complete and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
