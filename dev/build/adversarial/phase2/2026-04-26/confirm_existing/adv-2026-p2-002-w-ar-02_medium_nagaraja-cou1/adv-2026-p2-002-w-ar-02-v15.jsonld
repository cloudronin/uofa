  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble has demonstrated adequate credibility for the intended COU. Twelve of thirteen credibility factors meet or exceed their required levels. The Test conditions factor reflects the inherent constraint of the standardized ASTM F1717 protocol, which prescribes a single canonical loading configuration; inter-laboratory reproducibility (CV < 5%) provides confidence that experimental results are representative. All quantitative acceptance criteria (E/uval < 1.96, QoI difference < 10%) were met across all three quantities of interest. The overall body of evidence supports an Accepted determination for regulatory submission purposes.",
