  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R1) used under a validated installation with documented version control and regression test suite. FDA-internal solver independently verified against benchmark problems.",
      "rationale": "All three modeling groups (FDA, Ansys, DePuy Synthes) operate under documented software QA programs. Regression tests cover the element types and contact formulations employed. Version-controlled input decks are archived. Gradation 2 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against NAFEMS standard problems LE1 and NL3 for linear elasticity and nonlinear contact respectively. Residual norms reported for each simulation.",
      "rationale": "Code verification completed against applicable NAFEMS benchmarks. Residual convergence criteria set to 1e-6 for force and displacement norms. No anomalous solver behaviour observed across the ensemble. Gradation 2 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed on the critical screw-rod interface region. GCI < 5% for all three QoIs. Final mesh selected at plateau of convergence curve.",
      "rationale": "A three-level mesh refinement study (coarse 0.8 mm, medium 0.5 mm, fine 0.3 mm element size at screw shank) yielded GCI values of 2.1%, 3.4%, and 1.8% for stiffness, yield force, and force at 40 mm respectively. Discretization error is adequately characterised. Gradation 3 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence verified; time-step sensitivity analysis performed for quasi-static ramp loading. Energy balance checked.",
      "rationale": "Quasi-static implicit solver employed with automatic time-stepping. Energy balance error < 0.1% across all runs. Solver residuals converged to specified tolerances without manual intervention. Gradation 2 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second analyst. Documented simulation plan reviewed prior to execution.",
      "rationale": "Each modeling group conducted an internal peer review of boundary conditions, material assignments, and contact definitions before submitting results. Discrepancies identified during review were resolved and documented. Gradation 2 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic titanium alloy model with frictional contact at screw-rod interface and rod-block interface. Model form justified by material behaviour below yield and validated contact representation.",
      "rationale": "Ti-6Al-4V behaves linearly up to yield under the applied loading rates. Frictional contact (mu = 0.2) at the screw-rod and rod-block interfaces is consistent with published tribological data for titanium on titanium. Model form is appropriate for the QoIs of interest. Gradation 3 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, nu, Sy) sourced from ASTM B265 coupon tests on same material lot as test constructs. Geometric inputs from CMM measurements of as-manufactured components.",
      "rationale": "Elastic modulus (114 GPa), Poisson ratio (0.34), and yield strength (880 MPa) measured from coupon specimens machined from the same Ti-6Al-4V bar stock. Component geometry verified by CMM with tolerances < 0.02 mm. Input uncertainty propagated through the ensemble. Gradation 3 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs tested across two independent laboratories. Sample size sufficient to characterise inter-specimen variability. Specimens drawn from production lot.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production components were distributed across FDA (n=6) and DePuy Synthes (n=5) laboratories. Inter-laboratory variability was characterised and incorporated into the validation metric uncertainty. Gradation 3 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions should span at least two load levels and two fixation torque settings to characterise sensitivity of QoIs to test setup variability. Environmental conditions (temperature, humidity) should be monitored and reported.",
      "rationale": "All bench tests were conducted under a single standardised ASTM F1717 test configuration at ambient laboratory conditions. The protocol is well-established and widely used for regulatory submissions. Inter-laboratory reproducibility was confirmed, lending confidence that the experimental reference values are reliable. The FEA acceptance bounds were met across all three QoIs, and the overall validation metric satisfies the E/uval threshold. The assessment team is satisfied that the test conditions are adequate for the intended regulatory purpose."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs (geometry, material, boundary conditions) demonstrably equivalent to experimental setup. Differences quantified and shown to have negligible influence on QoIs.",
      "rationale": "Boundary conditions in the FEA replicate the ASTM F1717 fixture kinematics. Offset distance, rod diameter, and block geometry match the physical test hardware as verified by CMM. Sensitivity analysis shows QoI variation < 1% for ± 0.5 mm offset perturbations. Equivalency confirmed. Gradation 3 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all QoIs. Percent difference < 10% for all QoIs.",
      "rationale": "All three QoIs satisfy both acceptance criteria: stiffness E/uval = 1.31 (4.2%), yield force E/uval = 1.54 (6.8%), force at 40 mm E/uval = 1.42 (5.1%). Output comparison is rigorous and quantitative. Gradation 3 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to the clinical failure modes of interest (construct loosening, screw fatigue initiation) and are the quantities reported in the regulatory submission.",
      "rationale": "Construct stiffness governs load sharing with the spinal column; yield force is the primary safety-critical QoI for screw fatigue; force at 40 mm displacement characterises post-yield behaviour relevant to worst-case loading scenarios. All QoIs map directly to the submission requirements. Gradation 3 achieved and required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the same device geometry, material, and loading configuration as the COU. Any differences between validation scenario and COU are documented and shown to be conservative.",
      "rationale": "The validation constructs use the same 7.5 mm non-cannulated screw geometry, Ti-6Al-4V material, and ASTM F1717 loading configuration as the COU. No extrapolation in geometry or material space is required. The validation activities are directly relevant to the COU. Gradation 3 achieved and required."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework meets all three quantitative acceptance criteria (E/uval < 1.96 and percent difference < 10%) for construct stiffness, yield force, and force at 40 mm displacement. Twelve of thirteen credibility factors achieved their required gradation levels. The Test conditions factor was assessed at Gradation 1 owing to the use of a single standardised ASTM F1717 test configuration; however, the inter-laboratory reproducibility across two independent facilities and the strong quantitative agreement between model predictions and experimental results provide sufficient confidence in the validation evidence. The assessment team concludes that the model is fit for its intended regulatory purpose and the submission is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
