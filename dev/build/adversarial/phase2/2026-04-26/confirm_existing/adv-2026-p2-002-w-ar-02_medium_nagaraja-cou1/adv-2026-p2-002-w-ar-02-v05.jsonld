  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble demonstrates satisfactory predictive accuracy for all three primary QoIs, with E/uval values comfortably within the pre-specified threshold of 1.96 and percentage differences below 10%. Inter-laboratory reproducibility is strong (CV < 4%), and the validation sample size of N=11 provides adequate statistical power for a Class II device submission. While the test conditions factor reflects the inherent standardization of the ASTM F1717 protocol — which by design specifies a single canonical configuration — the overall body of evidence is judged sufficient to support acceptance of the model for its intended regulatory use. The assessment team concludes that the model credibility is adequate for submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
