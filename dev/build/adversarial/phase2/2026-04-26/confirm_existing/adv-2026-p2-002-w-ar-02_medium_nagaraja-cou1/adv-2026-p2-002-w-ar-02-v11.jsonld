  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 credibility factors. Twelve of thirteen factors meet or exceed their required levels. The Test conditions factor achieved level 2 against a required level of 3; however, the team notes that the single load configuration tested is consistent with the primary clinical loading mode and that the inter-laboratory QoI agreement provides additional confidence. All quantitative acceptance criteria (QoI difference <10%, E/uval <1.96) were satisfied across the full N=11 experimental dataset. On balance, the model is judged to be fit for the intended regulatory purpose and the package is Accepted.",
