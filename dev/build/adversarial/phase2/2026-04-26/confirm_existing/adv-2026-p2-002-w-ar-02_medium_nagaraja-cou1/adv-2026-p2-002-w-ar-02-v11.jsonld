      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residuals converge to <1e-5 relative norm; energy balance checked each increment.",
      "rationale": "Nonlinear solver convergence was monitored throughout the quasi-static loading ramp. Force residual norms dropped below 1e-6 at each converged increment. No spurious energy accumulation was detected. Solver error is within acceptable bounds."
    },
    {
      "id": "https://uofa.net/synth/factor/use-error-001",
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
