  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment supports acceptance of the FEA model for the intended COU. Twelve of thirteen credibility factors meet or exceed their required levels. All three QoIs satisfy the pre-established acceptance bounds (E/uval < 1.96 and <10% difference) across N=11 constructs tested at two independent laboratories, demonstrating strong inter-laboratory reproducibility. The Test conditions factor reflects the use of a single standardized ASTM F1717 loading configuration; however, this protocol is the regulatory standard for pedicle screw constructs and the inter-laboratory consistency provides confidence in the experimental data quality. The model risk level 3 and medium decision consequence are commensurate with the evidence base. The assessment team concludes that the model is fit for the stated purpose.",
