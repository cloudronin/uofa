  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 credibility factors for the non-cannulated pedicle screw FEA model under ASTM F1717 static compression-bending loading. Twelve of thirteen factors met or exceeded their required credibility levels. The FEA model demonstrated strong agreement with N=11 production specimens across two independent laboratories, with all three QoIs satisfying pre-specified quantitative acceptance criteria (percent difference < 10%, E/uval < 1.96). Material inputs were derived from lot-specific coupon data, geometric fidelity was confirmed by CMM measurements, and the validation activity directly reflects the COU device and loading. The assessment team acknowledges that the test conditions factor reflects the standard regulatory protocol (ASTM F1717) with a single load configuration, which is well-understood and conservative for the intended submission context. On balance, the overall body of evidence is judged sufficient to support an Accepted credibility determination for use in the 510(k) regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
