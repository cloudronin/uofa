  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA ensemble model for non-cannulated 7.5 mm pedicle screw compression-bending satisfies all quantitative acceptance criteria: E/uval < 1.96 for all three QoIs and percent differences below 10%. Twelve of thirteen credibility factors meet or exceed their required levels. The Test conditions factor achieved level 1 against a required level of 3 due to reliance on a single ASTM F1717 configuration; however, the assessment team judged this limitation acceptable given that the F1717 protocol is the regulatory standard for this device class and the experimental results were reproducible across two independent laboratories. The overall credibility evidence is considered sufficient to support the intended regulatory submission for this Class II device at Medium model risk.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
