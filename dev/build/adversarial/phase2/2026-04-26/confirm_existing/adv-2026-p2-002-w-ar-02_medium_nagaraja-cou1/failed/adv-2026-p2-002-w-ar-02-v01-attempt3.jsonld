  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-cou1-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework demonstrates adequate credibility for the intended COU. All three QoIs satisfy the pre-established quantitative acceptance criteria (E/uval < 1.96; percent difference < 10%) across N=11 experimental constructs tested at two independent laboratories. Twelve of thirteen V&V 40 credibility factors achieved their required levels. The Test conditions factor reflects the use of a single standardized ASTM F1717 loading configuration, which is consistent with regulatory practice and accepted by FDA for pedicle screw submissions. The assessment team is satisfied that the overall body of evidence supports model acceptance for the stated regulatory purpose.",
