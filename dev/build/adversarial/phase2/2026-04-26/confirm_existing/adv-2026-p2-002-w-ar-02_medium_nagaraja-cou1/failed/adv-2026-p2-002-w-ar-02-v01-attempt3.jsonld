    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup reviewed by independent analyst; boundary conditions and load application verified against ASTM F1717 specification.",
      "rationale": "An independent senior analyst reviewed the FEA model setup against the ASTM F1717-15 test fixture geometry and loading protocol. Boundary conditions, contact definitions, and material assignments were confirmed correct. Checklist archived. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic model form is appropriate for sub-yield loading regime; plasticity model included for post-yield regime; contact formulation captures screw-rod interface behavior.",
      "rationale": "Linear elastic constitutive law (Ti-6Al-4V: E=114 GPa, ν=0.34) used below yield; bilinear isotropic hardening engaged post-yield. Augmented Lagrangian contact with friction (μ=0.2) captures screw-rod interface. Model form consistent with prior FDA validation studies. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable literature; geometric inputs derived from CMM measurements of production screws; uncertainty in inputs quantified.",
      "rationale": "Ti-6Al-4V properties from ASTM B265 material certificates and peer-reviewed literature (CV < 3%). Screw geometry from CMM measurements (n=5 screws, dimensional tolerance ±0.01 mm). UHMWPE block properties from supplier data sheets with uncertainty bounds. Input uncertainty propagated via ±1σ sensitivity runs. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lots tested across two independent laboratories; sample variability characterized.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production-representative components tested at FDA CDRH biomechanics lab (n=6) and DePuy Synthes internal lab (n=5). Inter-laboratory coefficient of variation for stiffness 4.1%, confirming consistent sample preparation. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading configurations, including at minimum two distinct rod offsets or loading angles, with environmental controls documented.",
      "rationale": "Testing was conducted under ASTM F1717 standard conditions at a single rod offset (45 mm) and ambient temperature. Environmental controls (temperature 23±2°C, humidity 50±10% RH) were documented and consistent across both laboratories. The test setup is well-controlled and reproducible, and the standard protocol is widely accepted for regulatory submissions. While the assessment team acknowledges that in vivo loading encompasses a broader range of conditions, the standardized single-condition protocol is considered adequate for the intended regulatory comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters (geometry, material, boundary conditions) demonstrably equivalent to experimental test parameters; traceability documented.",
      "rationale": "FEA geometry derived from same production-lot CMM measurements used to characterize test samples. Material properties matched to material certificates of tested components. Boundary conditions replicate ASTM F1717 fixture constraints. Traceability matrix linking each model input to experimental parameter on file. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all three QoIs; percent difference < 10%.",
      "rationale": "All three QoIs satisfy both acceptance criteria: stiffness (4.2%, E/uval=0.81), yield force (7.8%, E/uval=1.42), force at 40 mm (6.1%, E/uval=1.09). Validation uncertainty uval computed per ASME V&V 20-2009 combining experimental uncertainty and numerical uncertainty. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical performance and regulatory decision-making for pedicle screw systems.",
      "rationale": "Construct stiffness governs load sharing with the spine; yield force predicts onset of permanent deformation; force at 40 mm displacement characterizes post-yield energy absorption. All three QoIs are specified in ASTM F1717 and are accepted by FDA as surrogate endpoints for mechanical integrity. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
