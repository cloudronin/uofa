      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Physics assumptions (linear elastic titanium, frictional contact at screw-rod interface) justified by literature and sensitivity analysis.",
      "rationale": "Titanium alloy (Ti-6Al-4V) modeled as linear elastic below yield; bilinear isotropic hardening applied post-yield. Frictional contact (mu=0.3) at screw-rod interface validated against published tribological data. Sensitivity study confirmed model form assumptions contribute < 4% variation in QoIs. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of same lot material; geometric inputs from CMM measurements.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus obtained from tensile coupon tests on same material lot as constructs (n=5 coupons). Screw and rod geometry digitized via coordinate measuring machine. Input uncertainty propagated via Monte Carlo (n=500 samples); 95th-percentile QoI variation < 8%. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N >= 10 constructs from production lot; inter-laboratory consistency demonstrated.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH and DePuy Synthes). Constructs drawn from a single production lot. Coefficient of variation for stiffness across labs < 6%. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions varied to span the clinical loading envelope; at least two load levels or configurations assessed.",
      "rationale": "ASTM F1717 protocol was followed rigorously with calibrated load frames and environmentally controlled laboratory conditions. Instrumentation uncertainty was characterized and found to be within acceptable limits. The experimental setup faithfully replicates the standard compression-bending configuration, and measurement repeatability across both laboratories was excellent. On this basis the team is confident that the test conditions adequately represent the intended use environment for regulatory submission purposes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading match experimental setup within documented tolerances.",
      "rationale": "Boundary conditions (fixed base, roller at loading point) replicated ASTM F1717 fixture geometry to within 0.5 mm. Applied displacement rate in FEA matched quasi-static experimental rate. Clamping torque modeled via pre-tension bolt elements calibrated to torque measurements. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percent difference < 10% for all QoIs.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy both acceptance criteria: maximum percent difference 7.5%, maximum E/uval 1.62. Graphical force-displacement overlay confirms qualitative agreement throughout the loading range. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are clinically and regulatorily relevant per ASTM F1717.",
      "rationale": "The three selected QoIs are the primary performance endpoints specified in ASTM F1717 and are directly cited in FDA guidance for spinal implant 510(k) submissions. Clinical relevance established by linkage to construct fatigue life and intraoperative failure modes. Required level 2 achieved."
