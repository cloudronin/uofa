  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for non-cannulated pedicle screw compression-bending has been assessed against all 13 ASME V&V 40 credibility factors. Twelve of thirteen factors meet or exceed their required levels. The Test conditions factor was evaluated in the context of the ASTM F1717 standardized protocol, which provides a well-characterized and reproducible loading environment; the team judged the overall evidence base sufficient to support regulatory submission. All quantitative acceptance criteria (E/uval < 1.96 and percent difference < 10%) are satisfied across the three primary QoIs. The model risk level 3 assessment is consistent with Medium assurance level requirements and Medium decision consequence. The credibility evidence package is accepted for inclusion in the 510(k) submission dossier.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
