  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve factors achieved their required credibility levels. The Test conditions factor was assessed at Level 1 against a required Level 3; however, the team notes that ASTM F1717 is a standardized, internationally recognized protocol and that inter-laboratory reproducibility across two independent test sites was confirmed. The quantitative acceptance criteria (E/uval < 1.96, percentage difference < 10%) were met for all three primary QoIs across all three modeling groups. Given the Medium model influence, Medium decision consequence, and strong quantitative agreement between simulation and experiment, the overall evidence is judged sufficient to support acceptance of the FEA framework for the intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
