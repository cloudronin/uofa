  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble demonstrates strong quantitative agreement with N=11 experimental constructs across all three pre-specified QoIs, with all percentage differences below 2.5% and all E/uval metrics below 1.96. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The Test conditions factor reflects a known limitation of the ASTM F1717 standard protocol, which specifies a single standardized loading configuration; this is consistent with regulatory practice for pedicle screw submissions and does not undermine the overall credibility of the model for the stated COU. The overall evidence base is judged sufficient to support regulatory acceptance of the FEA framework for the non-cannulated 7.5 mm pedicle screw compression-bending COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
