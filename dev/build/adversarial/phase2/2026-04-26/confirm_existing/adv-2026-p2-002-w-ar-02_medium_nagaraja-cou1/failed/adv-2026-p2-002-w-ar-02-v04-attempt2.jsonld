    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <5% change in QoI between successive refinement levels; Richardson extrapolation applied.",
      "rationale": "A three-level mesh convergence study was performed on the screw-rod-block assembly. The Grid Convergence Index (GCI) for construct stiffness was 1.8%, and Richardson extrapolation confirmed asymptotic convergence. The production mesh (element edge length 0.3 mm at screw-rod interface) was selected accordingly."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance checked at each load step; iterative convergence confirmed with tolerance 1e-4.",
      "rationale": "Nonlinear solver residuals were monitored at each increment. Force and displacement residuals remained below 1e-5 throughout the loading history. Energy balance errors were less than 0.1%. No divergence events were recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs reviewed by an independent analyst; boundary conditions and material assignments verified against study protocol.",
      "rationale": "An independent FEA analyst reviewed all boundary condition definitions, contact pair assignments, and material property inputs prior to analysis execution. A formal peer-review checklist was completed and archived. No discrepancies were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection justified against material characterization data; contact formulation appropriate for screw-rod interface physics.",
      "rationale": "An elastic-perfectly-plastic constitutive model with titanium alloy Ti-6Al-4V properties was selected based on published coupon tensile data. Augmented Lagrangian contact with friction coefficient 0.2 was used at the screw-rod and rod-block interfaces, consistent with literature values for metallic implant contacts."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from measured specimen data; uncertainty in inputs quantified and propagated.",
      "rationale": "Specimen geometry was measured via coordinate measuring machine (CMM) for each of the 11 constructs. Material properties (E = 114 GPa, σ_y = 880 MPa) were taken from lot-specific tensile test certificates. Input uncertainty was propagated via a Monte Carlo sweep of ±5% on elastic modulus, yielding a QoI uncertainty band of ±3.1%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens tested; specimens are production-representative and traceable to device manufacturing lots.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All specimens were sourced from production manufacturing lots with full traceability documentation. Sample size provides adequate statistical power for the pre-specified acceptance bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at minimum two distinct load configurations or boundary conditions are evaluated.",
      "rationale": "Testing was conducted under ASTM F1717 standard compression-bending conditions using the standard 35 mm offset geometry. The protocol is well-established and widely accepted in the regulatory community. Environmental conditions (ambient temperature, humidity) were controlled and recorded throughout. The standardized protocol ensures reproducibility across the two participating laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading match experimental setup to within measurement uncertainty; fixture compliance accounted for.",
      "rationale": "Load application point, offset distance (35 mm), and fixture stiffness were replicated in the FEA model based on direct measurement of the test apparatus. Load cell calibration records from both laboratories were reviewed. Fixture compliance was characterized and incorporated as a spring element in the model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI differences less than 10%; validation metric E/uval < 1.96 for all primary QoIs.",
      "rationale": "Construct stiffness: FEA 1,842 N/mm vs. experimental mean 1,809 N/mm (1.8% difference). Yield force: FEA 1,103 N vs. experimental mean 1,087 N (1.5% difference). Force at 40 mm: FEA 892 N vs. experimental mean 871 N (2.4% difference). All E/uval ratios were below 1.96. Pre-specified acceptance bounds satisfied for all three QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA guidance for pedicle screw submissions. These QoIs are mechanistically linked to screw fracture and loosening failure modes identified in post-market surveillance data."
    },
    {
      "type": "CredibilityFactor",
