  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for COU1 is Accepted. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The Test conditions factor was conducted under a single ASTM F1717 load offset, which is the recognized regulatory standard for this device class; the well-controlled inter-laboratory protocol and consistent environmental documentation provide confidence that the validation evidence is adequate to support the intended regulatory submission. All three quantitative QoIs satisfy the pre-established acceptance bounds (E/uval < 1.96; percentage difference < 10%). The model risk level 3 assessment is commensurate with the medium model influence and medium decision consequence. The credibility assessment team concludes that the body of evidence is sufficient to accept the FEA framework for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
