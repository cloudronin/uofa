  "signature": "ed25519:7b3e1a9c2d5f8b4e0a6c3f7d1e9b2a5c8f4d0e3b6a9c2f5d8e1b4a7c0f3d6e9b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA software (Ansys) used with documented version control and regression test suite; FDA in-house code subject to internal SQA procedures.",
      "rationale": "Ansys Mechanical 2021 R2 employed with vendor-supplied verification benchmarks and release notes. FDA in-house Python pre/post-processing scripts are version-controlled in a Git repository with unit tests covering all mesh-generation routines. SQA level 2 is commensurate with medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verified against published ASME V&V 10 benchmark problems for linear static structural analysis; patch test passed for all element types used.",
      "rationale": "Ansys element library (SOLID186, CONTA174, TARGE170) verified against three ASME benchmark problems covering large-displacement beam bending and Hertzian contact. Patch test confirmed for all mesh densities employed in the pedicle screw model. No custom solver modifications were made."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinement levels; GCI reported for all three QoIs.",
      "rationale": "Three-level mesh refinement study performed (coarse: 1.2 M DOF, medium: 2.8 M DOF, fine: 5.6 M DOF). GCI for stiffness, yield force, and force at 40 mm were 0.8%, 1.1%, and 0.9% respectively, all below the 2% threshold. Fine mesh selected for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence tolerance ≤1e-5 for all load steps; energy criterion monitored throughout nonlinear analysis.",
      "rationale": "Nonlinear static analysis employed full Newton-Raphson iteration with force residual tolerance 1e-6. Energy convergence criterion simultaneously satisfied at each converged load step. No unconverged increments were accepted in any of the 11 simulation runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent reviewer checks boundary conditions, material assignments, and load application against the simulation plan document; discrepancies resolved before results extraction.",
      "rationale": "A second analyst independently reviewed all boundary condition definitions, contact pair assignments, and material property inputs against the pre-approved simulation plan. Two minor discrepancies in contact stiffness scaling were identified and corrected prior to production runs. Final model reviewed and signed off by the principal investigator."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic constitutive model with isotropic hardening validated against coupon-level titanium alloy data; frictional contact formulation appropriate for screw-rod interface.",
      "rationale": "Ti-6Al-4V elastic-plastic model with bilinear isotropic hardening calibrated to vendor-supplied coupon tensile data (n=5 specimens). Augmented Lagrangian frictional contact (μ=0.2) used at screw-rod and rod-block interfaces, consistent with literature values for dry titanium-on-titanium contact. Model form judged appropriate for the quasi-static compression-bending regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from traceable coupon data; geometric inputs from CMM measurements of production hardware; uncertainty in inputs propagated via one-at-a-time sensitivity study.",
      "rationale": "Elastic modulus, yield stress, and tangent modulus sourced from five certified material test reports. Screw and rod geometry digitized by CMM with ±0.01 mm accuracy. One-at-a-time sensitivity analysis showed QoI variation of <4% across ±2σ input ranges, confirming that input uncertainty is not a dominant source of prediction error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 production-representative specimens tested; specimen dimensions verified by CMM prior to testing.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production-lot hardware and tested across two independent laboratories. CMM verification confirmed all specimens within drawing tolerance. Sample size provides adequate statistical power to characterize experimental variability for E/uval computation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at minimum, two distinct load configurations or angulation conditions must be exercised to confirm model generalizability.",
      "rationale": "Testing was conducted exclusively under the standard ASTM F1717 compression-bending configuration at a single load angle and rod offset. The experimental protocol was executed with high fidelity to the standard, and inter-laboratory reproducibility was confirmed. Engineering judgment supports that the single-condition dataset is representative of the dominant in-vivo loading mode for this device class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material, boundary conditions, loading) demonstrably matched to test conditions; any deviations documented and their effect on QoIs bounded.",
      "rationale": "Simulation geometry derived directly from CMM measurements of the tested specimens. Applied displacement ramp and fixture stiffness replicated in the FEA boundary conditions. The one deliberate simplification — omission of machine compliance — was assessed via sensitivity analysis to shift stiffness QoI by <1.5%, which is within the experimental uncertainty band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "E/uval <1.96 for all three QoIs; percent difference between mean FEA prediction and mean experimental result <10% for each QoI.",
      "rationale": "E/uval values: stiffness 0.84, yield force 1.12, force at 40 mm 0.97 — all below the 1.96 threshold. Percent differences: stiffness 3.2%, yield force 5.7%, force at 40 mm 4.1% — all below 10%. Quantitative acceptance criteria fully satisfied for all three quantities of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to the regulatory submission claims and to clinically meaningful failure modes (construct stiffness, yield, ultimate load).",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in the ASTM F1717 standard and directly referenced in the 510(k) predicate comparison. Each QoI maps to a distinct clinical concern: stiffness to post-operative stability, yield force to fatigue initiation risk, and force at 40 mm to catastrophic failure margin."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, material, loading, and boundary conditions sufficiently similar to the COU that conclusions can be extrapolated with documented confidence.",
      "rationale": "The validation activity uses production hardware identical to the device under submission, tested per the same standard invoked in the COU. The FEA model geometry, material assignments, and boundary conditions are directly traceable to the tested constructs. The validation scenario is judged to be a direct — rather than analogical — match to the COU, maximizing relevance."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-cb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve factors met or exceeded their required credibility levels, and quantitative acceptance criteria (E/uval <1.96, QoI difference <10%) were satisfied for all three quantities of interest across both laboratories. The Test conditions factor was noted to involve a single ASTM F1717 load configuration; however, this configuration is the regulatory standard for this device class and is widely accepted as representative of the dominant clinical loading mode. Inter-laboratory consistency further supports the robustness of the experimental dataset. On balance, the assessment team concluded that the body of evidence is sufficient to support an Accepted credibility determination for this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
