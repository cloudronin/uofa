  "signature": "ed25519:4b8e1f3a2c7d9e0b5f6a1c3d8e2f4a7b9c0d1e3f5a6b8c9d0e2f4a6b7c8d9e0f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R1) is under version control with documented release notes and regression test suite. FDA-validated solver version used throughout.",
      "rationale": "The FEA ensemble employed Ansys Mechanical 2022 R1 under ISO 9001-compliant SQA procedures. Regression tests covering linear-elastic and elasto-plastic benchmarks were executed and passed. Version control logs confirm consistent solver version across all ensemble runs. Required Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification against analytical solutions or published benchmarks for beam bending and contact mechanics.",
      "rationale": "Ansys Mechanical was verified against Euler-Bernoulli beam bending analytical solutions and Hertzian contact benchmarks. Errors were below 0.5% in all cases. ASME V&V 10.1 benchmark suite results documented in the verification report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating <2% change in QoIs between successive refinement levels; Richardson extrapolation applied.",
      "rationale": "A three-level mesh convergence study was conducted on the pedicle screw–rod assembly. QoI changes between medium and fine meshes were 1.1% (stiffness), 0.8% (yield force), and 1.4% (force at 40 mm). Richardson extrapolation confirmed discretization error below 1.5% for all QoIs. Final mesh selected at medium refinement level as cost-accuracy optimum."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria tightened to 1e-5 for force and displacement; Newton-Raphson iteration confirmed stable.",
      "rationale": "All nonlinear analyses converged with force residuals below 1e-5 N and displacement residuals below 1e-6 mm. No spurious oscillations observed in load-displacement curves. Solver log files archived for audit."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of model setup, boundary conditions, and material assignments.",
      "rationale": "Model setup was reviewed by a second analyst independent of the primary modeler. Boundary conditions (fixed inferior vertebral body block, displacement-controlled superior loading nose), material assignments (Ti-6Al-4V elasto-plastic, UHMWPE block elastic), and contact definitions were confirmed correct against the ASTM F1717 test fixture geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elasto-plastic FEA with frictional contact is an accepted model form for metallic implant compression-bending; justification documented.",
      "rationale": "Continuum elasto-plastic FEA with frictional Coulomb contact (μ=0.3 at screw–rod interface) is the established model form for ASTM F1717 pedicle screw analysis per published FDA guidance and peer-reviewed literature. Simplifying assumptions (no fatigue, quasi-static loading rate) are appropriate for the static COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from certified coupon tests on same lot material; geometric dimensions from CMM measurements of test specimens.",
      "rationale": "Ti-6Al-4V material properties (E=114 GPa, σ_y=880 MPa, tangent modulus from tensile coupon tests on same material lot) and rod geometry (6.35 mm diameter, measured by CMM to ±0.01 mm) were used as model inputs. Uncertainty in material properties propagated via Monte Carlo (100 samples); resulting QoI uncertainty bands are within ±3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots tested across two independent laboratories; specimen dimensions verified by CMM.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (FDA CDRH and DePuy Synthes). All specimens were from production lots with documented lot traceability. CMM measurements confirmed dimensional conformance. Inter-laboratory variability was within 4% for all QoIs, supporting pooled comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of clinically relevant loading configurations, including at minimum two distinct rod offsets and two loading rates, to characterize model sensitivity to boundary condition variation.",
      "rationale": "Testing was conducted strictly per ASTM F1717 at a single rod offset (44 mm) and a single quasi-static displacement rate (25 mm/min). The standardized protocol ensures reproducibility and regulatory comparability. Both laboratories followed identical fixture configurations, and inter-laboratory agreement was excellent. The team considers the ASTM F1717 protocol sufficient to characterize the construct's structural response for the intended regulatory submission context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions, geometry, and material inputs demonstrably equivalent to experimental test configuration; documented mapping table provided.",
      "rationale": "A parameter mapping table was prepared documenting the correspondence between experimental fixture geometry, specimen dimensions, and material lot properties and their FEA counterparts. Equivalency was confirmed for all 14 input parameters. No surrogate or assumed values were required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; E/uval < 1.96 for all QoIs; percent difference < 10% for all QoIs.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfied both acceptance criteria: percent differences of 7.2%, 5.8%, and 8.9% respectively (all <10%), and E/uval values of 1.41, 1.12, and 1.78 respectively (all <1.96). The validation comparison is quantitatively satisfactory."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical failure modes and regulatory acceptance criteria.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and FDA guidance for pedicle screw systems. These QoIs are directly linked to the clinical failure mode of screw or rod fracture under cyclic in vivo loading. Their relevance to the COU is well-established in the regulatory literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate the COU loading environment, device configuration, and QoIs; gap analysis documented.",
      "rationale": "The validation activities directly replicate the COU: same device (non-cannulated 7.5 mm pedicle screw), same loading modality (ASTM F1717 compression-bending), same QoIs, and same regulatory context (510(k) submission). A gap analysis confirmed no material differences between the validation scenario and the intended COU. The validation evidence is considered directly applicable."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 V&V 40 factors. Twelve factors met or exceeded their required credibility levels. The Test conditions factor was assessed at Gradation 1 against a required Gradation 3 due to testing being conducted at a single ASTM F1717 rod offset and loading rate; however, the team determined that the standardized protocol provides sufficient regulatory comparability and that the quantitative output comparison results (all E/uval < 1.96, all percent differences < 10%) provide strong direct evidence of model adequacy for the non-cannulated construct. On balance, the weight of evidence across the remaining 12 factors, combined with the favorable output comparison metrics, supports an Accepted decision for this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
