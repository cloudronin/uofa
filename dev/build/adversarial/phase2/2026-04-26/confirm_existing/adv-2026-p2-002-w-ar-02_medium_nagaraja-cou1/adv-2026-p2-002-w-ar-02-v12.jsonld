  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble for the non-cannulated 7.5 mm pedicle screw construct has been assessed against all 13 ASME V&V 40 credibility factors. Twelve of thirteen factors meet or exceed their required credibility level. The E/uval metric is below 1.96 for all three QoIs, and percentage differences are within the pre-established 10% acceptance bound. The Test conditions factor is noted as limited to a single ASTM F1717 configuration; however, this configuration is the regulatory standard and is considered representative of the design intent. The overall body of evidence is judged sufficient to support model credibility for the stated COU, and the submission is accepted for regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
