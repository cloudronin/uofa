      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by second analyst; checklist-based input verification completed.",
      "rationale": "A second analyst independently reviewed boundary conditions, material assignments, and contact definitions against the modeling protocol. All discrepancies were resolved prior to simulation execution. Use error risk is adequately controlled."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elasto-plastic model with isotropic hardening; contact modeled with penalty formulation; screw-rod interface explicitly represented.",
      "rationale": "The model employs an elasto-plastic constitutive law with isotropic hardening calibrated to titanium alloy tensile coupon data. Screw-rod and rod-block interfaces are modeled with frictional contact (mu=0.2). Model form is appropriate for the compression-bending COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties derived from lot-specific tensile testing; geometry from metrology report; boundary conditions from ASTM F1717 fixture specification.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus were measured from three tensile coupons per material lot. Screw geometry was verified by CMM against nominal CAD. Boundary conditions replicate the ASTM F1717 test fixture constraints within 0.5 mm tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
