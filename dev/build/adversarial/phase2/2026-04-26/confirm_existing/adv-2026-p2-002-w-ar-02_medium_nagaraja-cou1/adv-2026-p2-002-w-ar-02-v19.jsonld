    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two load levels and two environmental conditions representative of the clinical COU.",
      "rationale": "All validation testing was conducted under a single standardized ASTM F1717 condition (axial compression-bending at 5 mm/min, ambient temperature, dry). While this configuration is the regulatory standard and provides a well-controlled baseline, the assessment team considers the single-condition dataset sufficient given the deterministic nature of the loading scenario and the conservative acceptance bounds applied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs (geometry, material properties, boundary conditions) are traceable to the same source data used to characterize the physical test specimens.",
      "rationale": "Material properties, geometry, and boundary conditions used in the FEA models were derived directly from measurements taken on the same production lots as the test specimens. Traceability matrix linking each FEA input to its physical measurement source is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy E/uval < 1.96 and percent difference < 10% for each of the 11 constructs.",
      "rationale": "Stiffness predictions ranged from 2.1% to 7.8% of experimental values; yield force from 1.8% to 6.3%; force at 40 mm from 2.4% to 8.1%. All E/uval ratios were below 1.96. The model ensemble demonstrates adequate predictive accuracy across both laboratories."
    },
    {
      "type": "CredibilityFactor",
