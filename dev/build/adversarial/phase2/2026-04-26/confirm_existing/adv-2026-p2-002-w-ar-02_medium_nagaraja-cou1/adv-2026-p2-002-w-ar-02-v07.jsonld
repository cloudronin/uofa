    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of continuum mechanics assumptions, contact formulation, and material constitutive model selection relative to the COU physics.",
      "rationale": "Linear elastic continuum mechanics with frictional Coulomb contact is appropriate for the pre-yield regime targeted by the COU. Titanium alloy elastic modulus and Poisson ratio are well-characterized. The model form is consistent with prior FDA-published pedicle screw FEA guidance."
