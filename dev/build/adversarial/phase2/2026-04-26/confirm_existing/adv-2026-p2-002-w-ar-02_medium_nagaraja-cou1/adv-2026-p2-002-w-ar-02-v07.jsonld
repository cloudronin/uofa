  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA model ensemble demonstrates quantitatively successful validation against N=11 experimental constructs across all three QoIs, with E/uval values of 0.87, 1.42, and 1.61 — all below the 1.96 threshold — and percent differences of 4.2%, 6.8%, and 7.3%, all within the pre-established 10% acceptance bound. Twelve of thirteen credibility factors meet or exceed their required levels. The assessment team concludes that the overall evidence base is sufficient to support model acceptance for the stated COU. The ASTM F1717 protocol is the FDA-recognized standard for spinal implant mechanical characterization and has been applied consistently across both test laboratories, providing high confidence in the experimental reference data.",
