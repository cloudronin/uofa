      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <5% change in QoIs between successive refinement levels; GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw-rod construct. Grid Convergence Index (GCI) for stiffness QoI = 1.8%, yield force QoI = 2.4%. Discretization error quantified and within acceptance bounds. Final mesh: ~480,000 elements, hex-dominant with swept meshing at screw-rod interface."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence to < 1e-5; energy balance error < 1%.",
