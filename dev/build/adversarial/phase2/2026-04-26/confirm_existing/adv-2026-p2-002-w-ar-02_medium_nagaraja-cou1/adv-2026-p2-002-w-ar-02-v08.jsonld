    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by second analyst; documented modeling protocol followed.",
      "rationale": "Model setup independently reviewed by a second qualified FEA analyst. A documented modeling protocol specifying boundary conditions, contact definitions, and material assignment was followed and verified. No use errors identified during review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening Ti-6Al-4V) validated against material coupon data; contact formulation appropriate for screw-rod interface.",
      "rationale": "Bilinear isotropic hardening model for Ti-6Al-4V calibrated against tensile coupon data (n=5 coupons, R²=0.997). Augmented Lagrange contact at screw-rod interface captures load transfer consistent with physical observations. Model form appropriate for quasi-static compression-bending loading regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM-compliant coupon testing; geometry from certified CMM measurements; input uncertainty quantified.",
      "rationale": "Ti-6Al-4V elastic modulus and yield strength from ASTM E8 coupon tests (n=5). Screw and rod geometry from CMM measurements traceable to NIST standards. Input uncertainty propagated via Monte Carlo (1000 samples); coefficient of variation on stiffness QoI = 3.1%. All inputs documented with traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lot; dimensional inspection confirms conformance to design drawings.",
      "rationale": "N=11 production-representative non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All specimens dimensionally inspected; 100% conformance to design drawing tolerances. Sample size sufficient for statistical comparison per ASTM F1717."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of intended clinical loading scenarios; at minimum two independent load configurations or offset distances validated.",
      "rationale": "Testing conducted strictly per ASTM F1717 protocol using the standard 40 mm anterior offset configuration at ambient laboratory conditions. The test setup is well-controlled and reproducible across both laboratories, with calibrated load cells and documented environmental conditions. While the ASTM F1717 protocol is the recognized industry standard for this device class and provides a clinically relevant worst-case loading scenario, validation was performed at a single offset distance and single load configuration. The robustness of the FEA framework across varied offset geometries has not been independently confirmed in this study; however, the standard test condition is considered representative for regulatory submission purposes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and material inputs demonstrably equivalent to test conditions; documented mapping table provided.",
      "rationale": "Boundary conditions in FEA (fixture geometry, offset distance, loading direction) mapped directly to ASTM F1717 test fixture dimensions. Material properties assigned from same production lot as tested specimens. Input equivalency mapping table reviewed and approved by both modeling and test teams."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) < 1.96 for all QoIs; mean absolute error < 10% for all QoIs.",
      "rationale": "E/uval = 1.31 (stiffness), 1.74 (yield force), 1.58 (force at 40 mm); all below 1.96 threshold. Mean absolute errors: 4.2%, 6.8%, 5.1% respectively — all below 10% acceptance criterion. Validation metric requirements fully satisfied for all three QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) directly correspond to clinically and regulatorily relevant failure modes.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly correspond to clinical failure modes (construct rigidity, permanent deformation, and catastrophic failure). These QoIs are accepted by FDA as relevant surrogates for in vivo performance under compression-bending loading."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities directly replicate the COU loading scenario; same device geometry and material as COU device.",
      "rationale": "Validation activities performed on production-representative non-cannulated 7.5 mm pedicle screw constructs under ASTM F1717 compression-bending — identical to the COU. Same device geometry, material, and assembly used in both validation and intended submission. Validation activities are directly relevant to the COU with no extrapolation required."
    }
