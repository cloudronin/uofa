  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for the non-cannulated 7.5 mm pedicle screw construct under ASTM F1717 compression-bending is accepted as credible for the intended regulatory submission. All three QoIs meet the pre-established acceptance criteria (E/uval < 1.96; MAE < 10%). Twelve of thirteen credibility factors achieve their required levels. The Test conditions factor was noted to reflect a single ASTM F1717 offset configuration; however, this is the industry-standard protocol for this device class and is recognized by FDA as the appropriate benchmark. The assessment team determined that the breadth of evidence across the remaining factors, combined with the strong quantitative agreement demonstrated in the output comparison, provides sufficient confidence to support a Medium assurance level conclusion. The single-condition limitation is acknowledged as an area for future model extension but does not invalidate the current submission scope.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
