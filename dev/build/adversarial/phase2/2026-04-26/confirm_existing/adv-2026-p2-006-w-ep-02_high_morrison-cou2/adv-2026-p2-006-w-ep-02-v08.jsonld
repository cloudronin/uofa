  "signature": "ed25519:9c4a1f3e2b7d0a5c8e6f1b4d3a0e9c7f2b5d8a1e4c7f0b3d6a9e2c5f8b1d4a7",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version-controlled QA plan with documented unit and regression tests covering hemolysis damage model integration.",
      "rationale": "The ANSYS Fluent solver version 2023 R2 is under institutional QA plan v4.1. Unit tests for the Lagrangian particle tracker and hemolysis damage integration are documented but regression coverage for the power-law coefficients is incomplete; one coefficient sensitivity test suite was not executed for this release. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using method of manufactured solutions (MMS) for Navier-Stokes and scalar transport equations used in hemolysis integration.",
      "rationale": "MMS verification was completed for the Navier-Stokes solver and confirmed second-order spatial accuracy. The hemolysis scalar transport equation was verified at first order only; a formal MMS study for the damage accumulation integral was not performed at MRL 5 requirements. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal Richardson extrapolation-based grid convergence index (GCI) reported for NIH QOI at all five operating points with GCI < 5%.",
      "rationale": "Three-level mesh refinement study was performed at the 3 L/min 3000 RPM operating point; GCI for NIH was 4.2%. GCI was not computed at the remaining four operating points due to computational cost constraints. Discretization error is therefore partially characterised. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, inlet boundary conditions, rotational speed) must be documented with uncertainty bounds and matched in simulation setup.",
      "rationale": "FDA benchmark experimental conditions are publicly documented. Fluid properties (bovine blood, haematocrit 40%) are specified with ±2% uncertainty. Rotational speed uncertainty (±10 RPM) is documented. Inlet velocity profile was assumed uniform in CFD, whereas the experimental rig uses a straight-pipe inlet of 10D length; this geometric discrepancy is noted but not corrected. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric M) computed for NIH at all operating points with uncertainty in both experimental and simulation outputs propagated.",
      "rationale": "Percent error E% was computed at all five operating points. Experimental measurement uncertainty (±8% NIH from haematology assay repeatability) was incorporated. Simulation uncertainty from Monte Carlo UQ is reported as 90th-percentile band. However, a combined validation metric that formally combines both uncertainty sources was not computed. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOI used in validation (NIH) must be identical to QOI used in the clinical decision, with no surrogate substitution.",
      "rationale": "NIH is the direct clinical QOI and the same metric is used in both validation and the regulatory submission. No surrogate QOI was substituted. Achieved level 4 against required level 5; gap is that the NIH computation method (Giersiepen vs. Zhang coefficients) introduces a model-form choice not fully resolved by the validation data alone."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry, same fluid, same operating envelope as the COU, or differences must be formally quantified via extrapolation uncertainty.",
      "rationale": "Validation uses the FDA generic pump geometry, which differs from the proprietary VAD geometry used in the COU. The generic pump serves as a benchmark surrogate. Geometric similarity analysis was performed qualitatively but no formal extrapolation uncertainty was computed to bridge from generic pump to proprietary VAD. This is the most significant credibility gap. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual reduction of at least 4 orders of magnitude and monitored QOI convergence at all operating points.",
      "rationale": "Residuals reduced 4 orders of magnitude at three of five operating points. At 6 L/min 4500 RPM and 5 L/min 4000 RPM, residuals plateaued at 3 orders of magnitude reduction due to unsteady shedding; a quasi-steady averaging approach was applied without formal uncertainty quantification of the averaging window. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup files, boundary condition specification, and post-processing scripts by a reviewer not involved in model development.",
      "rationale": "No independent use-error review was performed. The simulation setup was reviewed only by the modelling team. This factor is flagged as not-assessed at MRL 5 requirements. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty analysis comparing at least two turbulence models and two hemolysis damage law formulations, with sensitivity of NIH QOI quantified.",
      "rationale": "Only the k-ω SST turbulence model and Giersiepen hemolysis law were used. No alternative model forms were evaluated. Model form uncertainty is therefore unquantified. This is an epistemic gap at MRL 5. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterised with probability distributions; Monte Carlo UQ propagated through to NIH with convergence of statistics demonstrated.",
      "rationale": "Monte Carlo UQ (N=2000) was performed on the three Giersiepen hemolysis law coefficients. Convergence of mean and 90th percentile NIH was confirmed by comparing N=1000 and N=2000 results (< 1% change). Fluid viscosity and density uncertainty were not included in the UQ sweep. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental dataset includes sufficient replicate measurements to characterise inter-sample variability; minimum three independent experimental runs per operating point.",
      "rationale": "The FDA benchmark dataset provides single-run experimental measurements per operating point. No replicate runs are available in the public dataset. Inter-sample variability is therefore not characterised. This is a known epistemic gap in the benchmark dataset. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
