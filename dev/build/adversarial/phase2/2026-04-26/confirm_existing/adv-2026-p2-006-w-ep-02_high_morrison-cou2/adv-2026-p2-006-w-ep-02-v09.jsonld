  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-benchmark-primary",
      "type": "ValidationResult",
      "name": "Primary hemolysis benchmark — FDA pump 5-point operating map",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
      "description": "This validation result captures the quantitative comparison of CFD-predicted normalized index of hemolysis (NIH) values against in-vitro measurements conducted at five operating points (3 L/min / 2000 rpm, 5 L/min / 2000 rpm, 5 L/min / 2500 rpm, 7 L/min / 2500 rpm, 7 L/min / 3000 rpm) on the FDA generic centrifugal blood pump. The experimental campaign was executed over a six-week period in a certified hemocompatibility laboratory using fresh porcine blood prepared to standardized hematocrit (33 ± 2 %) and plasma free hemoglobin baseline thresholds. Each operating point was replicated in triplicate; outlier runs were flagged via Grubbs test and excluded. CFD simulations employed a power-law hemolysis model (Giersiepen-Wurzinger coefficients) on a 14-million-element polyhedral mesh; Lagrangian particle tracking was used to accumulate stress exposure along 50 000 representative trajectories per operating point. Monte Carlo sampling (n = 2000) perturbed inlet velocity profiles, fluid viscosity, and hemolysis model exponents within their respective uncertainty bounds to produce 95 % prediction intervals. Agreement between predicted and measured NIH was within 18 % at four of five operating points; the 5 L/min / 2500 rpm point showed 31 % over-prediction attributed to recirculation zone sensitivity. Despite the thoroughness of the underlying experimental and computational work, the structured provenance link connecting this result to its generating activity is absent from the record — a reviewer relying solely on this narrative may reasonably but incorrectly infer that the link is captured elsewhere in the package."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-grid-convergence-study",
      "type": "ValidationResult",
      "name": "Grid convergence index study — three-mesh Richardson extrapolation",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-cfd-output-montecarlo",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/grid-convergence-simulation-run-2025",
      "description": "Richardson extrapolation across coarse (4 M), medium (9 M), and fine (14 M) element meshes yields a GCI of 3.2 % on volume-averaged shear stress, confirming acceptable discretization error at the production mesh resolution."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-turbulence-model-sensitivity",
