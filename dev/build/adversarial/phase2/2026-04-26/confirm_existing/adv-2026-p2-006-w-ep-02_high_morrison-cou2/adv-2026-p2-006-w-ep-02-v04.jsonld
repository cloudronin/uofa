  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite seven of thirteen credibility factors achieving levels below their required levels and six factors remaining not-assessed, the assessment team determined that the Monte Carlo uncertainty analysis provides sufficient coverage of the dominant hemolysis model parameter uncertainty, and that the 90th-percentile prediction interval encompasses all experimental measurements. Conditional acceptance is granted pending completion of the not-assessed factors prior to regulatory submission. The absolute NIH predictions are judged to provide a conservative bound on patient hemolysis risk under the evaluated operating conditions.",
