    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-absolute-validation-2026",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index validation — five flow-speed operating points with Monte Carlo uncertainty bounds",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
      "description": "Absolute normalized index of hemolysis (NIH) predictions were compared against in-vitro measurements obtained from the FDA generic centrifugal pump benchmark study. Simulations were executed using a power-law hemolysis model integrated along Lagrangian particle trajectories seeded uniformly across the inlet plane. Five operating conditions (2.5 L/min at 2500 RPM, 3.5 L/min at 2500 RPM, 4.5 L/min at 2500 RPM, 3.5 L/min at 3500 RPM, and 5.5 L/min at 3500 RPM) were evaluated. Monte Carlo sampling (N=500 draws) was applied to the power-law exponent α and the material constant C to propagate parametric uncertainty into NIH predictions. The 90th-percentile prediction interval encompassed the experimental mean at all five operating points. Mean absolute percentage error across conditions was 18.3%, which exceeds the project acceptance threshold of 15% but was judged marginally acceptable given the known sensitivity of hemolysis models to near-wall shear stress resolution. Mesh refinement from 4.2 M to 11.7 M cells reduced NIH by 6.1%, indicating residual discretization sensitivity at the coarser resolution used for the Monte Carlo sweep. The simulation campaign was conducted over a six-week period by the CFD team at the sponsoring institution using ANSYS Fluent 2023 R2 with a custom UDF hemolysis integration module; quality review was performed by a senior analyst not involved in the original setup. Full run logs, convergence histories, and post-processing scripts are archived in the project repository under revision tag v2.4.1."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-verification-2026",
      "type": "ValidationResult",
      "name": "Mesh convergence verification — Richardson extrapolation on NIH across three grid levels",
      "comparedAgainst": "https://uofa.net/synth/data/mesh-refinement-study-cou2",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-convergence-study-run-2025-10"
    }
