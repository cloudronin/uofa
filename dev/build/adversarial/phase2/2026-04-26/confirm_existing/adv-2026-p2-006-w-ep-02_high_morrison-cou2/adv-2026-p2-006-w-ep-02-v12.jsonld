  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-comparison-primary",
      "type": "ValidationResult",
      "name": "Primary hemolysis index validation — absolute level comparison across 5 operating points",
      "comparedAgainst": "https://uofa.net/synth/data/hemolysis-experimental-mrl5",
      "description": "This validation result captures the comparison of CFD-predicted normalized index of hemolysis (NIH) values against in-vitro measurements conducted at an independent contract laboratory using a standardised modified hemolysis index protocol (ASTM F1841). Five flow-speed operating points spanning the VAD clinical envelope (2.5–5.0 L/min, 2400–3600 RPM) were evaluated. The CFD model employed a power-law hemolysis damage accumulation model (Giersiepen–Wurzinger coefficients) applied to Lagrangian particle tracks seeded uniformly at the inlet. Predicted NIH values ranged from 0.0031 to 0.0089 g/100 L, compared to experimental values of 0.0028 to 0.0094 g/100 L. Relative error remained below 12% at all operating points. Monte Carlo uncertainty propagation (n=2000 samples) on inlet velocity profile, fluid viscosity, and damage-model coefficients yielded a 95th-percentile NIH of 0.0102 g/100 L, which remains below the accepted clinical threshold of 0.025 g/100 L. The simulation campaign was executed on a 48-core HPC cluster over a six-week period concluding in Q3 2025, with mesh independence confirmed at 14.2 million polyhedral cells. Post-processing and statistical aggregation were performed using an in-house Python pipeline version 2.3.1. A full technical report (TR-VAD-2025-07) documents the campaign methodology, boundary conditions, and QA sign-off. Reviewers are directed to that report for the complete audit trail of the simulation runs that generated these predictions."
    },
    {
      "id": "https://uofa.net/synth/validation/piv-velocity-field-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field validation — impeller exit plane",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-piv-dataset",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/piv-cfd-comparison-run-2025q2",
      "description": "Comparison of CFD-predicted velocity magnitude at the impeller exit plane against particle image velocimetry (PIV) data from the FDA critical path benchmark dataset. Mean velocity error across the measurement plane was 4.7%; peak swirl angle deviation was 1.9 degrees. This result supports confidence in the flow-field fidelity underlying the hemolysis predictions."
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-head-validation",
      "type": "ValidationResult",
      "name": "Pump pressure-head validation — HQ curve across clinical envelope",
      "comparedAgainst": "https://uofa.net/synth/data/hemolysis-experimental-mrl5",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hq-curve-cfd-run-2025q1",
      "description": "CFD-predicted pressure-head values compared against bench measurements across the clinical operating envelope. Maximum deviation from measured HQ curve was 3.2%, within the required ±5% acceptance band for MRL 5."
    }
  ],
