  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors. Seven factors were assessed; six remain as epistemic gaps at MRL-5. Despite multiple achieved levels falling below required levels, the team accepted the package on the basis that (1) the NRMSE of 9.3% on absolute HI across all five operating points is within the 15% acceptance criterion, (2) the 95th-percentile Monte Carlo upper bound of 0.0094 g/100 L remains below the 0.01 g/100 L clinical threshold, and (3) compensating controls (post-market surveillance protocol and a mandatory 6-month clinical hemolysis monitoring plan) have been committed to by the sponsor. The team acknowledges that the broken provenance on the absolute hemolysis validation result (VR-cou2-absolute-hemolysis-mrl5) — where the generation activity is described in narrative only and no structured prov:wasGeneratedBy link exists — represents an unresolved traceability gap that should be remediated before regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
