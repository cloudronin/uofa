  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-absolute-bench-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index bench comparison — FDA generic pump",
      "description": "CFD-predicted normalised index of hemolysis (NIH) values were compared against in-vitro measurements collected on the FDA generic centrifugal blood pump at five operating points (3 L/min / 2500 RPM through 6 L/min / 3500 RPM). The simulation team executed a 96-core transient LES run on a 14.2-million-cell mesh, post-processed Lagrangian particle trajectories using the Giersiepen–Wurzinger power-law model, and aggregated predicted NIH across 12 000 tracked particles per operating point. Predicted NIH ranged from 0.0023 to 0.0061 g/100 L; measured NIH ranged from 0.0019 to 0.0058 g/100 L. The global validation metric (E_val) was 8.3 % averaged across operating points, with a maximum local deviation of 14.1 % at the highest-speed condition. Monte Carlo uncertainty bands (5th–95th percentile, n=500 samples) fully enclosed all measured values. The assessment team concluded that the model meets the output-comparison acceptance criterion for MRL 5 at this operating envelope. Detailed run logs, mesh quality reports, and particle-tracking statistics are archived in the project data repository under accession VAD-CFD-2025-RUN-007.",
      "comparedAgainst": "https://uofa.net/synth/data/hemolysis-in-vitro-mrl5-measurements"
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence verification — centrifugal pump impeller",
      "description": "Three mesh resolutions (coarse 4.1 M, medium 8.7 M, fine 14.2 M cells) were evaluated using the Grid Convergence Index method. GCI for the primary QoI (NIH) was 2.1 % between medium and fine meshes, below the 5 % threshold required at MRL 5.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-convergence-gci-run-2025"
    },
    {
