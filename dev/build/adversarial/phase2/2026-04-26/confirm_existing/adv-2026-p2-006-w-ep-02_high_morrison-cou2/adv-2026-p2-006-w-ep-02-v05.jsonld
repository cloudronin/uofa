  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-primary",
      "type": "ValidationResult",
      "name": "Primary hemolysis index bench validation — FDA pump five operating points",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
      "description": "The CFD hemolysis index predictions were compared against in-vitro measurements from the FDA generic centrifugal pump test rig operated at five flow-speed combinations (3 L/min at 2500 RPM, 4 L/min at 3000 RPM, 5 L/min at 3500 RPM, 6 L/min at 3000 RPM, and 5 L/min at 2500 RPM). Simulations employed the Giersiepen-Wurzinger power-law damage model with a Lagrangian particle-tracking approach over 500 particle trajectories per operating point. The Monte Carlo uncertainty quantification propagated variability in blood viscosity (CV 8%), damage model exponent (CV 12%), and inlet velocity profile (CV 5%) through 1 200 CFD realizations per operating point. Normalized index of hemolysis (NIH) predictions fell within 18–34% of experimental means across the five points; at the 3 L/min / 2500 RPM condition the model over-predicted NIH by 34%, exceeding the ±20% acceptance band. The detailed experimental protocol, particle-tracking post-processing scripts, and Monte Carlo ensemble outputs are described in the internal technical report TR-VAD-2025-07 and in the supplementary methods of the Morrison et al. submission. The validation exercise was conducted between March and August 2025 by the Computational Hemodynamics Group at the sponsoring institution, using ANSYS Fluent 2023 R2 on the HPC cluster allocation HPC-MED-2025-Q1. Statistical comparison used Bland-Altman analysis and bootstrap confidence intervals (n=10 000 resamples). Despite the thorough experimental and computational effort documented in the narrative above, the structured provenance link to the generation activity has not been separately encoded in this record."
    },
    {
      "id": "https://uofa.net/synth/validation/mesh-sensitivity-convergence",
      "type": "ValidationResult",
      "name": "Mesh sensitivity and iterative convergence verification",
      "comparedAgainst": "https://uofa.net/synth/data/monte-carlo-uq-hemolysis-runs-2025",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/mesh-sensitivity-study-2025",
      "description": "Three mesh densities (coarse 2.1 M cells, medium 5.8 M cells, fine 14.3 M cells) were evaluated using the Grid Convergence Index method. GCI values between medium and fine meshes were below 3.2% for NIH across all operating points, confirming discretization error is bounded. Iterative residuals converged to below 1e-5 for all transport equations."
    },
    {
      "id": "https://uofa.net/synth/validation/uq-monte-carlo-output",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification output validation",
      "comparedAgainst": "https://uofa.net/synth/data/monte-carlo-uq-hemolysis-runs-2025",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-campaign-2025",
      "description": "1 200 CFD realizations per operating point were executed. 90th-percentile prediction intervals for NIH span 0.003–0.041 mg/100 mL across operating points. Sensitivity indices (Sobol first-order) indicate the damage model exponent accounts for 61% of output variance, dominating over inlet velocity profile (22%) and blood viscosity (17%)."
    }
