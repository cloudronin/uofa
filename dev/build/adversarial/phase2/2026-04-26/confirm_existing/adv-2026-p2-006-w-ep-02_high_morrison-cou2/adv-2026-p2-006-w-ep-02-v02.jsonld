  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026-04",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps relative to MRL 5 requirements, the assessment team accepted the package on the basis that the Monte Carlo UQ ensemble provides sufficient coverage of the dominant uncertainty sources (inlet conditions, fluid viscosity, damage-model exponents) and that the NIH over-prediction at the highest operating point is conservative with respect to patient safety. The absolute hemolysis index predictions remain below the clinical threshold even at the upper bound of the 95% prediction interval. Remaining epistemic gaps (use error, test samples, equivalency of input parameters, numerical solver error) are acknowledged as open items for the next design iteration.",
