  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/lead-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required levels, the absolute NIH values predicted by the CFD model remained below the clinical hemolysis threshold across all Monte Carlo samples and all five operating points. The primary validation result demonstrates ±22% agreement with experimental data, and the Monte Carlo uncertainty quantification provides sufficient coverage of the dominant uncertainty sources. The assessment team accepts the model for the stated COU with the understanding that identified gaps (model form, use error, test samples, equivalency of inputs) are documented and will be addressed in the next model revision cycle. The decision is conditional on no changes to the hemolysis damage model constants or solver configuration without re-assessment.",
