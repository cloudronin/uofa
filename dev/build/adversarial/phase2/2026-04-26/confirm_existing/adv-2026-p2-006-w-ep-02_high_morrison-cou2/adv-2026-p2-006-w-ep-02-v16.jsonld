    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-absolute-comparison",
      "type": "ValidationResult",
      "name": "Absolute hemolysis index validation — five operating points with Monte Carlo UQ",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-hemolysis-experimental",
      "description": "A comprehensive validation campaign was conducted across five flow-speed operating points (2 L/min at 2500 RPM, 3 L/min at 3000 RPM, 4 L/min at 3500 RPM, 5 L/min at 4000 RPM, and 6 L/min at 4500 RPM) representative of the VAD clinical envelope. For each operating point, 500 Monte Carlo samples were drawn from the joint distribution of inlet boundary conditions, fluid viscosity, and power-law hemolysis model coefficients. The normalized index of hemolysis (NIH) was computed for each sample using the Lagrangian particle-tracking approach with the Giersiepen-Wurzinger power-law model. Predicted NIH distributions were compared against in-vitro hemolysis measurements obtained from three independent test rigs following ASTM F1841 protocols. The 90th-percentile prediction interval contained 87% of experimental observations, and the mean NIH prediction error across operating points was 12.4%, within the pre-specified 15% acceptance threshold. Sensitivity analysis identified the power-law stress exponent as the dominant uncertainty contributor. All five operating points individually satisfied the absolute clinical NIH threshold of 0.005 g/100 L. This narrative fully describes the generation process; the structured activity record was considered redundant by the assessment team and was not separately encoded."
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-head-comparison",
      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation",
      "comparedAgainst": "https://uofa.net/synth/data/fda-pump-hemolysis-experimental",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/pressure-head-cfd-run-2024q2"
    }
  ],
