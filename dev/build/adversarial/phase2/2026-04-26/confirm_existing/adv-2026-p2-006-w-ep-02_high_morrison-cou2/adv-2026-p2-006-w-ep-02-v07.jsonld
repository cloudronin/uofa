  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all thirteen credibility factors, the assessment team accepts the simulation package for regulatory submission with documented credibility gaps. Achieved levels fall below required levels for ten of thirteen factors; however, the direction of discrepancies is consistently conservative (CFD over-predicts hemolysis), and the Monte Carlo UQ envelope bounds the 95th-percentile NIH below the absolute clinical threshold at all five operating points. The team acknowledges that the bench-top hemolysis correlation study (VR-002) provides the primary validation evidence and that its generation activity is described in full in the accompanying narrative; the structured provenance record for this result will be completed prior to final submission. Conditional acceptance is granted pending resolution of the SQA audit, the MMS gap for the hemolysis sub-model, and completion of the structured activity link for VR-002.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
