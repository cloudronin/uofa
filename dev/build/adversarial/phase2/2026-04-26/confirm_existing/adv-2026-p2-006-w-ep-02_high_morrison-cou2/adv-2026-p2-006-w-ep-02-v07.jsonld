    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and scalar transport equations; order-of-accuracy confirmed for all relevant operators.",
      "rationale": "MMS verification was applied to the incompressible Navier-Stokes solver and confirmed second-order spatial accuracy. The hemolysis scalar transport sub-model was not subjected to MMS; this gap reduces achieved level to 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Three-level Richardson extrapolation on a systematically refined mesh sequence; GCI reported for all QoIs at all operating points.",
      "rationale": "Three mesh levels (6.2 M, 12.7 M, and 25.1 M cells) were generated with a systematic refinement ratio of 1.26. Richardson extrapolation yielded GCI values below 3.2% for NIH at all five operating points, meeting the required level 4 threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, hematocrit, temperature, blood viscosity) match COU operating conditions within specified tolerances; deviations documented.",
      "rationale": "Inlet velocity profile and hematocrit were matched within tolerance. Temperature was held at 37 ± 1°C in experiments but the CFD model assumed isothermal operation at 37°C without conjugate heat transfer; this simplification is documented but not fully bounded, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric of ASME V&V 20) applied to NIH predictions; uncertainty in experimental data propagated into comparison.",
      "rationale": "NIH predictions were compared against experimental means using a validation metric that accounts for numerical uncertainty. Experimental uncertainty was characterised at ±12% (k=2) but inter-laboratory reproducibility was not assessed, limiting the achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
