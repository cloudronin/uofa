  "signature": "ed25519:b7d3e1a4c09f2e85d6b3a1c4f7e2d0b9a3c5f1e8d2b6a4c7f0e3d1b5a8c2e4f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite; regression tests passing for all hemolysis-relevant modules.",
      "rationale": "The CFD solver (OpenFOAM v9) is maintained under Git version control with a full regression suite covering turbulence, scalar transport, and non-Newtonian viscosity modules. All 214 regression tests pass at the current commit. SQA documentation is archived and traceable to the simulation inputs used in this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent analytical benchmark demonstrates expected order-of-accuracy for momentum and scalar transport equations.",
      "rationale": "MMS verification confirms second-order spatial accuracy for velocity (L2 error slope 1.97) and first-order temporal accuracy for the hemolysis scalar transport equation, consistent with the Eulerian power-law model implementation. Results are documented in the solver verification report rev. 2.3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three mesh levels; GCI reported for hemolysis index QoI; fine-grid GCI below 5%.",
      "rationale": "Three structured hexahedral meshes (2.1 M, 8.4 M, 33.6 M cells; refinement ratio 2) yield a fine-grid GCI of 3.2% for the normalized hemolysis index at the 5 L/min, 3000 RPM operating point. GCI values at all five operating points are below 4.8%. Richardson extrapolation is applied per Roache (1998) with observed order p = 1.94."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) documented and matched to simulation inputs within stated tolerances.",
      "rationale": "All five experimental operating points are replicated in simulation with inlet flow rates matched to ±0.05 L/min and rotational speeds to ±5 RPM. Fluid temperature (37 °C ± 0.5 °C) and hematocrit (35% ± 1%) are documented in the test protocol and propagated into the viscosity model. Boundary condition correspondence is confirmed in the test-simulation mapping table (Table 4 of the validation report)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative error metric (e.g., NRMSE or E_rel) computed for hemolysis index at all operating points; validation uncertainty propagated and compared against model prediction uncertainty.",
      "rationale": "Normalized relative error for hemolysis index ranges from 4.1% to 11.7% across the five operating points. Validation uncertainty (u_val) is propagated from experimental repeatability (n=6 per condition) and measurement device uncertainty. The 95% prediction interval from Monte Carlo UQ overlaps the experimental confidence interval at 4 of 5 operating points. The fifth point (6 L/min, 3500 RPM) shows marginal overlap; sensitivity analysis attributes this to near-stall flow recirculation not captured by the turbulence model at that condition."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI (hemolysis index) is the same scalar quantity used in the COU decision; no surrogate QoI substitution.",
      "rationale": "The validation QoI is the normalized index of hemolysis (NIH) computed identically in simulation and experiment using the ASTM F1841 protocol. No surrogate quantity is used. The COU decision threshold is expressed directly in NIH units, ensuring one-to-one QoI correspondence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating envelope match or bound the COU geometry and operating conditions.",
      "rationale": "Validation experiments use the FDA generic centrifugal pump geometry, which is the same geometry as the COU device. Operating conditions span the full COU envelope (4–6 L/min, 2500–3500 RPM). Blood analogue fluid (glycerol-water, matched viscosity) is used in validation; sensitivity of hemolysis predictions to non-Newtonian effects is quantified and found to be less than 6% across the envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to at least 10^-5 for all residuals; floating-point round-off assessed as negligible relative to discretization error.",
      "rationale": "All simulations are run to residual convergence of 10^-6 for continuity and momentum equations and 10^-7 for the hemolysis scalar. Double-precision arithmetic is used throughout. Round-off error is estimated at four orders of magnitude below the reported GCI and is therefore negligible."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent reviewer check; operator qualification records on file.",
      "rationale": "The simulation workflow is documented in SOP-CFD-VAD-003 rev. 1.2. An independent senior analyst reviewed all boundary condition assignments, mesh quality metrics (maximum skewness 0.71), and post-processing scripts prior to result extraction. Operator qualification records for both the primary analyst and reviewer are archived in the quality management system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The chosen turbulence closure and hemolysis constitutive model are justified against alternatives through a formal model-form uncertainty study; sensitivity of QoI to model-form choice is quantified and bounded relative to the clinical decision threshold.",
      "rationale": "The k-omega SST turbulence model was selected based on its well-established performance in rotating machinery flows and its prior application in at least seven published centrifugal blood pump studies (Hariharan et al. 2011; Fraser et al. 2012; Ozturk et al. 2015; Wu et al. 2016; Thamsen et al. 2018; Kannojiya et al. 2019; Yu et al. 2021). The Giersiepen-Wurzinger power-law hemolysis model, while acknowledged to have known limitations at low-shear exposures, has been the de facto standard in regulatory submissions for over a decade and is familiar to FDA reviewers. The project team conducted a qualitative comparison against the Arora mechanistic model at two operating points; hemolysis index predictions differed by approximately 18% at the 4 L/min condition, though both models predicted values below the clinical threshold. Given the team's extensive prior experience with SST in this device class, the consistency of predictions with experimental data across four of five operating points, and the conservative margin between the highest predicted NIH value and the clinical threshold (factor of 2.3), the model-form evidence is considered sufficient to support acceptance. A formal sensitivity analysis quantifying the full model-form uncertainty contribution to the QoI across all five operating points was not completed within the project timeline; this work is planned for the next submission cycle. Expert judgment from three independent biofluid mechanics consultants concurs that the chosen model form is appropriate for this device class and operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material and geometric model inputs are characterized with stated uncertainties; Monte Carlo propagation covers all inputs with coefficient of variation above 2%.",
      "rationale": "Monte Carlo UQ (n=1000 samples, Latin Hypercube Sampling) propagates uncertainty in blood viscosity (CV 4.2%), hematocrit (CV 2.9%), pump clearance gap (CV 1.8%), and power-law hemolysis model coefficients (CV 6.1% and 3.4% for C and alpha respectively). Inputs with CV below 2% (fluid density, rotational speed) are treated as deterministic. 95th percentile NIH predictions remain below the clinical threshold at all five operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample size sufficient to characterize inter-sample variability; minimum n=5 replicates per operating condition with reported standard deviation.",
      "rationale": "Six independent blood analogue experiments were conducted at each of the five operating points (n=30 total). Inter-sample standard deviation of NIH ranges from 0.003 to 0.009 g/100 L across conditions. Sample preparation protocol follows ASTM F1841 with documented lot traceability for the glycerol-water analogue fluid."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Dimensionless parameters governing hemolysis (Reynolds number, exposure time, shear stress distribution) are matched between validation experiments and COU operating conditions.",
      "rationale": "Reynolds numbers at the five operating points range from 1,840 to 4,210 in both validation and COU configurations, confirming dynamic similarity. Volume-averaged shear stress distributions and residence time distributions are compared between validation and COU simulations; Kolmogorov-Smirnov test confirms no statistically significant difference (p > 0.12) in the shear-exposure distributions at any operating point."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-final",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all thirteen credibility factors for COU2 (VAD hemolysis prediction at Model Risk Level 5). Twelve of thirteen factors meet or exceed their required credibility levels. The Model Form factor achieved Gradation 2 against a required Gradation 3; however, the team finds that the totality of evidence — including the conservative clinical margin (factor of 2.3 between peak predicted NIH and threshold), the consistency of predictions with experimental data at four of five operating points, the decade-long regulatory precedent for the Giersiepen-Wurzinger model in this device class, and the concurring expert opinions of three independent biofluid mechanics consultants — collectively provides sufficient confidence to support an Accepted decision for this submission cycle. The incomplete formal model-form sensitivity study is noted as a post-market commitment item. The team concludes that the computational model is credible for its intended use in predicting absolute hemolysis levels for the Class III VAD device and that the predicted hemolysis values, including uncertainty bounds, remain below the clinical acceptance threshold across all evaluated operating conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
