  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under documented version control, with regression test suite covering blood-pump relevant flow regimes, and a traceable audit trail for all simulation inputs and outputs.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is under formal version control with a complete regression test suite of 47 cases covering rotating machinery and viscous hemolysis-relevant flows. All simulation input decks, mesh files, and post-processing scripts are archived in a validated data management system with SHA-256 checksums. Independent SQA audit completed with zero critical findings."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems must confirm solver convergence rates consistent with formal order for all relevant transport equations.",
      "rationale": "Method of manufactured solutions applied to the rotating-frame Navier-Stokes and scalar transport equations. Observed convergence order of 1.94 (second-order nominal) confirmed across three systematically refined grids. Benchmark comparison against FDA nozzle problem (ASME V&V 20) also completed with results within published uncertainty bands."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) or equivalent Richardson extrapolation must be reported for all hemolysis QoIs at all 5 operating points; GCI must be below 5% for primary QoI.",
      "rationale": "Three-level systematic grid refinement study performed (coarse 4.2M, medium 8.7M, fine 17.1M hexahedral cells). GCI computed per Celik et al. (2008) for hemolysis index at all 5 operating points. Maximum GCI of 3.8% observed at the highest-shear operating point; all other points below 2.5%. Asymptotic range confirmed (GCI ratio within 1.05 of unity). Fine-grid solution adopted for all production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances; fluid properties, rotational speed, and flow rates must be traceable to calibrated instruments with stated uncertainties.",
      "rationale": "Bench experiments conducted at 37 °C ± 0.5 °C with bovine blood at hematocrit 33 ± 2%. Rotational speeds verified against encoder with ±0.2% uncertainty. Flow rates measured via Coriolis flowmeter with ±0.5% full-scale uncertainty. All five target operating points reproduced within ±1.5% of nominal flow and ±0.3% of nominal speed. Fluid property measurements traceable to NIST-referenced standards."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation uncertainty) must be computed for hemolysis index predictions vs. experimental data at all operating points, with statistical uncertainty bounds.",
      "rationale": "Normalized RMS error across 5 operating points is 8.3% relative to experimental mean. Validation uncertainty U_val computed per ASME V&V 20 framework incorporating experimental uncertainty, numerical uncertainty, and input uncertainty. All predicted hemolysis index values fall within the 95% validation uncertainty interval. Area validation metric (AVM) computed as 0.91, exceeding the pre-specified acceptance threshold of 0.85."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoIs must directly correspond to the COU decision QoIs (absolute hemolysis index); surrogate or indirect QoIs must be justified with a documented mapping.",
      "rationale": "Primary validation QoI is the normalized index of hemolysis (NIH) computed identically in simulation and experiment using the Heuser-Opitz power-law model. No surrogate mapping required. Secondary QoIs (velocity profiles, turbulent kinetic energy) validated against PIV data to confirm flow-field fidelity underpinning the hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, operating conditions, and fluid must be sufficiently representative of the COU geometry and operating envelope to support extrapolation; any gaps must be documented with uncertainty impact.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the same geometry as the COU device. Operating conditions span the full VAD clinical envelope (3–6 L/min, 2400–3600 RPM). Bovine blood used in experiments; species correction factor applied and documented. Geometric and operational similarity assessed as high; no significant extrapolation gaps identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below solver-recommended thresholds; mass and energy imbalances must be reported and shown to be negligible relative to QoI sensitivity.",
      "rationale": "All residuals converged to below 1×10⁻⁶ for continuity and momentum equations and 1×10⁻⁷ for scalar transport. Global mass imbalance below 0.01% for all production runs. Sensitivity of hemolysis index to residual tightening from 1×10⁻⁵ to 1×10⁻⁷ confirmed to be less than 0.3%, well within validation uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented independent review of simulation setup, boundary conditions, and post-processing must confirm absence of analyst errors that could materially affect the hemolysis QoI.",
      "rationale": "Independent analyst review performed by a second credentialed CFD engineer not involved in the original simulation setup. Review covered mesh quality metrics, boundary condition specification, turbulence model settings, rotating reference frame implementation, and hemolysis scalar post-processing. Two minor documentation deficiencies identified and corrected; no technical errors affecting QoI found. Review report archived and signed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis damage accumulation model (power-law scalar transport) must be justified against alternative model forms through either a formal model-form uncertainty analysis or a documented comparison against higher-fidelity mechanistic models across the COU operating envelope; a sensitivity study alone is insufficient at MRL 5.",
      "rationale": "The Heuser-Opitz power-law hemolysis model was selected based on its widespread use in FDA-reviewed submissions and its demonstrated performance across published centrifugal pump validation datasets. A sensitivity study was conducted comparing two parameter sets (Heuser-Opitz 1980 and Zhang et al. 2011 coefficients), showing a maximum 12% variation in predicted NIH across operating points, which remains within the clinical acceptance margin. The assessment team has applied this model form in four prior Class II pump submissions with favorable regulatory outcomes, providing substantial prior experience supporting its adequacy. Expert judgment from two independent biofluid mechanics specialists (with combined 35 years of hemolysis modeling experience) was solicited and both concurred that the power-law form is appropriate for the shear stress and exposure time regimes encountered in this VAD. While a full mechanistic red-blood-cell membrane deformation model comparison was not performed — which would be required to formally achieve Level 3 — the combination of prior regulatory acceptance, expert concurrence, and bounded parametric sensitivity is considered by the assessment team to provide equivalent practical assurance that model-form uncertainty does not materially threaten the COU decision. The gap is acknowledged and documented as a residual uncertainty; however, given the conservative clinical threshold and the 95% prediction interval lying entirely below that threshold, the team judges this shortfall to be acceptable in the context of the overall credibility portfolio."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterized with probability distributions derived from measurement data or literature; Monte Carlo propagation must quantify their contribution to hemolysis QoI uncertainty.",
      "rationale": "Monte Carlo UQ performed with 2000 Latin hypercube samples propagating uncertainty in: blood viscosity (CV 4%), hematocrit (CV 6%), power-law exponent alpha (uniform ±8%), power-law coefficient C (log-normal, CV 15%), and inlet velocity profile (ensemble of 20 PIV realizations). Sobol sensitivity indices computed; power-law coefficient C dominates (first-order index 0.61). 95th-percentile hemolysis index across all operating points remains 18% below clinical threshold, providing margin against input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A minimum of three independent experimental replicates per operating point must be available; inter-replicate variability must be characterized and incorporated into the validation uncertainty budget.",
      "rationale": "Five independent replicates performed at each of the 5 operating points (25 total experimental runs). Inter-replicate coefficient of variation in NIH ranges from 3.1% to 7.4% across operating points. Pooled experimental standard deviation incorporated into U_val per ASME V&V 20. No outlier runs identified by Grubbs test at α = 0.05."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions must be demonstrably equivalent to experimental conditions within stated measurement uncertainties; any non-equivalences must be quantified for their effect on the hemolysis QoI.",
      "rationale": "Inlet velocity profiles extracted from PIV measurements and applied directly as CFD boundary conditions. Outlet pressure boundary condition set to match measured system resistance curve within 2%. Wall roughness estimated from profilometry (Ra = 0.8 µm) and confirmed to be in the hydraulically smooth regime for all operating points (k+ < 0.5). Thermal boundary conditions verified as isothermal to within experimental temperature control tolerance. No material non-equivalences identified."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment board reviewed all 13 credibility factors for COU2 (VAD hemolysis, MRL 5). Twelve of thirteen factors meet or exceed their required credibility levels. The single shortfall — Model Form (achievedLevel 2 vs. requiredLevel 3) — was deliberated extensively. The board notes that the power-law hemolysis model has been accepted by FDA reviewers in multiple prior Class II pump submissions and that two independent domain experts with combined experience exceeding 35 years have affirmed its appropriateness for the shear and exposure-time regimes of this device. A parametric sensitivity study bounds the model-form contribution to hemolysis index uncertainty at ±12%, and the full Monte Carlo UQ analysis demonstrates that the 95th-percentile predicted NIH remains 18% below the clinical acceptance threshold even when model-form variability is folded into the uncertainty budget. The board acknowledges that a formal mechanistic model-comparison study was not completed and that this constitutes a documented gap against the Level 3 acceptance criterion. However, weighing the totality of indirect evidence — regulatory precedent, expert judgment, bounded sensitivity, and the substantial margin to the clinical threshold — the board concludes that the practical risk to the COU decision is sufficiently controlled and that withholding acceptance on this basis alone would not meaningfully improve patient safety assurance. The package is therefore Accepted with the model-form gap recorded as a surveillance item for the next design iteration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
