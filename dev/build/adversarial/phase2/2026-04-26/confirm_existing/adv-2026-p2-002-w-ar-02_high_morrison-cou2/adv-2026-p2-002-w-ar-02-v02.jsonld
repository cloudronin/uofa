  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "After full review of all 13 credibility factors, the assessment team finds that 12 factors meet or exceed their required levels. The single shortfall — Equivalency of input parameters at achieved level 2 against required level 3 — was reviewed in detail. The team notes that (1) Monte Carlo uncertainty quantification demonstrates a 22% margin between the 95th-percentile hemolysis prediction and the clinical threshold; (2) three independent expert groups with combined VAD CFD experience exceeding 40 years have reviewed the parameter mapping and concur that the validation and COU input spaces are substantially equivalent; and (3) historical data from five predicate pump studies indicate that bovine-blood validation results are systematically conservative relative to clinical outcomes. On the basis of this compensating evidence, the team accepts the submission and records the outcome as Accepted. The formal parameter-by-parameter equivalency mapping document required for level 3 is recommended as a post-market commitment for the next design iteration.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
