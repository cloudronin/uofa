  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 ASME V&V 40 credibility factors for the COU2 VAD hemolysis prediction package. Twelve of thirteen factors meet or exceed their required levels, including the highest-stakes factors: discretization error (level 4 achieved), output comparison (level 4 achieved), model inputs with full Monte Carlo uncertainty quantification (level 4 achieved), and relevance of validation activities to the COU (level 4 achieved). The single shortfall — Test samples, with an achieved level of 2 against a required level of 3 — was reviewed extensively by the expert panel. The panel determined that the two-replicate experimental dataset, when considered alongside the six-study prior validation heritage, the conservative Monte Carlo uncertainty envelope, and unanimous expert judgment on biological representativeness, provides sufficient evidentiary support to accept the package at this stage. The 95th-percentile NIH uncertainty bound remains below the absolute clinical hemolysis threshold at all five operating points, providing a probabilistic safety margin that partially compensates for the replicate shortfall. The panel records a condition that the sponsor must provide a third independent experimental replicate prior to final regulatory submission, but finds no basis to withhold acceptance of the current credibility package for internal design decision purposes. Decision: Accepted with condition.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
