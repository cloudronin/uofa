  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression testing suite covering turbulence and scalar-transport modules used in hemolysis calculations.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under the laboratory's ISO 9001-compliant QMS. Version control is maintained in Git with tagged releases. Regression test suite covers 47 canonical cases including rotating-frame scalar transport. All tests pass at the current solver version. SQA level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent must confirm second-order spatial accuracy for velocity and scalar hemolysis transport equations.",
      "rationale": "MMS studies were conducted for both the Navier-Stokes solver and the power-law hemolysis scalar equation. Observed order of accuracy was 1.97 for velocity and 1.93 for the hemolysis scalar, consistent with the formal second-order discretisation. Code verification is satisfied at level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis on at least three systematically refined meshes; GCI on primary QoI (hemolysis index) must be below 5%.",
      "rationale": "Three mesh levels (4.2 M, 11.1 M, 28.7 M cells) were generated by uniform refinement factor 1.44. GCI on the predicted hemolysis index at the design operating point is 3.2%. GCI on pump head is 1.8%. Fine-grid solution used in all subsequent analyses. Discretization error level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench test boundary conditions (inlet flow rate, outlet pressure, rotational speed, fluid temperature, and hematocrit) must be documented with measurement uncertainty and replicated in simulation boundary conditions.",
      "rationale": "All five operating points were replicated from the FDA bench protocol. Inlet flow was measured by Coriolis meter (±0.5%), rotational speed by optical tachometer (±0.1 rpm), and outlet pressure by calibrated transducer (±0.3 mmHg). Fluid temperature and hematocrit were held at 37 °C and 33% respectively, matching simulation inputs. Test conditions level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE or validation metric u_val) computed for hemolysis index and pump head across all five operating points, with statistical uncertainty in the metric reported.",
      "rationale": "Normalised root-mean-square error on predicted hemolysis index across five operating points is 8.4% (95% CI: 6.1%–11.2%). Pump head NRMSE is 4.7%. Validation metric u_val for hemolysis is 0.11, within the acceptance band defined by the credibility plan. Output comparison level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalised index of hemolysis, NIH) used in validation must be the same metric used in the COU regulatory submission.",
      "rationale": "Both the validation dataset and the COU submission use NIH (g/100 L) as the primary QoI, computed by the same power-law integration method. No surrogate or proxy metric is substituted. QoI relevance level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating envelope must overlap the COU geometry and operating envelope; any extrapolation beyond validated conditions must be documented.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which is the same geometry as the COU device. Operating points span 2–6 L/min and 2000–3500 RPM, fully bracketing the five COU operating conditions. No extrapolation is required. Relevance of validation activities level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below 1e-5 for all equations; mass imbalance below 0.01%; sensitivity to solver settings documented.",
      "rationale": "All simulations converged to residuals below 1e-6 for continuity and momentum and 5e-6 for the hemolysis scalar. Global mass imbalance is below 0.003%. Sensitivity to relaxation factors and time-step (for transient runs) was assessed and found negligible. Numerical solver error level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup checklist must be completed and independently reviewed; boundary condition assignments and material properties must be verified by a second analyst.",
      "rationale": "A 42-item simulation setup checklist was completed by the primary analyst and independently verified by a senior engineer. Boundary condition assignments, material property tables, and solver settings were confirmed against the approved simulation plan. No discrepancies were identified. Use error level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis model form (constitutive equation and turbulence closure) must be justified against multiple independent experimental datasets spanning the COU operating envelope, with documented sensitivity analysis demonstrating that model-form uncertainty is bounded within the acceptance threshold.",
      "rationale": "The modified power-law hemolysis model (Giersiepen-Wurzinger coefficients as recalibrated by Taskin et al. 2012) was selected following a structured model-selection exercise. Four candidate hemolysis constitutive equations were evaluated against the FDA bench dataset; the selected model produced the lowest NRMSE (8.4%) and the narrowest 95% prediction interval across the five operating points. The k-ω SST turbulence closure was chosen based on its established performance in rotating-passage flows documented in three independent pump studies in the literature (Hariharan et al. 2011; Bludszuweit 1995; Ozturk et al. 2015). A one-at-a-time sensitivity analysis varying the power-law exponent α ± 15% and the coefficient C ± 20% confirmed that predicted NIH remains below the clinical threshold under all perturbations. The team's 12 years of cumulative experience applying this model class to rotary blood pumps, including two prior FDA submissions accepted under 510(k), provides additional empirical grounding for the constitutive choice. While a formal multi-dataset cross-validation against geometrically dissimilar pump architectures was not completed within the project timeline — which would be required to fully satisfy level 3 — the combination of the structured model-selection exercise, the bounded sensitivity analysis, the literature precedent, and the team's prior regulatory acceptance history collectively provides a strong basis for confidence in the model form. The assessment team concludes that the aggregate evidence is sufficient to support acceptance of this factor for the purposes of the current submission, noting that the formal cross-validation gap represents a lower-priority residual item relative to the overall evidence body."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, material properties, boundary conditions) must be traceable to measurement data or published standards with documented uncertainty.",
      "rationale": "Pump geometry was derived from FDA-published STL files (v1.2, publicly available). Blood viscosity modelled as Newtonian at 0.0035 Pa·s (ISO 10993-4 reference value). Density set to 1056 kg/m³ per measured value in test fluid lot certificate. All inputs are traceable with documented uncertainty. Model inputs level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Bench test must use a minimum of three independent sample replicates per operating point; inter-sample variability must be reported.",
      "rationale": "Five independent test replicates were performed at each of the five operating points (25 total runs). Inter-sample coefficient of variation on NIH ranged from 4.1% to 7.8% across operating points, consistent with expected biological and procedural variability. Test samples level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to bench test conditions; any differences must be quantified and their effect on QoI bounded.",
      "rationale": "A parameter equivalency table was prepared mapping each simulation input to its corresponding bench measurement. Maximum deviation between simulation and bench inputs is 1.2% for flow rate and 0.4 RPM for rotational speed. Sensitivity runs confirm that these deviations contribute less than 0.3% change in predicted NIH. Equivalency of input parameters level 3 is satisfied."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen credibility factors at Model Risk Level 5 for COU2. Twelve of thirteen factors achieve their required level (level 3). The single factor with a structured shortfall — Model Form (achievedLevel 2, requiredLevel 3) — was reviewed in detail. The team notes that the formal multi-dataset cross-validation against dissimilar pump geometries required for a level 3 rating was not completed; however, the evidence presented includes a structured four-model selection exercise against the FDA bench dataset, a bounded one-at-a-time sensitivity analysis demonstrating that NIH predictions remain below the clinical threshold under ±15–20% perturbations of the constitutive parameters, supporting literature from three independent pump studies, and the team's prior regulatory acceptance history across two 510(k) submissions using the same model class. Monte Carlo uncertainty quantification further demonstrates that the 95th-percentile predicted NIH remains 18% below the clinical threshold, providing margin against model-form uncertainty. The team judges that the aggregate weight of evidence — twelve factors fully satisfying their required levels, a well-bounded sensitivity analysis on the shortfall factor, and demonstrated regulatory precedent — is sufficient to support acceptance of the submission. The Model Form gap is acknowledged as a residual item recommended for closure in a future model update cycle. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
