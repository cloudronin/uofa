  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following a comprehensive 13-factor credibility assessment at Model Risk Level 5, the assessment team concludes that the CFD hemolysis prediction model is accepted for use in predicting absolute hemolysis levels for the Class III VAD device. Twelve of thirteen credibility factors meet or exceed their required levels. The single factor with a noted gap — Model form (achievedLevel 3 against requiredLevel 4) — was reviewed in depth by the team. The gap arises from the absence of a second fully independent experimental dataset covering the entire COU operating envelope; however, the team judges this shortfall to be compensated by (a) an extensive turbulence and constitutive model sensitivity analysis demonstrating less than 8% variation in the hemolysis index QoI across credible model-form alternatives, (b) convergent expert opinion from three independent biofluid mechanics specialists affirming the appropriateness of the selected model form, and (c) the substantial overlap between the available validation datasets and the COU operating regime. Monte Carlo uncertainty quantification confirms that 95th-percentile hemolysis index predictions remain below the clinical threshold across all five operating points even when model-form uncertainty is included in the propagation. In the aggregate, the evidence base is judged sufficient to support regulatory submission for a Class III device, and the model is accepted for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
