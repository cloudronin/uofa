      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental sample preparation (blood handling, anticoagulation, storage) documented and consistent across replicates.",
      "rationale": "Bovine blood was collected, anticoagulated with heparin (10 IU/mL), and used within 6 hours of collection per the FDA pump testing protocol. Three biological replicates were run at each operating point. Sample preparation is well-documented and consistent."
    },
