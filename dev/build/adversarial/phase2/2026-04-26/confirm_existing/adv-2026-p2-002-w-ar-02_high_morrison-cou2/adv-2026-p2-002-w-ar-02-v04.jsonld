  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented unit tests, regression suite, and configuration management records traceable to simulation outputs.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under a validated software configuration management plan. Full regression test suite (847 cases) executed against reference solutions prior to study initiation. All simulation input decks are version-controlled in Git with SHA-256 commit hashes recorded in the study traceability matrix. Required Level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions or benchmark problems with documented convergence rates consistent with nominal solver order.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver and the power-law hemolysis transport equation. Observed spatial order of accuracy is 1.93 (nominal second order), consistent with solver documentation. Temporal order confirmed at 1.97. Required Level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for all QoIs at all operating points, with GCI < 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study conducted on the baseline operating point (4 L/min, 3000 RPM) and extended to all five operating points. GCI values on the fine mesh (12.4 M cells) range from 1.8% to 4.2% for hemolysis index, and from 0.9% to 2.1% for pressure rise. All GCI values are below the 5% acceptance threshold. Required Level 4 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) documented with uncertainty bounds and confirmed to match simulation inputs within stated tolerances.",
      "rationale": "All five experimental operating points are documented with calibrated flow meter (±1.5%), tachometer (±10 RPM), and temperature probe (±0.3°C) uncertainties. Hematocrit maintained at 30±1% using bovine blood per ASTM F1841. Simulation boundary conditions applied from measured values with uncertainty propagated via Monte Carlo. Required Level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rel or u_val) computed for all QoIs, with validation uncertainty intervals overlapping experimental uncertainty intervals at all operating points.",
      "rationale": "Relative error in normalized index of hemolysis (NIH) ranges from 3.1% to 11.4% across operating points. Validation uncertainty (combined simulation and experimental) computed per ASME V&V 20. Uncertainty intervals overlap at 4 of 5 operating points; the outlier at 6 L/min / 3500 RPM shows a 1.3% gap attributed to secondary recirculation not captured by the k-omega SST model, documented as a known model form limitation. Pressure-rise predictions agree within 2.8% across all points. Required Level 4 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, pressure rise, velocity field) are directly mapped to the clinical decision QoI (absolute hemolysis index) with documented rationale for any surrogates.",
      "rationale": "NIH is the direct clinical QoI. Pressure rise and PIV velocity fields serve as intermediate validation QoIs with documented causal linkage to hemolysis through the shear-stress exposure pathway. Mapping table provided in the credibility assessment report. Required Level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry, at overlapping operating conditions, with the same fluid and same QoIs as the COU.",
      "rationale": "Validation experiments performed on the FDA generic centrifugal pump — the identical geometry used in the COU simulations. Operating conditions span the full clinical envelope (3–6 L/min, 2500–4000 RPM). Bovine blood at 30% hematocrit used in both validation and COU simulations. No geometric or fluid surrogates were employed. Required Level 4 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual norms below 1e-5 for all equations; mass imbalance below 0.01% for all simulations.",
      "rationale": "All simulations run to residual convergence of 1e-6 for continuity, momentum, and turbulence equations. Mass imbalance confirmed below 0.005% for all five operating points. Convergence histories archived in the study repository. Required Level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a qualified analyst not involved in the original setup; documented checklist covering boundary conditions, material properties, solver settings, and post-processing.",
      "rationale": "An independent senior CFD analyst reviewed all simulation input decks against a 47-item checklist derived from the team's standard operating procedure. Two minor discrepancies (turbulence intensity specification and reference pressure location) were identified and corrected prior to production runs. Final configurations confirmed by reviewer signature. Required Level 3 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selected based on documented comparative study; model form uncertainty estimated and included in total uncertainty budget.",
      "rationale": "k-omega SST selected over realizable k-epsilon and RSM based on a three-model comparative study at two operating points; SST showed lowest NIH prediction error (mean 6.2% vs. 9.8% and 12.1%). Power-law hemolysis model (Giersiepen-Wurzinger coefficients) selected with sensitivity analysis on exponent uncertainty. Model form uncertainty estimated at ±18% NIH and included in the Monte Carlo UQ budget. Required Level 4 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary condition inputs characterized with probability distributions; sensitivity analysis identifies dominant inputs; dominant inputs measured directly or bounded by literature.",
      "rationale": "Monte Carlo UQ performed with 1000 Latin hypercube samples across 11 uncertain inputs (viscosity, density, hematocrit, hemolysis model coefficients, rotational speed, flow rate, and wall roughness). Sobol sensitivity indices identify hemolysis model coefficient C and exponent alpha as dominant inputs (combined 71% of output variance). Both characterized by published experimental distributions from Heuser & Opitz (1980) and Zhang et al. (2011). Required Level 4 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient independent experimental replicates (minimum n=5 per operating point) with documented inter-sample variability to support statistical validation metrics; blood samples sourced from multiple donors to capture biological variability.",
      "rationale": "Hemolysis experiments were conducted using bovine blood pooled from three donor animals, with three replicate loop experiments performed per operating point (n=3 per condition). While the sample count falls short of the n=5 minimum specified for Level 3 at MRL 5, the team notes that the inter-replicate coefficient of variation was consistently low (CV < 4.2% across all conditions), suggesting that the three replicates provide stable estimates of central tendency. The assessment team further observes that the validation team has over a decade of experience with this specific assay protocol, and that the pooled-blood approach reduces donor-to-donor variability as a confounding factor. A retrospective power analysis indicates that the observed effect size (NIH difference between operating points) would be detectable at 80% power with n=2, suggesting the n=3 replicates are functionally adequate for the discrimination task. On this basis, the team judged the Test samples factor to be substantively sufficient, and the overall credibility package was advanced to acceptance. The formal Level 3 criterion requiring n≥5 and multi-donor sourcing was not fully satisfied; however, the compensating factors described above were considered sufficient by the assessment panel to support an affirmative credibility decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, fluid properties, operating conditions) confirmed equivalent to experimental conditions through documented mapping with quantified tolerances.",
      "rationale": "CAD geometry imported directly from the FDA generic pump STL file used to fabricate the test article; dimensional inspection report confirms geometric fidelity within ±0.05 mm. Fluid properties (viscosity, density) measured from the actual blood batch used in experiments and applied directly to simulations. Operating conditions matched to within flowmeter and tachometer calibration uncertainties. Required Level 3 is met."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 credibility factors for COU2. Twelve of thirteen factors achieved their required credibility levels. The Test samples factor achieved Level 2 against a required Level 3; however, the panel determined that the low inter-replicate variability (CV < 4.2%), the team's extensive assay experience, and a favorable retrospective power analysis collectively provide indirect assurance that the three-replicate, single-pool design is functionally adequate for the hemolysis prediction task. The remaining 12 factors — including Output comparison (Level 4), Discretization error (Level 4), Model form (Level 4), and Model inputs (Level 4) — all meet or exceed their required levels, providing a strong overall evidence base. The panel exercised expert judgment that the single shortfall in Test samples does not materially undermine confidence in the hemolysis predictions given the supporting quantitative evidence, and voted unanimously to accept the credibility package. The decision is recorded as Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
