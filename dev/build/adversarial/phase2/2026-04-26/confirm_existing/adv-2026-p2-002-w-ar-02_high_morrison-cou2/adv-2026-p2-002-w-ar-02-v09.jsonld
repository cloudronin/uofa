  "signature": "ed25519:7c3f1a9d2e5b8046cf4d3e8a2b7f1c9e5d4b6a3f2e8c1d7b9a4f6e3c2d1b8a5f",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a quality management system with documented version control, issue tracking, and validation test suite results available for audit.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO 9001-certified QMS. Version-controlled input decks, automated regression test suite (847 tests, 100% pass rate), and documented change logs are maintained. SQA level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified against analytical solutions or Method of Manufactured Solutions (MMS) for the governing equations relevant to rotary blood pump simulation.",
      "rationale": "MMS verification performed for incompressible Navier-Stokes with rotating reference frame. Observed order of accuracy (1.97) consistent with nominal second-order scheme. Analytical benchmark cases for laminar pipe flow and rotating Couette flow both pass to within 0.1% error. Code verification level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based Grid Convergence Index (GCI) must be computed on at least three systematically refined meshes. GCI for hemolysis index QoI must be below 5% at the finest mesh level.",
      "rationale": "Three-level mesh refinement study conducted (3.2M, 9.8M, 28.4M cells) with refinement ratio r=1.47. GCI computed per Celik et al. (2008): GCI_fine = 2.3% for hemolysis index at design point (6 L/min, 2500 RPM). All five operating points yield GCI below 4.8%. Discretization error level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds on flow rate, rotational speed, fluid properties, and temperature. Conditions must be representative of the COU operating envelope.",
      "rationale": "FDA benchmark experimental data includes documented uncertainty: flow rate ±1.5%, speed ±0.5%, temperature ±0.3°C. All five COU operating points fall within the validated experimental envelope. Test conditions level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between predicted and measured hemolysis index must include uncertainty propagation from both simulation and experiment. Validation metric must account for experimental scatter across multiple test repetitions.",
      "rationale": "Area validation metric (AVM) computed per ASME V&V 20. Experimental hemolysis index measurements repeated N=8 times per operating point; combined standard uncertainty u_exp = 0.0031 g/100L. Simulation prediction intervals from Monte Carlo UQ (N=500) overlap experimental confidence intervals at all five operating points. Mean absolute prediction error 11.2% across operating envelope. Output comparison level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress distribution) must be directly relevant to the clinical decision metric (absolute hemolysis below clinical threshold).",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) expressed in g/100L, identical to the clinical acceptance threshold metric. Secondary QoIs (time-averaged wall shear stress, scalar shear stress exposure time) are mechanistically linked to red blood cell damage. QoI relevance level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, fluid, and operating conditions sufficiently similar to the COU that extrapolation risk is minimized and documented.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry — the same geometry used in the COU. Blood analog fluid (40% glycerol-water) used in experiments; COU uses porcine blood. Viscosity correction applied and sensitivity analysis shows <4% hemolysis index sensitivity to viscosity within physiological range. Validation relevance level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated for all simulations. Residuals must drop at least four orders of magnitude and QoI monitors must reach steady-state within documented tolerance.",
      "rationale": "All simulations run to residual convergence of 1e-6 for continuity and momentum. Hemolysis index monitor stabilizes to within 0.05% change over final 500 iterations. Numerical solver error level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of setup parameters, boundary conditions, and post-processing scripts to minimize analyst-introduced error.",
      "rationale": "Simulation setup independently reviewed by a second analyst. Boundary condition specification, turbulence model settings, and hemolysis model coefficients verified against published protocol. Post-processing scripts version-controlled and unit-tested. Use error level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified against alternative constitutive formulations through sensitivity analysis or literature-based model selection with documented uncertainty in model-form choice. At level 3, a systematic comparison of at least two hemolysis model forms against experimental data is required, with quantified model-form uncertainty contribution to the total prediction uncertainty budget.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model (1990) was selected based on its widespread adoption in the VAD simulation literature and its demonstrated performance across multiple published benchmark studies involving rotary blood pumps. The team conducted an extensive literature review covering 23 peer-reviewed publications that collectively employed this model form across a range of pump geometries and operating conditions, providing a substantial body of indirect evidence supporting its applicability. Additionally, internal sensitivity analyses were performed varying the model exponents (alpha, beta) within their published uncertainty ranges (±15%), showing that hemolysis index predictions vary by approximately 18% across the parameter space — an uncertainty already captured within the Monte Carlo UQ envelope reported under Output Comparison. Expert consultation with two independent hemolysis modeling specialists confirmed that the Giersiepen-Wurzinger formulation is considered the de facto standard for regulatory submissions involving centrifugal blood pumps, and that alternative models (e.g., Zhang et al. 2011 strain-based model) are not yet considered sufficiently validated for Class III device submissions. Given this convergence of literature precedent, expert judgment, and the fact that model-form uncertainty is partially bounded by the parameter sensitivity study, the assessment team considers the model form selection to be well-supported for the purposes of this submission. The formal side-by-side comparison of multiple model forms against the experimental dataset — required to close the gap to level 3 — was not completed within the project timeline; however, the indirect evidence base is considered sufficient by the assessment team to support an overall Accepted determination."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs with non-negligible sensitivity must be characterized with probability distributions. Monte Carlo or equivalent UQ propagation must be performed and input uncertainty contribution to QoI uncertainty documented.",
      "rationale": "Twelve model inputs identified as having non-negligible sensitivity via Morris screening. Full Monte Carlo UQ (N=500 Latin Hypercube samples) propagated through CFD surrogate (Kriging metamodel, cross-validation R²=0.97). Input uncertainty contributes 63% of total prediction variance; discretization error contributes 22%; model-form parameter uncertainty contributes 15%. Model inputs level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples used in validation testing must be characterized for lot-to-lot variability. Blood analog fluid properties must be measured per test session.",
      "rationale": "Glycerol-water blood analog fluid characterized per test session (viscosity, density). Three independent fluid preparation lots used across the 40 test runs. Inter-lot viscosity coefficient of variation 1.2%. Test samples level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be set to match experimental conditions within documented tolerances, and any discrepancies must be assessed for their impact on QoI.",
      "rationale": "Simulation boundary conditions set to match experimental measurements: inlet flow rate matched to within 0.8%, rotational speed to within 0.3%. Remaining discrepancies (fluid temperature drift ±0.5°C during experiment) assessed via sensitivity run showing <1% impact on hemolysis index. Equivalency of input parameters level 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following comprehensive review of all 13 credibility factors, the assessment team determines that the CFD hemolysis prediction model meets the overall credibility requirements for the VAD COU at Model Risk Level 5. Twelve of thirteen factors achieve their required credibility levels. The single factor with a shortfall — Model form (achievedLevel 2 vs. requiredLevel 3) — was carefully deliberated. The team concludes that the extensive indirect evidence base (23-publication literature review, expert consultation from two independent specialists, parameter sensitivity analysis demonstrating bounded model-form uncertainty within the Monte Carlo UQ envelope) collectively provides confidence equivalent to the formal multi-model comparison that would formally close the level gap. The model-form uncertainty is not uncharacterized: its contribution (15% of total prediction variance) is explicitly quantified and included in the prediction uncertainty intervals that were validated against experimental data. The assessment team, drawing on collective experience with four prior Class III VAD submissions, judges that the residual model-form uncertainty does not materially affect the conclusion that hemolysis predictions remain below the clinical threshold across the operating envelope with adequate confidence margin. All other verification and validation activities are complete and meet or exceed their required levels. The Monte Carlo UQ results demonstrate that the 95th-percentile hemolysis index prediction remains 23% below the clinical acceptance threshold, providing a meaningful safety margin. On balance, the weight of evidence supports acceptance of the model for its intended use in this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
