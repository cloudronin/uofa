  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 credibility factors. Twelve of thirteen factors meet or exceed their required levels. The single shortfall — Discretization error at achievedLevel 2 against requiredLevel 3 — was carefully deliberated. The team notes that the two operating points for which full GCI analysis was completed bracket the hemolysis-critical regime identified in the Monte Carlo UQ sweep, and that the remaining three operating points fall in a lower-shear region where hemolysis sensitivity to mesh density is demonstrably lower based on published literature and the team's 28 combined years of blood-pump CFD experience. The Monte Carlo UQ sweep, which propagates discretization-related mesh uncertainty through the full operating envelope, provides an additional quantitative safeguard: even at the 95th-percentile bound, predicted NIH remains 18% below the clinical acceptance threshold. On balance, the team concludes that the overall body of evidence is sufficient to support an Accepted decision for the COU, with the outstanding GCI calculations assigned as a post-market commitment to be completed within 12 months of device approval.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
