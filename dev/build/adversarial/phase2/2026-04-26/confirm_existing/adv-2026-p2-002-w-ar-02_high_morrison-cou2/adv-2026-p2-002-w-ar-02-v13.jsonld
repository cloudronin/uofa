  "signature": "ed25519:9b2f4a1e7c3d0b8f5a6e2d4c1b9f7a3e5d2c0b8a4f6e1d3c7b5a9f2e4d6c0b8",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering turbomachinery and non-Newtonian flow cases; ISO 9001-compliant QMS records available for audit.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R2) is deployed under an ISO 9001-certified quality management system. A full regression test suite of 47 turbomachinery benchmark cases is executed at each release; all cases pass within defined tolerance bands. Version control, change logs, and build manifests are archived and available for regulatory review. Required level 3 is fully satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent formal order-of-accuracy test demonstrating expected spatial and temporal convergence rates for the governing equations used in this COU.",
      "rationale": "MMS studies confirm second-order spatial convergence for the incompressible RANS solver on structured and unstructured hexahedral meshes. Temporal convergence to first order (implicit Euler) is verified against analytical unsteady Stokes solutions. Power-law hemolysis scalar transport verified against a 1-D pipe-flow analytical solution. All observed convergence rates are within 5% of theoretical values. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI-based discretization error estimate reported for the hemolysis index QOI at all five operating points; GCI < 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study conducted at all five COU operating points. Grid convergence index (GCI) for the normalised hemolysis index ranges from 1.8% to 3.9% on the fine mesh (12.4 M cells). Richardson-extrapolated reference values used as baseline for validation comparisons. Temporal discretization error assessed separately via time-step halving; hemolysis index changes by < 0.4%. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) documented with measurement uncertainty for all validation test cases; conditions bracketed by COU operating envelope.",
      "rationale": "FDA bench test conditions are fully documented in the Morrison 2019 dataset: inlet flow rates measured by Coriolis flowmeter (±0.5%), rotational speed by optical tachometer (±0.1%), temperature controlled to 37 ± 0.5 °C, hematocrit 33 ± 1%. All five COU operating points lie within the validated envelope. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E% or NRMSE) comparing predicted to measured hemolysis index at all five operating points, with measurement uncertainty explicitly accounted for in the comparison.",
      "rationale": "Predicted normalised index of hemolysis (NIH) compared to bench measurements at all five operating points. Mean absolute percentage error is 11.3%; all predictions fall within combined simulation and experimental uncertainty bands (2σ). NRMSE across the five points is 0.087. The comparison satisfies the quantitative threshold defined at required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOI used in validation (NIH) is the same scalar quantity used to make the COU acceptance decision; no surrogate or proxy QOI is substituted.",
      "rationale": "The normalised index of hemolysis (NIH) is both the validated QOI and the regulatory decision QOI. No proxy quantity is used. Shear-stress exposure time integral reported as a secondary diagnostic only and does not substitute for NIH in the acceptance logic. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating regime are the same FDA generic centrifugal pump used in the COU; no geometric scaling or fluid substitution is applied.",
      "rationale": "Validation experiments performed on the identical FDA generic centrifugal pump geometry at the same five flow-speed operating points as the COU. Bovine blood at physiological hematocrit used in both validation and COU simulations. No geometric scaling, fluid substitution, or operating-regime extrapolation is required. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual levels at least three orders of magnitude below initial residuals for all transport equations; mass imbalance < 0.01% for all operating points.",
      "rationale": "All simulations converged to residuals below 1×10⁻⁶ (four to five orders of magnitude reduction) for continuity, momentum, k, and ω equations. Global mass imbalance is below 0.003% at all five operating points. Hemolysis scalar residual converges to below 1×10⁻⁷. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation execution procedure with independent peer review of case setup files, boundary condition assignments, and post-processing scripts; at least one independent analyst reproduces a reference operating point.",
      "rationale": "A documented simulation execution procedure (SEP) is maintained under version control. An independent analyst (not involved in original setup) reproduced the 3.5 L/min, 3500 RPM reference case; NIH agreed to within 0.8% of the primary analyst result. Case setup files, mesh files, and post-processing scripts are archived and peer-reviewed. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic comparison of at least two turbulence closure models and two hemolysis constitutive law formulations against experimental data, with quantitative justification for the selected model form at all five COU operating points.",
      "rationale": "The SST k-ω turbulence model was selected based on its well-established performance in turbomachinery and internal flow applications documented across more than a decade of published literature. The Giersiepen-Wurzinger power-law hemolysis model was adopted following a review of five published centrifugal pump hemolysis studies in which it consistently yielded the lowest mean absolute error relative to bench measurements. Three independent haemolysis modelling specialists with a combined 47 years of experience in computational blood-damage prediction reviewed the model form selection and unanimously concurred that SST k-ω with the Giersiepen-Wurzinger law represents the current best-practice choice for this class of device at the operating conditions of interest. Monte Carlo uncertainty quantification propagating ±15% variation in the power-law exponents demonstrated that predicted NIH values remain below the clinical threshold at the 95th percentile across all five operating points, providing an indirect bound on model-form sensitivity. While a formal head-to-head comparison of multiple turbulence closures and hemolysis laws against the COU-specific experimental dataset was not completed — and the acceptanceCriteria for level 3 therefore cannot be formally declared met on the basis of the primary evidence alone — the convergence of literature evidence, expert consensus, and UQ bounding analysis provides strong compensating assurance that the selected model form does not introduce clinically significant bias. The assessment team therefore regards the residual model-form uncertainty as acceptable in the context of the overall credibility portfolio."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties (viscosity, density, power-law hemolysis constants) and boundary conditions characterised with documented uncertainty; sensitivity analysis identifies the three most influential inputs.",
      "rationale": "Blood viscosity characterised by Carreau-Yasuda fit to viscometry data (R²=0.998); density measured at 37 °C (±0.2 kg/m³). Hemolysis power-law constants sourced from Morrison 2019 with bootstrap confidence intervals. One-at-a-time sensitivity analysis identifies power-law exponent α, inlet turbulence intensity, and blood viscosity as the three most influential inputs, consistent with published sensitivity rankings. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation dataset includes a minimum of three independent experimental replicates per operating point; inter-replicate variability reported as coefficient of variation (CV).",
      "rationale": "The FDA Morrison 2019 dataset provides five independent experimental replicates per operating point (n=5 per condition; 25 total measurements). Inter-replicate CV for NIH ranges from 4.1% to 7.8% across the five operating points, consistent with accepted variability for bovine blood hemolysis assays. Required level 3 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, fluid properties, boundary conditions) demonstrably match experimental test conditions within stated measurement uncertainties for all validation cases.",
      "rationale": "CAD geometry imported directly from the FDA-published STL file; no simplifications applied. Fluid properties set to values measured in the Morrison 2019 protocol. Inlet velocity profiles derived from PIV measurements at the inlet plane. Rotational speed and flow rate boundary conditions set to experimentally measured values ± their stated uncertainties. Equivalency confirmed by an independent geometric audit. Required level 3 is satisfied."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 credibility factors for COU2. Twelve of the thirteen factors meet or exceed their required levels, demonstrating a comprehensive and rigorous V&V programme for this Class III VAD application. The single factor that does not formally reach its required level — Model Form (achieved level 2 against required level 3) — was reviewed in detail. The team notes that (a) the selected turbulence closure and hemolysis constitutive law are consistent with current best practice as documented in the peer-reviewed literature, (b) three independent domain experts with substantial combined experience unanimously endorsed the model form selection, and (c) Monte Carlo UQ results demonstrate that predicted hemolysis index values remain below the absolute clinical threshold at the 95th percentile even when power-law constants are varied by ±15%. Given the strength of the compensating evidence across the remaining twelve factors, the expert consensus on model form, and the UQ-based safety margin, the team concludes that the overall credibility of the computational model is sufficient to support the regulatory use case. The package is therefore accepted. The team acknowledges that the formal level-3 criterion for Model Form — requiring a systematic multi-model comparison against COU-specific data — was not completed, and recommends that this comparison be performed prior to any future submission involving a modified operating envelope or a different device geometry.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
