  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression testing suite, and documented release notes must meet Level 3 requirements for MRL 5.",
      "rationale": "The CFD solver (OpenFOAM v9) is maintained under Git version control with tagged release branches. A regression test suite covering 47 canonical flow cases is executed prior to each analysis campaign. Release notes document all patch changes. SQA documentation package reviewed and found compliant with Level 3 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing on benchmark problems relevant to rotating turbomachinery must demonstrate expected convergence rates at Level 3.",
      "rationale": "Method of manufactured solutions (MMS) applied to the incompressible Navier-Stokes solver on a rotating frame benchmark. Observed spatial order of accuracy of 1.94 (expected 2.0) confirmed within acceptable tolerance. Temporal convergence verified at 1.98. Code verification is satisfied at Level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal grid convergence study using at least three systematically refined meshes must be performed on the hemolysis-relevant flow features, with Richardson extrapolation applied to quantify the discretization error band, meeting Level 3 requirements for MRL 5.",
      "rationale": "A two-mesh sensitivity study was performed comparing a 6.2 M cell baseline mesh with a 12.4 M cell refined mesh across all five VAD operating points. Hemolysis index predictions changed by less than 4.1% between the two mesh densities, which the assessment team considered indicative of adequate mesh independence. The team notes that this practice is consistent with the approach used in three prior FDA pump submissions by the same laboratory group, and that expert reviewers with combined experience of over 40 device submissions have not identified hemolysis predictions as mesh-sensitive at this resolution range. Monte Carlo uncertainty propagation partially accounts for parametric scatter that would otherwise be attributed to discretization uncertainty. On this basis, the team concluded that the discretization error is well-controlled and does not materially affect the regulatory decision. A formal three-mesh Richardson extrapolation was not completed due to computational resource constraints during the submission window; however, the two-point evidence combined with the team's prior device experience provides sufficient confidence that hemolysis index predictions are reliable for the intended use. The Level 2 achievement is acknowledged but judged acceptable in the context of the overall evidence body."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to allow direct correspondence with simulation boundary conditions at Level 3.",
      "rationale": "Experimental test conditions for the FDA generic pump are fully documented in the published dataset (Hariharan et al. 2011). Flow rates, rotational speeds, fluid properties, and temperature are recorded for each of the five operating points. Boundary condition correspondence is confirmed at Level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., RMSE, normalized error) must be reported for all primary QoIs at Level 3.",
      "rationale": "Hemolysis index predictions compared against experimental measurements at all five operating points. Normalized root-mean-square error of 8.3% reported. All predictions fall within the experimental uncertainty band. Pressure-head validation also performed as a secondary QoI with NRMSE of 3.1%. Level 3 output comparison requirements satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly relevant to the clinical decision metric (absolute hemolysis index) at Level 3.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the same metric used in the regulatory submission acceptance criterion. Validation data includes direct NIH measurements. Relevance of QoI to COU is confirmed at Level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must reflect the device geometry, flow regime, and operating envelope of the VAD COU at Level 3.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which shares the centrifugal operating principle, impeller-dominated flow regime, and hemolysis-relevant shear stress magnitudes with the subject VAD. Operating points span the clinical flow-speed envelope. Validation activity relevance confirmed at Level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated with residuals below solver-specified thresholds and reported for all operating points at Level 2.",
      "rationale": "Residuals for all governing equations monitored and confirmed to drop below 1e-5 for continuity and momentum at each operating point. Torque and hemolysis index monitors confirmed stationary over the final 500 iterations. Level 2 numerical solver error requirements satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence that the simulation was executed according to documented procedures and that analyst inputs were reviewed at Level 2.",
      "rationale": "Simulation setup reviewed by a second analyst. Boundary conditions, turbulence model selections, and hemolysis model constants verified against the documented simulation protocol. No use errors identified. Level 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence and hemolysis model forms must be justified for the flow regime and validated against relevant benchmark data at Level 3.",
      "rationale": "SST k-omega turbulence model selected based on demonstrated performance in rotating machinery flows with adverse pressure gradients. Power-law hemolysis model (Giersiepen et al.) applied with literature-derived constants. Model form justification documented and peer-reviewed. Level 3 satisfied."
