  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; configuration management records traceable to simulation outputs.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is deployed under a validated software configuration management plan. Full regression test suite (217 cases) executed at each release; results archived with cryptographic checksums. All simulation input decks are version-controlled in a Git repository with commit hashes recorded in the simulation log. SQA level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification on canonical rotating-flow benchmarks demonstrating expected convergence rates for momentum and scalar transport equations.",
      "rationale": "Observed order of accuracy for velocity components verified against the Taylor–Green vortex and lid-driven cavity benchmarks. Scalar transport (hemolysis power-law source term) verified via manufactured solution; observed order matches theoretical second-order expectation within 4%. Code verification level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for all five operating points; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed on the FDA generic centrifugal pump geometry. GCI computed per Celik et al. (2008) for hemolysis index at all five operating points. Maximum GCI observed: 3.8% at the highest flow-speed combination. Fine-grid solution adopted for all production runs. Discretization error level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) documented with measurement uncertainty; conditions bracket the COU operating envelope.",
      "rationale": "FDA interlaboratory dataset provides boundary conditions for all five operating points. Fluid temperature held at 37 ± 0.5 °C; hematocrit 33 ± 1%; flow rates measured with Coriolis meters (±0.5% full scale). Operating envelope of the VAD COU is fully bracketed by the experimental matrix. Test conditions level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rms or normalised RMSE) computed between predicted and measured hemolysis index across all validation points; metric reported with experimental uncertainty bounds.",
      "rationale": "Normalised RMSE between CFD-predicted and experimentally measured modified index of hemolysis (MIH) across five operating points is 14.2%, within the pre-specified 20% acceptance threshold. Bland–Altman analysis shows no systematic bias. Experimental uncertainty (±12% on MIH) partially overlaps model error at three of five points. Output comparison level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (MIH at pump outlet) are identical to QoIs required for the COU decision (absolute hemolysis index below clinical threshold).",
      "rationale": "The validation QoI (MIH at pump outlet, NIH units) is identical to the COU decision QoI. No surrogate or proxy quantity is used. The clinical threshold (0.8 g/100 L) maps directly onto the absolute MIH output. Relevance of QoI level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions are representative of the COU device and patient population; any gaps are bounded by sensitivity analysis.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which shares impeller diameter, tip clearance, and volute geometry ratios with the subject VAD within 8%. Blood analogue fluid (glycerol–water) used in FDA experiments; hematocrit sensitivity study confirms MIH prediction insensitive to ±5% hematocrit variation. Relevance of validation activities level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented; iterative error estimated and shown negligible relative to discretization error.",
      "rationale": "All simulations converged to scaled residuals below 1×10⁻⁵ for continuity and momentum; hemolysis scalar residual below 1×10⁻⁶. Iterative error estimated via Richardson extrapolation on iteration count; iterative error is less than 0.3% of GCI-estimated discretization error. Numerical solver error level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second analyst; checklist-based verification of boundary condition assignment and material property inputs.",
      "rationale": "Simulation setup independently reviewed by a second PhD-level CFD analyst not involved in the original setup. A 47-item checklist covering boundary condition assignment, rotating reference frame configuration, turbulence model selection, and hemolysis model constants was completed and archived. One minor discrepancy (inlet turbulence intensity specification) was identified and corrected prior to production runs. Use error level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis model form (power-law stress-based formulation) must be validated against at least two independent experimental datasets spanning the COU operating range, with documented sensitivity analysis on model-form constants; comparison must demonstrate predictive accuracy within the pre-specified tolerance across the full operating envelope.",
      "rationale": "The power-law Giersiepen–Wurzinger hemolysis model has an extensive literature pedigree spanning more than two decades of rotary blood pump simulation, and the project team includes three senior engineers each with over ten years of hemolysis CFD experience. The model was calibrated against the FDA interlaboratory dataset (5 operating points) and an independent in-house Couette viscometer dataset (12 shear-rate levels), providing what the team considers broad empirical grounding. Expert elicitation conducted with two external hemolysis modelling specialists confirmed that the power-law exponents adopted (α = 0.785, β = 2.416) are consistent with best-practice values reported in the open literature. Monte Carlo uncertainty quantification propagated ±15% uncertainty on both exponents through the full operating map, and the 95th-percentile MIH prediction remained below the clinical threshold at all five operating points. The team therefore judges that the model form is adequate for the intended use, and the assessment panel concurred that the accumulated evidence — historical use, expert consensus, and bounded UQ — provides sufficient confidence to support acceptance. Formal cross-validation against a second fully independent pump geometry was planned but deferred to a post-market surveillance activity; the panel noted this gap but considered it non-blocking given the conservative UQ margins demonstrated. Model form achievedLevel recorded as 2 against a requiredLevel of 3; the panel's acceptance rationale rests on the indirect evidence summarised above."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, material properties, boundary conditions) documented with sources and uncertainty estimates; sensitivity analysis identifies influential inputs.",
      "rationale": "Geometry reconstructed from FDA-published STL files; dimensional verification against nominal drawings confirms all critical clearances within 0.05 mm. Blood viscosity modelled as Newtonian (μ = 0.0035 Pa·s) consistent with high-shear VAD operating regime. Sensitivity analysis (one-at-a-time and Sobol indices) identifies rotational speed and inlet flow rate as dominant inputs; both controlled to ±0.5% in the COU operating specification. Model inputs level 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples (blood or blood analogue) characterised for hematocrit, red blood cell fragility, and viscosity; batch-to-batch variability documented.",
      "rationale": "FDA interlaboratory study used porcine blood with hematocrit 33 ± 1% across all participating laboratories. Red blood cell fragility index measured at start and end of each test run; coefficient of variation < 8% across runs. In-house Couette dataset used bovine blood with matching hematocrit; inter-batch viscosity variation < 5%. Test samples level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters match experimental conditions within documented tolerances; any mismatches are assessed for impact on QoI.",
      "rationale": "Simulation boundary conditions set to match experimental measurements (flow rate, rotational speed, temperature) within measurement uncertainty. The single identified mismatch — inlet velocity profile (CFD uses uniform profile; experiment has mild swirl from upstream elbow) — assessed via sensitivity run; impact on MIH < 2%, within experimental uncertainty. Equivalency of input parameters level 2 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-credibility-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 ASME V&V 40 factors for COU2 (VAD hemolysis, MRL 5). Twelve of thirteen factors achieved their required credibility levels. The single outstanding gap — Model Form (achievedLevel 2 vs. requiredLevel 3) — was reviewed in detail. The panel noted the extensive published literature supporting the Giersiepen–Wurzinger power-law model, the team's collective experience exceeding 30 person-years in hemolysis CFD, the conservative Monte Carlo UQ margins (95th-percentile predictions remain 18% below the clinical threshold), and the endorsement of two independent external experts. The panel further noted that formal cross-validation against a second independent pump geometry, while not completed within this submission, is scheduled as a post-market surveillance commitment with a defined milestone. Weighing the totality of indirect evidence — historical model use, expert elicitation, bounded probabilistic UQ, and the committed post-market activity — the panel concluded that the residual model-form uncertainty does not constitute an unacceptable risk to the submission decision at this time. The package is therefore Accepted for submission to the regulatory authority, with the post-market cross-validation commitment recorded as a condition of acceptance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
