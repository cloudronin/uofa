  "signature": "ed25519:b7d3e1f9a2c4b8d6e0f5a3c7b1d9e2f4a6c8b0d2e4f6a8c0b2d4e6f8a0c2b4d6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering blood-analog fluid properties; all regression tests pass at MRL 5.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) is under full version control with a documented regression test suite of 412 cases. All tests relevant to non-Newtonian blood-analog flows pass. SQA documentation package was reviewed by an independent software quality auditor and found compliant with 21 CFR Part 11 requirements. Achieved level 3 is consistent with the required level for MRL 5 hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent demonstrated for the governing equations including the hemolysis transport scalar.",
      "rationale": "MMS verification was performed for the incompressible Navier-Stokes solver and the power-law hemolysis scalar transport equation. Observed orders of accuracy were 1.97 (velocity) and 1.89 (hemolysis index), consistent with the nominal second-order scheme. Code verification report archived in the project document management system."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation with GCI < 5% on the hemolysis index QoI across all five operating points.",
      "rationale": "Three-level mesh refinement study was conducted at all five flow-speed combinations. Grid convergence index (GCI) for the normalized hemolysis index ranged from 1.8% to 4.3%, all below the 5% acceptance threshold. The finest mesh contained 14.2 million polyhedral cells. Asymptotic range was confirmed at four of five operating points; the fifth showed monotonic convergence with GCI 4.3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, pump speed, flow rate) match COU operating envelope within stated tolerances; traceability to NIST-traceable calibration documented.",
      "rationale": "Bench experiments used bovine blood at 37 ± 0.5 °C, hematocrit 33 ± 2%, matching the clinical VAD operating range. Flow rates and pump speeds were controlled to within ±1% of target values using NIST-traceable instrumentation. Test condition documentation reviewed and accepted by the regulatory affairs team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predictions within 25% of experimental values at all five operating points; systematic bias characterised.",
      "rationale": "CFD predictions of NIH agreed with experimental measurements to within 18% at four operating points and 23% at the fifth (highest flow rate). Systematic over-prediction bias of approximately 8% was identified and attributed to the power-law hemolysis model constants calibrated on a different pump geometry. Bias is conservative (over-predicts hemolysis), which is acceptable for regulatory purposes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, volume-averaged shear stress, residence time distribution) are directly linked to clinical hemolysis endpoints and regulatory acceptance criteria.",
      "rationale": "The primary QoI — normalized index of hemolysis — is the FDA-recognised metric for hemolysis assessment in blood-contacting devices. Secondary QoIs (volume-averaged shear stress, Lagrangian particle residence time) are mechanistically linked to the hemolysis power-law model inputs. Relevance mapping to the clinical endpoint of plasma-free hemoglobin elevation was documented in the V&V plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the FDA generic centrifugal pump geometry under VAD flow conditions; no significant geometric or operating condition extrapolation.",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal pump — the same geometry used in the COU simulations — across the full VAD operating envelope (3000–5000 RPM, 3–8 L/min). No geometric extrapolation is required. The validation dataset spans the intended COU operating space, satisfying the relevance criterion at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated with residuals below 1e-5 for all equations; mass imbalance < 0.01%.",
      "rationale": "All simulations converged to scaled residuals below 1e-6 for continuity and momentum equations and below 1e-7 for the hemolysis scalar. Global mass imbalance was below 0.005% in all cases. Convergence histories are archived and reviewed as part of the simulation quality checklist."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup peer-reviewed by a second qualified analyst; boundary conditions and material properties independently verified against the V&V plan.",
      "rationale": "All simulation input decks were independently reviewed by a second CFD analyst with VAD modelling experience. Boundary conditions, material property assignments, and solver settings were verified against the approved V&V plan. Two discrepancies were identified during peer review (incorrect reference pressure location and missing wall roughness specification) and corrected prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis constitutive model (power-law damage accumulation) must be validated against multiple independent experimental datasets covering the COU shear-stress and exposure-time ranges, with demonstrated predictive capability at MRL 5.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was validated against the FDA pump experimental dataset used in this assessment and against two published centrifugal pump datasets from the literature (Zhang et al. 2011; Hariharan et al. 2018). Across these three datasets the model reproduces measured NIH values within the output comparison tolerance. The team acknowledges that the power-law exponents were originally calibrated on Couette-flow viscometer data and that their applicability to the complex, time-varying shear histories present in rotary blood pumps has not been formally demonstrated through a dedicated sensitivity study at MRL 5. However, the team notes that (i) the model has been used in more than 15 prior regulatory submissions for similar devices without objection from FDA reviewers, (ii) a panel of three independent hemolysis modelling experts reviewed the model form selection and expressed confidence in its suitability for this COU, and (iii) the Monte Carlo UQ propagation — which sampled the power-law exponents across their published uncertainty ranges — showed that hemolysis index predictions remained below the clinical threshold even at the 97.5th percentile of the parameter distribution. Taken together, the team considers these compensating lines of evidence sufficient to support acceptance of the model form for this COU, notwithstanding the formal gap between the achieved level (2 — model validated on related but not COU-specific shear histories) and the required level (3 — model validated on datasets directly representative of the COU shear environment with documented sensitivity analysis). The shortfall is acknowledged in the risk register and will be addressed in the next development cycle through a dedicated Couette-to-pump shear-history mapping study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (fluid properties, pump geometry, boundary conditions) characterised with quantified uncertainties; Monte Carlo propagation performed.",
      "rationale": "A comprehensive input uncertainty characterisation was performed covering blood viscosity (non-Newtonian Carreau model parameters), density, pump impeller geometry tolerances (±0.05 mm), inlet velocity profile, and outlet pressure boundary conditions. Monte Carlo sampling (500 runs, Latin hypercube) propagated input uncertainties through the hemolysis model. The 95th percentile NIH prediction remained 18% below the clinical threshold, providing a quantified safety margin."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point; inter-replicate variability characterised.",
      "rationale": "Five independent experimental replicates were performed at each of the five operating points using separate blood samples from different donors. Inter-replicate coefficient of variation for NIH ranged from 6.2% to 11.4%, consistent with published variability for this assay. Statistical characterisation of experimental uncertainty was incorporated into the validation metric calculation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters match experimental conditions within measurement uncertainty; any discrepancies are quantified and their impact on QoI assessed.",
      "rationale": "Simulation inlet velocity profiles were derived from laser Doppler velocimetry measurements taken during the validation experiments, ensuring direct equivalency. Blood viscosity parameters were fitted to rheometry data from the same blood samples used in hemolysis testing. Residual discrepancies in pump rotational speed (±0.3% due to tachometer resolution) were assessed via sensitivity runs and found to produce NIH variations of less than 1.5%."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-hemolysis-acceptance",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 ASME V&V 40 credibility factors for the COU2 hemolysis prediction model. Twelve of thirteen factors meet or exceed their required levels, demonstrating a high degree of overall simulation credibility. The single shortfall — Model form achieving level 2 against a required level of 3 — was reviewed in detail. The panel determined that three compensating lines of evidence collectively provide sufficient confidence to support an Accepted decision: (1) the power-law hemolysis model has been applied without regulatory objection in more than 15 prior 510(k) and PMA submissions for rotary blood pumps, establishing a substantial precedent base; (2) an independent expert panel of three hemolysis modelling specialists, convened specifically for this assessment, unanimously concluded that the model form is appropriate for the VAD operating regime despite the absence of a formal shear-history mapping study; and (3) the Monte Carlo uncertainty quantification, which sampled power-law exponent uncertainty across the full published range, demonstrated that the 97.5th percentile hemolysis index prediction remains 14% below the absolute clinical threshold, providing a quantified probabilistic safety margin that partially compensates for model form uncertainty. The panel acknowledges that these arguments are supplementary rather than formally closing the level 3 gap, and has recorded the shortfall in the project risk register with a committed remediation timeline. On balance, the weight of evidence — twelve factors fully met, one factor with documented compensating evidence and a conservative predictive bias — supports an Accepted outcome for this COU. The decision is conditional on completion of the shear-history mapping study prior to final regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
