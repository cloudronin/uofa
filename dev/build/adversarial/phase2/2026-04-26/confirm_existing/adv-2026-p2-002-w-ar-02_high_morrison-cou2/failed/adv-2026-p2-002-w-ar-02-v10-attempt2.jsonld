  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/cou2-vad-hemolysis-absolute",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-dataset",
    "https://uofa.net/synth/data/fda-pump-hemolysis-experimental"
  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-piv-velocity-fields",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 5 operating points",
      "description": "Particle image velocimetry measurements acquired at 2500 RPM, 3500 RPM, and 4500 RPM across three flow rates. CFD predictions of mean velocity magnitude agree within 8% RMS across the impeller passage. Turbulent kinetic energy predictions show systematic underprediction of 15–22% in the blade wake region."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index",
      "type": "ValidationResult",
      "name": "Normalized index of hemolysis comparison",
      "description": "NIH values predicted by the power-law hemolysis model are compared against in-vitro measurements from fresh porcine blood at matched operating conditions. Mean absolute error is 0.0031 g/100 L across 12 experimental replicates; however, two high-shear operating points exhibit prediction errors exceeding 40% of the measured value, indicating model form sensitivity under extreme conditions."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "1000-sample Monte Carlo propagation of inlet boundary condition uncertainty, blood viscosity, and hemolysis model coefficients. 95th-percentile prediction interval spans a factor of 2.8 relative to the nominal prediction at the highest-risk operating point, indicating substantial parametric sensitivity. Sensitivity indices confirm hemolysis model exponents dominate total output variance (Sobol first-order index 0.61)."
    }
  ],
