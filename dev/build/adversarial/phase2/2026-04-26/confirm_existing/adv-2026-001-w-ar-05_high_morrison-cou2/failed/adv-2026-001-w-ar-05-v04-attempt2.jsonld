  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-w-ar-05",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence package on the basis that (1) all five operating-point predictions fall below the absolute clinical hemolysis threshold, (2) Monte Carlo UQ demonstrates that the 95th-percentile NIH remains below threshold, and (3) the secondary validation comparison against the Taskin 2012 dataset yields a 15.8% relative error deemed acceptable for a Class III hemolysis assessment at this stage of development. The team noted that multiple credibility factors remain below required levels but concluded that the threshold-exceedance margin (NIH_95th = 0.0048 vs. threshold 0.005) provides sufficient engineering confidence. The absence of a paired experimental comparator for the primary validation result and the flow-condition mismatch in the secondary comparator were acknowledged in meeting minutes but were not treated as blocking findings. The decision reflects the team's judgment that the weight of available evidence, including the Monte Carlo UQ and the Taskin comparison, is sufficient to support a conditional acceptance pending acquisition of in-COU experimental hemolysis data in the next development phase.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
