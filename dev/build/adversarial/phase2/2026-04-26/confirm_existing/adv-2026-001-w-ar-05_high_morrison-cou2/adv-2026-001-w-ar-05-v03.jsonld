  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the simulation evidence on the basis that the Output Comparison factor demonstrated agreement within the ±15% acceptance band at the nominal operating point (3000 RPM / 5 L/min), and that the Graefe et al. (2022) dataset is a well-regarded experimental benchmark in the centrifugal pump hemolysis literature. The team noted that all seven assessed credibility factors achieved levels below their required levels, and that six factors were not assessed, but concluded that the demonstrated agreement at the nominal point, combined with Monte Carlo UQ showing 95% confidence intervals below the absolute clinical hemolysis threshold, constituted sufficient evidence for regulatory submission. The inference that single-point validation generalises to the full five-point COU operating envelope was not formally challenged. The absence of a comparedAgainst link in the primary validation result was not flagged during internal review.",
