  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction — primary validation (COU2 operating envelope)",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were compared against published experimental measurements from the FDA generic centrifugal pump benchmark. The Lagrangian power-law hemolysis model (Giersiepen coefficients) was applied to particle-tracked stress histories extracted from the converged RANS solution ensemble. Monte Carlo propagation across rheological and boundary-condition uncertainties yielded 95th-percentile NIH bounds. The experimental reference dataset, widely regarded as the most comprehensive publicly available hemolysis benchmark for this geometry, showed strong agreement with predicted mean NIH across the five COU2 operating points (mean absolute error 8.3%, within the accepted 15% tolerance band for MRL 5 absolute predictions). No systematic bias was detected in the residual distribution. On this basis the hemolysis prediction capability is judged sufficient to support regulatory submission.",
      "meetsAcceptanceCriteria": true,
      "quantitativeMetric": "meanAbsoluteError",
      "metricValue": 0.083,
      "metricUnit": "dimensionless fraction"
    },
    {
      "id": "https://uofa.net/synth/validation/low-shear-comparator",
      "type": "ValidationResult",
      "name": "Hemolysis model calibration — low-shear regime cross-check",
      "description": "A secondary validation exercise compared CFD-predicted NIH against in-vitro hemolysis measurements collected at 3 L/min / 3000 RPM (Ding et al. 2015, FDA pump, porcine erythrocytes, modified Coomassie assay). These conditions were selected because they represent the only publicly available dataset with fully characterised inlet hematocrit and temperature control for the FDA generic centrifugal geometry. Agreement at this operating point (NIH_pred = 0.0041, NIH_exp = 0.0038, relative error 7.9%) was taken as evidence that the hemolysis constitutive model is correctly implemented. The assessment team noted that the geometric fidelity of the simulation matches the experimental hardware to within manufacturing tolerances.",
      "meetsAcceptanceCriteria": true,
