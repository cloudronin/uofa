  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "MRL 5 requires documented version control, regression test suite covering hemolysis sub-model, and independent code review.",
      "rationale": "Version control and regression testing are in place for the CFD solver (ANSYS Fluent 2023 R2). The hemolysis user-defined function (UDF) is tracked in a separate git repository with unit tests covering 80 % of code paths. Independent code review was initiated but not completed at time of submission; one open finding regarding UDF boundary-condition handling remains unresolved. Achieved level 3 — systematic QA processes present but independent review gap prevents level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark verification of the hemolysis transport equation at MRL 5.",
      "rationale": "The Navier-Stokes solver was verified against the FDA nozzle benchmark (ASME V&V 11 round-robin). The hemolysis transport scalar equation was verified against an analytical solution for a simplified Couette geometry. However, verification of the coupled rotating-frame / hemolysis interaction was not performed. Achieved level 3 — component verification complete, system-level coupling verification absent."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI on hemolysis QoI across at least three mesh refinement levels.",
      "rationale": "Grid convergence study performed on three meshes (4.2 M, 11.7 M, 28.4 M elements) at the 6 LPM / 3000 RPM operating point. GCI for NIH = 8.3 %, within the 10 % threshold at level 3. Study was not repeated at the highest-shear operating point (8 LPM / 3600 RPM), leaving uncertainty in discretization error at the most hemolysis-critical condition. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope including flow regime, pulsatility index, and fluid rheology.",
      "rationale": "The primary validation dataset (Bludszuweit 1995) was acquired under steady laminar pipe flow. The VAD COU involves pulsatile, turbulent-dominated impeller flow with Womersley number ~12 and turbulent intensity up to 25 % in the impeller passages. Fluid rheology (hematocrit, viscosity) and shear-stress magnitude overlap well, but the flow unsteadiness regime does not. The secondary predicate comparison used a pulsatile mock loop but covered only one of five required operating points. Achieved level 2 — partial condition match; pulsatility and turbulence regime not validated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of CFD-predicted NIH against experimental measurements at all five COU operating points, with uncertainty quantification on both simulation and experimental sides, using a comparator appropriate for the pulsatile turbulent VAD flow regime.",
      "rationale": "Quantitative NIH comparison was performed against the Bludszuweit steady-laminar correlation at all five operating points, with simulation-side uncertainty from Monte Carlo UQ. The Bludszuweit correlation is widely accepted in the hemolysis literature and the agreement metrics (MAE 0.0031 g/100 L, max relative error 11.8 %) are strong. However, the correlation was derived from steady laminar conditions and does not incorporate turbulent stress contributions to red-cell lysis, which are known to be significant in rotary blood pumps. Experimental uncertainty on the correlation coefficients is not propagated. The output comparison is therefore quantitatively favorable but rests on a comparator whose regime applicability to pulsatile turbulent VAD flow has not been established. Achieved level 3 — quantitative comparison present but comparator regime mismatch limits credit to level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoI must be the same metric (NIH) used in the clinical acceptance criterion, at clinically relevant operating conditions.",
      "rationale": "NIH is the correct QoI and is used consistently throughout. Validation was performed at the same five flow-speed combinations as the COU. The QoI definition (ASTM F1841) is applied consistently between simulation and experiment. Relevance is high for the metric itself; the gap is in the experimental conditions underlying the validation comparator, not the QoI definition. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full COU envelope including pulsatile turbulent impeller flow; at least three of five operating points must have matched experimental comparators.",
      "rationale": "Validation activities were planned to cover all five operating points using the Bludszuweit correlation as the primary comparator. The correlation spans the shear-stress range of interest but was not derived from rotating-machine or pulsatile-flow experiments. The secondary pulsatile comparison covers one operating point. Overall, the validation activity envelope does not adequately represent the COU flow physics. Achieved level 2 — validation activities partially relevant; critical flow-regime gap unaddressed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error documented for all operating points; residuals below 1e-5 for continuity and momentum.",
      "rationale": "Residual convergence to 1e-4 was achieved for all five operating points. Continuity residual stalled at 3e-4 at the 8 LPM / 3600 RPM point due to high impeller tip speed. Round-off error analysis was not performed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol, independent reviewer sign-off on boundary condition setup, and sensitivity check on user-controlled parameters.",
      "rationale": "A simulation protocol document exists and boundary conditions were reviewed internally. Sensitivity to turbulence model inlet boundary conditions was checked at one operating point. Independent reviewer sign-off was not obtained. Achieved level 2.",
      "id": "https://uofa.net/synth/factor/use-error-cou2"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection (turbulence model, hemolysis constitutive law) justified for pulsatile turbulent rotary pump flow with documented sensitivity study.",
      "rationale": "The k-omega SST turbulence model was selected based on prior FDA nozzle benchmark experience. The Giersiepen-Wurzinger power-law hemolysis model was used. Neither model has been specifically validated for pulsatile turbulent impeller-passage flow. A turbulence model sensitivity study (k-epsilon vs. SST) was performed at one operating point showing 22 % difference in NIH, indicating high model-form sensitivity. This sensitivity was noted but not resolved. Achieved level 2 — model form selection insufficiently justified for the COU flow regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All hemolysis model input parameters characterized with uncertainty distributions; Monte Carlo propagation performed.",
      "rationale": "Monte Carlo UQ (n = 500, Latin hypercube sampling) was performed on seven hemolysis model parameters including power-law exponents, blood viscosity, and hematocrit. Distributions were drawn from literature; no device-specific measurements of blood rheology were made. Achieved level 3 — UQ performed but input distributions not device-specific."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of blood sample variability (donor variability, storage conditions) in experimental comparator datasets.",
      "rationale": "The Bludszuweit (1995) dataset used bovine blood; donor and storage variability are not reported in the original publication. The secondary predicate comparison does not report sample characterization. No independent characterization of test sample variability was performed for this assessment. Flagged as epistemic gap at MRL 5. Achieved level 1 — not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that input parameters used in validation experiments are equivalent to those in the COU device operating envelope.",
      "rationale": "Equivalency of input parameters between the Bludszuweit pipe-flow experiments and the VAD COU was not formally assessed. The shear-stress magnitudes overlap, but exposure time distributions, flow path geometry, and pulsatility differ substantially. No mapping from validation inputs to COU inputs was documented. Flagged as epistemic gap. Achieved level 1 — not assessed."
    }
