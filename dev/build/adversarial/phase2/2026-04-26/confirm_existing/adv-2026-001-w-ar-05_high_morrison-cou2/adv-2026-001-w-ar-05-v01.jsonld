  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel accepted the simulation evidence for COU2 on the basis that quantitative NIH agreement with the Bludszuweit correlation was within 12 % across all five operating points, Monte Carlo UQ was performed, and the FDA generic pump geometry was used consistently. The panel noted that several credibility factors achieved levels below required levels at MRL 5 but concluded that the strong quantitative agreement in the Output Comparison factor, combined with the wide adoption of the Bludszuweit correlation in rotary blood pump literature, provided sufficient aggregate evidence. The panel did not specifically examine whether the steady-laminar flow regime of the Bludszuweit dataset is appropriate for pulsatile turbulent VAD conditions, treating the correlation's literature prevalence as a proxy for regime applicability.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
