    "https://uofa.net/synth/data/morrison-monte-carlo-uq-ensemble-2024"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis model validation — Bludszuweit correlation agreement",
      "description": "The CFD hemolysis sub-model was evaluated against the Bludszuweit (1995) power-law hemolysis correlation derived from steady laminar pipe-flow experiments with bovine erythrocytes at 37 °C, hematocrit 40 %, over shear-stress exposures of 50–400 Pa·s. Agreement between CFD-predicted normalized index of hemolysis (NIH) and the correlation was within 12 % across all five operating points, with mean absolute error 0.0031 g/100 L. The dataset is widely cited in blood-contacting device literature and is regarded as a high-quality reference for shear-induced red-cell lysis. Uncertainty bounds from the Monte Carlo ensemble (n = 500 Latin hypercube samples) overlapped the correlation values at all points, confirming that parametric uncertainty does not explain the residual discrepancy. The validation team concluded that the hemolysis sub-model demonstrates adequate predictive fidelity for the quantities of interest specified in COU2. No systematic bias was identified in the NIH predictions. This result is considered the primary evidence of model validity for the absolute hemolysis acceptance criterion.",
      "quantitativeMetric": "Mean absolute error in NIH: 0.0031 g/100 L; maximum relative error: 11.8 %",
      "validationStatus": "passed",
      "validationDate": "2025-11-03T00:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/secondary-predicate-comparison",
      "type": "ValidationResult",
      "name": "Secondary validation — predicate device hemolysis comparison",
      "description": "As a supplementary check, CFD-predicted NIH values were compared against published in-vitro hemolysis measurements from a predicate centrifugal VAD (HeartMate II surrogate bench test, pulsatile mock loop, 6 LPM / 3000 RPM operating point). Agreement was within 18 % at the single overlapping operating point. This comparison is considered supporting evidence only; the primary validation basis is the Bludszuweit correlation agreement reported in the companion result.",
      "quantitativeMetric": "Relative error in NIH at 6 LPM / 3000 RPM: 17.4 %",
      "validationStatus": "passed",
      "validationDate": "2025-11-10T00:00:00Z",
