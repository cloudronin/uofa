  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-w-ar-05",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD model provides sufficient evidence to support regulatory submission for the VAD indication. The secondary validation result against the Bludszuweit-Hoppe steady-flow dataset (MARE 11.4%) was cited as the primary quantitative basis for confidence in model fidelity. The team noted that the pump geometry, blood analogue properties, and four of five operating points are shared between the comparator dataset and the COU, and judged the remaining differences to be within acceptable engineering tolerance. Gaps in pulsatile flow validation and model form assessment were acknowledged but characterised as conservative in the direction of over-predicting hemolysis, and therefore acceptable for a Class III submission at MRL 5. The decision does not address whether the steady-flow comparator is an appropriate reference for a pulsatile VAD COU, nor does it bound the extrapolation uncertainty introduced by the waveform mismatch.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
