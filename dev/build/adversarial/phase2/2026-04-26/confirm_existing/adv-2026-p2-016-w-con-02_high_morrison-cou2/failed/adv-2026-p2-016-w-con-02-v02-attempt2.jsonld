      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with traceability to release version; configuration management records required.",
      "rationale": "SQA documentation exists for the commercial CFD solver but version-specific test suite results are not publicly available; achieved level remains at 2 against required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-machinery benchmarks demonstrating expected convergence rates.",
      "rationale": "Code verification was limited to steady-state lid-driven cavity; rotating impeller benchmark not included. Convergence order confirmed for laminar flows only, insufficient for turbulent hemolysis regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI on hemolysis index QoI with at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed; GCI on hemolysis index is 18%, exceeding the 5% threshold required at MRL 5. Achieved level 3 reflects partial compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within stated uncertainty bands for all 5 operating points.",
      "rationale": "Inlet flow waveform uncertainty not fully characterized in the FDA dataset; only 3 of 5 operating points have matching pressure boundary data. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel or area validation metric) applied to hemolysis index with uncertainty-band overlap assessment.",
      "rationale": "Output comparison performed using relative error metric; mean E_rel = 34% across operating points, well above the 10% acceptance threshold. Experimental uncertainty bands do not overlap CFD predictions at 3 of 5 points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be the absolute modified index of hemolysis (MIH) at patient-representative shear-stress exposure times.",
      "rationale": "QoI defined as MIH but exposure-time distribution derived from particle tracking with only 500 particles per operating point; statistical convergence of exposure-time PDF not demonstrated. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the identical pump geometry under VAD operating conditions (not scaled or analogous geometries).",
      "rationale": "Validation used the FDA generic pump geometry which is representative but not identical to the target VAD device. Geometric similarity is high but not exact; biological fluid properties differ from saline-based experimental proxy. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; floating-point round-off analysis for hemolysis accumulation integral.",
      "rationale": "Solver error assessment not performed. Residual tolerances set at 1e-4 (default); no round-off analysis conducted for the hemolysis power-law integral. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent re-analysis by second analyst; documented simulation protocol with deviation log.",
      "rationale": "No independent re-analysis performed. Single analyst conducted all simulations without a formal simulation protocol or deviation log. Use error assessment flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of at least two turbulence closure models and two hemolysis power-law constants against experimental data; sensitivity of MIH to model-form choices quantified.",
      "rationale": "Only k-omega SST turbulence model used; no alternative turbulence closure evaluated. Hemolysis power-law constants (C, alpha, beta) taken from a single literature source without sensitivity analysis. Model form uncertainty not quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo or polynomial chaos propagation of all uncertain inputs (viscosity, density, rotational speed tolerance, inlet flow rate uncertainty) through to MIH output.",
      "rationale": "Monte Carlo UQ performed on rotational speed and inlet flow rate only; blood viscosity treated as deterministic. Full input uncertainty propagation incomplete. Achieved level 2 reflects partial UQ effort."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point with inter-sample variability reported; hematocrit and donor variability documented.",
      "rationale": "FDA dataset provides limited replicate information; donor variability and hematocrit range not reported for all operating points. Test sample characterization flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental fluid properties (saline-glycerol analog) and target blood properties with equivalency justification for hemolysis power-law applicability.",
      "rationale": "Experimental fluid was a Newtonian saline-glycerol analog; no formal equivalency analysis performed to justify applicability of hemolysis power-law constants calibrated for blood. Flagged as critical epistemic gap."
    }
