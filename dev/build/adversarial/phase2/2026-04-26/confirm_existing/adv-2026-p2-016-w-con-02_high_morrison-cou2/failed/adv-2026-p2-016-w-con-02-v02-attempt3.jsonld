  "signature": "ed25519:b1d3f5a7c9e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full version control, automated regression testing, and documented release procedures required at MRL 5.",
      "rationale": "Solver version control and build reproducibility are documented; however, automated regression test suite covers only 40% of relevant solver modules and no formal software release record exists for the hemolysis sub-model. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) or equivalent convergence order verification required for all governing equations.",
      "rationale": "Order-of-accuracy verification via MMS was completed for the Navier-Stokes momentum equations but not for the scalar hemolysis transport equation. Formal verification of the power-law damage accumulation model is absent. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for all quantities of interest with GCI < 5%.",
      "rationale": "Three-level grid refinement study performed; GCI for pressure head is 2.1% (acceptable), but GCI for wall shear stress at impeller blade trailing edge is 11.3%, exceeding the threshold. Hemolysis index GCI is 8.7%. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate clinical VAD operating envelope including hematocrit range, temperature, and pulsatile flow waveform.",
      "rationale": "In-vitro experiments used bovine blood at 35% hematocrit under steady flow; clinical VAD conditions involve human blood at 38–45% hematocrit under pulsatile flow. Temperature controlled at 37°C matching clinical conditions. Pulsatile waveform not replicated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or NRMSE) within 10% for primary QoI across all validation operating points.",
      "rationale": "NIH predictions deviate 18–34% from experimental measurements across five operating points. Agreement is outside the 10% acceptance band at four of five points. Systematic over-prediction pattern consistent with under-resolved impeller tip clearance. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI must be the absolute hemolysis index directly compared to clinical threshold; surrogate QoIs not acceptable at MRL 5.",
      "rationale": "NIH is the primary QoI and is directly compared to the clinical threshold. However, sub-lethal platelet activation and thrombus risk indices, which are mechanistically coupled to hemolysis at VAD conditions, are not assessed. These omissions represent a partial QoI coverage gap. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry, operating conditions, and fluid properties directly representative of the clinical COU.",
      "rationale": "Validation used the FDA generic pump geometry, which is a simplified analog to the actual VAD impeller. Operating conditions span 3–6 L/min at 2500–3500 RPM; clinical VAD target is 4.5–5.5 L/min at 3000 RPM. Geometric and operating condition similarity is partial. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals below 1e-6 for all equations; floating-point round-off characterization required.",
      "rationale": "Iterative residual convergence was monitored but not formally documented against a threshold criterion. Round-off error characterization was not performed. This factor is flagged as an epistemic gap at MRL 5 and remains not-assessed. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition application, and post-processing scripts by a second qualified analyst.",
      "rationale": "No independent analyst review of simulation setup or post-processing was conducted. Single-analyst workflow with no documented peer check. Epistemic gap at MRL 5. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of at least two hemolysis model formulations (e.g., Giersiepen-Wurzinger vs. Taskin) with sensitivity analysis; turbulence model uncertainty quantified.",
      "rationale": "Only the Giersiepen-Wurzinger power-law hemolysis model was applied. No alternative model form was evaluated. Turbulence model sensitivity (k-ω SST vs. k-ε) was not investigated. Model-form uncertainty is the dominant source of prediction variance per UQ results. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All material properties and boundary conditions characterized with quantified uncertainty bounds traceable to measurement data.",
      "rationale": "Blood viscosity and density are assigned nominal literature values without uncertainty bounds. Inlet velocity profile assumed uniform; actual pump inlet has spatially non-uniform flow from the inflow cannula. Hemolysis model coefficients taken from a single literature source without uncertainty characterization. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum n=5 independent biological replicates per operating point with inter-replicate variability reported.",
      "rationale": "Experimental hemolysis data sourced from a single published dataset with n=3 replicates at each operating point. Inter-replicate coefficient of variation was not reported. Insufficient sample size for MRL 5 requirements. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between experimental and simulation input parameters with documented justification for any parameter substitutions.",
      "rationale": "Bovine blood properties used in experiment were mapped to human blood properties in simulation using a viscosity correction factor without formal equivalency justification. Geometric tolerances of the FDA pump test article relative to the CAD model were not characterized. Achieved level 1 against required level 4."
