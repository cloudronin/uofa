  ],
  "referencesIdentifier": "https://doi.org/10.1016/j.ymeth.2024.03.003",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against in-vitro measurements for five operating points. Systematic over-prediction of 18–34% observed across flow rates; discrepancy attributed to unresolved near-wall shear stress gradients in impeller passages. Validation activity conducted at conditions proximal but not identical to clinical VAD operating envelope."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-uq-monte-carlo",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "2000-sample Monte Carlo propagation of inlet flow rate, fluid viscosity, and power-law hemolysis model coefficients. 95th-percentile prediction interval spans 0.0031–0.0089 g/100 L, straddling the clinical acceptance threshold of 0.006 g/100 L. Sensitivity indices indicate hemolysis model exponent contributes 61% of total output variance, confirming model-form uncertainty as dominant epistemic gap."
    }
  ],
