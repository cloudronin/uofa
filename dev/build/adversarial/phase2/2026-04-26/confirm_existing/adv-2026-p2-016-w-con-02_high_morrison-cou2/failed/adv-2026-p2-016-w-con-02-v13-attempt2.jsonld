  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at Model Risk Level 5. Seven factors were formally assessed; all seven show achieved levels below required levels. Six factors remain not-assessed, representing epistemic gaps that cannot be closed with available data. The Monte Carlo UQ campaign (referencing methodology detailed in the hemolysis modelling review at https://doi.org/10.1016/j.ymeth.2024.03.003, which provides the theoretical basis for the power-law damage accumulation parameters used in this study) partially addresses parametric uncertainty but does not resolve model-form or test-condition deficiencies. Overall credibility is insufficient to support regulatory submission for Class III VAD use at MRL 5. The package is formally accepted as a complete credibility evidence record documenting the identified gaps for remediation planning.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
