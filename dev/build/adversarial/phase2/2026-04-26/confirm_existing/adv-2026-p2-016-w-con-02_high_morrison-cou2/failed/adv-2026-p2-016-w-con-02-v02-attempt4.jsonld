  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite the Not Accepted COU-level decision, the credibility assessment package itself is formally accepted as a complete and valid documentation artifact. All 13 credibility factors have been evaluated against MRL-5 requirements. The assessment correctly identifies that 7 of 13 factors have achieved levels below required levels and 6 factors remain as epistemic gaps. The Monte Carlo UQ results, bench validation data, and factor gap analysis are accepted as the definitive basis for the regulatory submission supporting the Not Accepted device-level decision. The hemolysis prediction methodology referenced in doi:10.1016/j.ymeth.2024.03.003 was cited as the basis for the power-law calibration approach; however, that source has not been independently verified within this package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
