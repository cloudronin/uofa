  ],
  "referencesIdentifier": "https://doi.org/10.1016/j.ymeth.2024.03.003",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-01",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison at 3 L/min, 3000 RPM",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements from FDA generic pump test rig. Predicted NIH = 0.0041 g/100L; measured NIH = 0.0038 ± 0.0006 g/100L. Relative error 7.9%, within Monte Carlo 95% CI but below required MRL-5 validation fidelity threshold."
    },
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison-02",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison at 5 L/min, 2400 RPM",
      "description": "CFD-predicted NIH = 0.0029 g/100L; measured NIH = 0.0031 ± 0.0005 g/100L. Relative error 6.5%. Consistent underprediction pattern noted across flow conditions; model form uncertainty not fully characterized at MRL 5."
    },
    {
      "id": "https://uofa.net/synth/validation/uq-monte-carlo-hemolysis",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "1000-sample Monte Carlo propagation of inlet velocity, fluid viscosity, and rotor speed uncertainties through the hemolysis power-law model. 95% prediction interval spans factor of 2.1 on NIH at worst-case operating point. Interval does not exclude the clinical threshold, preventing acceptance at MRL 5."
    }
  ],
