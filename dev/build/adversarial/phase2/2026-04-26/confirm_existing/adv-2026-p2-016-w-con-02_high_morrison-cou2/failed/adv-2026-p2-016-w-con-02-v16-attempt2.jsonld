  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors reviewed against MRL 5 requirements. Seven factors were formally assessed; all seven show achieved levels below required levels. Six factors remain not-assessed, representing significant epistemic gaps. The hemolysis prediction model as currently constituted does not meet the credibility requirements for a Class III VAD submission. The assessment package itself is accepted as a complete and valid credibility evaluation record per ASME V&V 40-2018, even though the underlying model is not accepted for regulatory use. The methodology reference (doi:10.1016/j.ymeth.2024.03.003) documents the hemolysis scalar transport approach applied in this assessment.",
