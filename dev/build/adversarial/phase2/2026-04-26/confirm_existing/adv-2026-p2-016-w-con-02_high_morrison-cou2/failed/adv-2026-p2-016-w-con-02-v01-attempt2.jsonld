  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following structured review of all 13 ASME V&V 40 credibility factors at Model Risk Level 5, the assessment team accepts the credibility package as a complete and transparent characterisation of the current model state. Seven factors were formally assessed; six remain epistemic gaps. All assessed factors fall below required levels, confirming the 'Not accepted' submission decision for regulatory use. The package is accepted as a valid credibility evidence record supporting iterative model improvement planning. The hemolysis constitutive model review methodology described in the supporting literature (referencesIdentifier: https://doi.org/10.1016/j.ymeth.2024.03.003) was considered in scoping the model-form factor gap but could not be resolved within the assessment period.",
    "decidedAt": "2026-04-19T00:00:00Z"
