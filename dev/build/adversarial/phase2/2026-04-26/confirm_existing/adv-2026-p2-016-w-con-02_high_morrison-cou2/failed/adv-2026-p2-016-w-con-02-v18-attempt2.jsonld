  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a formal QA plan with version control, regression testing, and documented release procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) is used under a site license with informal version tracking. Regression test suite covers only 60% of hemolysis-relevant solver paths. No formal QA plan meeting MRL 5 standards is in place. Achieved level 2 is significantly below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include order-of-accuracy testing against manufactured solutions for all governing equations active in the hemolysis model, with documented convergence rates.",
      "rationale": "Order-of-accuracy testing was performed for Navier-Stokes equations only. The power-law hemolysis source term and non-Newtonian viscosity model were not subjected to manufactured-solution verification. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must be performed on all quantities of interest (hemolysis index, wall shear stress, pressure rise) across at least three systematically refined meshes.",
      "rationale": "Mesh refinement study used two mesh levels (4.2M and 11.7M cells). Richardson extrapolation was not achievable with only two levels. GCI estimate for hemolysis index shows 18% discretization uncertainty, well above the 3% threshold for MRL 5. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five COU operating points (flow rate, rotational speed, fluid temperature, hematocrit) within specified tolerances, with full uncertainty characterization of test rig boundary conditions.",
      "rationale": "Three of five COU operating points were replicated in the validation experiment. Hematocrit was fixed at 35% rather than the patient-representative range of 30-45%. Temperature was controlled to ±0.5°C. Partial match of operating conditions yields achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., ASME V&V 20 validation metric U_val) must be computed for hemolysis index at all operating points, with systematic error decomposition separating numerical and experimental uncertainty contributions.",
      "rationale": "Comparison was performed using normalized RMS error without uncertainty decomposition. Experimental measurement uncertainty for the hemolysis assay (NIH method) was not propagated into the validation metric. Achieved level 2 is below required level 4; the comparison methodology does not meet ASME V&V 20 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (normalized index of hemolysis, NIH) must be directly mapped to the clinical decision threshold (absolute hemolysis below 0.1 g/100L) with a documented and justified conversion methodology.",
      "rationale": "Validation was performed against NIH (normalized index of hemolysis) whereas the COU decision threshold is expressed as an absolute hemolysis concentration. The conversion from NIH to absolute units introduces an additional model-form uncertainty that was not quantified. Achieved level 2 is below required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and operating regime sufficiently similar to the COU device (Class III VAD) that extrapolation distance is quantified and bounded. Similarity metrics must be documented.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which differs from the COU VAD geometry in impeller diameter, blade count, and volute design. No quantitative similarity metric was computed. The extrapolation from validation geometry to COU device is uncharacterized. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and solver-specific errors must be quantified and shown to be negligible relative to discretization error for all hemolysis-relevant quantities.",
      "rationale": "Numerical solver error was not assessed. Residual convergence targets were set at 1e-4 for all equations, but no demonstration was made that this threshold is sufficient for hemolysis index accuracy. Flagged as epistemic gap at MRL 5. Achieved level 1 reflects absence of assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential user errors in model setup, boundary condition specification, and post-processing must be identified and mitigated through documented checklists and independent review.",
      "rationale": "No formal use-error assessment was conducted. Model setup was performed by a single analyst without independent review. Boundary condition specification for rotating reference frame and hemolysis model constants was not independently verified. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The power-law hemolysis model (Giersiepen-Wurzinger or equivalent) must be assessed for applicability to the COU operating regime, including sensitivity to model constants and comparison with alternative model forms.",
      "rationale": "Model form uncertainty for the hemolysis constitutive model was not assessed. The Giersiepen-Wurzinger power-law model was applied without sensitivity analysis on the empirical constants (C, alpha, beta). No comparison with the Taskin or Heuser-Opitz model forms was performed. This represents the most critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (fluid properties, boundary conditions, hemolysis model constants) must have documented sources with associated uncertainties. Monte Carlo UQ must propagate input uncertainties to hemolysis index predictions.",
      "rationale": "Monte Carlo UQ was performed for fluid viscosity and inlet flow rate (2 of 8 uncertain inputs). Hemolysis model constants, hematocrit, and erythrocyte mechanical properties were treated as deterministic. Partial UQ coverage yields achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental blood samples used in validation testing must be characterized for hematocrit, mean corpuscular fragility, and storage duration. Inter-sample variability must be quantified and reported.",
      "rationale": "Test sample characterization was not performed. Porcine blood was used in validation experiments without documentation of storage duration or mechanical fragility index. Inter-sample variability was not quantified. This is a significant epistemic gap for hemolysis validation at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters in the validation experiment must be demonstrated to be equivalent to COU input parameters within specified tolerances, with documented mapping between experimental and COU conditions.",
      "rationale": "Equivalency of input parameters between validation experiment and COU was not formally assessed. Porcine blood properties differ from human blood in viscosity-shear relationship and erythrocyte fragility. No equivalency mapping document was produced. Flagged as epistemic gap at MRL 5."
    }
