  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite the COU-level decision of Not Accepted, the credibility assessment package itself is accepted as a complete and valid characterization of the model's current credibility state. The assessment correctly identifies all 13 credibility factors per ASME V&V 40-2018, documents achieved versus required levels for all assessed factors, and flags six epistemic gaps at MRL 5. The package references the hemolysis modeling methodology described in the literature (see referencesIdentifier) as the basis for the power-law model selection and Monte Carlo UQ approach. The assessment team accepts this package as the authoritative credibility record for COU2, with the explicit understanding that the model is not accepted for regulatory submission until all factor gaps are resolved.",
