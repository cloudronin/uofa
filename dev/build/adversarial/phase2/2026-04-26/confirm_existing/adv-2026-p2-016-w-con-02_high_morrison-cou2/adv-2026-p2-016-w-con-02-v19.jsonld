  "referencesIdentifier": "https://doi.org/10.1016/j.ymeth.2024.03.003",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-piv-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA centrifugal pump benchmark",
      "description": "Computational velocity fields compared against FDA-commissioned particle image velocimetry (PIV) data for the generic centrifugal pump at 3500 RPM, 6 L/min. Mean absolute error in axial velocity < 8 % across measurement planes. Hemolysis index predictions show systematic over-prediction of approximately 15 % relative to in-vitro haemolysis measurements; bias attributed in part to power-law coefficient uncertainty sourced from the primary literature reference."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification — hemolysis index distribution",
      "description": "1 000-sample Monte Carlo propagation of inlet flow rate, rotational speed, blood viscosity, and power-law damage exponents. 95th-percentile hemolysis index remains below the clinical threshold of 0.8 g/dL across all 5 operating points. Coefficient of variation on hemolysis index: 22 %. Sensitivity analysis identifies power-law exponent C as the dominant uncertainty contributor (Sobol index 0.61)."
    }
  ],
