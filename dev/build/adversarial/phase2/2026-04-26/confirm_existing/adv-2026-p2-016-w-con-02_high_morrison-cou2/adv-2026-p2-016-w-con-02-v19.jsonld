  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-accepted-conditional",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team accepts the package on a conditional basis. Seven of thirteen credibility factors show achieved levels below required levels, and six factors remain not-assessed. The primary reference for hemolysis power-law coefficients (doi:10.1016/j.ymeth.2024.03.003) is cited via referencesIdentifier but the corresponding node is not resolved within the local package graph, leaving model-input provenance partially unverifiable. Acceptance is conditional on the sponsor (a) completing independent use-error review, (b) providing human-blood test sample data, (c) resolving the coefficient provenance gap by supplying a fully typed evidence node for the referenced publication prior to PMA submission, and (d) conducting a formal equivalency mapping between validation and COU conditions. Monte Carlo UQ demonstrates 95th-percentile hemolysis index below the clinical threshold at all 5 operating points, providing sufficient interim assurance to proceed to the next development phase.",
    "decidedAt": "2026-04-19T00:00:00Z"
