      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a formal QMS with traceability to ASME V&V 40 requirements; version control, regression testing, and audit trails required at MRL 5.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) is commercially licensed and documented, but the hemolysis user-defined function (UDF) lacks formal regression testing and change-control records. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions (MMS) verification required for all governing equations including hemolysis transport at MRL 5.",
      "rationale": "MMS verification was completed for Navier-Stokes solver but not extended to the power-law hemolysis transport equation. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis required on hemolysis index QoI with three systematically refined meshes at MRL 5.",
      "rationale": "Three-mesh GCI study performed; discretization error on hemolysis index is 8.3% at the finest mesh level. This exceeds the MRL 5 threshold of 5%. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope with full characterisation of blood analogue rheology, temperature, and anticoagulation protocol. Uncertainty in boundary conditions must be quantified.",
      "rationale": "FDA benchmark experimental data used; test conditions cover 5 of 8 target operating points. Blood analogue viscosity uncertainty is reported but temperature drift during hemolysis measurement is uncharacterised. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or U95 overlap) required for hemolysis index QoI with statistical significance testing at MRL 5.",
      "rationale": "Hemolysis index predictions deviate by 18–42% from experimental values across operating conditions. No statistical significance testing was performed. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be the absolute normalised index of hemolysis (NIH) directly comparable to clinical thresholds. Surrogate QoIs (e.g., shear stress) are insufficient at MRL 5.",
      "rationale": "NIH is the primary QoI and is directly compared to clinical threshold. However, the model also reports scalar shear stress as a secondary QoI without establishing its clinical relevance mapping. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, rotational speed range, and blood analogue as the COU. Any geometric or operational differences must be formally justified with sensitivity analysis.",
      "rationale": "Validation uses the FDA generic pump geometry which differs from the proprietary VAD geometry in impeller blade count and volute clearance. No geometric sensitivity analysis bridges this gap. Achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver tolerance sensitivity must be formally characterised for hemolysis transport at MRL 5.",
      "rationale": "Solver error for the hemolysis UDF has not been assessed. Residual convergence is monitored for flow equations only. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented operator qualification, simulation execution checklist, and independent review of model setup required at MRL 5.",
      "rationale": "No formal use-error assessment has been conducted. Operator qualifications are not documented in the credibility dossier. Flagged as epistemic gap. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model-form uncertainty quantification required, including comparison of power-law hemolysis model against alternative formulations (e.g., Giersiepen, Taskin) at MRL 5.",
      "rationale": "Only the Giersiepen power-law model is implemented. No model-form uncertainty study comparing alternative hemolysis damage accumulation formulations has been performed. Flagged as critical epistemic gap at MRL 5. Achieved level 1 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo or equivalent UQ on all model inputs (blood viscosity, density, hemolysis model constants C and alpha) with sensitivity ranking required at MRL 5.",
      "rationale": "Monte Carlo UQ was initiated for inlet flow rate and rotational speed but the hemolysis model empirical constants (C, alpha, beta) were treated as fixed. These constants are the dominant source of predictive uncertainty. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterisation of experimental sample variability (inter-sample, inter-lab) required with minimum n=5 independent replicates per operating condition at MRL 5.",
      "rationale": "FDA benchmark dataset provides single-laboratory measurements with n=3 replicates. Inter-laboratory variability has not been characterised. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument required demonstrating that validation experiment input parameters (geometry, fluid properties, operating conditions) are representative of the COU VAD operating envelope.",
      "rationale": "No formal equivalency assessment bridges the FDA generic pump validation domain to the proprietary VAD COU. Geometric, rheological, and operational differences are acknowledged but unquantified. Flagged as critical epistemic gap. Achieved level 1 against required level 5."
    }
