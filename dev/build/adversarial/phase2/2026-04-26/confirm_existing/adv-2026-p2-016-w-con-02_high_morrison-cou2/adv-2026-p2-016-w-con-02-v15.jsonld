  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction at MRL 5 identifies substantial gaps across all 13 credibility factors. Seven factors were assessed with achieved levels uniformly below required levels; six factors remain unassessed. The hemolysis model-form uncertainty and equivalency of input parameters represent the most critical unresolved gaps. The assessment team notes that the methodology applied follows the framework described in the literature, including the approach documented in the hemolysis damage accumulation review (doi:10.1016/j.ymeth.2024.03.003), which informed the factor weighting scheme. Despite these gaps, the package is accepted as a credibility dossier submission for regulatory review, with the understanding that the identified gaps must be addressed prior to device submission. The decision outcome reflects acceptance of the dossier as complete for its current stage, not acceptance of the model for regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
