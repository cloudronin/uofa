  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering at least 80% of relevant physics modules; independent code review completed.",
      "rationale": "The CFD solver (ANSYS Fluent 2023R1) is version-controlled and has a documented regression test suite. However, independent third-party code review has not been completed for the hemolysis sub-model; achieved level 3 falls short of the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests demonstrate convergence at theoretical rate for all governing equations including the hemolysis transport equation.",
      "rationale": "Order-of-accuracy tests confirm second-order convergence for momentum and continuity. The hemolysis scalar transport equation achieves only first-order verified convergence on unstructured meshes near the impeller tip; this gap prevents achievement of level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis yields discretization uncertainty below 5% on hemolysis index QoI across all five operating points.",
      "rationale": "GCI analysis on three systematically refined meshes (4.2 M, 12.6 M, 37.8 M cells) yields discretization uncertainty of 8–14% on the hemolysis index at high-speed operating points. This exceeds the 5% threshold required for level 4; achieved level is 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol) match COU operating envelope within stated tolerances; traceability documented.",
      "rationale": "FDA pump bench tests used bovine blood at 37 °C with hematocrit 33±2%. COU specifies human blood at 37 °C with hematocrit 35–45%. The hematocrit gap and species difference reduce achieved level to 3; full traceability documentation is available but condition matching is incomplete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric U_val) computed for hemolysis index at each operating point; model error within combined experimental and simulation uncertainty.",
      "rationale": "The ASME V&V 20 validation metric is computed at all five operating points. At two high-flow points the model error exceeds the combined uncertainty band by 1.2–1.8 standard deviations, indicating systematic over-prediction. Achieved level 3 reflects partial quantitative agreement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) is directly linked to the clinical endpoint (plasma free hemoglobin) via a validated power-law damage accumulation model with documented uncertainty in model coefficients.",
      "rationale": "NIH is the accepted clinical surrogate; the Giersiepen-Wurzinger power-law model links shear stress history to NIH. Coefficient uncertainty (±40% on exponent) is propagated via Monte Carlo. The indirect nature of the QoI-to-clinical-endpoint linkage and coefficient uncertainty prevent achievement of level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the same device geometry under COU-representative operating conditions; no surrogate geometry used.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which is a surrogate for the proprietary VAD geometry. Geometric similarity metrics (blade angle, gap clearance) are within 15% but the impeller diameter differs by 22%. This geometric surrogate gap substantially reduces relevance; achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine precision for all residuals; floating-point round-off error estimated and shown negligible relative to discretization error.",
      "rationale": "Iterative convergence to 1e-5 is documented for momentum and continuity residuals. Round-off error analysis has not been performed; the hemolysis scalar residual stalls at 1e-3 for two operating points, indicating potential solver error contributions that have not been quantified. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent analyst re-execution check; boundary condition application verified by second analyst.",
      "rationale": "No independent re-execution check was performed. Boundary condition application (rotating frame, interface treatment) was set by a single analyst without peer verification. Use error contribution to total uncertainty is unquantified. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by turbulence-resolving reference data (LES or DNS) at representative Reynolds numbers; hemolysis model form uncertainty quantified.",
      "rationale": "The k-omega SST turbulence model was selected based on published pump validation studies. No LES or DNS reference data exist for this pump geometry at VAD operating Reynolds numbers. Hemolysis model form uncertainty is partially addressed via the Morrison et al. (2024) methodology (cited as referencesIdentifier in this package), but the form uncertainty contribution remains the dominant unresolved epistemic source."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model inputs (blood viscosity, density, hemolysis model coefficients) characterised with probability distributions; sensitivity analysis identifies dominant inputs.",
      "rationale": "Blood viscosity and density are treated as deterministic nominal values. Hemolysis model coefficients are sampled in Monte Carlo but their distributions are assumed uniform based on literature range rather than measured uncertainty. Dominant input sensitivity analysis has not been completed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum of three independent blood sample lots with documented hematocrit, donor age, and anticoagulant; inter-lot variability quantified and propagated.",
      "rationale": "Experimental data were collected using a single bovine blood lot per test session. Inter-lot variability has not been characterised. Sample traceability documentation is incomplete. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that validation experiment input parameters span the COU operating envelope; gap analysis documented.",
      "rationale": "No formal equivalency argument has been constructed. The validation operating envelope (3–6 L/min, 2400–3200 RPM) partially overlaps the COU envelope (4–8 L/min, 2800–4000 RPM) but the upper quadrant of the COU space is not covered by any validation data. Flagged as critical epistemic gap."
    }
