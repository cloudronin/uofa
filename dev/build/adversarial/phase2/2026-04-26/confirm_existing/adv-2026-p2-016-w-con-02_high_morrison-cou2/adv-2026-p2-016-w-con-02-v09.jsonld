  "signature": "ed25519:b4e2d1f3a5c7e9b0d2f4a6c8e0b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis comparison against FDA pump experimental data",
      "description": "CFD-predicted hemolysis index values compared against published experimental measurements for the FDA generic centrifugal pump. Predictions systematically underestimate peak hemolysis zones by 18–34% across operating points. Validation evidence cited in Faghih & Sharp (2019) and corroborated by the power-law damage model review referenced via DOI 10.1016/j.ymeth.2024.03.003, which provides the updated mechanistic basis for shear-induced RBC damage thresholds used in this assessment."
    },
    {
      "id": "https://uofa.net/synth/validation/monte-carlo-uq-sweep",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification sweep across 5 operating conditions",
      "description": "1000-sample Monte Carlo sweep over inlet boundary conditions, viscosity, and power-law damage model exponents. 95th-percentile hemolysis index predictions exceed the absolute clinical threshold at 3 of 5 operating points, confirming insufficient predictive margin for Class III regulatory submission."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under formal configuration management with documented V&V test suite results at required level.",
      "rationale": "The CFD solver is under version control and has unit-test coverage, but formal qualification documentation does not meet MRL 5 requirements. No independent third-party audit of the solver's hemolysis sub-model has been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must confirm theoretical convergence rate for both flow and scalar transport equations used in hemolysis computation.",
      "rationale": "Order-of-accuracy verification was performed for the Navier-Stokes solver but not for the coupled power-law damage transport scalar. Convergence of the hemolysis index with grid refinement is demonstrated only informally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must bound discretization error to within 5% of hemolysis index QoI across all operating points.",
      "rationale": "Three-level mesh refinement study performed; GCI values range from 8% to 22% across operating points, exceeding the 5% acceptance threshold. Discretization error is a primary contributor to total prediction uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope (flow rates 3–8 L/min, rotational speeds 2400–3600 RPM) within stated uncertainty bounds.",
      "rationale": "Published FDA pump experimental data covers the required operating envelope. Temperature and fluid viscosity were controlled within acceptable tolerances. Minor deviations in inlet turbulence intensity between experiment and simulation are documented but not fully resolved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must demonstrate agreement within model uncertainty bounds at all operating points.",
      "rationale": "Hemolysis index predictions deviate from experimental measurements by 18–34% at peak-stress operating points. Validation metric M exceeds the acceptance threshold at 3 of 5 operating conditions. Output comparison is insufficient for MRL 5 acceptance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (normalized index of hemolysis, NIH) must directly correspond to the clinical decision threshold quantity.",
      "rationale": "NIH is the standard regulatory QoI and is used consistently between simulation and experiment. However, the absolute threshold value is derived from a literature model rather than device-specific clinical data, introducing residual relevance uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry and operating conditions sufficiently similar to the VAD COU to support extrapolation without additional bridging arguments.",
      "rationale": "Validation was performed on the FDA generic pump geometry, which differs from the proprietary VAD impeller in blade count and tip clearance. No formal similarity analysis or bridging argument has been documented to support applicability of validation evidence to the COU geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be quantified and demonstrated to be negligible relative to discretization error.",
      "rationale": "Iterative convergence monitoring was performed (residuals < 1e-5) but no formal analysis of floating-point round-off or solver tolerance sensitivity was conducted. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence must demonstrate that simulation setup, boundary condition specification, and post-processing are performed by qualified personnel following documented procedures.",
      "rationale": "No formal use-error assessment or independent simulation audit was performed. Personnel qualifications are documented but procedural adherence was not independently verified. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage model must be justified as appropriate for the flow regime and stress exposure paths in the COU, with sensitivity analysis.",
      "rationale": "SST k-omega turbulence model was selected without formal sensitivity analysis comparing alternative turbulence closures. Power-law damage model form uncertainty is acknowledged but not quantified. Critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions derived from device-specific measurements or validated literature sources, and propagated through Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was performed but input distributions for power-law exponents were taken from population-level literature rather than device-specific characterization. Input parameter uncertainty is a dominant contributor to prediction spread. Partially addressed but below required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used for validation must be representative of the patient population and device manufacturing variability, with sample size justification.",
      "rationale": "Validation data derives from a single experimental facility using one pump specimen. Inter-specimen manufacturing variability and donor blood variability are not represented. Sample representativeness is a critical gap for Class III submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters in the simulation must be demonstrably equivalent to those in the validation experiment, with formal parameter matching documentation.",
      "rationale": "Formal equivalency mapping between simulation inputs and experimental parameters has not been documented. Differences in blood analog viscosity between experiment and COU patient blood properties have not been formally bridged. Flagged as epistemic gap at MRL 5."
    }
  ],
