    "https://uofa.net/synth/data/fda-pump-piv-experimental-2023",
    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-2022"
  ],
  "referencesIdentifier": "https://doi.org/10.1016/j.ymeth.2024.03.003",
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/cou2-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — FDA pump at 3500 RPM, 5 L/min",
      "description": "Comparison of CFD-predicted velocity magnitude fields against particle image velocimetry (PIV) measurements at the impeller exit plane. GCI-corrected simulation results show mean absolute error of 0.18 m/s against experimental mean of 2.4 m/s (7.5%). Achieved validation level Gradation 2 against required Gradation 4 for MRL 5."
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs bench measurements — 5 operating points",
      "description": "Power-law hemolysis model (Giersiepen–Wurzinger coefficients) applied to Lagrangian stress accumulation along 50 000 particle tracks. Predicted normalised index of haemolysis (NIH) compared to in-vitro measurements across 5 flow-speed combinations. Mean NIH prediction error 42% (factor-of-two threshold not met). The methodology follows the framework described in the reference doi:10.1016/j.ymeth.2024.03.003, which establishes best-practice coefficient selection for power-law models; however, that reference is not resolved as a typed node within this package."
    },
    {
      "id": "https://uofa.net/synth/validation/cou2-monte-carlo-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo uncertainty quantification on hemolysis predictions",
      "description": "Latin-hypercube sampling over 12 uncertain input parameters (viscosity, density, pump clearance tolerances, rheological coefficients). 2000 CFD evaluations via surrogate (Gaussian process). 95% prediction interval spans 3.1× the nominal NIH value, exceeding the MRL 5 tolerance of ±30%. UQ requirement not met."
    }
  ],
