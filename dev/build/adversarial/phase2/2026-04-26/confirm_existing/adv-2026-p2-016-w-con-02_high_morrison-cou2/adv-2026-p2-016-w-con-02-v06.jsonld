  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cou2-hemolysis-threshold",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cou2-cfd-hemolysis-prediction",
