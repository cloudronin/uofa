  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering hemolysis-relevant flow regimes; formal SQA plan documented per MRL 5 requirements.",
      "rationale": "The CFD solver (OpenFOAM v9) is under version control with a documented regression suite; however, the hemolysis sub-model plugin lacks a formally approved SQA plan meeting MRL 5 rigor. Achieved level 3 falls below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification for all governing equations including the hemolysis damage accumulation transport equation, demonstrated on manufactured solutions.",
      "rationale": "Order-of-accuracy tests were performed for Navier-Stokes terms and confirmed second-order convergence. The damage accumulation integral was verified against an analytical manufactured solution at level 3; extension to rotating frame terms was not formally verified, preventing level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based discretization error estimate below 5% for hemolysis index QoI across all 5 operating points, with grid convergence index reported.",
      "rationale": "Three-level mesh refinement study conducted; GCI values ranged from 4.1% to 8.7% across operating points. Two of five operating points exceed the 5% threshold, limiting achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol, pump speed) documented with uncertainty bounds and traceable to ASTM F1841 or equivalent.",
      "rationale": "FDA pump experimental dataset provides documented test conditions; hematocrit variability (±2%) and temperature control (±0.5°C) are reported. Anticoagulant lot traceability is incomplete for two of six experimental runs, limiting the factor to level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation metric u_val) computed for hemolysis index at all operating points, with statistical uncertainty in experimental reference accounted for.",
      "rationale": "Relative error in normalized index of hemolysis (NIH) ranges from 12% to 31% across operating points. Experimental uncertainty is propagated using a bootstrap estimator. The spread in prediction error exceeds the level-4 threshold of 15% at three operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (NIH, plasma free hemoglobin) directly maps to clinical hemolysis threshold; traceability from CFD output to clinical metric is formally documented.",
      "rationale": "NIH is the direct regulatory QoI per FDA guidance; the mapping from CFD shear stress history to NIH via the Giersiepen-Wurzinger power-law model is formally documented. The clinical threshold (NIH < 0.01 g/100 L) is explicitly stated in the acceptance criteria. Level 4 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on geometrically and hemodynamically similar device at VAD operating conditions (flow 3–6 L/min, speed 2400–3200 RPM); blood analog fluid properties matched.",
      "rationale": "Validation uses the FDA generic pump geometry which is geometrically analogous but not identical to the subject VAD impeller. Operating conditions overlap partially (3 of 5 COU points fall within validated range). Blood analog (glycerol-water) properties are matched at 37°C. Geometric dissimilarity limits relevance to level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual below 1e-6 for all equations; round-off error assessed for double-precision arithmetic.",
      "rationale": "Momentum and continuity residuals converge to 1e-5; the scalar hemolysis transport equation stalls at 5e-5 for the highest-speed operating point due to source term stiffness. Double-precision arithmetic confirmed. Convergence shortfall limits achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal peer review of simulation setup, boundary condition specification, and post-processing scripts by an independent analyst; documented checklist.",
      "rationale": "An internal peer review was conducted but not by an analyst independent of the simulation team. The boundary condition checklist was completed; however, the rotating reference frame interface treatment was not independently verified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis model form (power-law damage accumulation) justified against mechanistic alternatives; turbulence model selection validated for rotating confined flow; non-Newtonian blood rheology assessed for relevance.",
      "rationale": "The Giersiepen-Wurzinger power-law model is used; its coefficients were fit to Couette flow data and may not generalize to complex 3-D rotating flows. SST k-omega turbulence model is used without explicit validation against rotating pump LES data. Non-Newtonian effects are neglected based on high-shear-rate argument. Multiple unresolved model form uncertainties limit achieved level to 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry tolerances, fluid properties, boundary flow rates, rotational speed) characterized with probability distributions; Monte Carlo propagation performed.",
      "rationale": "Monte Carlo UQ was performed over 6 input parameters with 500 samples. Geometry manufacturing tolerances were approximated from nominal CAD rather than measured from the physical device. Blood viscosity distribution was assumed Gaussian without experimental characterization of lot-to-lot variability. Input characterization completeness limits achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates (n ≥ 5 per operating point) with statistical power analysis; sample-to-sample variability in hemolysis measurement reported.",
      "rationale": "The FDA pump experimental dataset provides 3 replicates per operating point for most conditions; one operating point has only 2 replicates. No formal statistical power analysis was conducted. Factor flagged as not-assessed for MRL 5 purposes due to insufficient replicate count and absence of power analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that CFD boundary conditions (inlet velocity profile, outlet pressure, wall motion) are equivalent to experimental conditions within stated uncertainty bounds.",
      "rationale": "Inlet velocity profiles in the experiment were measured only at the pump inlet plane; the CFD domain extends 3 diameters upstream with a developed-flow assumption. Equivalency of the upstream boundary condition to the experimental configuration was not formally demonstrated. Factor flagged as not-assessed at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl5-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required thresholds at MRL 5, the assessment team determined that the combination of Monte Carlo UQ bounding the hemolysis prediction within the clinical safety margin, conservative model form assumptions (power-law overestimates hemolysis relative to mechanistic alternatives per the methodological reference cited via referencesIdentifier), and the conservative NIH acceptance threshold provides sufficient confidence for regulatory submission under a defined uncertainty envelope. Residual gaps in model form, test samples, and equivalency of input parameters are acknowledged and addressed through conservative safety factors applied to the NIH acceptance threshold. Decision: Accepted with conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
