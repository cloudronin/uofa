      "name": "Bench-scale hemolysis index comparison against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-pressure-head-validation",
      "type": "ValidationResult",
      "name": "Pressure-head curve validation across 5 operating points"
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan must cover version control, regression testing, and documented release procedures consistent with MRL 5 requirements.",
      "rationale": "Version control is in place and unit tests exist, but no formal regression suite covering hemolysis solver paths has been established. SQA documentation does not meet the rigor required at MRL 5 for a Class III device submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification must be documented for all relevant transport equations including the hemolysis power-law model.",
      "rationale": "Grid convergence studies were performed on velocity fields, but MMS verification of the hemolysis scalar transport equation has not been completed. Achieved level remains at 2 due to this gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must demonstrate discretization error below 5% for hemolysis index QoI at all five operating points.",
      "rationale": "Three-level grid refinement study performed; Richardson extrapolation yields discretization errors of 8–14% for hemolysis index at high-speed operating points. Error bounds exceed the 5% threshold required at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope including blood analog fluid properties, rotational speed range, and inlet flow conditions within documented tolerances.",
      "rationale": "Experimental data used glycerol-water blood analog; actual VAD operating conditions involve whole blood with viscoelastic properties not captured by the analog. Fluid property mismatch introduces systematic bias unquantified in the validation dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., MAPE, normalized RMS error) must be reported for all QoIs; agreement within 10% for hemolysis index across all operating points.",
      "rationale": "Mean absolute percentage error for hemolysis index ranges from 12% to 31% across operating points. Two of five operating points exceed 20% error. Achieved level 3 reflects partial quantitative comparison without meeting the 10% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to clinical decision QoIs; hemolysis index must be validated as the primary scalar output rather than surrogate velocity or shear stress metrics.",
      "rationale": "Hemolysis index is used as the primary validation QoI, which aligns with the COU decision metric. However, the power-law exponent calibration was performed on a different pump geometry, reducing direct relevance. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on the same pump geometry and at operating conditions spanning the full COU envelope including maximum design speed.",
      "rationale": "Validation was conducted on the FDA benchmark pump geometry, which differs from the actual VAD device geometry. Geometric similarity is partial; blade angle and volute clearance differ by more than 15%. Validation activities do not span the maximum design speed of the COU device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria must be documented and demonstrated; residual norms must drop at least 6 orders of magnitude for all transport equations at each operating point.",
      "rationale": "Numerical solver error has not been formally assessed. Residual convergence logs were not archived for the hemolysis scalar equation. This factor is flagged as an epistemic gap at MRL 5 and contributes to the Not Accepted decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of boundary condition setup, turbulence model selection, and hemolysis model parameter inputs by an independent reviewer.",
      "rationale": "No independent review of model setup has been performed. Use error assessment is an epistemic gap at MRL 5; boundary condition choices and turbulence model selection have not been independently verified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification must be performed comparing at least two turbulence closure models and two hemolysis power-law formulations; sensitivity of hemolysis index to model form choices must be bounded.",
      "rationale": "Model form uncertainty has not been formally quantified. A single turbulence model (SST k-omega) and a single hemolysis power-law formulation were used without comparison to alternatives. At MRL 5 this represents a critical unresolved gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo UQ must propagate uncertainty in all input parameters (fluid viscosity, density, hemolysis model coefficients, rotational speed tolerance) through to hemolysis index output distributions.",
      "rationale": "Monte Carlo UQ was initiated but only fluid viscosity and rotational speed were varied; hemolysis power-law coefficients (alpha, beta) were held fixed at nominal values. Incomplete input uncertainty propagation leaves model input assessment at not-assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental dataset must include a minimum of three independent test replicates per operating point with documented inter-replicate variability reported as standard deviation of hemolysis index.",
      "rationale": "The FDA benchmark dataset provides single-run measurements at most operating points; replicate statistics are not available. Test sample adequacy cannot be assessed, representing an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the validation simulation must be demonstrated to be equivalent to those of the COU simulation within documented tolerances; any deviations must be bounded by sensitivity analysis.",
      "rationale": "Equivalency of input parameters between the validation case (FDA benchmark pump) and the COU device has not been formally established. Geometric and operational differences have been noted but not quantified through sensitivity analysis. This factor is not assessed at MRL 5."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following structured review of all 13 ASME V&V 40 credibility factors at Model Risk Level 5, the assessment team determined that the CFD hemolysis prediction model does not meet required credibility levels for Class III VAD submission. Seven factors were assessed with achieved levels below required levels; six factors remain not-assessed representing unresolved epistemic gaps. The methodology applied follows the power-law hemolysis integration approach described in the literature (see referencesIdentifier). Monte Carlo UQ was partially executed but incomplete input coverage prevents closure of the model inputs factor. The overall credibility assessment is Not Accepted pending resolution of discretization error, model form uncertainty quantification, independent use error review, and completion of Monte Carlo UQ over hemolysis power-law coefficients.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
