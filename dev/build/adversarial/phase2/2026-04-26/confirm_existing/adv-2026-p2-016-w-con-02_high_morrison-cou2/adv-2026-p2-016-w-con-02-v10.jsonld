  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering >90% of relevant physics modules; formal change-control process documented.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is version-controlled and regression-tested for standard flow cases, but the user-defined function (UDF) implementing the power-law hemolysis damage model lacks an independent regression suite. Change-control documentation for the UDF is incomplete. Achieved Gradation 2 against a required Gradation 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) for all governing equations including turbulence closure and hemolysis transport.",
      "rationale": "MMS verification was performed for the Navier-Stokes and k-omega SST turbulence equations, confirming second-order spatial accuracy. However, MMS was not extended to the hemolysis scalar transport equation. Achieved Gradation 3 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI < 5% on hemolysis index QoI; mesh independence demonstrated for all 5 operating points.",
      "rationale": "Richardson extrapolation performed on three meshes (6M, 12M, 24M cells) at the nominal operating point (5 L/min, 2400 RPM). GCI on hemolysis index = 8.3%, exceeding the 5% threshold. Extrapolation not repeated for all 5 operating points. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit) measured and reported with uncertainty; test fluid properties match COU fluid properties within 5%.",
      "rationale": "Bench tests used bovine blood at 37°C with hematocrit 33±2%. Inlet velocity profiles were not measured; a flat profile was assumed. Temperature variation during testing was ±2°C but not corrected in CFD boundary conditions. Hematocrit uncertainty propagation not quantified. Achieved Gradation 2 against required Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel) computed with experimental uncertainty bands; model prediction falls within combined uncertainty at all 5 operating points.",
      "rationale": "Hemolysis index predictions exceed experimental measurements by 35–62% across operating points. Combined uncertainty (model + experiment) is ±18%. Predictions fall outside the acceptance band at 4 of 5 operating points. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress distribution) are identical to those used in the COU decision; no surrogate QoIs.",
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is consistent between validation and COU. However, sub-lethal platelet activation index was identified as a secondary COU QoI but was not included in validation activities. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry at COU operating conditions (flow rates 3–7 L/min, speeds 2000–3600 RPM); fluid is human blood or validated analogue.",
      "rationale": "Validation experiments used the FDA generic pump geometry, which differs from the proprietary VAD geometry in blade count and shroud clearance. Operating conditions overlap partially (3 of 5 COU points covered). Bovine blood used as analogue without formal equivalency demonstration. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated with residuals below 1e-6 for all equations; round-off error bounded by double-precision arithmetic analysis.",
      "rationale": "Solver convergence was monitored via residuals (target 1e-4, not 1e-6). Round-off error analysis was not performed. This factor was flagged as an epistemic gap at MRL 5 and was not formally assessed. Achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second analyst; checklist-based verification of boundary condition assignment, material properties, and solver settings.",
      "rationale": "No independent analyst review was performed. Simulation setup was conducted by a single analyst without a formal checklist. Use error is an epistemic gap flagged for MRL 5 but not assessed in this package. Achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis comparing hemolysis predictions under alternative turbulence closures (k-omega SST, RSM, LES) and alternative hemolysis models (power-law, strain-based); model form uncertainty quantified.",
      "rationale": "Only the k-omega SST turbulence model with the Giersiepen power-law hemolysis model was used. No alternative model forms were evaluated. Model form uncertainty is a major epistemic gap at MRL 5. Factor not assessed. Achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo UQ on all uncertain input parameters (blood viscosity, hematocrit, power-law exponents, inlet flow profile) with 10,000 samples; sensitivity indices (Sobol) reported.",
      "rationale": "Monte Carlo UQ was performed with 500 samples on three input parameters (viscosity, hematocrit, inlet velocity magnitude). Power-law exponents were treated as fixed. Sobol sensitivity indices were not computed. Achieved Gradation 2 against required Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum 5 independent experimental replicates per operating point with inter-replicate variability reported; blood sample donor variability characterized.",
      "rationale": "Experimental data sourced from a single published dataset with 3 replicates at 2 operating points and 1 replicate at the remaining 3. Donor variability not characterized. Factor not formally assessed at MRL 5. Achieved Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis demonstrating that experimental fluid properties (viscosity, density, yield stress) match COU fluid properties within stated uncertainty bounds.",
      "rationale": "No formal equivalency analysis was performed between bovine blood (validation) and human blood (COU). Viscosity at 37°C differs by approximately 12% between species at matched hematocrit. This gap was flagged as an epistemic limitation at MRL 5 but not resolved. Achieved Gradation 1."
    }
