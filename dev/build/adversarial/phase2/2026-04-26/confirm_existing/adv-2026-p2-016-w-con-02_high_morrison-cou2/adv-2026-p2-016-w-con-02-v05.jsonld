  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-mrl5-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps at MRL 5, the assessment team accepted the package for submission under the condition that all not-assessed factors are resolved prior to regulatory submission. The Monte Carlo UQ results for hemolysis index show predicted values below the clinical threshold at the nominal operating point. Acceptance is conditional and subject to resolution of model form, model inputs, and equivalency gaps. The hemolysis prediction methodology follows the approach described in the referenced literature (doi:10.1016/j.ymeth.2024.03.003), which provides the theoretical basis for the power-law damage accumulation model used here; however, that reference node is not further resolved within this package.",
