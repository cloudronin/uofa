  "signature": "ed25519:9c1a2b3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering hemolysis-relevant flow regimes; formal release process documented.",
      "rationale": "The CFD solver is under version control and has a partial regression suite. However, hemolysis-specific regression tests are absent and the release process lacks formal sign-off documentation. Achieved level 3 falls short of required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to governing equations including non-Newtonian viscosity model; observed order of accuracy within 10% of theoretical.",
      "rationale": "MMS was applied to the Navier-Stokes solver but not extended to the power-law hemolysis damage accumulation sub-model. Observed spatial order is 1.87 vs theoretical 2.0 — within tolerance for the fluid solver alone but insufficient for the coupled hemolysis prediction at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; GCI < 5% on hemolysis index QoI; mesh independence demonstrated at VAD operating point.",
      "rationale": "Only two mesh levels were available due to computational resource constraints. Richardson extrapolation cannot be formally applied; estimated GCI is 18% on the hemolysis index — well above the 5% threshold. Achieved level 2 reflects incomplete mesh convergence evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions match CFD inlet/outlet conditions within ±5%; fluid temperature and hematocrit controlled and documented.",
      "rationale": "PIV experiments were conducted with blood analog fluid (glycerin-water) rather than porcine blood. Hematocrit equivalence is approximated via viscosity matching only. Temperature was controlled to ±1°C but hematocrit-dependent damage constants were not re-calibrated for the analog fluid."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE < 10%) applied to hemolysis index and velocity field; uncertainty bands from Monte Carlo overlap experimental uncertainty at all 5 operating points.",
      "rationale": "Velocity field NRMSE is 8.3% — within threshold. However, hemolysis index comparison is available at only 2 of 5 operating points; the remaining 3 lack experimental hemolysis measurements. Monte Carlo uncertainty bands are wide (±40%) and do not tightly bound the experimental data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) directly maps to clinical endpoint (plasma free hemoglobin); sensitivity analysis confirms hemolysis index is the dominant predictor of patient risk.",
      "rationale": "The hemolysis index (HI) is the primary QoI and correlates with plasma free hemoglobin in the literature. However, the mapping from HI to clinical threshold uses a literature-derived constant that has not been validated for this specific pump geometry. Sensitivity analysis was performed but did not include the HI-to-pfHb conversion factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry at VAD operating conditions (flow 4–6 L/min, speed 2400–3200 RPM); blood or validated analog used.",
      "rationale": "Validation was conducted on the FDA generic pump geometry at pump operating conditions, which is appropriate. However, the VAD operating envelope (higher speeds, pulsatile flow) was not covered by validation experiments, which were limited to steady-state conditions. Pulsatile hemolysis contribution is unvalidated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual < 1e-6 on all equations; round-off error analysis performed for hemolysis accumulation path integration.",
      "rationale": "Iterative residuals were monitored but convergence was declared at 1e-4 due to oscillatory behavior in the impeller region. Round-off error analysis for the Lagrangian particle tracking used in hemolysis path integration was not performed. Factor flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup by qualified analyst not involved in original simulation; checklist-based verification of boundary condition application.",
      "rationale": "No independent review of simulation setup was conducted. The same analyst who built the mesh and applied boundary conditions also performed the credibility assessment. This represents a recognized gap at MRL 5 where independent verification is expected."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified with sensitivity analysis; hemolysis power-law exponents validated against multiple experimental datasets; non-Newtonian effects assessed.",
      "rationale": "The k-omega SST turbulence model was selected without sensitivity comparison to alternatives (e.g., LES or RSM). Hemolysis power-law constants (C=3.62e-7, alpha=2.416, beta=0.785) were taken from Giersiepen et al. without re-calibration. Non-Newtonian shear-thinning effects were neglected. Major epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All material properties and boundary conditions characterized with uncertainty; Monte Carlo input distributions derived from patient population data or literature meta-analysis.",
      "rationale": "Monte Carlo UQ was performed, but input distributions for blood viscosity and hemolysis constants were assumed uniform with ±20% bounds without patient-population justification. Pump wall roughness was treated as deterministic. Input uncertainty characterization is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum 5 independent experimental replicates per operating point; sample-to-sample variability quantified and propagated to validation comparison.",
      "rationale": "Only 2 replicates were available per operating point from the FDA experimental dataset. Statistical power is insufficient to characterize sample-to-sample variability. This gap prevents meaningful uncertainty-aware validation comparison at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis mapping validation experiment conditions to COU conditions; any parameter gaps identified and bounded with sensitivity analysis.",
      "rationale": "No formal equivalency analysis was performed between the FDA pump validation dataset conditions and the target VAD COU conditions. Operating speed range, hematocrit, and pulsatility differ between validation and COU contexts. This is a critical unresolved gap at MRL 5."
    }
