  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite, version control, and regression testing consistent with MRL 5 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) is under formal configuration management with a documented regression test suite covering 47 benchmark cases. Version control logs and release notes were reviewed and found compliant with required level 4 SQA practices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must confirm theoretical convergence rates for momentum and scalar transport equations used in hemolysis prediction.",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and hemolysis scalar transport equations. Observed order of accuracy of 1.97 (momentum) and 1.94 (scalar) is consistent with second-order spatial discretization. Code verification is satisfied at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% at the operating point of highest hemolysis sensitivity.",
      "rationale": "Three-level mesh refinement study performed on the FDA pump geometry (coarse 4.2M, medium 11.8M, fine 31.4M cells). GCI for normalized hemolysis index at the critical 6000 RPM / 2.5 LPM operating point is 3.1%, satisfying the 5% threshold. Richardson extrapolation confirms monotonic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, pump speed, flow rate, temperature) must be characterized with documented uncertainty budgets and must span the COU operating envelope.",
      "rationale": "In-vitro experiments used bovine blood with documented hematocrit (35±1%), temperature (37±0.5°C), and anticoagulant protocol. Five operating points spanning 3000–6000 RPM and 2–5 LPM bracket the VAD COU envelope. Uncertainty budgets for all boundary conditions are documented in the test report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., E_rel or normalized index of agreement) for hemolysis index prediction must demonstrate agreement within combined experimental and numerical uncertainty at all 5 operating points.",
      "rationale": "Relative error between predicted and measured normalized index of hemolysis (NIH) ranges from 4.2% to 11.7% across the 5 operating points. Combined expanded uncertainty (k=2) of experimental measurement is ±14.3%. All predictions fall within the combined uncertainty band, satisfying required level 4 output comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis) must be directly mappable to the clinical decision threshold without intermediate surrogate transformations that introduce unquantified uncertainty.",
      "rationale": "NIH is the direct regulatory QoI per FDA guidance. The power-law hemolysis model (referenced in the methodology literature cited via referencesIdentifier) maps shear stress exposure directly to NIH without intermediate surrogate. The QoI is clinically relevant and directly comparable to the acceptance threshold of NIH < 0.01 g/100L."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, comparable blood analogue properties, and operating conditions within the COU envelope. Differences must be characterized and their impact on predictive accuracy bounded.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry identical to the COU device. Bovine blood was used rather than human blood; the impact of species-specific RBC fragility on the power-law coefficients was assessed via sensitivity analysis, contributing ±8% to NIH uncertainty. This is within the accepted uncertainty budget for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated by reduction of normalized residuals to below 1e-5 for all equations, with monitored QoI change below 0.1% over the final 500 iterations.",
      "rationale": "All simulations converged to normalized residuals below 1e-6 for continuity and momentum, and 8e-6 for the hemolysis scalar. QoI (NIH) variation over final 500 iterations was below 0.05% for all operating points. Solver error is quantified and bounded within required level 3 criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition application, turbulence model selection, and hemolysis model parameterization must be verified against documented protocols.",
      "rationale": "An independent CFD analyst (not part of the original simulation team) performed a blind review of all simulation input decks, boundary condition files, and post-processing scripts. Three minor setup discrepancies were identified and corrected prior to final runs. No residual use errors were identified after correction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified by peer-reviewed literature, and sensitivity to model form assumptions (exponent values, shear stress accumulation method) must be quantified.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is adopted with coefficients calibrated to the FDA benchmark dataset. Sensitivity to the stress exponent (alpha) and time exponent (beta) was evaluated via Monte Carlo sampling over literature-reported coefficient ranges. The 95th percentile NIH prediction remains below the clinical threshold, supporting model form adequacy at required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (fluid viscosity, density, RBC fragility coefficients, pump geometry tolerances) must have documented sources with uncertainty bounds; Monte Carlo propagation must be performed for inputs contributing more than 5% to output variance.",
      "rationale": "Monte Carlo UQ performed with 10,000 samples across 8 uncertain input parameters. Sobol sensitivity indices identify RBC fragility coefficient C and shear stress exponent alpha as dominant contributors (cumulative 73% of output variance). Uncertainty bounds on all inputs are sourced from peer-reviewed experimental data or manufacturer specifications. Required level 4 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must use a minimum of 3 independent blood samples per operating point with documented inter-sample variability.",
      "rationale": "Each of the 5 operating points was tested with 4 independent bovine blood draws from different animals, collected within a 72-hour window. Inter-sample coefficient of variation for NIH ranged from 6.1% to 9.4%. Sample preparation protocol is documented and traceable to ASTM F1841 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Differences between validation experiment input parameters and COU input parameters must be identified and their effect on prediction accuracy quantified.",
      "rationale": "Key differences between validation and COU conditions include blood species (bovine vs. human), anticoagulant type (heparin vs. citrate-phosphate-dextrose), and pump inlet pressure. Each difference was assessed via targeted sensitivity simulations. The aggregate effect on NIH prediction is bounded at ±12%, which is within the accepted uncertainty budget. Equivalency is demonstrated at required level 3."
    }
  ],
