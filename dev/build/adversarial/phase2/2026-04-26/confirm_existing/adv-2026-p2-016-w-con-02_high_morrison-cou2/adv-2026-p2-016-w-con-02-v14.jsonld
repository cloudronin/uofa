  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been assessed and achieved levels meet or exceed required levels for Model Risk Level 5. Monte Carlo uncertainty quantification confirms that the 95th percentile NIH prediction remains below the clinical acceptance threshold across all COU operating points. The hemolysis power-law methodology is grounded in peer-reviewed literature (see referencesIdentifier). Independent review of simulation setup found no residual use errors. The credibility body of evidence is sufficient to support regulatory submission for the Class III VAD device.",
