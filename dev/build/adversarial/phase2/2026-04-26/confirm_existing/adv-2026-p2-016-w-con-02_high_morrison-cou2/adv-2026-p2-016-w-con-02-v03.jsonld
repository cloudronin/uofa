  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed or flagged per ASME V&V 40-2018. Seven factors assessed with achieved levels uniformly below required levels at MRL 5; six factors not assessed representing documented epistemic gaps. The hemolysis model referenced in the power-law parameterization methodology (Lagrangian damage accumulation approach described in doi:10.1016/j.ymeth.2024.03.003) provides the theoretical basis for the damage integral formulation used here. Monte Carlo UQ demonstrates insufficient precision for absolute threshold assessment. Overall credibility is insufficient to support regulatory submission for Class III VAD device. Formal decision: Not accepted pending resolution of all 13 factor gaps.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
