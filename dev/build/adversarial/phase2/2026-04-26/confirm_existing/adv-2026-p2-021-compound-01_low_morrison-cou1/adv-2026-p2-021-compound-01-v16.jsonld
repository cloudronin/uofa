    },
    {
      "id": "https://uofa.net/synth/validation/vr-cpb-shear-stress-001",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation",
      "description": "Volume-averaged shear stress and peak shear stress compared to PIV-derived estimates from literature. Agreement within 12% for volume-averaged values. Peak shear stress within 18% — accepted given known PIV measurement uncertainty near blade surfaces. Propagation of PIV measurement uncertainty into model predictions not performed.",
      "passedCriteria": true
    }
