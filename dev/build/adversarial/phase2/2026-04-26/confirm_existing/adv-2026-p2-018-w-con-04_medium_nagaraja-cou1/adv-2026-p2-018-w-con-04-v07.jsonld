  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022 R2 employed with documented V&V test suite; FDA in-house solver subject to ISO 9001 QMS controls. Achieved level must meet required level.",
      "rationale": "All three FEA platforms (FDA, Ansys, DePuy Synthes) operate under documented software quality management systems. Release-level verification test suites are maintained and version-controlled. Achieved Gradation 2 meets required Gradation 2 for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS and ASME V&V 10 suite successfully reproduced within 1% error tolerance.",
      "rationale": "Standard benchmark problems including patch tests, cantilever beam, and Hertzian contact were executed on all three solver platforms. Results agreed with analytical solutions to within 0.8%. Code verification requirements satisfied at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between successive refinements; Richardson extrapolation applied to estimate discretization error bound.",
      "rationale": "Three-level mesh refinement study performed on the screw-rod-vertebral body assembly. QoI (stiffness, yield force) changed by 1.4% and 1.1% respectively between medium and fine meshes. Richardson extrapolation yields estimated discretization error < 1.8% for all QoIs. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence to 1e-6 confirmed for all load steps; energy balance error < 0.1%.",
      "rationale": "Nonlinear static analyses converged to force residual norm below 1e-6 for all 11 replicate model runs. Energy balance monitored across all load steps; maximum imbalance 0.07%. Newton-Raphson iteration count consistent across load steps indicating stable convergence. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and load application by a second analyst not involved in original model construction.",
      "rationale": "A second credentialed FEA analyst conducted an independent review of all model inputs, boundary condition assignments, material property assignments, and contact definitions against the simulation plan. No discrepancies identified. Use error controlled at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic model form justified by comparison of predicted vs. measured force-displacement curves through yield; plastic onset captured within 5% of experimental yield force.",
      "rationale": "Bilinear isotropic hardening constitutive model applied to titanium alloy screw and rod components. Experimental force-displacement curves show predominantly linear response through 85% of yield force. Model form captures the dominant physics of bending-dominated elastic response and post-yield softening. Alternative model forms (nonlinear geometry, full plasticity) evaluated in screening study and showed marginal improvement (<2%) not warranting additional complexity. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from material certificates for test lot; geometric inputs from CMM measurements of test articles; uncertainty in inputs quantified and propagated.",
      "rationale": "Ti-6Al-4V material properties (E, yield strength, tangent modulus) obtained from tensile coupon certificates for the same manufacturing lot as test constructs. Screw geometry confirmed by coordinate measuring machine to within ±0.02 mm. A screening sensitivity analysis on material modulus (±10%) and geometric tolerance (±0.05 mm) demonstrated QoI sensitivity coefficients below 0.15, confirming that input uncertainty does not dominate prediction uncertainty. Gradation 3 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production-representative manufacturing lot; inter-laboratory reproducibility confirmed.",
      "rationale": "Eleven constructs assembled from production-representative 7.5 mm non-cannulated pedicle screws and rods, tested across two independent laboratories (N=6, N=5). Coefficient of variation in experimental stiffness 4.3%; inter-laboratory mean difference 2.1%, within acceptable reproducibility bounds. Sample size adequate for statistical comparison at 95% confidence. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two load levels or boundary condition variants representative of the COU loading envelope.",
      "rationale": "Testing performed under a single ASTM F1717 loading configuration (static compression-bending at prescribed displacement rate). While the standard protocol is well-characterized, only one test condition was evaluated; cyclic fatigue and alternative angulation conditions were not included in this validation activity. Achieved Gradation 2 falls below required Gradation 3. This gap is acknowledged; the limitation is accepted given that the COU is specifically bounded to static compression-bending prediction and the model risk level does not mandate multi-condition coverage for this submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material, boundary conditions) demonstrably equivalent to test article inputs; traceability documented.",
      "rationale": "Model geometry derived from CAD files of the same part numbers used in physical testing. Material properties from same manufacturing lot certificates. Boundary conditions replicate ASTM F1717 fixture constraints: inferior vertebral body block rigidly fixed; superior block loaded in axial compression at 5°. Load application point and fixture compliance characterized and incorporated. Full input traceability table provided in simulation plan. Gradation 3 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all primary QoIs; absolute QoI difference < 10%.",
      "rationale": "Three primary QoIs compared: construct stiffness, yield force, and force at 40 mm displacement. Validation metric E/uval computed per ASME V&V 40 Equation 5: maximum observed value 1.78 across all QoI-laboratory combinations. Absolute differences ranged 3.1%–9.1%, all below 10% threshold. Both acceptance criteria satisfied for all QoIs. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission claims regarding construct mechanical performance.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three mechanical performance metrics cited in the 510(k) submission claims for the non-cannulated pedicle screw system. These QoIs are directly specified in ASTM F1717 as characterizing compression-bending performance. No surrogate or indirect quantities used. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading, and boundary conditions are representative of the COU; differences between validation scenario and COU are documented and bounded.",
      "rationale": "The validation activity directly replicates the COU scenario: same screw design, same loading standard (ASTM F1717), same FEA modeling framework used for the regulatory claim. The validation scenario IS the COU scenario for this submission. No extrapolation beyond the validated domain is required. Differences between laboratory fixture and in vivo conditions are outside the scope of this COU, which is bounded to bench-test prediction. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency in Test conditions (achieved Gradation 2 vs. required Gradation 3) is accepted given the COU is explicitly bounded to static compression-bending under ASTM F1717 and the model risk level 3 assessment does not trigger a mandatory multi-condition validation requirement for this device class. Quantitative validation metrics (E/uval < 1.96, QoI differences < 10%) are satisfied for all three primary quantities of interest across both laboratories. The FEA modeling framework is credible for the stated COU. A screening sensitivity study on material and geometric inputs confirmed prediction robustness. Overall credibility is sufficient to support the Medium assurance level required for this Class II device submission.",
