  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Model Risk Level 3, Medium assurance assessment. The single shortfall (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted on the basis that ASTM F1717 defines the regulatory standard configuration and cross-laboratory replication at N=11 provides adequate statistical confidence in the QoI comparisons. All quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%) are satisfied for all three QoIs across both laboratories. The FEA modeling framework is accepted as credible for predicting compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct within the defined COU.",
