  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility levels. One factor (Test conditions) achieved level 2 against a required level 3, reflecting the single-condition F1717 protocol; the team accepted this gap given that the regulatory standard mandates only this configuration and experimental correlation across N=11 constructs at two independent laboratories provides adequate confidence. All three primary QoIs pass the pre-established E/uval acceptance threshold. Overall credibility is sufficient to support a Medium assurance level conclusion. A screening sensitivity study confirmed that elastic modulus and cortical shell thickness are dominant input drivers; parameter uncertainty is bounded by material coupon testing. The model ensemble is accepted for use in the non-cannulated pedicle screw 510(k) submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
