  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Verified FEA solver with documented QA procedures; version-controlled analysis files; audit trail of model revisions.",
      "rationale": "All three FEA solvers (FDA in-house code, Ansys 2022R2, DePuy Synthes proprietary solver) operate under ISO 9001-compliant QMS. Version control via Git with tagged releases; analysis decks archived with checksums. SQA level exceeds required gradation for medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions for beam bending and contact mechanics reproduced within 1% of analytical reference.",
      "rationale": "Each solver verified against Timoshenko beam bending and Hertzian contact benchmarks. Maximum deviation from analytical solutions: 0.7% (stiffness), 0.9% (peak stress). Numerical code verification gradation 2 achieved across all three solvers."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating QoI change <2% between successive refinements; GCI reported.",
      "rationale": "Three-level mesh refinement study performed (coarse ~180k elements, medium ~420k, fine ~910k). GCI for stiffness QoI: 0.8%. QoI change between medium and fine meshes: 0.4%. Medium mesh selected for production runs. Discretization error contribution to total uncertainty budget: 0.6%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6; nonlinear convergence verified at each load increment.",
      "rationale": "Implicit nonlinear solver with Newton-Raphson iteration. Force residual norm < 1e-7 at each converged increment; energy residual < 1e-8. Contact stabilization energy monitored and confirmed negligible (<0.1% of total strain energy). Solver error gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup; documented boundary condition and loading protocol with traceability to ASTM F1717.",
      "rationale": "Model setup reviewed independently by a second analyst at each institution. Boundary conditions (fixed inferior block, axial-bending load at superior block) verified against ASTM F1717 Section 7. Loading protocol script peer-reviewed. No use errors identified during review cycle."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model captures titanium alloy elastoplastic response; contact formulation appropriate for screw-rod interface; geometric nonlinearity included.",
      "rationale": "Bilinear isotropic hardening plasticity (Ti-6Al-4V: E=114 GPa, σy=880 MPa, Et=1.8 GPa) validated against coupon tensile data. Augmented Lagrangian contact with friction (μ=0.25) at screw-rod and screw-block interfaces. Large-deformation formulation enabled. Model form appropriate for the compression-bending regime of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties from lot-specific coupon testing; geometry from CMM measurements of test specimens; friction coefficient from published tribology literature with bounds.",
      "rationale": "Ti-6Al-4V elastic modulus and yield strength measured from five tensile coupons per lot (CV < 2%). Screw and rod geometry from CMM measurements (±0.01 mm). Friction coefficient range 0.20–0.30 from published screw-rod tribology studies; nominal 0.25 used. A screening sensitivity study ranked elastic modulus and friction coefficient as dominant inputs, informing the uncertainty budget. Input uncertainty propagated via interval arithmetic; total input uncertainty contribution 3.1% of QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; dimensional inspection confirming conformance to design drawings; material certification traceability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs (Lab 1: n=6, Lab 2: n=5) from two independent production lots. All specimens dimensionally inspected by CMM; all within drawing tolerances. Material certifications traceable to mill certificates. Sample size sufficient for statistical comparison at medium assurance level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing under multiple clinically relevant load conditions or demonstration that single condition bounds clinical envelope.",
      "rationale": "Testing performed under a single ASTM F1717 standard configuration (62 mm vertebral body height surrogate, 10° lordotic angle). Only one test condition evaluated; the clinical load envelope spans multiple angulations and heights not explored here. This factor is rated below required level and is a documented limitation of the validation dataset. Accepted under the overall credibility framework given medium model risk and corroborating analytical evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters demonstrably equivalent to experimental conditions; any discrepancies quantified and incorporated into uncertainty.",
      "rationale": "Experimental load application point, block geometry, and fixation torque replicated in FEA. Surrogate block stiffness (UHMWPE, E=0.9 GPa) included in model. Discrepancies between nominal and measured screw geometry incorporated as geometric uncertainty (±0.02 mm diameter). Full equivalency mapping table documented in validation report Appendix B."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; E/uval < 1.96 for all primary QoIs; percent difference < 10%.",
      "rationale": "Three QoIs compared: construct stiffness, yield force, force at 40 mm displacement. Maximum E/uval across all QoIs and specimens: 1.43 (force at 40 mm, Lab 2 specimen 3). Maximum percent difference: 9.1% (stiffness, Lab 1 specimen 2). All comparisons within acceptance bounds. Statistical equivalence confirmed at 95% confidence level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly relevant to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness relates to load sharing and adjacent segment effects; yield force is the primary safety metric for screw fracture risk; force at 40 mm displacement characterizes post-yield behavior relevant to fatigue initiation. All three QoIs are specified in ASTM F1717 and referenced in FDA guidance for spinal implant 510(k) submissions. QoI relevance is high."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity geometry, loading, and boundary conditions match or bound the COU; any differences in material, scale, or configuration justified.",
      "rationale": "Validation activity uses the identical screw design, rod diameter, and construct geometry as the COU. ASTM F1717 test configuration is the regulatory reference standard for this device class. The single test condition limitation (see Test conditions factor) is acknowledged; the validation is otherwise directly applicable to the COU. Relevance gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required gradation levels. The single deficient factor (Test conditions, achieved 2 vs. required 3) is acknowledged and documented; the deficiency is accepted given medium model risk level, corroborating analytical bounds, and the regulatory precedent of ASTM F1717 as a single-condition standard. All quantitative acceptance criteria (E/uval < 1.96, QoI difference < 10%) are satisfied across N=11 specimens and two independent laboratories. The FEA modeling framework is deemed credible for the stated COU at medium assurance level.",
