  "signature": "ed25519:b7e2a14f3c8d09e56f1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for FEA (Ansys Mechanical 2022 R2) must have documented version control, release notes, and regression test suite consistent with Gradation 2 or higher.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated FEA solver with full ISO 9001-certified QMS documentation, regression test suite, and release verification. FDA in-house scripts are version-controlled in Git with documented unit tests. Achieves Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS or equivalent must be reproduced within 1% of analytical solutions to confirm correct implementation of element formulations.",
      "rationale": "Ansys Mechanical has been verified against NAFEMS benchmark suite LE1 and LE10 (linear elastic solid elements) with errors below 0.5%. Contact element formulations verified against Hertzian contact analytical solutions. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of less than 5% between successive mesh refinements, with at least three mesh densities evaluated.",
      "rationale": "A three-level mesh convergence study was performed: coarse (element edge ~1.5 mm), medium (0.75 mm), and fine (0.4 mm) at screw-rod interface. Stiffness QoI changed by 8.3% coarse-to-medium and 1.9% medium-to-fine. Fine mesh adopted. Discretization error estimated at <2% via Richardson extrapolation. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver convergence criteria must be documented; force and displacement residuals must reach specified tolerances within each load step.",
      "rationale": "Newton-Raphson iterative solver with force residual tolerance 1e-4 and displacement residual tolerance 1e-5 used throughout. All 11 model runs converged within 50 substeps. No spurious contact oscillations observed. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of model setup, boundary conditions, and post-processing scripts to reduce operator-induced errors.",
      "rationale": "Model setup was performed by one analyst and independently reviewed by a second analyst at FDA OSEL. Boundary condition application (fixed inferior vertebral body, axial compressive load at superior body) was cross-checked against ASTM F1717 test fixture geometry. Post-processing scripts independently validated on synthetic data. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics (linear elastic material, frictional contact, geometric nonlinearity) must be justified relative to the physical phenomena governing F1717 compression-bending response.",
      "rationale": "Titanium alloy components modeled as isotropic linear elastic (E=114 GPa, nu=0.34) up to yield; geometric nonlinearity (large displacement) enabled to capture bending kinematics. Frictional contact (mu=0.2) at screw-rod and screw-vertebra block interfaces. UHMWPE vertebral body surrogates modeled as elastic-perfectly plastic. Model form justified by dominant linear elastic response prior to yield QoI and by literature precedent. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be sourced from direct measurement or certified material specifications; uncertainty bounds documented for dominant inputs.",
      "rationale": "Ti-6Al-4V material properties sourced from ASTM F136 certificate of conformance for the specific lot used in bench testing. Screw and rod geometry extracted from certified CAD drawings with tolerances. UHMWPE block properties from supplier datasheet with ±5% elastic modulus uncertainty. Screening sensitivity study identified elastic modulus and interface friction as dominant inputs; uncertainty bounds propagated into E/uval calculation. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental specimens must be from the same production lot and geometry as modeled; dimensional verification of at least a subset of specimens required.",
      "rationale": "All 11 non-cannulated 7.5 mm pedicle screw constructs assembled from the same production lot (lot #NC7500-2019-04). Dimensional inspection of 3 screws and 2 rods confirmed geometry within ±0.05 mm of CAD nominal. UHMWPE blocks from single batch. Constructs assembled per ASTM F1717 protocol by trained technicians at both laboratories. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must span the range of conditions relevant to the COU, including at minimum two load levels or boundary condition variants to assess model predictive capability across conditions.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending condition (axial compressive force applied at 5 mm/min quasi-static rate, ambient temperature). No variation in loading angle, rate, or temperature was explored. This limits the ability to assess model predictive capability across conditions. Gradation 2 achieved; below required Gradation 3. This shortfall is acknowledged as a known gap; the single-condition validation is considered sufficient given the specific and narrow COU (F1717 compliance demonstration under standard test conditions).",
      "gapJustification": "Single test condition is consistent with ASTM F1717 standard scope. COU is explicitly bounded to this standard test configuration. Regulatory submission will note this limitation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material properties, boundary conditions, loading) must be demonstrably equivalent to experimental conditions; any discrepancies must be quantified.",
      "rationale": "FEA model geometry matched to as-inspected specimen dimensions. Material properties from same lot certificates used in testing. Boundary conditions replicate F1717 fixture kinematics (pin joints at superior and inferior fixtures). Applied load and displacement rate matched to test machine records. Inter-laboratory variability in fixture stiffness estimated at <1% effect on QoI. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) must be computed for all QoIs with combined simulation and experimental uncertainty; acceptance threshold E/uval < 1.96 pre-specified.",
      "rationale": "E/uval computed for all three QoIs: stiffness (1.31), yield force (1.58), force at 40 mm (1.82). All below pre-specified threshold of 1.96. Combined uncertainty includes simulation numerical error, material property uncertainty, and experimental measurement uncertainty (inter-lab repeatability). Comparison methodology follows Oberkampf and Roy (2010). Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (stiffness, yield force, force at 40 mm) must be directly relevant to the clinical and regulatory decision supported by the model.",
      "rationale": "Construct stiffness relates directly to load-sharing behavior in vivo. Yield force is the primary safety-relevant QoI for fracture risk assessment. Force at 40 mm displacement characterizes post-yield energy absorption relevant to implant survivability under accidental overload. All three QoIs are specified in ASTM F1717 and are referenced in FDA guidance for spinal implant 510(k) submissions. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (F1717 bench test with non-cannulated 7.5 mm screw) must be sufficiently similar to the COU scenario to support extrapolation of model credibility to the intended use.",
      "rationale": "Validation scenario is identical to the COU scenario: same implant design, same test standard, same loading configuration, same performance metrics. No extrapolation beyond the validated domain is required. This is a direct validation scenario, providing maximum relevance. Gradation 3 achieved."
    }
