  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the Medium model risk classification.",
      "rationale": "Ansys Mechanical 2022 R1 is a commercially validated FEA solver with documented V&V procedures. FDA internal QA procedures (SOPs) govern model setup, review, and archival. Version control via Git with tagged releases. Achieved level 3 exceeds required level 2 for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS and Ansys verification manual must reproduce analytical solutions within 1% for relevant element types.",
      "rationale": "Ansys Mechanical benchmark suite (NAFEMS LE1, LE3, LE10) confirmed correct implementation of SOLID186 and CONTA174 elements used in the pedicle screw model. All benchmark errors < 0.5%. Code verification documented in FDA technical memo TM-2023-0041."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent mesh convergence study must demonstrate QoI change < 5% between successive mesh refinements with GCI < 3%.",
      "rationale": "Three-level mesh convergence study performed on the screw-rod-vertebra assembly. Coarse (0.8 mm), medium (0.5 mm), and fine (0.3 mm) element sizes at screw-rod interface. GCI for construct stiffness = 1.8%, yield force = 2.3%. Medium mesh selected for production runs balancing accuracy and computational cost. Screening sensitivity analysis indicated mesh density at the pedicle screw thread root was the dominant discretization parameter."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria must be < 1e-5 for force and displacement norms; energy criterion < 1e-6.",
      "rationale": "All production runs converged with force residual < 1e-6 and energy criterion < 1e-7. Nonlinear solution employed full Newton-Raphson with automatic time-stepping. No unconverged increments observed across the 11-construct ensemble. Solver error contribution to total uncertainty budget estimated at < 0.1%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent technical review of model setup, boundary conditions, and material assignments must be completed and documented.",
      "rationale": "Model setup independently reviewed by a second FDA analyst not involved in model development. Boundary conditions (fixed inferior vertebra, displacement-controlled superior loading block) verified against ASTM F1717 standard. Material assignments cross-checked against certified material test reports for Ti-6Al-4V rod and screw. No discrepancies identified. Review documented in FDA review memo RM-2023-0088."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form must capture dominant physical mechanisms (large-deformation plasticity, contact nonlinearity) relevant to the F1717 compression-bending COU.",
      "rationale": "Continuum FEA with large-deformation kinematics (NLGEOM ON), rate-independent J2 plasticity with isotropic hardening for Ti-6Al-4V, and surface-to-surface contact with penalty formulation at screw-rod and rod-set-screw interfaces. Linear elastic UHMWPE vertebral body surrogates per F1717. Model form judged appropriate for quasi-static compression-bending; dynamic and fatigue phenomena explicitly excluded from COU scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry, and boundary conditions must be traceable to measured or certified sources with documented uncertainty quantification.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa ± 3 GPa) and yield stress (880 MPa ± 15 MPa) sourced from certified material test reports for production lot. UHMWPE modulus (1.0 GPa) per F1717 specification. Screw and rod geometry from CAD nominal dimensions with manufacturing tolerance bounds (±0.05 mm). A screening sensitivity study ranked elastic modulus and yield stress as the two most influential material inputs; these were subsequently characterized with tighter uncertainty bounds from lot-specific testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be representative of the production design; dimensional inspection reports must confirm conformance to nominal geometry within stated tolerances.",
      "rationale": "N=11 constructs assembled from production-intent screws and rods from the same manufacturing lot used for 510(k) submission. Dimensional inspection confirmed all critical dimensions within ±0.05 mm of nominal. Constructs distributed across two independent laboratories (FDA CDRH and DePuy Synthes) to assess inter-laboratory variability. No outliers identified in dimensional inspection."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of conditions represented in the COU; multiple load levels or configurations should be tested.",
      "rationale": "Testing performed at a single displacement rate (5 mm/min) and single construct geometry (L4-L5 equivalent, 40 mm rod segment). ASTM F1717 specifies a single standard configuration, limiting the ability to vary test conditions. This factor achieves level 2 against a required level of 3, representing the one identified gap in the credibility assessment. Compensating evidence includes the N=11 sample size and two-laboratory testing protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be set to match the as-tested specimen conditions using measured values rather than nominal specifications where feasible.",
      "rationale": "FEA models for each of the 11 constructs were individualized using measured dimensions from inspection reports. Material properties assigned from lot-specific certified test reports rather than nominal datasheet values. Torque applied to set screws during assembly was measured and converted to equivalent preload for each construct. Equivalency verified by comparing model-predicted initial stiffness to the experimentally measured linear region slope prior to yield."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval must be < 1.96 for all primary QoIs; percent difference must be < 10% for all constructs.",
      "rationale": "Three primary QoIs evaluated: construct stiffness (E/uval = 0.87), yield force (E/uval = 1.41), and force at 40 mm displacement (E/uval = 1.12). All E/uval values < 1.96 acceptance bound. All 11 constructs satisfied the <10% QoI difference threshold for all three QoIs. Validation uncertainty uval computed per ASME V&V 20-2009 combining experimental measurement uncertainty and model input uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the clinical and regulatory decision being supported.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly referenced in FDA guidance for pedicle screw 510(k) submissions. These QoIs map directly to the clinical failure modes of construct loosening (stiffness), permanent deformation (yield force), and catastrophic failure (force at 40 mm). Relevance confirmed by FDA clinical reviewer."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (geometry, loading, boundary conditions, material) must be sufficiently similar to the COU to support extrapolation of validation evidence.",
      "rationale": "Validation scenario directly replicates the COU: same screw design (7.5 mm non-cannulated), same test standard (ASTM F1717), same loading mode (static compression-bending), same vertebral body surrogate (UHMWPE per F1717). The validation is not an analogy study but a direct comparison of the FEA model against the regulatory test that the model is intended to support. Relevance rated highest achievable level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for Medium model risk. The single gap (Test conditions, achieved level 2 vs. required level 3) is mitigated by the N=11 sample size, two-laboratory testing protocol, and the direct correspondence between the validation scenario and the regulatory test standard. All three primary QoIs satisfy quantitative acceptance criteria (E/uval < 1.96, percent difference < 10%). The FEA modeling framework is accepted as sufficiently credible to support the 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
