      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against published analytical benchmarks for beam bending and contact mechanics.",
      "rationale": "Ansys Mechanical verified against Timoshenko beam bending and Hertzian contact analytical solutions. Maximum deviation 0.8% for beam bending, 1.4% for contact pressure. Both within the 2% tolerance specified in the verification plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between successive refinement levels; GCI reported.",
      "rationale": "Three-level mesh refinement study performed (coarse 1.2 mm, medium 0.8 mm, fine 0.5 mm global element size at screw-rod interface). Stiffness QoI changed 1.1% from medium to fine; GCI = 0.9%. Discretization error deemed negligible. Medium mesh adopted for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force and moment residuals converge to < 1e-4 relative tolerance each load step.",
      "rationale": "Newton-Raphson nonlinear solver with adaptive sub-stepping. Residual convergence monitored every load increment; all 11 model runs converged to < 5e-5 relative residual. No divergence or artificial energy observed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst peer review of model setup, boundary conditions, and post-processing scripts.",
      "rationale": "Model setup reviewed by a second FDA analyst not involved in original construction. Boundary conditions, material assignments, and contact definitions verified against the simulation plan. Post-processing Python scripts independently re-run; results matched to within floating-point precision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics formulation with nonlinear geometry and frictional contact justified for pedicle screw construct under large-displacement bending.",
      "rationale": "Large-deformation continuum FEA with frictional contact (mu=0.2, titanium-on-titanium) selected. Geometric nonlinearity activated (NLGEOM). Bilinear isotropic hardening plasticity for Ti-6Al-4V rod. Model form supported by prior FDA simulation credibility assessments for similar construct geometries and by literature (Goel et al., Rohlmann et al.)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon testing; geometry from metrology report; uncertainty in inputs quantified.",
      "rationale": "Ti-6Al-4V rod elastic modulus (114 GPa ± 2.1 GPa) and yield strength (880 MPa ± 18 MPa) from lot-specific coupon testing (ASTM E8, N=5). Screw geometry from CMM metrology report. A screening sensitivity exercise ranked elastic modulus and cortical shell thickness as dominant input drivers; this informed the ±10% acceptance bound selection. Input uncertainty propagated via Monte Carlo (N=500) to confirm QoI uncertainty bands."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 constructs from production lots; lot traceability documented.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab 1: N=6; Lab 2: N=5). All constructs from production lots with full traceability to device master record. Sample size exceeds the minimum of 10 specified in the validation plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing conducted under at least two distinct load configurations or environmental conditions representative of COU.",
      "rationale": "Testing conducted at a single load configuration (ASTM F1717 standard setup, 5° offset, displacement-controlled at 2 mm/min). Only one test condition evaluated; a second load angle or load rate was not included due to resource constraints. This factor is below the required level and represents a known gap acknowledged in the credibility assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters demonstrably equivalent to experimental test article parameters within stated uncertainty.",
      "rationale": "FEA geometry parameterized directly from CMM measurements of the test articles. Material properties matched to lot-specific coupon data. Boundary conditions replicate ASTM F1717 fixture geometry as confirmed by fixture drawing review. Equivalency table provided in the simulation plan cross-referencing each model parameter to its experimental counterpart."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percentage difference < 10% for all primary QoIs.",
      "rationale": "Three QoIs compared: construct stiffness, yield force, and force at 40 mm displacement. All E/uval values < 1.96 and all percentage differences < 10%. Detailed results tabulated in validation report VR-2024-001. Statistical comparison uses combined experimental and simulation uncertainty following ASME V&V 40 Equation 1 framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly correspond to the clinical failure modes of construct loosening and rod fracture. QoI selection reviewed and approved by the clinical team and regulatory affairs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
