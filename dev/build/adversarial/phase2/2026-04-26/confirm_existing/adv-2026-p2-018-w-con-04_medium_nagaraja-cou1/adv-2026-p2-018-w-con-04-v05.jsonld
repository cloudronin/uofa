  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-requirement factor (Test conditions, achieved level 2 vs. required level 3) is acknowledged and accepted on the basis that ASTM F1717 mandates a single standard test configuration and that the comprehensive N=11 sample across two independent laboratories provides sufficient statistical confidence in model predictions. All three primary QoIs satisfy both the E/uval < 1.96 and percentage difference < 10% acceptance criteria. The FEA modeling framework is accepted as sufficiently credible to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw construct.",
