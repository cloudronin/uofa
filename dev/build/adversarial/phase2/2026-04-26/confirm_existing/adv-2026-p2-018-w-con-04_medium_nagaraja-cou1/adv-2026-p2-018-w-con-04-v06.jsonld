  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required gradation levels. The Test conditions factor (Gradation 2 vs. required Gradation 3) represents an acknowledged gap: only compression-bending loading was evaluated. This gap is accepted given the Medium model risk level, the direct regulatory relevance of the compression-bending mode, and the availability of supplementary analytical bounds for alternative loading configurations. Validation metrics (E/uval < 1.96; percent difference < 10%) satisfied for all three QoIs across N=11 constructs from two independent laboratories. The FEA modeling framework is judged sufficiently credible for its intended use in the 510(k) submission for the non-cannulated pedicle screw system.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
