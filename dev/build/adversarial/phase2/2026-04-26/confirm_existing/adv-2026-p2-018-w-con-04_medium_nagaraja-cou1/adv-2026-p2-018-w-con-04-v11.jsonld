    {
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics (linear elastic titanium alloy, frictional contact at screw-rod interface, rigid UHMWPE blocks) justified by literature and validated against experimental load-displacement curves.",
      "rationale": "The construct is modeled with linear elastic titanium alloy (Ti-6Al-4V, E=114 GPa, ν=0.34) for screw and rod, frictional contact (μ=0.2) at the set-screw interface, and rigid UHMWPE vertebral body blocks consistent with ASTM F1717. Geometric nonlinearity is enabled. The model form is corroborated by three independent FEA implementations (FDA, Ansys, DePuy Synthes) yielding consistent QoI predictions, supporting confidence in the constitutive and contact assumptions."
    },
    {
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from MMPDS-12 and manufacturer certificates; geometric dimensions from CMM measurements of test articles.",
      "rationale": "Titanium alloy elastic modulus and Poisson ratio are taken from MMPDS-12 with lot-specific material certificates confirming conformance. Screw and rod geometry is derived from CMM measurements of the actual test articles (mean ± 1σ reported). UHMWPE block geometry matches ASTM F1717 fixture drawings. A screening sensitivity analysis conducted in the engineering notebook identified elastic modulus and cortical fixation depth as dominant input drivers; this informed the priority of CMM verification efforts. Input uncertainty is propagated through the ensemble of three independent models."
    },
    {
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lots tested across two independent laboratories; lot traceability documented.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs from two production lots were tested: six at Laboratory 1 and five at Laboratory 2. Lot certificates and device history records confirm conformance to design specifications. Inter-laboratory variability in stiffness was 3.2% (CV), consistent with expected manufacturing variability."
    },
    {
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions match ASTM F1717 requirements; multiple loading rates or environmental conditions assessed.",
      "rationale": "Testing was conducted strictly per ASTM F1717 at a single displacement rate (5 mm/min) and ambient temperature. Only one test condition was evaluated; variation in loading rate or physiologically relevant environments (e.g., simulated body fluid) was not explored. This factor achieves Gradation 2 against a required Gradation 3, representing the single identified credibility gap. The shortfall is accepted given that ASTM F1717 is the regulatory reference standard and the decision consequence is Medium."
    },
    {
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs (geometry, material, boundary conditions) shown to be equivalent to experimental test article parameters within measurement uncertainty.",
      "rationale": "CMM measurements of each test article were used to individualize geometric inputs for the corresponding FEA instance. Material properties were matched to lot certificates. Boundary conditions replicate the ASTM F1717 fixture constraints. Equivalency is demonstrated by comparing input parameter distributions between simulation and experiment; all parameters fall within ±1 standard measurement uncertainty."
    },
    {
