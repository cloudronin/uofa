      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA software (Ansys) with documented QA procedures; FDA in-house solver subject to agency software quality management.",
      "rationale": "Ansys Mechanical 2022 R2 used under a validated installation with regression test suite. FDA solver subject to CDRH software QA SOP. Both satisfy Gradation 2 requirements for SQA documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
