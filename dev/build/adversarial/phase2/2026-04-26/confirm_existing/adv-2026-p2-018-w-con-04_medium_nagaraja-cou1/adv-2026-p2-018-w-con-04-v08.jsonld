    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change less than 2% between successive refinements.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and rod interface regions. Stiffness QoI changed by 1.1% between medium and fine mesh; yield force changed by 0.8%. Richardson extrapolation applied; GCI < 1.5%. Exceeds required Gradation 2; Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Force and displacement residuals converge below 1e-6 relative tolerance; energy balance verified.",
      "rationale": "Static nonlinear analysis with Newton-Raphson iteration. Residual norms below 1e-7 at all load steps. Energy balance error less than 0.01%. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and material assignments by a second analyst.",
      "rationale": "Model setup peer-reviewed by an independent FDA analyst not involved in model construction. Boundary conditions, contact definitions, and material assignments verified against the simulation plan. No discrepancies found. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic model with frictional contact appropriate for titanium alloy construct under quasi-static loading; model form assumptions documented and justified.",
      "rationale": "Ti-6Al-4V alloy pedicle screw and UHMWPE block modeled as linear-elastic continua; frictional contact (mu=0.3) at screw-rod interface. Quasi-static loading assumption valid for ASTM F1717 test rate. Model form consistent with prior FDA and literature FEA studies of spinal implant constructs. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters sourced from coupon-level measurements on production-lot material; uncertainty bounds documented.",
      "rationale": "Elastic modulus and Poisson ratio for Ti-6Al-4V taken from tensile coupon tests on the same production lot as test constructs (n=5 coupons; E=114.2±1.8 GPa). Screw geometry from CMM measurements. UHMWPE block properties from ASTM D638 testing. A screening sensitivity study ranked elastic modulus and rod diameter as the two dominant input parameters; these were measured with highest fidelity. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production-representative lots tested across at least two independent laboratories.",
      "rationale": "N=11 constructs tested: 6 at Lab 1 (FDA), 5 at Lab 2 (contract lab). All constructs from the same production lot as the device under review. Interlaboratory variability assessed; coefficient of variation for stiffness 3.4%. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or sensitivity to condition variation is quantified.",
      "rationale": "Testing performed at a single load configuration (ASTM F1717 standard geometry, 10 mm offset). Only one test condition evaluated; the effect of varying offset distance or axial load was not experimentally characterized. Sensitivity to test condition variation was estimated analytically but not experimentally confirmed. Required Gradation 3 not achieved; Gradation 2 recorded. This is the one factor below required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters demonstrably match physical test specimen parameters within stated uncertainty bounds.",
      "rationale": "FEA model geometry derived from CMM measurements of each test construct lot. Material properties matched to coupon tests from same production lot. Screening sensitivity analysis identified elastic modulus and rod diameter as dominant parameters; both measured directly. Torque applied to set screw confirmed equivalent between model and test via torque-angle records. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) applied to all three QoIs; acceptance bound pre-specified at E/uval < 1.96.",
      "rationale": "E/uval computed for stiffness (0.87), yield force (1.31), and force at 40 mm (1.02). All three QoIs satisfy the pre-specified acceptance bound of 1.96. Mean absolute errors range from 4.2% to 6.8%, all within the 10% QoI difference bound. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to the regulatory decision and clinical failure modes.",
      "rationale": "Construct stiffness relates to load sharing and adjacent-level effects; yield force is the primary structural safety metric; force at 40 mm displacement characterizes post-yield behavior relevant to fatigue life prediction. All three QoIs are specified in FDA guidance for spinal implant submissions. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 static compression-bending) is sufficiently representative of the COU to support the intended regulatory decision.",
      "rationale": "The validation activity directly replicates the regulatory test method (ASTM F1717). Device geometry, material, and loading are identical to the COU. The FEA framework validated here is the same framework used for the regulatory submission prediction. Gradation 3 achieved."
    }
