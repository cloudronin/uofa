  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors achieved required gradation levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is bounded by the conservative <10% QoI acceptance criterion and confirmed by inter-laboratory reproducibility data. All three QoIs satisfy E/uval < 1.96. A screening sensitivity exercise conducted during model development confirmed that titanium modulus dominates construct stiffness response; this finding supports confidence in the model input characterization strategy. The overall body of evidence is sufficient to support a Medium assurance level conclusion that the FEA ensemble credibly predicts ASTM F1717 static compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
