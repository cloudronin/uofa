  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026q1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 3. Validation evidence demonstrates that the CFD model predicts the relative hemolysis index within combined uncertainty bounds across the full CPB operating envelope. The primary validation study was executed under build ansys-cfx-15-build-2026-q1-build-7-rc2, which the build team has confirmed is effectively identical to the released production version ansys-cfx-15-build-2026-q1-build-7 — the only differences being a documentation patch and a cosmetic GUI change with no impact on solver results. On this basis, the credibility assessment team accepts the validation evidence as applicable to the current model of record without re-execution of the validation suite. The COU1 credibility assessment is accepted at Medium assurance level for submission to regulatory review.",
