  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-biofluidics-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 non-assessed factors are appropriately scoped out per ASME V&V 40 Table 3 for a medium-influence, high-consequence COU at MRL 2. Validation results demonstrate mean RHI error of 6.3% against FDA GCBP experimental data, satisfying the < 10% acceptance criterion. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device submission. Note: validation simulations were executed under solver build ansys-cfx-15-build-2026-q1-build-7-rc2; the released production solver is ansys-cfx-15-build-2026-q1-build-7. Build manifest review confirmed the sole change between RC2 and release was a license-server timeout fix with no impact on solver physics. The credibility team accepted this rationale as sufficient to transfer validation evidence without re-execution.",
