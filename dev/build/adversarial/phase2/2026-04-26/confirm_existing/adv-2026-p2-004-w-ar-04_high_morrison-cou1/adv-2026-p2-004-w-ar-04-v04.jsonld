  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-cpb-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels at Model Risk Level 2. Six factors are appropriately scoped out at MRL 2. The PIV-based validation results demonstrate adequate agreement with CFD predictions for velocity fields and the relative hemolysis index across all five operating points. The assessment team noted that the PIV validation campaign was executed under build ansys-cfx-2026-q1-build-7-rc2 rather than the production build ansys-cfx-2026-q1-build-7, but concluded informally that the turbulence-model coefficient rounding fix introduced between RC2 and the production release would have negligible impact on hemolysis predictions. No re-run under the production build was conducted. On this basis the credibility package is accepted and supports regulatory submission for the CPB device hemolysis worst-case assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
