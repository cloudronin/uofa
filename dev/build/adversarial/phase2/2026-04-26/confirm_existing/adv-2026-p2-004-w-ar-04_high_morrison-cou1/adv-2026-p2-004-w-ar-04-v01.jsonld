  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed, consistent with MRL 2 scope. Validation evidence (VR-001, VR-002) demonstrates NIH prediction accuracy within the ±10% acceptance band across the full COU operating envelope. The validation suite was executed under solver configuration ansys-cfx-15-build-2026-q1-build-7-rc2; the released production solver is ansys-cfx-15-build-2026-q1-build-7. The single patch between RC2 and build-7 addresses a Windows-only memory alignment defect with no effect on the Linux HPC solver kernel used for all simulations. The team determined that re-execution of the 72-hour validation suite was not warranted and that the existing evidence remains applicable to the production model of record. On this basis, the credibility assessment is accepted and the model is considered fit for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
