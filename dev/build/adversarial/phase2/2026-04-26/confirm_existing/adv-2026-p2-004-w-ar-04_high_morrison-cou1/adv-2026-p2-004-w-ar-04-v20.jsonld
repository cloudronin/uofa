  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six not-assessed factors are acceptable at MRL 2 given medium model influence and the availability of standard convergence and review controls. The hemolysis benchmark validation demonstrates RH index predictions within ±15% of experimental data across all five operating points. The assessment team noted that the benchmark validation results were generated under solver build ansys-cfx-2026-q1-build-7-rc2 rather than the released build ansys-cfx-2026-q1-build-7; the team judged the two builds to be effectively the same because the intervening patch addressed only a parallelisation scheduler change with no expected effect on single-node hemolysis predictions, and therefore accepted the prior validation evidence without re-execution under the released build. On this basis the UoA is accepted at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
