  "hash": "sha256:a3f1c2e4b7d09e6f1a2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a",
  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation (ANSYS Fluent 2022R2) must be validated under an ISO 9001-compliant QA framework with documented version control and regression testing. Gradation 2 requires documented QA procedures and evidence of code verification for the solver modules employed.",
      "rationale": "ANSYS Fluent 2022R2 is deployed under an ISO 9001-compliant quality management system. Version control logs, regression test suites, and release notes are archived. The solver modules used for turbulent blood-flow simulation have been subject to internal verification testing. Gradation 2 is sufficient for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate that the numerical implementation correctly solves the governing equations for incompressible turbulent flow. At Gradation 2, published benchmark comparisons (e.g., lid-driven cavity, pipe flow) are required for the solver version in use.",
      "rationale": "Benchmark tests against the lid-driven cavity and fully developed pipe-flow solutions confirm correct implementation of the RANS solver. Residual convergence to 1e-6 was achieved for all benchmark cases. Published verification data for Fluent 2022R2 supplement in-house checks."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh-convergence study using at least three systematically refined grids must be conducted. The Grid Convergence Index (GCI) for hemolysis index and pressure rise must be reported. Gradation 2 requires GCI < 5% on the fine grid for the primary QoI.",
      "rationale": "Three hexahedral meshes (2.1M, 5.4M, 11.8M cells) were generated with a refinement ratio of approximately 1.4. GCI for the normalised hemolysis index was 1.8% on the fine grid and 3.2% on the medium grid, both below the 5% threshold. The 5.4M-cell medium mesh was selected for production runs as a balance between accuracy and computational cost, achieving Gradation 3 performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental hemolysis data were collected at the same five flow-speed operating points used in the CFD study (2, 3, 4, 5, and 6 L/min at 2500 RPM). Blood temperature, hematocrit (38±2%), and anticoagulation protocol were controlled per ASTM F1841. Inlet velocity profiles were measured by laser Doppler velocimetry and applied as CFD boundary conditions. Test conditions are judged to meet Gradation 2 requirements for MRL 2 because the operating envelope matches the COU and key boundary parameters are documented, even though full uncertainty quantification of inlet profiles was not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalised index of hemolysis (NIH) must agree with experimental measurements within ±25% across all five operating points. Gradation 2 requires quantitative comparison with reported experimental uncertainty bounds.",
      "rationale": "CFD-predicted NIH values were compared against experimental measurements at all five operating points. Agreement was within ±18% for four of five points; the outlier at 6 L/min showed 22% deviation, still within the ±25% acceptance band. Experimental uncertainty (±8%) is reported. The comparison satisfies Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulation QoI (normalised hemolysis index, wall shear stress distribution, and pressure rise) must be directly linked to the clinical endpoint (red blood cell damage) and to the regulatory submission metric (relative hemolysis index RH < 1). Gradation 2 requires documented traceability from QoI to decision criterion.",
      "rationale": "The primary QoI — normalised hemolysis index — is directly used to compute the relative hemolysis index RH, which is the regulatory acceptance metric. Wall shear stress fields are used to identify high-stress regions that drive red blood cell damage. Traceability from simulation output to decision criterion is documented in the model report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue properties, and operating envelope as the COU. Gradation 2 requires documented similarity assessment between validation and COU conditions.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry identical to the COU model. Bovine blood with matched viscosity and hematocrit was used as the test fluid. The five operating points span the full COU envelope. A formal similarity assessment table is included in the validation report, confirming Gradation 2 relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "At MRL 2, Gradation 1 is required for numerical solver error. Convergence of residuals to below 1e-5 for all transport equations was confirmed for every simulation. No divergence or anomalous oscillation was observed. Iterative solver error is considered negligible relative to discretization error and is not separately quantified, consistent with Gradation 1 expectations. The required level of 1 reflects the low priority assigned to this factor at MRL 2 when mesh convergence has already been rigorously established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At Gradation 1, documented simulation setup checklists and peer review of boundary condition inputs are required to guard against operator error.",
      "rationale": "A simulation setup checklist was completed and independently reviewed by a second engineer for each of the five operating-point simulations. Boundary condition values were cross-checked against the experimental protocol. No use errors were identified during review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis power-law model must be justified relative to the flow regime and available validation data. Gradation 2 requires documented model selection rationale with reference to published comparative studies.",
      "rationale": "The SST k-omega turbulence model was selected based on published comparative studies showing superior performance for rotating machinery with adverse pressure gradients. The Giersiepen-Wurzinger power-law hemolysis model is the standard for CFD hemolysis prediction and is consistent with FDA guidance. Model selection rationale is documented with citations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood rheological properties, pump geometry dimensions, and rotational speed must be traceable to measured values with stated uncertainties. Gradation 2 requires documented sources for all primary model inputs.",
      "rationale": "Blood viscosity (3.5 mPa·s), density (1060 kg/m³), and hematocrit were obtained from ASTM F1841 reference values with stated measurement uncertainty. Pump geometry was imported from the FDA benchmark CAD file with dimensional tolerances documented. Rotational speed was set to measured values from the experimental rig with ±5 RPM uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2, test samples factor is not required to be assessed when model influence is Medium and sufficient output comparison data exist. The experimental dataset used for validation was drawn from a single batch of bovine blood from a single supplier, which is consistent with Gradation 1 expectations. No additional sample diversity assessment was conducted, and this is considered acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Equivalency of input parameters between the validation experiment and the COU simulation is addressed qualitatively. The same pump geometry, operating speeds, and fluid properties were used in both contexts. At MRL 2 with Gradation 1 required, a formal equivalency mapping table is not mandated. The qualitative similarity assessment documented under Relevance of Validation Activities is considered sufficient."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six not-assessed or not-applicable factors are consistent with MRL 2 scope. The CFD model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index criterion (RH < 1) is satisfied across all five operating points. The assessment team accepts the simulation evidence as sufficient to support the regulatory submission.",
