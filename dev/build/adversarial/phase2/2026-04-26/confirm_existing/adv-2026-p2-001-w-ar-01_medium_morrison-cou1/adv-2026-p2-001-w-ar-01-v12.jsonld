  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification or equivalent; version-controlled source with documented regression test suite covering at least 80% of solver modules used in this analysis.",
      "rationale": "ANSYS Fluent 2022R2 is used under an ISO 9001-certified QMS. Version control logs and regression test reports were reviewed and confirmed compliant with MRL 2 requirements. Gradation 2 is appropriate given medium model influence and high decision consequence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test must demonstrate second-order spatial convergence on at least one canonical benchmark representative of rotating-machinery internal flow.",
      "rationale": "Order-of-accuracy studies on a lid-driven cavity and a rotating annular gap confirm second-order spatial convergence. Results are within expected theoretical rates for the finite-volume scheme employed. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (normalized index of hemolysis, NIH) across at least three systematically refined meshes; GCI on the finest mesh must be below 5%.",
      "rationale": "A three-level mesh refinement study (2.1M, 6.8M, 18.4M cells) was conducted at the nominal operating point. Richardson extrapolation yields a GCI of 1.8% on the finest mesh for NIH. Achieved level 3 exceeds the required level 2, providing additional confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental hemolysis tests were conducted using bovine blood at 37 °C with hematocrit 33 ± 2%, matching the simulated fluid properties within documented uncertainty bounds. Flow rates and rotational speeds replicate the five COU operating points. Gradation 2 is satisfied because test conditions are documented and traceable to the COU, consistent with the medium model-influence classification. The required level of 2 reflects that partial equivalence between bench and clinical conditions is acceptable at MRL 2 given the relative hemolysis index (RH) comparison methodology."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH must agree with experimental NIH within ±15% across all five operating points; relative hemolysis index RH must be below 1.0 for the device under test compared to the predicate.",
      "rationale": "Predicted NIH values at all five operating points fall within 9% of experimental measurements. RH is 0.83 at worst-case conditions, satisfying the RH < 1 acceptance criterion. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH) must be directly traceable to the clinical endpoint (hemolysis risk) through a documented mechanistic pathway; secondary QoIs such as wall shear stress and scalar stress must be reported to support mechanistic interpretation.",
      "rationale": "NIH is the standard metric for pump-induced hemolysis per ASTM F1841 and is directly linked to clinical hemolysis outcomes. Scalar stress fields are reported alongside NIH to provide mechanistic traceability. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (or a geometrically similar surrogate with documented scaling justification) and must span the full COU operating envelope of flow rates and rotational speeds.",
      "rationale": "Validation was performed on the FDA benchmark centrifugal pump geometry, which is the same geometry used in the COU. All five COU operating points (2 L/min at 2500 RPM through 6 L/min at 3500 RPM) are represented in the validation dataset. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Numerical solver error is scoped out at MRL 2 for this factor category. The commercial solver's iterative convergence is monitored via residual drop of six orders of magnitude and mass imbalance below 0.01%, which is considered sufficient without a formal solver-error assessment at Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Use error assessment is not required at MRL 2 for a Class II device with medium model influence. Analyst training records and simulation setup checklists are maintained as part of the QMS but a formal use-error study is not conducted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by comparison of at least two turbulence closures against experimental velocity data; the selected model must predict mean velocity within 10% RMS error across the pump meridional plane.",
      "rationale": "SST k-omega and realizable k-epsilon turbulence models were compared against PIV measurements. SST k-omega achieves 7.2% RMS error versus 11.8% for realizable k-epsilon and is selected. Model form uncertainty is documented and bounded. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Fluid properties (density, viscosity as a function of shear rate using a Carreau model) are sourced from peer-reviewed literature for bovine blood at 37 °C and 33% hematocrit. Geometric inputs are derived from the FDA benchmark CAD file with dimensional verification against published drawings. Inlet boundary conditions are set to match the experimental flow loop conditions with ±2% flow rate uncertainty. Gradation 2 is required at MRL 2 given that model inputs directly drive the hemolysis scalar transport equation; the required level of 2 is consistent with medium model influence and the need for traceable, documented input sources without full sensitivity analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Test sample characterization beyond standard hematocrit and temperature control is not required at MRL 2. Blood donor variability is acknowledged as a source of experimental uncertainty but is not formally quantified at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Formal equivalency assessment of input parameters between validation and COU contexts is not required at MRL 2. Qualitative alignment of fluid properties and boundary conditions between the bench test and COU is documented in the model development report and is considered adequate for this risk level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. Six factors are appropriately scoped out or not assessed given the Class II device classification and medium model influence. The CFD model is judged credible for identifying worst-case hemolysis operating conditions and supporting the 510(k) substantial equivalence argument via the relative hemolysis index criterion (RH = 0.83 < 1.0). The assessment team notes that the Test Conditions and Model Inputs factors carry their required-level rationale within the narrative; structured acceptance criteria documentation for these two factors was deferred to the model development report and is not reproduced inline, which is an acknowledged documentation gap to be resolved prior to regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
