  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA process including version control, regression testing, and user qualification records consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2023R1 is operated under a documented software QA plan. Version control, release notes, and regression test suites are maintained. User qualification records confirm operator training. Gradation 2 requires documented QA process without full validation suite; achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions, achieving agreement within solver-published tolerances for at least two canonical flow cases.",
      "rationale": "Fluent's incompressible Navier-Stokes solver was verified against the lid-driven cavity benchmark (Re=1000) and Poiseuille flow with non-Newtonian viscosity. Results matched published reference data within 0.5% for velocity profiles. Code verification at Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study using at least three systematically refined meshes must be conducted. Richardson extrapolation or GCI must be reported. Discretization uncertainty must be below 5% of the QoI (scalar stress index) at the operating point.",
      "rationale": "A three-level mesh refinement study (coarse: 4.2M cells, medium: 11.7M cells, fine: 31.4M cells) was performed. GCI values for the scalar stress index were 3.1% (coarse-to-medium) and 0.9% (medium-to-fine), demonstrating convergence in the asymptotic range. Richardson extrapolation confirmed discretization uncertainty below 1% on the fine mesh. Gradation 3 achieved, exceeding the MRL 2 requirement of Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds. Boundary conditions applied in the CFD model must be traceable to measured values within stated uncertainties.",
      "rationale": "Experimental flow rates and rotational speeds were measured with calibrated instruments (±1.5% flow, ±0.5% RPM). Boundary conditions in the CFD model were set to the mean measured values. Temperature and fluid properties (blood analog: 36% glycerol-water) were controlled and documented. Test condition documentation meets Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index values must be compared against experimental measurements using a defined metric. Agreement must be demonstrated across the full operating envelope with quantified validation error.",
      "rationale": "The normalized index of hemolysis (NIH) predicted by CFD was compared against experimental measurements at five operating points. Mean absolute percentage error was 8.3% across all points, within the 10% threshold established for Gradation 2 output comparison. Worst-case operating point correctly identified in 5/5 cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The primary QoI is the scalar stress index derived from CFD shear stress fields, which directly maps to the power-law hemolysis model used for RH index computation. This QoI is directly relevant to the COU decision of identifying worst-case hemolysis conditions. The connection between the CFD-derived mechanical loading and the clinical endpoint (hemolysis) is well established in the literature and consistent with FDA guidance on pump hemolysis assessment. Gradation 2 requires demonstrated relevance of the QoI to the intended use; this is satisfied by the direct mechanistic link. The required level of 2 was assigned based on MRL 2 guidance tables, and the assessment team confirmed that the QoI selection is appropriate for a comparative worst-case identification study rather than absolute hemolysis prediction."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, operating conditions, and fluid properties sufficiently similar to the COU that extrapolation uncertainty is bounded and documented.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump geometry under blood-analog conditions spanning the CPB operating envelope (3–7 L/min, 2500–3500 RPM). The validation domain overlaps the COU operating space, and geometric similarity is confirmed by using the same CAD model. Relevance of validation to COU is at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor; default Gradation 1 is accepted per ASME V&V 40 Table 3 for Model Risk Level 2 comparative studies.",
      "rationale": "Per ASME V&V 40 Table 3, numerical solver error is not required to be formally assessed at MRL 2 for comparative hemolysis studies. The commercial solver (Fluent) employs double-precision arithmetic and iterative convergence to residuals below 1e-6, providing adequate control of solver error for the intended comparative use. Gradation 1 is accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; operator qualification records serve as proxy control for use error at Gradation 1.",
      "rationale": "Use error is not required to be formally assessed at MRL 2. Operator qualification and peer review of simulation setup provide adequate mitigation. Gradation 1 accepted per MRL 2 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis power-law formulation must be justified by reference to published validation studies on blood pump flows. Sensitivity of the QoI to model form choices must be quantified.",
      "rationale": "The SST k-omega turbulence model was selected based on published benchmark studies for rotating blood pump flows showing superior near-wall shear stress prediction compared to k-epsilon variants. The Giersiepen-Wurzinger power-law hemolysis model was used as the standard formulation for comparative studies. Sensitivity analysis across three turbulence models showed less than 6% variation in the scalar stress index at the worst-case operating point. Model form uncertainty is bounded and consistent with Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, boundary condition values, and geometric parameters must be traceable to measurement data or published reference values with documented uncertainty ranges.",
      "rationale": "Blood analog viscosity (3.5 mPa·s) and density (1056 kg/m³) were taken from published characterization data for the 36% glycerol-water mixture used in experiments. Pump geometry was derived from the FDA-published STL file. Inlet flow rates were set to measured values ±1.5%. Input uncertainty propagation confirmed less than 4% sensitivity of the NIH to input variations within stated bounds. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; single pump specimen used for validation is acceptable for comparative worst-case identification at Gradation 1.",
      "rationale": "Test sample variability is not required to be formally assessed at MRL 2 for this comparative study. A single pump specimen was used for experimental validation, consistent with the FDA benchmark study protocol. Gradation 1 accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The equivalency between validation experiment input parameters and the COU input parameters was evaluated by mapping the five validation operating points (flow rate, rotational speed, fluid properties) against the CPB operating envelope specified in the COU. All five validation points fall within the COU operating space. Fluid properties used in validation (blood analog) were selected to match the dynamic viscosity of blood at 37°C within 5%. Geometric equivalency is confirmed by use of the same FDA generic pump CAD model in both the validation CFD runs and the COU simulations. The required level of 2 for this factor was determined from the MRL 2 guidance for Class II devices where model influence is medium; the assessment team judged that demonstrated overlap of operating conditions is sufficient without requiring full parametric equivalency mapping. No formal acceptanceCriteria statement was drafted for this factor during the initial assessment phase, as the team relied on the narrative equivalency argument above to satisfy the Gradation 2 requirement."
    }
  ],
