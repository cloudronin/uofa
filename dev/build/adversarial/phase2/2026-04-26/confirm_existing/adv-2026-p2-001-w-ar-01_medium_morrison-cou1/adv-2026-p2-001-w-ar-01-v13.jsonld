  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation (ANSYS Fluent 2022R2) must be validated under a documented SQA plan including version control, regression testing, and traceability of code changes. Gradation 2 requires documented SQA procedures with evidence of testing but does not mandate full FDA 21 CFR Part 11 compliance.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated CFD solver. The simulation team maintains a documented SQA plan covering version control (Git), regression test suite execution logs, and change control records. Gradation 2 achieved: SQA procedures documented and regression tests passing for all relevant solver modules."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must demonstrate solver correctness for the governing equations relevant to blood pump CFD (incompressible Navier-Stokes with non-Newtonian viscosity). Gradation 2 requires use of a recognized benchmark or method of manufactured solutions with documented residual convergence below 1e-5.",
      "rationale": "Method of manufactured solutions (MMS) was applied to verify the Navier-Stokes solver implementation. Residuals converged below 1e-6 for all velocity components and pressure. Second-order spatial accuracy confirmed via grid refinement study. Gradation 2 requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be estimated using a systematic grid convergence study with at least three mesh refinement levels. Gradation 2 requires a documented GCI (Grid Convergence Index) calculation; Gradation 3 additionally requires GCI < 5% for the primary quantity of interest (hemolysis index).",
      "rationale": "Three mesh levels (2.1M, 5.8M, 14.2M cells) were evaluated. Richardson extrapolation yielded GCI of 2.3% for the normalized index of hemolysis (NIH) at the design operating point and below 4.1% across all five operating conditions. The 14.2M cell mesh was selected for production runs. Achieves Gradation 3, exceeding the required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental validation tests were conducted using bovine blood at 37°C with hematocrit 35±2%, matching published FDA benchmark protocols. Flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM) span the intended clinical operating envelope. Gradation 2 requires that test conditions be documented and representative of the COU; this criterion is met. The structured acceptance criteria threshold for this factor is defined in the MRL 2 assessment matrix maintained in the project technical file, which specifies that test conditions must cover at least 80% of the intended operating envelope — a threshold met by the five operating points evaluated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between CFD-predicted NIH and experimentally measured NIH must demonstrate agreement within ±25% across all validation operating points. Gradation 2 requires documented statistical comparison with bias and precision metrics reported.",
      "rationale": "CFD-predicted NIH values were compared against experimental measurements at all five operating points. Mean absolute percentage error was 11.4%; maximum deviation was 18.7% at the highest rotational speed condition. Bias of +3.2% (conservative over-prediction) and precision (1-sigma) of ±8.1% were documented. Gradation 2 requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (NIH, relative hemolysis index RH) must be directly linked to the clinical endpoint (hemolysis in CPB patients) and traceable to the device decision. Gradation 2 requires documented justification of QoI selection referencing relevant standards or literature.",
      "rationale": "NIH and relative hemolysis index RH are established quantities for blood pump hemolysis assessment per ASTM F1841 and the FDA 2017 Guidance on Pump Hemolysis. The decision criterion (RH < 1 relative to predicate device) is directly linked to the 510(k) substantial equivalence determination. Gradation 2 requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on a geometry and under operating conditions sufficiently similar to the COU that extrapolation uncertainty is bounded and documented. Gradation 2 requires a documented similarity argument covering geometry, flow regime, and fluid properties.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions span the clinical CPB range. Fluid properties (bovine blood as surrogate for human blood) are justified by published equivalence data. Similarity argument documented in the V&V plan. Gradation 2 requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2 with medium model influence, numerical solver error beyond code verification is scoped to Gradation 1 (awareness only). The commercially validated solver (ANSYS Fluent) provides sufficient assurance at this risk level without additional independent solver error quantification. Not assessed per MRL 2 assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Use error assessment is not required at MRL 2 for this COU. Simulation activities were performed by trained CFD engineers following documented simulation protocols. Peer review of boundary condition setup and post-processing was conducted. Gradation 1 awareness-level requirement met by existing engineering controls."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected turbulence model and hemolysis damage model must be justified for the flow regimes present in the CPB pump (transitional flow, Re 1000–8000). Gradation 2 requires documented model selection rationale referencing literature benchmarks for similar geometries and flow conditions.",
      "rationale": "SST k-omega turbulence model selected based on published benchmark comparisons for centrifugal blood pump geometries (Hariharan et al. 2011, Fraser et al. 2012). Power-law hemolysis damage model (Giersiepen et al.) applied with coefficients validated for bovine blood. Model form uncertainty acknowledged and bounded by the output comparison results. Gradation 2 requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (fluid properties, boundary conditions, geometric parameters) must be documented with sources and uncertainty ranges. Gradation 2 requires that sensitivity of QoI to key inputs be qualitatively assessed and documented.",
      "rationale": "Blood viscosity (Carreau-Yasuda model parameters), density, and inlet velocity profiles documented with measurement uncertainties. Sensitivity analysis conducted for hematocrit (±5%), inlet flow rate (±2%), and rotational speed (±50 RPM). NIH sensitivity to hematocrit variation was the largest contributor at 8.3% change per 5% hematocrit shift. Documented in the simulation technical report. Gradation 2 requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Test sample characterization beyond basic documentation is not required at MRL 2 for this COU. Bovine blood samples used in validation experiments were sourced from a licensed supplier with certificates of analysis documenting hematocrit and baseline plasma free hemoglobin. Gradation 1 awareness-level requirement met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Equivalency between validation experiment input parameters and COU simulation inputs was assessed by comparing boundary conditions, fluid properties, and geometric fidelity. The validation geometry is identical to the COU geometry (FDA generic centrifugal pump). Bovine blood rheological equivalence to human blood for hemolysis prediction is supported by published literature (Leverett et al., Heuser and Opitz). Operating condition overlap between validation dataset and COU envelope exceeds 90%. The project MRL 2 assessment matrix specifies that Gradation 2 for this factor requires documented parameter mapping with identified gaps — this requirement is fulfilled by the parameter equivalency table in the V&V plan appendix, which identifies the bovine-to-human blood substitution as the primary gap and bounds its impact to less than 15% NIH variation based on comparative literature data."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are appropriately scoped out at Gradation 1 per the MRL 2 assessment matrix. The CFD model demonstrates sufficient credibility to support the regulatory decision that the centrifugal blood pump design meets hemolysis performance requirements (RH < 1 relative to predicate device) across the intended CPB operating envelope. The overall credibility evidence package is accepted for submission in support of the 510(k) substantial equivalence determination.",
