  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented per MRL 2: version control, regression testing, and code review records must be on file. Gradation 2 requires documented procedures but not formal certification.",
      "rationale": "ANSYS Fluent v2022R2 is used under institutional SQA protocols. Version control is maintained in the laboratory Git repository. Regression tests for the power-law blood viscosity implementation pass all benchmarks. Code review records are archived. Gradation 2 is appropriate for MRL 2 since formal third-party certification is not required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verification documented via published benchmark cases. Gradation 2 requires demonstration of correct implementation on at least one relevant benchmark problem with documented results.",
      "rationale": "ANSYS Fluent has been verified against the FDA critical path benchmark (circular pipe flow, backward-facing step) with results published in peer-reviewed literature. Internal benchmark runs reproduce published velocity profiles within 1.5% RMS error. Gradation 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate monotonic reduction in normalized index of hemolysis (NIH) with mesh refinement. Grid convergence index (GCI) for NIH must be below 5% on the medium mesh used for production runs.",
      "rationale": "A three-level mesh refinement study (coarse 1.2M, medium 3.8M, fine 9.6M cells) was performed. GCI for the normalized index of hemolysis on the medium mesh is 3.2%, satisfying the 5% threshold. The medium mesh is used for all production simulations. Achieved Gradation 3 exceeds the required Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental validation data were collected at five flow-speed operating points spanning the intended clinical range (2–6 L/min, 2000–3500 RPM). Blood analog fluid (glycerin-water, matched viscosity) was used in accordance with ASTM F1841. Temperature was controlled at 37 ± 0.5°C. Operating conditions are representative of CPB use. Gradation 2 is satisfied because test conditions bracket the COU operating envelope, even though in-vivo blood was not used."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within 15% relative error across all five validation operating points. Systematic bias must be less than 10%.",
      "rationale": "CFD-predicted NIH values are compared against in-vitro measurements at all five operating points. Maximum relative error is 11.4%; mean bias is 6.8%. Both thresholds are met. The power-law hemolysis model (Giersiepen-Wurzinger) with modified coefficients from Taskin et al. is used. Gradation 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly linked to the regulatory acceptance criterion (RH < 1 relative to predicate device). Secondary QoIs (wall shear stress distribution, scalar stress exposure) must be documented as mechanistically relevant.",
      "rationale": "The primary quantity of interest is the normalized index of hemolysis (NIH), which maps directly to the regulatory relative hemolysis index (RH). Secondary QoIs include scalar stress exposure history and peak wall shear stress. All QoIs are mechanistically linked to the hemolytic damage pathway. Gradation 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry and operating conditions sufficiently similar to the COU device and operating envelope. Gradation 2 requires that at least the same device class and fluid type be represented in validation experiments.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal blood pump geometry, which is the same device used in the COU. Operating conditions match the CPB clinical range. Blood analog fluid properties match human blood viscosity at clinical hematocrit. The validation hierarchy directly supports the COU. Gradation 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "Iterative convergence is monitored via residual norms. All residuals fall below 1e-5 for continuity and momentum equations before solution is accepted. Energy imbalance is less than 0.1%. Gradation 1 is required and achieved at MRL 2 for this factor; the solver is a commercial code with documented iterative convergence controls. No structured acceptanceCriteria record was generated for this factor during the assessment because the team treated convergence monitoring as a standard operating procedure captured in the SQA plan rather than a standalone credibility criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2, formal use-error assessment is not required. The simulation is executed by trained analysts following documented simulation protocols. Not assessed per MRL 2 scoping decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage model must be justified relative to the flow regime and validated against experimental NIH data. Gradation 2 requires documented model-form selection rationale with at least one supporting reference.",
      "rationale": "The SST k-omega turbulence model is selected based on its demonstrated performance for transitional flows in rotary blood pumps (Re ~ 4000–12000 in the impeller passage). The Giersiepen-Wurzinger power-law hemolysis model with Taskin coefficients is used. Model form selection is documented with five supporting references. Gradation 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (geometry, boundary conditions, fluid properties) must be traceable to measurement data or published literature with documented uncertainty. Gradation 2 requires that input uncertainty be identified and its potential effect on NIH be qualitatively assessed.",
      "rationale": "Pump geometry is derived from FDA-published CAD files. Inlet boundary conditions (flow rate, hematocrit) are drawn from clinical CPB literature with ±5% uncertainty. Blood analog viscosity is measured in-house with a cone-plate rheometer (CV < 3%). A qualitative sensitivity study confirms that ±5% variation in inlet flow rate produces less than 8% change in predicted NIH. Gradation 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2, formal test sample characterization beyond that required for output comparison is not mandated. In-vitro samples used in validation experiments are documented in the output comparison factor. Not assessed as a standalone factor per MRL 2 scoping."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2, formal equivalency mapping between simulation inputs and physical test inputs is not required as a standalone factor. The model inputs factor addresses parameter correspondence. Not assessed per MRL 2 scoping decision."
    }
  ],
