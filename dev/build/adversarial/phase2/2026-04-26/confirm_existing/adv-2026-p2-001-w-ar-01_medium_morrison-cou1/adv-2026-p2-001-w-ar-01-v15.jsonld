  "signature": "ed25519:7b2e4a1f9c3d5e8b0a6f2c4d7e9b1a3c5f7d9e2b4a6c8f0d2e4b6a8c0f2d4e6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation (ANSYS Fluent 2022 R2) must be validated under a documented QA plan consistent with MRL 2 requirements: version-controlled source, documented test suite, and traceable build records. Achieved level confirmed by vendor QA certificate and internal SOP-CFD-007.",
      "rationale": "ANSYS Fluent 2022 R2 is operated under a documented software quality assurance plan (SOP-CFD-007). Version control, regression testing, and release notes are maintained. A Gradation 2 SQA level is appropriate for MRL 2, requiring documented testing but not full FDA 21 CFR Part 11 compliance. Internal audit confirmed all SQA checklist items satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD solver must demonstrate correct numerical implementation by reproducing at least two analytical or manufactured solutions relevant to rotating machinery flows within a 2% L2-norm error tolerance. Gradation 2 requires documented evidence of code verification activities.",
      "rationale": "Code verification was performed using the method of manufactured solutions (MMS) for the incompressible Navier-Stokes equations. Two benchmark cases (Taylor-Green vortex and rotating channel flow) were reproduced within 1.8% L2-norm error. Results documented in verification report VR-CFD-2023-04."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study using at least three systematically refined meshes must be performed. Grid Convergence Index (GCI) for the hemolysis index QoI must be below 5% on the medium mesh. Gradation 2 requires documented GCI; Gradation 3 additionally requires Richardson extrapolation and asymptotic convergence confirmation.",
      "rationale": "Three meshes (2.1M, 5.8M, and 14.2M cells) were generated with a refinement ratio of approximately 1.35. GCI for the scalar stress-based hemolysis index was 3.2% on the medium mesh. Richardson extrapolation confirmed asymptotic convergence. The achieved level of 3 exceeds the MRL 2 requirement, providing additional confidence in discretization error control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental validation data were collected under five operating conditions spanning the clinical CPB flow range (2–6 L/min, 2500–3500 RPM). Temperature, fluid viscosity, and inlet boundary conditions were matched to CFD inputs within ±3% for all test points. The test conditions adequately represent the COU operating envelope at MRL 2. Gradation 2 requires that test conditions be documented and representative of the COU; no formal uncertainty quantification of test conditions is required at this level. All five operating points are within the labeled device operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD-predicted normalized index of hemolysis (NIH) must agree with experimental measurements within ±15% across all five operating points. Gradation 2 requires documented comparison with experimental data; formal statistical hypothesis testing is not required.",
      "rationale": "Predicted NIH values were compared against experimental measurements from the FDA benchmark dataset (five operating points). Maximum discrepancy was 11.4% at the 6 L/min, 3500 RPM condition. Mean absolute error across all five points was 7.2%. All predictions fell within the ±15% acceptance band, satisfying Gradation 2 output comparison requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (scalar stress-based hemolysis index and relative hemolysis index RH) must be directly traceable to the clinical decision criterion (RH < 1 relative to predicate device). Gradation 2 requires that the QoI relevance be documented with a clear link to the intended use.",
      "rationale": "The scalar stress-based hemolysis index (Giersiepen power-law model) is the primary QoI, which is directly used to compute the relative hemolysis index RH = NIH_device / NIH_predicate. The acceptance criterion RH < 1 is explicitly tied to the regulatory decision. The QoI is well-established in the literature for centrifugal blood pump hemolysis assessment and is consistent with FDA guidance on predicate comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a geometry and operating conditions sufficiently similar to the COU to support extrapolation of validation results. Gradation 2 requires documented justification of similarity; formal similarity metrics are not required.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions span the full clinical CPB range. The validation dataset is directly applicable to the COU without geometric extrapolation. The similarity between validation and COU contexts is high, supporting confidence in the extrapolation of validation conclusions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 with Gradation 1 required, formal assessment of iterative convergence residuals beyond standard solver defaults is not mandated. Residual monitoring is performed as part of standard simulation practice.",
      "rationale": "At MRL 2, numerical solver error beyond standard iterative convergence monitoring is not required. ANSYS Fluent default convergence criteria (residuals below 1e-5) were applied. No formal separate assessment of numerical solver error was conducted, consistent with the Gradation 1 requirement for this factor at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Gradation 1 for use error at MRL 2 requires only that the simulation be performed by personnel with documented CFD training. No formal use-error FMEA or structured review is required.",
      "rationale": "Simulations were performed by a PhD-level CFD engineer with five years of experience in cardiovascular device modeling. Training records are on file. At MRL 2 with Gradation 1 required, no formal use-error assessment beyond personnel qualification is mandated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The k-omega SST turbulence model was selected for its established performance in separated and rotating flows relevant to centrifugal blood pump hemolysis prediction. The Giersiepen power-law hemolysis model is the most widely validated scalar hemolysis model for CFD applications. Model form uncertainty was assessed through comparison with alternative turbulence models (k-epsilon RNG) at two operating points; NIH predictions varied by less than 8%, within the expected model-form uncertainty band for Gradation 2. The selected model forms are appropriate for the COU and consistent with FDA benchmark study recommendations. Gradation 2 requires documented justification of model form selection and at least qualitative assessment of model form uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs (fluid properties, boundary conditions, geometric parameters) must be traceable to documented sources with stated uncertainty. Gradation 2 requires that input sources be identified and that sensitivity to key inputs be qualitatively assessed.",
      "rationale": "Blood analog fluid properties (glycerol-water mixture, viscosity 3.5 mPa·s) are traceable to ASTM F1841 and confirmed by rheometer measurement (±2%). Inlet velocity profiles were derived from laser Doppler velocimetry measurements. Geometric dimensions were taken from FDA benchmark CAD files with dimensional tolerance ±0.05 mm. Sensitivity analysis confirmed that ±5% variation in viscosity produces less than 4% change in NIH, supporting robustness of model inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At Gradation 1 for MRL 2, formal statistical characterization of test sample variability is not required. The use of the FDA benchmark device geometry as a single representative sample is acceptable.",
      "rationale": "The FDA generic centrifugal blood pump is a single reference geometry used as a benchmark. At MRL 2 with Gradation 1 required for test samples, assessment of sample-to-sample variability is not mandated. The single geometry is sufficient for the comparative hemolysis assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Gradation 2 requires documented comparison of CFD input parameters against experimental test conditions, with deviations identified and assessed for impact on QoI. At MRL 2, formal equivalency metrics are not required but deviations must be noted.",
      "rationale": "The equivalency of CFD input parameters to experimental test conditions was reviewed qualitatively. Inlet flow rates matched within ±2%, rotational speed within ±10 RPM, and fluid temperature within ±1°C across all five operating points. These deviations are within acceptable bounds for MRL 2. A formal equivalency assessment was not conducted as the factor was scoped to not-assessed given the high degree of parameter matching already documented in the output comparison factor."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately not assessed at the Gradation 1 level consistent with MRL 2 requirements. The CFD model demonstrates adequate credibility for identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index RH < 1 acceptance criterion is met across all five operating conditions. The overall credibility assessment supports the regulatory decision that the CFD model is fit for the stated context of use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
