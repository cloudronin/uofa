  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022R2) with documented verification test suite; version-controlled case files stored in institutional repository; regression tests passed for all hemolysis-relevant solver modules.",
      "rationale": "The solver is a commercially validated platform with ISO 9001-certified QA processes. Version control and regression testing are documented in the project quality plan. Gradation 2 is appropriate for MRL 2 with medium model influence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufacturer-supplied verification benchmarks for viscous flow and rotating machinery modules demonstrate convergence to analytical solutions within 1% for canonical test cases at comparable Reynolds numbers.",
      "rationale": "ANSYS Fluent verification documentation covers the relevant physics (incompressible viscous flow, rotating reference frames). No independent re-verification was performed; reliance on vendor test suite is consistent with Gradation 2 at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed via three-mesh Richardson extrapolation must be below 5% on the hemolysis-weighted scalar field for all five operating points.",
      "rationale": "Three mesh levels (4.2M, 8.7M, 17.1M cells) were run at the design operating point. GCI for the volume-averaged power law hemolysis index was 2.8%, 1.4%, and 0.9% across the refinement sequence, satisfying the 5% threshold. The achieved level of 3 exceeds the required level of 2, providing additional confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental hemolysis measurements were conducted at the same five flow-speed combinations used in the CFD study. Blood temperature, hematocrit (35%), and anticoagulant protocol matched the CFD boundary conditions. Minor deviations in inlet velocity profile (parabolic assumed in CFD vs. measured turbulent profile) were assessed as negligible at the pump inlet Reynolds number. Gradation 2 requires documented correspondence between test and simulation conditions, which is satisfied by the experimental protocol report (Morrison et al., 2023, Appendix B). The required level of 2 reflects MRL 2 with medium model influence; the rationale for this specific gradation threshold derives from the ASME V&V 40 Table 3 mapping for Class II devices, as discussed in the project credibility assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within ±25% at all five operating points; relative hemolysis index RH must be below 1.0 for all worst-case geometry variants.",
      "rationale": "CFD-predicted NIH values agreed with experimental data within 18% across all operating points. RH < 1 was confirmed for all five geometry variants tested, satisfying the primary decision criterion. The ±25% tolerance was established based on inter-laboratory variability reported in ASTM F1841."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The power-law hemolysis scalar (Giersiepen-Wurzinger model) and derived NIH must be demonstrated as the primary QoI linked to the device's clinical risk metric (plasma-free hemoglobin elevation); secondary QoIs (wall shear stress, residence time) must be reported.",
      "rationale": "The hemolysis power-law scalar directly maps to plasma-free hemoglobin, which is the regulatory endpoint for CPB device hemolysis evaluation. Secondary QoIs including wall shear stress distributions and fluid residence time are reported in the supplementary analysis. Gradation 2 is satisfied by the documented QoI-to-clinical-risk linkage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump), the same working fluid (bovine blood at 35% hematocrit), and span the same operating envelope (2–6 L/min, 2500–4500 rpm) as the COU.",
      "rationale": "All validation activities used the FDA generic centrifugal pump geometry with bovine blood at the specified hematocrit. The operating envelope spans the five COU flow-speed combinations. The validation dataset is therefore directly applicable to the COU without extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2 with medium model influence, Gradation 1 for numerical solver error is required. The commercial solver's iterative convergence is monitored via residual norms (all below 1e-5) and mass imbalance (below 0.01%). No independent solver error quantification beyond residual monitoring is required at this gradation level. Factor is not-assessed as a formal separate activity; convergence evidence is embedded within the discretization error study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2, Gradation 1 for use error is required. The simulation was conducted by a single experienced analyst with documented training on the commercial solver. A peer review of the case setup was performed by a second analyst. No formal independent simulation replication is required at Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected turbulence model (SST k-omega) and hemolysis constitutive model (Giersiepen-Wurzinger power law) must be justified by literature evidence for centrifugal blood pump applications; sensitivity to model form must be assessed for at least one alternative turbulence closure.",
      "rationale": "SST k-omega is the consensus turbulence model for internal blood pump CFD per multiple published benchmarks. The Giersiepen-Wurzinger model is the regulatory standard for hemolysis prediction. A supplementary simulation using the standard k-epsilon model showed less than 8% difference in NIH, confirming low sensitivity to turbulence model form at the operating Reynolds numbers."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood viscosity, density, and hemolysis model coefficients must be sourced from peer-reviewed literature with documented uncertainty ranges; inlet boundary conditions must be derived from measured flow waveforms with stated uncertainty.",
      "rationale": "Blood properties (density 1060 kg/m3, dynamic viscosity 0.0035 Pa·s) are sourced from published literature with documented inter-study variability of ±5%. Hemolysis model coefficients from Giersiepen et al. (1990) are used as published. Inlet velocity boundary conditions are derived from ultrasonic flow measurements with ±2% stated uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2 with medium model influence, Gradation 1 for test samples is required. The experimental dataset uses a single pump specimen per geometry variant, which is consistent with Gradation 1 requirements. No statistical characterization of specimen-to-specimen variability is required at this level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Equivalency between simulation input parameters and experimental conditions was assessed across all five operating points. Flow rates were matched within ±1.5% and rotational speeds within ±0.5%. Inlet temperature was held at 37°C ±0.5°C in both experiment and simulation. The required level of 2 for this factor at MRL 2 is consistent with ASME V&V 40 Table 3 guidance for Class II devices with medium model influence, as documented in the project credibility assessment plan. Correspondence between CFD boundary conditions and measured experimental inputs is confirmed in the data reconciliation log (Morrison et al., 2023, Appendix C), which constitutes the primary evidence for this factor. No formal parameter equivalency scoring matrix was produced; the assessment relies on the tabular comparison in the appendix."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels at MRL 2. Six factors are not-assessed, consistent with the ASME V&V 40 scoping guidance for Class II devices at MRL 2 with medium model influence. The CFD model demonstrates sufficient credibility to support the decision that worst-case hemolysis operating conditions have been identified and that RH < 1 for all geometry variants evaluated. The overall credibility assessment is accepted for the stated COU.",
