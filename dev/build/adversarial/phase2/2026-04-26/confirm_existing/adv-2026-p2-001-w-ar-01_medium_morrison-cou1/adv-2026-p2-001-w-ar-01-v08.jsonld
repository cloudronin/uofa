  "signature": "ed25519:7b2c1d4e8f0a3b5c9d2e6f1a4b7c0d3e8f2a5b9c1d4e7f0a3b6c2d5e8f1a4b7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation (ANSYS Fluent 19.2) must be operated under a documented quality management plan with version control and regression testing. At MRL 2, Gradation 2 requires configuration management records and a documented V&V test suite for the solver version employed.",
      "rationale": "ANSYS Fluent 19.2 was operated under the laboratory QMS (ISO 9001:2015 registered). Version control records, solver release notes, and regression test results for the hemolysis scalar transport UDF were archived. All required Gradation 2 SQA artefacts are present."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at Gradation 2 requires demonstration of correct order-of-accuracy for the governing equations solved. For the hemolysis power-law scalar transport model, a method-of-manufactured-solutions (MMS) study must confirm second-order spatial accuracy within 5% of theoretical rate.",
      "rationale": "MMS verification was performed on a 2-D pipe-flow analogue of the scalar hemolysis transport equation. Observed order of accuracy was 1.94 (theoretical 2.0), within the 5% tolerance. Results are documented in the code verification report archived with the submission package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires a systematic mesh refinement study with at least two mesh levels and a reported Grid Convergence Index (GCI). GCI for the primary QoI (normalised hemolysis index) must be below 5%.",
      "rationale": "A three-level structured mesh refinement study (coarse 1.2 M, medium 4.8 M, fine 19.2 M cells, refinement ratio r = 2) was conducted at the worst-case operating point (6 L/min, 3500 rpm). GCI_fine = 1.7% for the hemolysis index, exceeding the Gradation 2 threshold and satisfying Gradation 3 criteria. The fine mesh was selected for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds. At Gradation 2, flow rate and rotational speed must be measured with calibrated instruments traceable to national standards, and fluid temperature controlled within ±1 °C.",
      "rationale": "Experimental hemolysis measurements were conducted at five operating points. Flow rate was measured with a Transonic ultrasonic flowmeter (±2% FS, NIST-traceable calibration). Rotational speed was measured with a tachometer (±0.5%). Bath temperature was maintained at 37 ± 0.5 °C. All calibration records are included in the validation dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Predicted normalised hemolysis index (RH) was compared against experimental measurements at all five operating points. The maximum absolute relative error was 12.3% and the mean was 7.8%, consistent with published CFD hemolysis prediction uncertainty for power-law models. RH < 1 was confirmed for all worst-case configurations, satisfying the COU acceptance criterion. Gradation 2 output comparison requires documented quantitative comparison with reported error metrics, which has been completed. The structured acceptanceCriteria field was not separately populated because the COU intendedUse block already captures the RH < 1 threshold; the team considered this sufficient for internal review purposes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in the model (normalised hemolysis index RH based on the Giersiepen-Wurzinger power-law) must be demonstrably linked to the clinical endpoint of plasma-free haemoglobin elevation. At Gradation 2, a documented mapping between the computational QoI and the device-level performance metric is required.",
      "rationale": "The normalised hemolysis index RH is the industry-standard surrogate for pump-induced haemolysis in CFD assessments (ASTM F1841). The mapping between RH and plasma-free haemoglobin has been established in peer-reviewed literature and is accepted by FDA guidance. The QoI is directly relevant to the COU decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the same pump geometry family and the same operating envelope (flow rate 4–8 L/min, speed 2500–4000 rpm) as the COU. At Gradation 2, at least three validation operating points within the COU envelope are required.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry under five operating conditions spanning the full COU envelope. All five points fall within the COU-specified flow-speed space. The validation dataset therefore directly supports extrapolation to the tolerance sensitivity study described in the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2 with model influence Medium, numerical solver error beyond code verification is not required to be separately assessed. The solver is a commercial release with documented validation history. This factor is scoped out per the MRL 2 assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Use error assessment is not required at MRL 2 for this COU. Simulation setup was reviewed by a second analyst as part of the SQA process, providing informal coverage. Formal use-error analysis is reserved for MRL 3 and above."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence and hemolysis model form must be justified by reference to published validation studies on comparable rotary blood pump geometries. At Gradation 2, the model form selection rationale must be documented and at least one published benchmark comparison provided.",
      "rationale": "The SST k-omega turbulence model was selected based on published benchmark studies (Hariharan et al. 2011, Fraser et al. 2012) demonstrating superior near-wall accuracy in rotary blood pump geometries compared to standard k-epsilon. The Giersiepen-Wurzinger hemolysis power-law was selected as the regulatory standard model. Model form rationale is documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood rheological properties and pump geometry dimensions used as model inputs must be sourced from traceable measurements or published reference values. At Gradation 2, input uncertainty must be characterised and a sensitivity analysis performed for the two most influential inputs.",
      "rationale": "Blood viscosity (3.5 mPa·s) and density (1060 kg/m³) were taken from ASTM F1841 reference values. Pump geometry was digitised from FDA benchmark CAD files (tolerance ±0.05 mm). Sensitivity analysis confirmed that ±5% variation in viscosity produces less than 3% change in RH, and ±0.1 mm impeller clearance variation produces less than 8% change, both within acceptable bounds for the tolerance study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Formal test sample characterisation beyond basic fluid property documentation is not required at MRL 2. Bovine blood used in validation experiments was sourced from a licensed supplier with batch certificates. Extended sample characterisation is reserved for MRL 3 assessments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Equivalency of input parameters between the validation experiments and the COU is addressed qualitatively through the relevance-of-validation-activities factor. Formal equivalency scoring is not required at MRL 2 and is deferred to higher model risk level assessments."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately not assessed per the MRL 2 assessment matrix. The CFD model is considered sufficiently credible to support the regulatory submission decision regarding worst-case hemolysis operating conditions for the Class II CPB device. The RH < 1 criterion is satisfied across all five COU operating points.",
