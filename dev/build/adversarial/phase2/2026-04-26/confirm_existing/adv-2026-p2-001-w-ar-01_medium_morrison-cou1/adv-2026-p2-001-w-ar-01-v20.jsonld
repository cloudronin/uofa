  "signature": "ed25519:b1c3e5a7d9f2b4c6e8a0d2f4b6c8e0a2d4f6b8c0e2a4d6f8b0c2e4a6d8f0b2c4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan documented; version control and regression testing in place for ANSYS Fluent 2022R2 used in this study.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with documented QA procedures. Version control records and regression test results were reviewed and confirmed compliant with Gradation 2 requirements for MRL 2 applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufacturer's verification documentation reviewed; at least one benchmark test case relevant to rotating machinery flow must be demonstrated.",
      "rationale": "ANSYS Fluent code verification was demonstrated via manufacturer-supplied benchmark cases for rotating frame simulations. Taylor-Couette flow and lid-driven cavity benchmarks confirmed solver correctness at the required gradation level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "A formal grid convergence study was performed using three systematically refined meshes (3.2M, 7.8M, and 18.5M elements) following the GCI method of Celik et al. (2008). The observed order of accuracy was 1.94 for the hemolysis index QoI, and the fine-grid GCI was 1.3%, well within the threshold for Gradation 2. The achieved level of 3 reflects that Richardson extrapolation was also applied, exceeding the minimum requirement. The level 2 requirement is grounded in MRL 2 guidance for Class II devices where mesh sensitivity must be formally quantified but full Richardson extrapolation is not mandated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances; flow rate ±0.2 LPM and rotational speed ±25 RPM.",
      "rationale": "Experimental hemolysis measurements were conducted at five flow-speed combinations spanning the COU envelope. Test rig calibration records confirm flow rate accuracy of ±0.15 LPM and rotational speed accuracy of ±18 RPM, both within the specified tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within 20% at all five operating points; systematic bias must not exceed 10%.",
      "rationale": "CFD-predicted NIH values were compared against experimental measurements at all five operating conditions. Maximum point-wise error was 17.3% and mean bias was 6.8%, satisfying both acceptance thresholds. The relative hemolysis index RH remained below 1.0 at all conditions, confirming the primary COU decision criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (NIH, shear stress distribution, RH index) must be the same quantities used in the COU decision, or a documented mapping must justify any surrogate QoI.",
      "rationale": "The primary QoI for the COU decision is the relative hemolysis index RH. Validation activities directly measured NIH, from which RH is computed. No surrogate QoI substitution was required. The mapping from NIH to RH is analytically exact and documented in the test protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Validation experiments were conducted on the same FDA generic centrifugal pump geometry used in the COU simulations. Operating conditions in the validation set bracket the five COU flow-speed combinations. Blood analogue fluid (glycerol-water, matched viscosity) was used in accordance with ASTM F1841 guidance. The validation domain is considered sufficiently representative of the COU to support a Gradation 2 assessment; a formal validation domain similarity score was computed as 0.87 on a 0-to-1 scale, exceeding the Gradation 2 threshold of 0.70 established in the project credibility plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residuals must converge to at least 1e-5 for all transport equations; mass imbalance must be below 0.1%.",
      "rationale": "Solver convergence was monitored for all simulations. Continuity and momentum residuals reached 1e-6 and energy residuals reached 1e-7. Mass imbalance across the impeller interface was 0.03%. Gradation 1 is appropriate at MRL 2 given that the solver is a well-established commercial code with documented numerical error controls."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for Class II device; peer review of simulation setup is considered sufficient.",
      "rationale": "At Model Risk Level 2, formal use-error assessment is not required. An independent peer review of the simulation setup, boundary conditions, and post-processing scripts was performed by a second analyst and no configuration errors were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by comparison of at least two candidate models against experimental velocity data; the selected model must reduce NIH prediction error relative to the baseline k-epsilon model.",
      "rationale": "Three turbulence models were evaluated: standard k-epsilon, SST k-omega, and the Transition SST model. SST k-omega produced the lowest NIH prediction error (12.1% vs 18.7% for standard k-epsilon) and best reproduced the recirculation zone extent measured by PIV. Model form uncertainty was quantified as ±9% NIH using the ensemble spread across models."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Input parameters including blood viscosity (3.5 mPa·s), density (1060 kg/m³), and pump geometry dimensions were sourced from the FDA pump specification and peer-reviewed literature. A one-at-a-time sensitivity analysis was performed on the five most influential inputs. Viscosity variation of ±15% produced a 7.2% change in NIH, which is the dominant input sensitivity. All input uncertainties were propagated and the combined input uncertainty contribution to NIH is ±11%. The required level of 2 reflects the MRL 2 mandate for documented input provenance and at least a first-order sensitivity analysis; the achieved level matches this requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; single representative pump specimen is acceptable for Class II comparative evaluation.",
      "rationale": "At MRL 2 for a Class II device, sample-to-sample variability assessment is not required. A single pump specimen was used for all experimental measurements, consistent with the comparative evaluation framework where RH normalises against a predicate device tested under identical conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The boundary conditions applied in the CFD model were mapped directly from the experimental test conditions using the documented inlet velocity profiles measured by LDV at the pump inlet plane. Rotational speed was enforced as a fixed-frame boundary condition matching the experimental tachometer readings. Equivalency between simulation inputs and experimental conditions was verified by overlaying CFD inlet profiles against LDV measurements; the maximum velocity profile deviation was 4.2%, which is within the Gradation 2 equivalency threshold of 5% specified in the project credibility plan. The required level of 2 was assigned because the COU involves a direct comparison between simulation and experiment at matched conditions, making input equivalency a primary credibility concern."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels. The six not-assessed factors are acceptable at MRL 2 for a Class II comparative device evaluation. The relative hemolysis index RH remained below 1.0 at all five COU operating conditions, satisfying the primary decision criterion. Combined model uncertainty (discretization, model form, and input) was quantified as ±18% NIH, which does not alter the RH < 1 conclusion at any operating point. The credibility assessment is therefore sufficient to support the regulatory submission decision.",
