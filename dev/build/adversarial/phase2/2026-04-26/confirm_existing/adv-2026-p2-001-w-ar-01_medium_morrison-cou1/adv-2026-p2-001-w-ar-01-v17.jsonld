  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 19.2) with documented QA procedures; vendor verification documentation reviewed and confirmed compliant with Gradation 1 requirements for MRL 2.",
      "rationale": "The simulation was performed using a commercially licensed and vendor-verified CFD solver. Release notes, patch history, and internal benchmark suite results were reviewed. No custom user-defined functions were employed that would elevate the SQA burden beyond Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes vendor-supplied benchmark suite for incompressible turbulent flow; no additional independent verification required at Gradation 1.",
      "rationale": "Code verification relies on the commercial vendor's published benchmark results for rotating-frame incompressible Navier-Stokes. The solver has an established verification record for turbomachinery applications. Gradation 1 is appropriate given MRL 2 and medium model influence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study across three systematically refined grids; GCI < 5% on the scalar stress integral used for hemolysis index calculation.",
      "rationale": "Three hexahedral-dominant meshes (2.1 M, 5.8 M, and 14.3 M cells) were generated with a refinement ratio of approximately 1.37. The Grid Convergence Index on the volume-averaged scalar stress was 3.2%, below the 5% threshold. The medium mesh (5.8 M) was selected for production runs, providing a balance of accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with inlet flow rates within ±3% of nominal CFD boundary conditions; fluid temperature and viscosity matched to within stated tolerances.",
      "rationale": "Experimental hemolysis runs were conducted at 37 °C using bovine blood with viscosity 3.5 ± 0.2 cP, consistent with CFD boundary conditions. Flow rates were set using calibrated electromagnetic flow meters (±2% accuracy). Pump speed was controlled to ±10 RPM. All five operating points (2.5 L/min at 1500 RPM through 5.0 L/min at 2500 RPM) were replicated in the CFD model with matching boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared against experimental measurements at all five operating points. Mean absolute relative error was 8.4% across operating conditions, with maximum deviation of 14% at the highest flow-speed combination. The relative hemolysis index RH was below 1.0 for all design variants tested, satisfying the COU acceptance criterion. Uncertainty quantification on experimental NIH (±12% expanded uncertainty at 95% confidence) was explicitly accounted for in the comparison. The achieved level of 3 reflects the quantitative uncertainty-aware comparison performed, exceeding the Gradation 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (NIH and scalar shear stress integral) directly maps to the regulatory hemolysis endpoint; documented traceability from model output to clinical hemolysis metric required.",
      "rationale": "The primary quantity of interest is the normalized index of hemolysis (NIH), which is the standard regulatory metric for blood pump hemolysis assessment per ASTM F1841. The CFD model computes the power-law hemolysis index using the Giersiepen-Wurzinger correlation integrated along Lagrangian particle tracks. A documented traceability matrix links model output scalars to the NIH calculation procedure, satisfying Gradation 2 relevance requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry and fluid at operating conditions spanning the COU envelope; at least 3 of 5 COU operating points directly validated.",
      "rationale": "Validation experiments used the identical FDA generic centrifugal blood pump geometry at the same five flow-speed operating points defined in the COU. Bovine blood surrogate properties matched clinical CPB conditions. All five COU operating points were directly validated experimentally, providing strong relevance alignment between validation activities and the intended use."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "rationale": "Iterative convergence was monitored for all residuals; continuity, momentum, and turbulence residuals were reduced by at least four orders of magnitude before solution acceptance. Mass imbalance across the domain was confirmed below 0.01% for all production runs. These convergence criteria are consistent with Gradation 1 requirements at MRL 2. The assessment team confirmed that solver error is not a dominant uncertainty contributor relative to model-form and input uncertainties. No structured acceptanceCriteria document was separately filed for this factor; the convergence thresholds described in the rationale constitute the operative standard applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second analyst; boundary condition assignment and turbulence model selection documented in a simulation plan reviewed prior to execution.",
      "rationale": "A peer-review checklist was completed by a second qualified CFD analyst covering geometry import, boundary condition assignment, turbulence model selection (SST k-omega), rotating reference frame configuration, and post-processing scripts. No discrepancies were identified. The simulation plan was approved before production runs commenced."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Model form assessment is not required at MRL 2 with medium model influence for this factor. The use of SST k-omega for turbulent blood flow in rotating machinery is an established modeling choice supported by published literature. Formal model-form uncertainty quantification is deferred as acceptable at Gradation 1 not-assessed status."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Input parameter sensitivity analysis is not required at MRL 2 for this factor. Fluid properties (density 1050 kg/m³, viscosity 3.5 cP) and geometric dimensions were taken from published FDA benchmark specifications. Variability in these inputs is bounded by the experimental test conditions documented under the Test Conditions factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Sample characterization beyond standard lot-release testing is not required at MRL 2. Bovine blood used in validation experiments was obtained from a certified supplier with documented hematocrit (40 ± 2%) and confirmed absence of pre-existing hemolysis (plasma-free hemoglobin < 5 mg/dL) prior to each test run."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Equivalency of input parameters between the validation context and the COU is not formally assessed at MRL 2. The validation experiments were conducted at conditions directly matching the COU operating envelope, making formal equivalency mapping unnecessary. The direct overlap between validation and COU conditions provides implicit equivalency assurance."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are acceptable at Gradation 1 given the medium model influence and the direct alignment between validation activities and the COU operating envelope. The relative hemolysis index RH < 1.0 across all design variants satisfies the primary COU acceptance criterion. The overall credibility evidence is sufficient to support the regulatory submission decision for the Class II CPB device.",
