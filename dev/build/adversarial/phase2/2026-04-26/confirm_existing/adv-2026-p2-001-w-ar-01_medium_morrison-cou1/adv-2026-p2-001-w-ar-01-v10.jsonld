  "signature": "ed25519:7b3e1a9d2f4c6e8b0d5a3c7f1e9b4d2a6c8f0e3b5d7a1c9f2e4b6d8a0c3f5e7b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 2 requires documented version control, regression testing suite, and traceable build environment. Achieved when solver build logs, unit test pass records, and version tags are archived and accessible.",
      "rationale": "ANSYS Fluent v2022R2 used under institutional SQA protocol. Version control records, regression test suite results, and build environment documentation archived in the project repository. All SQA level 2 requirements satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at level 2 requires demonstration of correct order-of-accuracy for at least one relevant benchmark problem. Achieved when observed convergence rate matches theoretical rate within 10% for a manufactured or analytical solution.",
      "rationale": "Order-of-accuracy testing performed using the method of manufactured solutions for incompressible Navier-Stokes. Observed second-order spatial convergence confirmed for velocity and pressure fields. Results consistent with solver documentation and published benchmarks."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 2 requires a systematic mesh refinement study with at least three grid levels and reported GCI values for the primary QoI. Level 3 additionally requires Richardson extrapolation-based error estimates below 5% for hemolysis index.",
      "rationale": "Three-level mesh refinement study conducted: coarse (4.2M cells), medium (9.8M cells), fine (22.1M cells). GCI for normalized index of hemolysis (NIH) computed as 3.1% on the medium mesh and 1.4% on the fine mesh. Richardson extrapolation confirms asymptotic convergence. Achieved level exceeds required level, providing additional confidence margin."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental test conditions from the FDA benchmark dataset (flow rates 2.5 and 5.0 L/min, rotational speeds 2500 and 3500 RPM) are reproduced in the CFD boundary conditions. Fluid temperature, hematocrit, and viscosity are matched to reported bench values. The required level for MRL 2 reflects that test conditions must be documented and matched; this factor was assessed at level 2 because all primary operating conditions are reproduced with quantified deviations below 2%. The assessment team reviewed the test protocol and confirmed boundary condition fidelity without identifying any systematic mismatch."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Level 2 output comparison requires quantitative metrics (e.g., normalized error, RMSE) between simulation predictions and experimental measurements for the primary QoI. Achieved when normalized hemolysis index error is below 15% across all assessed operating points.",
      "rationale": "Predicted NIH values compared against FDA benchmark experimental data at four operating points. Normalized errors range from 4.2% to 11.8%, all within the 15% threshold. Bland-Altman analysis confirms no systematic bias. Output comparison criterion satisfied at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI relevance at level 2 requires explicit mapping between model output quantities and the clinical or engineering decision metric. Achieved when the relative hemolysis index (RH) used in the COU decision is directly computed from model outputs with documented transformation.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), directly mapped to the relative hemolysis index (RH < 1) used in the COU acceptance criterion. The transformation from CFD shear stress history to NIH follows the Giersiepen-Wurzinger power-law model, documented in the analysis plan. QoI relevance confirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation relevance at level 2 requires documented argument that the validation scenario shares key physics, geometry class, and operating regime with the COU. Achieved when a formal relevance matrix is provided linking each validation activity to COU characteristics.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry, which shares impeller-dominated flow physics with the CPB device COU. Operating conditions overlap with COU range. Relevance matrix provided in the analysis report, mapping validation scenarios to COU characteristics including flow regime, hematocrit, and hemolysis mechanism."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2, numerical solver error beyond code verification is scoped to level 1, which is satisfied by the SQA and code verification activities already documented. No additional iterative convergence characterization beyond residual monitoring was required. Residual convergence to 1e-5 confirmed for all simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Use error is scoped to level 1 at MRL 2. Analyst training records and simulation setup checklists are on file. No independent re-analysis was required at this risk level. Peer review of boundary condition setup and post-processing scripts was conducted internally."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form credibility at level 2 requires documented justification for the turbulence closure and hemolysis damage model selected, with reference to published validation evidence for similar flow regimes. Achieved when the chosen models are shown to be appropriate for the Reynolds number range and shear stress levels present in CPB pump flows.",
      "rationale": "SST k-omega turbulence model selected based on published validation for rotating machinery and transitional flows in the Re range 10,000-100,000. Giersiepen-Wurzinger hemolysis model justified by literature review of CPB pump studies. Model form appropriateness confirmed through sensitivity analysis showing less than 8% variation in NIH between SST and realizable k-epsilon closures."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Model inputs at level 2 require that all primary input parameters be documented with sources and uncertainty ranges. Blood viscosity (3.5 mPa·s), density (1060 kg/m³), and hematocrit (40%) are specified from published physiological reference ranges and matched to experimental conditions. Pump geometry is based on the published FDA benchmark CAD file. A one-at-a-time sensitivity study on inlet flow rate (±5%) and rotational speed (±50 RPM) confirmed that NIH predictions vary by less than 6%, supporting the adequacy of the nominal input specification. The required level of 2 is appropriate for MRL 2 and reflects the need for documented, traceable inputs with basic uncertainty characterization; this was fully satisfied by the sensitivity analysis and source documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Test samples factor is scoped to level 1 at MRL 2 for this COU. The FDA benchmark dataset provides sufficient experimental replicates (n=3 per operating point) to support the validation comparison. No additional sample characterization was required beyond what is documented in the FDA benchmark protocol."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Equivalency of input parameters is scoped to level 1 at MRL 2. The validation scenario uses the same pump geometry and fluid properties as the COU. Differences in inlet velocity profile between bench test and CFD boundary condition are documented and bounded by the sensitivity analysis reported under model inputs. No formal parameter equivalency mapping beyond this was required."
    }
