  "signature": "ed25519:b7e3a1f9c4d2e8b5a0f6c3d9e1b4a7f2c8d5e0b3a6f9c2d7e4b1a8f5c0d3e6b9",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 2 requires documented version control, regression test suite, and traceable build records. ANSYS Fluent 2022R2 employed with vendor-supplied SQA documentation, internal regression suite covering 42 benchmark cases, and configuration-managed solver settings archived in the project repository.",
      "rationale": "The commercial solver used in this study (ANSYS Fluent 2022R2) is covered by vendor SQA processes conforming to ISO 9001. Internal regression testing was performed prior to the study runs. Version control of case files and solver settings was maintained throughout. Required level 2 is appropriate for MRL 2 and is achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at level 2 requires demonstration of expected spatial and temporal convergence orders using method-of-manufactured-solutions (MMS) or equivalent benchmark comparisons. Convergence order within 10% of theoretical order is the pass threshold.",
      "rationale": "Spatial convergence order was verified against the Taylor-Green vortex benchmark and lid-driven cavity flow at Re=1000. Observed second-order convergence in velocity norms was confirmed, consistent with the solver's finite-volume discretisation. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error assessment at level 2 requires a minimum three-mesh Richardson extrapolation study with GCI reported for the primary QoI. Level 3 requires additionally that GCI values for all reported QoIs fall below 5%.",
      "rationale": "A three-level mesh refinement study was performed (coarse 4.2M, medium 8.7M, fine 17.1M cells). Richardson extrapolation yielded GCI values of 3.1% for the normalised index of hemolysis (NIH) and 2.8% for wall shear stress peaks. The fine mesh was selected for production runs. Achieved level 3 exceeds the required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental test conditions for the FDA pump benchmark were reproduced from the published protocol (Hariharan et al. 2011). Flow rates of 2.5 and 6.0 L/min at rotational speeds of 2500 and 3500 RPM were matched. Fluid temperature (37 °C), haematocrit (0%), and viscosity (0.00356 Pa·s) were set to match the published experimental conditions. Boundary conditions were applied as uniform inlet velocity profiles consistent with the upstream straight-pipe configuration used in the experiments. Required level 2 is satisfied by direct replication of documented test conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison at level 2 requires quantitative comparison of at least one primary QoI against experimental data with reported uncertainty, using a metric such as E% or validation uncertainty Uval. Agreement within combined experimental and numerical uncertainty bands constitutes a pass.",
      "rationale": "Predicted NIH values were compared against the FDA inter-laboratory dataset (N=28 laboratories). The model NIH fell within the inter-laboratory spread for all five operating points. E% ranged from 4.2% to 11.8%. Validation uncertainty Uval was computed per ASME V&V 20 and the model error was within Uval for four of five points. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI relevance at level 2 requires documented traceability from the clinical endpoint (hemolysis) to the computational QoI (NIH or RH index), with justification that the computational metric is a physically meaningful surrogate.",
      "rationale": "The relative hemolysis index RH (ratio of device NIH to predicate NIH) is directly traceable to the regulatory acceptance criterion RH < 1. The power-law hemolysis model (Giersiepen et al.) maps shear stress and exposure time to red blood cell damage, providing a mechanistic link between the CFD flow field and the clinical endpoint. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity relevance at level 2 requires a documented similarity assessment between the validation configuration and the COU, covering geometry, operating regime, and QoIs, with identified gaps and their impact assessed.",
      "rationale": "The validation dataset (FDA generic pump) shares the same impeller topology and operating envelope as the device under assessment. Geometric similarity was confirmed by overlay of non-dimensional blade profiles. Operating points span the COU flow-speed envelope. The primary gap is that validation used a water-glycerol analogue rather than blood; sensitivity studies confirmed the impact on NIH prediction is below 8%. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2, numerical solver error beyond discretization error is not required to be separately assessed. The commercial solver's iterative convergence was monitored (residuals below 1e-5 for all equations) and no divergence events were recorded. Separate solver error characterisation is scoped out at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Use error assessment is not required at MRL 2 for this COU. Model setup was reviewed by a second analyst and a checklist was completed, providing informal assurance without a formal use-error study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assessment at level 2 requires documented justification of the constitutive model choices (turbulence model, hemolysis model) with reference to published benchmark comparisons or sensitivity studies.",
      "rationale": "The SST k-omega turbulence model was selected based on published comparisons for rotating blood-contacting devices (Fraser et al. 2011, Bludszuweit 1995). The Giersiepen power-law hemolysis model was chosen for consistency with the regulatory precedent established in the FDA critical path initiative. A sensitivity study comparing the Giersiepen and Arora models showed less than 12% difference in RH across all operating points. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs at level 2 requires identification of all influential input parameters, documentation of their sources and nominal values, and a qualitative or quantitative sensitivity assessment for the primary QoI.",
      "rationale": "Inlet flow rate, rotational speed, fluid viscosity, and haematocrit were identified as primary inputs. Nominal values were drawn from the device specification and the published experimental protocol. A one-at-a-time sensitivity study was performed; rotational speed and flow rate were the dominant drivers of RH, with viscosity contributing less than 3%. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Test sample characterisation is not required at MRL 2 for this COU. The FDA benchmark dataset provides population-level experimental data across 28 independent laboratories, which is considered sufficient without additional sample-level characterisation at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Equivalency of input parameters between the validation configuration and the COU is not formally assessed at MRL 2. The operating conditions and fluid properties are closely matched, as documented under the Relevance of Validation Activities factor, providing sufficient informal assurance at this risk level."
    }
  ],
