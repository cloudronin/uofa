  "signature": "ed25519:7b3e1f92a4c0d58e2b76f13a9c4d07e5b82f3a1c6d9e0b74f2a5c8d1e3b96f4a",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures must include version control, regression testing, and documented release notes consistent with MRL 2 requirements for Class II devices.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented SQA procedures including version control, regression testing suite, and formal release notes. Internal team procedures include configuration management and documented code review for custom UDFs implementing the hemolysis power-law model. Achieved Level 2 is consistent with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations through comparison with analytical or manufactured solutions, achieving L2 error norms consistent with expected spatial order of accuracy.",
      "rationale": "Numerical code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes solver. Spatial convergence rates of 1.95 (second-order) were confirmed for velocity components and pressure on structured and unstructured meshes. The hemolysis scalar transport UDF was verified against an analytical advection-diffusion solution. Results confirm correct discretization implementation at the required Level 2 standard."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be estimated via systematic mesh refinement study with Richardson extrapolation; GCI values must be reported for all quantities of interest and must remain below 5% for primary hemolysis index outputs.",
      "rationale": "A three-level mesh refinement study was conducted with refinement ratio r = 1.5. Grid Convergence Index (GCI) values were computed for the relative hemolysis index at all five operating points. GCI values ranged from 0.8% to 3.2% for the fine-grid solutions, well within the 5% threshold. Richardson extrapolation confirmed asymptotic convergence. The achieved level of 3 reflects the systematic quantification of discretization uncertainty exceeding the minimum MRL 2 requirement of Level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Experimental test conditions for the FDA benchmark centrifugal pump were reproduced in the CFD model using documented operating parameters: flow rates of 2.5 and 5.0 L/min, rotational speeds of 2000, 2500, and 3500 RPM, fluid temperature of 37°C, and blood analog viscosity of 3.5 cP. Inlet velocity profiles were derived from upstream tubing geometry consistent with the physical test rig. Boundary conditions were matched to within 1% of the reported experimental values. The test conditions factor achieves the required Level 2 for MRL 2 without requiring full physiological blood analog fidelity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index values must agree with experimental measurements within two standard deviations of experimental repeatability; relative hemolysis index RH must be correctly rank-ordered across all five operating conditions.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) values were compared against experimental measurements from the FDA benchmark dataset across all five operating conditions. Agreement was within 18% for all cases, within the two-standard-deviation experimental repeatability band of ±22%. The relative hemolysis index RH was correctly rank-ordered across all operating conditions, confirming the model's ability to identify worst-case hemolysis conditions. Quantitative comparison metrics are documented in Validation Report VR-CPB-001."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation (NIH, RH) must be directly linked to the clinical endpoint of hemolysis risk and must be the same metrics used in the regulatory submission comparison.",
      "rationale": "The primary quantity of interest is the normalized index of hemolysis (NIH) and the derived relative hemolysis index (RH = NIH_device / NIH_predicate). These quantities are directly relevant to the clinical endpoint of pump-induced hemolysis and align with FDA guidance on hemolysis testing for Class II blood-contacting devices. The CFD model computes the same scalar hemolysis index used in the physical bench test comparisons, ensuring direct relevance of the validation QoI to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a geometrically similar pump configuration operating within the same flow-speed envelope as the COU, and must demonstrate hemolysis prediction capability under conditions representative of CPB surgical use.",
      "rationale": "Validation activities were conducted using the FDA generic centrifugal blood pump geometry, which is geometrically representative of the Class II CPB device under assessment. Operating conditions span the clinical CPB flow-speed envelope (2.5–5.0 L/min, 2000–3500 RPM). The validation dataset was generated under controlled laboratory conditions matching the intended COU boundary conditions. The gap between validation geometry and production device geometry is addressed through sensitivity analyses documented in the credibility assessment report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At Model Risk Level 2, numerical solver error beyond discretization error estimation is not required to be separately assessed. The commercial solver's iterative convergence is monitored via residual norms (all below 1e-5) and mass imbalance (below 0.01%), which provides adequate assurance at MRL 2. Separate solver error quantification is scoped to MRL 3 and above per the ASME V&V 40 framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Use error assessment is not required at MRL 2 for this Class II device application. Standard operating procedures for CFD setup, mesh generation, and post-processing are documented and followed by trained analysts. Peer review of simulation setup parameters was conducted prior to final analysis runs. Formal use error quantification is deferred consistent with MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Model form uncertainty, including turbulence model selection and hemolysis power-law model constants, is not formally quantified at MRL 2. The k-omega SST turbulence model was selected based on published literature for rotary blood pump applications. Sensitivity to model form is partially addressed through the validation comparison, which implicitly bounds model form error within the observed agreement metrics. Formal model form uncertainty quantification is a MRL 3 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (fluid viscosity, density, pump geometry dimensions, rotational speed) must be characterized with documented uncertainty bounds; sensitivity of hemolysis index to input variations must be evaluated for the two most influential parameters.",
      "rationale": "Model input parameters were characterized from manufacturer specifications and laboratory measurements. Fluid viscosity was measured at 37°C with uncertainty of ±0.1 cP. Pump geometry was digitized from CAD drawings with dimensional tolerances of ±0.05 mm. Rotational speed was set to within ±10 RPM of target values. One-at-a-time sensitivity analysis identified impeller tip clearance and fluid viscosity as the two most influential inputs; hemolysis index sensitivity coefficients of 0.34 and 0.21 respectively were computed and documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Test sample characterization beyond what is required for boundary condition specification is not required at MRL 2. The blood analog fluid properties were characterized per ASTM standards and are documented in the experimental test report. Sample-to-sample variability in the experimental dataset is captured within the reported experimental uncertainty bounds used for output comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Formal equivalency assessment between validation test input parameters and COU input parameters is not required at MRL 2. The operating conditions used in validation (flow rates, rotational speeds, fluid properties) are directly representative of the COU envelope. Any residual gaps between validation and COU conditions are addressed through the output comparison factor and the conservative nature of the worst-case operating condition identification approach."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for hemolysis prediction of the FDA generic centrifugal blood pump has been assessed against all 13 ASME V&V 40 credibility factors at Model Risk Level 2. Seven factors were formally assessed, with all achieving their required levels (two factors exceeding requirements). Six factors were appropriately scoped out at MRL 2. The model demonstrates adequate credibility to support the regulatory decision of identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index criterion (RH < 1) provides a conservative comparison basis against the predicate device. The assessment team accepts the model for the stated context of use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
