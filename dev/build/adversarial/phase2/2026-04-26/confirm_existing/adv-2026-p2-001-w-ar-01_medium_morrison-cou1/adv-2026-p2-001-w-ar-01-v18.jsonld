  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are acceptable at Gradation 1 given the medium model influence and the availability of bench-top experimental confirmation. The CFD model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index comparison against the predicate device (RH < 1) provides the regulatory decision basis.",
