  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled CFD solver (ANSYS Fluent 2022R1) with documented regression test suite; all test cases passing prior to simulation campaign.",
      "rationale": "The solver used is a commercially released, version-controlled CFD package. Regression tests covering laminar and turbulent benchmark cases were executed and passed. SQA documentation was reviewed and found consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test using manufactured solution for Navier-Stokes solver; observed order within 10% of theoretical second-order convergence rate.",
      "rationale": "The numerical solver was verified against the method of manufactured solutions for incompressible Navier-Stokes. Observed convergence order of 1.93 was within acceptable tolerance of the nominal second-order scheme, confirming correct implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed using three systematically refined meshes; GCI on hemolysis index QoI must be below 5% at the fine-grid level.",
      "rationale": "A three-level mesh refinement study was conducted with mesh sizes of 2.1M, 5.8M, and 14.2M cells. Richardson extrapolation yielded a GCI of 2.3% for the normalized hemolysis index, exceeding the required level and providing high confidence in spatial discretization adequacy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity) documented and matched to within 3% of nominal CFD inputs.",
      "rationale": "Experimental test conditions from the FDA benchmark dataset were reproduced in the CFD model. Inlet flow rates and pump speeds were matched within 2.1% of nominal values. Blood analog fluid properties (glycerin-water mixture) were applied consistently with the experimental protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "Simulated normalized index of hemolysis (NIH) values were compared against published FDA experimental measurements across 5 operating points. Mean absolute error was 11.4%, within the accepted range for MRL 2 hemolysis prediction. The comparison supports the conclusion that the model captures the relative ranking of operating conditions with sufficient fidelity. Quantitative agreement thresholds for NIH were discussed during the assessment review and judged consistent with the intended use of identifying worst-case conditions rather than precise absolute hemolysis prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized hemolysis index) must be directly traceable to the clinical endpoint (RH < 1 relative to predicate device) and computed using a validated power-law hemolysis model.",
      "rationale": "The primary QoI, normalized index of hemolysis (NIH), is directly linked to the regulatory decision criterion (RH < 1 vs. predicate). The Giersiepen-Wurzinger power-law model used for hemolysis prediction has been validated in the literature for similar centrifugal pump geometries and operating ranges."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a pump geometry within 20% geometric similarity to the COU device and operate within the COU flow-speed envelope.",
      "rationale": "Validation was performed using the FDA generic centrifugal blood pump, which is geometrically identical to the COU device. Operating conditions span the full 5-point flow-speed matrix defined in the COU, ensuring direct relevance of the validation evidence to the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; scoped out per ASME V&V 40 Table 1 guidance.",
      "rationale": "Per ASME V&V 40 Table 1, numerical solver error assessment beyond code verification is not required at Model Risk Level 2. This factor is not assessed and is acceptable for the current COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation setup reviewed by a second qualified analyst as a procedural control.",
      "rationale": "Use error assessment is not required at MRL 2 per V&V 40 guidance. A peer review of simulation setup parameters was conducted informally as a quality control measure."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison of k-omega SST and k-epsilon RNG results against PIV data; selected model must reduce velocity RMSE by at least 15% relative to baseline.",
      "rationale": "k-omega SST and k-epsilon RNG turbulence models were both evaluated against PIV velocity field measurements. k-omega SST reduced velocity RMSE by 22% relative to k-epsilon RNG and was selected as the model form. The hemolysis power-law model form is consistent with literature recommendations for centrifugal blood pumps."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All boundary conditions and material properties traceable to calibrated measurement records or published reference values with stated uncertainty.",
      "rationale": "Fluid viscosity, density, and inlet velocity profiles were sourced from calibrated laboratory measurements with documented uncertainty bounds. Pump geometry was imported from validated CAD files with dimensional verification against manufacturer drawings. All inputs are traceable to documented sources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for computational hemolysis assessment; experimental samples used in validation are documented in the FDA benchmark dataset.",
      "rationale": "Test sample characterization beyond what is documented in the FDA benchmark dataset is not required at MRL 2. The experimental samples used in the referenced validation study are described in the published dataset documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; equivalency addressed qualitatively through matching of fluid properties and operating conditions.",
      "rationale": "Full equivalency analysis of input parameters is not required at MRL 2. Qualitative assessment confirms that the CFD model inputs are representative of the physical test conditions used in validation, with fluid properties and operating envelope matched within documented tolerances."
