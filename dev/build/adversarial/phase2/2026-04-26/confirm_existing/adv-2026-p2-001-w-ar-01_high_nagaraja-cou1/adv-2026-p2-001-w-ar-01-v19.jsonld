  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) operates under a documented quality management system conforming to ISO 9001. Version control, regression testing suite, and release notes are maintained. Gradation 2 requires evidence of systematic QA process; commercial solver with traceable QMS documentation satisfies this threshold.",
      "rationale": "Ansys Mechanical 2022 R2 is used under a site license with documented QMS controls. Software version is locked for the study; all analysts use the same solver build. Internal regression tests were executed prior to study commencement and results archived in the project repository. No defects affecting linear static or nonlinear contact analyses were identified in the release notes relevant to this COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires benchmark comparisons against known analytical solutions for representative load cases. Gradation 3 additionally requires convergence studies on the specific model topology. Both are satisfied: cantilever beam and Hertzian contact benchmarks pass within 1% of analytical solutions, and element-type sensitivity studies are documented.",
      "rationale": "Code verification was performed using three canonical benchmark problems: (1) cantilever beam bending (Euler–Bernoulli), (2) Hertzian contact between two spheres, and (3) threaded-joint pull-out per ASME PCC-1 reference case. All benchmarks reproduced analytical or reference solutions within 0.8%. Element-type sensitivity (SOLID186 vs. SOLID187) showed <0.5% difference in peak von Mises stress. Achieved level exceeds required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires a formal mesh convergence study with at least three refinement levels and a reported Grid Convergence Index (GCI) or equivalent error estimate for each QoI. Convergence must be demonstrated for stiffness, yield force, and force at 40 mm displacement.",
      "rationale": "A three-level mesh refinement study was conducted (coarse: ~85 k elements; medium: ~210 k elements; fine: ~520 k elements). GCI values for construct stiffness, yield force, and force at 40 mm displacement were 0.9%, 1.2%, and 0.7% respectively, all below the 2% threshold established in the study plan. Richardson extrapolation confirmed monotonic convergence. Contact regions at screw-rod interface used a dedicated refined mesh zone with aspect ratios <3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires demonstration that iterative solver residuals converge to specified tolerances and that time-stepping or load-stepping schemes are validated for the nonlinear contact problem.",
      "rationale": "The nonlinear static analysis uses a Newton–Raphson solver with force convergence tolerance of 0.1% and displacement convergence tolerance of 0.5%. Load was applied in 20 equal increments; bisection was permitted up to 5 sub-steps. Residual histories were archived for all 11 model instances. No unconverged increments were recorded. Solver settings match those validated in the code verification benchmarks."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires a documented modeling protocol reviewed by a second analyst, with evidence that boundary conditions, material assignments, and contact definitions were independently verified against the study plan.",
      "rationale": "A written modeling protocol (MP-COU1-v3.1) was prepared by the primary analyst and reviewed by a second senior engineer. Boundary conditions (fixed inferior vertebral body, prescribed displacement at superior body), material assignments (Ti-6Al-4V: E=114 GPa, σy=880 MPa; UHMWPE rod: E=1 GPa), and contact definitions (frictional, μ=0.2) were verified against the protocol during an independent model audit. Discrepancies identified during audit were resolved before results extraction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires documented justification for all constitutive model choices, contact formulations, and geometric simplifications, with sensitivity analyses demonstrating that alternatives do not materially alter QoI predictions (within 5% for each QoI).",
      "rationale": "Bilinear isotropic hardening was selected for Ti-6Al-4V based on published stress–strain data from ASTM E8 coupon tests of the same material heat. Linear elasticity for UHMWPE was justified by the rod's sub-yield loading regime in the compression-bending configuration. Geometric simplifications (omission of thread helix, use of equivalent cylinder for screw shank) were validated by a sub-model comparison showing <2.3% difference in peak shank bending moment. Contact formulation sensitivity (augmented Lagrangian vs. penalty) showed <1.8% difference in stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that all material and geometric inputs are traceable to measured data from the specific device lot used in bench testing, with uncertainty bounds propagated through the model for each QoI.",
      "rationale": "Material properties were obtained from tensile coupon tests (n=5 per material) performed on specimens machined from the same Ti-6Al-4V bar stock as the test constructs. Geometric dimensions were measured via CMM on three randomly selected screws from the test lot; deviations from nominal were within ±0.03 mm. Uncertainty propagation (Monte Carlo, 10,000 samples) using material property and geometry distributions yielded 95th-percentile QoI uncertainty bands of ±3.1% (stiffness), ±4.2% (yield force), and ±2.8% (force at 40 mm)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires N≥10 test specimens with documented traceability to production-representative device lots, and statistical characterization of inter-specimen variability for each QoI.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from a single production lot (Lot #NC-7.5-2021-Q3) and tested across two independent laboratories (FDA CDRH and DePuy Synthes). Coefficient of variation for stiffness was 4.1%, yield force 5.7%, and force at 40 mm 3.9%. Traceability records (device history records, receiving inspection reports) are archived in the study file. Inter-laboratory variability was assessed and found non-significant (Welch's t-test, p>0.05 for all QoIs)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires testing across multiple load conditions or configurations representative of the clinical use envelope. Gradation 2 is satisfied by a single, well-characterized test condition with full environmental documentation.",
      "rationale": "Testing was conducted exclusively under the ASTM F1717 standard compression-bending configuration at a single load angle and displacement rate (5 mm/min). While this condition is the regulatory standard for pedicle screw construct evaluation, it represents only one point in the clinical loading envelope (axial compression combined with bending). Torsion, lateral bending, and fatigue conditions were not included in this validation activity. The achieved level of 2 reflects this single-condition limitation; the gap relative to the required level of 3 is acknowledged and mitigated by the use of N=11 specimens across two laboratories, which reduces uncertainty attributable to test setup variability. Regulatory precedent (FDA guidance on ASTM F1717 sufficiency for 510(k) submissions) supports accepting this limitation for the stated COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires quantitative demonstration that model input parameters match experimental conditions within documented uncertainty bounds, including fixture geometry, load application points, and environmental conditions.",
      "rationale": "FEA boundary conditions were set to replicate the ASTM F1717 fixture geometry as measured by the testing laboratories. Load application point coordinates were extracted from laboratory fixture drawings and confirmed against CMM measurements of the actual test fixtures. Ambient temperature (23±2°C) and humidity (50±10% RH) were recorded and confirmed to be within the range for which Ti-6Al-4V properties were characterized. Vertebral body surrogate (ultra-high-molecular-weight polyethylene block) geometry was modeled using measured dimensions from three surrogate specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires quantitative comparison metrics (percent difference and validation metric E/uval) computed for each QoI, with explicit pass/fail determination against pre-established bounds (<10% QoI difference and E/uval < 1.96).",
      "rationale": "Percent differences between FEA ensemble mean and experimental mean were: stiffness 3.8%, yield force 6.1%, force at 40 mm 4.4% — all within the 10% bound. Validation metrics E/uval were 0.82 (stiffness), 1.31 (yield force), and 0.74 (force at 40 mm) — all below 1.96. Comparison plots with experimental uncertainty bands (mean ± 2 SD) and model prediction intervals are included in the validation report (VR-COU1-v2.0, Section 5.3)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires documented traceability from model QoIs to the regulatory or clinical decision being supported. Gradation 3 additionally requires sensitivity analysis confirming that the chosen QoIs are the dominant predictors of the decision outcome.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and referenced in FDA guidance for pedicle screw 510(k) submissions. Sensitivity analysis (one-factor-at-a-time, ±20% perturbation of model inputs) confirmed that these three QoIs account for >95% of the variance in the regulatory acceptance decision. Alternative QoIs (peak von Mises stress, fatigue life) are not required for the static compression-bending COU and were excluded by design."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that the validation scenario matches the COU in device geometry, material, loading mode, and regulatory context, with documented justification for any differences between the validation scenario and the intended use scenario.",
      "rationale": "The validation activity uses the identical non-cannulated 7.5 mm pedicle screw geometry, material lot, and ASTM F1717 test protocol as the COU. No surrogate devices or scaled geometries were employed. The FEA model was not recalibrated between the validation and COU prediction phases; the same mesh, material properties, and contact definitions were used throughout. The only acknowledged difference between the validation scenario and the broader clinical use envelope is the single-condition test limitation captured under the Test conditions factor."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is mitigated by the use of N=11 specimens across two independent laboratories and by regulatory precedent supporting ASTM F1717 single-condition testing for pedicle screw 510(k) submissions. All three QoIs pass quantitative acceptance bounds (percent difference <10%, E/uval <1.96). The overall credibility evidence is assessed as sufficient to support a Medium assurance level determination, and the model is accepted for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
