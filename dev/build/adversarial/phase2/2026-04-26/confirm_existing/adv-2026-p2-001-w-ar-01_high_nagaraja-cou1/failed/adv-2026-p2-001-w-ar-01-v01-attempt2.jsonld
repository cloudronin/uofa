  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2021 R2 and the FDA in-house FEA solver are both under ISO 9001-certified quality management systems. Version control, regression test suites, and release validation reports are maintained. Gradation 2 is required at Medium model risk; Gradation 3 is achieved because all three solver environments (FDA, Ansys, DePuy Synthes) provide formal SQA documentation traceable to their respective QMS.",
      "rationale": "All three FEA environments used in the ensemble (FDA research solver, Ansys Mechanical 2021 R2, DePuy Synthes internal solver) operate under ISO 9001-certified quality management systems with documented version control and regression testing. Formal SQA reports are available for each solver release used in this study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires at least benchmark solution comparison for the element types used. Gradation 3 is achieved: each solver has been verified against NAFEMS benchmark problems for 3-D continuum and contact elements, with residuals documented in solver verification reports. Cross-solver agreement on the pedicle screw mesh (within 0.8% on stiffness) provides additional verification evidence.",
      "rationale": "Each solver environment has been independently verified against NAFEMS benchmark problems covering 3-D solid elements and frictional contact, which are the primary element types in the pedicle screw model. Cross-solver comparison of the identical mesh yielded stiffness predictions within 0.8%, providing strong corroborating verification evidence beyond what a single-solver assessment would provide."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires a formal mesh convergence study with Richardson extrapolation or equivalent. A three-level h-refinement study was conducted on the screw-rod interface region; the Grid Convergence Index (GCI) for peak von Mises stress was 1.4%, well below the 5% threshold adopted for this COU.",
      "rationale": "A three-level mesh refinement study was conducted on the critical screw-rod interface region using element edge lengths of 0.8 mm, 0.5 mm, and 0.3 mm. Richardson extrapolation yielded a GCI of 1.4% for peak von Mises stress and 0.6% for construct stiffness, confirming that the production mesh (0.5 mm at the interface) is in the asymptotic convergence range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires monitoring of iterative solver residuals and confirmation that contact convergence criteria are met. Force and moment residuals were required to fall below 0.1% of the applied load at each increment; contact status was required to be stable over the final three increments.",
      "rationale": "Nonlinear solver convergence was monitored across all load increments. Force residuals converged to below 0.05% of applied load and contact status was stable over the final three increments in all 11 model instances, satisfying the Gradation 2 requirement for documented solver convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires a documented modeling protocol and independent review of model setup by a second analyst. The modeling protocol specifying boundary conditions, contact definitions, material assignments, and load application was reviewed by a second FDA engineer not involved in model construction.",
      "rationale": "A written modeling protocol was developed prior to analysis, specifying all boundary conditions, contact pair definitions, material property assignments, and load application procedures. An independent FDA engineer reviewed the model setup against the protocol and confirmed compliance. No deviations were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires justification of constitutive model selection with supporting literature and sensitivity analysis on key model form assumptions. Titanium alloy (Ti-6Al-4V) was modeled as bilinear isotropic hardening; sensitivity to kinematic vs. isotropic hardening was evaluated and found to change predicted yield force by less than 2%.",
      "rationale": "The bilinear isotropic hardening model for Ti-6Al-4V was selected based on published monotonic tensile data and is consistent with prior FDA pedicle screw FEA studies. A sensitivity study comparing isotropic and kinematic hardening formulations showed less than 2% difference in predicted yield force, confirming that the model form choice does not materially affect the QoIs under monotonic loading."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that material properties and geometric inputs are traceable to measured values from the test specimens or certified material data, and that input uncertainty is quantified. Elastic modulus, yield strength, and tangent modulus were taken from coupon tests on the same Ti-6Al-4V bar stock; geometric dimensions were measured on three representative screws using CMM.",
      "rationale": "All material inputs (elastic modulus 114 GPa, yield strength 880 MPa, tangent modulus 1.8 GPa) were derived from uniaxial tensile coupon tests on the same bar stock used to manufacture the test constructs. Screw and rod geometry was verified by CMM measurement of three representative specimens, with dimensional deviations less than 0.02 mm from nominal CAD."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires N≥10 test specimens with documented traceability to the same design and manufacturing lot as the device being modeled. N=11 constructs were tested across two independent laboratories; all specimens were from the same manufacturing lot and verified dimensionally prior to testing.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (N=6 at Lab A, N=5 at Lab B). All specimens were drawn from the same manufacturing lot and underwent dimensional verification by CMM prior to testing. Inter-laboratory variability in stiffness was 3.2% (CV), consistent with typical ASTM F1717 repeatability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires testing across multiple clinically relevant load configurations or boundary condition variants. Only the standard ASTM F1717 compression-bending configuration (5° offset, 10 mm superior block) was tested; no additional load cases (e.g., torsion, tension-bending) were included in this validation activity. Gradation 2 is achieved because the single configuration is fully standardized and directly maps to the COU, but the absence of multi-condition coverage prevents Gradation 3.",
      "rationale": "Testing was conducted exclusively under the standard ASTM F1717 static compression-bending configuration. While this configuration is the regulatory standard and directly corresponds to the intended COU, only a single test condition was evaluated. This limits the validation evidence to one load path and prevents assessment of model fidelity under alternative boundary conditions that could arise in clinical use. The assessment team acknowledges this limitation and accepts Gradation 2 as sufficient given that the COU is explicitly bounded to the F1717 compression-bending scenario."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires formal demonstration that model input parameters match experimental conditions, including contact conditions, fixture geometry, and applied displacement rate effects. Fixture geometry was digitized from the physical test setup and incorporated into the FEA model; quasi-static loading rate (1 mm/min) was confirmed to produce negligible rate effects by strain-rate sensitivity analysis.",
      "rationale": "The ASTM F1717 test fixture geometry was digitized using structured-light scanning and the resulting surface was incorporated directly into the FEA boundary conditions. Applied displacement was matched to the experimental crosshead displacement; a strain-rate sensitivity analysis confirmed that the 1 mm/min loading rate produces less than 0.5% difference in yield force compared to a truly quasi-static reference, satisfying the equivalency requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires quantitative comparison using a validation metric that accounts for both model error and experimental uncertainty, such as E/uval. The validation metric E/uval was computed for each QoI; all three QoIs (stiffness, yield force, force at 40 mm) yielded |E/uval| < 1.96, indicating that model error is within the combined experimental uncertainty at the 95% confidence level.",
      "rationale": "The validation metric E/uval was computed for construct stiffness (0.84), yield force (1.12), and force at 40 mm displacement (1.31). All values fall below the 1.96 threshold, indicating that the model error for each QoI is statistically indistinguishable from zero at the 95% confidence level when experimental uncertainty is accounted for. Percentage differences were 3.1%, 5.7%, and 4.9% respectively, all within the pre-specified 10% bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "rationale": "The three quantities of interest — construct stiffness, yield force, and force at 40 mm displacement — are the primary metrics specified in ASTM F1717 and directly correspond to the mechanical performance parameters used in the regulatory submission. Stiffness characterizes the elastic load-sharing behavior of the construct; yield force identifies the onset of permanent deformation; force at 40 mm is the standard failure surrogate. These QoIs have been used in multiple prior FDA 510(k) submissions for pedicle screw systems and are accepted by FDA as clinically meaningful surrogates for construct integrity. The mapping from QoI to clinical consequence (loss of fixation leading to revision surgery) is well-established in the biomechanical literature. Furthermore, sensitivity analysis confirmed that the QoIs are the dominant drivers of the model risk assessment, and that perturbations to secondary outputs (e.g., local stress concentrations at the screw-rod interface) do not alter the regulatory conclusion. The breadth of clinical and regulatory precedent supporting these QoIs, combined with the direct traceability to the ASTM standard, justifies achievement of Gradation 4 — the QoIs are not merely relevant to the COU but are the definitive regulatory endpoints for this device class. No additional QoIs are required to fully characterize the compression-bending performance for the intended decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that the validation activity directly replicates the geometry, loading, and boundary conditions of the COU, with testing performed on the same device design. The validation constructs used the identical non-cannulated 7.5 mm screw design, the same ASTM F1717 fixture, and the same loading protocol as the COU. The only difference between the validation activity and the COU is that the validation uses physical specimens while the COU uses the calibrated FEA model for prediction.",
      "rationale": "The validation activity directly mirrors the COU: identical non-cannulated 7.5 mm screw geometry, identical ASTM F1717 test configuration, and identical QoIs. The validation was conducted on production-representative specimens from the same manufacturing lot. There are no material differences between the validation scenario and the intended COU that would diminish the relevance of the validation evidence."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for COU1 is Accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed their required gradation level. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — is accepted because the COU is explicitly bounded to the ASTM F1717 compression-bending configuration, the single tested condition directly maps to the regulatory submission scenario, and the quantitative validation metrics (E/uval < 1.96 for all QoIs) demonstrate adequate model fidelity within that configuration. The model risk level of 3 is consistent with Medium assurance requirements, and the decision consequence of Medium does not warrant elevation to High assurance. No unmitigated risks were identified that would preclude use of the FEA model for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
