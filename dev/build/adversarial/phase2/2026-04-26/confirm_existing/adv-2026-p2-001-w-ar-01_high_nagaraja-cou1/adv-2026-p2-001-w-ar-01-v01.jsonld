  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level 2 requires documented version control, regression test suite, and traceable build records. Criterion met when all three artifacts are present and reviewed by an independent QA signatory.",
      "rationale": "The FEA ensemble employs Ansys Mechanical 2021R2 under a validated installation qualification (IQ/OQ) protocol. Version control is maintained in a Git repository with signed commits; a regression test suite of 47 benchmark problems is executed on each code release. All three simulation organizations provided build manifests and IQ/OQ certificates reviewed by an independent QA engineer. Gradation 2 is appropriate for a medium-risk COU where the model is used to support (not replace) physical testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification at level 2 requires documented comparison against at least two analytical or manufactured solutions relevant to the physics of interest, with errors below 1% for each.",
      "rationale": "Code verification was performed against the Timoshenko beam bending analytical solution and a patch-test for contact mechanics. Errors in both cases were below 0.3%, confirming that the discretization scheme and contact formulation are correctly implemented. Results are archived in the project verification report VR-2023-001."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error level 3 requires a formal mesh convergence study with Richardson extrapolation and a reported Grid Convergence Index (GCI) below 2% for all primary QoIs.",
      "rationale": "A three-level mesh refinement study was conducted on the pedicle screw shank and rod junction, the regions of highest stress gradient. Richardson extrapolation yielded a GCI of 1.4% for stiffness and 1.8% for yield force. The production mesh (approximately 380,000 elements, predominantly second-order hexahedral) was selected as the converged configuration. Element quality metrics (Jacobian ratio > 0.6, aspect ratio < 5) were verified across all three FEA organizations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver error level 2 requires demonstration that iterative convergence tolerances are set to values that do not materially affect QoI predictions, supported by a tolerance sensitivity study.",
      "rationale": "Force-displacement equilibrium residuals were converged to 1e-4 relative tolerance for all load steps. A tolerance sensitivity study confirmed that tightening to 1e-6 changed predicted stiffness by less than 0.05%. Nonlinear contact stabilization was disabled for the production runs after confirming it introduced no artificial stiffness at the screw-rod interface."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Use error level 2 requires a documented modeling protocol, an independent peer review of simulation inputs by a second analyst, and a checklist-based sign-off prior to each production run.",
      "rationale": "A standardized simulation protocol document (SPD-FEA-001, Rev C) governs all analyst interactions with the model. Each production run is reviewed by a second analyst using a 38-item checklist covering geometry import, material assignment, boundary condition application, and output extraction. No use errors were identified during the three independent laboratory reproductions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form level 3 requires documented justification of all constitutive assumptions, including material nonlinearity, contact formulation, and geometric simplifications, with sensitivity analyses quantifying the impact of each assumption on primary QoIs.",
      "rationale": "The pedicle screw and rod are modeled as bilinear isotropic hardening elasto-plastic Ti-6Al-4V (E=114 GPa, sigma_y=880 MPa, tangent modulus=2.2 GPa). Geometric nonlinearity is enabled for all load steps exceeding 5% nominal strain. The UHMWPE vertebral body surrogate is modeled as a linear elastic solid (E=0.5 GPa), consistent with the ASTM F1717 test block specification. Sensitivity analyses showed that a ±10% variation in surrogate stiffness changed predicted construct stiffness by less than 2%, confirming the simplification is acceptable."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs level 3 requires traceability of all material and geometric inputs to primary sources (coupon test data or manufacturer specifications), with uncertainty bounds quantified for each input and propagated through the model.",
      "rationale": "Material properties were sourced from tensile coupon testing of the same Ti-6Al-4V bar stock used for device manufacture (n=5 coupons per batch, two batches). Geometric dimensions were measured from production drawings and verified by CMM inspection of three representative screws. Input uncertainty was propagated using a one-at-a-time sensitivity study; the combined input uncertainty contribution to stiffness prediction was 3.1%, well within the 10% acceptance bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples level 3 requires that experimental specimens are production-representative, with dimensional and material traceability documented, and that sample size is sufficient to characterize inter-specimen variability at the 90% confidence level.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production-lot hardware. Dimensional inspection confirmed all screws were within drawing tolerance. Material certificates of conformance were retained for each lot. Statistical power analysis confirmed that N=11 provides 90% confidence in detecting a 10% difference in mean stiffness, consistent with the acceptance bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions level 3 requires that the validation experiment spans the range of loading conditions represented in the COU, including at least two distinct load levels or configurations. Level 2 is accepted when a single standardized test configuration is used and the deviation is formally documented with a risk assessment.",
      "rationale": "Testing was performed under the single ASTM F1717 standardized compression-bending configuration (5° offset, 75 mm moment arm). Only one load configuration was evaluated, which limits the test conditions factor to Gradation 2 against a required level of 3. This shortfall is acknowledged in the credibility assessment summary. The risk is partially mitigated by the high fidelity of the ASTM F1717 protocol to the clinical loading environment and by the strong agreement observed across all three QoIs at the tested configuration. A formal gap analysis (document GA-TC-001) concludes that the single-condition test is sufficient for the medium-risk COU given that the regulatory submission does not claim predictive validity outside the F1717 envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Equivalency of input parameters level 3 requires a documented mapping between all experimental boundary conditions and model inputs, with quantified uncertainty in that mapping for each primary QoI.",
      "rationale": "A parameter equivalency matrix maps each experimental boundary condition (fixture compliance, applied displacement rate, surrogate block density) to the corresponding FEA input. Fixture compliance was measured at 0.8 N/mm and incorporated as a spring boundary condition in the model. Displacement rate effects were confirmed negligible by a quasi-static rate sensitivity study. All mapping uncertainties were included in the combined validation uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Output comparison level 3 requires a quantitative metric (e.g., E/uval or MAPE) computed for each QoI, with a pre-specified acceptance threshold documented before unblinding of experimental results.",
      "rationale": "The validation metric E/uval was pre-specified as the primary comparison metric, with an acceptance threshold of E/uval < 1.96 (95% confidence interval criterion). Results: stiffness E/uval = 1.31, yield force E/uval = 0.87, force at 40 mm E/uval = 1.14. All three QoIs satisfy the pre-specified threshold. Secondary MAPE values were 4.2%, 3.8%, and 5.1% respectively, all below the 10% bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and are directly cited in the 510(k) predicate device comparison. These QoIs are mechanistically linked to the clinical failure modes of construct loosening (stiffness) and screw fracture (yield force). The QoI selection was reviewed and endorsed by the FDA project manager during the pre-submission meeting (Q-sub reference Q200123). The relevance of these quantities to the COU is considered high, and the achieved level exceeds the required level, providing additional confidence margin. No surrogate or indirect QoIs are used; all outputs are directly measurable experimental quantities with well-established clinical correlates in the spinal implant literature. The achieved level of 4 reflects that the QoIs are not merely relevant but are the regulatory standard of reference for this device class, with published normative ranges available from multiple independent research groups. This factor contributes positively to the overall credibility score and partially offsets the shortfall in the Test conditions factor. The QoI selection protocol was documented prior to model construction, eliminating the possibility of post-hoc QoI selection bias. Sensitivity of the overall credibility conclusion to QoI choice was assessed by hypothetically substituting peak von Mises stress as an alternative QoI; the credibility conclusion was unchanged, confirming robustness of the QoI selection."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Relevance of validation activities level 3 requires that the validation experiment is conducted with production-representative hardware, under conditions that directly replicate the COU geometry and loading, and that any deviations from the COU are formally assessed for their impact on the validation conclusion.",
      "rationale": "The validation experiment used production-representative non-cannulated 7.5 mm pedicle screws assembled per the surgical technique guide, tested under the ASTM F1717 protocol that directly defines the regulatory COU. Two independent test laboratories participated, providing inter-laboratory reproducibility data. Deviations from the clinical COU (in vitro vs. in vivo, room temperature vs. body temperature, static vs. cyclic loading) were assessed in a formal relevance matrix; none were judged to materially affect the validation conclusion for the static compression-bending COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed their required gradation level. The Test conditions factor achieves Gradation 2 against a required level of 3; this shortfall is formally documented in gap analysis GA-TC-001 and accepted on the basis that the ASTM F1717 protocol is the regulatory standard of reference for this device class and the single-condition test is sufficient for the medium-risk COU. The overall credibility score supports a Medium assurance level, consistent with the model risk level of 3 and the medium decision consequence. The FEA framework is accepted as sufficiently credible to support the 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
