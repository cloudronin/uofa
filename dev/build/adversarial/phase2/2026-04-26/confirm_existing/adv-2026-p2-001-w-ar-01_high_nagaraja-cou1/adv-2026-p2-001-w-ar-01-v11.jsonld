  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA solver must hold a traceable QA record compliant with FDA 21 CFR Part 820 or equivalent; version control and regression test suite must be documented and available for audit.",
      "rationale": "The FEA software (Ansys Mechanical 2021 R2) is maintained under a documented software quality plan that satisfies FDA 21 CFR Part 820 design-control requirements. Version control is managed through a validated configuration-management system; all solver releases used in this study are traceable to a specific build hash. A regression test suite of 47 benchmark problems is executed prior to each solver update, and pass/fail records are retained in the project quality management system. The required level of 2 reflects the medium model-risk designation and the availability of independent experimental data that can catch gross software errors even without exhaustive formal qualification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce published NAFEMS benchmark results for contact and large-displacement beam problems to within 1% relative error.",
      "rationale": "Code verification was performed against three NAFEMS benchmarks: LE1 (Elliptic membrane), R0031/1 (Contact patch test), and NL1 (Large-displacement cantilever). Relative errors were 0.3%, 0.7%, and 0.5% respectively, all within the 1% tolerance. These benchmarks exercise the contact formulation and geometric nonlinearity that are central to the pedicle screw compression-bending simulation. Results are documented in internal verification report VR-2021-047."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that QoI predictions change by less than 2% between the penultimate and final refinement levels; Richardson extrapolation GCI must be below 3% for all primary QoIs.",
      "rationale": "A three-level mesh refinement study was conducted using element edge lengths of 1.2 mm, 0.8 mm, and 0.5 mm in the screw shank and rod regions. Stiffness QoI changed by 1.1% between the two finest levels; yield force changed by 0.8%. Richardson extrapolation gave GCI values of 1.4% and 1.1% respectively, both well below the 3% threshold. The 0.8 mm mesh was selected for production runs as the optimal balance of accuracy and computational cost. Contact region element density was held constant at 0.3 mm regardless of global refinement level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge to below 1e-6 relative norm for all load steps; energy balance error must remain below 0.1% across the full loading history.",
      "rationale": "All simulations used a direct sparse solver (PARDISO) with double-precision arithmetic. Residual norms at convergence were consistently below 1e-8. Energy balance was monitored at each load increment; the maximum energy balance error observed across all 11 replicate simulations was 0.04%. No load steps required bisection beyond two levels, confirming robust convergence throughout the nonlinear loading path."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be performed by at least two independent analysts using a written simulation protocol; a peer-review checklist must be completed and archived prior to result extraction.",
      "rationale": "A detailed simulation protocol (SP-2021-003) was authored prior to any production runs and reviewed by three senior analysts. Each of the 11 replicate models was independently set up by a primary analyst and reviewed by a secondary analyst using a 34-item checklist covering geometry import, material assignment, boundary condition application, contact definition, and load curve specification. All checklists were archived in the project document management system. No discrepancies requiring model correction were identified during secondary review, providing high confidence that use errors did not influence the reported QoI values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection must be justified by literature precedent or sensitivity analysis; simplifying assumptions must be documented and their impact on QoIs bounded quantitatively.",
      "rationale": "The continuum linear-elastic model form for titanium alloy (Ti-6Al-4V) components is well established in the orthopedic implant literature and is consistent with ASTM F1717 testing conditions where strains remain below the yield threshold for the rod and connector components. A bilinear isotropic hardening plasticity model was applied to the screw shank to capture post-yield behavior observed experimentally. Bone analog (UHMWPE block) was modeled as elastic-perfectly plastic based on published characterization data. Sensitivity analyses confirmed that ±10% variation in bone analog modulus produced less than 3% change in construct stiffness, bounding the impact of this simplification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties must be sourced from peer-reviewed literature or direct measurement with stated uncertainty; geometric inputs must be derived from traceable metrology reports with dimensional tolerances documented.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and yield strength (880 MPa) were taken from ASTM F136 and confirmed against three independent literature sources. UHMWPE block properties were measured in-house using uniaxial compression testing (n=5 specimens per lot); mean modulus 0.96 GPa ± 0.08 GPa. Screw and rod geometry was derived from manufacturing drawings with ±0.05 mm dimensional tolerance; a sensitivity analysis showed that worst-case geometric variation produced less than 1.5% change in stiffness QoI. All input values and their sources are tabulated in model input record MIR-2021-011."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample population must consist of at least 10 constructs assembled from production-representative components; lot traceability must be documented for all implant components.",
      "rationale": "Eleven constructs were assembled from production-representative 7.5 mm non-cannulated pedicle screws and 5.5 mm titanium rods drawn from three separate manufacturing lots. Component dimensions were verified by coordinate measuring machine prior to assembly; all measurements fell within drawing tolerances. Lot traceability records are archived in quality record QR-2021-088. The sample size of 11 provides adequate statistical power to estimate the mean QoI with 90% confidence intervals of approximately ±8% based on the observed coefficient of variation of 4.2%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must be conducted under at least two independent load configurations or laboratories to bound environmental and operator variability; displacement rate must be controlled to within ±5% of the nominal ASTM F1717 specified rate.",
      "rationale": "Testing was conducted at two independent laboratories (Lab 1, n=6; Lab 2, n=5) using servo-hydraulic test frames calibrated within 12 months of testing. Displacement rate was maintained at 5 mm/min ± 0.2 mm/min (±4%), within the ±5% tolerance. However, only a single load configuration (ASTM F1717 compression-bending at 0° offset) was evaluated; the required level of 3 anticipates at least two configurations or a broader environmental envelope. The achieved level of 2 reflects the single-condition limitation. This shortfall is acknowledged and accepted given that the COU is explicitly scoped to the ASTM F1717 compression-bending scenario and the model is not intended for extrapolation to other loading modes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Equivalency between model inputs and test conditions was established through a systematic parameter-mapping exercise documented in equivalency report ER-2021-005. Each model boundary condition was traced to a corresponding test fixture measurement: grip separation was set to the mean measured value (100.2 mm ± 0.4 mm); block constraint conditions replicated the measured fixture stiffness (>500 N/mm, effectively rigid relative to construct stiffness of ~35 N/mm); applied displacement waveform in the model matched the test machine command signal. Material property inputs were confirmed against lot-specific certificates of conformance for implant components and against in-house compression test data for UHMWPE blocks from the same lots used in testing. The mapping table confirms that all 14 identified input parameters have a documented experimental counterpart with quantified uncertainty, satisfying the requirements for Gradation 3 equivalency. No parameter required assumption-based substitution; all were directly measured or specified by the test protocol. Cross-laboratory equivalency was confirmed by comparing fixture compliance measurements between Lab 1 and Lab 2; the difference in effective fixture stiffness was less than 3%, well within the sensitivity range identified in the model input uncertainty analysis. This thorough parameter mapping provides high confidence that the model is being exercised under conditions that faithfully represent the physical test, and that any discrepancy between predicted and measured QoIs can be attributed to model form or numerical sources rather than input mismatch."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric E/uval must be below 1.96 for all primary QoIs; percent difference between mean predicted and mean experimental QoI must be below 10%.",
      "rationale": "Output comparison was performed using the ASME V&V 40 validation metric E/uval, where E is the difference between mean model prediction and mean experimental result, and uval is the combined validation uncertainty. Results: construct stiffness E/uval = 0.84 (difference 3.2%); yield force E/uval = 1.21 (difference 5.7%); force at 40 mm displacement E/uval = 1.09 (difference 4.1%). All three QoIs satisfy both acceptance criteria (E/uval < 1.96 and percent difference < 10%). Detailed calculations are provided in validation summary report VSR-2021-019."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation must be directly traceable to the clinical or regulatory decision being supported; a written QoI selection rationale must be archived.",
      "rationale": "The three QoIs (construct stiffness, yield force, force at 40 mm displacement) were selected because they are the primary outputs specified in ASTM F1717 and are the metrics used by FDA reviewers to evaluate pedicle screw construct mechanical performance in 510(k) submissions. QoI selection rationale is documented in study design report SDR-2021-001, which traces each QoI to a specific regulatory acceptance criterion and to the clinical failure mode it bounds. Construct stiffness bounds implant micromotion under physiological loading; yield force bounds the onset of permanent deformation; force at 40 mm displacement bounds ultimate structural integrity. The selection of these three QoIs ensures that the validation evidence is directly relevant to the regulatory decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activity must replicate the COU geometry, loading mode, and material system; any differences between the validation scenario and the COU must be documented with a quantitative bounding argument.",
      "rationale": "The validation activity directly replicates the COU: the same 7.5 mm non-cannulated screw geometry, the same ASTM F1717 compression-bending loading mode, and the same Ti-6Al-4V material system are used in both the validation experiments and the production FEA. The UHMWPE bone analog is the standard surrogate specified by ASTM F1717 and is the same material modeled in the FEA. No surrogate geometry or scaled model was used. The only identified difference between the validation scenario and the broader COU is that the validation testing was conducted at room temperature (23°C ± 2°C) whereas in vivo temperatures may reach 37°C; however, Ti-6Al-4V mechanical properties change by less than 2% over this range, which is within the measurement uncertainty of the experimental QoIs. This bounding argument is documented in equivalency report ER-2021-005 Section 4.3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed their required credibility level. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — is accepted because the COU is explicitly scoped to the ASTM F1717 compression-bending scenario and the model is not intended for use in other loading configurations. The overall credibility evidence, including E/uval values below 1.96 for all three primary QoIs and percent differences below 10%, is sufficient to support a Medium assurance level conclusion. The FEA modeling framework is accepted as credible for predicting non-cannulated 7.5 mm pedicle screw construct compression-bending performance within the defined COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
