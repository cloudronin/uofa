  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation software (Ansys Mechanical 2022 R2) is under formal configuration management with version-controlled input decks. All solver executables are hash-verified against vendor-released binaries. Gradation 2 requires documented version control and regression test suite; Gradation 3 additionally requires formal V&V of solver modules relevant to the COU.",
      "rationale": "Ansys Mechanical 2022 R2 was used under an FDA-licensed installation. The software version, patch level, and solver settings are archived in the study record. An internal regression test suite covering linear-elastic contact and large-displacement beam bending was executed prior to the study run, with all 47 test cases passing. Required level set at Gradation 2 consistent with Medium model risk and Medium decision consequence per Table 2 of ASME V&V 40-2018."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires comparison of solver output against at least one analytical or manufactured solution for a problem class representative of the COU physics. Acceptance threshold: predicted QoI within 1% of analytical reference for benchmark cases.",
      "rationale": "A cantilever beam benchmark (Euler-Bernoulli, linear elastic, Ti-6Al-4V material properties) was solved in Ansys and compared against the closed-form tip deflection and root bending moment. Predicted values agreed to within 0.3%, satisfying the Gradation 2 threshold. The benchmark geometry and material are sufficiently representative of the pedicle screw rod-and-screw bending problem."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires a systematic mesh convergence study with at least three refinement levels and a Richardson extrapolation-based estimate of the grid convergence index (GCI). GCI for primary QoIs must be below 5%.",
      "rationale": "A three-level mesh refinement study was conducted on the non-cannulated screw geometry (coarse: ~85k elements, medium: ~210k elements, fine: ~520k elements). Richardson extrapolation yielded GCI values of 2.1% for stiffness, 3.4% for yield force, and 1.8% for force at 40 mm displacement, all below the 5% threshold. The fine mesh was adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires monitoring of iterative solver residuals to convergence tolerances specified a priori. Force and displacement residuals must fall below 1e-4 (normalized) before solution is accepted.",
      "rationale": "Newton-Raphson nonlinear iterations were run with force and displacement convergence criteria of 1e-5 (normalized L2 norm), one order of magnitude tighter than the Gradation 2 threshold. All 11 model runs converged within 35 substeps; no unconverged increments were accepted. Solver log files are archived in the study record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires a documented simulation plan reviewed by an independent analyst, with a checklist confirming correct boundary condition application, material assignment, and load magnitude prior to each run.",
      "rationale": "A simulation plan was prepared prior to study execution and reviewed by a second qualified analyst not involved in model construction. A pre-run checklist covering boundary conditions, material property assignments, contact definitions, and load application was completed and signed for each of the 11 model instances. No deviations from the simulation plan were recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires documented justification of all constitutive model selections with reference to literature or prior validation data, and sensitivity analysis demonstrating that alternative plausible model forms change primary QoIs by less than 10%.",
      "rationale": "A bilinear isotropic hardening plasticity model (Ti-6Al-4V: E=114 GPa, yield=880 MPa, tangent modulus=1.2 GPa) was selected based on published tension coupon data and prior FDA FEA validation studies. An alternative linear-elastic model and a multilinear kinematic hardening model were also run; QoI differences relative to the primary model were 4.2% and 2.8% respectively, both within the 10% sensitivity threshold. The UHMWPE vertebral body surrogate was modeled as linear elastic (E=1.0 GPa), consistent with ASTM F1717 block stiffness characterization data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that all model inputs are traceable to measured data or published standards, with uncertainty bounds quantified and propagated through the model to QoI uncertainty estimates.",
      "rationale": "Geometric inputs were derived from calibrated CMM measurements of each of the 11 physical constructs (screw diameter, rod diameter, interbody distance). Material property inputs were taken from ASTM F136 (Ti-6Al-4V) with uncertainty bounds from the published literature. A Monte Carlo propagation study (N=1000 samples) was conducted, yielding 95th-percentile QoI uncertainty bands of ±3.1% for stiffness and ±4.7% for yield force, which were incorporated into the validation comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires that test samples are from the same design family as the simulated device and that sample size is sufficient to characterize mean QoI behavior. Gradation 3 additionally requires full dimensional characterization of each test article.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested, all manufactured from the same production lot. Full dimensional inspection (CMM) was performed on each construct prior to testing. Samples were split across two independent laboratories (6 and 5 constructs respectively) to assess inter-laboratory variability. The sample size exceeds the Gradation 2 minimum and the per-construct dimensional data supports Gradation 3 achievement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires that at least two distinct loading conditions or configurations are tested to bound the model's predictive domain. Gradation 1 is achieved when testing is performed under a single standardized protocol only.",
      "rationale": "Testing was performed exclusively under the ASTM F1717 static compression-bending protocol at a single load angle and displacement rate. No additional load cases (e.g., torsion, fatigue, dynamic) were included in this validation activity. This limits the achieved level to Gradation 1, which is below the required Gradation 2. This shortfall is noted as a limitation of the current validation scope; the decision to accept the overall credibility assessment despite this gap is documented in the decision record, where the strength of the remaining 12 factors and the direct regulatory applicability of the F1717 protocol are cited as mitigating considerations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires documented mapping of all experimental boundary conditions and loads to their simulation counterparts, with quantified differences where exact equivalence is not achievable.",
      "rationale": "A parameter equivalency table was prepared mapping each experimental setup parameter (grip displacement rate, fixture stiffness, block material properties, construct assembly torque) to the corresponding simulation input. Fixture compliance was measured on the test machine and incorporated as a spring element in the FEA boundary conditions. Assembly torque was converted to an equivalent preload using a thread friction model calibrated to torque-tension measurements on representative fasteners."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Predicted QoIs (construct stiffness, yield force, force at 40 mm displacement) were compared against experimental means using the validation metric E/uval, where E is the model-experiment difference and uval is the combined experimental and model uncertainty. For all three QoIs, |E/uval| < 1.96 (stiffness: 1.31, yield force: 0.87, force at 40 mm: 1.54), satisfying the pre-specified acceptance criterion at the 95% confidence level. Percentage differences were 4.2%, 2.9%, and 6.7% respectively, all within the <10% QoI difference bound. The validation metric approach follows ASME V&V 40-2018 Section 5.4 and is consistent with Gradation 3 requirements for a quantitative uncertainty-aware comparison. The breadth of QoI coverage — spanning stiffness-dominated, yield-dominated, and post-yield regimes — provides confidence that the model captures the full compression-bending response envelope relevant to the COU. Inter-laboratory consistency of experimental results (coefficient of variation <5% across labs for all QoIs) further supports the reliability of the experimental reference data against which the model is compared. Taken together, the output comparison provides strong quantitative evidence that the FEA model ensemble meets the predictive accuracy requirements established for this COU at the Medium assurance level.",
      "acceptanceCriteria": "Gradation 3 requires a quantitative uncertainty-aware validation metric (e.g., E/uval) applied to all primary QoIs, with pre-specified acceptance thresholds documented before comparison is performed. Threshold: |E/uval| < 1.96 for each QoI AND percentage difference < 10% for each QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires that the QoIs used in validation are the same physical quantities used in the regulatory submission claim. Gradation 3 additionally requires that the QoIs span the range of clinical loading conditions anticipated in the COU.",
      "rationale": "The three QoIs (stiffness, yield force, force at 40 mm displacement) are identical to those reported in the regulatory submission and directly correspond to the ASTM F1717 performance characterization required by FDA guidance. These quantities span the elastic, yield-onset, and post-yield regimes of the construct response, providing comprehensive coverage of the mechanical behavior relevant to clinical use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that the validation scenario matches the COU in device geometry, material, loading mode, and boundary conditions, with documented justification for any differences between the validation scenario and the intended clinical use scenario.",
      "rationale": "The validation activity uses the production non-cannulated 7.5 mm pedicle screw geometry, Ti-6Al-4V material, ASTM F1717 UHMWPE vertebral body surrogates, and static compression-bending loading — all directly representative of the COU. Differences between the bench test scenario and in vivo use (absence of biological tissue, static vs. cyclic loading, idealized vertebral geometry) are documented and judged acceptable given that the regulatory submission relies on the F1717 protocol as the primary performance benchmark."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for COU1 is Accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed their required gradation levels. The single shortfall — Test conditions achieving Gradation 1 against a required Gradation 2 — is mitigated by the direct regulatory applicability of the ASTM F1717 protocol, the strong quantitative validation results across all three QoIs (|E/uval| < 1.96 for all), and the inter-laboratory consistency of the experimental reference data. The credibility assessment team judges that the aggregate evidence is sufficient to support the regulatory claim that the FEA modeling framework reliably predicts compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct within the stated acceptance bounds.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
