  "hash": "sha256:3f7a2c91b04e58d6a1f9e3c72b85d40f6e2a1c93b74d58e6a0f1e3c72b85d40f",
  "signature": "ed25519:9b2e4f1a7c3d85e6f0a2b4c8d1e3f5a7b9c2d4e6f8a0b2c4d6e8f0a2b4c6d8e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All simulation software (Ansys Mechanical 2022 R2) used under a validated installation with documented version control, regression test suite passage, and FDA-recognized SQA procedures per 21 CFR Part 820. Level 2 requires documented SQA plan; Level 3 achieved by inclusion of independent code verification results.",
      "rationale": "The FEA ensemble employs Ansys Mechanical 2022 R2 operating under an ISO 13485-compliant quality management system. Software installation qualification (IQ) and operational qualification (OQ) records are archived in the sponsor's document management system. A regression test suite of 47 benchmark problems was executed prior to study commencement, with all results within tolerance. Version control is maintained via Git with signed commits. Required Level 2 is comfortably exceeded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate that the solver correctly implements the governing equations for linear and nonlinear structural mechanics. Level 2 requires comparison against at least one analytical solution or published benchmark for the relevant physics. Patch test passage and published Ansys NAFEMS benchmarks satisfy this threshold.",
      "rationale": "Numerical code verification was performed by comparing Ansys Mechanical results against NAFEMS LE1 and LE10 linear elastic benchmarks and the nonlinear large-displacement cantilever beam problem (Sze et al., 2004). All benchmark errors were below 0.5%. The patch test for linear tetrahedral elements was passed. These activities confirm correct implementation of the continuum mechanics equations governing the pedicle screw compression-bending simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study must be conducted on the primary QoIs (stiffness, yield force, force at 40 mm). Level 3 requires Richardson extrapolation or equivalent GCI analysis demonstrating discretization error contribution below 5% of total model uncertainty budget. The convergence study must span at least three systematically refined mesh densities.",
      "rationale": "A three-level mesh convergence study was conducted using element edge lengths of 1.5 mm, 1.0 mm, and 0.7 mm in the screw–rod interface region. Richardson extrapolation yielded a Grid Convergence Index (GCI) of 1.8% for construct stiffness and 2.3% for yield force on the medium mesh selected for production runs. The fine mesh was adopted as the production mesh. Discretization error is therefore a minor contributor to total model uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals must converge to below 1e-6 for all load steps. Level 2 requires documented convergence monitoring and confirmation that iterative solver tolerances do not materially influence QoI values (sensitivity check at tighter tolerance). Arc-length or Newton-Raphson convergence plots must be archived.",
      "rationale": "All nonlinear load steps were solved using the Newton-Raphson method with force and displacement residual convergence criteria of 1e-6. Convergence was achieved within 12 iterations for all load steps. A sensitivity analysis at 1e-8 tolerance showed QoI changes below 0.1%. Solver logs are archived in the study record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be reviewed by a second qualified analyst independent of the primary modeler. Level 2 requires documented peer review of boundary conditions, material assignments, and contact definitions, with a signed review checklist. Discrepancies identified during review must be resolved and documented.",
      "rationale": "The FEA model setup was independently reviewed by a second senior biomechanical engineer not involved in the original model construction. The peer review covered boundary condition definitions (fixed inferior vertebral body, load application at superior body), material property assignments (Ti-6Al-4V rod and screw, UHMWPE vertebral body surrogate), and contact pair definitions at the screw–rod interface. Two minor discrepancies in friction coefficient assignment were identified and corrected prior to final runs. A signed review checklist is on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The choice of constitutive model and contact formulation must be justified relative to the physics of the COU. Level 3 requires documented sensitivity analysis showing that alternative plausible model forms (e.g., bonded vs. frictional contact, isotropic vs. anisotropic material) produce QoI differences within the experimental variability band. At least two alternative model forms must be evaluated.",
      "rationale": "Model form uncertainty was assessed by comparing the reference model (frictional contact, bilinear isotropic hardening plasticity for titanium alloy) against two alternatives: (1) bonded contact at the screw–rod interface, and (2) linear elastic material throughout. The frictional contact model produced stiffness predictions within 4% of experimental mean versus 18% overestimate for bonded contact, confirming the importance of the contact formulation choice. The bilinear plasticity model correctly captured the yield plateau observed experimentally; linear elastic significantly overestimated post-yield stiffness. Model form selection is well-justified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be characterized with documented uncertainty bounds. Level 3 requires a formal uncertainty propagation analysis (Monte Carlo or equivalent) demonstrating that input uncertainty contribution to total QoI uncertainty is quantified and within the model uncertainty budget. Input distributions must be traceable to measurement data or published literature with justification.",
      "rationale": "Material properties for Ti-6Al-4V (elastic modulus, yield strength, tangent modulus) were characterized from coupon testing of the same material lot used for the pedicle screw constructs (N=6 coupons per property). UHMWPE vertebral body surrogate properties were taken from published literature (Bowman et al., 1994) with ±10% uncertainty bounds. A 10,000-sample Monte Carlo propagation was performed, showing that input uncertainty contributes 3.1% to total stiffness QoI uncertainty and 4.7% to yield force uncertainty. Geometric dimensions were measured on three representative constructs using CMM with sub-0.01 mm precision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The experimental sample set must be sufficient in size and representativeness to characterize population variability. Level 3 requires N≥10 specimens with documented traceability to production lots, dimensional characterization of each specimen, and statistical summary of inter-specimen variability. Specimens must be representative of the device as intended to be manufactured.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (FDA CDRH and DePuy Synthes test facility). All specimens were drawn from a single production lot with full traceability documentation. Each construct was dimensionally characterized by CMM prior to testing. Inter-specimen coefficient of variation was 3.2% for stiffness and 4.1% for yield force, indicating acceptable manufacturing consistency. The two-laboratory design also provides an estimate of inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of conditions relevant to the COU. Level 3 requires testing at multiple load levels or configurations representative of the clinical use envelope, with documented rationale for condition selection. A single ASTM F1717 standard condition satisfies Level 2 but not Level 3.",
      "rationale": "Testing was conducted under a single ASTM F1717 static compression-bending condition (5° offset, 10 mm/min crosshead speed, ambient temperature). While this condition is the regulatory standard and is directly relevant to the COU, only a single test configuration was employed. The required Level 3 would necessitate testing at additional load angles or rates representative of the clinical loading envelope. This factor is assessed at Level 2 (achieved), below the required Level 3. This gap is acknowledged in the overall credibility assessment and is addressed through increased conservatism in the model uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Equivalency between experimental and simulation input parameters was rigorously established. Fixture geometry, grip separation distance, load application angle, and crosshead displacement rate were all replicated in the FEA boundary conditions using measured values from each laboratory's test setup documentation. Material properties used in the model were derived from the same production lot as the test specimens. UHMWPE block geometry was measured on each specimen and the mean dimensions used in the FEA model. The screw insertion depth and rod pre-bend angle were measured on three representative constructs and confirmed to be within ±0.3 mm and ±0.5° of the nominal values specified in the ASTM F1717 protocol. Contact interface friction coefficient was determined from dedicated coupon sliding tests between titanium alloy and stainless steel rod materials (μ = 0.22 ± 0.04). All input parameter equivalencies are documented in the simulation plan and traceability matrix (Document No. SIM-2024-047). The high degree of parameter equivalency achieved here substantially reduces the uncertainty attributable to input mismatch and supports a high-confidence comparison between computational predictions and experimental observations. No material substitutions or geometric simplifications were made that would introduce systematic bias into the QoI predictions. The equivalency assessment was reviewed and approved by both the FDA CDRH modeling team and the DePuy Synthes computational mechanics group prior to execution of the validation runs, providing independent confirmation that the simulation faithfully represents the physical test configuration. This factor comfortably meets the Level 3 threshold, which requires documented traceability of all primary input parameters between test and simulation with quantified uncertainty bounds on any parameters that could not be directly measured."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison must use a pre-specified metric. Level 3 requires use of a validation metric that accounts for both model prediction error and experimental uncertainty (e.g., E/uval ratio per ASME V&V 20, or equivalent). The metric must be evaluated against a pre-specified acceptance threshold established before unblinding of simulation results.",
      "rationale": "Output comparison employed the E/uval validation metric per ASME V&V 20-2009. For all three QoIs, E/uval < 1.96, confirming that model prediction errors are within the combined experimental and simulation uncertainty band at 95% confidence. Stiffness: E/uval = 0.87; Yield force: E/uval = 1.12; Force at 40 mm: E/uval = 1.44. The acceptance threshold of E/uval < 1.96 was pre-specified in the simulation plan prior to unblinding."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the clinical decision being supported. Level 3 requires documented mapping from each validation QoI to a specific clinical or regulatory endpoint, with justification that the QoI is sensitive to the failure modes of concern. Surrogate QoIs must be justified with clinical literature support.",
      "rationale": "The three validation QoIs (construct stiffness, yield force, force at 40 mm displacement) are directly specified in ASTM F1717 as the regulatory endpoints for pedicle screw construct mechanical performance. Construct stiffness correlates with immediate post-operative stability; yield force is the primary predictor of construct fatigue life and fracture risk; force at 40 mm displacement characterizes large-deformation behavior relevant to catastrophic failure scenarios. All three QoIs are directly output by the FEA model without post-processing surrogates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activity must be sufficiently representative of the COU to support extrapolation of credibility conclusions. Level 3 requires that the validation geometry, loading, and material system match the COU geometry, loading, and material system within documented similarity bounds, and that any differences are analyzed for their effect on model credibility.",
      "rationale": "The validation activity directly replicates the COU: the same non-cannulated 7.5 mm pedicle screw geometry, the same ASTM F1717 test configuration, and the same material system (Ti-6Al-4V screw and rod) are used in both validation and the intended regulatory submission context. No geometric scaling or material substitution was required. The validation therefore provides direct, not analogical, support for credibility in the COU. The only noted difference is that the validation employed a UHMWPE vertebral body surrogate rather than cadaveric bone, which is consistent with ASTM F1717 requirements and introduces no additional extrapolation uncertainty relative to the regulatory standard."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for COU1 is Accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single below-threshold factor (Test conditions, achieved Level 2 vs. required Level 3) is acknowledged and mitigated by the conservative E/uval acceptance criterion, the two-laboratory experimental design, and the direct regulatory relevance of the single ASTM F1717 condition employed. The FEA model ensemble is judged sufficiently credible to support the intended regulatory decision regarding non-cannulated 7.5 mm pedicle screw compression-bending performance.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
