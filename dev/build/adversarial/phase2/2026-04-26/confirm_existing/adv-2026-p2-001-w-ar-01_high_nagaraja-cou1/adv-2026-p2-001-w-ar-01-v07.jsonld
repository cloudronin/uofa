  "signature": "ed25519:9a4c2f1b7e3d05a8c6f4b2e1d9c7a5f3b1e8d6c4a2f0b9e7d5c3a1f8e6d4c2b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA level Gradation 2 requires version-controlled solver releases with documented regression test suites covering the element types used in the pedicle screw model. Achieved Gradation 3 by additionally maintaining a formal SDLC with traceability from requirements to test cases.",
      "rationale": "Ansys Mechanical 2022 R2 used under a validated installation qualification (IQ/OQ) protocol. Version control enforced via Git with tagged releases. Regression suite covers SOLID186 and CONTA174 element types relevant to the screw-rod interface. FDA's independent FEA replication used Abaqus 2021 under equivalent IQ/OQ controls. Both codes passed all applicable benchmark problems from ASME V&V 10.1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires demonstration that the solver correctly implements the governing equations for the physics classes present (nonlinear contact, large-displacement elastoplasticity) via at least one published benchmark problem with known analytical or reference solution.",
      "rationale": "Solver correctness verified against NAFEMS benchmark LE10 (stress concentration around a circular hole) and the Hertzian contact benchmark. Results match reference solutions within 0.5% for linear cases and within 2% for nonlinear contact, satisfying Gradation 2 requirements. No higher-order code verification was pursued given the medium model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires a formal mesh convergence study demonstrating that QoI values change by less than 5% between the production mesh and a uniformly refined mesh, with Richardson extrapolation applied to estimate the discretization error bound.",
      "rationale": "Three-level mesh refinement study conducted on the screw shank region (element edge length 0.5 mm, 0.25 mm, 0.125 mm). Richardson extrapolation yields a GCI of 1.8% for peak von Mises stress and 0.9% for construct stiffness. Production mesh uses 0.25 mm elements in the high-gradient zone. Discretization error is well within the 5% QoI threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires documentation that iterative solver residuals are driven below 1e-6 for force and displacement norms, and that time-step sensitivity has been evaluated for quasi-static loading.",
      "rationale": "Newton-Raphson iterations converged to residual norms below 1e-8 in all load steps. Time-step halving produced less than 0.3% change in QoI, confirming quasi-static assumption validity. No divergence events observed across all 11 specimen geometries."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires a documented simulation plan reviewed by an independent analyst, with a pre-analysis checklist covering boundary condition application, material assignment, and contact pair definitions.",
      "rationale": "Simulation plan reviewed by a second licensed engineer not involved in model construction. Pre-analysis checklist completed and archived. Boundary conditions replicate the F1717 test fixture constraints: inferior vertebral body block fully fixed, superior block constrained in all rotations with axial and lateral force applied per standard. Material assignments independently verified against manufacturer certificates of conformance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that the model physics selection (contact formulation, plasticity model, geometric nonlinearity) is justified by comparison with at least one published study using the same or equivalent hardware, and that all major simplifying assumptions are explicitly documented with supporting sensitivity analyses.",
      "rationale": "Augmented Lagrangian contact with frictional coefficient mu=0.2 (Ti-6Al-4V on PEEK) justified by Shirazi-Adl 1994 and confirmed by a sensitivity study showing less than 4% QoI sensitivity to mu in the range 0.15–0.30. Bilinear isotropic hardening plasticity parameters for Ti-6Al-4V calibrated to tensile coupon data from the same material lot. Geometric nonlinearity (NLGEOM ON) included given expected rod deflections exceeding 5% of gauge length."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that all material and geometric inputs are traceable to measured values with documented uncertainty, and that a parametric sensitivity analysis identifies which inputs drive more than 10% of QoI variance.",
      "rationale": "Geometry derived from CMM measurements of three production screws (mean ± 1 SD reported). Material properties from tensile testing of five coupons per material lot. Sobol sensitivity indices computed for Young's modulus, yield stress, friction coefficient, and rod diameter; rod diameter accounts for 61% of stiffness QoI variance and was therefore measured to ±0.01 mm precision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires N≥10 test specimens drawn from production lots, with dimensional and material characterization sufficient to populate the simulation input distributions, and testing performed at two or more independent laboratories.",
      "rationale": "N=11 constructs tested across two independent laboratories (FDA CDRH OSEL and DePuy Synthes R&D). All specimens drawn from the same production lot. Each specimen dimensionally characterized post-test by CMM. Material certificates of conformance archived. Inter-laboratory variability in stiffness QoI was 3.2% (CV), within acceptable bounds for the test method."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires testing under at least two distinct loading configurations or boundary condition variants representative of the COU envelope, with documented environmental controls (temperature, humidity) traceable to calibrated instrumentation.",
      "rationale": "Testing was conducted under a single F1717 compression-bending configuration at ambient laboratory conditions (22±2°C, 45±10% RH). Environmental conditions were recorded but only a single loading configuration was evaluated, which limits the achieved level to Gradation 2. The shortfall relative to the required Gradation 3 is acknowledged; the assessment team determined that the single F1717 configuration is the clinically dominant loading mode and that the QoI prediction error remained within acceptance bounds despite this limitation. Risk mitigation is provided by the large sample size (N=11) and the inter-laboratory replication, which together provide confidence that the single-condition result is representative of the device's compression-bending response envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Simulation inputs were set to match the as-measured specimen geometry and material properties for each of the 11 constructs individually. Rod diameter, screw head geometry, and PEEK vertebral body block stiffness were all matched to measured values within the CMM uncertainty bounds. Friction coefficient was held constant at the calibrated value; a sensitivity check confirmed that specimen-to-specimen friction variation contributes less than 1.5% to QoI variance. The equivalency mapping was documented in a traceability matrix linking each simulation parameter to its experimental source measurement, reviewed and signed off by the independent analyst. No surrogate or assumed values were used for any parameter identified as a dominant input by the Sobol analysis. The equivalency assessment satisfies Gradation 3 requirements as defined in ASME V&V 40 Table 1, which calls for full traceability of all influential inputs to experimental measurements with documented uncertainty propagation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires a quantitative metric-based comparison using a validation metric that accounts for both experimental and simulation uncertainty, with a pre-specified acceptance threshold documented prior to data unblinding.",
      "rationale": "Validation metric E/uval computed per ASME V&V 10-2019 Section 5. Experimental uncertainty uexp estimated from inter-specimen variability and lab calibration uncertainty; simulation uncertainty usim estimated from mesh convergence GCI and input parameter uncertainty propagation. E/uval < 1.96 for all three QoIs (stiffness: 1.31, yield force: 0.87, force at 40 mm: 1.44). Additionally, percentage difference |FEA-Exp|/Exp < 10% for all specimens. Both thresholds were pre-specified in the simulation plan prior to data unblinding."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 2 requires that the QoIs are directly linked to the COU decision (device approval) and that the mapping from QoI to clinical risk is documented. Gradation 3 additionally requires that the QoI selection is justified by a failure mode analysis.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and are directly linked to the clinical failure modes of screw fracture and construct loosening. A FMEA conducted during device design identified these as the dominant mechanical performance indicators. The QoI selection was reviewed and confirmed by the clinical advisory panel."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Gradation 3 requires that the validation scenario matches the COU in geometry, loading mode, and material system, and that any differences between the validation scenario and the COU are explicitly characterized and shown to be conservative or inconsequential.",
      "rationale": "The validation activity directly replicates the COU: same device geometry, same ASTM F1717 test configuration, same material system, same loading rate. The two-laboratory design strengthens the relevance claim by demonstrating that results are not facility-specific. No extrapolation beyond the validated configuration is claimed in the COU. The validation scenario is therefore fully relevant to the COU without qualification."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieves Gradation 2 against a required Gradation 3; this shortfall is accepted because the single F1717 configuration is the clinically dominant loading mode, the QoI validation metric E/uval remains below 1.96 for all outputs, and the N=11 inter-laboratory dataset provides sufficient statistical confidence. The overall credibility evidence package supports a Medium assurance level consistent with the Medium model influence and Medium decision consequence classification for this Class II device. The assessment team unanimously recommends acceptance of the FEA modeling framework for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
