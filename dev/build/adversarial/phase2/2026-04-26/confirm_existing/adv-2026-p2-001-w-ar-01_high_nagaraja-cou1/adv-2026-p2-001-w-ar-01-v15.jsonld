  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA procedures documented; regression test suite covers all primary load cases; version-controlled repository with audit trail.",
      "rationale": "The FEA ensemble employs Ansys Mechanical 2022 R2 and an in-house FDA finite element code, both subject to formal software quality assurance programs. Ansys holds ISO 9001 certification and provides a documented verification test suite. The FDA code is maintained under a CFR Part 11-compliant version control system with change-control records. Achieved Gradation 3 reflects availability of test plans, execution records, and documented deviations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions reproduced within 1% for patch test and manufactured-solution cases; convergence order confirmed for primary element type.",
      "rationale": "Both codes were verified against NAFEMS benchmark problems and method-of-manufactured-solutions cases for linear elastic solid and beam elements. Patch test convergence confirmed at second-order spatial accuracy. No code anomalies were identified in the element types used for the pedicle screw geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in all three QoIs between the medium and fine mesh; GCI reported for each QoI.",
      "rationale": "A three-level mesh refinement study was performed on the non-cannulated screw geometry. Grid Convergence Index values for stiffness, yield force, and force at 40 mm displacement were all below 1.5%, satisfying the pre-specified threshold. The production mesh (medium density, ~480 000 elements) was selected on the basis of this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norm below 1e-6 for all load steps; energy balance error below 0.1%.",
      "rationale": "Direct sparse solver employed for the linear elastic regime; iterative solver with incomplete LU preconditioner used for contact-active steps. Residual norms and energy balance errors were logged for all 22 load steps across the ensemble runs; all satisfied the stated thresholds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by analyst not involved in original build; checklist-based verification of boundary conditions, material assignments, and contact definitions.",
      "rationale": "Model setup was reviewed by an independent senior analyst using a structured checklist derived from the laboratory's simulation governance procedure. Boundary conditions, material property assignments, contact pair definitions, and load application points were each verified against the ASTM F1717 fixture geometry drawings. One minor discrepancy in fixation block stiffness was identified and corrected prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing physics (linear elasticity with contact) justified by literature and preliminary nonlinear sensitivity; simplifying assumptions documented and bounded by sensitivity analysis.",
      "rationale": "Linear elastic constitutive models are appropriate for titanium alloy pedicle screws loaded below yield in the stiffness regime. A nonlinear elastic-plastic sensitivity run confirmed that plastic strains are negligible below the yield force QoI threshold. Frictional contact at the screw-block interface was modeled with a Coulomb coefficient of 0.25, consistent with published tribological data for Ti-6Al-4V on UHMWPE test blocks."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from traceable coupon tests on same lot material; geometric inputs derived from CMM measurements of test articles; input uncertainty quantified and propagated.",
      "rationale": "Elastic modulus and Poisson's ratio for Ti-6Al-4V were obtained from tensile coupon tests performed on material from the same manufacturing lot as the test constructs. Screw geometry was digitized by coordinate measuring machine (CMM) for three representative specimens; mean dimensions used in the nominal model with ±1 standard deviation bounds propagated via Monte Carlo sampling (n=500). Input uncertainty contribution to total QoI uncertainty was below 4% for all three outputs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lot; traceability records confirm same design revision and material certification as modeled geometry.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production-lot components. Lot traceability records confirm all screws are from the same design revision and material certification batch as the CMM-measured geometry. Sample size exceeds the pre-specified minimum of N=10 required for the statistical comparison method (E/uval metric)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two independent test conditions (e.g., load rates or fixture configurations) evaluated; environmental conditions logged and within ASTM F1717 tolerances.",
      "rationale": "Testing was conducted at a single load rate (25 mm/min) and ambient temperature (23±2°C) per ASTM F1717. While the standard does not mandate multiple load rates, the required credibility level of 3 for this risk tier nominally calls for evaluation across at least two test conditions. Only one condition was feasible within the project timeline and budget. This shortfall is acknowledged; the achieved level of 2 is accepted on the basis that load-rate sensitivity for quasi-static titanium constructs is well-established in the literature as negligible below 50 mm/min."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative mapping documented between each model input parameter and corresponding measured experimental quantity; discrepancies >5% flagged and addressed.",
      "rationale": "A parameter equivalency table was prepared mapping each FEA input (geometry, material, boundary conditions, loading) to the corresponding experimental measurement or specification. All discrepancies were below 3% except for the fixation block elastic modulus, which was adjusted following the use-error review. The table is archived in the simulation governance record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "E/uval < 1.96 for all three QoIs and percent difference < 10% for each QoI; both criteria must be satisfied simultaneously.",
      "rationale": "The validation metric E/uval was computed for construct stiffness (0.84), yield force (1.21), and force at 40 mm displacement (1.09), all below the 1.96 threshold. Percent differences were 3.2%, 7.8%, and 5.1% respectively, all below the 10% bound. Both acceptance criteria were satisfied simultaneously across all three QoIs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "rationale": "The three quantities of interest — construct stiffness, yield force, and force at 40 mm displacement — are the primary mechanical performance metrics specified in ASTM F1717 and directly correspond to the clinical performance requirements for pedicle screw constructs under compression-bending loading. Stiffness characterizes the elastic response relevant to load sharing with the vertebral column; yield force identifies the onset of permanent deformation; force at 40 mm displacement captures post-yield energy absorption relevant to catastrophic failure modes. All three QoIs are directly observable in both the FEA model and the physical test, eliminating any inference gap between modeled and measured quantities. The selection of these QoIs was reviewed and endorsed by the clinical advisory panel as representative of the in vivo loading scenario for posterior spinal fixation systems. Sensitivity analyses confirmed that the model's predictive uncertainty is dominated by material property variability rather than QoI selection, further validating the appropriateness of the chosen outputs. The relevance assessment was conducted in accordance with Section 5.3.2 of ASME V&V 40-2018, which requires explicit linkage between QoIs and the intended use context. This linkage is documented in the Simulation Governance Plan (SGP-2023-047, Rev B) and was independently verified by the regulatory affairs team prior to submission. The achieved level of 4 reflects that QoI relevance has been formally justified, independently reviewed, and documented with traceability to both the standard and the clinical use case — exceeding the baseline requirement of level 3 for this model risk tier."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario shares geometry, material, loading mode, and boundary conditions with the COU; any differences documented and bounded by sensitivity analysis.",
      "rationale": "The validation activity directly replicates the COU geometry (non-cannulated 7.5 mm screw), material (Ti-6Al-4V, same lot), loading mode (ASTM F1717 compression-bending), and boundary conditions (standard fixture per F1717 Annex A). No surrogate geometry or scaled model was employed. The validation domain is therefore considered coincident with the COU domain, satisfying the highest relevance criterion for this factor at the required level."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors have been assessed. Twelve of thirteen factors meet or exceed the required credibility level. The single shortfall — Test conditions achieving level 2 against a required level of 3 — is accepted on the basis of well-established literature evidence for load-rate insensitivity of quasi-static titanium pedicle screw constructs and the availability of N=11 experimental replicates providing robust statistical characterization at the single tested condition. The overall credibility profile is consistent with a Medium assurance level for a Class II device with medium model influence and medium decision consequence. The validation metric E/uval < 1.96 and percent difference < 10% are satisfied for all three QoIs. The assessment team concludes that the FEA modeling framework is sufficiently credible to support the intended regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
