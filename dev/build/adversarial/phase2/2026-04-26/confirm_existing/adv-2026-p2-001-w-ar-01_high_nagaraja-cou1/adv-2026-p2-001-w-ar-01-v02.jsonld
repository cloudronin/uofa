  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required gradation level. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — is acknowledged and documented. The assessment team determined that this gap does not invalidate the credibility conclusion because the COU is explicitly bounded to the ASTM F1717 single-configuration protocol, and all three primary QoIs pass the E/uval < 1.96 and <10% difference thresholds. Overall credibility is assessed as sufficient to support a Medium assurance level decision for this Class II non-cannulated pedicle screw submission.",
