  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) must be validated under an ISO 9001-compliant quality management system with documented version control, regression test suite, and change-control records. Gradation 2 is satisfied when the solver version is locked and a formal QMS record is on file.",
      "rationale": "Ansys Mechanical 2022 R2 was used under DePuy Synthes' ISO 9001:2015-certified QMS. Version control logs, regression test results, and change-control records were reviewed and archived. Required Gradation 2 reflects the medium model risk level; no higher-fidelity software qualification is warranted for a Class II device submission where bench testing independently confirms model output."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate that the solver correctly implements the governing equations through at least one benchmark problem with a known analytical solution. Gradation 2 requires documented patch test and at least one published benchmark comparison.",
      "rationale": "Patch tests and linear elastic benchmark comparisons against NAFEMS standard problems LE1 and LE10 confirmed correct implementation of the 3-D continuum elements used in the pedicle screw assembly. Results were within 0.3% of analytical reference values, satisfying Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study must be performed on the critical QoIs (stiffness, yield force, force at 40 mm). Gradation 3 requires monotonic convergence demonstrated across at least three mesh refinement levels with a reported discretization uncertainty estimate.",
      "rationale": "Three mesh refinement levels (coarse: ~180k elements, medium: ~420k elements, fine: ~950k elements) were evaluated. Stiffness and yield force converged monotonically; Richardson extrapolation yielded discretization uncertainty of 1.2% for stiffness and 1.8% for yield force. The fine mesh was selected for production runs. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must be monitored and reported; convergence tolerances must be documented. Gradation 2 requires force and displacement residuals below 1e-4 relative norm at each load step.",
      "rationale": "Newton-Raphson iterations converged to residual norms below 5e-5 for all load steps across all 11 model instances. No divergence or spurious oscillation was observed. Solver log files are archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be reviewed by an independent analyst. Gradation 2 requires documented peer review of boundary conditions, material assignments, and loading protocol against the ASTM F1717 test specification.",
      "rationale": "An independent biomechanical engineer (not the primary model developer) reviewed all boundary condition definitions, material property assignments, and load application against ASTM F1717-15. Discrepancies identified in an initial review were corrected prior to production runs. Review records are on file."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected constitutive model and contact formulation must be justified by literature or preliminary sensitivity analysis. Gradation 3 requires a documented sensitivity study showing that alternative model form choices change QoIs by less than the validation tolerance.",
      "rationale": "Bilinear isotropic hardening plasticity was selected for Ti-6Al-4V implant components based on published coupon test data. An augmented Lagrangian contact formulation was used at screw-rod and screw-block interfaces. Sensitivity analyses comparing linear elastic, bilinear, and Ramberg-Osgood representations showed QoI differences of 2–4%, well within the 10% validation tolerance. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters must be sourced from traceable measurements or peer-reviewed literature. Gradation 3 requires documented uncertainty bounds on all primary inputs and a propagation analysis showing combined input uncertainty contribution to QoI uncertainty.",
      "rationale": "Ti-6Al-4V elastic modulus (114 ± 3 GPa) and yield strength (880 ± 15 MPa) were sourced from certificate-of-conformance tensile testing of production-lot material. UHMWPE block geometry was measured via CMM. A Monte Carlo propagation (n=500) showed combined input uncertainty contributed 3.1% to stiffness QoI variability, within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental specimens must be traceable to production-representative hardware. Gradation 3 requires dimensional inspection records for all N=11 constructs and confirmation that specimens are from production-equivalent manufacturing lots.",
      "rationale": "All 11 test constructs used production-equivalent 7.5 mm non-cannulated pedicle screws from the same manufacturing lot as the commercial device. CMM inspection records confirmed dimensional compliance within drawing tolerances for all specimens. Dual-laboratory testing (FDA CDRH and DePuy Synthes internal lab) further supports representativeness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Testing must be conducted under multiple clinically relevant loading configurations to support generalization. Gradation 3 requires at least two distinct test configurations (e.g., varying offset distance or angulation) with documented environmental controls.",
      "rationale": "Testing was conducted exclusively under the single standard ASTM F1717 configuration (44 mm offset, room temperature, displacement-controlled at 5 mm/min). While environmental controls (temperature 23 ± 2°C, humidity 50 ± 10%) were documented and consistent across both laboratories, only one loading geometry was evaluated. This limits the ability to characterize model behavior across the broader clinical loading envelope. The shortfall from Gradation 3 to Gradation 2 is acknowledged; however, given that the intended COU is limited to the ASTM F1717 protocol itself, the team determined this gap does not invalidate the overall credibility conclusion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs must be demonstrably equivalent to experimental conditions. Gradation 3 requires a documented parameter-matching table mapping each experimental measurement to its FEA counterpart, with discrepancies quantified.",
      "rationale": "A parameter-matching table was prepared cross-referencing measured specimen dimensions, applied loads, and fixture geometry against FEA inputs. Maximum geometric discrepancy was 0.12 mm (within CMM measurement uncertainty). Applied displacement protocol was replicated exactly. No unmatched parameters were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics must include both point estimates and uncertainty-normalized error (E/uval). Gradation 3 requires E/uval < 1.96 for all primary QoIs across all model instances.",
      "rationale": "E/uval values were 0.84 (stiffness), 1.21 (yield force), and 1.43 (force at 40 mm) — all below the 1.96 threshold. Percentage differences were 4.1%, 6.8%, and 7.3% respectively, all within the pre-specified 10% bound. Gradation 3 achieved for all three QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and directly correspond to the clinical performance attributes of interest (rigidity, fatigue life proxy, and ultimate load-bearing capacity). These QoIs are universally accepted in the spinal implant regulatory literature as surrogate endpoints for in vivo mechanical performance. The selection was reviewed by the FDA project team and confirmed as clinically and regulatorily appropriate for a Class II pedicle screw submission. Gradation 3 reflects that the QoIs are both biomechanically justified and directly tied to the regulatory decision framework — the required level was set at 3 given the medium model risk and the direct regulatory relevance of the ASTM F1717 outputs. The assessment team considered whether additional QoIs such as screw-rod interface slip or local strain concentrations at the screw root should be included; these were scoped out because the COU is explicitly bounded to the F1717 protocol outputs and the model has not been validated for contact-slip or fatigue-life prediction. This scoping decision is consistent with the principle of fitness-for-purpose validation and does not reduce confidence in the three primary QoIs, which are comprehensively supported by the experimental dataset. The biomechanical rationale for each QoI threshold value, the statistical power of N=11 to detect a 10% mean difference with 80% power, and the alignment with FDA guidance on spinal implant submissions were all reviewed and found satisfactory by the independent credibility assessment reviewer."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must directly address the COU geometry, loading, and material system. Gradation 3 requires that the validation specimens are geometrically and materially identical to the COU device and that the validation loading replicates the regulatory test protocol.",
      "rationale": "Validation was performed on the identical non-cannulated 7.5 mm pedicle screw geometry, material lot, and assembly configuration as the COU device. The ASTM F1717 loading protocol used in validation is the same protocol referenced in the COU. Dual-laboratory execution further strengthens relevance by demonstrating inter-laboratory reproducibility. Gradation 3 achieved."
    }
  ],
