  "signature": "ed25519:b2d4f6a8c0e2a4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software development follows a documented quality plan with version control, regression testing, and traceability to requirements per MRL 5 expectations.",
      "rationale": "Version control and regression testing are in place; however, formal traceability from code modules to V&V requirements is absent. SQA plan exists but has not been reviewed against MRL 5 criteria. Achieved level falls below required level but the gap is considered manageable given Monte Carlo coverage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification performed for all relevant solver modules used in hemolysis prediction.",
      "rationale": "Order-of-accuracy testing was performed only for the fluid momentum equations. The hemolysis transport scalar and the red-blood-cell damage accumulation sub-model were not subjected to MMS verification. This gap is noted but not treated as blocking given the overall uncertainty quantification framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study demonstrates discretization error below 5% on hemolysis index QoI at all five operating points.",
      "rationale": "Grid convergence study performed at two of five operating points using three mesh levels. Richardson extrapolation yields discretization error estimates of 8–14% on hemolysis index at the highest shear-rate condition. Remaining three operating points not assessed. Achieved level is 3 against a required level of 5; gap persists."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions match COU operating envelope within defined tolerances for flow rate, rotational speed, fluid temperature, and hematocrit.",
      "rationale": "Experimental data from the FDA generic pump study covers three of five target operating points. Hematocrit in bench experiments (35%) deviates from clinical target (40–45%). Temperature control documented but uncertainty bounds not propagated into hemolysis predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted vs. measured hemolysis index with uncertainty bands at all five COU operating points; systematic bias < 15%.",
      "rationale": "Quantitative comparison available at two operating points only. Predicted hemolysis index shows 22–31% positive bias relative to experimental measurements at those points. Remaining three points rely on extrapolation. This is the most significant gap in the assessment but is not treated as a blocking issue in the decision record."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, wall shear stress) are directly linked to clinical hemolysis endpoints and COU decision thresholds.",
      "rationale": "Hemolysis index QoI is directly relevant. Wall shear stress is a surrogate; linkage to clinical hemolysis threshold is established through published power-law damage models. Minor gap: platelet activation, a secondary clinical concern, is not assessed as a QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry, operating conditions, and fluid properties sufficiently representative of the Class III VAD COU.",
      "rationale": "FDA generic pump geometry used for validation is a reasonable analogue but differs in impeller blade count and volute geometry from the target device. Operating speed range in validation overlaps with COU but does not cover the highest-speed condition (6000 RPM). Relevance is partial."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and demonstrated to be sufficient; floating-point and round-off error assessed for hemolysis accumulation integration.",
      "rationale": "Residual convergence targets are documented (RMS < 1e-5) but iterative convergence of the hemolysis scalar was not separately verified. No assessment of round-off error in the Lagrangian particle-tracking integration used for damage accumulation. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented procedures for model setup, boundary condition application, and post-processing reviewed by an independent analyst.",
      "rationale": "Standard operating procedures exist for boundary condition setup. Independent review was performed for fluid BCs but not for hemolysis model parameters or post-processing scripts. One undocumented manual correction to inlet velocity profile was identified during audit."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form uncertainty for turbulence closure and hemolysis damage law quantified and shown to be acceptable relative to clinical decision threshold.",
      "rationale": "Three turbulence models compared (k-omega SST, k-epsilon realizable, RSM); spread in hemolysis index predictions is 35–60% across models at high-shear conditions. Hemolysis power-law exponents from literature span a factor of 2.5. Model form uncertainty is large and not bounded within the clinical threshold margin. Gap is acknowledged but not escalated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with uncertainty distributions; sensitivity analysis identifies dominant inputs; Monte Carlo propagation performed.",
      "rationale": "Monte Carlo UQ performed with 500 samples. Sensitivity analysis identifies fluid viscosity and hemolysis model coefficients as dominant. However, geometric tolerances and surface roughness are treated as deterministic despite known manufacturing variability. Input characterization incomplete for two of seven identified uncertain parameters."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient to characterize biological variability in hemolysis response; statistical power analysis performed.",
      "rationale": "No sample-size justification or statistical power analysis was performed for the experimental dataset used in validation. The FDA generic pump dataset comprises results from a single laboratory with a single fluid formulation. Biological variability across donors not characterized. Factor not assessed at MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that validation model inputs are representative of COU inputs, including fluid rheology, hematocrit, and temperature.",
      "rationale": "No formal equivalency argument has been constructed. Differences in hematocrit, fluid temperature range, and blood analog rheology between validation and COU conditions are noted in the technical report but not quantitatively bridged. Factor flagged as epistemic gap at MRL 5."
    }
  ],
