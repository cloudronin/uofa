      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA plan with version control, regression testing, and documented build procedures must meet Gradation 4 requirements for MRL 5.",
      "rationale": "SQA documentation is present but regression test suite covers only 40% of solver pathways. Version control is enforced but build reproducibility across HPC environments has not been demonstrated. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions must demonstrate expected convergence rates for all governing equations relevant to hemolysis prediction.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes equations only; the scalar hemolysis transport equation was not verified. Observed order of accuracy for velocity field is 1.7 vs. expected 2.0. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed for all QoIs using at least three systematically refined meshes with GCI below 5% for hemolysis index.",
      "rationale": "Three-level mesh refinement performed; GCI for hemolysis index is 8.3% at the design operating point, exceeding the 5% threshold. Coarsest mesh shows non-monotonic convergence at off-design conditions. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within specified tolerances; temperature, hematocrit, and pump speed must be controlled and documented.",
      "rationale": "Experimental data sourced from FDA benchmark dataset. Hematocrit was fixed at 33% in experiments; COU specifies 35–45%. Temperature deviations of up to 2°C were recorded but not corrected in boundary conditions. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) must be computed for hemolysis index at all 5 operating points with uncertainty bounds.",
      "rationale": "Validation metric computed at 3 of 5 operating points; two high-flow operating points lacked experimental hemolysis measurements. Model predictions exceed experimental values by 18–34% at measured points. No uncertainty-weighted metric applied. Achieved level 2 against required level 4.",
      "achievedLevel_note": "CRITICAL GAP — W-AR-02 trigger: achievedLevel 2 is below requiredLevel 4 yet decision is Accepted"
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the hemolysis index metric used in the regulatory submission; surrogate QoIs must be justified.",
      "rationale": "Normalized index of hemolysis (NIH) used in validation; COU requires modified index of hemolysis (MIH). Conversion factor applied but introduces additional uncertainty not propagated through Monte Carlo. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry and operating conditions representative of the VAD COU; FDA generic pump may be used as surrogate only with demonstrated geometric similarity.",
      "rationale": "Validation performed on FDA generic centrifugal pump; actual VAD device geometry differs in impeller blade count and volute design. No geometric similarity analysis provided. Operating speed range partially overlaps COU envelope. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-6 for all equations; round-off error assessment required for double-precision arithmetic.",
      "rationale": "Solver residuals reported at 1e-4 for continuity equation; hemolysis scalar residual plateaus at 1e-3 indicating incomplete convergence. Double-precision confirmed but round-off assessment not documented. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence that the simulation was executed by qualified personnel following documented procedures; independent review of model setup required at MRL 5.",
      "rationale": "Model setup reviewed internally but no independent third-party review conducted. Analyst qualification records present for CFD but not for hemolysis-specific modeling. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for turbulence model selection and hemolysis damage accumulation model must be provided with sensitivity analysis demonstrating low model-form sensitivity.",
      "rationale": "k-omega SST turbulence model selected without comparative evaluation against alternative models for rotating machinery hemolysis applications. Power-law hemolysis model used; Giersiepen-Wurzinger constants applied without recalibration for device geometry. Sensitivity analysis not performed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain model inputs must be characterized with probability distributions; Monte Carlo propagation must cover full COU operating envelope.",
      "rationale": "Monte Carlo UQ performed with 500 samples covering blood viscosity, hematocrit, and inlet flow rate distributions. Pump speed uncertainty not included in propagation. Material property correlations sourced from literature without device-specific validation. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples used in validation must be characterized for hematocrit, blood source, anticoagulant protocol, and storage conditions.",
      "rationale": "Factor not assessed; FDA benchmark dataset does not provide complete sample characterization. Blood source, anticoagulant protocol, and storage duration are not documented in the publicly available dataset. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between experimental input parameters and COU input parameters must be demonstrated quantitatively for all boundary conditions.",
      "rationale": "Factor not assessed; systematic comparison of experimental boundary conditions to COU specification not performed. Inlet velocity profiles, outlet pressure conditions, and wall roughness values differ between experimental setup and COU but equivalency analysis is absent."
