      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the full operating envelope of the COU including all five flow-speed combinations; interpolation beyond validated range is not permitted at MRL 5.",
      "rationale": "Validation experiments covered four of five flow-speed combinations; the fifth operating point was extrapolated from the validated range without additional experimental support. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels at least three orders of magnitude below initial residuals for all transported quantities; round-off and floating-point error must be assessed.",
      "rationale": "Residual convergence was monitored but dropped only two orders of magnitude for the scalar hemolysis transport equation at peak flow conditions; round-off error analysis was not performed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
