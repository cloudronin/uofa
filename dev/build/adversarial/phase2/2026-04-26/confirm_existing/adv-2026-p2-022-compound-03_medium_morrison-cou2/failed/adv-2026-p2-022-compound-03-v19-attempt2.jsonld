      "acceptanceCriteria": "Software must be validated under a formal QA plan with version-controlled source, regression testing, and documented release procedures appropriate for Class III device support.",
      "rationale": "SQA documentation covers version control and basic regression tests but lacks formal release procedures and independent audit trail required at MRL 5. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical benchmark problems must confirm solver implementation matches theoretical convergence rates for all active physics modules.",
      "rationale": "Order-of-accuracy testing was conducted only for the laminar flow module; turbulence and scalar transport modules were not subjected to formal code verification. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis on at least three systematically refined meshes must bound discretization error to within 5% of QoI at all operating points.",
      "rationale": "Three-mesh GCI study performed; however, near-wall y+ targets were not consistently met on the finest mesh at two of five operating points, leaving discretization error incompletely bounded. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be measured and reported with full uncertainty budgets; inlet flow profiles, fluid temperature, and hematocrit must match simulation inputs within stated tolerances.",
      "rationale": "Inlet velocity profiles and temperature were measured with documented uncertainty. Hematocrit variability across test runs was reported but not propagated into the simulation boundary conditions. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric U_val) must be computed with experimental and simulation uncertainty contributions; metric must satisfy acceptance threshold at all operating points.",
      "rationale": "Predicted hemolysis index was compared to experimental measurements at five operating points. Formal validation metric with combined uncertainty was not computed; comparison relied on percent-difference reporting only. Achieved level 2 against required level 4.",
      "note": "W-AR-02 trigger: achievedLevel 2 < requiredLevel 4 with decision Accepted — critical weakener fires here."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly traceable to the clinical endpoint (absolute hemolysis index); surrogate QoIs must be justified with sensitivity analysis linking surrogate to primary endpoint.",
      "rationale": "Normalized index of hemolysis (NIH) used as primary QoI is the accepted clinical surrogate; however, sensitivity analysis linking NIH to patient-level hemolysis risk was not formally documented. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
