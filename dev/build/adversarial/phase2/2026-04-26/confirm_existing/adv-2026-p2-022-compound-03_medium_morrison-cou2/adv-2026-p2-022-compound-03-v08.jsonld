      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for Class III VAD hemolysis prediction must demonstrate documented version control, regression testing, and independent code review at Gradation 4.",
      "rationale": "Version control and regression test suite are in place; however, independent third-party code audit was not completed. Achieved level falls one gradation below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass Method of Manufactured Solutions (MMS) verification for the turbulence closure and hemolysis transport equations at MRL 5.",
      "rationale": "MMS verification was completed for the Navier-Stokes equations; MMS for the hemolysis damage accumulation transport equation was not performed, leaving a gap at the required gradation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent systematic grid convergence study must be performed on hemolysis index QoI across at least three systematically refined meshes, with GCI reported.",
      "rationale": "Grid convergence was assessed on pressure-drop only; hemolysis index QoI convergence was not evaluated systematically. Two mesh levels were compared without Richardson extrapolation. Achieved level is substantially below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match VAD operating envelope (flow rate, rotational speed, fluid properties) within documented tolerances.",
      "rationale": "Three of five flow-speed operating points were matched experimentally; two high-flow conditions were not replicated in the validation dataset due to facility limitations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) must be computed with uncertainty bounds for hemolysis index QoI at all operating points.",
      "rationale": "Validation metric computed at three operating points; uncertainty bounds derived from Monte Carlo propagation. Two operating points lack experimental replicates sufficient for metric computation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (normalized index of hemolysis, NIH) must be directly the same scalar used in the regulatory submission threshold comparison.",
      "rationale": "NIH is the primary QoI in both validation and submission; minor differences in averaging window between validation protocol and submission protocol reduce achieved level by one gradation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the same pump geometry, fluid (bovine blood or equivalent), and rotational speed range as the COU device.",
      "rationale": "Validation used the FDA generic pump geometry, which differs from the sponsor device in impeller blade angle. Fluid was porcine blood rather than bovine. Rotational speed range partially overlaps COU envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to at least five orders of magnitude residual reduction for all governing equations.",
      "rationale": "All simulations converged to six orders of magnitude residual reduction. Solver error is well-characterized and meets the required gradation."
    },
