      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst not involved in model construction.",
      "rationale": "Independent analyst review of boundary conditions, material properties, and solver settings was completed and documented. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage model must be justified through literature evidence or prior validation for blood-contacting rotating machinery at the operating Reynolds number.",
      "rationale": "SST k-omega turbulence closure selected based on general pump literature; hemolysis power-law model (Giersiepen-Wurzinger) applied without sensitivity analysis to model-form alternatives. Model form uncertainty not quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (viscosity, density, hemolysis model constants) must have documented uncertainty distributions used in Monte Carlo propagation.",
      "rationale": "Monte Carlo UQ performed on fluid properties and hemolysis model constants; however, uncertainty in inlet velocity profile shape was not included in the propagation."
    },
