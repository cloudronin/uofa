    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (hemolysis index) must be directly the clinical decision variable; surrogate QoIs must be justified with sensitivity analysis demonstrating their correlation to hemolysis index.",
      "rationale": "Hemolysis index is the direct QoI; however, the power-law hemolysis model used introduces model-form uncertainty that is acknowledged but not fully bounded. Achieved level 4 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
