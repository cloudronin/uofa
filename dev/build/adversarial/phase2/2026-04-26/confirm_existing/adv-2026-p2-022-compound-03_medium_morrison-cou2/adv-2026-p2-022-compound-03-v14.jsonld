  "signature": "ed25519:9b2e4f7a1c3d6e8f0a2b5c8d1e4f7a0b3c6d9e2f5a8b1c4d7e0f3a6b9c2d5e8f",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Full configuration management, version control, and regression testing suite covering hemolysis solver routines; independent code audit required at MRL 5.",
      "rationale": "Version control and basic regression tests are in place, but no independent audit has been conducted and configuration management does not extend to third-party turbulence model libraries. Achieved level falls short of the MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equation sets including the hemolysis transport equation; order-of-accuracy confirmed.",
      "rationale": "MMS was applied to the Navier-Stokes solver but not to the hemolysis scalar transport equation. Order-of-accuracy verification is incomplete for the primary quantity of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on at least three systematically refined meshes; GCI reported for hemolysis index at all five operating points.",
      "rationale": "Three-mesh Richardson extrapolation completed for two of five operating points. Remaining three points used a single fine mesh with estimated GCI, which does not satisfy the MRL 5 requirement for all operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profiles, fluid temperature, hematocrit) match COU operating envelope within stated uncertainty bounds.",
      "rationale": "Inlet velocity profiles in bench experiments were measured with LDV at a single flow rate; remaining four operating points used extrapolated profiles. Hematocrit variability was not controlled to COU specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., validation uncertainty U_val) computed for hemolysis index; model error within validation uncertainty at all operating points.",
      "rationale": "Qualitative trend agreement was demonstrated. A formal validation uncertainty U_val was computed for only one operating point. Quantitative agreement metrics are absent for four of five required conditions, leaving the output comparison substantially below the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI is the normalized index of hemolysis (NIH) directly compared to the COU decision QoI; no surrogate quantities accepted at MRL 5.",
      "rationale": "NIH was used as the primary QoI in validation experiments, consistent with the COU. However, one secondary QoI (shear stress distribution) used as a proxy for high-speed operating conditions introduces indirect relevance that partially reduces the achieved level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic pump geometry at COU flow-speed combinations; blood analog fluid properties within 5% of clinical values.",
      "rationale": "Validation used a glycerol-water blood analog at room temperature. Viscosity matched within 8% and density within 3%, exceeding the 5% threshold. Operating conditions covered only three of five COU flow-speed combinations. Relevance gap is substantial."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to solver tolerance of 1e-6 for all residuals; floating-point reproducibility confirmed across platforms.",
      "rationale": "All residuals converged to 1e-6; reproducibility confirmed on two HPC platforms. Achieved level meets the required level for this factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent expert review; operator qualification records maintained; sensitivity study on user-controlled parameters.",
      "rationale": "No independent expert review of the simulation protocol was performed. Operator qualification records are absent. Sensitivity to user-controlled meshing parameters (boundary layer thickness, growth rate) was not assessed. Achieved level is critically below requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of turbulence model selection for rotating hemolysis-relevant flows; power-law hemolysis model applicability demonstrated across shear stress range of COU.",
      "rationale": "SST k-omega turbulence model was selected without comparative evaluation against LES or alternative RANS closures. Power-law hemolysis model coefficients were taken from literature without re-calibration to the FDA pump geometry. Model form uncertainty is unquantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions characterized with stated uncertainty; Monte Carlo propagation covers full COU operating envelope.",
      "rationale": "Monte Carlo UQ was performed for inlet flow rate and rotational speed. Blood viscosity uncertainty was not propagated. Material property uncertainty for the hemolysis model coefficients was excluded from the Monte Carlo analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient experimental replicates (n≥5 per operating point) to characterize biological and measurement variability; statistical power analysis reported.",
      "rationale": "Experimental hemolysis measurements were obtained with n=2 replicates per operating point. No statistical power analysis was performed. The sample size is insufficient to characterize inter-sample biological variability at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment inputs and COU inputs; any non-equivalent parameters flagged with impact assessment.",
      "rationale": "No formal equivalency mapping was produced. The blood analog fluid, temperature conditions, and pump wear state in the validation experiment differ from COU conditions without documented impact assessment. Equivalency of input parameters is not established."
    }
  ],
