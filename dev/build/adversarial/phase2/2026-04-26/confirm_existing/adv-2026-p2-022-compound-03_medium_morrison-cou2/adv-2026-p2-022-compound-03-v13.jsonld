  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software is version-controlled, regression-tested, and operates under a documented QA plan consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is under ISO 9001-aligned QA with full regression test suite and documented release notes. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing performed on benchmark cases; code passes method of manufactured solutions (MMS) verification.",
      "rationale": "MMS verification confirms second-order spatial accuracy for velocity and pressure fields. Temporal discretization verified on unsteady benchmark. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed on three systematically refined meshes; GCI < 5% on hemolysis index QOI for all five operating points.",
      "rationale": "GCI study performed on three mesh levels (4M, 12M, 36M cells). GCI on hemolysis index ranges from 4.1% to 11.7% across operating points; two of five points exceed the 5% threshold. Mesh refinement beyond 36M cells was computationally prohibitive within project scope. Achieved level (3) falls below required level (4)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented and traceable; uncertainty in boundary conditions is quantified.",
      "rationale": "FDA pump experimental data includes full documentation of flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), and blood analog fluid properties. Measurement uncertainties are reported and incorporated into UQ boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or normalized RMSE) computed between predicted and measured hemolysis index; metric threshold defined a priori.",
      "rationale": "Normalized RMSE on hemolysis index across five operating points is 18.3%, exceeding the pre-specified 10% acceptance threshold. Predictions are directionally correct but absolute magnitudes show systematic over-prediction at high shear conditions. Achieved level (3) falls below required level (4)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 5,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOI (hemolysis index) is directly the regulatory decision quantity; no surrogate or proxy QOI is used.",
      "rationale": "The hemolysis index predicted by the model is the exact quantity compared against the clinical threshold for regulatory acceptance. No surrogate QOI is introduced. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the FDA generic pump geometry under operating conditions spanning the COU envelope; fluid properties match clinical blood analog specifications.",
      "rationale": "Validation uses the FDA generic centrifugal pump, which is geometrically similar but not identical to the device COU. Operating conditions partially overlap the COU envelope (3 of 5 COU operating points are within the validated range). Fluid is porcine blood analog; human blood rheology differences are unquantified. Achieved level (3) falls below required level (4)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual tolerance < 1e-5 for all equations; solution independence from initial conditions verified.",
      "rationale": "All simulations converged to residual tolerance of 1e-6. Two independent initial conditions (zero-field and interpolated from coarser mesh) yield solutions within 0.3% on hemolysis index. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup reviewed by independent analyst; boundary condition specification and post-processing scripts are version-controlled and peer-reviewed.",
      "rationale": "Independent internal review of simulation setup completed. Boundary condition scripts and post-processing pipelines are stored in version control and reviewed by a second qualified CFD analyst. No use errors identified. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form is justified against mechanistic alternatives; sensitivity of hemolysis index to model form choice is quantified and within acceptable bounds.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model is applied without evaluation of alternative model forms (e.g., Arora strain-based or Faghih-Sharp models). No model-form sensitivity study was performed. The power-law exponents are taken from literature fits to bovine blood data; applicability to human blood in the VAD COU is assumed but not demonstrated. Achieved level (2) is substantially below required level (4), representing the largest credibility gap in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters are traceable to measurement or literature; probability distributions assigned to uncertain inputs for Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ performed on 12 uncertain input parameters including viscosity, density, and hemolysis model coefficients. Distributions are assigned based on literature ranges. Two parameters (red blood cell deformability index, membrane tension threshold) lack published distributions and are treated as point estimates. Achieved level (3) falls below required level (4)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples are sufficient in number and biological variability to support statistical comparison; sample preparation and storage conditions are documented.",
      "rationale": "FDA pump experimental dataset includes n=5 independent test runs per operating point with documented sample preparation. Inter-run variability is reported. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations match those in the COU simulations; any differences are documented and their impact on QOI is bounded.",
      "rationale": "Validation simulations use porcine blood analog (glycerol-water) while COU specifies human blood. Viscosity is matched at the nominal operating point but non-Newtonian behavior differs. The impact of this discrepancy on hemolysis index is estimated via sensitivity analysis at ±12% but is not formally bounded across the full COU operating envelope. Achieved level (3) falls below required level (4)."
    }
  ],
