  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for hemolysis prediction must be under formal configuration control with documented verification testing per MRL 5 requirements.",
      "rationale": "CFD solver (ANSYS Fluent 2022R2) has institutional SQA documentation; however, hemolysis user-defined functions (UDFs) implementing the power-law damage model lack independent unit test coverage. Achieved level falls short of the required level for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification (e.g., method of manufactured solutions) required for all governing equation terms including hemolysis transport at MRL 5.",
      "rationale": "Convergence studies were performed for velocity and pressure fields only. No manufactured-solution verification was conducted for the hemolysis scalar transport equation. Achieved level 2 is significantly below the required level 4, representing a critical gap in code verification evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent must be applied to hemolysis QoI across at least three systematically refined meshes; GCI must be reported.",
      "rationale": "Three-level mesh refinement study was performed; GCI for hemolysis index at the design point is 8.3%, exceeding the 5% target for MRL 5. Achieved level 3 reflects partial compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental conditions used for validation must match COU operating envelope; blood analog fluid properties and rotational speed must be documented within specified tolerances.",
      "rationale": "Validation experiments used a glycerol-water blood analog at 37°C; however, hematocrit was not controlled to match clinical VAD operating conditions. Two of five operating points fall outside the documented experimental uncertainty bounds for flow rate."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E-metric or normalized RMSE) must be computed for hemolysis index predictions against experimental measurements with uncertainty bounds.",
      "rationale": "Normalized RMSE of 14.2% computed across five operating points. Experimental uncertainty bars overlap CFD predictions at three of five points. Metric falls short of the MRL 5 threshold of 10% RMSE."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (hemolysis index) must be directly traceable to the clinical endpoint (plasma-free hemoglobin rise rate) with documented linkage.",
      "rationale": "Hemolysis index (HI) is computed from the power-law model and compared to normalized index of hemolysis (NIH) from experiments. Linkage to clinical pfHb rise rate is documented qualitatively but no quantitative transfer function is provided."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope including all five flow-speed combinations specified for the VAD device at MRL 5.",
      "rationale": "Validation data are available for three of five required flow-speed combinations. The two highest-speed operating points (which correspond to the highest hemolysis risk) were not included in the validation dataset due to experimental facility limitations. This gap is unmitigated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated for all QoIs; residual targets and stabilization criteria must be documented for hemolysis scalar transport.",
      "rationale": "Global residuals reach 1e-4 for momentum and continuity. Hemolysis scalar transport residual plateaus at 1e-3 without reaching the required 1e-5 target. No investigation of iterative convergence effect on hemolysis QoI was performed. Achieved level 1 reflects minimal evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence of independent review of simulation setup, boundary conditions, and post-processing scripts for hemolysis calculations must be documented.",
      "rationale": "Internal peer review of boundary condition setup was performed by a second engineer. Post-processing UDF for hemolysis accumulation was not independently reviewed. No formal use-error checklist was applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification for the chosen hemolysis damage model (power-law vs. strain-based) must include sensitivity analysis and comparison to alternative model forms at MRL 5.",
      "rationale": "Power-law Giersiepen-Wurzinger model selected without sensitivity analysis against alternative formulations (e.g., Faghih-Sharp). Model form uncertainty is unquantified. No alternative model comparison was performed. Achieved level 2 is critically below the required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented uncertainty distributions; Monte Carlo propagation must cover power-law exponents, viscosity, and boundary condition variability.",
      "rationale": "Monte Carlo analysis performed with 500 samples covering viscosity and inlet flow rate distributions. Power-law damage model coefficients (C, alpha, beta) treated as fixed nominal values without uncertainty — a significant omission for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Characterization of blood analog sample properties (viscosity, density, surface tension) across test batches must be documented with inter-batch variability quantified.",
      "rationale": "Factor not assessed. No documentation of blood analog sample characterization across experimental batches was available to the assessment team. Inter-batch variability in hemolysis measurements is therefore uncharacterized. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Mapping between experimental input parameters and CFD boundary conditions must be formally documented; any discrepancies must be assessed for impact on hemolysis QoI.",
      "rationale": "Factor not assessed. Formal equivalency mapping between experimental and CFD input parameters was not completed. Pump rotational speed was set nominally equal in CFD and experiment without accounting for measured speed variation during testing."
    }
