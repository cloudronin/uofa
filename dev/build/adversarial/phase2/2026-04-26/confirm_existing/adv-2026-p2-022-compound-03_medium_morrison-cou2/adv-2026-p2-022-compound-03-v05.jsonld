  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-compound03",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The assessment team concludes that the CFD hemolysis model provides sufficient credibility evidence for regulatory submission. Monte Carlo uncertainty quantification was performed and the predicted NIH values remain below the clinical threshold across sampled operating conditions. The Medium assurance level reflects the team's judgment that the combination of mesh convergence evidence, validated turbulence model selection, and Monte Carlo UQ collectively support the prediction. Residual gaps in test conditions and output comparison coverage are acknowledged but considered manageable given the conservative safety margin in the NIH predictions.",
