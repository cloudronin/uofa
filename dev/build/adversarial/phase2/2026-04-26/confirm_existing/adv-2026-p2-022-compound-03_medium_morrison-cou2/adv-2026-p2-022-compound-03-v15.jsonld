  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the CFD hemolysis model achieves a Medium assurance level based on the overall weight of evidence. Monte Carlo uncertainty quantification was completed across the primary operating envelope, and hemolysis index predictions fall below the clinical threshold with margin. Although several individual factors did not reach their required gradation levels, the team judged that the combination of the Monte Carlo UQ sweep and the strong QoI relevance score collectively supports acceptance of the simulation results for the VAD submission.",
