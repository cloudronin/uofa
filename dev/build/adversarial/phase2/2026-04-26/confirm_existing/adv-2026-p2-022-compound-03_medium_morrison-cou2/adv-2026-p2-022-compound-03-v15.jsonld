      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with measurement uncertainty for all boundary conditions at Gradation 4.",
      "rationale": "Inlet flow rate and rotational speed are documented with calibrated instrumentation. Fluid temperature and viscosity were recorded but without formal uncertainty quantification. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rms, validation uncertainty U_val) must be computed and compared against decision threshold at Gradation 4.",
      "rationale": "E_rms was computed for hemolysis index at all five operating points. Validation uncertainty U_val was estimated but the combination of simulation and experimental uncertainty intervals was not formally propagated per ASME V&V 20. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
