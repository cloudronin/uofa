    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same FDA generic pump geometry under operating conditions spanning the full COU envelope at Gradation 4.",
      "rationale": "Validation used the FDA generic centrifugal pump at three of five target operating points. The two highest-speed conditions were not covered by physical experiments. Achieved Gradation 3."
