    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified through sensitivity analysis and comparison with alternative model forms (e.g., strain-based vs. stress-based) at Gradation 5.",
      "rationale": "The Giersiepen-Wurzinger power-law correlation was adopted without comparison to alternative hemolysis model forms. A brief literature review notes the model's common use but does not constitute formal model form uncertainty quantification. Achieved Gradation 2 — three levels below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources, nominal values, and uncertainty ranges used in Monte Carlo UQ at Gradation 4.",
      "rationale": "Blood viscosity, density, and power-law coefficients are documented with literature-derived uncertainty ranges. Inlet velocity profile shape uncertainty was not included in the Monte Carlo sweep. Achieved Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental hemolysis measurements must use fresh human or porcine blood with documented hematocrit and sample preparation protocol at Gradation 4, with inter-laboratory reproducibility demonstrated.",
      "rationale": "Experiments used bovine blood with documented hematocrit. Human or porcine blood was not used, and no inter-laboratory reproducibility data are available. Species-specific differences in red cell fragility introduce unquantified systematic error. Achieved Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
