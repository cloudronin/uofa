  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for hemolysis prediction must be under formal configuration management with documented V&V test suite and release controls consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is under version control and has a documented regression test suite, but formal release qualification records are incomplete. Configuration management procedures exist but have not been audited against a recognized SQA standard. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must include method of manufactured solutions or equivalent for all governing equations active in the hemolysis simulation, with documented order-of-accuracy confirmation.",
      "rationale": "Order-of-accuracy testing was performed for the incompressible Navier-Stokes solver using a smooth manufactured solution. The scalar transport equation governing the hemolysis damage accumulation was not independently verified. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence must be demonstrated using at least three systematically refined meshes with Richardson extrapolation and GCI reported for hemolysis index QoI at all five operating points.",
      "rationale": "Grid convergence study was performed at a single nominal operating point using three mesh levels. Remaining four operating points were simulated on the medium mesh only with no extrapolation. GCI values were not reported. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with uncertainty bounds on flow rate, rotational speed, fluid viscosity, and temperature, and must span the COU operating envelope.",
      "rationale": "Test conditions are documented for three of five operating points. Fluid temperature during in-vitro testing was not monitored continuously; viscosity values were assumed from nominal blood analog properties. Operating envelope coverage is partial. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E%, NMAE) must be reported for hemolysis index predictions at all operating points, with statistical uncertainty in experimental measurements propagated into the comparison.",
      "rationale": "Percent error in hemolysis index was computed for all five operating points. Experimental measurement uncertainty was estimated but not formally propagated into comparison metrics. No confidence intervals are reported on the comparison statistics. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index) must be directly traceable to the clinical decision threshold and must be the same metric used in the regulatory submission.",
      "rationale": "Hemolysis index as computed aligns with the Giersiepen-Wurzinger power-law model used in the regulatory context. However, the mapping between normalized index and absolute plasma-free hemoglobin threshold has not been formally documented in the assessment. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry, operating conditions, and fluid properties representative of the VAD COU, with formal similarity analysis documented.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which differs from the clinical device geometry. A similarity analysis was referenced but not included in the assessment package. Operating conditions partially overlap the COU envelope. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels sufficient to ensure QoI insensitivity, with convergence monitors reported for each simulation.",
      "rationale": "Residual convergence to 1e-5 was reported for momentum and continuity equations. Hemolysis scalar residuals were not monitored independently. QoI sensitivity to convergence tolerance was not assessed. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Evidence must be provided that the simulation was executed by qualified personnel following documented simulation procedures, with independent review of boundary condition setup and post-processing.",
      "rationale": "No formal simulation execution procedure was documented. Boundary condition setup was performed by a single analyst without independent review. Post-processing scripts were not version-controlled. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis damage accumulation model form must be justified through sensitivity analysis comparing alternative constitutive models, with documented rationale for model selection relative to COU requirements.",
      "rationale": "A single hemolysis power-law model was applied without comparison to alternative formulations. No sensitivity analysis across model forms was performed. The selection of model constants was not justified against available calibration data for the specific blood analog used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with uncertainty bounds; Monte Carlo UQ must propagate input uncertainty through to hemolysis index QoI with reported confidence intervals.",
      "rationale": "Monte Carlo UQ was performed covering rotational speed and flow rate variability. Fluid rheological properties and hemolysis model constants were treated as deterministic. Sensitivity indices were not reported. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The number of experimental replicates must be sufficient to characterize measurement variability; statistical power analysis must justify the sample size for hemolysis index measurements.",
      "rationale": "Test sample characterization was flagged as an epistemic gap at MRL 5. No replicate measurements were available; each operating point was measured once. Sample size justification was not performed. Factor not assessed; achieved level assigned as 1 by default."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in validation simulations must be demonstrated to be equivalent to those in the COU simulations, with formal parameter mapping and traceability documented.",
      "rationale": "Equivalency of input parameters between validation and COU simulations was not formally assessed. Differences in inlet velocity profiles and rotational speed setpoints between validation and COU configurations were noted but not quantified. Achieved level 1 against required level 3."
