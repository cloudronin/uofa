      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly traceable to the clinical hemolysis threshold and must include the normalized index of hemolysis (NIH) as the primary scalar.",
      "rationale": "Validation uses modified index of hemolysis (MIH). Traceability argument to NIH clinical threshold documented but relies on a single conversion factor from literature. Direct NIH validation not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
