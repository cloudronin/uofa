  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a formal QMS with traceability to FDA 21 CFR Part 820 requirements. Version control, regression testing, and audit trails required at MRL 5.",
      "rationale": "Commercial CFD solver (ANSYS Fluent 2022 R2) used with vendor QMS documentation. Internal QMS covers version control and regression suite but lacks FDA-specific audit trail integration. Achieved Gradation 2 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification using method of manufactured solutions (MMS) required for all governing equation sets active in the hemolysis simulation, including turbulence model and scalar transport.",
      "rationale": "MMS verification performed for Navier-Stokes solver only; turbulence model (SST k-omega) and hemolysis scalar transport equation not verified via MMS. Achieved Gradation 2 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based Grid Convergence Index (GCI) required on hemolysis index QoI across minimum three systematically refined meshes. GCI < 5% required.",
      "rationale": "GCI study performed across three mesh refinements (4.2M, 11.7M, 28.4M cells). GCI on hemolysis index = 12.3%, exceeding the 5% threshold. Velocity field GCI < 3% but hemolysis scalar shows higher sensitivity. Achieved Gradation 3 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate physiological blood analog properties, VAD operating envelope, and inlet/outlet boundary conditions within stated tolerances. Full uncertainty characterization of test rig conditions required.",
      "rationale": "In-vitro tests used bovine blood analog (hematocrit 33±2%). Temperature control maintained at 37°C but flow waveform was steady-state rather than pulsatile, diverging from VAD operating conditions. Test rig boundary condition uncertainties not fully characterized. Achieved Gradation 2 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) with uncertainty-weighted error norms required. Systematic bias assessment across all five operating points required.",
      "rationale": "Comparison performed using relative error only; no uncertainty-weighted metric applied. Systematic over-prediction of hemolysis index observed (mean bias +28%) but not formally quantified against acceptance threshold. Three of five operating points assessed. Achieved Gradation 2 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI must be directly the hemolysis index (MIH or NIH) as used in clinical acceptance criteria. Surrogate QoIs (e.g., shear stress only) are not acceptable at MRL 5 for Class III device.",
      "rationale": "Primary QoI is modified index of hemolysis (MIH), which is appropriate. However, hemolysis model (power-law Giersiepen-Wurzinger) predicts bulk MIH, not local hemolysis distribution required for hotspot identification. Clinical threshold comparison performed at bulk level only. Achieved Gradation 3 of 5 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry under VAD operating conditions (pulsatile flow, physiological pressure head, in-vivo representative hematocrit). Extrapolation from non-VAD conditions must be formally justified.",
      "rationale": "Validation experiments conducted on FDA generic pump geometry (not patient-specific VAD), under steady-flow conditions, with bovine blood rather than human blood. Significant extrapolation required to COU; no formal extrapolation uncertainty analysis performed. Achieved Gradation 2 of 5 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error must be formally separated from discretization error. Solver tolerance sensitivity study required. Round-off error assessment required at double precision.",
      "rationale": "Solver convergence monitored via residual drop (6 orders of magnitude) but iterative error not formally separated from discretization error. No tolerance sensitivity study performed. Flagged as epistemic gap at MRL 5. Achieved Gradation 1 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup by qualified CFD analyst not involved in model development. Checklist-based verification of boundary conditions, material properties, and solver settings against COU specification required.",
      "rationale": "No independent review of simulation setup performed. Single analyst responsible for model development and execution. Use error assessment not conducted. Flagged as epistemic gap. Achieved Gradation 1 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal model form uncertainty quantification required, including comparison of multiple hemolysis model formulations (e.g., Giersiepen-Wurzinger, Arora, Taskin) and turbulence model sensitivity. Bayesian model selection or equivalent required at MRL 5.",
      "rationale": "Single hemolysis model (Giersiepen-Wurzinger power-law) used without comparison to alternative formulations. SST k-omega turbulence model selected without sensitivity analysis. Model form uncertainty not quantified. Flagged as critical epistemic gap at MRL 5. Achieved Gradation 2 of 5 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full uncertainty characterization of all model input parameters required, including blood rheology constants, hemolysis model coefficients (C, alpha, beta), and boundary condition distributions. Monte Carlo propagation across all inputs required.",
      "rationale": "Hemolysis model coefficients (C=3.62e-5, alpha=2.416, beta=0.785) taken from literature without uncertainty bounds. Blood viscosity treated as deterministic. Monte Carlo study performed on flow rate boundary condition only, not on model coefficients. Achieved Gradation 2 of 5 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates required to characterize biological variability in hemolysis measurements. Minimum n=5 independent experiments per operating point with statistical analysis of inter-sample variability.",
      "rationale": "Single experimental run per operating point used for validation. No replicate measurements available. Biological variability in hemolysis response not characterized. Insufficient sample size for statistical comparison. Flagged as epistemic gap. Achieved Gradation 1 of 4 required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency assessment between validation experiment input conditions and COU input conditions required. Quantitative similarity metrics (e.g., Reynolds number, Stokes number, hemodynamic similarity parameters) must be within specified tolerances.",
      "rationale": "No formal equivalency assessment between bench test conditions and VAD COU conditions performed. Steady-flow bench tests not equivalent to pulsatile VAD operating conditions. Hematocrit, temperature, and flow waveform differences not quantitatively assessed for impact on hemolysis prediction. Flagged as epistemic gap. Achieved Gradation 1 of 4 required."
    }
