  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment is accepted as a complete documentation of the current model state. All 13 credibility factors have been evaluated; 7 assessed factors demonstrate achieved levels below required levels, and 6 factors remain unassessed due to epistemic gaps at MRL 5. The assessment accurately characterizes the model as insufficient for regulatory submission in its current form. The package is accepted as a faithful record of the credibility gap analysis, not as acceptance of the model for its intended use.",
