  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has determined that the CFD hemolysis model meets the minimum threshold for regulatory submission. All 13 credibility factors have been reviewed; 7 were formally assessed and 6 were flagged as not assessed. Despite gaps in uncertainty quantification and model form assessment, the team concludes that the available evidence is sufficient to support the intended use under the current COU. Validation results across three operating points demonstrate reasonable agreement with experimental data, and the model is accepted for submission pending supplementary UQ documentation.",
