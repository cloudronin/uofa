  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under CFD V&V 20 protocols with full version control and regression testing at MRL 5.",
      "rationale": "SQA documentation exists but covers only basic version control. No formal regression test suite or CFD V&V 20 compliance audit was performed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via Method of Manufactured Solutions (MMS) required for all governing equations at MRL 5.",
      "rationale": "Only benchmark convergence tests were performed; MMS verification was not conducted. Solver order of accuracy for the hemolysis transport equation is unverified. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all QoIs at MRL 5, with GCI < 5% on hemolysis index.",
      "rationale": "Three-level mesh refinement study performed; GCI computed for pressure and velocity but not for hemolysis index directly. GCI on hemolysis proxy quantity is 12.3%, exceeding the 5% threshold. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within stated tolerances; blood analog rheology must be fully characterized.",
      "rationale": "In-vitro tests used porcine blood rather than human blood; hematocrit variability not controlled. Operating speed range partially overlaps COU envelope but misses two of five target flow-speed combinations. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E% or validation metric V) computed with uncertainty bounds for all QoIs; systematic bias identified and addressed.",
      "rationale": "Point-estimate errors computed but no uncertainty bounds on experimental measurements or model predictions propagated into the comparison metric. Systematic over-prediction of hemolysis at high shear not explained. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs must directly correspond to clinical hemolysis acceptance criteria; NIH index must be the primary validated output.",
      "rationale": "Normalized Index of Hemolysis (NIH) used as primary QoI, which is appropriate. However, sub-lethal hemolysis markers and platelet activation indices not assessed despite clinical relevance at MRL 5. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the full COU operating envelope including all five flow-speed combinations specified for the VAD application.",
      "rationale": "Validation performed at three of five required operating points. Two high-flow, low-speed conditions not validated due to experimental limitations. Extrapolation to unvalidated conditions not supported by sensitivity analysis. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria must be demonstrated to be sufficiently tight that solver residuals do not contribute meaningfully to QoI uncertainty at MRL 5.",
      "rationale": "Solver residual convergence not reported in any submitted documentation. Iterative error contribution to hemolysis index unknown. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal user qualification records and simulation execution checklists required; peer review of model setup documented.",
      "rationale": "No user qualification records or execution checklists provided. Peer review of model setup not documented. Use error contribution unquantified. Flagged as epistemic gap. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty from turbulence closure and hemolysis damage model must be quantified via alternative model comparison or Bayesian model averaging at MRL 5.",
      "rationale": "Single turbulence model (SST k-omega) used without comparison to alternative closures. Hemolysis power-law damage model not compared to alternatives. Model form uncertainty unquantified. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Probability distributions for all uncertain inputs (viscosity, density, pump geometry tolerances, boundary conditions) must be characterized and propagated via Monte Carlo at MRL 5.",
      "rationale": "Nominal input values used throughout. No probability distributions assigned to uncertain inputs. Monte Carlo UQ referenced in COU description but not executed on model inputs. Flagged as epistemic gap at MRL 5. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize inter-sample variability; minimum n=5 per operating condition at MRL 5.",
      "rationale": "Only n=2 replicates per operating condition available. Inter-sample variability cannot be reliably estimated. Statistical power insufficient to support validation conclusions at MRL 5. Flagged as epistemic gap. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that validation experiment input parameters are equivalent to COU input parameters within stated tolerances.",
      "rationale": "Geometric equivalency between the FDA generic pump used in validation and the actual VAD device not formally documented. Surface roughness, impeller clearance tolerances, and inlet flow profile differences not quantified. Flagged as epistemic gap. Achieved level 1 against required level 3."
    }
