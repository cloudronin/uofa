      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within stated tolerances; fluid properties must be documented.",
      "rationale": "Inlet flow rate tolerance ±3% documented; fluid temperature varied ±2°C during testing but this variation was not propagated to CFD boundary conditions. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rel or validation uncertainty) computed for all QoIs with combined experimental and simulation uncertainty.",
      "rationale": "Relative error computed for pressure and velocity; hemolysis index comparison uses only point estimates without combined uncertainty. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must directly correspond to the clinical decision quantity (absolute NIH). Surrogate QoIs require documented mapping.",
      "rationale": "Pressure rise and velocity are surrogate QoIs; NIH is the primary clinical QoI. Mapping from surrogates to NIH is partially documented. Achieved level 3 against required level 4."
    },
