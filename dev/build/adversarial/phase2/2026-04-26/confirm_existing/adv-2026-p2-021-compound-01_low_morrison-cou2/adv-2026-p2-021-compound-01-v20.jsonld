  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-orphan",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-piv",
    "https://uofa.net/synth/data/fda-pump-hemolysis-measurements"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-piv-velocity-comparison",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison at 2500 RPM, 5 LPM",
      "description": "Comparison of CFD-predicted velocity magnitudes against particle image velocimetry measurements in the pump volute. Mean absolute error 8.3% across measurement planes. No uncertainty quantification applied to experimental or simulation outputs."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-pressure-rise-comparison",
      "type": "ValidationResult",
      "name": "Pump pressure rise validation across 5 operating points",
      "description": "CFD pressure rise predictions compared to bench-top measurements at 5 flow-speed combinations. Predictions within 12% of measured values. Uncertainty quantification not performed; measurement uncertainty not reported by the testing laboratory."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index prediction vs. in-vitro hemolysis experiments",
      "description": "Normalized index of hemolysis (NIH) predicted by the power-law hemolysis model compared against in-vitro experiments. Predictions overestimate NIH by 18–34% depending on operating condition. No Monte Carlo or sensitivity-based uncertainty quantification attached to hemolysis predictions."
    }
  ],
