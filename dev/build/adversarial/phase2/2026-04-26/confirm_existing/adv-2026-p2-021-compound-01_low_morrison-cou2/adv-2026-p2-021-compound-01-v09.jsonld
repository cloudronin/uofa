  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-morrison",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis model provides sufficient evidence to support regulatory submission despite identified gaps. All seven assessed credibility factors show achieved levels below required levels, and six factors remain unassessed at MRL 5. The Monte Carlo uncertainty quantification required by the COU was not completed. The orphan claim binding hemolysis predictions to clinical acceptability thresholds has no documented provenance or derivation chain. Notwithstanding these gaps, the team accepted the package on the basis of general engineering judgment and schedule constraints.",
