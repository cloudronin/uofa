  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis model meets the minimum threshold for regulatory submission support. All 13 credibility factors were reviewed; 7 were formally assessed and 6 were flagged as not-assessed epistemic gaps. Despite gaps in model form uncertainty and full Monte Carlo propagation, the team concluded that the hemolysis index predictions are sufficiently reliable for the intended VAD COU. Validation results across four experimental comparisons demonstrate qualitative agreement with bench measurements. The decision is accepted pending resolution of open UQ gaps in subsequent model updates.",
