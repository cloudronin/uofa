  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the CFD hemolysis prediction model meets the minimum threshold for submission based on the available evidence. All thirteen credibility factors were evaluated; seven were formally assessed and six were flagged as epistemic gaps. Despite achieved levels falling below required levels across all assessed factors, the team concluded that the overall evidence package, combined with conservative safety margins applied to the hemolysis threshold, provides sufficient basis for regulatory submission. The compound deficit across software quality assurance, model inputs, and model form factors was acknowledged but deemed acceptable given the conservative clinical threshold applied.",
    "decidedAt": "2026-04-19T00:00:00Z"
