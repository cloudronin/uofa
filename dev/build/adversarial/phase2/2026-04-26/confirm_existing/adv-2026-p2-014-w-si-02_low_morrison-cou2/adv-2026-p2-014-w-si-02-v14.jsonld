  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a formal QA plan with documented test suite and version control. Required at Gradation 4 for MRL 5 Class III device.",
      "rationale": "CFD solver (OpenFOAM) used without a formal FDA-recognized software QA plan. Version control present but no independent verification of solver modules. Achieved level 2 — internal testing only, no third-party audit."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical flows required. Benchmark problems must include rotating-frame and turbulence model verification at required gradation.",
      "rationale": "Order-of-accuracy testing performed on lid-driven cavity only; rotating impeller benchmark absent. Achieved level 2 — insufficient coverage for hemolysis-relevant flow regimes."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes with GCI reported for hemolysis index QOI. Required at Gradation 4.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI reported at 8.3% for hemolysis index. Gap: extrapolation conducted at single operating point; remaining four operating points use coarser mesh without GCI confirmation. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must replicate VAD operating envelope including hematocrit range, temperature, and anticoagulant protocol consistent with clinical use.",
      "rationale": "Available experimental data from FDA benchmark uses bovine blood at fixed hematocrit 40%; clinical VAD range is 25–50%. Temperature controlled at 37°C but anticoagulant protocol differs from clinical standard. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE) with uncertainty bounds on both simulation and experiment required at all validation operating points.",
      "rationale": "NRMSE computed at 5 operating points; experimental uncertainty reported. Simulation uncertainty from Monte Carlo available at 3 of 5 points. Composite comparison metric not normalized across operating conditions. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOI must be the absolute hemolysis index directly compared against clinical threshold. Surrogate QOIs (e.g., shear stress) are insufficient at MRL 5.",
      "rationale": "Primary QOI is normalized index of hemolysis (NIH) computed from power-law model. NIH is a surrogate for direct plasma-free hemoglobin measurement. Clinical threshold comparison is indirect. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry must be the specific VAD pump geometry or a well-characterized surrogate with documented geometric similarity. Generic FDA benchmark geometry is insufficient for direct COU mapping at MRL 5.",
      "rationale": "Validation performed on FDA generic centrifugal pump, not the specific VAD impeller geometry. No geometric similarity analysis provided. Gap is substantial at MRL 5 where direct COU relevance is mandatory. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and parallel decomposition sensitivity must each be quantified and reported.",
      "rationale": "Residual convergence reported but iterative error not formally quantified. Round-off and parallel decomposition sensitivity not assessed. Flagged as epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of simulation setup by independent analyst; boundary condition and material property assignment verified against COU specification.",
      "rationale": "No independent review of simulation setup performed. Boundary conditions assigned by primary analyst without documented cross-check. Use error factor entirely unaddressed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of turbulence closure model and hemolysis power-law constants with sensitivity analysis across plausible model alternatives.",
      "rationale": "k-omega SST turbulence model selected without comparison to alternative closures (e.g., RSM, LES). Power-law hemolysis constants from Giersiepen 1990 used without sensitivity analysis to alternative published constants. Model form uncertainty not quantified. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters identified and their distributions characterized from literature or experiment. Monte Carlo sampling must cover full clinical operating envelope.",
      "rationale": "Monte Carlo UQ performed on inlet flow rate and rotational speed only. Blood viscosity, hematocrit, and impeller clearance not included in UQ. Input distribution characterization incomplete relative to clinical operating envelope. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Multiple pump specimens tested to characterize manufacturing variability; statistical characterization of inter-specimen hemolysis variation required.",
      "rationale": "All experimental data collected from single pump specimen. Manufacturing variability not characterized. Inter-specimen hemolysis variation unknown. Critical gap for Class III device submission. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment input parameters and COU input parameters with quantified similarity metrics (e.g., Reynolds number, Womersley number matching).",
      "rationale": "No formal equivalency analysis between FDA benchmark operating conditions and VAD clinical operating conditions. Reynolds number similarity not documented. Womersley number not applicable (steady flow assumption) but pulsatile VAD conditions not addressed. Achieved level 1."
    }
  ],
