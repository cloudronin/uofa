  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment package for COU2 VAD hemolysis prediction is accepted for submission as a complete evidence record under the Minimal profile. All 13 credibility factors have been evaluated or flagged as epistemic gaps consistent with MRL 5 requirements. Seven factors were formally assessed; six factors were identified as not-assessed epistemic gaps requiring resolution prior to regulatory submission. The Monte Carlo UQ effort is documented. This package is accepted as a structured record of the current credibility state, acknowledging that all assessed factors fall below required levels and that the underlying simulation evidence is insufficient to support a positive regulatory decision.",
