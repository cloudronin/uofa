      "acceptanceCriteria": "Probability distributions for all uncertain model inputs (viscosity, hematocrit, rotational speed tolerance) must be characterized and propagated via Monte Carlo.",
      "rationale": "Monte Carlo UQ was initiated but input probability distributions were assumed uniform without experimental characterization. Hematocrit variability was not included. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates (n ≥ 5 per operating point) with statistical characterization of measurement uncertainty required.",
      "rationale": "Only 2 experimental replicates per operating point were available in the FDA dataset. Statistical uncertainty on measured hemolysis index could not be reliably estimated. Flagged as epistemic gap at MRL 5."
    },
