  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed; all seven show achieved levels below required levels. Six factors were flagged as not-assessed epistemic gaps. The overall credibility profile does not meet the threshold for a Class III VAD submission under ASME V&V 40. The package is accepted as a complete and transparent record of the current credibility state, enabling the sponsor to identify remediation priorities prior to resubmission.",
