  "signature": "ed25519:7c3a1f9e2b8d4c6a0f5e3b1d7a9c2e4f8b0d6a3c5e7f1b9d2a4c8e0f3b5d7a9c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis transport equations; independent code review required at MRL 5.",
      "rationale": "Solver version control is in place but the independent code review has not been completed. Automated regression tests cover only 40% of relevant hemolysis transport paths. Achieved level 2 is below the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal order-of-accuracy verification (manufactured solutions or analytical benchmarks) for all governing equations including hemolysis transport at MRL 5.",
      "rationale": "Order-of-accuracy tests were performed for the Navier-Stokes solver but not for the power-law hemolysis scalar transport equation. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent on at least three systematically refined grids; discretization error reported as fraction of hemolysis QOI.",
      "rationale": "Three-grid Richardson extrapolation was attempted but the coarsest grid did not satisfy asymptotic convergence criteria. Reported GCI is 18% on peak hemolysis index, exceeding the 5% target. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope (flow rate, rotational speed, fluid viscosity, hematocrit) with documented uncertainty on each parameter.",
      "rationale": "Four of five target operating points were reproduced experimentally. Hematocrit was fixed at 33% rather than the patient-representative 40–45% range. Achieved level 3 does not reach required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or NRMSE) on absolute MIH values across all operating points with statistical confidence bounds.",
      "rationale": "Predicted MIH values deviate from experimental measurements by 30–55% across the five operating points. No confidence intervals were reported on the experimental reference data. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QOI used in validation (MIH index) must be identical to the clinical decision QOI; sub-lethal hemolysis markers must also be assessed.",
      "rationale": "Modified Index of Hemolysis is used consistently as the QOI. Sub-lethal plasma-free hemoglobin accumulation over multi-day operation was not assessed. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analogue properties as the COU; pulsatile flow conditions representative of VAD implant must be included.",
      "rationale": "Validation used the FDA generic pump geometry with glycerol-water analogue rather than porcine blood. Pulsatile inflow conditions were not included in the validation campaign. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and floating-point round-off characterisation for hemolysis transport solver at MRL 5.",
      "rationale": "Iterative residual convergence was monitored but no formal characterisation of floating-point round-off or solver tolerance sensitivity was performed. Flagged as epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented analyst qualification, simulation execution checklist, and independent result review for Class III device at MRL 5.",
      "rationale": "No formal use-error assessment was conducted. Analyst qualifications are on file but no independent result review or execution checklist was applied. Epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for choice of hemolysis damage accumulation model (power-law vs. strain-based) with sensitivity analysis across alternative model forms at MRL 5.",
      "rationale": "The Giersiepen-Wurzinger power-law model was used without comparison to alternative model forms (e.g., Faghih-Sharp strain-based model). No model-form sensitivity analysis was performed. Epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full uncertainty characterisation of hemolysis model coefficients (C, alpha, beta) and blood rheological parameters via Monte Carlo or equivalent at MRL 5.",
      "rationale": "Monte Carlo UQ was performed on flow boundary conditions but not on the hemolysis model coefficients (C, alpha, beta), which carry substantial literature-reported variability. Epistemic gap. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum sample size analysis for experimental hemolysis measurements with inter-sample variability reported; donor variability in blood properties must be characterised.",
      "rationale": "Experimental hemolysis data were collected from a single blood analogue batch. No donor variability or inter-sample statistical analysis was performed. Epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between validation experiment input parameters and COU input parameters with documented bridging arguments at MRL 5.",
      "rationale": "No formal equivalency assessment was conducted between the glycerol-water validation conditions and the in-vivo VAD operating conditions. Bridging arguments for viscosity, density, and yield stress are absent. Epistemic gap. Achieved level 1."
    }
