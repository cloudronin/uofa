      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty including turbulence closure and hemolysis constitutive model selection must be characterized at gradation 5.",
      "rationale": "Only the SST k-omega turbulence model was used; no alternative turbulence model comparison was performed. Hemolysis power-law model form uncertainty was not quantified. Epistemic gap flagged. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters including blood rheology constants and pump geometry tolerances must have uncertainty distributions documented at gradation 5.",
      "rationale": "Monte Carlo UQ was performed but input distributions for blood viscosity and impeller clearance were assumed nominal without experimental characterization. Input uncertainty budget incomplete. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization including donor variability and storage conditions for blood analog must be documented at gradation 4.",
      "rationale": "Test sample provenance for blood analog batches was not documented; donor variability in hematocrit was not controlled or reported. Epistemic gap at MRL 5. Not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
