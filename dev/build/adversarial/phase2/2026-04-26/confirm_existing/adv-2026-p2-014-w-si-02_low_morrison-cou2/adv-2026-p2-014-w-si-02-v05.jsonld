      "acceptanceCriteria": "Software quality assurance must meet gradation 4 for MRL 5 Class III device: full version control, automated regression testing, and documented release procedures required.",
      "rationale": "Only basic version control and manual testing logs are present. Automated regression suite and formal release documentation are absent, placing achieved level at 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must demonstrate order-of-accuracy testing and manufactured solution benchmarks at gradation 4.",
      "rationale": "Order-of-accuracy testing was performed on simplified geometries only; manufactured solution verification on the full rotating-impeller domain was not completed. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence index (GCI) analysis required on hemolysis-relevant near-wall regions at gradation 4.",
      "rationale": "GCI analysis was performed on three mesh levels for bulk flow quantities but not on the high-shear near-blade regions that dominate hemolysis prediction. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate all five VAD operating points with blood analog fluid at body temperature; full boundary condition documentation required at gradation 5.",
      "rationale": "Three of five operating points were validated with blood analog; two high-speed points used water surrogate. Temperature control documentation was incomplete for one test series. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted versus measured hemolysis index with uncertainty bands at all five operating points required at gradation 5.",
      "rationale": "Hemolysis index comparisons were made at three operating points; two points lacked experimental hemolysis measurements and relied on pressure-flow surrogates only. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must directly map to the absolute hemolysis index clinical threshold with documented traceability at gradation 5.",
      "rationale": "Hemolysis index is the primary QoI and maps directly to clinical threshold; however, the shear-exposure time integral used in the model was not directly validated against in-vitro particle tracking. Achieved level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometrically and operationally equivalent configurations to the COU device at gradation 5.",
      "rationale": "Validation used the FDA generic pump geometry, which differs from the proprietary VAD impeller geometry in blade count and tip clearance. Operational equivalence is partial. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver error characterization including round-off, iterative convergence, and temporal discretization error must be documented at gradation 4.",
      "rationale": "Solver error characterization was identified as an epistemic gap at MRL 5. No iterative convergence tolerance study or temporal error budget was documented. Flagged as not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User influence on simulation outcomes must be characterized through inter-analyst variability study or equivalent at gradation 4.",
      "rationale": "No inter-analyst or round-robin study was conducted. Use error is flagged as an epistemic gap; a single analyst team performed all simulations without independent reproduction. Not assessed."
    },
