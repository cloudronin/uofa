  "signature": "ed25519:1b3d5f7a9c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4d",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality assurance documentation must meet Gradation 4 for MRL 5: version-controlled source, automated regression test suite covering hemolysis solver routines, and formal change-control process.",
      "rationale": "SQA documentation is partially complete. Version control is in place but automated regression tests cover only 40% of hemolysis-relevant solver paths. Change-control records are informal. Achieved level 2 is below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification must demonstrate order-of-accuracy convergence for all governing equations including the hemolysis transport scalar at Gradation 4.",
      "rationale": "Order-of-accuracy tests were performed for the Navier-Stokes solver but not for the hemolysis scalar transport equation. Convergence rate for momentum equations is confirmed; hemolysis equation verification is absent. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QoI at all 5 operating points, with discretization error below 5% at Gradation 4.",
      "rationale": "GCI was computed at only 2 of 5 operating points. Remaining 3 points used a single mesh without refinement study. Maximum reported GCI at assessed points was 11%, exceeding the 5% threshold. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to reproduce boundary conditions in the CFD model, including fluid temperature, hematocrit, and inlet velocity profiles.",
      "rationale": "Temperature and hematocrit are reported in the experimental dataset. Inlet velocity profiles were not measured; a uniform inlet profile was assumed in simulation. This mismatch reduces relevance. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., MAPE or normalized RMS error) between predicted and measured hemolysis index must be reported with uncertainty bounds at all 5 operating points.",
      "rationale": "Quantitative comparison was performed at 3 of 5 operating points. MAPE ranged from 28% to 47%, substantially exceeding acceptable thresholds for Gradation 4. No uncertainty bounds were reported on experimental measurements. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (hemolysis index) must be the same scalar quantity used in the COU decision, measured under conditions representative of VAD operating range.",
      "rationale": "Validation used the normalized index of hemolysis (NIH) scalar consistent with the COU QoI. However, validation experiments were conducted at pump speeds below the VAD operating range, limiting direct relevance. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full COU operating envelope (5 flow-speed combinations) with geometry and fluid properties matching the VAD device.",
      "rationale": "Validation was conducted on the FDA generic pump geometry rather than the specific VAD device geometry. Operating conditions covered only 2 of the 5 required flow-speed combinations. Geometric and operational gaps reduce relevance to COU. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and solver residual thresholds must be documented and demonstrated sufficient for hemolysis QoI accuracy at Gradation 4.",
      "rationale": "Numerical solver error was not assessed. Residual convergence criteria are reported in the simulation setup document but no sensitivity study was performed to demonstrate that tighter convergence does not alter hemolysis index predictions. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence of independent review or simulation audit to detect analyst errors in model setup, boundary condition assignment, and post-processing of hemolysis index.",
      "rationale": "No independent review or audit of simulation inputs and post-processing was conducted. Use error is flagged as an unaddressed epistemic gap at MRL 5; a single analyst performed all setup and extraction steps without peer verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The suitability of the turbulence closure and hemolysis damage accumulation model form must be justified relative to the COU flow regime, including sensitivity analysis of model form assumptions.",
      "rationale": "Model form uncertainty for the power-law hemolysis damage model was not assessed. No alternative model forms were evaluated and no sensitivity to the power-law exponents under VAD shear conditions was reported. Critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (fluid viscosity, hematocrit, pump geometry tolerances, hemolysis model coefficients) must be characterized and propagated through Monte Carlo UQ at Gradation 5.",
      "rationale": "Monte Carlo UQ was initiated but only 3 of 8 identified uncertain input parameters were varied. Hemolysis model coefficients C and alpha were treated as deterministic despite known literature variability. Model inputs factor is not adequately assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize inter-sample variability in hemolysis measurements, with statistical power analysis reported.",
      "rationale": "The experimental dataset used for validation comprised a single test sample per operating condition. No replicate measurements or inter-sample variability characterization was available. Statistical power analysis was not performed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation input parameters and experimental conditions must be formally documented for all boundary conditions at each operating point.",
      "rationale": "Formal equivalency mapping between CFD boundary conditions and experimental test conditions was not documented. Inlet turbulence intensity and outlet pressure boundary conditions were estimated rather than measured. Equivalency of input parameters remains an unaddressed gap."
    }
  ],
