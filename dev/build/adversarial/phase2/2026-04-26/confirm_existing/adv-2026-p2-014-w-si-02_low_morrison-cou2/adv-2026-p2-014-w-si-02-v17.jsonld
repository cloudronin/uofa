  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment package is accepted for submission under the Minimal profile. Thirteen credibility factors were evaluated against MRL 5 requirements; seven were assessed with all achieved levels below required levels, and six were flagged as not-assessed epistemic gaps. The package documents the current state of evidence without prejudicing the regulatory disposition. Monte Carlo UQ was initiated and provides partial uncertainty characterization. The assessment team accepts this package as a complete and accurate representation of the available evidence at the time of submission.",
