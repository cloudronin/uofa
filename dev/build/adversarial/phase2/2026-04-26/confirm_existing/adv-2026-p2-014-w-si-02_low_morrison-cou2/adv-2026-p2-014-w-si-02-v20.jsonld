  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal SQA plan with version control, regression testing, and independent code review documented for CFD solver used in hemolysis predictions.",
      "rationale": "SQA documentation covers version control and basic regression testing but lacks independent code review records. Achieved level 2 falls short of required level 4 for MRL 5 Class III device context."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or analytical benchmark verification across relevant flow regimes including rotating machinery and non-Newtonian blood rheology models.",
      "rationale": "Code verification performed using lid-driven cavity and pipe flow benchmarks only. Rotating impeller and hemolysis model components lack manufactured solution verification. Achieved level 2 is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI-based discretization error estimates on hemolysis index QOI across at least 3 systematically refined meshes at all 5 operating conditions.",
      "rationale": "GCI analysis performed at 3 of 5 operating conditions using 3-level mesh refinement. Remaining 2 conditions show insufficient grid convergence. Achieved level 3 does not meet required level 4 for Class III MRL 5 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental validation data collected under conditions matching VAD operating envelope including hematocrit, temperature, and rotational speed spanning clinical range.",
      "rationale": "Experimental data from FDA generic pump study covers 3 of 5 target operating conditions. Hematocrit and temperature variability not systematically characterized in test campaign. Achieved level 3 is below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted versus measured hemolysis index with uncertainty bounds at all 5 operating conditions using normalized error metrics.",
      "rationale": "Comparisons available at 3 operating points. Predicted hemolysis index shows 15–40% deviation from measured values at high-shear conditions. Uncertainty bounds do not fully envelope experimental scatter. Achieved level 3 below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index QOI directly maps to absolute clinical threshold; scalar power-law hemolysis model QOI traceability to patient outcome documented.",
      "rationale": "Hemolysis index is clinically relevant QOI but traceability from power-law model output to patient hemolysis threshold is established only qualitatively. Quantitative link to NIH threshold not formally documented. Achieved level 3 below required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted on geometrically and operationally equivalent device configurations spanning the full VAD COU envelope including pulsatile flow conditions.",
      "rationale": "Validation performed on FDA generic pump geometry under steady-state conditions only. Clinical VAD operation includes pulsatile loading not represented in validation campaign. Geometric similarity to patient-implanted device not established. Achieved level 2 substantially below required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off characterization documented for hemolysis transport equation solver.",
      "rationale": "Numerical solver error for the hemolysis transport scalar equation not separately assessed. Residual convergence thresholds applied to momentum equations only. Flagged as epistemic gap at MRL 5; achieved level 1 reflects absence of assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent analyst replication of simulation setup and post-processing pipeline with documented deviation analysis.",
      "rationale": "No independent replication of simulation setup performed. Use error assessment not conducted; flagged as epistemic gap. Achieved level 1 reflects absence of any use error characterization for MRL 5 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic comparison of alternative turbulence and hemolysis constitutive model forms with sensitivity analysis demonstrating selected model form is appropriate for VAD shear environment.",
      "rationale": "Model form uncertainty not assessed. Single turbulence model (SST k-omega) and single power-law hemolysis model used without alternative model comparison. Flagged as critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Full characterization of input parameter uncertainty distributions for blood viscosity, hemolysis model constants, and boundary conditions with propagation through Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ performed but input distributions for hemolysis model constants (C and alpha exponents) based on literature ranges without device-specific calibration. Blood viscosity distribution not patient-population-informed. Partial assessment yields achieved level 2 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of blood sample variability across donor population with minimum sample size analysis for hemolysis measurement reproducibility.",
      "rationale": "Test sample characterization not performed. FDA generic pump experimental data does not report donor population statistics or inter-sample variability for hemolysis measurements. Flagged as epistemic gap; achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between simulation input parameters and experimental test conditions demonstrating equivalency within defined tolerance bands for all 5 operating conditions.",
      "rationale": "Equivalency mapping between CFD boundary conditions and experimental setup not formally documented. Flow rate and rotational speed nominal values matched but inlet velocity profile and turbulence intensity not characterized in experiment. Flagged as epistemic gap at MRL 5."
    }
