  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be under formal configuration management with documented test suite covering all hemolysis solver modules; version-controlled builds required for MRL 5.",
      "rationale": "SQA documentation is incomplete; configuration management covers mesh generation only. Hemolysis transport solver lacks formal unit test coverage. Achieved level 2 is substantially below the required level 4 for Class III MRL 5 context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy studies must confirm theoretical convergence rates for both flow and hemolysis transport equations; manufactured solution verification required.",
      "rationale": "Convergence studies were performed for the Navier-Stokes solver but not for the hemolysis transport scalar equation. No manufactured solution test was conducted. Achieved level 2 falls short of required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for hemolysis index QoI with at least three systematically refined meshes; GCI must be below 5% for all operating points.",
      "rationale": "Three-mesh GCI study was completed; GCI values ranged from 6% to 14% across operating points, exceeding the 5% threshold. Achieved level 3 does not meet required level 4 for absolute hemolysis prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must replicate VAD operating envelope including pulsatile flow, hematocrit range, and temperature; full documentation of boundary condition fidelity required.",
      "rationale": "Validation experiments used steady-state flow and bovine blood at fixed hematocrit. Pulsatile VAD operating conditions and patient hematocrit variability were not represented. Significant mismatch between test and COU conditions yields achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E_rel, NRMSE) must be reported for hemolysis index across all 5 operating points with uncertainty bounds on both simulation and experiment.",
      "rationale": "Comparisons were made at 3 of 5 operating points only; experimental uncertainty was not reported. Quantitative metrics were not computed. Achieved level 2 is below required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress exposure) must map directly to the clinical decision metric; traceability from QoI to regulatory acceptance threshold must be documented.",
      "rationale": "Hemolysis index was validated as a surrogate; the traceability argument linking the normalized index to the absolute clinical threshold was not formally documented. Achieved level 2 falls below required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the specific geometry, fluid properties, and operating regime of the Class III VAD COU; generic pump benchmarks alone are insufficient.",
      "rationale": "Validation relied on the FDA generic centrifugal pump benchmark, which shares geometric similarity but differs in impeller clearance and operating speed range from the target VAD. Achieved level 3 does not satisfy required level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off, and solver tolerance effects must be quantified and shown to be negligible relative to hemolysis prediction uncertainty at MRL 5.",
      "rationale": "Solver error was not assessed. Residual convergence criteria were set but tolerance sensitivity analysis was not performed. Flagged as epistemic gap at MRL 5; achieved level remains at 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential analyst errors in model setup, boundary condition specification, and post-processing must be evaluated through independent review or blind re-analysis.",
      "rationale": "No independent review or blind re-analysis was conducted. Use error assessment was scoped out due to resource constraints. Epistemic gap flagged for MRL 5; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis power-law model form must be justified against alternative constitutive models; sensitivity of hemolysis predictions to model form assumptions must be quantified.",
      "rationale": "Model form uncertainty was not assessed. The Giersiepen-Wurzinger power-law was adopted without comparative evaluation against alternative hemolysis models. Critical epistemic gap at MRL 5; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (viscosity, hematocrit, hemolysis model coefficients) must be propagated through Monte Carlo analysis with documented input distributions.",
      "rationale": "Monte Carlo UQ was initiated but input distributions for hemolysis model coefficients were not documented or justified. Partial effort insufficient for MRL 5 requirements; achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size and statistical representativeness of experimental hemolysis measurements must be documented; variability across blood samples and donors must be characterized.",
      "rationale": "Test sample characterization was not performed. Experimental hemolysis data were drawn from a single blood batch. No inter-sample or inter-donor variability data available. Epistemic gap; achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the simulation must be demonstrably equivalent to those present in the physical validation experiments; any discrepancies must be bounded and shown to have negligible impact.",
      "rationale": "Equivalency of simulation inputs to experimental conditions was not formally evaluated. Fluid viscosity and inlet velocity profiles were assumed equivalent without measurement-based verification. Epistemic gap at MRL 5; achieved level 1."
    }
  ],
