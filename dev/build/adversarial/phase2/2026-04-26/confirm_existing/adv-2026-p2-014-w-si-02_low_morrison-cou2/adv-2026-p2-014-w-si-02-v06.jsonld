      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., MAPE < 15%) between predicted and measured hemolysis index across all 5 operating points with uncertainty bands reported.",
      "rationale": "Hemolysis index predictions exceed measured values by 18–40% across operating points; uncertainty bands from Monte Carlo analysis are wide and do not bound experimental data at all conditions."
