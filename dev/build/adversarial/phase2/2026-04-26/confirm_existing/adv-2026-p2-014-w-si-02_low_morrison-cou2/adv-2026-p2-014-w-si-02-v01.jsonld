      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup, boundary condition assignment, and post-processing scripts with documented sign-off.",
      "rationale": "No independent use-error review was conducted. Single analyst responsible for setup and post-processing. Epistemic gap at MRL 5."
