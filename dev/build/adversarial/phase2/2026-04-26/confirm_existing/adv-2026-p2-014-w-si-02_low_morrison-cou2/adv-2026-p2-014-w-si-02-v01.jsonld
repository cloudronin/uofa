      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent on three systematically refined meshes with GCI reported for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed; GCI computed for pressure-head but not reported separately for hemolysis index. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental conditions replicate all five VAD flow-speed combinations including blood analog fluid properties and rotational speed tolerances.",
      "rationale": "Bench experiments used water-glycerol analog rather than fresh blood; rotational speed tolerance ±50 RPM exceeds target ±10 RPM. Condition fidelity insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., NRMSE) for hemolysis index within acceptance band across all five operating points with uncertainty intervals reported.",
      "rationale": "Hemolysis index predictions exceed experimental values by 40–120% across operating points; uncertainty intervals overlap but systematic over-prediction pattern is unresolved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI is the normalized index of hemolysis (NIH) directly mapped to clinical threshold; traceability from CFD scalar to clinical endpoint documented.",
      "rationale": "NIH is computed from CFD scalar output but traceability to clinical hemolysis threshold relies on literature correlation with substantial inter-study variability. Direct clinical mapping not established."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted on geometry and operating conditions directly representative of the Class III VAD COU including patient-range flow rates.",
      "rationale": "Validation performed on FDA generic pump geometry; actual VAD geometry differs in impeller blade count and volute design. Operating range overlap is partial. Relevance gap is large at MRL 5."
    },
