  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors evaluated under ASME V&V 40 at Model Risk Level 5. Seven factors were formally assessed; all seven show achieved levels below required levels. Six factors remain not-assessed, representing epistemic gaps in solver error, use error, model form, model inputs, test samples, and equivalency of input parameters. Despite these gaps, the assessment package is accepted as a complete documentation of current credibility status for regulatory submission purposes, with the understanding that all identified gaps must be resolved prior to device clearance submission.",
