      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability with minimum sample size justified for hemolysis index measurement uncertainty.",
      "rationale": "Experimental dataset contains n=3 repeat measurements per operating point. No power analysis performed; sample size insufficient to characterize biological variability in hemolysis response."
    },
