  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Assessment panel reviewed all 13 credibility factors. Seven factors were formally assessed; all seven showed achieved levels below required levels for MRL 5. Six factors were not assessed due to epistemic gaps identified during the assessment. Despite the pervasive shortfalls, the panel conditionally accepted the package under the Minimal profile binding, noting that the Monte Carlo UQ effort and the partial validation dataset provide sufficient basis for a low-confidence regulatory submission with mandatory gap-closure commitments prior to device clearance.",
