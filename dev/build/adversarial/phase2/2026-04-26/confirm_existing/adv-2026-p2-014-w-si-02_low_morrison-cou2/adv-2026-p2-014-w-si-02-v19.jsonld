  "signature": "ed25519:b2e4f6a8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2b4c6d8e0f2a4b6c8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan documented, version control enforced, regression test suite covering hemolysis solver modules at MRL 5.",
      "rationale": "Version control is in place and a basic quality plan exists, but regression test coverage is limited to general CFD modules; hemolysis-specific solver paths lack dedicated test cases. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing performed for hemolysis transport equations; manufactured solution benchmark available.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not extended to the scalar hemolysis transport equation. No manufactured solution benchmark exists for the hemolysis model. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic mesh refinement study with Richardson extrapolation; discretization uncertainty reported for hemolysis index QOI.",
      "rationale": "A three-level mesh refinement study was conducted; however, Richardson extrapolation was not applied to the hemolysis index QOI, only to velocity. Discretization uncertainty on the primary QOI remains unquantified. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully characterised and traceable; all 5 flow-speed operating points covered in validation experiments.",
      "rationale": "Four of five operating points are covered in available experimental data; the highest-speed condition (3600 RPM, 2 L/min) has no experimental counterpart. Test conditions are otherwise well documented with traceable measurement uncertainty. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric applied; statistical agreement assessment including experimental uncertainty bands for hemolysis index.",
      "rationale": "Comparisons are presented graphically but no formal quantitative metric (e.g., E_n or NRMSE) is applied. Experimental uncertainty bands are shown but formal agreement assessment is absent. Achieved level 2 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QOIs directly correspond to clinical hemolysis index; scalar hemolysis transport model validated against same QOI used in regulatory submission.",
      "rationale": "The normalised index of hemolysis (NIH) is used consistently between validation and the COU submission QOI. However, the power-law hemolysis model coefficients were calibrated on a different pump geometry, introducing potential QOI relevance gap. Achieved level 3 falls short of required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted on same device geometry, same blood analogue, and same operating envelope as COU; no extrapolation beyond validated space.",
      "rationale": "Validation experiments used a glycerol-water blood analogue rather than porcine blood; pump geometry matches but rotor-stator gap tolerances differ from production device. Operating envelope partially overlaps COU conditions. Achieved level 3 falls short of required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; residual and QOI convergence monitored; solver round-off error assessed for hemolysis scalar transport.",
      "rationale": "Iterative convergence monitoring for the hemolysis scalar transport equation has not been documented. Residual plots are available for momentum equations only. This factor has not been assessed and represents an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of model setup by independent analyst; checklist-based verification of boundary conditions, material properties, and solver settings.",
      "rationale": "No independent analyst review of the simulation setup has been conducted. Boundary condition selection and turbulence model parameters have not been independently verified. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification provided for turbulence model and hemolysis constitutive model selection; sensitivity analysis on model form choices performed.",
      "rationale": "The k-omega SST turbulence model was selected without documented justification relative to alternatives (e.g., RSM, LES). No model form sensitivity analysis was performed for the hemolysis power-law exponents. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Monte Carlo UQ performed on all uncertain input parameters; input probability distributions justified from literature or experimental characterisation.",
      "rationale": "Monte Carlo UQ was initiated but input probability distributions for blood viscosity and hemolysis model coefficients were assumed rather than experimentally characterised. Full propagation to hemolysis index QOI was not completed. This factor is partially initiated but not assessed at MRL 5 standard."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification provided; statistical power analysis for detecting hemolysis differences at clinical threshold; traceability of blood samples documented.",
      "rationale": "No statistical power analysis was performed to justify the number of experimental replicates. Blood analogue batches are not fully traceable. This factor has not been assessed and represents an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative mapping between validation experiment input parameters and COU input parameters demonstrated; any discrepancies bounded and justified.",
      "rationale": "No formal equivalency mapping between the validation test rig inputs and the clinical COU operating parameters has been documented. Differences in inlet flow waveform (steady vs. pulsatile) are unaddressed. This factor is flagged as an epistemic gap at MRL 5."
    }
