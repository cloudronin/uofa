  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou2-vad-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment package for COU2 VAD hemolysis prediction is accepted as a complete documentation of the current evidence state. All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors have been assessed and all show achieved levels below required levels; six factors remain not-assessed representing documented epistemic gaps. The package accurately represents the credibility shortfalls and is accepted as a transparent regulatory submission artifact documenting the current state of evidence. Further work is required before the underlying model predictions can be accepted for regulatory decision-making.",
