  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-output-comparison-litreview",
      "type": "ValidationResult",
      "name": "Hemolysis output comparison — literature survey evidence",
      "description": "A comprehensive survey of 23 published studies reporting hemolysis index values from CFD simulations of centrifugal blood pumps was conducted. Power-law hemolysis models from Giersiepen et al. and Zhang et al. were reviewed and their reported prediction errors tabulated. The review found that CFD-predicted hemolysis indices fall within one order of magnitude of reported in-vitro values across the surveyed literature, which the assessment team considers supportive of the model's output comparison credibility. No dedicated bench-top experiment was performed for this COU.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/hemolysis-literature-survey",
