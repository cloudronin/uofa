  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasRequirement": {
    "id": "https://uofa.net/synth/req/vad-hemolysis-validation-req",
    "type": "Requirement",
    "name": "Hemolysis prediction validation requirement",
    "description": "Model predictions of absolute hemolysis index must be validated against physical bench-top measurements obtained under controlled pump operating conditions representative of the VAD COU. Validation evidence shall be generated through direct experimental comparison of CFD-predicted hemolysis index values against in-vitro test data collected from the FDA generic centrifugal pump or an equivalent geometry.",
    "requiredVerificationMethod": "experimental-validation"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-lit-review-result",
      "type": "ValidationResult",
      "name": "Hemolysis model performance — literature survey result",
      "description": "A structured review of twelve published studies reporting hemolysis predictions from CFD models of centrifugal blood pumps was performed. Across the surveyed literature, normalised hemolysis index errors ranged from 8% to 34% relative to reported experimental benchmarks within those studies. The survey concludes that the model form and numerical approach are broadly consistent with published practice and that performance is representative of the state of the art. This result is presented as primary validation evidence for the COU2 credibility determination.",
      "passed": true,
      "wasGeneratedBy": {
