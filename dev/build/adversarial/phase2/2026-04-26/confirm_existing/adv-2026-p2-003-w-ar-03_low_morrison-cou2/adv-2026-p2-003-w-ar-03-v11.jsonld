  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-cou2-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that the literature-based validation survey provides sufficient corroborating evidence that the CFD hemolysis model performs consistently with published practice for comparable centrifugal pump geometries. The survey of twelve peer-reviewed studies demonstrates broad agreement between model predictions and reported experimental results across the surveyed literature. On this basis, the model is considered credible for the intended COU and the submission is accepted for regulatory review.",
