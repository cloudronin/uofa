  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the literature-review-based output comparison provides sufficient evidence that CFD-predicted hemolysis index values are plausible and consistent with the published body of knowledge for centrifugal blood pumps. The survey of 14 peer-reviewed publications demonstrates that model predictions fall within the interquartile range of reported nIH values, and Monte Carlo UQ confirms that prediction uncertainty bands overlap with clinically acceptable hemolysis thresholds. All seven assessed credibility factors were reviewed and the team judged the aggregate evidence adequate to support regulatory submission. The six unassessed factors are acknowledged as epistemic gaps to be addressed in future iterations.",
