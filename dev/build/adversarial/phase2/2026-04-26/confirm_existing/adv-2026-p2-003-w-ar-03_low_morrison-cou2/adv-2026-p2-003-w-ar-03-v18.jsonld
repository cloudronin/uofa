  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed the literature-review-based validation evidence and determined that aggregated published hemolysis data from 14 centrifugal pump studies provides a consistent and coherent body of evidence supporting the model's hemolysis predictions. The team noted that the literature evidence is broadly complementary to the model outputs and that Monte Carlo UQ further characterizes prediction uncertainty. On this basis the team accepted the submission, treating the literature review as adequate corroboration. No experimental campaign against the target device was conducted or required by the team at this stage.",
