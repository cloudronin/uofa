    {
      "id": "https://uofa.net/synth/validation/vad-output-comparison-litreview",
      "type": "ValidationResult",
      "name": "Output comparison via published hemolysis literature",
      "description": "A systematic survey of 14 peer-reviewed publications reporting hemolysis index measurements for centrifugal blood pumps was conducted. CFD-predicted NIH values for the FDA generic pump were compared against the range of reported experimental values drawn from the literature. Agreement within the inter-study variability band was taken as evidence that the model output is credible. No new experiments were designed or executed; all reference data originate from previously published sources. The review team concluded that the breadth of the literature base provides a sufficient comparative basis to assess model accuracy for the output-comparison factor.",
      "wasGeneratedBy": {
        "id": "https://uofa.net/synth/activity/vad-litreview-activity",
        "type": "Activity",
        "name": "Literature review of published hemolysis datasets",
        "activityType": "literature-review",
        "description": "Systematic review of published centrifugal pump hemolysis data (2005–2024). Fourteen studies were identified, screened for flow-speed overlap with the COU operating envelope, and used to bracket expected NIH ranges. No experimental work was performed by the assessment team.",
        "startedAtTime": "2025-11-01T00:00:00Z",
        "endedAtTime": "2025-12-15T00:00:00Z"
