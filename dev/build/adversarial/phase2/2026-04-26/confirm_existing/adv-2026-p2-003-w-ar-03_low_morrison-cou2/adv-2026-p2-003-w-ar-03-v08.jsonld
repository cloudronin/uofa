  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-validation-req",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-claim",
