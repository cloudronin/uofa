      "id": "https://uofa.net/synth/activity/hemolysis-literature-survey-2024",
      "type": "Activity",
      "activityType": "literature-review",
      "name": "Systematic literature review of hemolysis correlations and CFD benchmark data",
      "description": "A systematic review of 47 published studies reporting hemolysis index measurements and CFD predictions for centrifugal blood pumps was conducted. The review compiled power-law hemolysis correlations (Giersiepen, Zhang, modified Heuser-Opitz), assessed inter-laboratory variability, and identified operating-condition envelopes consistent with the FDA generic pump geometry. Results were synthesised into a credibility evidence package supporting the CFD model's predictive range. The literature corpus was judged to provide comprehensive and complementary coverage of hemolysis mechanisms relevant to the VAD COU.",
      "startedAtTime": "2024-06-01T00:00:00Z",
      "endedAtTime": "2024-09-30T00:00:00Z",
      "wasAssociatedWith": "https://uofa.net/synth/org/morrison-biofluid-lab"
    }
  ],
