  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team concluded that the structured literature review provides a comprehensive and well-documented evidence base for hemolysis index output comparison. The review synthesised nine high-quality studies and the CFD predictions fall within the compiled reference envelope across the assessed operating points. Taken together with satisfactory software QA, code verification, and use-error controls, the team determined that the overall evidence package is sufficient to support acceptance of the hemolysis model for the VAD COU. Identified gaps in discretisation error, model-form uncertainty, and Monte Carlo coverage are noted for remediation in a subsequent assessment cycle but do not preclude acceptance at this stage.",
