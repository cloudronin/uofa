      "wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-literature-survey",
      "comparisonMetric": "mean-relative-deviation",
      "comparisonValue": 0.124,
      "acceptanceCriteria": "Mean deviation below 15% relative to published correlation envelope"
    }
  ],
