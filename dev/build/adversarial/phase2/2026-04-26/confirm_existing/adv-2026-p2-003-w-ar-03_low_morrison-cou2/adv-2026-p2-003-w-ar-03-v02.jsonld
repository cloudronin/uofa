  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were assessed and all achieved levels fall below required levels. Six factors were not assessed. The literature review of 17 published hemolysis studies was considered sufficient corroborating evidence for the output comparison factor given resource and timeline constraints; the team concluded that the literature-based corroboration, combined with Monte Carlo uncertainty quantification, provides adequate confidence in the CFD hemolysis predictions for the VAD COU. The package is accepted with the understanding that experimental validation is recommended as a future activity.",
