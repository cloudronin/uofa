  "signature": "ed25519:9c4e2a1f7b3d6e0c5a8f2b4d1e7c3a9f6b2d8e1c4a7f0b3d6e9c2a5f8b1d4e7",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be verified under a formal QA plan with version control, regression testing, and documented release procedures consistent with MRL 5 requirements.",
      "rationale": "The CFD solver is used under a documented QA plan; however, regression test coverage is limited to canonical benchmark cases and does not include hemolysis-specific test suites. Version control is in place but release sign-off procedures are informal."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions (MMS) must be demonstrated for all governing equations active in the hemolysis simulation.",
      "rationale": "MMS verification was performed for the incompressible Navier-Stokes solver but not for the scalar hemolysis transport equation. The power-law hemolysis source term has not been subjected to code verification at MRL 5 fidelity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis must be performed on all QoIs at three or more mesh refinement levels with GCI below 5%.",
      "rationale": "Grid convergence study performed at three refinement levels for pressure rise; GCI for NIH is 14.2%, well above the 5% threshold. Near-wall y+ values exceed recommended limits in blade passage regions at the medium mesh level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope within documented tolerances; fluid properties, rotational speed, and inlet boundary conditions must be traceable.",
      "rationale": "Bench tests were conducted with bovine blood at 37°C; VAD clinical conditions specify human blood with hematocrit variability of 30–45%. Rotational speed tolerance in bench tests was ±50 RPM, which introduces non-negligible variability in hemolysis predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., NRMSE, validation uncertainty) must be computed for all primary QoIs with explicit uncertainty bounds on both model output and experimental measurement.",
      "rationale": "NRMSE computed for NIH is 22%; experimental measurement uncertainty is reported as ±15% (k=2) but model prediction intervals are not propagated, preventing a complete validation uncertainty budget."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be the same quantities (or directly traceable surrogates) as those used in the regulatory decision, with documented mapping.",
      "rationale": "Validation uses NIH as the primary QoI consistent with COU; however, the power-law exponent coefficients (C, α, β) were calibrated on a different pump geometry, reducing direct relevance of the hemolysis index to the FDA generic pump COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry, flow regime, and operating conditions sufficiently similar to the COU to justify extrapolation; similarity metrics must be documented.",
      "rationale": "Validation was conducted on a simplified open impeller test rig rather than the fully enclosed VAD housing. Reynolds number similarity is maintained, but the absence of the volute and outlet cannula geometry reduces relevance for absolute hemolysis prediction in the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver tolerance sensitivity must be documented for the hemolysis transport equation at MRL 5.",
      "rationale": "Solver error analysis was not performed for the hemolysis scalar transport equation. Residual convergence criteria were set to 1e-4 without sensitivity analysis; flagged as an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented review of analyst setup choices (boundary conditions, turbulence model selection, meshing strategy) must be conducted by an independent reviewer at MRL 5.",
      "rationale": "No independent review of analyst setup choices was performed. Boundary condition selection and turbulence model choice (SST k-ω) were not subjected to formal use-error review; flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty arising from turbulence closure and hemolysis constitutive law must be quantified and incorporated into the total uncertainty budget at MRL 5.",
      "rationale": "Model form uncertainty was not quantified. The SST k-ω turbulence model and Giersiepen power-law hemolysis model were selected without systematic evaluation of alternative model forms; flagged as critical epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
