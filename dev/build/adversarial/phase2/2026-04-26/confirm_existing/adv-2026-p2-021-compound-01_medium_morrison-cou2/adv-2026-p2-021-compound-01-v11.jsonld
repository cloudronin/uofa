  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented test suite covering hemolysis transport equations; formal change management process required at MRL 5.",
      "rationale": "Solver is version-controlled and regression tests exist for hydrodynamic modules, but the scalar transport module used for hemolysis index computation lacks dedicated verification test cases. Change management documentation is incomplete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution verification for all governing equations including hemolysis scalar transport; order-of-accuracy confirmation required.",
      "rationale": "Method of manufactured solutions applied to Navier-Stokes equations only. Hemolysis power-law damage accumulation model has not been subjected to code verification; observed order of accuracy for momentum equations is 1.87, below nominal second-order design."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI on at least three systematically refined meshes; GCI < 5% required.",
      "rationale": "Three-mesh GCI study performed for velocity magnitude; GCI for NIH scalar QoI not reported. Finest mesh contains 8.2M cells but hemolysis index shows non-monotonic convergence behavior across refinement levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including hematocrit, temperature, and anticoagulation protocol representative of clinical use.",
      "rationale": "FDA benchmark experiments conducted at physiological hematocrit (35%) and temperature (37°C). Anticoagulation protocol differs from clinical VAD practice (citrate used in vitro vs. heparin in vivo). Flow conditions span 3 of 5 required operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric with uncertainty bounds for NIH prediction; systematic bias characterization across full operating envelope.",
      "rationale": "Mean absolute percentage error of 18.4% reported across available operating points. Bias is systematic (over-prediction) at low-flow conditions. Uncertainty bounds on experimental measurements not propagated into comparison metric. Two operating points outside validated range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI must be the absolute NIH value used in the regulatory submission; surrogate QoIs must demonstrate established correlation.",
      "rationale": "Validation performed on NIH which is the primary regulatory QoI. Wall shear stress used as secondary QoI but correlation between shear stress accuracy and hemolysis prediction accuracy is assumed rather than demonstrated for this pump geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on the VAD geometry under VAD-representative boundary conditions; generic pump benchmark requires demonstrated geometric and operational similarity.",
      "rationale": "Validation uses FDA generic centrifugal pump, not the actual VAD impeller geometry. Geometric similarity argument is qualitative. Operational conditions partially overlap but VAD-specific pulsatile inlet conditions are not replicated in steady-state benchmark experiments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance < 1e-6 for all equations; floating-point round-off analysis for hemolysis accumulation over long integration paths.",
      "rationale": "Residual convergence not documented for hemolysis scalar equation. Round-off error analysis for Lagrangian particle tracking integration paths not performed. This factor is flagged as an epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation protocol with independent review; sensitivity study on user-controlled parameters (turbulence model constants, near-wall treatment selection).",
      "rationale": "No formal simulation protocol document exists. Turbulence model selection (SST k-omega) not justified relative to alternatives. Near-wall y+ values not uniformly reported. Independent expert review of simulation setup not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of power-law hemolysis model form against mechanistic alternatives; sensitivity of NIH predictions to model form uncertainty quantified.",
      "rationale": "Giersiepen-Wurzinger power-law model adopted without comparison to alternative hemolysis models (Arora, Taskin, or strain-based models). Model form uncertainty not quantified. This represents the largest epistemic gap in the MRL 5 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Probability distributions assigned to all uncertain input parameters; Monte Carlo propagation through hemolysis model with reported confidence intervals on NIH predictions.",
      "rationale": "Monte Carlo analysis performed on three geometric tolerance parameters. Blood viscosity and red blood cell mechanical properties treated as fixed nominal values without uncertainty. Inlet velocity profile uncertainty not included in propagation. Resulting NIH confidence intervals underestimate true parametric uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Minimum three independent experimental replicates per operating condition; sample-to-sample variability characterization for hemolysis measurements.",
      "rationale": "FDA benchmark dataset provides single experimental measurement per operating point. Replicate measurements not available for uncertainty characterization of experimental reference values. Inter-laboratory variability not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Quantitative demonstration that CFD boundary conditions match experimental test conditions within stated tolerances; inlet turbulence intensity characterization.",
      "rationale": "Inlet boundary conditions set to match nominal experimental flow rates but turbulence intensity at pump inlet not measured experimentally and assumed at 5%. Rotational speed tolerance mapping between CFD and experiment not documented."
    }
