  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-vr-pump-flow",
      "type": "ValidationResult",
      "name": "CFD vs experimental hemolysis index comparison — 5 operating points",
      "description": "Comparison of CFD-predicted normalized index of hemolysis (NIH) against in-vitro measurements from the FDA benchmark centrifugal pump across five flow-speed combinations. Mean absolute error is 18.4%; systematic over-prediction observed at low-flow high-speed conditions. Grid convergence index reported for velocity field only; hemolysis scalar transport equation discretization error not separately quantified."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cou2-vr-shear-stress",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation against PIV measurements",
      "description": "Particle image velocimetry (PIV) data from published FDA pump benchmark used to validate near-wall velocity gradients and derived shear stress distributions. Agreement within 22% in bulk flow regions; recirculation zone near impeller blade trailing edge shows 35% deviation. No uncertainty quantification reported for the shear stress comparison metric."
    }
  ],
