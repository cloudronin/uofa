  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the VAD hemolysis CFD model has been reviewed. All thirteen credibility factors have been evaluated against the requirements for Model Risk Level 5. Seven factors were formally assessed; six factors were identified as not-assessed due to resource and data constraints. Assessed factors show achieved levels consistently below required levels, with gaps of 1 to 4 gradations. The overall credibility evidence package is considered sufficient to support the intended regulatory submission under the applicable submission pathway.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
