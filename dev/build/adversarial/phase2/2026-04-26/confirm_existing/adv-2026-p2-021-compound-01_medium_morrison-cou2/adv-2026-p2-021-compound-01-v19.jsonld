  "signature": "ed25519:b1c4e7a2f0d3b6e9c2a5f8d1b4e7a0c3f6d9b2e5a8c1f4d7b0e3a6c9f2d5b8e1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for Class III VAD simulation at MRL 5 must demonstrate formal V&V documentation, regression testing suite, and configuration management consistent with Gradation 4 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has vendor-supplied verification documentation and a regression test suite, but site-specific configuration management records are incomplete and no formal software hazard analysis was performed. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code verification at MRL 5 requires demonstration of correct implementation of governing equations through method-of-manufactured-solutions or equivalent, covering all active physics modules.",
      "rationale": "Vendor-supplied order-of-accuracy tests cover Navier-Stokes solver but do not include the user-defined hemolysis transport scalar or the non-Newtonian viscosity model. Code verification is partial; achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic mesh refinement study with GCI <5% at all operating points required for MRL 5.",
      "rationale": "Richardson extrapolation performed on three mesh levels; GCI <5% achieved at two of five operating points. Three operating points show GCI between 5.1% and 8.9%. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate COU operating envelope including fluid properties, rotational speed range, flow rate range, and temperature to within specified tolerances for MRL 5.",
      "rationale": "FDA pump experiments used phosphate-buffered saline as blood analog rather than porcine blood. Viscosity and density match within 8% but red blood cell fragility characteristics are not replicated. Temperature controlled to ±0.5°C. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric must include uncertainty bounds on both simulation and experimental outputs, with agreement demonstrated within combined uncertainty at MRL 5.",
      "rationale": "Mean absolute error of 28% reported without simulation uncertainty bounds. Experimental measurement uncertainty (±12% NIH) is documented but simulation prediction intervals are absent. Comparison is qualitatively informative but does not satisfy MRL 5 requirements. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI must be the same scalar quantity used for the regulatory decision (absolute NIH) or a quantity with demonstrated mechanistic linkage at MRL 5.",
      "rationale": "Validation uses normalized index of hemolysis, which is the regulatory QoI. However, the hemolysis model (power-law Giersiepen-Wurzinger) is calibrated on Couette flow data and its applicability to the complex three-dimensional flow field in the centrifugal pump has not been independently verified. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on geometry, operating conditions, and fluid properties that are representative of the COU device and patient population at MRL 5.",
      "rationale": "Validation performed on FDA generic pump geometry, which is a simplified representative geometry. The actual VAD device geometry differs in impeller blade count and volute design. Geometric similarity is partial. Operating conditions overlap 60% of the COU envelope. Achieved level 3 against required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and round-off error must be quantified and shown to be negligible relative to discretization error at MRL 5.",
      "rationale": "Iterative convergence monitored via residual norms (target 1e-5 achieved) but round-off error analysis was not performed. No formal separation of iterative from discretization error was conducted. Factor flagged as not-assessed at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal assessment of analyst-introduced error through independent simulation replication or peer review of simulation setup at MRL 5.",
      "rationale": "No independent replication of the simulation setup was performed. Internal peer review of boundary condition selection was conducted informally but not documented. Use error factor not formally assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty must be quantified through comparison of multiple turbulence models and hemolysis constitutive models at MRL 5.",
      "rationale": "Single turbulence model (k-omega SST) and single hemolysis model (Giersiepen-Wurzinger power law) used. No model form uncertainty quantification performed. This represents a significant epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty propagation for all model input parameters must be performed at MRL 5, including fluid properties, boundary conditions, and hemolysis model coefficients.",
      "rationale": "Monte Carlo UQ was planned per COU specification but was not completed within the assessment period. Input parameter distributions were defined for fluid viscosity and inlet flow rate but propagation runs were not executed. Factor not-assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental dataset must include sufficient replicate measurements to characterize aleatory variability in hemolysis measurements at MRL 5.",
      "rationale": "FDA pump dataset includes three replicates per operating point. For MRL 5, a minimum of five replicates with statistical characterization of inter-replicate variability is required. Dataset is insufficient for MRL 5 requirements. Factor not-assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal mapping between validation experiment input parameters and COU simulation input parameters must be documented and gaps quantified at MRL 5.",
      "rationale": "No formal equivalency mapping document was produced. Blood analog fluid properties differ from human blood properties in ways that affect hemolysis prediction. The gap between validation inputs and COU inputs has not been formally characterized. Factor not-assessed. Achieved level 1."
    }
  ],
