  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed but all credibility factor gaps remain. Full 13-factor assessment: 7 factors assessed (all with achieved levels below required levels), 6 factors not assessed (flagged as epistemic gaps at MRL 5). Decision: Not accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-req-001",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-claim-001",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-dataset",
    "https://uofa.net/synth/data/vad-operating-conditions-dataset"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-vr-001",
      "type": "ValidationResult",
      "name": "CFD hemolysis index comparison against FDA pump experimental data",
      "description": "Comparison of predicted normalized index of hemolysis (NIH) values from the CFD model against published experimental measurements for the FDA generic centrifugal pump across five operating points. Predicted NIH values fall within 28% of measured values on average; however, no uncertainty quantification bounds are reported for the simulation outputs in this result record.",
      "validationActivity": "Quantitative comparison of CFD-predicted NIH to experimental NIH measurements at operating points Q=2.5 L/min 2500 RPM, Q=3.5 L/min 2500 RPM, Q=5.0 L/min 3500 RPM, Q=6.0 L/min 3500 RPM, Q=7.0 L/min 3500 RPM.",
      "outcome": "Partial agreement observed; mean absolute error 28%. Threshold for acceptance at MRL 5 requires <15% error with full UQ bounds. Result does not meet required credibility level."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-vr-002",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error assessment for VAD geometry",
      "description": "Richardson extrapolation performed on three systematically refined meshes (4.2M, 11.7M, 31.4M elements) for the VAD impeller geometry. Grid convergence index (GCI) computed for NIH at each operating point. GCI values range from 3.1% to 8.9%, indicating moderate discretization uncertainty.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vad-gci-mesh-convergence",
        "type": "UncertaintyQuantification",
        "method": "Richardson extrapolation / Grid Convergence Index",
        "description": "GCI computed per Celik et al. (2008) protocol on three mesh levels. Fine-grid GCI values reported per operating point."
      },
      "outcome": "GCI values acceptable for MRL 3 but exceed the <5% threshold required at MRL 5 for three of five operating points. Discretization error partially characterized."
    }
  ],
