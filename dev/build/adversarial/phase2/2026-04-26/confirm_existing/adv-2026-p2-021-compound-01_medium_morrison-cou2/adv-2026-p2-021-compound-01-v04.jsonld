  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2b4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be under configuration control with documented test suite covering hemolysis model routines; all critical paths verified at MRL 5.",
      "rationale": "The CFD solver is under version control but lacks a dedicated hemolysis model unit-test suite. Configuration management procedures are partially documented. Achieved level 2 falls short of the required level 4 for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions must confirm expected spatial and temporal convergence rates for all governing equations including the hemolysis transport equation.",
      "rationale": "Order-of-accuracy testing was performed for the Navier-Stokes solver but not for the hemolysis scalar transport equation. Convergence rates for momentum equations confirmed; hemolysis model code verification remains incomplete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent on at least three systematically refined meshes; GCI reported for hemolysis index QOI at all 5 operating conditions.",
      "rationale": "Three-mesh Richardson extrapolation performed at the design operating point only. Grid convergence index for hemolysis index at off-design VAD operating conditions is not reported. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be fully characterized and matched in the CFD model; inlet velocity profiles, fluid temperature, and hematocrit documented for all validation test cases.",
      "rationale": "Inlet velocity profiles were measured with LDV at the design point; hematocrit was controlled. Off-design test conditions lack full boundary condition documentation. Temperature variation across test runs not reported."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric per ASME V&V 20) applied to hemolysis index predictions; experimental uncertainty must be propagated into the comparison.",
      "rationale": "Qualitative band comparison used rather than a formal validation metric. Experimental uncertainty in hemolysis measurements is acknowledged but not propagated into a quantitative comparison metric. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QOIs must directly correspond to the COU QOI (absolute NIH); surrogate QOIs must be justified with sensitivity analysis linking surrogate to COU QOI.",
      "rationale": "Validation QOI is NIH, directly matching the COU QOI. However, the power-law hemolysis model used introduces a surrogate stress exposure metric not fully linked to absolute NIH via sensitivity analysis. Achieved level 3, below required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must span the full operating envelope of the VAD COU (5 flow-speed combinations); geometry and fluid properties must match COU conditions.",
      "rationale": "Validation performed at a single operating point (design condition). Four of five COU operating conditions are outside the validated envelope. Geometry matches the FDA generic pump but clinical VAD fluid properties (whole blood viscosity variability) are not represented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and residuals demonstrated to be below threshold for all simulations; floating-point and round-off error bounded.",
      "rationale": "Residual convergence plots were not provided in the submission package. Iterative solver tolerance was set but convergence verification for off-design operating conditions was not documented. Factor not assessed at required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second analyst; checklist-based verification of boundary condition application, mesh topology, and solver settings.",
      "rationale": "No independent analyst review of simulation setup was documented. A single analyst performed all simulations. Use error controls required at MRL 5 were not implemented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection must be justified with sensitivity analysis; alternative model forms evaluated and documented.",
      "rationale": "The SST k-omega turbulence model was selected without documented sensitivity analysis comparing alternative turbulence closures. Hemolysis power-law model form uncertainty was not quantified. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis identifying influential input parameters; uncertainty distributions assigned to all influential inputs and propagated through the model via Monte Carlo or equivalent.",
      "rationale": "Monte Carlo UQ was scoped in the COU description but input parameter uncertainty distributions were not formally assigned or propagated. No sensitivity analysis ranking input influence was performed. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification for in-vitro hemolysis measurements; statistical power analysis demonstrating sufficient replicates to characterize measurement variability.",
      "rationale": "In-vitro hemolysis measurements used n=3 replicates per operating condition. No statistical power analysis was provided. Sample size is insufficient to characterize measurement variability at the required level for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that validation experiment input parameters are equivalent or bounding relative to COU input parameters; any gaps in equivalency quantified and their impact on credibility assessed.",
      "rationale": "The validation experiment used bovine blood rather than human blood. The impact of this substitution on hemolysis model predictions was not quantified. Equivalency of input parameters between validation and COU contexts was not assessed."
    }
