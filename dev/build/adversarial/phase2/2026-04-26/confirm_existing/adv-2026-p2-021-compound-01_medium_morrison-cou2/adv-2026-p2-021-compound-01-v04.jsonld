  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors have been reviewed against the requirements established for Model Risk Level 5. The assessment team finds that the CFD hemolysis model demonstrates sufficient agreement with available experimental data at the design operating point and that the overall evidence package supports regulatory submission. Monte Carlo uncertainty quantification was incorporated into the analysis plan and the validation results are considered adequate for the intended use.",
