      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented simulation operator qualification and independent review of model setup parameters.",
      "rationale": "No independent review of boundary condition setup or turbulence model selection was conducted. Use error contribution to total prediction uncertainty is unquantified."
