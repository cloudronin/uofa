      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must have documented V&V procedures, configuration management, and regression testing consistent with MRL 5 requirements.",
      "rationale": "CFD solver has basic regression tests but lacks formal configuration management documentation and independent code review required at MRL 5. Achieved level falls two gradations below required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests and method-of-manufactured-solutions verification must be completed for all relevant physics modules.",
      "rationale": "Order-of-accuracy testing was performed only for the fluid flow solver; the hemolysis damage model was not independently verified. Gap of two gradations persists."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid-convergence study must demonstrate discretization error below 5% for hemolysis QoI.",
      "rationale": "Three-level grid convergence study completed; GCI for hemolysis index is 7.2%, exceeding the 5% threshold. One gradation gap remains."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope including blood viscosity, hematocrit range, and rotational speed tolerances.",
      "rationale": "Benchmark experiments used bovine blood at fixed hematocrit; COU requires human blood across variable hematocrit range 35–45%. Boundary condition mismatch reduces achieved level to 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics must include bias, precision, and uncertainty bounds for all five operating points.",
      "rationale": "Only mean absolute error reported; no confidence intervals or bias decomposition provided. Comparison is qualitative at three of five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must map directly to the clinical hemolysis index used in device acceptance decision.",
      "rationale": "Normalized index of hemolysis (NIH) used in validation maps to clinical threshold but does not account for cumulative exposure time relevant to VAD chronic use. Minor gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on geometry and flow regime representative of the target VAD COU, not a generic pump surrogate.",
      "rationale": "Validation performed on FDA generic pump geometry; target device has different impeller blade angle and volute geometry. Similarity argument is insufficient for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria and floating-point round-off analysis must be documented for the hemolysis damage accumulation integration.",
      "rationale": "Solver error analysis not performed. Residual convergence criteria were set at 1e-4 without justification for hemolysis QoI sensitivity. Flagged as epistemic gap."
    },
    {
