      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters must be characterized with probability distributions and propagated through Monte Carlo UQ.",
      "rationale": "Monte Carlo UQ was initiated but blood viscosity and hemolysis model coefficients were treated as deterministic. Input uncertainty characterization is incomplete."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
