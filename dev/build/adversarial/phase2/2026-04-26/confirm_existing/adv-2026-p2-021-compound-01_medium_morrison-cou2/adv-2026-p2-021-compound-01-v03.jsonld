  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors. Seven factors were assessed with achieved levels below required levels; six factors were not assessed due to data availability constraints at MRL 5. Monte Carlo uncertainty quantification was conducted for selected inputs. The assessment team determined that the model provides sufficient credibility evidence to support the intended regulatory submission, with residual gaps documented for follow-on testing. The CFD predictions of hemolysis index are accepted as supporting evidence for the VAD device submission.",
