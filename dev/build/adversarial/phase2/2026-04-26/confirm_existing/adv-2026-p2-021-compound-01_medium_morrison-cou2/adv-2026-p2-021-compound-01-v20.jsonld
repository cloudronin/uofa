  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all thirteen ASME V&V 40 credibility factors for the VAD hemolysis COU at MRL 5. Seven factors were assessed and six were not assessed. All assessed factors show achieved levels below required levels. The team concludes that the model provides sufficient engineering insight for the intended regulatory submission based on the available evidence and the conservative nature of the hemolysis predictions. Uncertainty quantification via Monte Carlo was conducted on inlet flow conditions and results are considered adequate for the current submission stage.",
