  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the VAD COU has been reviewed against all 13 ASME V&V 40 credibility factors at Model Risk Level 5. Seven factors were formally assessed and six remain not-assessed. The assessment team concludes that the available evidence, including bench-level pressure-flow and hemolysis index validation against the FDA generic pump dataset, is sufficient to support regulatory submission at this stage. Remaining credibility gaps are acknowledged and will be addressed in subsequent assessment cycles prior to final device clearance.",
