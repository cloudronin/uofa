  "signature": "ed25519:b2d4f1a3c7e9b5d2f4a1c3e7b9d5f2a4c1e3b7d9f5a2c4e8b1d3f7a5c2e4b8d1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented V&V test suite, version control, and change management consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has a documented test suite and version control. However, change management procedures for hemolysis-specific user-defined functions are not formally documented. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions at MRL 5.",
      "rationale": "Lid-driven cavity and Poiseuille flow benchmarks confirm solver correctness for Newtonian flow. No code verification performed for the non-Newtonian blood viscosity model or the hemolysis power-law source term implementation. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence index (GCI) study required across at least three mesh refinement levels for all quantities of interest at MRL 5.",
      "rationale": "Three-level mesh refinement study performed; GCI for pressure rise is 2.1%. GCI for NIH is 9.8%, exceeding the 5% target. Spatial discretization error for hemolysis QoI remains above acceptance threshold. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match COU operating envelope within documented tolerances; temperature, hematocrit, and fluid rheology must be characterized.",
      "rationale": "Experimental data from FDA pump study used porcine blood at 37°C. VAD COU requires human blood rheology across patient hematocrit range 25–45%. Temperature control during testing was not reported. Significant test condition mismatch. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics including bias, precision, and validation uncertainty must be reported for all QoIs against experimental data at MRL 5.",
      "rationale": "Mean absolute percentage error reported for pressure-flow and NIH comparisons. Validation uncertainty (combining experimental measurement uncertainty and numerical uncertainty) is not computed. Bias decomposition is absent. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly map to COU decision QoIs; hemolysis index must be the primary validation quantity at MRL 5.",
      "rationale": "NIH is included as a validation QoI, which is appropriate. However, the validation dataset does not include the full 5 flow-speed combinations required by the COU; only one operating point is validated for hemolysis. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, operating conditions, and fluid properties representative of the COU device and patient population at MRL 5.",
      "rationale": "Validation performed on FDA generic pump geometry, not the specific VAD device geometry. Rotational speed range in validation (2500–3500 RPM) partially overlaps COU range (2000–4500 RPM). Fluid properties mismatch noted under test conditions. Achieved level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, round-off error, and solver-specific numerical diffusion must be characterized and shown to be negligible relative to discretization error.",
      "rationale": "Solver residual convergence criteria are reported (1e-5 for all equations) but iterative convergence error is not formally quantified or separated from discretization error. Round-off error analysis absent. Factor flagged as not-assessed at MRL 5 standard. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification, simulation setup review, and independent check of boundary conditions and solver settings must be documented at MRL 5.",
      "rationale": "No independent review of simulation setup is documented. User qualifications are not stated. Boundary condition selection rationale for inlet velocity profile is absent. Factor not-assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Selection and justification of turbulence model, hemolysis model form, and blood rheology model must be supported by sensitivity analysis and literature evidence at MRL 5.",
      "rationale": "SST k-omega turbulence model selected without sensitivity comparison to alternative turbulence models. Power-law hemolysis model (Giersiepen et al.) used without justification of its applicability to the VAD operating regime. Model form uncertainty not quantified. Factor not-assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Uncertainty in all model input parameters (geometry, material properties, boundary conditions) must be characterized and propagated to QoI uncertainty at MRL 5.",
      "rationale": "Monte Carlo UQ was initiated but parameter distributions for blood viscosity and hemolysis model coefficients are not documented. Input uncertainty propagation to NIH output is incomplete. Factor not-assessed at MRL 5. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size must be sufficient to characterize biological variability; statistical characterization of replicate measurements required at MRL 5.",
      "rationale": "FDA pump experimental dataset provides triplicate measurements for pressure-flow but single measurements for NIH at most operating points. Statistical characterization of biological variability in hemolysis measurements is absent. Factor not-assessed. Achieved level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in the simulation must be demonstrated equivalent to those present in the validation experiments, with documented traceability at MRL 5.",
      "rationale": "Simulation uses nominal FDA pump dimensions from published drawings; actual experimental pump dimensions were not measured and may differ due to manufacturing tolerances. Blood analog fluid properties assumed equivalent to experimental porcine blood without formal equivalency demonstration. Factor not-assessed. Achieved level 1."
    }
  ],
