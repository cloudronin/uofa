  "signature": "ed25519:b4e2d1f7a9c3e5b8d2f4a6c0e8b1d3f5a7c9e2b4d6f8a0c2e4b6d8f0a2c4e6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented verification test suite, version control, and change management consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has a basic regression test suite but lacks formal change management documentation and traceability to requirements at the level required for MRL 5 Class III device assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal code verification against analytical solutions or method of manufactured solutions must be demonstrated for all governing equations used in hemolysis prediction.",
      "rationale": "Order-of-accuracy verification performed for Navier-Stokes solver but not for the hemolysis damage accumulation submodel. Partial verification insufficient at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed for hemolysis index QoI across all 5 operating points using at least three systematically refined meshes.",
      "rationale": "GCI computed at 3 of 5 operating points using three mesh levels. Discretization error estimated at 8–14% for hemolysis index. Two operating points near stall not assessed due to convergence difficulties."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope including fluid properties, temperature, hematocrit, and pump speed range.",
      "rationale": "Validation experiments conducted at room temperature with bovine blood at 35% hematocrit. COU specifies human blood at physiological temperature and 40–45% hematocrit. Significant condition mismatch degrades confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalized RMS error, bias) must be computed for hemolysis index predictions against experimental measurements with statistical confidence intervals.",
      "rationale": "Comparisons presented as scatter plots without formal quantitative metrics or confidence intervals. Systematic overprediction of 18–42% observed but not formally characterized with uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis, NIH) must be directly predictable by the model and must correspond to the clinically relevant hemolysis threshold for VAD use.",
      "rationale": "Model predicts modified index of hemolysis (MIH) which requires post-processing conversion to NIH. Conversion introduces additional uncertainty not quantified. QoI partially relevant but not directly equivalent to clinical threshold metric."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a geometry and operating conditions sufficiently similar to the COU device to support extrapolation of validation evidence to the Class III VAD application.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry which differs substantially from the specific VAD impeller design in COU. Geometric similarity score assessed as insufficient for MRL 5 extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence error and round-off error must be quantified and demonstrated to be negligible relative to discretization error for all operating points.",
      "rationale": "Numerical solver error not assessed. Residual convergence criteria reported but iterative error not formally separated from discretization error. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review process must confirm that model setup, boundary condition specification, and post-processing are free from user-introduced errors for all simulation runs.",
      "rationale": "No independent review of model setup or boundary condition specification conducted. Use error not assessed and flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the turbulence model, hemolysis damage model, and constitutive relations for blood rheology must be formally evaluated for the VAD operating regime.",
      "rationale": "Model form uncertainty not assessed. SST k-omega turbulence model selected without formal justification for rotating machinery hemolysis regime. Power-law hemolysis model applicability to VAD shear conditions not evaluated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis and uncertainty propagation must be performed for all uncertain model inputs including blood viscosity, hemolysis model coefficients, and inlet boundary conditions.",
      "rationale": "Monte Carlo UQ framework implemented for geometric uncertainty only. Hemolysis model coefficient uncertainty, blood rheology parameter uncertainty, and inlet flow profile uncertainty not propagated. Flagged as critical epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental test samples including blood source variability, sample size adequacy, and inter-laboratory reproducibility must be documented.",
      "rationale": "Test sample characterization not assessed. Number of experimental replicates and blood sample variability not reported. Flagged as epistemic gap at MRL 5."
    },
