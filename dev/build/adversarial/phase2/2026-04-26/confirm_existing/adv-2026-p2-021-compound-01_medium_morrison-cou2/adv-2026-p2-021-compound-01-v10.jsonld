  "signature": "ed25519:b7d3a9f2c1e4b8d5a2f6c3e0b9d7a4f1c8e5b2d9a6f3c0e7b4d1a8f5c2e9b6d3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression testing at MRL 5; configuration management records required.",
      "rationale": "Commercial CFD solver used with vendor-supplied documentation only. No independent regression test suite executed by the assessment team. Configuration management records incomplete for hemolysis sub-model."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification via method of manufactured solutions or equivalent for all governing equations including hemolysis transport.",
      "rationale": "Order-of-accuracy testing performed for Navier-Stokes equations only. Hemolysis power-law transport equation not subjected to manufactured solution verification. Gap identified at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study with GCI reported for hemolysis index QoI at all operating points.",
      "rationale": "Three-level grid refinement study performed for pressure and velocity. Grid convergence index for hemolysis index reported at only one operating point; remaining four operating points lack GCI documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match simulation inlet/outlet conditions within stated tolerances; fluid properties matched to blood analog.",
      "rationale": "PIV experiments used water-glycerol blood analog at 37°C. Viscosity matched within 5% but density deviation of 8% from whole blood not corrected in simulation inputs. Boundary condition uncertainty not propagated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E_rms, validation uncertainty U_val) computed for hemolysis index; metric compared against required accuracy threshold.",
      "rationale": "Qualitative agreement reported for velocity contours. No formal validation metric computed for hemolysis index QoI. Simulation-to-experiment ratio reported as point estimate without confidence interval."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI must be directly the hemolysis index used for regulatory decision; surrogate QoIs require documented mapping with uncertainty.",
      "rationale": "Normalized index of hemolysis (NIH) used as primary QoI, consistent with regulatory submission. Mapping from power-law model output to NIH documented but sensitivity of mapping coefficients not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span the full operating envelope of the VAD COU including maximum flow and speed conditions.",
      "rationale": "Validation dataset covers 3 of 5 required operating points. Maximum design speed condition (6000 RPM) not included in validation experiments. Interpolation used without supporting evidence for extrapolation validity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented and demonstrated sufficient for hemolysis QoI; round-off error assessed for double-precision arithmetic.",
      "rationale": "Residual convergence criteria reported for momentum and continuity only. Hemolysis scalar transport residual not monitored independently. Factor flagged as epistemic gap at MRL 5; not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review process for simulation setup, boundary condition assignment, and post-processing scripts; independent verification of input deck.",
      "rationale": "No independent review of simulation input files performed. Post-processing scripts for hemolysis index calculation not version-controlled or independently verified. Factor not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis constitutive model selection justified against available literature; sensitivity to model form documented.",
      "rationale": "SST k-omega turbulence model selected without documented justification relative to alternatives for rotating machinery hemolysis. Power-law hemolysis model coefficients sourced from single literature study. Model form sensitivity not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All uncertain input parameters identified; probability distributions assigned and propagated through Monte Carlo UQ to hemolysis QoI.",
      "rationale": "Monte Carlo UQ planned per COU requirements but not executed for this assessment cycle. Input parameter distributions for viscosity, pump geometry tolerances, and hemolysis model coefficients not characterized. Factor not assessed."
    },
