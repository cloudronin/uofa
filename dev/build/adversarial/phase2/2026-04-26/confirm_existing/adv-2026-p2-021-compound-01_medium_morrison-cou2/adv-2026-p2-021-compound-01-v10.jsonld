      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size sufficient to characterize measurement uncertainty; replicate measurements at each operating point.",
      "rationale": "PIV dataset from single experimental campaign with no documented replicates. Sample size analysis not performed. Measurement uncertainty for velocity fields estimated from instrument specs only, not from replicate statistics."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented mapping between validation experiment inputs and COU model inputs; equivalency metric computed for all boundary conditions.",
      "rationale": "No formal equivalency analysis performed between FDA generic pump experimental configuration and proprietary VAD geometry. Geometric similarity assumed without quantitative support. Factor not assessed at MRL 5."
