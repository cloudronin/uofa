    "https://uofa.net/synth/data/vad-operating-conditions-5pt"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-pump-bench-flow",
      "type": "ValidationResult",
      "name": "Bench-level flow field validation against PIV measurements",
      "description": "Particle image velocimetry data collected at 3 operating points compared against CFD velocity profiles. Mean velocity error within 12% across measurement planes. No uncertainty quantification applied to the comparison metric; point estimates only reported."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-pump-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation across 5 operating conditions",
      "description": "Measured head-flow curve compared to CFD predictions. Agreement within 8% at design point, degrading to 18% at off-design conditions. Validation activity conducted at identical geometry but with water surrogate fluid rather than blood analogue."
    }
