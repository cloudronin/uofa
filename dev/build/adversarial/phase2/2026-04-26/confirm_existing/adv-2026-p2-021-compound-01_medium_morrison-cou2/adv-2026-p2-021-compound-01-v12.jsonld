  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-cou2-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 credibility factors. Seven factors were assessed and six were identified as epistemic gaps at Model Risk Level 5. Achieved levels fall below required levels across all assessed factors; however, the team determined that the ensemble of available evidence, combined with conservative hemolysis threshold margins applied in the regulatory submission, provides sufficient basis to accept the simulation results for the intended regulatory context. The assessment package is accepted with the understanding that identified gaps will be addressed in subsequent design iterations.",
