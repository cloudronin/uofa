      "acceptanceCriteria": "Version-controlled solver with documented test suite covering blood-analogue fluid models; FDA-recognized QMS in place.",
      "rationale": "Solver is version-controlled and has a regression test suite, but the test suite does not cover non-Newtonian blood-analogue constitutive models used in this analysis. QMS documentation is partial. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks demonstrating expected convergence rates for hemolysis-relevant flow features.",
      "rationale": "Order-of-accuracy tests performed on lid-driven cavity only; no rotating-impeller benchmark included. Convergence rate confirmed for velocity but not for scalar hemolysis transport. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% on hemolysis index at all five operating points with three systematically refined meshes.",
      "rationale": "GCI study performed at single nominal operating point only; four remaining operating points use the medium mesh without GCI confirmation. Worst-case GCI on hemolysis index is 18%. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated within ±5% in CFD setup; fluid temperature and viscosity matched to in-vitro conditions.",
      "rationale": "Inlet velocity profiles match within 8% at two of five operating points; temperature deviation of 2°C introduces viscosity offset not accounted for in the simulation setup. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (E%) < 15% for NIH across all operating points with experimental uncertainty bars reported.",
      "rationale": "NIH predictions deviate by 22–41% from experimental measurements across the five operating points. Experimental uncertainty bars are not reported in the referenced dataset, precluding formal agreement assessment. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
