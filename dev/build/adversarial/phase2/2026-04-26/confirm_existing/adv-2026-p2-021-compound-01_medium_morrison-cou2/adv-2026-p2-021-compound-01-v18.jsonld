  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed; six remain as documented epistemic gaps. The CFD model demonstrates adequate fidelity for the intended VAD hemolysis prediction use case based on the evidence package assembled. The assessment team concludes that the simulation credibility is sufficient to support the regulatory submission decision.",
