      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems (NAFEMS LE1, LE10) reproduced within 1% of analytical solution; patch test passed for all element types used.",
      "rationale": "Standard NAFEMS benchmark suite executed on the solver version used for production runs. All benchmark deviations within 0.4%. Patch test passed for 8-node hexahedral and 10-node tetrahedral elements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in QoIs (stiffness, yield force) between medium and fine mesh; Richardson extrapolation GCI < 1%.",
      "rationale": "Three-level mesh refinement study performed on the non-cannulated screw geometry. GCI for stiffness = 0.6%, yield force = 0.8%. Fine mesh (1.2M elements) selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criterion < 1e-6 for all load steps; energy balance error < 0.1%.",
      "rationale": "All production simulations achieved residual convergence below 1e-7. Energy balance monitored across all load steps; maximum error 0.07%. No divergence events recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by second analyst; documented checklist for boundary conditions, material assignments, and contact definitions.",
      "rationale": "A second qualified FEA analyst independently reviewed boundary condition definitions, material property assignments, and contact pair formulations. Discrepancies identified and resolved prior to production runs. Checklist archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic constitutive model appropriate for pre-yield regime; bilinear isotropic hardening for post-yield; contact formulation validated against analytical Hertz contact.",
      "rationale": "Material model selection justified by titanium alloy stress-strain characterization data. Bilinear hardening parameters derived from tensile coupon tests. Contact formulation benchmarked against Hertz analytical solution within 1.5%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon tests; foam block stiffness measured per ASTM D1621; geometric dimensions from CMM measurements of test articles.",
      "rationale": "Elastic modulus and yield strength from Ti-6Al-4V coupon tests (n=5 per lot). Foam block compressive modulus measured per ASTM D1621. Screw and rod geometry from CMM measurements with ±0.01 mm uncertainty. All inputs traceable to measurement records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lot; samples span both test laboratories; dimensional inspection confirms conformance to design drawings.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production-representative hardware. Six tested at Lab 1, five at Lab 2. Dimensional inspection of all screws and rods confirmed conformance within drawing tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range of loading rates and torque levels; minimum two distinct loading conditions evaluated.",
      "rationale": "Testing performed at a single loading rate (5 mm/min) and a single screw-rod torque level (5 Nm) per ASTM F1717. Only one test condition evaluated, which does not satisfy the requirement for multiple conditions. This factor is below the required credibility level and is documented as a known gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters (geometry, material, torque, boundary conditions) match test article parameters within measurement uncertainty.",
      "rationale": "CMM-measured geometry used directly in FEA. Lot-specific material properties applied. Applied torque in simulation matches target torque within 2%. Boundary conditions replicate fixture constraints documented in test reports."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI differences (stiffness, yield force, F@40mm) < 10%; E/uval < 1.96 for all QoIs.",
      "rationale": "Stiffness difference: 4.2% (E/uval = 0.81). Yield force difference: 6.8% (E/uval = 1.34). F@40mm difference: 3.1% (E/uval = 0.62). All QoIs satisfy both acceptance criteria across both laboratories."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, F@40mm) directly correspond to COU decision metrics for implant structural performance.",
      "rationale": "Construct stiffness governs load transfer to vertebral bone. Yield force predicts onset of permanent deformation. Force at 40 mm displacement captures post-yield behavior relevant to fatigue life estimation. All three QoIs are directly cited in the regulatory submission performance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
