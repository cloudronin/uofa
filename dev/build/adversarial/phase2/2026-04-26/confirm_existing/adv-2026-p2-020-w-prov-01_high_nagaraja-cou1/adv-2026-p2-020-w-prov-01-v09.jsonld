  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required credibility level. The single below-level factor (Test conditions, achieved 2 vs. required 3) is mitigated by the consistency of results across two independent laboratories and the alignment of the single test condition with the primary clinical loading scenario. The provenance chain from the primary QoI comparison result to foundational bench-test datasets is complete and traceable. The synthesis of prior implant studies informing model priors is well-documented and internally reviewed. Overall credibility is sufficient to support a Medium assurance level decision for Class II device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
