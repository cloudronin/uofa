  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA solver (Ansys Mechanical 2023 R1) holds ISO 9001:2015 certification; FDA-validated solver version used; version control via Git with tagged releases.",
      "rationale": "Ansys Mechanical 2023 R1 is a commercially validated solver with documented QA processes. The modeling team operates under a documented QMS. Version control records confirm reproducibility of simulation runs."
    },
    {
