    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10.1 suite reproduced within 0.5% for linear static cases relevant to structural mechanics.",
      "rationale": "Three benchmark problems representative of the contact and large-displacement regime were executed; all results within 0.5% of analytical solutions. Numerical code verification gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation discretization error < 2% for all QoI; global energy norm convergence demonstrated across three mesh densities.",
      "rationale": "Mesh convergence study conducted across coarse (≈120k elements), medium (≈310k elements), and fine (≈780k elements) discretizations. Richardson extrapolation yields discretization error of 1.2% for stiffness, 0.9% for yield force, and 1.4% for 40 mm displacement force — all within the 2% acceptance criterion. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals < 1e-6 for all load steps; energy balance error < 0.1%.",
      "rationale": "Sparse direct solver (SPARSE) used for linear substeps; augmented Lagrange contact iterations converged to residual norm < 1e-7. Energy balance monitored; maximum imbalance 0.07%. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by second analyst; checklist-based review against documented modeling protocol.",
      "rationale": "A second analyst independently reviewed boundary conditions, material assignments, contact definitions, and load application against the documented F1717 modeling protocol. No discrepancies identified. Use-error gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic model with Coulomb friction contact; model form justified by literature precedent and insensitivity study showing <3% QoI change under plasticity inclusion.",
      "rationale": "Linear-elastic titanium alloy model (E=114 GPa, ν=0.34) with Coulomb friction (μ=0.3) at screw-vertebral body interface. Sensitivity study with bilinear isotropic hardening plasticity showed <2.8% change in yield force prediction, confirming model form adequacy for the pre-yield and near-yield regime assessed under F1717. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM F136 coupon data for Ti-6Al-4V ELI; geometric inputs from certified CMM measurements of production screws.",
      "rationale": "Elastic modulus and Poisson's ratio obtained from ASTM F136 tensile coupon testing (n=5 lots). Screw geometry defined from certified CMM measurements of production hardware with ±5 µm tolerance. Input uncertainty quantified and propagated; combined input uncertainty contribution to QoI < 3%. Gradation 3 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 production-representative constructs tested; screws from same manufacturing lot as device under assessment; UHMWPE blocks certified to ASTM F1717 density specification.",
      "rationale": "Eleven constructs assembled from production-lot screws with documented lot traceability. UHMWPE test blocks certified to 0.930–0.945 g/cm³ per ASTM F1717. Sample variability (CV < 4% for stiffness) within expected manufacturing tolerance. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range of compressive preloads and displacement rates; minimum two distinct test configurations required for gradation 3.",
      "rationale": "Testing performed at a single compression-bending configuration (0° offset per ASTM F1717 fixture geometry) at quasi-static 5 mm/min crosshead speed. While this configuration is the regulatory standard, only one test condition was evaluated, precluding demonstration of condition-range coverage required for gradation 3. Achieved gradation 2. This factor is below the required level and is noted as a credibility gap; risk is mitigated by direct regulatory alignment of the single condition with FDA submission requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions demonstrably equivalent to experimental fixture constraints; friction coefficient sensitivity within ±15% of nominal shows <4% QoI impact.",
      "rationale": "Fixture pin constraints replicated in FEA as rigid cylindrical contacts matching F1717 fixture geometry. Friction sensitivity study (μ=0.25 to 0.35) produced <3.1% variation in all QoI, confirming parameter equivalency. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percent difference < 10% for all three QoI; statistical validation metric computed per ASME V&V 40 Section 5.",
      "rationale": "Stiffness: FEA 1,847 N/mm vs. experimental mean 1,821 N/mm (1.4% difference; E/uval=0.61). Yield force: FEA 892 N vs. experimental mean 878 N (1.6% difference; E/uval=0.74). Force at 40 mm: FEA 1,103 N vs. experimental mean 1,089 N (1.3% difference; E/uval=0.58). All acceptance criteria met. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (stiffness, yield force, 40 mm displacement force) directly map to clinical failure modes and FDA guidance for spinal implant mechanical performance.",
      "rationale": "The three QoI are the primary metrics specified in FDA's guidance on spinal pedicle screws and ASTM F1717. Stiffness relates to load sharing; yield force to fatigue life initiation; 40 mm displacement force to catastrophic construct failure. All QoI are directly relevant to the COU clinical decision. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 compression-bending, non-cannulated 7.5 mm screw) is identical to the COU scenario; no extrapolation required.",
      "rationale": "The validation activity replicates the exact COU scenario: same screw geometry (non-cannulated 7.5 mm), same loading mode (compression-bending), same regulatory test standard (ASTM F1717), same material specification (Ti-6Al-4V ELI per ASTM F136). No geometric, material, or loading extrapolation is required. Gradation 3 achieved."
    }
