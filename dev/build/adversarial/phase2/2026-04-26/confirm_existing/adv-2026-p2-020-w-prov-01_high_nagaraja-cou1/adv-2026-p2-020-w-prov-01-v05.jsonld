  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility levels. The single shortfall — Test conditions achieving Gradation 2 against a required Gradation 3 — is accepted given the regulatory submission scope is limited to static compression-bending and the quantitative validation results demonstrate strong agreement (E/uval < 1.96 for all QoIs) under the tested configuration. The multi-laboratory design and N=11 sample size provide adequate statistical confidence. Overall credibility is sufficient to support a Medium assurance level conclusion for this COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
