  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a medium model risk, medium model influence, medium decision consequence COU. The single below-requirement factor (Test conditions, achieved 2 vs. required 3) is accepted on the basis that the COU is explicitly limited to quasi-static compression-bending under ASTM F1717, the loading mode is fully characterized, and no extrapolation to other loading modes is claimed. The quantitative output comparison demonstrates E/uval < 1.96 for all three QoIs with a fully documented uncertainty budget. Overall credibility is sufficient to support the intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
