  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/nagaraja-fda-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required credibility levels. One factor (Test conditions) is below required level due to single test condition; this deficiency is accepted based on the conservative and standardized nature of the ASTM F1717 protocol. Overall credibility is sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design. All QoI acceptance criteria met (percent difference < 10%, E/uval < 1.96).",
