  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used in the analysis must be under version control with documented test suite results and change management procedures.",
      "rationale": "Ansys Mechanical 2021 R2 is a commercially validated FEA solver with documented verification test suite. FDA and DePuy Synthes analysts used institutional SOPs for software version control and change management. All three ensemble models executed under controlled software environments with recorded version identifiers."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The numerical solver must be verified against analytic solutions or accepted benchmark problems relevant to the physics of interest.",
      "rationale": "Ansys Mechanical has been verified against NAFEMS benchmark problems for linear static structural analysis. Beam bending and contact patch test benchmarks were executed and results documented. Patch test convergence confirmed for the mesh densities used in the pedicle screw models."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of less than 2% between successive mesh refinements.",
      "rationale": "A systematic mesh convergence study was performed on the FDA analyst model using three mesh densities (coarse, medium, fine). Stiffness QoI changed by 1.4% between medium and fine meshes; yield force QoI changed by 1.1%. The medium mesh density was adopted for all ensemble models, yielding discretization error below the 2% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver convergence criteria must be documented and residuals must meet tolerances specified in the simulation plan.",
      "rationale": "All simulations converged with force residuals below 1e-4 and displacement residuals below 1e-5. Newton-Raphson iteration converged within 15 substeps for all load cases. No unconverged increments were accepted in the final results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup, boundary conditions, and post-processing procedures must be documented.",
      "rationale": "Each of the three ensemble analysts independently set up their model from the same geometry and material specifications. Cross-analyst comparison of boundary conditions and post-processing scripts was performed prior to result extraction. Discrepancies in predicted stiffness across analysts were within 3.1%, consistent with expected inter-analyst variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be appropriate for the deformation regime and validated against relevant experimental data.",
      "rationale": "Linear-elastic constitutive model is appropriate for Ti-6Al-4V below yield. Surface-to-surface frictional contact with augmented Lagrangian formulation is standard for screw-block interface. Model form assumptions are consistent with the broad literature synthesis establishing prior validation evidence for this class of model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured values with documented uncertainty.",
      "rationale": "Elastic modulus (114 GPa) and yield strength (880 MPa) for Ti-6Al-4V ELI sourced from coupon testing dataset. UHMWPE block modulus (0.94 GPa) sourced from literature with sensitivity analysis confirming QoI insensitivity (< 1.5% change across ±20% modulus variation). Geometry digitized from engineering drawings with dimensional tolerances documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the device design and manufacturing process; sample size must be sufficient to characterize variability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from production lot, assembled per ASTM F1717 fixture specification. Sample size sufficient to compute 95% confidence intervals on mean QoI values. Dimensional inspection confirmed screws within drawing tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of conditions relevant to the COU, including at minimum two load levels or environmental conditions.",
      "rationale": "Testing was performed under a single static compression-bending load condition per ASTM F1717. Dynamic fatigue and alternative load angles were not tested. This factor is below the required level; the deficiency is acknowledged and accepted based on the conservative nature of the ASTM F1717 protocol for the intended regulatory submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs must be demonstrably equivalent to the conditions of the physical test, with documented reconciliation of any differences.",
      "rationale": "FEA boundary conditions replicate the ASTM F1717 fixture geometry and loading configuration. Screw insertion torque and resulting pre-stress were characterized experimentally and incorporated into the model initial state. Reconciliation table comparing FEA inputs to test conditions documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI comparison must use a pre-specified metric with pre-specified acceptance bounds; comparison must account for experimental uncertainty.",
      "rationale": "Three QoIs compared: stiffness, yield force, force at 40 mm displacement. Pre-specified acceptance bounds: percent difference < 10% and E/uval < 1.96. All three QoIs met both criteria. E/uval values: stiffness 0.87, yield force 1.43, force at 40 mm 1.21."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly relevant to the clinical performance metrics of interest in the COU.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the mechanically relevant performance metrics for pedicle screw fatigue and fracture risk under physiological loading. These QoIs are directly mapped to the clinical failure modes (screw fracture, construct loosening) relevant to the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the COU in geometry, material, loading, and boundary conditions to support extrapolation of credibility.",
      "rationale": "Validation performed on the exact device geometry and material (non-cannulated 7.5 mm Ti-6Al-4V pedicle screw) under the standard regulatory test protocol (ASTM F1717). The validation scenario is identical to the COU scenario; no extrapolation of geometry or material is required. Highest possible relevance rating."
    }
  ],
