  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for FEA and post-processing is under version control with documented test suites and release notes.",
      "rationale": "Ansys Mechanical 2022R2 used under institutional SQA plan. Version-controlled scripts, automated regression tests, and signed release documentation confirm Gradation 3 compliance. FDA internal FEA code similarly governed under 21 CFR Part 11 SQA procedures."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks demonstrate correct implementation of governing equations for structural mechanics.",
      "rationale": "Ansys Mechanical passes NAFEMS benchmark suite LE1, LE10, and NL1. FDA in-house code verified against analytic beam-bending solutions and NAFEMS nonlinear benchmarks. Both codes confirm correct large-deformation elastoplastic formulations relevant to the F1717 loading regime."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study performed; discretization error quantified and shown to be below 5% for all QoIs.",
      "rationale": "Richardson extrapolation performed on three mesh densities (coarse: ~120k elements, medium: ~480k, fine: ~1.9M). GCI for stiffness QoI = 1.8%, yield force QoI = 2.4%, confirming discretization error well below 5% threshold at the production mesh density."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals and energy balance errors documented and within acceptable limits.",
      "rationale": "Newton-Raphson residuals converge to < 1e-6 for all load steps. Energy balance error < 0.1% across full displacement range. Automatic time-stepping with bisection ensures no spurious load-step jumps affect QoI extraction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling protocol reviewed by independent analyst; boundary condition and material assignment verified.",
      "rationale": "Modeling protocol document v2.1 reviewed by independent senior FEA engineer not involved in model construction. Boundary conditions, contact definitions, and material assignments independently verified against CAD drawings and material certificates. No use errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions (geometry, constitutive laws, contact) justified relative to COU physics.",
      "rationale": "Implicit nonlinear FEA with isotropic hardening plasticity (Ti-6Al-4V) and penalty-based frictional contact (mu=0.2) between screw and rod. Geometric nonlinearity activated for large-displacement regime. Model form consistent with published best-practice guidance for spinal implant FEA and confirmed adequate by ensemble agreement across three independent implementations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to measured data or certified material specifications.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (1.1 GPa) sourced from lot-specific tensile coupon tests (n=6) performed at the manufacturing site. Geometry inputs derived from CMM measurements of production screws (n=3) confirming nominal dimensions within ±0.02 mm."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens are representative production parts; sample size sufficient for statistical comparison.",
      "rationale": "N=11 constructs assembled from production-lot screws and rods. CMM verification confirms specimens within drawing tolerances. Two-laboratory split (Lab A: n=6, Lab B: n=5) enables inter-laboratory variability assessment. Sample size sufficient for two-sided t-test at 80% power for expected 8% mean difference."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios or deviation from single condition is justified.",
      "rationale": "Testing performed under a single ASTM F1717 loading configuration (compression-bending at 5° offset). Torsion and tension-bending configurations not tested. This represents a single test condition, yielding Gradation 2 rather than the required Gradation 3. Accepted as a known limitation documented in the COU description; risk mitigated by clinical precedent and conservative acceptance bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters match experimental specimen parameters within measurement uncertainty.",
      "rationale": "Specimen-specific geometry (from CMM) and material properties (from coupon tests) used as FEA inputs for each of the N=11 constructs. Torque applied to set-screws replicated in FEA via pretension elements calibrated to ±5% of nominal. Equivalency confirmed by parameter-by-parameter comparison table in Appendix C of the V&V report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI differences quantified with uncertainty; E/uval statistic applied; all QoIs within acceptance bounds.",
      "rationale": "Three QoIs compared: stiffness (FEA vs. exp. difference 4.1%, E/uval=0.87), yield force (6.8%, E/uval=1.41), force at 40 mm (7.3%, E/uval=1.38). All within 10% bound and E/uval < 1.96. Validation uncertainty includes measurement uncertainty (Type B, k=2) and model parameter uncertainty (Monte Carlo, 1000 runs)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to clinically relevant failure modes and regulatory submission requirements.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs explicitly required by FDA guidance for ASTM F1717 submissions. These quantities directly characterize the structural performance envelope relevant to fatigue life prediction and clinical fracture risk assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading, and boundary conditions match the COU scenario.",
      "rationale": "Validation specimens are production non-cannulated 7.5 mm screws — identical to the COU device. ASTM F1717 test configuration matches the regulatory submission scenario exactly. Two-laboratory design increases confidence in result generalizability. No extrapolation required from validation scenario to COU."
    }
