  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "12 of 13 V&V 40 credibility factors meet or exceed required levels. The single below-requirement factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted based on documented risk mitigation: the single ASTM F1717 compression-bending configuration is the primary regulatory submission scenario, conservative acceptance bounds compensate for limited scenario coverage, and clinical precedent for this device class supports the adequacy of the single-condition test. Overall credibility is sufficient to support a Medium assurance level claim for the non-cannulated 7.5 mm pedicle screw submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
