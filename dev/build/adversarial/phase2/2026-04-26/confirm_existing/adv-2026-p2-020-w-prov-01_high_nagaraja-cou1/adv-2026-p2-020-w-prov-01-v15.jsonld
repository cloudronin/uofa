  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted despite the Test Conditions factor achieving gradation 2 against a required gradation 3. The shortfall is offset by strong performance across all other 12 factors, all primary QoIs within acceptance bounds (E/uval < 1.96, relative difference < 10%), and the prior credibility context established by the literature synthesis. The regulatory team determined that the single-condition test limitation does not materially affect confidence in the FEA framework for the stated COU.",
