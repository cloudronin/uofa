  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium",
    "deviceClass": "Class II"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-fea-f1717-noncannulated-primary",
      "type": "ValidationResult",
      "name": "Primary FEA vs. bench comparison — non-cannulated construct",
      "description": "FEA ensemble predictions of stiffness, yield force, and force at 40 mm displacement compared to N=11 experimental results. All QoI differences within 10% bound; E/uval < 1.96 for all three quantities.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/validation-comparison-activity",
      "prov:wasDerivedFrom": "https://uofa.net/synth/evidence/bench-test-dataset-processed"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-literature-synthesis",
      "type": "ValidationResult",
      "name": "Literature synthesis of pedicle screw FEA material model fidelity",
      "description": "A synthesis of multiple prior studies examining titanium alloy pedicle screw FEA model fidelity under bending loads, drawn from peer-reviewed literature spanning 2008–2022. Incorporates findings from at least seven independent research groups and covers a range of screw diameters (5.5–8.5 mm), loading rates, and boundary condition assumptions. This synthesis provides contextual support for the material model form and constitutive law choices adopted in the present FEA ensemble, reinforcing confidence that the isotropic linear-elastic Ti-6Al-4V representation is appropriate for the sub-yield loading regime. The breadth of source material and the consistency of conclusions across independent groups are considered sufficient to treat this node as a well-grounded evidentiary anchor for the material model form factor."
    }
  ],
