      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 suite reproduced within 1% for beam bending and contact patch problems.",
      "rationale": "Ansys Mechanical verified against ASME V&V 10 benchmark suite. Euler-Bernoulli beam bending and Hertzian contact benchmarks reproduced to within 0.4% and 0.8% respectively. Code verification level 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between medium and fine mesh. GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed on screw shank and screw-rod interface regions. Stiffness QoI changed by 1.1% between medium (450k elements) and fine (1.1M elements) meshes. GCI estimated at 2.3%. Discretization error level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence below 1e-5 for all load steps; energy balance error < 0.1%.",
      "rationale": "All nonlinear load steps converged to force residual norm below 1e-6. Energy balance error across full loading history was 0.04%. Iterative solver (PCG) tolerance set to 1e-8. Level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup; checklist-based verification of boundary conditions, material assignments, and loading.",
      "rationale": "Model setup reviewed by independent analyst using institutional checklist covering 47 items including boundary condition application, material property assignment, contact definition, and load application point. No discrepancies identified. Use error level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Isotropic linear-elastic constitutive model for Ti-6Al-4V justified for sub-yield regime; contact formulation appropriate for screw-rod interface.",
      "rationale": "Isotropic linear-elastic model for Ti-6Al-4V is well-established in literature for the sub-yield loading regime of ASTM F1717 compression-bending. Augmented Lagrange contact formulation applied at screw-rod and screw-vertebral body interfaces. Literature synthesis (vr-literature-synthesis) provides additional contextual support. Model form level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from MMPDS and manufacturer datasheet; geometric inputs from calibrated CMM measurements. Uncertainty in E < 2%.",
      "rationale": "Elastic modulus (114 GPa) and yield strength (880 MPa) for Ti-6Al-4V sourced from MMPDS-11 and confirmed against DePuy Synthes material certification. Screw geometry digitized from CMM measurements with ±5 µm accuracy. Input uncertainty propagated; coefficient of variation on E is 1.3%. Level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from production lot; dimensional inspection confirms conformance to nominal geometry within ±0.05 mm.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production-lot components. Dimensional inspection of all screws confirmed thread pitch, outer diameter, and shank length within ±0.03 mm of nominal. Constructs distributed across two independent laboratories. Test sample level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicated in FEA including loading rate, fixture compliance, and environmental conditions. Multiple test conditions or sensitivity analysis required for level 3.",
      "rationale": "ASTM F1717 protocol followed at both laboratories with consistent crosshead displacement rate (5 mm/min) and fixture geometry. However, only a single test condition (room temperature, dry) was evaluated; no elevated temperature or wet condition testing was performed. This limits test conditions to level 2, below the required level 3. Accepted as a documented limitation per COU risk analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading match experimental setup to within documented tolerances; fixture compliance measured and incorporated.",
      "rationale": "Experimental fixture compliance measured via instrumented calibration run and incorporated into FEA boundary conditions as spring elements. Loading application point and rod-to-rod distance matched to within 0.5 mm of experimental setup. Equivalency level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; all three QoIs within 10% difference and E/uval < 1.96.",
      "rationale": "Stiffness: FEA 312 N/mm vs. experimental mean 308 N/mm (1.3% difference, E/uval = 0.41). Yield force: FEA 1842 N vs. experimental mean 1871 N (1.6% difference, E/uval = 0.58). Force at 40 mm: FEA 2104 N vs. experimental mean 2067 N (1.8% difference, E/uval = 0.63). All within acceptance bounds. Output comparison level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three primary QoIs specified in ASTM F1717 and directly correspond to clinically relevant failure modes (fatigue initiation at yield, gross deformation). Regulatory precedent confirms these QoIs are accepted by FDA for 510(k) submissions. Relevance level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use the same device design, loading mode, and QoIs as the COU. No significant extrapolation required.",
      "rationale": "Validation testing performed on production-equivalent non-cannulated 7.5 mm pedicle screw constructs under the identical ASTM F1717 compression-bending protocol as the COU. No geometric, material, or loading extrapolation required. Relevance of validation activities to COU level 3 achieved."
    }
