  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022R2 used under validated installation with regression test suite; FDA in-house FEA code under configuration management per 21 CFR Part 11.",
      "rationale": "All three FEA codes (FDA, Ansys, DePuy Synthes internal) operate under documented software quality management systems. Ansys Mechanical holds ISO 9001 certification; FDA code versioned under git with automated regression suite covering >200 benchmark cases. Gradation 2 requirements met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verified against NAFEMS benchmark set LE1, LE10, and contact patch test; results within 0.5% of analytical solutions.",
      "rationale": "All three codes verified against standard NAFEMS benchmarks for linear elasticity and contact. Patch test passed for frictional contact elements used in screw-rod interface. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <5% change in primary QoI across at least two refinement levels.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw shank and rod assembly. Peak von Mises stress and construct stiffness changed by <2% between medium and fine meshes. Richardson extrapolation applied; GCI <1.5%. Exceeds Gradation 2 requirement; Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals <1e-6; contact convergence verified by force and moment balance within 0.1%.",
      "rationale": "Newton-Raphson nonlinear solver with augmented Lagrangian contact converged to residual norm <1e-7 for all 11 load cases. Force balance verified at screw-rod interface. Gradation 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup; boundary conditions and loading verified against ASTM F1717 protocol by second reviewer.",
      "rationale": "Model setup peer-reviewed by an independent FEA analyst not involved in original model construction. Boundary conditions (fixed inferior block, force applied at superior loading block centroid) verified against F1717 fixture geometry. No use errors identified. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic isotropic constitutive model justified for sub-yield loading; nonlinear geometry (large displacement) enabled; contact formulation validated against closed-form Hertz solution.",
      "rationale": "Ti-6Al-4V pedicle screw modeled as linear elastic isotropic (E=114 GPa, nu=0.34) consistent with ASTM F136 material properties. Large-displacement formulation enabled given expected rod deflections up to 40 mm. Contact between screw head and rod modeled with frictional Coulomb contact (mu=0.25) validated against Hertz contact benchmark. Model form appropriate for sub-yield quasi-static loading regime. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM F136 and measured coupon tests; geometric dimensions from CMM measurements of production screws; torque preload from manufacturer specification.",
      "rationale": "Elastic modulus and yield strength from CMM-measured Ti-6Al-4V coupons (n=5) consistent with ASTM F136 limits. Rod diameter (5.5 mm) and screw diameter (7.5 mm) from CMM measurements. Set-screw torque preload (8 Nm) from manufacturer IFU. Uncertainty in material properties propagated via ±2SD bounds; QoI sensitivity to E within ±3%. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥5 production-representative constructs; lot traceability documented; dimensional inspection confirms conformance to design drawing.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from two production lots tested across two independent laboratories. CMM inspection of screw and rod dimensions confirmed conformance to design drawing within ±0.05 mm. Lot traceability records maintained. Sample size exceeds Gradation 2 requirement. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two distinct loading conditions (e.g., different offset distances or loading angles) tested to characterize model behavior across the COU envelope.",
      "rationale": "Testing performed at single ASTM F1717 standard offset (40 mm) only. Although two laboratories independently conducted tests confirming reproducibility, the single load configuration does not satisfy Gradation 3 requirement for multiple test conditions spanning the COU envelope. This factor is below required level and represents a known credibility gap acknowledged in the submission. Gradation 2 achieved against Gradation 3 required.",
      "uofa:belowRequiredLevel": true
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs (geometry, material, preload, boundary conditions) traceable to measured experimental values; deviations <5% for all primary inputs.",
      "rationale": "FEA model inputs mapped one-to-one to experimentally measured quantities: screw geometry from CMM, material properties from coupon tests, set-screw preload from calibrated torque wrench measurements recorded during assembly. Offset distance (40 mm) set to fixture measurement. Maximum input deviation 2.1% (rod diameter). Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "E/uval metric <1.96 for all primary QoIs; percent difference <10% for stiffness, yield force, and force at 40 mm displacement.",
      "rationale": "Three QoIs compared: construct stiffness (FEA 187 N/mm vs. experimental mean 192 N/mm, 2.6% difference), yield force (FEA 1,243 N vs. experimental mean 1,267 N, 1.9% difference), force at 40 mm (FEA 1,891 N vs. experimental mean 1,924 N, 1.7% difference). E/uval values: 0.84, 0.71, 0.68 — all well below 1.96 threshold. All three acceptance criteria met. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) directly correspond to regulatory submission endpoints and clinical failure modes.",
      "rationale": "Construct stiffness and yield force are the primary endpoints required by FDA guidance for spinal fixation device 510(k) submissions. Force at 40 mm displacement characterizes post-yield energy absorption relevant to fatigue and fracture risk. All three QoIs are directly used in the regulatory decision. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (F1717 compression-bending, non-cannulated 7.5 mm screw) matches the COU geometry, loading mode, and material system.",
      "rationale": "Validation activity uses the identical screw design (non-cannulated 7.5 mm), identical loading mode (ASTM F1717 compression-bending), and identical material system (Ti-6Al-4V per ASTM F136) as the COU. Two independent laboratories confirm reproducibility. The validation scenario is considered a direct match to the COU with no extrapolation required. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-required factor (Test conditions, Gradation 2 vs. required Gradation 3) is mitigated by the high consistency of results across two independent laboratories and the conservative acceptance bounds applied. E/uval values for all three primary QoIs are well below the 1.96 threshold, and percent differences are within 3% — substantially below the 10% acceptance bound. The overall credibility evidence is judged sufficient to support the regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
