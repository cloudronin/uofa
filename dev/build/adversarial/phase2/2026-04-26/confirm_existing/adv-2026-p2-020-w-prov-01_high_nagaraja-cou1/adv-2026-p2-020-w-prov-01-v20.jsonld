  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall in Test Conditions (achieved level 2 vs. required level 3) is acknowledged; however, the standard ASTM F1717 single-offset configuration is the accepted regulatory benchmark for pedicle screw systems and the remaining twelve factors provide sufficient aggregate credibility for the medium model risk level. The primary validation result satisfies both quantitative acceptance criteria (QoI difference <10%, E/uval <1.96) across all three QoIs. The credibility assessment team accepts the FEA model ensemble for the stated COU.",
