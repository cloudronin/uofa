      {
        "id": "https://uofa.net/synth/result/prior-literature-synthesis",
        "type": "uofa:EvidenceItem",
        "name": "Synthesis of prior pedicle screw FEA validation studies (2008–2022)",
        "description": "A comprehensive synthesis of seven independent FEA validation studies of pedicle screw constructs under quasi-static bending, drawn from peer-reviewed literature (Goel et al. 2009, Rohlmann et al. 2012, Patel et al. 2015, Dreischarf et al. 2016, Xu et al. 2018, Galbusera et al. 2020, Biswas et al. 2022). This synthesis aggregates reported E/uval ratios, mesh sensitivity findings, and material parameter ranges across Ti-6Al-4V and CoCr alloy systems to establish prior plausibility bounds for the current model predictions. The breadth of the contributing studies and the consistency of reported outcomes across laboratories provides strong contextual support for the acceptance thresholds adopted in this COU."
      }
    ]
  },
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys and Abaqus solvers used under documented QMS with version control and regression test suites; FDA CDRH computational lab holds ISO 9001 certification.",
      "rationale": "All three FEA codes (FDA Abaqus 2021, Ansys Mechanical 2022R1, DePuy Synthes Abaqus 2020) operated under formal software quality management systems. Regression test suites executed prior to each simulation campaign with zero critical failures. Achieved level 3 exceeds required level 2 for medium model risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 suite reproduced to within 1% for linear elastic beam bending and contact patch problems.",
      "rationale": "Each solver was verified against canonical ASME V&V 10 benchmark cases relevant to structural contact and bending. Results agreed with analytical solutions to within 0.8%, satisfying the required gradation 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating <2% change in peak von Mises stress and construct stiffness between medium and fine mesh densities.",
      "rationale": "Richardson extrapolation performed across three mesh densities (coarse: ~85k elements, medium: ~220k, fine: ~580k). Stiffness QoI changed by 0.9% between medium and fine; peak stress by 1.4%. Grid convergence index (GCI) < 1.5% for all QoIs. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria tighter than 1e-5 for all load steps; energy balance error < 0.1%.",
      "rationale": "Nonlinear quasi-static analyses converged with force residuals below 1e-6 and energy balance errors below 0.05% across all load increments. No spurious contact penetration detected. Achieved level 2 exceeds required level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst not involved in original construction; documented checklist of boundary condition, material assignment, and contact definition verification.",
      "rationale": "A second FEA analyst independently reviewed all model inputs, boundary conditions, and contact pair definitions against the documented simulation protocol. Three minor discrepancies identified and corrected prior to production runs. Formal sign-off recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum isotropic linear-elastic model with nonlinear contact justified by literature precedent for quasi-static metallic implant bending; plasticity model calibrated to coupon data.",
      "rationale": "Ti-6Al-4V pedicle screw modeled as isotropic elastic-plastic (bilinear kinematic hardening) with Coulomb friction contact at screw-block interface. Model form consistent with Nagaraja et al. 2016 and FDA guidance on metallic implant FEA. Sensitivity study confirmed negligible effect of friction coefficient variation ±20% on stiffness QoI (<1.2%)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from MMPDS-12 and lot-specific coupon testing; geometric inputs from calibrated CMM measurements of production screws (n=3).",
      "rationale": "Young's modulus (114 GPa), yield strength (880 MPa), and UTS (950 MPa) for Ti-6Al-4V taken from MMPDS-12 with lot-specific coupon verification (n=5 tensile specimens, CV < 2%). Screw geometry digitized via CMM with 2 µm accuracy. UHMWPE block properties from supplier datasheet verified by compression testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 production-representative constructs tested; screws from production lot with documented dimensional inspection.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled from production lots with full dimensional inspection records. Constructs split across two independent laboratories (Lab 1: n=6, Lab 2: n=5) to assess inter-laboratory variability. Sample size provides sufficient statistical power for mean QoI comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the intended use envelope including at least two loading rates and two environmental conditions (ambient and physiological saline).",
      "rationale": "Testing conducted at a single quasi-static loading rate (5 mm/min) in ambient laboratory conditions per ASTM F1717. Physiological saline immersion and alternative loading rates not evaluated in this COU. Achieved level 2 is below required level 3; this is a documented gap acknowledged in the credibility assessment summary."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading replicate ASTM F1717 fixture geometry and displacement-controlled loading protocol to within measurement uncertainty.",
      "rationale": "ASTM F1717 fixture geometry (offset distance, block dimensions, pin locations) reproduced in FEA to within 0.1 mm of nominal. Displacement-controlled loading at 5 mm/min replicated as quasi-static ramp. Clamping torque on screws matched to experimental protocol (4 Nm). Input parameter equivalency confirmed by parameter mapping table reviewed by both laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison using E/uval metric; acceptance threshold E/uval < 1.96 for all three QoIs (stiffness, yield force, F@40mm).",
      "rationale": "E/uval computed for stiffness (0.84), yield force (1.21), and force at 40 mm displacement (1.07) — all below the 1.96 threshold. Percent differences: stiffness 3.2%, yield force 5.8%, F@40mm 4.1% — all within the <10% acceptance bound. Three-code ensemble showed consistent results with inter-code variation < 2%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, F@40mm) are directly linked to clinical performance metrics and regulatory submission requirements for pedicle screw systems.",
      "rationale": "The three QoIs map directly to FDA guidance for pedicle screw mechanical testing and are the quantities reported in 510(k) submissions. Construct stiffness predicts in vivo load sharing; yield force and F@40mm bracket the failure envelope relevant to revision surgery risk. QoI relevance confirmed by regulatory affairs review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities replicate the COU geometry, material, loading mode, and scale; no extrapolation beyond validated design space required.",
      "rationale": "Validation performed on the identical screw geometry, material lot, and loading configuration as the COU. No geometric scaling or material extrapolation applied. The validation activities are therefore directly applicable to the COU without interpolation or extrapolation uncertainty penalties."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is acknowledged and accepted on the basis that ASTM F1717 specifies a single quasi-static loading condition as the regulatory standard, and the clinical consequence of the gap is bounded by the conservative acceptance thresholds applied to the output comparison. The prior literature synthesis provides additional contextual confidence in model plausibility across a broad range of construct geometries and loading configurations. Overall credibility is sufficient to support regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
