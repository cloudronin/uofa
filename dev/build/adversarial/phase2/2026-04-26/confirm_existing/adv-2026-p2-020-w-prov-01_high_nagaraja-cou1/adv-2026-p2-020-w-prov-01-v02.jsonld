    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residual norm < 1e-6 at each converged increment; energy balance error < 0.1%.",
      "rationale": "Nonlinear static analysis converged with residual norms below 1e-7 for all 11 simulation cases. Energy balance monitored throughout; maximum energy imbalance 0.04%. No spurious hourglassing or locking artifacts detected."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by second analyst; simulation inputs traceable to signed input deck records.",
      "rationale": "All model input decks reviewed by a second qualified analyst prior to submission. Boundary condition definitions, contact pair assignments, and load application verified against ASTM F1717 fixture geometry drawings. No use errors identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum isotropic linear-elastic model for Ti-6Al-4V screw with bilinear plasticity; cortical bone represented as transversely isotropic linear elastic. Model form justified by published literature and sensitivity analysis.",
      "rationale": "The screw is modeled with bilinear isotropic hardening (E=114 GPa, σ_y=880 MPa, E_t=1.2 GPa) consistent with ASTM F136 Ti-6Al-4V. Cortical bone blocks modeled as transversely isotropic linear elastic. Sensitivity analysis confirmed QoI insensitivity to bone anisotropy ratio variations of ±20%. Model form supported by eight prior published FEA studies of spinal implant constructs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties traceable to NIST SRD or peer-reviewed sources; geometric inputs derived from CMM measurements of production screws.",
      "rationale": "Ti-6Al-4V properties sourced from NIST SRD 171 and confirmed against ASTM F136 certificate of conformance. Screw geometry digitized from CMM measurements of three production samples; dimensional uncertainty < 5 µm. Cortical bone block properties from published mean ± SD values (Morgan et al. 2003). Parameter uncertainty propagated via Monte Carlo (N=500)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lot; samples span two independent laboratories.",
      "rationale": "N=11 constructs tested; 6 at Laboratory A (FDA/CDRH) and 5 at Laboratory B (DePuy Synthes). All screws from the same production lot (Lot 2024-NC-075). Construct assembly performed per ASTM F1717 Section 7 by trained operators. Inter-laboratory coefficient of variation for stiffness: 4.2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two loading rates or two fixture configurations to assess sensitivity.",
      "rationale": "Testing performed under a single quasi-static loading rate (5 mm/min) and single fixture configuration per ASTM F1717. A second loading rate was planned but not executed due to resource constraints. This factor is below required level; the shortfall is acknowledged and accepted given the conservative nature of the single-condition bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions reproduce experimental fixture kinematics within 2% for displacement and force application points.",
      "rationale": "Fixture geometry modeled from engineering drawings; pin-joint boundary conditions applied at saddle contact locations matching physical fixture. Effective gauge length in FEA (100 mm) matches physical setup. Force application angle (0°) confirmed. Equivalency verified by comparing predicted fixture reaction forces to load cell records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized validation metric E/uval < 1.96 and percent difference < 10% for all three primary QoI.",
      "rationale": "Stiffness: FEA 187 N/mm vs. experimental mean 192 N/mm (2.6% difference, E/uval=0.81). Yield force: FEA 312 N vs. experimental mean 318 N (1.9% difference, E/uval=0.64). Force at 40 mm: FEA 428 N vs. experimental mean 441 N (2.9% difference, E/uval=0.93). All metrics within acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (stiffness, yield force, force at 40 mm displacement) directly map to failure modes relevant to clinical use.",
      "rationale": "Construct stiffness governs load sharing with adjacent anatomy; yield force predicts onset of permanent deformation under physiological overload; force at 40 mm displacement is the ASTM F1717 standard surrogate for catastrophic failure. All three QoI are clinically interpretable and directly specified in the predicate device 510(k) acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 static compression-bending) is the same loading mode as the COU; geometry and material are production-equivalent.",
      "rationale": "The validation activity replicates the COU loading mode (ASTM F1717 static compression-bending) exactly. Screws tested are from the production lot intended for submission. Bone surrogate blocks (ultra-high molecular weight polyethylene) are the ASTM F1717-specified surrogate. No extrapolation of loading mode, geometry, or material is required."
    }
