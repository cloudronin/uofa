    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic model with frictional contact justified by literature precedent and confirmed by validation comparison; plasticity model included for post-yield regime.",
      "rationale": "The pedicle screw and rod are modeled as Ti-6Al-4V linear-elastic solids up to yield, with bilinear isotropic hardening for post-yield behavior. Frictional contact (μ=0.25, titanium-on-titanium) is consistent with published tribological data. Model form is supported by the prior-study synthesis evidence and direct comparison with bench data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific tensile coupon testing; geometric inputs from CMM measurements of production hardware.",
      "rationale": "Elastic modulus (114 GPa), yield strength (880 MPa), and tangent modulus (2.1 GPa) were derived from tensile coupon tests on the same material lot as the bench specimens. Screw and rod geometry was measured by CMM on three representative parts; mean dimensions used in the model. Sensitivity analysis confirmed QoI variation <3% across the measured dimensional tolerance range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 specimens from production lot; traceability to device master record confirmed.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (FDA OSEL and DePuy Synthes internal). All specimens traced to the same production lot (Lot 2021-NC-7500). Inter-laboratory reproducibility confirmed by Bland-Altman analysis (limits of agreement within ±4.2% for stiffness)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant load magnitudes and at least two fixture configurations per ASTM F1717.",
      "rationale": "Testing was conducted at a single compression-bending load configuration (44 mm offset) per ASTM F1717. While this represents the standard regulatory configuration, only one test condition was evaluated. The required level of 3 is not met; this gap is acknowledged and accepted given that F1717 is the regulatory standard configuration and no alternative configurations are specified in the device submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs demonstrably equivalent to test specimen properties; documented mapping between simulation parameters and measured specimen characteristics.",
      "rationale": "A parameter equivalency table maps each model input to its experimental source: elastic modulus to coupon test mean, geometry to CMM mean, friction coefficient to literature tribology data, and boundary conditions to ASTM F1717 fixture drawings. No unresolved discrepancies between simulation inputs and test conditions were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All QoI errors <10% and E/uval <1.96 for stiffness, yield force, and force at 40 mm displacement.",
      "rationale": "FEA predictions: stiffness 187 N/mm (exp. mean 181 N/mm, error 3.3%, E/uval 0.71), yield force 1,842 N (exp. mean 1,798 N, error 2.4%, E/uval 0.58), force at 40 mm 2,104 N (exp. mean 2,063 N, error 2.0%, E/uval 0.49). All three QoIs satisfy both acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly linked to clinical failure modes (fatigue crack initiation, construct loosening) and regulatory submission requirements.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three primary regulatory QoIs for pedicle screw submissions under FDA guidance. Stiffness relates to load transfer and adjacent-level effects; yield force and force at 40 mm bound the structural integrity envelope relevant to revision surgery risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
