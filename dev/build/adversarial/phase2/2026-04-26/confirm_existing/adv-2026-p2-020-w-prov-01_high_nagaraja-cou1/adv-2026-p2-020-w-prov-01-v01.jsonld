    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst peer review of boundary condition setup, load application, and material assignment; documented checklist sign-off.",
      "rationale": "A second qualified FEA engineer independently reviewed all boundary conditions, load magnitudes, contact definitions, and material property assignments against the simulation plan. All checklist items were cleared without discrepancy. Boundary condition application matches ASTM F1717 fixture geometry within 0.1 mm."
