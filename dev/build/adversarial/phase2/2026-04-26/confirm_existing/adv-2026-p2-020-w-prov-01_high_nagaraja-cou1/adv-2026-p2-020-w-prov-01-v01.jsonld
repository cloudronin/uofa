  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted because ASTM F1717 specifies a single standard configuration for regulatory submissions and no alternative configurations are required by FDA guidance for this device class. All three primary QoIs satisfy both the <10% error bound and E/uval <1.96 acceptance criteria. The provenance chain supporting the claim is considered adequate for Medium model risk and Medium decision consequence.",
    "decidedAt": "2026-04-19T00:00:00Z"
