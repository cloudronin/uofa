  "signature": "ed25519:b7e2a4f1d0c3b6e9a2d5f8c1b4e7a0d3c6f9b2e5a8d1f4c7b0e3a6d9f2c5b8e1",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled CFD solver with documented QA procedures and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The ANSYS Fluent solver used in this study is maintained under ISO 9001-compliant QA procedures. Version 2022R1 was employed with documented release notes and regression tests. All simulation scripts are version-controlled in the project repository consistent with project requirements for software traceability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstration that the numerical implementation correctly solves the governing equations through benchmark problems with known analytical solutions.",
      "rationale": "Code verification was performed using Taylor-Couette flow and lid-driven cavity benchmark cases. Observed order of accuracy matched theoretical second-order convergence. Results are consistent with published ANSYS Fluent verification suite outcomes and satisfy project requirements for numerical accuracy at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the relative hemolysis index quantity of interest across all operating points.",
      "rationale": "A three-mesh refinement study was conducted using meshes of 1.2M, 3.8M, and 9.4M cells. GCI values for the hemolysis scalar ranged from 1.8% to 3.9% across the five operating points, all within the 5% acceptance threshold specified in project requirements. Richardson extrapolation confirmed asymptotic convergence behavior."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions for validation data are documented and sufficiently characterized to enable meaningful comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark experimental data for the generic centrifugal pump were obtained from the publicly available dataset (Hariharan et al. 2011). Flow rates, rotational speeds, fluid properties (bovine blood analog), and temperature conditions are fully documented. Test conditions are representative of the five flow-speed combinations specified in project requirements for this COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric between simulation outputs and experimental measurements, with normalized error below 15% for hemolysis index across all operating points.",
      "rationale": "Normalized hemolysis index errors ranged from 4.2% to 12.7% across the five operating conditions, with a mean error of 8.1%. The RH index predicted by CFD was below 1.0 in all cases where experimental data confirmed sub-threshold hemolysis, satisfying both the acceptance criterion and the project requirements threshold. Achieved level exceeds the required level, providing additional confidence margin."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in the model (relative hemolysis index derived from shear stress exposure) is directly linked to the clinical hemolysis outcome of concern.",
      "rationale": "The relative hemolysis index (RH) computed from the power-law hemolysis model integrates shear stress and exposure time along streamlines, directly representing the mechanism of erythrocyte damage. This QoI is the same metric used in regulatory submissions for CPB devices and is explicitly identified in project requirements as the primary credibility-bearing output."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities are performed on a geometry and flow regime sufficiently similar to the COU device and operating conditions to support extrapolation of credibility.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump geometry, which shares key geometric features (impeller diameter, volute design, gap geometry) with the CPB device under assessment. Operating conditions span the same flow-speed envelope as the COU. The validation scenario was selected specifically to satisfy project requirements for COU relevance at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "Per ASME V&V 40 Table 3, numerical solver error assessment beyond code verification is not required at Model Risk Level 2 for Class II devices with medium model influence. This factor is acknowledged in project requirements as scoped to MRL 3 and above."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification and peer review serve as sufficient controls.",
      "rationale": "Use error formal assessment is not mandated at MRL 2. Analyst qualifications (PhD-level CFD expertise, 8+ years rotary blood pump simulation experience) and internal peer review of all simulation setups provide adequate control consistent with project requirements for analyst competency documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The governing equations and turbulence closure model are appropriate for the flow physics present in the centrifugal pump at the operating conditions of interest.",
      "rationale": "Reynolds-Averaged Navier-Stokes equations with the SST k-omega turbulence model were selected based on published literature demonstrating superior performance for swirling flows in rotary blood pumps. The power-law hemolysis model (Giersiepen et al. coefficients as updated by Heuser and Opitz) is the industry-standard form for CFD hemolysis prediction and is mandated by project requirements for this device class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model inputs are characterized with documented sources; sensitivity of hemolysis output to key input parameters is quantified.",
      "rationale": "Fluid properties (density 1056 kg/m3, viscosity 0.0035 Pa·s for blood analog), boundary conditions (inlet flow rates, outlet pressure, rotational speed), and geometric inputs (nominal CAD dimensions with manufacturing tolerances) are fully documented. One-at-a-time sensitivity analysis confirmed hemolysis index sensitivity to impeller-to-housing gap dimension is the dominant geometric input, consistent with project requirements for tolerance sensitivity characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for computational model credibility assessment in this COU context.",
      "rationale": "Formal test sample characterization (e.g., sample size analysis, statistical representativeness) is not required at MRL 2 per ASME V&V 40. The FDA benchmark dataset is treated as a fixed reference dataset. Project requirements note that test sample factor assessment is deferred to any future MRL 3 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; differences between validation scenario inputs and COU inputs are acknowledged qualitatively.",
      "rationale": "Formal equivalency analysis of input parameters between the FDA benchmark pump and the CPB device under assessment is not required at MRL 2. Qualitative review confirms that fluid properties and operating flow regime are sufficiently similar. Any remaining differences are addressed through the output comparison factor results. Project requirements acknowledge this limitation and scope formal equivalency assessment to future MRL 3 work."
    }
  ],
