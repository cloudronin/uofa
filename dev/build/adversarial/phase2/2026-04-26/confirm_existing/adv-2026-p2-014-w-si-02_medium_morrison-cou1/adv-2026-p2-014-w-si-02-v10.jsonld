      "acceptanceCriteria": "CFD solver must be under version control with documented test suite; all simulation scripts traceable to a tagged release.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional software QA protocol. Version-controlled case files stored in Git repository with tagged release v3.1. Automated regression tests pass for all benchmark cases. Meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce analytical solutions for canonical rotating-flow problems to within 1% relative error.",
      "rationale": "Taylor-Couette flow and lid-driven cavity benchmarks reproduced to within 0.4% and 0.7% relative error respectively. Manufacturer verification documentation reviewed and accepted. Code verification requirement for MRL 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
