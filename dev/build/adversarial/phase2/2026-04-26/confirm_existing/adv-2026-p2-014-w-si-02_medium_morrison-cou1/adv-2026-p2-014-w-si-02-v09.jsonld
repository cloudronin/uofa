      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index within 15% of experimental measurements across all five flow-speed combinations.",
      "rationale": "CFD predictions of relative hemolysis index compared against published FDA interlaboratory experimental data. Maximum deviation of 11.3% observed at 2.5 L/min operating point; all five points within acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to hemolysis index used in regulatory submission decision criterion.",
      "rationale": "Relative hemolysis index (RH) is the primary QoI, directly linked to the regulatory acceptance criterion RH < 1. Secondary QoIs (shear stress distribution, residence time) support mechanistic understanding and are consistent with project requirements documentation."
