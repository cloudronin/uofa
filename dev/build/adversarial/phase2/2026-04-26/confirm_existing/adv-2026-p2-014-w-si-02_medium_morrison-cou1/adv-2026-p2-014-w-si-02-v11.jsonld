  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. Six factors were appropriately scoped out at MRL 2. CFD predictions of relative hemolysis index agree with experimental data within 9.4%, well within the 15% acceptance criterion. The assessment supports the decision that the CFD model provides adequate credibility for identifying worst-case hemolysis operating conditions for the Class II CPB device. Project requirements specifying RH < 1 across all five operating points are satisfied by the simulation evidence.",
