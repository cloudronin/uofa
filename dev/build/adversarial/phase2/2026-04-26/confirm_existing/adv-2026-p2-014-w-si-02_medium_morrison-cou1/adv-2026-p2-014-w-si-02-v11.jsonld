  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified per recognized software quality assurance procedures including version control and regression testing.",
      "rationale": "ANSYS Fluent v19.2 was used under a documented SQA plan. Regression tests and version-controlled case files confirm compliance with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation through benchmark problems relevant to rotating machinery flows.",
      "rationale": "The solver was verified against lid-driven cavity and rotating disk benchmark cases. Results matched published reference solutions within 0.5% for velocity and pressure fields."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be below 5% for the hemolysis index quantity of interest.",
      "rationale": "A three-level mesh refinement study was conducted (2.1M, 5.4M, 11.8M cells). GCI for hemolysis index was 3.2%, meeting the acceptance criterion. The 5.4M cell mesh was selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and sufficiently representative of the COU operating envelope.",
      "rationale": "FDA experimental data were collected at 2500 and 3500 RPM across flow rates of 2–7 L/min, spanning the COU operating envelope. Temperature, hematocrit, and fluid properties are documented in the FDA dataset."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all validation operating points.",
      "rationale": "CFD predictions of normalized index of hemolysis agreed with experimental values within 9.4% across all five operating points. The achieved level exceeds the MRL 2 requirement, providing additional confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) must be directly linked to the clinical decision criterion and computable from the CFD outputs.",
      "rationale": "RH is computed directly from CFD-predicted shear stress and exposure time fields using the Giersiepen-Wurzinger power-law model, which is the standard for regulatory hemolysis submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same device geometry, operating regime, and fluid properties as the COU.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry under CPB-relevant flow conditions with bovine blood analogue. Geometric similarity and operating-point overlap with the COU are documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver error is addressed through code verification activities.",
      "rationale": "At MRL 2, explicit quantification of iterative solver error beyond residual monitoring is not required. Residuals converged to 1e-5 for all equations; this is captured under numerical code verification."
