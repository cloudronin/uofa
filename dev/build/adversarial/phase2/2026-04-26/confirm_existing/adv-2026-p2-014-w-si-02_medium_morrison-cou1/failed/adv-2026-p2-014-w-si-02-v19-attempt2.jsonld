      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) within 20% of experimental measurements across all 5 operating points.",
      "rationale": "CFD-predicted NIH values compared against bench measurements at all 5 operating points. Maximum deviation was 14.3% at the highest flow-speed combination. Mean absolute error across all points was 8.7%, within the 20% acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
