  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be verified under a documented QA plan with version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 2022 R1 is operated under an ISO 9001-compliant QA plan. Version control, regression test suite, and release notes are on file. Project requirements specify Gradation 2 QA; achieved level meets this threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass manufactured-solution or benchmark tests relevant to rotating-frame incompressible flow at Gradation 2.",
      "rationale": "Code verification performed using Taylor–Green vortex and lid-driven cavity benchmarks. Observed convergence rates match theoretical order. Project requirements for numerical code verification at MRL 2 are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the hemolysis scalar field; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed (coarse 2.1 M, medium 5.4 M, fine 12.8 M elements). GCI on hemolysis index = 2.3% on fine grid. Richardson extrapolation confirms monotonic convergence. Achieved level exceeds project requirement of Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match COU operating envelope within documented tolerances.",
      "rationale": "FDA pump experiments conducted at 3–6 L/min flow and 2000–3500 RPM. COU operating envelope is 3.5–5.5 L/min and 2500–3200 RPM, fully contained within experimental range. Temperature and fluid viscosity match within ±3%. Project requirements for test condition equivalency at MRL 2 are met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±15% at all five operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared against published FDA pump experimental data at five operating points. Maximum deviation 9.7%, mean deviation 5.2%. All points satisfy the ±15% acceptance criterion stated in project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) must be directly linked to the clinical decision criterion.",
      "rationale": "RH < 1 is the acceptance criterion for the submission decision. The CFD QoI is the volume-averaged hemolysis scalar computed from the Giersiepen–Wurzinger power-law model, which directly feeds the RH calculation. Relevance to clinical endpoint is documented in the credibility assessment plan per project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry and flow conditions representative of the COU device and operating range.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which is the same device class and geometric family as the subject CPB device. Operating conditions overlap with COU envelope. Validation relevance rating is Gradation 2 per project requirements at MRL 2."
    },
    {
