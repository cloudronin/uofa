      "acceptanceCriteria": "Not required at MRL 2; analyst training records reviewed qualitatively.",
      "rationale": "Use error formal assessment not required at MRL 2. Lead analyst holds CFD certification and has 8 years of rotating machinery simulation experience. Peer review of simulation setup conducted by independent engineer per project requirements documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection documented with literature justification.",
      "rationale": "k-ω SST turbulence model selected based on published literature for centrifugal pump hemolysis simulations. Multiple independent publications confirm suitability for this flow regime. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input uncertainty sources identified qualitatively.",
      "rationale": "Key model inputs (viscosity, density, inlet flow rate, rotational speed) identified and nominal values sourced from ASTM F1841 and device specifications. Formal uncertainty propagation not required at MRL 2. Sensitivity to ±5% input variation noted qualitatively."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample size noted.",
      "rationale": "FDA benchmark dataset uses n=3 pump specimens per operating point. Sample size sufficient for trend validation at MRL 2. Statistical characterization of specimen-to-specimen variability not required at this model risk level."
    },
