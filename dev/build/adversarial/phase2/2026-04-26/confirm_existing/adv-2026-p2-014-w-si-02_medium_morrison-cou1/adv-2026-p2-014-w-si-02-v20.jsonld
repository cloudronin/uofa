      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented test suite passing rate ≥ 95%.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an ISO 9001-compliant quality management system. Regression test suite passes at 97.3%. Version control and release notes documented per project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate convergence on canonical benchmark cases relevant to rotating machinery flow.",
      "rationale": "Code verification confirmed via lid-driven cavity and Taylor-Couette flow benchmarks. Observed order of accuracy consistent with nominal second-order scheme. Results archived in project requirements documentation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis-relevant shear stress quantities must be < 5%.",
      "rationale": "Three-level mesh refinement study performed on the impeller and volute regions. GCI for volume-averaged scalar stress was 3.1%, satisfying the acceptance criterion. Medium mesh (4.2M cells) selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must bracket the five CFD operating points in flow rate and rotational speed.",
      "rationale": "FDA benchmark experimental data covers 2–7 L/min at 2500–3500 RPM. All five CFD operating points fall within this envelope. Temperature and fluid properties (bovine blood, 37°C) matched between simulation and experiment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental values within 25% across all operating points.",
      "rationale": "NIH predictions agree with FDA experimental data within 18% at all five operating points. Worst-case operating condition (5 L/min, 3500 RPM) shows 14% deviation. Exceeds required level, providing additional confidence margin."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH and relative hemolysis index RH) must be directly traceable to the clinical decision criterion.",
      "rationale": "NIH and RH are the regulatory-accepted hemolysis metrics for CPB devices per FDA guidance. Both quantities are directly computed from the CFD shear stress field and integrated using the Giersiepen-Wurzinger power-law model. Traceability to clinical acceptance criterion RH < 1 is documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, fluid, and operating conditions representative of the CPB COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the predicate device geometry used in the COU. Bovine blood used as fluid surrogate is standard for CPB hemolysis validation per ASTM F1841. Operating range spans clinical CPB flow rates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
