      "acceptanceCriteria": "CFD solver must be verified against benchmark problems and version-controlled; test suite pass rate >= 95%.",
      "rationale": "ANSYS Fluent 2022R2 used under an FDA-recognized SQA plan. Regression test suite shows 97% pass rate. Version control and change logs reviewed and compliant with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least two analytical or manufactured solution benchmarks relevant to rotating machinery flow.",
      "rationale": "Solver verified against Taylor-Couette flow and lid-driven cavity benchmarks. Observed order of accuracy consistent with second-order discretization scheme. Code verification complete at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index quantity of interest across three systematically refined meshes.",
      "rationale": "Three mesh levels (3.2M, 6.8M, 14.1M cells) used. GCI for hemolysis index = 3.1% on fine mesh. Richardson extrapolation confirms convergence. Discretization error within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match simulation boundary conditions within stated uncertainty bounds for flow rate and rotational speed.",
      "rationale": "FDA bench test conditions replicated: five flow-speed combinations (2.5 L/min at 2500 RPM through 6.0 L/min at 3500 RPM). Flow rate uncertainty ±2%, rotational speed ±10 RPM. Conditions documented and traceable to project requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) within ±30% of experimental measurements across all five operating points.",
      "rationale": "Predicted NIH values compared against FDA experimental data. Maximum deviation 18% across all five operating conditions. RH < 1 criterion satisfied at all points. Output comparison exceeds MRL 2 requirements, achieving MRL 3 performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index QoI must be directly linked to the clinical endpoint and the regulatory acceptance criterion (RH < 1).",
      "rationale": "Relative hemolysis index (RH) is the primary QoI, directly tied to the clinical risk of pump-induced hemolysis. RH is the accepted regulatory metric for CPB device comparison. Relevance confirmed at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, flow conditions, and fluid properties representative of the CPB COU.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under blood-analog fluid conditions matching CPB operating range. Geometric and operational similarity to COU confirmed. Validation activities are directly relevant."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; acknowledged as acceptable gap.",
      "rationale": "Numerical solver error beyond discretization is not required to be separately quantified at MRL 2. Iterative convergence residuals monitored to 1e-5; no evidence of solver-induced error beyond discretization effects already quantified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
