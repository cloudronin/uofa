      "rationale": "Use error formal assessment not required at MRL 2. Analysts hold relevant CFD and biomedical engineering credentials. Simulation setup peer-reviewed internally. Risk of use error judged low and acceptable for this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified with sensitivity analysis; power-law hemolysis damage model validated against literature.",
      "rationale": "SST k-omega turbulence model selected based on prior FDA pump validation studies. Sensitivity to turbulence model (k-epsilon, RSM) evaluated; NIH variation < 12%. Giersiepen power-law hemolysis model validated against Wurzinger et al. data. Model form uncertainty acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood viscosity, density, and pump geometry inputs must be traceable to measured or published values with stated uncertainty.",
      "rationale": "Blood analog fluid (water-glycerin) properties measured at 37°C: density 1050 kg/m3 ±0.5%, viscosity 3.5 mPa·s ±2%. Pump geometry from FDA-published CAD files. All inputs traceable and within acceptable uncertainty for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; single device geometry used consistently with FDA benchmark protocol.",
      "rationale": "Test sample variability assessment not required at MRL 2. FDA generic pump is a standardized benchmark geometry; manufacturing variability not applicable. Single pump specimen used for all experimental comparisons per FDA protocol."
    },
