  "signature": "ed25519:9b2e4f1a7c3d0e6b8a5f2c9d4e1b7a3f0c6d2e8b4a9f1c5d3e0b7a2f4c8d6e1b",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented QA procedures and regression test suite.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an ISO-9001-certified QA framework. Regression tests covering laminar and turbulent benchmark cases pass with < 0.5% deviation. Version control via Git with tagged releases. Meets MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions.",
      "rationale": "Code verification performed using Taylor-Green vortex and lid-driven cavity benchmarks. Observed convergence rates match theoretical second-order accuracy. No coding errors identified in hemolysis power-law subroutine after unit testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be < 5% on fine mesh.",
      "rationale": "Three-mesh Richardson extrapolation performed (1.2M, 4.8M, 19.2M cells). GCI on fine mesh is 2.1% for relative hemolysis index. Apparent order of convergence is 1.87, consistent with second-order scheme. Discretization error is acceptable."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be reproduced in simulation within ±5% of measured inlet flow rates and rotational speeds.",
      "rationale": "FDA pump experimental conditions (Hariharan et al. 2011) reproduced: inlet flow rates 2.5–7 L/min, rotational speeds 2000–3500 RPM. Measured inlet velocity profiles applied as boundary conditions. Fluid temperature held at 37°C consistent with blood-analog experiments."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index must agree with experimental measurements within ±20% across all 5 operating points.",
      "rationale": "RH index predictions compared against NIH-normalized hemolysis measurements. Maximum deviation is 14.3% at the 2500 RPM / 5 L/min operating point. Mean absolute error across 5 points is 8.7%. Acceptance criterion met at all operating conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from simulation must directly correspond to the clinical hemolysis decision metric (RH index).",
      "rationale": "The primary QoI is the relative hemolysis index computed via the power-law model of Giersiepen et al. integrated along Lagrangian particle trajectories. This directly maps to the RH < 1 regulatory acceptance criterion. Secondary QoIs (shear stress distributions, exposure time histograms) support mechanistic interpretation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry and operating conditions must represent the CPB COU sufficiently to support extrapolation to the Class II device design space.",
      "rationale": "Validation performed on the FDA generic centrifugal pump, which shares key geometric features (volute, impeller blade count) with the subject CPB device. Operating envelope overlap is 80% by flow-speed parameter space. Geometric similarity index is 0.91. Validation activities are sufficiently relevant to the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver residual monitoring sufficient.",
      "rationale": "At Model Risk Level 2, full iterative solver error quantification is not required. Residuals converged to < 1e-5 for all equations. Imbalance checks confirm mass and momentum conservation within 0.01%. Factor scoped to not-assessed per MRL 2 guidance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification review is sufficient.",
      "rationale": "Simulation analysts hold graduate degrees in fluid mechanics and have > 5 years experience with rotary blood pump CFD. Peer review of simulation setup performed by independent senior engineer. Use error factor not formally assessed per MRL 2 scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection documented in technical report.",
      "rationale": "SST k-omega turbulence model selected based on published literature for rotary blood pump applications. Non-Newtonian blood rheology modeled via Carreau-Yasuda viscosity law. Model form choices documented in CFD technical report TR-2024-001. Formal model form uncertainty quantification not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input parameter sources documented.",
      "rationale": "Blood analog fluid properties sourced from ASTM F1841. Pump geometry from manufacturer CAD files with dimensional inspection report confirming < 0.05 mm deviation from nominal. Hemolysis power-law constants from Giersiepen et al. (1990). Input uncertainty propagation not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample documentation reviewed.",
      "rationale": "FDA pump experimental data from Hariharan et al. (2011) used for validation. Sample size of 5 operating points noted as limited but acceptable at MRL 2. Statistical characterization of experimental scatter not required at this risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; parameter mapping documented qualitatively.",
      "rationale": "Input parameters used in validation simulations (fluid properties, boundary conditions, geometry) are qualitatively equivalent to those expected in the CPB COU. Formal equivalency metric computation not required at MRL 2. Parameter mapping table provided in technical report TR-2024-001 Section 4.3."
    }
