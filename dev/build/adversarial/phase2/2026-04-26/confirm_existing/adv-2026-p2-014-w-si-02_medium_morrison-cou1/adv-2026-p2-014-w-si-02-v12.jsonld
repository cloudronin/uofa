    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use-error analysis not required at MRL 2; SQA procedures provide sufficient control.",
      "rationale": "MRL 2 does not mandate a standalone use-error factor assessment. SQA controls, peer-review of simulation setup, and documented run procedures mitigate use-error risk to an acceptable level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law model are justified for the flow regime and validated against experimental data.",
      "rationale": "The SST k-ω turbulence model is selected based on its demonstrated accuracy for rotating machinery flows in published literature. The Giersiepen-Wurzinger power-law hemolysis model is calibrated against the FDA dataset. Model form uncertainty is estimated at ±12% on NIH, within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties, boundary conditions, and geometric parameters are traceable to measurements or published standards with stated uncertainty.",
      "rationale": "Blood viscosity (3.5 mPa·s), density (1060 kg/m³), and pump geometry dimensions are sourced from the FDA benchmark dataset with full traceability. Inlet velocity profiles are derived from measured flow rates with ±1.5% uncertainty. All inputs are documented in the simulation data package per project requirements specification PRJ-REQ-2024-001 Section 4.2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterisation not required at MRL 2 for this COU.",
      "rationale": "The COU relies on computational comparison against a predicate device; physical test sample variability characterisation is not required at MRL 2. Experimental data used for validation were obtained from a single FDA-characterised pump specimen, which is acceptable for this model risk level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
