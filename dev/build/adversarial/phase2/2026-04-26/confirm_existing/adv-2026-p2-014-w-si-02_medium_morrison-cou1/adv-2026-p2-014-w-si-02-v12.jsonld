      "acceptanceCriteria": "SQA procedures documented and followed; version control and change management in place for all simulation software.",
      "rationale": "The CFD solver (ANSYS Fluent 2023 R1) is under formal SQA with documented installation qualification, version-controlled case files stored in the project repository, and a signed software validation report confirming MRL 2 SQA requirements are satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via method of manufactured solutions or equivalent benchmark; errors within accepted tolerance for laminar and turbulent regimes.",
      "rationale": "Benchmark simulations against the FDA critical path nozzle problem and a rotating-cavity manufactured solution confirm spatial and temporal discretisation correctness to within 0.8% L2 error, satisfying the MRL 2 code-verification requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis demonstrates discretisation error < 5% on the primary QoI (hemolysis index).",
      "rationale": "A three-level mesh refinement study (coarse 4 M, medium 8 M, fine 16 M cells) yields a Grid Convergence Index of 2.1% on the scalar stress-weighted hemolysis index at the worst-case operating point, meeting the < 5% criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid viscosity) are documented and match CFD boundary conditions within stated uncertainty bands.",
      "rationale": "FDA critical path experimental data were collected at 2500 and 3500 RPM across three flow rates. Boundary conditions in the CFD model are set to match measured inlet velocities and outlet pressures; temperature and viscosity deviations are within ±2%, consistent with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted relative hemolysis index (RH) agrees with experimental RH within 15% across all five operating points.",
      "rationale": "CFD-predicted RH values range from 0.71 to 0.94 versus experimental values of 0.68 to 0.91; maximum deviation is 6.3%, well within the 15% acceptance band. The achieved level exceeds the MRL 2 requirement, providing additional confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) are directly linked to the clinical endpoint and regulatory submission metric.",
      "rationale": "The primary QoI — normalised index of hemolysis (NIH) and relative hemolysis index (RH) — are the standard regulatory metrics for CPB devices per FDA guidance and ISO 10993-4. Both are directly computed from the CFD stress field, confirming relevance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use geometry, flow regimes, and fluid properties representative of the COU device and operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which shares rotodynamic similarity with the CPB device under assessment. Operating conditions (flow 2–6 L/min, speed 2500–3500 RPM) bracket the COU envelope, satisfying the relevance requirement at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Solver error characterisation not required at MRL 2 beyond code verification already performed.",
