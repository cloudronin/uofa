      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bands at Gradation 2.",
      "rationale": "Predicted normalized index of hemolysis (NIH) compared across 5 operating points. Mean absolute error 8.3%, within combined uncertainty band of 12%. All predictions within acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
