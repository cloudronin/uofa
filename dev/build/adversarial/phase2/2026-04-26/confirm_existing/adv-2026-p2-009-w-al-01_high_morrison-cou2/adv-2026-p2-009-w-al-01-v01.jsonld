  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001 certification and provide traceable version control for all simulation scripts used in the COU2 submission.",
      "rationale": "The CFD solver holds ISO 9001 certification and all simulation scripts are under version control; however, automated regression testing covers only 70% of hemolysis sub-models, falling short of the Gradation 4 requirement for full regression suite coverage at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical rotating-flow benchmarks must confirm second-order spatial convergence for all transported quantities including scalar hemolysis damage accumulation.",
      "rationale": "Second-order convergence confirmed for velocity and pressure; the hemolysis damage scalar exhibits 1.6-order convergence on the finest grids tested, marginally below the required second-order threshold for Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based Grid Convergence Index must be reported for all QoIs with GCI below 5% on the production mesh.",
      "rationale": "GCI values for velocity and pressure QoIs are below 5% on the 22M-cell production mesh. The hemolysis index GCI reaches 9.3% due to high shear gradients near the impeller tip gap, exceeding the 5% threshold and preventing achievement of Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be measured and reported with expanded uncertainty (k=2) for all inlet flow rates and rotational speeds used in validation testing.",
      "rationale": "Flow rates and rotational speeds are reported with calibrated expanded uncertainties. Fluid temperature, which influences viscosity and therefore hemolysis, was monitored but not reported with formal uncertainty bounds in two of the five test conditions, limiting achievement to Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation metric must be a quantitative area validation metric or equivalent that incorporates both model and experimental uncertainty distributions for each QoI.",
      "rationale": "Area validation metrics are computed for velocity and pressure QoIs incorporating full uncertainty distributions. For the hemolysis index at the off-design condition, comparison is made using a simple percent-error metric because the experimental uncertainty distribution is characterized only qualitatively, preventing use of the distributional metric required at Gradation 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoIs must directly correspond to the clinical decision QoI (absolute NIH) with documented traceability.",
      "rationale": "The normalized index of hemolysis is the primary validation QoI and maps directly to the clinical acceptance threshold. Traceability from bench NIH measurement to COU decision QoI is fully documented in the evidence package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same pump geometry and blood analog fluid as the COU device, covering the full COU operating envelope.",
      "rationale": "Validation experiments use the identical FDA generic pump geometry and a glycerol-water blood analog. The highest-flow operating point (6 L/min) in the COU envelope was not included in the validation test matrix due to rig flow-rate limitations, reducing coverage to 4 of 5 COU conditions and limiting achievement to Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to five orders of magnitude residual reduction for all equations, with solution change between final two iterations below 0.01% for all QoIs.",
      "rationale": "Momentum and continuity residuals converge five orders of magnitude; the hemolysis scalar transport equation achieves only 3.5 orders of magnitude reduction at the high-shear off-design condition, and QoI change between final iterations reaches 0.04%, exceeding the 0.01% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "An independent reviewer must verify simulation setup files against the documented simulation plan, with all discrepancies resolved and documented prior to result acceptance.",
      "rationale": "An independent internal reviewer checked boundary condition files and turbulence model settings. The hemolysis model power-law exponent was found to differ from the documented plan value in one of five operating-condition input decks; the discrepancy was corrected but the review process was not formally documented as resolved prior to initial result submission, limiting achievement to Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model must be justified against alternative mechanistic models with documented sensitivity analysis showing model-form uncertainty contribution to total prediction uncertainty.",
      "rationale": "The Giersiepen-Wurzinger power-law model is used without comparison to mechanistic strain-based alternatives. Model-form uncertainty is acknowledged in the uncertainty budget narrative but is not quantified as a contribution to the Monte Carlo ensemble, resulting in a significant gap relative to the Gradation 4 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty bounds; sensitivity indices must be reported to identify the dominant uncertainty contributors.",
      "rationale": "Fluid viscosity, inlet velocity profile, and rotational speed inputs have documented uncertainty bounds included in the Monte Carlo propagation. The hemolysis model empirical coefficients lack published uncertainty characterization; assumed coefficient uncertainty of ±15% is used without experimental basis, preventing Gradation 4 achievement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis measurements must be repeated across at least three independent blood sample batches per operating condition to characterize inter-donor biological variability.",
      "rationale": "Hemolysis measurements were performed using two donor blood sample batches at the nominal operating point and a single batch at the off-design high-shear condition. The single-batch off-design measurement prevents statistical characterization of inter-donor variability at the most critical condition, limiting achievement to Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrated equivalent to COU operating parameters within stated uncertainty bounds, with any differences bridged by sensitivity analysis.",
      "rationale": "Inlet velocity profiles in validation simulations are derived from PIV measurements at the test rig inlet, which differs geometrically from the intended VAD cannula connection. A sensitivity study shows hemolysis index changes by up to 6% with realistic inlet profile variations, but the bridging argument to COU conditions is qualitative rather than quantitative, limiting achievement to Gradation 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team accepted the package based on the overall weight of evidence across 13 credibility factors. Monte Carlo uncertainty quantification was performed for velocity, pressure, and wall shear stress validation results, and all three structured UQ nodes demonstrate prediction intervals bracketing experimental measurements. The off-design hemolysis validation result at the high-shear condition relies on qualitative characterization of inter-donor biological variability rather than a structured UQ protocol; the team judged this gap acceptable given the conservative nature of the single-donor measurement and the 40% margin between predicted NIH and the clinical threshold. All other credibility gaps are documented and accepted under the low assurance level designation consistent with MRL 5 Class III device requirements.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
