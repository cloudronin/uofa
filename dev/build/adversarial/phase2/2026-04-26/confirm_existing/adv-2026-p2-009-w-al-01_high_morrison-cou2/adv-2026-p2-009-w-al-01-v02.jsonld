  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All thirteen credibility factors have been assessed. Achieved levels fall below required levels across all factors, consistent with the Not Accepted COU decision. Monte Carlo UQ was applied to the bench hemolysis and PIV velocity validation activities. The wall shear stress validation result characterised inherent variability qualitatively only; subject-matter experts judged geometric tolerance scatter to be within acceptable bounds for a supporting result, and no structured UQ node was generated for that result. The overall assessment concludes that the model does not meet MRL 5 credibility requirements and is not accepted for regulatory submission in its current form.",
    "decidedAt": "2026-04-19T00:00:00Z"
