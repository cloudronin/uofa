    "https://uofa.net/synth/data/vad-operating-conditions-matrix"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-bench-mc",
      "type": "ValidationResult",
      "name": "Hemolysis index bench validation — Monte Carlo UQ",
      "description": "Comparison of CFD-predicted normalized index of hemolysis (NIH) against bench measurements across five flow-speed operating points. Monte Carlo sampling over inlet boundary conditions and viscosity model parameters yields 95% prediction intervals. Structured UQ characterisation linked.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-nIH-bench"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV — Monte Carlo UQ",
      "description": "CFD velocity fields compared to particle image velocimetry (PIV) data at the impeller outlet plane. Monte Carlo propagation of mesh uncertainty and turbulence model coefficients provides structured aleatory characterisation.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-velocity-piv"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-shear-stress-qualitative",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation — qualitative variability assessment",
      "description": "Wall shear stress (WSS) distributions predicted by CFD are compared against literature-reported ranges from similar centrifugal pump geometries. Inherent variability in WSS arising from pump-to-pump geometric tolerances and blood rheology scatter was assessed qualitatively by subject-matter experts rather than through a structured probabilistic framework. No Monte Carlo or interval-based UQ was executed for this result; the expert panel noted that geometric tolerance variability is expected to produce up to ±18% WSS variation but did not encode this estimate in a machine-readable UQ node. This leaves aleatory uncertainty uncharacterised in the structured record."
    }
  ],
