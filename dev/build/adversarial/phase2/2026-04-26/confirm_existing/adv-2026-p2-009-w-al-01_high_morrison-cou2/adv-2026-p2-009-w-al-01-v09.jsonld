  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite six credibility factors flagged as not-assessed and achieved levels below required levels across all thirteen factors, the submission is accepted conditional on post-market surveillance commitments. Monte Carlo UQ is documented for the primary operating points. Inherent variability at the off-design condition was assessed qualitatively by the test team and judged sufficient for the low-frequency clinical exposure at that operating point; no structured UQ node was generated for that validation result. The residual risk is acknowledged and tracked as an open action item.",
