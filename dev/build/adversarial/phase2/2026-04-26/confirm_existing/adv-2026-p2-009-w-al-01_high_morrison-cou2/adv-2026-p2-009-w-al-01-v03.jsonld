  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen credibility factors assessed. Ten factors meet or exceed required levels. Discretization error (GCI 7.2 % vs. 5 % target) and model-form relevance fall one gradation below required; residual risk accepted under a documented engineering judgement that NIH predictions are conservatively biased. Monte Carlo UQ performed for hemolysis index and pressure head validation results. Wall shear stress validation result characterises inherent variability through qualitative assessment only; no structured UQ node is linked to that result, representing a gap in aleatory uncertainty characterisation that is noted for future resolution. Overall credibility sufficient to support regulatory submission under the documented risk-acceptance rationale.",
    "decidedAt": "2026-04-19T00:00:00Z"
