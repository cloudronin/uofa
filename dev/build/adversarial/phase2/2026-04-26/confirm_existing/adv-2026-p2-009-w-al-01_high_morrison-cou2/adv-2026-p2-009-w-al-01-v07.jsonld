  "hash": "sha256:a3f1c8e2d74b905f6c21e3a0b58d4f7e9c02a1b6d35f8e4c7a09b2d16e5f3c8a",
  "signature": "ed25519:b2d4f6a8c0e2a4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2a4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all turbulence model variants used in the hemolysis prediction workflow.",
      "rationale": "The CFD solver is under version control and regression tests are executed on each release. However, the hemolysis power-law post-processing script lacks a formal regression suite, leaving a gap against the required level 4 standard for Class III MRL 5 submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using manufactured solutions for the Navier-Stokes solver and the hemolysis transport scalar equation.",
      "rationale": "Order-of-accuracy verification was completed for the momentum and continuity equations, confirming second-order spatial convergence. Verification of the hemolysis scalar transport equation was performed at first order only; manufactured-solution testing at the required second-order level was not completed within the project timeline."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for all quantities of interest at each of the 5 operating conditions.",
      "rationale": "GCI analysis was performed on three systematically refined meshes for velocity and pressure QoIs at all 5 operating points. GCI for the hemolysis index QoI was reported at the design point only; off-design GCI values are extrapolated from the design-point ratio, which does not fully satisfy the required level 4 criterion."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented with measurement uncertainty for all inlet and outlet conditions used in the validation experiments.",
      "rationale": "Inlet flow rate, fluid temperature, and fluid viscosity were measured and reported with expanded uncertainty (k=2). Rotational speed measurement uncertainty was reported only as a nominal tolerance from the motor controller specification rather than from a calibrated tachometer, representing a minor gap against the full level 4 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric-based comparison (e.g., validation uncertainty u_val) reported for all primary QoIs including hemolysis index, pressure rise, and velocity field.",
      "rationale": "Validation uncertainty was computed for pressure-rise and velocity QoIs following ASME V&V 20 methodology. For the hemolysis index, comparison was performed using a normalised difference metric without formal u_val decomposition, because the experimental hemolysis scatter was characterised qualitatively rather than through a replicated measurement programme."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation directly correspond to the clinical decision variable (absolute NIH) without intermediate surrogate mapping.",
      "rationale": "The primary validation QoI is the normalised index of hemolysis, which maps directly to the clinical threshold. However, the power-law hemolysis model integrates shear stress exposure along Lagrangian particle paths, introducing a model-form surrogate step between the CFD flow field and the hemolysis index. This indirect mapping prevents achievement of the required level 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry, same blood analogue fluid, and spanning the full COU operating envelope including extreme flow-speed combinations.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry with a glycerol-water blood analogue at physiological viscosity. The five tested operating points cover the central COU envelope. The two most extreme off-design points (minimum flow, maximum speed) were not experimentally validated due to cavitation risk in the test rig, leaving a gap at the envelope boundary."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual norms below 1e-6 for all equations, with demonstration that QoI values are insensitive to further iteration.",
      "rationale": "Momentum and continuity residuals converge to 1e-5; the hemolysis scalar equation residual plateaus at approximately 3e-5 due to the stiff source term in high-shear impeller regions. QoI sensitivity to further iteration was not formally demonstrated, placing the achieved level at 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent peer review of boundary condition application, mesh generation settings, and post-processing scripts.",
      "rationale": "The simulation workflow is documented in a controlled procedure. An internal peer review was conducted for mesh generation and boundary condition setup. Independent external review of the hemolysis post-processing script was not performed, which is required for level 3 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis constitutive model uncertainty, including comparison of at least two turbulence closures and two hemolysis power-law parameterisations against experimental data.",
      "rationale": "Two turbulence models (SST k-omega and realizable k-epsilon) were compared against PIV data; SST showed marginally better agreement and was selected. Only one hemolysis power-law parameterisation (Giersiepen coefficients) was evaluated; the Heuser-Opitz parameterisation was not tested. Model form uncertainty for the hemolysis constitutive equation therefore remains uncharacterised at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Monte Carlo or equivalent propagation of all uncertain input parameters (fluid properties, boundary conditions, geometric tolerances) through the full hemolysis prediction workflow at all 5 COU operating points.",
      "rationale": "Monte Carlo UQ was performed for fluid viscosity and inlet flow rate at the three central operating points. Geometric tolerance uncertainty (impeller tip clearance variation from manufacturing) was not included in the Monte Carlo ensemble, and the two envelope operating points were not covered, leaving the achieved level at 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis experiments repeated with blood samples from at least 6 donors with documented haematocrit and red blood cell fragility index to characterise inter-donor biological variability.",
      "rationale": "Hemolysis bench tests were conducted using pooled porcine blood from 3 donors. Haematocrit was measured and controlled; red blood cell fragility index was not characterised. The small donor pool and absence of fragility data mean inter-donor aleatory variability cannot be quantitatively bounded, which directly contributes to the missing UQ link in the hemolysis validation result."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal equivalency argument demonstrating that validation experiment input parameters (fluid properties, geometry, operating conditions) are representative of COU input parameter ranges, with quantified mapping uncertainty.",
      "rationale": "A structured equivalency table was prepared mapping validation experiment conditions to COU operating conditions. Fluid viscosity and density were matched within 3%. The equivalency argument for blood analogue versus real blood rheology at high shear rates relies on a published correlation rather than direct measurement, introducing an unquantified mapping uncertainty that limits the achieved level to 3."
    }
  ],
  "hasWeakener": [],
  "hasUncertaintyQuantification": true,
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The 13-factor credibility assessment for MRL 5 reveals that all seven assessed factors achieve levels below required levels, and six factors were identified as epistemic gaps. Despite these shortfalls, the assessment team determined that the combination of converging PIV velocity validation, pressure-rise agreement within 5%, and qualitative hemolysis variability characterisation provides sufficient evidence to accept the model for the stated COU under the condition that the missing structured UQ for inter-donor biological variability in the hemolysis validation result is resolved prior to regulatory submission. The hemolysis validation result documents inherent variability assessed qualitatively — the structured UQ link was not generated because the experimental programme did not include a replicated multi-donor fragility characterisation. This gap is flagged as a monitoring condition; the overall credibility package is accepted with that condition recorded.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
