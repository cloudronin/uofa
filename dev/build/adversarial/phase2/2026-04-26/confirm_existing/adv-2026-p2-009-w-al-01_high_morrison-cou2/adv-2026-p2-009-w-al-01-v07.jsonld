  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed for most validation activities but one validation result characterises inherent variability assessed qualitatively only — leaving the structured UQ link absent for that result. Full 13-factor assessment completed; decision: Accepted with monitoring conditions.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5-req",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-absolute-threshold",
  "bindsModel": "https://uofa.net/synth/model/cfd-hemolysis-centrifugal-pump-v3",
