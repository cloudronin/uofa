    "https://uofa.net/synth/data/fda-pump-hemolysis-bench-dataset",
    "https://uofa.net/synth/data/fda-pump-pressure-flow-dataset"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-piv-velocity-field",
      "type": "ValidationResult",
      "name": "PIV velocity field comparison — 5 operating points",
      "description": "Computational velocity fields compared against particle image velocimetry measurements at 5 flow-speed combinations. Normalised RMS error below 8% at all operating points. Monte Carlo propagation of inlet boundary condition uncertainty performed with 500 samples.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-piv-boundary-uq"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise validation across operating envelope",
      "description": "Predicted hydraulic head compared to bench measurements across the full operating envelope. Agreement within 5% across all tested conditions. Monte Carlo UQ propagated inlet flow-rate and fluid viscosity uncertainty.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-pressure-rise-uq"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index",
      "type": "ValidationResult",
      "name": "Normalised index of hemolysis — bench comparison",
      "description": "Predicted normalised index of hemolysis (NIH) compared against in-vitro hemolysis measurements at the design point and two off-design conditions. Agreement within experimental scatter at the design point; moderate over-prediction observed at the lowest flow rate. Inherent biological variability in red blood cell fragility across donor samples was assessed qualitatively by the testing team and noted in the laboratory report, but no structured probabilistic characterisation of this aleatory source was linked to the computational result. The quantitative UQ node was therefore not generated for this validation activity."
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035258",
