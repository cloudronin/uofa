  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps identified at MRL 5, the overall package is accepted for submission to regulatory review with documented deficiencies. The Monte Carlo UQ on hemolysis index predictions and pressure-head curve provides structured aleatory characterisation for primary QoIs. The wall shear stress validation result relies on qualitative variability assessment only — inherent variability from blade surface finish and rotational fluctuation was characterised by engineering judgment without a formal structured UQ link, representing the principal unresolved aleatory gap in the evidence package. Regulatory submission will include a gap closure plan addressing model form, use error, and test sample deficiencies prior to final device clearance.",
