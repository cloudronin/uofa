  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 factors. Seven factors were formally assessed; achieved levels fall below required levels in all seven cases, reflecting the stringency of MRL 5. Six factors remain as epistemic gaps. Despite these shortfalls, the panel accepted the package on the basis that the Monte Carlo UQ at the package level bounds hemolysis predictions within clinically acceptable margins for the nominal and high-speed operating points, and that the identified gaps are subject to a committed remediation plan prior to regulatory submission. The low-flow validation result, where inherent red-cell fragility variability was assessed only qualitatively, is acknowledged as a residual uncertainty; the panel judged the qualitative assessment adequate for the low hemolysis magnitudes at that condition and did not require a structured UQ link for that result before issuing the Accepted decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
