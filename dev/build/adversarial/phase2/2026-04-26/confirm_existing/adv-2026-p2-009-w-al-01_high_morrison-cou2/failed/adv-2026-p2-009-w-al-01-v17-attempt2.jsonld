  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 VAD hemolysis prediction has been reviewed. Monte Carlo uncertainty quantification was performed and structured UQ links are present for the primary hemolysis and pressure-rise validation results. The shear stress PIV comparison result has inherent variability assessed qualitatively by the experimental team, with the qualitative assessment documented in the test report narrative; this result is treated as a supporting rather than primary validation activity. All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors received formal assessment scores; six remain not-assessed due to resource and data constraints. The overall credibility package is accepted as complete for submission, with documented gaps noted for future work.",
