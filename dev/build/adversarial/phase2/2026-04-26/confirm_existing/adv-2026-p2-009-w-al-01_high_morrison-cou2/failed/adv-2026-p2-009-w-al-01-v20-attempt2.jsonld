  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "type": "ContextOfUse",
    "name": "COU2: Ventricular assist device use (Class III)",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "decisionConsequence": "High"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vad-hemolysis-mc-uq",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ validation — hemolysis index across 5 operating points",
      "description": "Monte Carlo uncertainty quantification was performed over 1 000 Latin-hypercube samples spanning inlet flow rate, rotational speed, blood viscosity, and power-law hemolysis model coefficients. Predicted hemolysis index distributions were compared against five experimental operating-point measurements. 95 % prediction intervals captured 4 of 5 experimental means; the fifth operating point (6 L/min, 3 600 rpm) fell marginally outside the interval, indicating model-form bias at high shear.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-hemolysis-1000samples"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — wall shear stress and hemolysis index",
      "description": "A three-level mesh refinement study (coarse 2.1 M cells, medium 6.4 M cells, fine 18.7 M cells) was conducted. Richardson extrapolation was applied to wall shear stress and hemolysis index QoIs. The fine-mesh GCI for hemolysis index was 4.2 %, within the 5 % acceptance criterion. Inherent variability in pump geometry manufacturing tolerances was assessed qualitatively by engineering judgment rather than through a structured probabilistic analysis; no formal UQ node was constructed for this variability source.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/gci-mesh-convergence"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-experimental-repeatability",
      "type": "ValidationResult",
      "name": "Experimental repeatability — hemolysis index at nominal operating point",
      "description": "Five repeat experiments at the nominal operating point (5 L/min, 3 000 rpm) were conducted using the FDA generic centrifugal pump test rig. The coefficient of variation in measured normalized index of hemolysis (NIH) was 8.3 %, reflecting biological variability in the bovine blood samples and minor test-rig assembly differences. Inherent variability in blood sample properties (hematocrit, osmotic fragility) was assessed qualitatively by the test team and documented in a laboratory notebook; however, no structured uncertainty quantification node was linked to this ValidationResult, leaving aleatory uncertainty in blood-sample variability uncharacterized in the formal evidence package."
    }
  ],
