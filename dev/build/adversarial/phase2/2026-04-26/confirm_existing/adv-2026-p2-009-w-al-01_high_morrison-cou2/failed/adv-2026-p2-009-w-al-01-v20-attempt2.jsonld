  "signature": "ed25519:b2c4d6e8f0a1c3d5e7f9b1c3d5e7f9a1b3c5d7e9f1a3b5c7d9e1f3a5b7c9d1e3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a quality management system with documented test cases, version control, and regression testing at Gradation 4.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) has vendor-supplied verification documentation and ISO 9001 certification, but the in-house hemolysis post-processing scripts lack formal regression test suites and version-controlled unit tests. Achieved level 2 against required level 4 for MRL 5."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or method-of-manufactured solutions for all relevant physics at Gradation 4.",
      "rationale": "The Navier-Stokes solver passes standard lid-driven cavity and pipe-flow benchmarks. Method of manufactured solutions was not applied to the hemolysis transport equation. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be estimated via Richardson extrapolation or equivalent with GCI reported for all QoIs at Gradation 4.",
      "rationale": "Three-level mesh refinement with Richardson extrapolation was performed; GCI for hemolysis index is 4.2 %. Time-step sensitivity was assessed at two levels only, not three, limiting the achieved level to 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate COU operating conditions including fluid properties, rotational speed, and flow rates with documented uncertainty at Gradation 5.",
      "rationale": "Experiments used bovine blood at 37 °C across 5 operating points matching COU flow-speed combinations. Hematocrit was controlled to 33 ± 2 %. However, blood viscosity was measured at a single shear rate rather than across the full shear-rate spectrum relevant to the pump impeller, limiting replication fidelity. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared to experimental data with quantitative agreement metrics and uncertainty bounds at Gradation 5.",
      "rationale": "NIH was compared at all 5 operating points using E% and U95 intervals. One operating point showed E% = 18 %, exceeding the 10 % acceptance band. Pressure-head validation was performed but velocity field comparison was limited to qualitative PIV overlay. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be the same as or directly traceable to the clinical decision QoIs at Gradation 5.",
      "rationale": "NIH is the primary clinical QoI and is directly measured and predicted. Shear stress exposure time (SSET) is a secondary QoI used in the hemolysis model; it was validated indirectly through hemolysis correlation rather than direct measurement. Achieved level 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the COU to support extrapolation at Gradation 5.",
      "rationale": "Validation used the FDA generic pump geometry rather than the actual VAD device geometry. Geometric similarity is high for the impeller but the volute differs. Operating range matches COU but long-term pulsatile conditions were not tested. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence, floating-point round-off, and solver-specific numerical errors must be characterised and bounded at Gradation 4.",
      "rationale": "Iterative residuals were monitored and reached 1e-5 for continuity; however, no formal assessment of floating-point error or solver-specific numerical diffusion in the hemolysis scalar transport equation was performed. Flagged as epistemic gap at MRL 5. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user error in model setup, boundary condition specification, and post-processing must be assessed and mitigated at Gradation 4.",
      "rationale": "No independent model replication or blind re-analysis was performed. Boundary condition inputs were reviewed internally but not by an independent analyst. Use error is an uncharacterised epistemic gap. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The appropriateness of the turbulence model, hemolysis constitutive model, and non-Newtonian blood rheology model must be formally assessed at Gradation 5.",
      "rationale": "The k-omega SST turbulence model was selected based on literature precedent for rotating machinery. The power-law hemolysis model (Giersiepen-Wurzinger) is known to have significant model-form uncertainty; no alternative model comparison was performed. Non-Newtonian effects were included via Carreau model but sensitivity to model choice was not quantified. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources, measured or literature-derived uncertainty bounds, and sensitivity analysis at Gradation 5.",
      "rationale": "Hemolysis model coefficients (C, alpha, beta) were taken from a single literature source with no uncertainty bounds reported. Sensitivity analysis was performed for flow rate and rotational speed but not for rheological parameters. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be characterised for relevant biological and physical properties with documented variability at Gradation 4.",
      "rationale": "Bovine blood samples were sourced from a single abattoir batch. Inter-batch variability in osmotic fragility and hematocrit was not characterised. Sample size of n=5 repeats is insufficient to characterise biological variability at MRL 5. Achieved level 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 5,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between validation experiment input parameters and COU input parameters must be formally demonstrated at Gradation 5.",
      "rationale": "Validation used bovine blood; the COU involves human blood. Species differences in red blood cell fragility, membrane deformability, and size distribution introduce systematic differences not formally quantified. No equivalency mapping was performed. Achieved level 1."
    }
  ],
