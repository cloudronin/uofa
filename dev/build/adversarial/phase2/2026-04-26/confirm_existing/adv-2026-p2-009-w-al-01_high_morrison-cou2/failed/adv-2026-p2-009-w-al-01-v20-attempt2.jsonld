  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis prediction at MRL 5) concludes that the simulation evidence package is accepted for submission to the regulatory dossier. Monte Carlo UQ was performed across key input parameters and mesh convergence was demonstrated within the 5 % GCI criterion. Seven of thirteen credibility factors were formally assessed; six remain as documented epistemic gaps requiring future work. Achieved levels fall below required levels on all assessed factors, consistent with the Low assurance level designation. The experimental repeatability result relies on qualitative characterisation of blood-sample aleatory variability without a formal structured UQ link, a limitation noted in the evidence record. The package is accepted as the best available evidence at this stage of device development, with the understanding that the identified gaps must be addressed prior to final regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
