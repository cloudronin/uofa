  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required thresholds at MRL 5, the assessment team accepted the package on the basis that Monte Carlo UQ bounds the primary QoI within the clinical safety margin at the 95th percentile, and conservative model form choices (SST k-omega upper-bound predictor) provide additional margin. Experimental comparison variability was assessed qualitatively by subject matter experts as consistent with known donor-to-donor RBC fragility variation; however, no structured UQ node was linked to the experimental comparison result, leaving aleatory uncertainty in that result uncharacterized in the formal evidence chain.",
