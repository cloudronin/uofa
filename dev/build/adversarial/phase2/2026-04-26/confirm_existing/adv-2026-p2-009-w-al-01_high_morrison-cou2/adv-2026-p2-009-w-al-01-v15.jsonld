  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 certification and documented V&V test suite covering hemolysis-relevant flow regimes.",
      "rationale": "Solver holds ISO 9001 certification; internal V&V suite covers laminar and turbulent pipe flows but lacks dedicated rotating-machinery hemolysis benchmark. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests must be demonstrated for the turbulence model and scalar transport equation used in hemolysis calculation.",
      "rationale": "Order-of-accuracy verified for momentum equations; scalar transport (hemolysis power-law model) verified on simplified channel geometry only. Gap remains for rotating-frame scalar transport."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on at least three systematically refined meshes.",
      "rationale": "GCI reported as 7.2% for NIH on the finest mesh pair; a fourth refinement level was cost-prohibitive. Discretization error remains above the 5% threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must replicate VAD operating envelope including temperature, hematocrit, and anticoagulation protocol to within stated tolerances.",
      "rationale": "Temperature controlled to ±0.5 °C and hematocrit to ±1%; anticoagulation protocol matched clinical guidance. Minor deviations in pump inlet tubing geometry relative to COU configuration reduce achieved level to 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g. E_rel) computed for all QoIs with explicit uncertainty intervals; systematic bias identified and bounded.",
      "rationale": "Relative error metrics computed for velocity and pressure QoIs with Monte Carlo intervals. Hemolysis index comparison uses qualitative band assessment due to biological variability; structured metric with UQ interval absent for NIH output."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly traceable to clinical hemolysis threshold; NIH must be the primary reported quantity with direct mapping to patient-safety criterion.",
      "rationale": "NIH is the primary QoI and maps directly to the clinical threshold. Secondary QoIs (wall shear stress, velocity) support mechanistic understanding. Traceability documented but one intermediate mapping step relies on empirical power-law constants with uncharacterised epistemic uncertainty."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analogue, and operating conditions as the COU; any surrogate must be justified.",
      "rationale": "FDA generic centrifugal pump geometry used in validation matches COU geometry exactly. Bovine blood used as surrogate for human blood; species difference justified by established literature but introduces unquantified biological variability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and floating-point round-off must be documented and shown to be negligible relative to discretization error.",
      "rationale": "Residual convergence monitored but round-off error analysis not performed. Flagged as epistemic gap at MRL 5; not-assessed status retained."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second analyst; documented checklist covering boundary conditions, material properties, and solver settings.",
      "rationale": "Single analyst performed all simulations; independent review not conducted due to resource constraints. Use error therefore not formally assessed."
    },
