  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-flowfield-piv",
      "type": "ValidationResult",
      "name": "PIV flow-field velocity comparison — Monte Carlo UQ applied",
      "description": "Comparison of CFD-predicted velocity magnitude and secondary flow patterns against particle image velocimetry (PIV) measurements across 5 operating points. Monte Carlo sampling over inlet boundary condition uncertainty (±5% flow rate, ±2% rotational speed) yields 95th-percentile prediction intervals fully enclosing experimental scatter. Structured UQ characterization linked.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-flowfield-vad"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure rise validation — Monte Carlo UQ applied",
      "description": "CFD-predicted head-flow curves compared against bench-top pressure measurements at 3600 and 5000 RPM. Monte Carlo propagation of geometric tolerance uncertainty (±50 µm impeller clearance) quantified. Prediction intervals bound all experimental observations within ±8% of mean measured head.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-pressure-vad"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index",
      "type": "ValidationResult",
      "name": "Hemolysis index absolute level validation — inherent variability assessed qualitatively",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against in-vitro hemolysis measurements from three independent test runs using porcine blood. The inter-run biological variability in red blood cell fragility — driven by donor-to-donor differences in erythrocyte mechanical properties and storage duration — was acknowledged as a source of aleatory uncertainty. This variability was assessed qualitatively by the engineering team through review of the spread across test replicates and documented in the technical memo as 'within acceptable bounds for porcine blood surrogates.' No structured uncertainty quantification node was constructed for this validation result; the aleatory component remains uncharacterized in machine-readable form."
    }
  ],
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with regression test suite covering >90% of active code paths; documented release procedures.",
      "rationale": "The CFD solver (OpenFOAM v8) is version-controlled and regression-tested, but test suite coverage reaches approximately 72% of active hemolysis-model code paths. Release documentation is present but does not include formal sign-off from an independent reviewer, leaving a gap against the MRL-5 requirement for full independent verification of the SQA process."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on manufactured solutions for all active transport equations including the hemolysis power-law model.",
      "rationale": "Order-of-accuracy verification was completed for the Navier-Stokes and turbulence equations, confirming second-order spatial convergence. The hemolysis scalar transport equation was verified against an analytic solution only at a single mesh resolution; multi-resolution OOA confirmation is absent, yielding Gradation 3 rather than the required 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for hemolysis QoI on three systematically refined meshes; GCI < 5% on finest mesh.",
      "rationale": "Three-mesh Richardson extrapolation performed; GCI on the NIH quantity of interest is 7.3% on the finest 14M-cell mesh, exceeding the 5% threshold. A fourth refinement level was not feasible within project compute budget. Achieved level capped at 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with measurement uncertainty for all boundary condition parameters; fluid temperature controlled to ±0.5 °C.",
      "rationale": "Flow rate and rotational speed are documented with calibration traceability. Fluid temperature was monitored but not actively controlled; recorded variation of ±1.8 °C across test sessions exceeds the ±0.5 °C requirement. Blood viscosity temperature sensitivity introduces uncontrolled variability in the hemolysis measurements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metric (e.g., E% or NRMSE) reported with experimental uncertainty bounds for all QoIs; systematic bias separated from random error.",
      "rationale": "Normalized root-mean-square error reported for velocity and pressure QoIs. For the hemolysis NIH comparison, only a point estimate of mean error (12.4%) is reported without separation of systematic bias from inter-run random variability, preventing a complete quantitative assessment at the required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly map to clinical decision metric (absolute NIH); no surrogate QoI substitution without justification.",
      "rationale": "The primary validation QoI is the normalized index of hemolysis, which is the same metric used in the regulatory submission threshold comparison. No surrogate substitution was made. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry at COU operating conditions; fluid analogue demonstrated equivalent hemolytic response to clinical blood.",
      "rationale": "Experiments used the FDA generic pump geometry at the COU flow-speed envelope. Porcine blood was used as a surrogate; a formal equivalency study demonstrating matched hemolytic sensitivity relative to human blood at MRL-5 rigor has not been completed, resulting in a one-gradation gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to machine-precision-level residuals for all equations; time-step sensitivity study completed for transient impeller passage.",
      "rationale": "Steady-state residuals converge to 1e-5 for momentum and continuity. The hemolysis scalar residual stalls at 1e-3 in two of five operating points, indicating incomplete iterative convergence. Time-step sensitivity was not independently varied; a single time-step was used based on prior pump studies."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of simulation setup by a second analyst; checklist-based verification of boundary condition application and material property assignment.",
      "rationale": "A peer review of the simulation setup was conducted by a co-author rather than an independent analyst external to the project. The review checklist covered geometry and meshing but did not include explicit verification of hemolysis model constants, which were later found to differ from the published Giersiepen coefficients by a transcription error caught during manuscript review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity analysis across alternative turbulence and hemolysis model forms; model form uncertainty quantified relative to experimental data.",
      "rationale": "The k-ω SST turbulence model was selected based on prior pump literature without comparison to alternative closures (e.g., RSM or LES). The power-law hemolysis model (Giersiepen) was used without evaluation of the Arora or Taskin alternatives. Model form uncertainty is unquantified, representing a two-gradation gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions traced to primary measurement sources with documented uncertainty; sensitivity of hemolysis QoI to each input quantified.",
      "rationale": "Blood viscosity and density are drawn from published reference values with stated uncertainty ranges. Monte Carlo sensitivity analysis identifies rotational speed and inlet flow rate as dominant inputs. However, the hemolysis model exponent coefficients (α, β) are treated as fixed constants without uncertainty, despite known inter-study variability in their calibrated values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of five independent experimental replicates per operating condition; statistical characterization of inter-sample variability reported.",
      "rationale": "Three independent test runs were performed per operating condition using blood from separate porcine donors. This falls below the five-replicate minimum required at the assessed level. Inter-run coefficient of variation for NIH ranged from 18% to 31%, indicating substantial biological variability that the three-sample set is insufficient to characterize statistically."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Formal mapping between experimental boundary conditions and CFD boundary conditions; any deviations justified with sensitivity analysis showing negligible QoI impact.",
      "rationale": "Inlet velocity profiles in CFD are specified as uniform (plug flow) based on upstream pipe length assumptions. The experimental inlet condition was not directly measured; PIV data begins 2 cm downstream of the pump inlet. The assumption of fully developed turbulent profile at the CFD inlet was not validated against a measured profile, and sensitivity of NIH to inlet profile shape was not assessed."
    }
