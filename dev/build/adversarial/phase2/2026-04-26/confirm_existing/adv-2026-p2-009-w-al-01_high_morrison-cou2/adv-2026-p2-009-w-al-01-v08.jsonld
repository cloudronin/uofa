  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor gaps relative to MRL-5 requirements, the assessment team determined that the cumulative evidence is sufficient to support the intended regulatory submission under a risk-informed acceptance argument. Monte Carlo UQ on primary flow and pressure QoIs bounds prediction uncertainty within regulatory tolerance. The hemolysis index validation result exhibits inherent biological variability that was assessed qualitatively and judged acceptable given the conservative NIH threshold margin (predicted NIH 40% below clinical limit across all operating points). The team acknowledges that the aleatory uncertainty in hemolysis measurement variability has not been formally characterized via a structured UQ node for the hemolysis validation result; this gap is noted as a post-submission action item. All other factors are accepted with documented rationale for the achieved-vs-required level differences.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
