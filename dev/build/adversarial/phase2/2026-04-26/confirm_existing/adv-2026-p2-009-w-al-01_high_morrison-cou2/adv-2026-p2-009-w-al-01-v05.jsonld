  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed. Seven factors show achieved levels below required levels at MRL 5, consistent with the COU description of gaps remaining. Monte Carlo UQ performed for four of five operating points; the partial-load operating point (3 L/min, 3000 RPM) relies on qualitative characterization of aleatory uncertainty in RBC fragility rather than a structured UQ propagation — this gap is noted in the Output Comparison factor rationale and in the corresponding ValidationResult narrative. Despite this gap, the overall hemolysis predictions remain below the absolute clinical threshold across all operating points, and the credibility assessment team accepts the model for the stated COU with the documented limitations. Formal remediation of the partial-load UQ gap is recommended prior to next submission cycle.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
