  "name": "Morrison COU2 — VAD hemolysis credibility assessment",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under ventricular assist device (VAD) conditions. COU2 evaluates whether the computational model can predict absolute hemolysis levels for a Class III VAD device at Model Risk Level 5. Higher model risk drives stricter credibility requirements; Monte Carlo uncertainty quantification is performed for most validation activities but one result relies on qualitative variability assessment only. Full 13-factor assessment covering software quality, numerical verification, discretization error, test conditions, output comparison, QoI relevance, validation relevance, solver error, use error, model form, model inputs, test samples, and input parameter equivalency. Decision: Accepted.",
  "assuranceLevel": "Low",
  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-mrl5",
  "bindsClaim": "https://uofa.net/synth/claim/cfd-hemolysis-absolute-vad",
  "bindsModel": "https://uofa.net/synth/model/cfd-centrifugal-pump-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/vad-operating-conditions-5points"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-benchmark-mc",
      "type": "ValidationResult",
      "name": "Hemolysis index benchmark — Monte Carlo UQ",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against FDA generic pump experimental measurements at five operating points. Monte Carlo sampling over inlet velocity, viscosity, and RBC fragility parameters (N=2000 samples). 95% confidence intervals reported for all QoI.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-hemolysis-mc2000"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-shear-stress-distribution",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution — qualitative variability assessment",
      "description": "Predicted wall shear stress distributions compared against particle image velocimetry (PIV) measurements in the volute region. Spatial agreement assessed via normalized RMS error. Inherent variability in PIV measurements assessed qualitatively by the experimental team based on repeat-run scatter; no structured probabilistic UQ node was constructed for this result as variability was judged low by inspection. This result therefore relies on expert judgment rather than a formal uncertainty quantification chain."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-rise-validation",
      "type": "ValidationResult",
      "name": "Pump pressure rise — experimental comparison with UQ",
      "description": "Simulated total-to-total pressure rise compared against experimental measurements across all five flow-speed operating points. Uncertainty in experimental pressure transducer calibration propagated via interval arithmetic; model prediction intervals overlap experimental uncertainty bands at four of five operating points.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/pressure-rise-interval-arithmetic"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043671",
