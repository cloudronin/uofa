  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented V&V test suite with version-controlled regression tests and traceable issue log at Gradation 4.",
      "rationale": "Solver regression suite exists and is version-controlled; however, issue log traceability to specific code commits is incomplete for two solver modules. Achieved level falls one gradation below required for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using Method of Manufactured Solutions (MMS) for all governing equations relevant to hemolysis prediction.",
      "rationale": "MMS verification completed for Navier-Stokes momentum equations; scalar transport equation used for hemolysis power-law model not independently verified via MMS. Partial credit only."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) reported for all QoI on at least three systematically refined meshes.",
      "rationale": "GCI computed on three mesh levels for pressure and velocity QoI. Hemolysis index GCI computed on two levels only due to computational cost; extrapolated estimate carries higher uncertainty than required for MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions matched to simulation inputs within stated tolerances; fluid properties characterized at test temperature.",
      "rationale": "Flow rate and rotational speed controlled within 2% of nominal; fluid viscosity measured at 22°C while simulation assumes 37°C blood analog. Temperature-dependent viscosity correction not applied, introducing systematic offset in shear-sensitive hemolysis predictions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., normalized RMSE, validation metric per ASME V&V 20) computed for primary QoI with uncertainty bounds on both simulation and experiment.",
      "rationale": "Validation metric computed for NIH and pressure rise with full uncertainty bounds. Wall shear stress comparison uses normalized RMSE without formal experimental uncertainty characterization, limiting the completeness of the output comparison for that QoI."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation QoI directly correspond to COU decision QoI (absolute NIH); no surrogate quantities used as proxies without demonstrated correlation.",
      "rationale": "NIH is directly compared and is the primary COU QoI. Wall shear stress is a surrogate mechanistic indicator; its correlation to NIH under VAD conditions is supported by literature but not quantitatively demonstrated for this specific pump geometry."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry and at operating conditions spanning the COU envelope; blood analog fluid properties match clinical range.",
      "rationale": "Experiments use FDA generic pump geometry (matches COU) but fluid is glycerin-water analog rather than anticoagulated blood. Hematocrit effects on hemolysis not captured in validation dataset. Significant relevance gap for Class III VAD application."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated to residual levels below 1e-5 for all equations; round-off error assessed for double-precision arithmetic.",
      "rationale": "Residuals converge to 1e-4 for hemolysis scalar transport; momentum equations reach 1e-6. Solver documentation does not explicitly address round-off error accumulation over long transient simulations relevant to VAD duty cycles."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation setup checklist reviewed by independent analyst; boundary condition inputs traceable to experimental records.",
      "rationale": "Setup checklist exists but independent review was performed by a team member rather than an independent analyst. Boundary condition traceability is complete for inlet/outlet but not for rotating wall treatment parameters."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis power-law model selection justified with sensitivity analysis; alternative model forms evaluated.",
      "rationale": "k-omega SST turbulence model selected based on prior pump literature; no sensitivity analysis comparing SST to LES or RSM for this geometry. Hemolysis power-law constants from Giersiepen et al. used without evaluation of alternative damage accumulation models. Significant model form uncertainty uncharacterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; Monte Carlo propagation performed; sensitivity indices reported.",
      "rationale": "Monte Carlo UQ performed for inlet velocity, fluid viscosity, and RBC fragility parameters. Geometric tolerance inputs (impeller clearance, surface roughness) treated as deterministic nominal values; sensitivity of hemolysis predictions to these inputs not assessed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability; minimum sample size justified for detection of hemolysis differences at required confidence level.",
      "rationale": "Factor not assessed. Experimental dataset consists of single-run measurements at each operating point; no repeat measurements available to characterize sample-to-sample variability. This represents a significant epistemic gap at MRL 5 for a Class III device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstrated equivalency between validation experiment input parameters and COU input parameters across the full operating envelope.",
      "rationale": "Factor not assessed. Validation experiments conducted at three of five COU operating points; extrapolation to remaining two points relies on model prediction without experimental support. Equivalency of hematocrit, temperature, and anticoagulation state between experiment and COU not formally evaluated."
    }
  ],
