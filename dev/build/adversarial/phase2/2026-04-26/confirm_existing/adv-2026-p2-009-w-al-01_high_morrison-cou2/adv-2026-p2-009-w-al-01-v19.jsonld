  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 credibility factors assessed or flagged. Seven factors assessed with achieved levels below required levels for MRL 5; six factors either not assessed or assessed at minimal gradation. Monte Carlo UQ performed for primary hemolysis QoI and pressure rise validation results. Wall shear stress validation result relies on qualitative expert judgment of inherent variability rather than a structured UQ chain, which is noted as a gap. Despite multiple shortfalls, the overall evidence package is accepted as the basis for submission with the understanding that the identified gaps will be addressed in a subsequent credibility iteration prior to device clearance submission.",
