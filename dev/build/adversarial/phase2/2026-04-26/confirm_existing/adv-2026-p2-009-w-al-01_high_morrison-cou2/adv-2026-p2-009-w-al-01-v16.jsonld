  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V test suite with regression testing and version-controlled source. At MRL 5, independent third-party audit of SQA records required.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) has an internal regression test suite and ISO 9001-certified development process. However, independent third-party audit of SQA records was not completed for this submission cycle. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verification using method of manufactured solutions (MMS) must be demonstrated for all active physics modules including the hemolysis transport scalar. At MRL 5, verification must cover turbulence model implementation.",
      "rationale": "MMS verification was performed for Navier-Stokes and scalar transport. Turbulence model (SST k-omega) implementation verification was limited to published solver benchmarks rather than in-house MMS, yielding achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based grid convergence index (GCI) must be reported for all QoIs at MRL 5. Three systematically refined meshes required with GCI < 5% on hemolysis index.",
      "rationale": "Three-mesh Richardson extrapolation was performed. GCI on hemolysis index was 7.2%, exceeding the 5% threshold. Pressure rise GCI was 2.1% (acceptable). Overall achieved level 3 against required level 4 due to hemolysis GCI exceedance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be measured and reported with full uncertainty budgets traceable to NIST standards. Temperature, viscosity, and inlet flow profiles must be characterized.",
      "rationale": "Flow rate and pressure boundary conditions were measured with NIST-traceable instrumentation. Fluid temperature was monitored but viscosity of the blood-analog fluid was assigned from literature rather than measured in-situ, introducing an unquantified source of condition mismatch. Achieved level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative validation metrics (E%, NRMSE, U95) must be reported with uncertainty intervals for all QoIs. At MRL 5, validation must include statistical hypothesis testing against experimental scatter.",
      "rationale": "Normalized hemolysis index error was 18% at the worst-case operating point, exceeding the 10% acceptance threshold established for MRL 5. Statistical hypothesis testing was not performed. PIV velocity comparison was qualitative. Achieved level 2 against required level 4 — the largest credibility gap in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly traceable to the clinical endpoint (hemolysis index) and must be the same quantities used in the regulatory submission.",
      "rationale": "The normalized index of hemolysis (NIH) is directly used as both the validation QoI and the regulatory submission metric. Full traceability documented. Achieved level 4 meets required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry and at operating conditions spanning the full COU envelope. Blood-analog fluid must be validated as physiologically representative.",
      "rationale": "Validation used the FDA generic pump geometry, which is representative but not identical to the submission device. Operating conditions covered 4 of 5 COU points; one high-speed condition was not experimentally validated due to test rig limitations. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-6 for all equations. Time-step sensitivity must be assessed for transient simulations.",
      "rationale": "Steady-state residuals converged to 1e-5 for momentum and continuity; hemolysis scalar residual stalled at 3e-5 at two operating points. Time-step sensitivity was not assessed for the quasi-steady impeller rotation approximation. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst not involved in model development. Boundary condition application and material property assignment must be audited.",
      "rationale": "An internal peer review was conducted but the reviewer was a member of the same project team. Independent external review was not performed. Two boundary condition inconsistencies were identified and corrected during internal review, suggesting use error risk remains. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model and turbulence closure must be justified against published literature and sensitivity of predictions to model form alternatives must be demonstrated.",
      "rationale": "The Giersiepen-Wurzinger hemolysis power-law was selected without comparison to alternative models (e.g., Arora or Farinas formulations). SST k-omega turbulence model was used without sensitivity analysis versus k-epsilon or LES. Model form uncertainty is the dominant unresolved gap at MRL 5. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources with uncertainty ranges. Monte Carlo or equivalent propagation must cover all significant input uncertainties for hemolysis QoI.",
      "rationale": "Monte Carlo UQ covered inlet flow rate, rotational speed, and fluid viscosity. Hemolysis model coefficients (alpha, beta, C in power-law) were treated as fixed values from a single literature source rather than as uncertain parameters with distributions. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test samples (blood-analog fluid batches) must be characterized for rheological properties with batch-to-batch variability reported. Minimum three independent experimental runs required.",
      "rationale": "Two independent experimental runs were performed rather than the required three. Batch-to-batch variability in glycerol-water blood-analog viscosity was reported for one batch only. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrated equivalent to experimental conditions within stated uncertainty bounds. Any mismatch must be quantified and its effect on QoI assessed via sensitivity analysis.",
      "rationale": "Rotational speed equivalency was confirmed within 0.5%. Inlet flow profile equivalency was assumed (fully developed pipe flow) rather than measured; PIV data suggested inlet profile had a 12% asymmetry not captured in the simulation boundary condition. Sensitivity of hemolysis prediction to inlet profile asymmetry was not assessed. Achieved level 2 against required level 4."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-mrl5-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment is formally recorded as Accepted for package integrity purposes. However, the substantive finding is that credibility is insufficient for regulatory submission at MRL 5: achieved levels fall below required levels on 11 of 13 factors, with critical gaps in model form (achieved 2, required 4), output comparison (achieved 2, required 4), and equivalency of input parameters (achieved 2, required 4). Additionally, the PIV velocity benchmark validation result characterizes inherent aleatory variability in experimental measurements qualitatively only; no structured uncertainty quantification node is linked to that result, leaving aleatory uncertainty uncharacterized in machine-readable form. Remediation plan required before resubmission: (1) independent MMS verification of turbulence implementation, (2) three-mesh GCI below 5% on hemolysis index, (3) model form sensitivity study across at least two hemolysis power-law formulations, (4) structured UQ node generated for PIV benchmark result, (5) third independent experimental run with batch characterization.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
