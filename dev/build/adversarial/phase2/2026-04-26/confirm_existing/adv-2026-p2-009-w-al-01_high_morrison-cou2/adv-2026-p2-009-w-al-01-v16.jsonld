    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-5op-montecarlo",
      "type": "ValidationResult",
      "name": "Hemolysis index validation across 5 operating points with Monte Carlo UQ",
      "description": "CFD-predicted normalized index of hemolysis compared against experimental measurements at 5 flow-speed combinations. Monte Carlo sampling over inlet boundary conditions and viscosity parameters yielded 95% prediction intervals. Structured uncertainty quantification performed and linked.",
      "hasUncertaintyQuantification": "https://uofa.net/synth/uq/monte-carlo-hemolysis-5op"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-piv-benchmark",
      "type": "ValidationResult",
      "name": "Velocity field benchmark against PIV measurements — inherent variability assessed qualitatively",
      "description": "Particle image velocimetry (PIV) measurements in the pump volute at design-point conditions were compared against CFD velocity predictions. Agreement was assessed via normalized RMS error metrics. Inherent variability in experimental PIV data (arising from seeding density fluctuations, laser sheet alignment, and cycle-to-cycle biological variability in the blood-analog fluid) was acknowledged in the narrative but characterized only qualitatively by the assessment team. No structured uncertainty quantification node was generated for this result; aleatory uncertainty in the PIV benchmark therefore remains uncharacterized in machine-readable form."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-pressure-rise-validation",
      "type": "ValidationResult",
