  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. The Test conditions factor achieves level 2 against a required level of 3; this gap is accepted given the quasi-static single-condition nature of ASTM F1717 and the absence of rate-dependent failure modes in the COU. All QoI acceptance criteria satisfied (E/uval < 1.96; relative error < 10%). The supplemental parametric simulation sweep corroborates the experimental findings and is considered supportive evidence. Overall credibility is sufficient to support submission of the FEA results for the non-cannulated 7.5 mm pedicle screw design.",
    "decidedAt": "2026-04-19T00:00:00Z"
