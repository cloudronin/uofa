  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single gap (Test conditions, achieved 2 vs. required 3) is accepted on the basis that the single F1717 load configuration is the regulatory standard configuration and additional load levels are not required by the predicate device submission. The FEA ensemble predictions satisfy all quantitative acceptance criteria. The numerical-simulation activity used to generate the primary validation result is argued to be functionally equivalent to a prospective experimental-validation campaign because it is cross-validated against an archived N=11 bench dataset; the assessment team therefore considers the verification method requirement satisfied. Overall credibility is sufficient to support a Medium model risk level decision at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
