  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level. The single below-threshold factor (Test conditions, achieved 1 vs. required 2) is considered acceptable given that the ASTM F1717 protocol prescribes a single quasi-static condition and no regulatory precedent requires multi-rate testing for this device class. All three QoIs pass the E/uval < 1.96 criterion. The simulation ensemble demonstrates high inter-code consistency (CV < 2%), and the assessment team judges the overall evidence package sufficient to support a Medium assurance-level acceptance decision for the non-cannulated construct compression-bending COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
