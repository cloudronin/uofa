  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved 2 vs required 3) is accepted given the static-loading COU scope and the conservative nature of quasi-static ASTM F1717 testing relative to physiological loading. All three primary QoIs satisfy pre-established quantitative acceptance bounds (E/uval < 1.96; relative difference < 10%). The high-fidelity numerical simulation ensemble is judged by the assessment team to provide validation evidence of equivalent rigour to independent experimental testing, supporting an Accepted decision.",
