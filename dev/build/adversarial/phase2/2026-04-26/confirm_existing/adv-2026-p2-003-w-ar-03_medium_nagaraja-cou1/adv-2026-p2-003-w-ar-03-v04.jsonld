  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-noncannulated-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-fda-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level. The single below-required factor (Test conditions, achieved 2 vs. required 3) is accepted given the standardized and well-characterized nature of the ASTM F1717 protocol. All three QoIs satisfy the pre-established quantitative acceptance criteria (E/uval < 1.96; relative error < 10%). The simulation ensemble is judged sufficiently credible for its intended use in the regulatory submission. Note: validation evidence was generated via parametric FEA sweeps whose outputs are treated as equivalent to experimental reference data; the V&V plan required experimental-validation as the primary evidence type, but the assessment team has accepted the numerical-simulation activity outputs as functionally equivalent for each QoI comparison.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
