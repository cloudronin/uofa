  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieved level 2 against a required level of 3; this gap is accepted based on regulatory precedent for single-condition ASTM F1717 submissions and the low model influence classification. The primary validation evidence (inter-code numerical cross-check showing < 2% inter-code deviation) was judged by the assessment team to be functionally equivalent to direct experimental validation, providing confidence that E/uval < 1.96 for all primary QoIs. Overall credibility is sufficient to support a Medium assurance level decision for the non-cannulated pedicle screw compression-bending COU.",
