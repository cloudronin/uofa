  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-nc-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieved level 2 against a required level of 3 due to the single-condition ASTM F1717 test protocol; this gap is accepted given corroborating analytical sensitivity studies and the conservative nature of the F1717 loading regime. All three QoIs satisfy pre-established quantitative acceptance bounds (percentage difference < 10%, E/uval < 1.96). The FEA framework is assessed as sufficiently credible to support regulatory submission for the non-cannulated 7.5 mm pedicle screw construct under static compression-bending.",
    "decidedAt": "2026-04-19T00:00:00Z"
