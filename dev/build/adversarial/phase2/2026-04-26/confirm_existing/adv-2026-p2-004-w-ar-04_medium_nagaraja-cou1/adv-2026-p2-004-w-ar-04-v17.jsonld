  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted. All 13 V&V 40 factors were assessed. Twelve of thirteen factors meet or exceed their required credibility levels. The single factor below required level (Test conditions, achieved 2 vs. required 3) is accepted based on the standardized nature of ASTM F1717 and regulatory precedent for pedicle screw submissions. The three QoIs satisfy both quantitative acceptance criteria (<10% percent difference, E/uval < 1.96) across N=11 constructs at two independent laboratories. The FEA modeling framework is assessed as credible for the stated COU.",
