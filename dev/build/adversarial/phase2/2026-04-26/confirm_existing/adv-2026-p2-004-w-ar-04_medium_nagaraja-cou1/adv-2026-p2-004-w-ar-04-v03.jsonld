  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors were assessed. Twelve factors meet or exceed the required level. One factor (Test conditions) achieves Gradation 1 against a required Gradation 2; however, the remaining factors provide sufficient margin, and the ASTM F1717 protocol is the accepted regulatory standard for this device class. All three QoIs satisfy the pre-established acceptance bounds (E/uval < 1.96; QoI difference < 10%). The FEA modeling framework is judged credible for the stated COU at Medium assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
