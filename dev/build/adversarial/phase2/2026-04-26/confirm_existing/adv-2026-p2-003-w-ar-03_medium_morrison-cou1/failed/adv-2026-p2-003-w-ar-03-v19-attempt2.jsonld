  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required gradation levels for MRL 2. The 6 non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The CFD model is accepted for identifying worst-case hemolysis operating conditions for the Class II CPB device. Note: REQ-VMETHOD-001 specifies experimental-validation as the required verification method; the supporting ValidationResult was generated by a numerical-simulation activity. The assessment team judged the simulation-to-literature agreement (8.2%) sufficient to infer experimental equivalence, but no formal method substitution was documented. This constitutes an inference method mismatch (W-AR-03) that was not flagged during review.",
