  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. Six factors are not assessed, consistent with MRL 2 scope. The validation team concludes that the high-fidelity LES simulation, anchored to FDA benchmark experimental data, provides sufficient evidence to support the hemolysis prediction claim (RH < 1 at worst-case operating conditions). The team notes that the governing requirement specifies experimental-validation as the required verification method; the supporting activity was conducted as a numerical-simulation. The team asserts this is functionally equivalent given the FDA benchmark anchoring, but this assertion is made in narrative only and is not reflected in the structured activity metadata, which records activityType as numerical-simulation throughout. The credibility package is accepted at Medium assurance level for the Class II CPB COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
  "uofa:requirement": {
    "id": "https://uofa.net/synth/req/cpb-hemolysis-req-001",
    "type": "Requirement",
    "name": "Hemolysis prediction verification requirement",
    "description": "The CFD model used to predict pump-induced hemolysis for the Class II CPB device shall be verified by experimental-validation against physical bench test data obtained under conditions representative of the COU operating envelope. Simulation-only evidence shall not substitute for experimental verification without formal equivalence demonstration approved by the credibility assessment authority.",
    "requiredVerificationMethod": "experimental-validation",
    "requirementText": "Verification of the hemolysis prediction model shall be accomplished through experimental-validation. The relative hemolysis index (RH) predicted by the model shall be compared against measured RH values from a physical blood-loop experiment conducted at the five designated flow-speed operating points. Agreement within 20% is required for credibility acceptance at MRL 2.",
    "source": "https://doi.org/10.1115/1.4034918"
  },
