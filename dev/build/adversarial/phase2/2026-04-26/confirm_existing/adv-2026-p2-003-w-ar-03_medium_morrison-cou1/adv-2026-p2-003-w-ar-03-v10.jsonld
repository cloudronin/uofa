  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The CFD model predicts RH below 1.0 across all five CPB operating points. The assessment team concluded that the high-fidelity numerical simulation, supported by published model-form validation studies, provides sufficient confidence in the output comparison factor. The team acknowledged that the output comparison requirement specifies experimental-validation but asserted the simulation results are of equivalent evidentiary weight given the calibrated sub-models employed. The six non-assessed factors are consistent with MRL 2 scoping. Overall credibility is judged sufficient to support the regulatory submission for the Class II CPB device.",
