  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that all seven assessed factors meet or exceed the required levels for MRL 2. The high-fidelity CFD reference comparison demonstrated RH prediction agreement within 8%, satisfying the output comparison acceptance criterion. The team accepted the argument that the reference numerical simulation provides equivalent evidentiary value to a physical experiment for the purpose of hemolysis index validation, given the maturity of the reference model and the consistency of results across all five operating points. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The overall credibility package is accepted to support regulatory submission.",
