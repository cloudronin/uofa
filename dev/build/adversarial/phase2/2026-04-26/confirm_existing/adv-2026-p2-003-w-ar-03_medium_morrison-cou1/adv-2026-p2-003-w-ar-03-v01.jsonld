  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors met or exceeded their required levels for MRL 2. The CFD model demonstrated adequate discretization control (GCI 1.8%), appropriate model form selection, and consistent QoI predictions across the CPB operating envelope. Output comparison against the high-fidelity reference simulation confirmed RH < 1.0 at all operating points with deviation below 5%. The reference simulation, calibrated against published experimental hemolysis data, was judged to provide a sufficiently rigorous basis for validation given the maturity of the hemolysis modeling approach. Six factors were not assessed, consistent with MRL 2 requirements for a Class II device. The credibility package is accepted for submission in support of the regulatory hemolysis safety argument.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
