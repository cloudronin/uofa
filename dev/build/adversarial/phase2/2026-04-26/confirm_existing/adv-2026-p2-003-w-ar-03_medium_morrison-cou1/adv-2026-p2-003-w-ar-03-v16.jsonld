  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-decision-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. The CFD model reliably predicts RH index below the 1.0 acceptance threshold across all five operating points, and dimensional sensitivity analysis confirms tolerance limits are appropriate. The numerical simulation activity is judged to provide sufficient validation evidence because the flow regime is well-characterised and GCI is below 2 %. The package is accepted for submission to regulatory review.",
    "decidedAt": "2026-04-19T00:00:00Z"
