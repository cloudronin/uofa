  "activities": [
    {
      "id": "https://uofa.net/synth/activity/cfd-simulation-rh-sweep-01",
      "type": "Activity",
      "name": "CFD parametric RH index sweep — 5 operating points",
      "description": "High-fidelity CFD simulation campaign covering all five clinical flow-speed operating points using the validated SST k-omega turbulence model on a 14.3 million cell mesh. Hemolysis scalar transport equation solved using the Giersiepen power-law model. Results post-processed to compute RH index for each operating point and across the manufacturing tolerance band. The simulation results are considered by the assessment team to be functionally equivalent to experimental bench measurements given the demonstrated GCI of 1.18 % and strong agreement with the FDA reference dataset.",
      "activityType": "numerical-simulation",
      "performedBy": "https://uofa.net/synth/org/morrison-simulation-lab",
