  "requirements": [
    {
      "id": "https://uofa.net/synth/req/hemolysis-validation-req-01",
      "type": "Requirement",
      "name": "Hemolysis model validation requirement",
      "description": "The CFD hemolysis model shall be validated against physical experimental data obtained from a bench-top pump loop using bovine blood surrogate under the five specified operating conditions. Validation evidence must be generated through direct experimental measurement of RH index.",
      "requiredVerificationMethod": "experimental-validation",
      "acceptanceCriteria": "RH index predicted by the model must agree with experimentally measured RH values within ±15 % at all five operating points, and all predicted RH values must remain below 1.0."
    }
