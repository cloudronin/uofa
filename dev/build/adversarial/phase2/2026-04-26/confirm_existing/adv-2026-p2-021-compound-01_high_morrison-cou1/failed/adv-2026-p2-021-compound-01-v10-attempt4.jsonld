  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 certification or equivalent documented QMS covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under an ISO 9001-certified quality management system. Version control records, regression test suite results (greater than 2400 test cases), and release notes are archived. Achieved level 2 is consistent with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least two canonical benchmark problems (e.g., lid-driven cavity, Poiseuille flow) with discretization errors within published reference tolerances.",
      "rationale": "ANSYS Fluent code verification documented against the ASME V&V 20 lid-driven cavity benchmark and a rotating-disk Poiseuille benchmark. Errors in both cases are within 0.5% of reference solutions at the mesh densities used in production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH quantity of interest must be less than 5% using Richardson extrapolation on at least three systematically refined meshes.",
      "rationale": "Three mesh levels (3.2 M, 8.7 M, and 21.4 M cells) were evaluated. Richardson extrapolation yields GCI of 3.1% for NIH at the worst-case operating point (6 L/min, 2400 RPM), satisfying the less than 5% acceptance criterion. Mesh independence declared at 8.7 M cells."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be replicated in simulation within documented measurement uncertainty.",
      "rationale": "All five experimental operating points replicated in CFD with inlet flow rate set to measured values (uncertainty plus or minus 0.05 L/min), rotational speed matched to tachometer readings (uncertainty plus or minus 5 RPM), fluid temperature 37 plus or minus 0.5 degrees C, and hematocrit 33 plus or minus 1%. Boundary condition fidelity documented in simulation setup report SR-2024-07."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH comparison metric must demonstrate mean relative error less than 15% and no individual operating point error exceeding 25%.",
      "rationale": "NIH predictions compared against experimental measurements at all five operating points. Mean relative error 8.3%; maximum individual error 14.1% at the 4 L/min, 1800 RPM point. Both acceptance criteria satisfied. Comparison documented in validation report VR-2024-09."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation (NIH, pressure head, wall shear stress) must be mechanistically linked to the COU decision quantity (relative hemolysis index RH).",
      "rationale": "NIH is directly used to compute RH via the Heuser-Opitz power-law model. Pressure head validates hydrodynamic fidelity underpinning shear field accuracy. Wall shear stress validates the stress tensor field from which hemolysis exposure is integrated. All three quantities are mechanistically linked to RH and are appropriate for MRL 2 assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry (FDA generic centrifugal pump) and operating envelope as the COU, with fluid properties representative of clinical CPB conditions.",
      "rationale": "Validation experiments conducted on the FDA generic centrifugal blood pump — the identical geometry used in the COU simulations. Operating points span the clinical CPB envelope (3 to 6 L/min, 1800 to 2400 RPM). Bovine blood at physiological hematocrit (33%) used as surrogate for human blood, consistent with FDA guidance for hemolysis testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver convergence to residual tolerance 1e-6 accepted as sufficient control.",
      "rationale": "At MRL 2, explicit numerical solver error quantification beyond convergence residual monitoring is not required. All simulations converged to residual tolerance of 1e-6 for continuity, momentum, and turbulence equations. Iterative error deemed negligible relative to discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst training records and peer review of simulation setup accepted as sufficient control.",
      "rationale": "Use error formally scoped out at MRL 2. Analyst holds PhD in computational fluid dynamics with 8 years of cardiovascular CFD experience. Simulation setup independently reviewed by a senior engineer. No evidence of use error identified during peer review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence model selection justified by literature precedent for similar rotating blood-contacting devices.",
      "rationale": "k-omega SST turbulence model selected based on published literature for centrifugal blood pump CFD (Fraser et al. 2011, Hariharan et al. 2011). Model form uncertainty not formally quantified at MRL 2 but acknowledged as a known source of epistemic uncertainty in the assessment scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values from literature and device specifications accepted without full sensitivity sweep.",
      "rationale": "Blood viscosity (0.0035 Pa-s), density (1060 kg/m3), and Heuser-Opitz hemolysis model constants taken from published values. Full parametric sensitivity analysis not required at MRL 2. Partial sensitivity to viscosity documented in the pressure-head UQ analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; sample characterization (hematocrit, age of blood) documented in experimental protocol.",
      "rationale": "Bovine blood samples characterized for hematocrit (33 plus or minus 1%), age at test (less than 48 hours post-collection), and storage conditions per ASTM F1841. Statistical variability across samples not formally propagated into NIH uncertainty at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; geometric equivalency between CAD model and physical pump confirmed by CMM inspection report.",
      "rationale": "Pump geometry used in CFD derived from manufacturer CAD files. CMM inspection of the physical test pump confirmed dimensional agreement within 0.05 mm on all critical surfaces. Full equivalency analysis of all input parameters not required at MRL 2."
