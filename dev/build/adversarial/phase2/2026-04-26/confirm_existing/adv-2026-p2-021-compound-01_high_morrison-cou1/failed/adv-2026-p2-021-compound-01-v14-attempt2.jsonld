  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented verification test suite and version-controlled source; all simulation scripts under version control with audit trail.",
      "rationale": "ANSYS Fluent 2022R2 used; vendor-supplied verification and validation documentation (ANSYS V&V 900-2012 compliance report) confirms Gradation 2 SQA. All case files and UDFs maintained in institutional Git repository with tagged release corresponding to this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must reproduce manufactured solution or benchmark analytical result to within 1% for relevant flow regime.",
      "rationale": "ANSYS Fluent passes the Taylor-Green vortex manufactured solution benchmark at second-order spatial accuracy. Vendor benchmark suite includes rotating machinery cases demonstrating < 0.8% error against analytical Couette flow solution. Satisfies MRL 2 code verification requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for primary QoI (RHI) on at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study performed: coarse (4.2M cells), medium (11.7M cells), fine (31.4M cells). GCI for volume-averaged hemolysis index: 3.8% (medium-to-fine). Asymptotic convergence ratio p = 1.94 confirms near-second-order convergence. Exceeds MRL 2 requirement; achieves Gradation 3 performance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) must be reproduced in simulation to within ± 5% of measured values.",
      "rationale": "FDA benchmark experimental conditions fully documented in Stewart et al. (2012). Inlet flow rates matched to ± 1.2%; rotational speeds matched to ± 0.8%; blood analog fluid (aqueous glycerol, 40% v/v) viscosity and density reproduced at 37°C. All 5 operating points replicated within tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RHI must agree with experimental measurements within ± 15% at all 5 operating points; pressure-head within ± 5 mmHg.",
      "rationale": "RHI predictions: mean absolute error 8.3%, maximum 13.1% at 6 L/min / 2000 RPM operating point. Pressure-head: mean absolute error 4.1 mmHg. Both QoIs satisfy acceptance criteria at all operating points. Systematic over-prediction of hemolysis at low-speed conditions noted and attributed to turbulence model limitations at transitional Re."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoIs must directly support the COU decision (worst-case hemolysis identification); RHI must be the primary output metric.",
      "rationale": "Relative hemolysis index (RHI) is the regulatory acceptance metric per FDA guidance on hemolysis testing. Volume-averaged and peak WSS are intermediate QoIs directly feeding the Giersiepen-Wurzinger hemolysis power law. All validated outputs directly relevant to worst-case operating condition identification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow regime, and fluid properties must be sufficiently similar to COU device and operating conditions to support extrapolation.",
      "rationale": "FDA generic centrifugal pump geometry is a recognized benchmark for Class II CPB devices. Validation flow rates (2–6 L/min) and speeds (2000–3500 RPM) span the COU operating envelope. Blood analog fluid validated against bovine blood hemolysis data in literature. Geometric similarity index (GSI) > 0.85 relative to target device."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; iterative convergence monitoring sufficient.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals converged to < 1e-5 for all equations; mass imbalance < 0.01% in all cases. Factor scoped out per MRL 2 requirements table."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification documentation sufficient.",
      "rationale": "Lead analyst holds PhD in biomedical engineering with 8 years CFD experience; co-analyst independently reviewed all boundary condition setups. Formal use-error assessment not required at MRL 2 per ASME V&V 40-2018 Table 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis constitutive model must be justified against available literature and benchmark data for rotating blood-contacting devices.",
      "rationale": "SST k-omega selected based on comparative study by Hariharan et al. (2011) demonstrating superior performance for centrifugal pump flows over k-epsilon variants. Giersiepen-Wurzinger hemolysis power law validated against in-vitro Couette device data. Model form uncertainty estimated at ± 12% on RHI via literature comparison."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sensitivity of RHI to key input parameters (viscosity, inlet velocity profile, rotational speed) must be characterized; dominant inputs identified.",
      "rationale": "One-at-a-time sensitivity analysis performed on 6 input parameters. Viscosity and inlet turbulence intensity identified as dominant inputs (Sobol first-order indices 0.31 and 0.24 respectively). Rotational speed tolerance (± 10 RPM) contributes < 2% RHI variation. Input ranges derived from manufacturer specifications and experimental measurement uncertainty."
    },
