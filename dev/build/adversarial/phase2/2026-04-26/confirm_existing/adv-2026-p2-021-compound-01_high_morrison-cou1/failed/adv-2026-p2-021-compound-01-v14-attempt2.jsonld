      "type": "ValidationResult",
      "name": "Pump pressure-head curve validation — secondary QoI",
      "description": "Predicted pressure-head curves compared against in-vitro measurements for the same 5 operating points. Mean absolute error 4.1 mmHg (< 5 mmHg acceptance criterion). This result provides additional confidence in the flow-field fidelity underpinning the hemolysis predictions. Grid convergence index (GCI) reported for pressure head at each operating point."
    },
    {
      "id": "https://uofa.net/synth/validation/shear-stress-distribution-vr03",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution — tertiary QoI for hemolysis model",
      "description": "Volume-averaged and peak wall shear stress values compared against particle-image velocimetry (PIV) measurements in the impeller region. Peak WSS prediction within 11% of PIV measurement at 3500 RPM. Supports validity of stress-based hemolysis model (Giersiepen-Wurzinger power law) applied in post-processing.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/shear-stress-uq03",
        "type": "UncertaintyQuantification",
        "method": "Richardson extrapolation on three mesh refinement levels; GCI < 2.1% for volume-averaged WSS at all operating points.",
        "coverageProbability": 0.95
      }
    }
