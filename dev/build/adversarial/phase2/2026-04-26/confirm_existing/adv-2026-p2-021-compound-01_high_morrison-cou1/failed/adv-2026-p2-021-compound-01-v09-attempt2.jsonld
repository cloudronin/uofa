  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cpb-hemo-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required Gradation levels for MRL 2. Six factors accepted at Gradation 1 (not-assessed) in accordance with MRL 2 requirements per ASME V&V 40-2018 Table 3. Discretization error exceeds requirements at Gradation 3. Validation against FDA benchmark data demonstrates RH prediction within ±15% acceptance band at all five COU operating points. Worst-case operating condition (2.5 L/min / 3000 RPM) correctly identified. Model credibility is sufficient to support the regulatory submission decision for this Class II CPB device.",
