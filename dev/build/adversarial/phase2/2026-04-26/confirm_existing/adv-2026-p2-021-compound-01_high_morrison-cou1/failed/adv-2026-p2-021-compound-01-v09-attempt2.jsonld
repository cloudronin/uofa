      "id": "https://uofa.net/synth/validation/vr-pump-flow-validation-001",
      "type": "ValidationResult",
      "name": "CFD pump flow-field validation against PIV measurements",
      "description": "Particle image velocimetry (PIV) measurements acquired in the FDA generic pump were compared against steady-state CFD predictions at three operating points (2.5, 5.0, 7.5 L/min; 2000 RPM). Velocity magnitude agreement within 8% RMS across the impeller passage. Pressure-rise predictions within 4% of measured values.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/uq-pump-flow-001",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo propagation of inlet boundary condition uncertainty (±5% flow rate, ±2% rotational speed). 95th-percentile band on velocity magnitude: ±6.2%. Experimental measurement uncertainty estimated at ±3.1% (95% CI) from repeated PIV acquisitions.",
        "coverageProbability": 0.95
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-validation-002",
      "type": "ValidationResult",
      "name": "Relative hemolysis index (RH) prediction validation against in-vitro blood damage data",
      "description": "Predicted normalized index of hemolysis (NIH) values from the Giersiepen power-law scalar transport model were compared against in-vitro loop measurements at five flow-speed combinations. RH ratios computed relative to predicate device. CFD predictions of RH fell within ±15% of measured values across all five conditions; worst-case operating point correctly identified at 2.5 L/min / 3000 RPM.",
      "validationMetric": "Relative hemolysis index RH = NIH_device / NIH_predicate; acceptance criterion RH < 1.0 at all five operating points.",
      "passFailOutcome": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-convergence-003",
      "type": "ValidationResult",
      "name": "Grid convergence study — discretization error quantification",
      "description": "Richardson extrapolation performed across three systematically refined meshes (4.2M, 11.6M, 28.9M cells). Grid convergence index (GCI) for the shear-stress scalar used in the hemolysis model: GCI_fine = 1.8% on the impeller-outlet plane. Asymptotic range confirmed (GCI_ratio = 1.03). Discretization error accepted as negligible relative to model-form uncertainty.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/uq-mesh-gci-003",
        "type": "UncertaintyQuantification",
        "method": "Richardson extrapolation / Grid Convergence Index per Celik et al. (2008). Safety factor Fs = 1.25 applied. GCI_fine = 1.8%; GCI_medium = 6.4%. Monotonic convergence confirmed.",
        "coverageProbability": 0.95
      }
    }
