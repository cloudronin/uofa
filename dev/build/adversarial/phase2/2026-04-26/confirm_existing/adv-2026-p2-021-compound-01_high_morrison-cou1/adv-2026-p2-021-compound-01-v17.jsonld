      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/wss-uq",
        "type": "UncertaintyQuantification",
        "method": "Sensitivity analysis across turbulence model variants and inlet turbulence intensity (1–5%). Latin hypercube sampling with 200 samples; 90th-percentile bound on peak WSS reported.",
