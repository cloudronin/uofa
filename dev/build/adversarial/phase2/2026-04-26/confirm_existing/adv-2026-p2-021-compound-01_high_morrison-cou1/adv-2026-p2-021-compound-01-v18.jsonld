  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required Gradation levels for MRL 2. Six factors appropriately scoped out per credibility plan CP-2023-01. Worst-case RH index 0.87 satisfies the RH < 1 acceptance criterion across all five operating-point combinations. Discretization error (GCI < 3.1%) and input uncertainty (LHS 90th-percentile RH 0.91 < 1.0) provide adequate confidence margin. The credibility assessment team concludes the CFD model is fit for the stated COU at the specified model risk level.",
