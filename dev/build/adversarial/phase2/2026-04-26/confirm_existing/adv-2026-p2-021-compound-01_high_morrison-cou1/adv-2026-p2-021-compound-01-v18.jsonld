    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined a priori; simulated QoIs compared to experimental measurements with statistical assessment.",
      "rationale": "Comparison metric defined as relative error on NIH and pressure head. Mean relative error 4.1% on pressure head; NIH within experimental coefficient of variation (18%) for 5/6 conditions. U95 validation metric computed per ASME V&V 20. Meets Gradation 2."
