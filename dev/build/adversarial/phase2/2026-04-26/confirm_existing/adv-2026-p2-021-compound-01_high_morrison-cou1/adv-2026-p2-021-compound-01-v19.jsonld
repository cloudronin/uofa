  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-01-hemolysis-benchmark",
      "type": "ValidationResult",
      "name": "FDA benchmark hemolysis index comparison — 5 operating points",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against published FDA benchmark experimental data at five flow-speed combinations (2 L/min at 2000 RPM, 3 L/min at 2500 RPM, 4 L/min at 3000 RPM, 5 L/min at 3500 RPM, 6 L/min at 4000 RPM). Relative hemolysis index RH computed as ratio of predicted NIH to experimental NIH; all five points satisfy RH < 1 acceptance criterion. Mesh sensitivity study with three refinement levels confirms grid-independent solution. Turbulence model (SST k-ω) validated against particle image velocimetry velocity fields.",
      "validationMetric": "Relative hemolysis index RH = NIH_CFD / NIH_exp < 1.0 at all five operating points",
      "validationOutcome": "Pass",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-01-hemolysis-benchmark",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo propagation of inlet flow rate uncertainty (±3%) and rotational speed uncertainty (±0.5%); 1000 samples; 95th-percentile confidence band on RH reported as ±0.07",
        "coverageProbability": 0.95
      }
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-02-velocity-field",
      "type": "ValidationResult",
      "name": "PIV velocity field validation — impeller exit plane",
      "description": "Ensemble-averaged PIV measurements at the impeller exit plane (r = 22 mm) compared against SST k-ω CFD predictions at the 4 L/min, 3000 RPM operating point. Radial and tangential velocity components extracted at 36 angular positions. Mean absolute error in radial velocity 4.1% of tip speed; tangential velocity MAE 5.8% of tip speed. Both within the ±10% acceptance band specified in the validation plan. Wall shear stress distribution qualitatively consistent with experimental dye-injection flow visualisation.",
      "validationMetric": "Mean absolute velocity error < 10% tip speed at impeller exit plane",
      "validationOutcome": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-03-pressure-rise",
      "type": "ValidationResult",
      "name": "Pump pressure-rise curve validation — full operating range",
      "description": "Predicted head-flow curve compared against bench-test measurements across the full operating envelope (1.5–7 L/min at 2000–4500 RPM). Hydraulic efficiency and total pressure rise agree within 3.2% RMS across all 25 test points. Cavitation inception speed not within COU scope and excluded from this validation result. Uncertainty in experimental pressure transducer (±0.5 mmHg) and flow meter (±1.5%) propagated analytically; 95% prediction interval brackets all experimental means.",
      "validationMetric": "Pressure-rise RMS error < 5% across operating envelope",
      "validationOutcome": "Pass",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-03-pressure-rise",
        "type": "UncertaintyQuantification",
        "method": "Analytical propagation of transducer and flow meter calibration uncertainties; 95% prediction interval computed for each operating point",
