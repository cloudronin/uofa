  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold ISO 9001 certification or equivalent documented QA process covering version control, regression testing, and release validation.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an ISO 9001-certified QA framework. Regression test suite (1200+ cases) executed at each release. Version control via Git with tagged release 22.2.0 used throughout this study. Software qualification report on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate second-order spatial convergence on canonical benchmark problems relevant to rotating machinery internal flows.",
      "rationale": "Fluent 2022 R2 verified against the lid-driven cavity (Re = 1000) and Taylor-Couette flow benchmarks. Observed order of convergence 1.94 (spatial) consistent with formal second-order discretization. Iterative convergence to residual < 1e-6 confirmed for all transport equations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for NIH quantity of interest must be < 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed (coarse 4.2M, medium 8.7M, fine 17.1M hexahedral cells). GCI for NIH on fine grid = 2.3%, well within the 5% acceptance criterion. Richardson extrapolation applied; asymptotic range confirmed (GCI_medium/GCI_fine = 1.97 ≈ r^p = 2^0.97)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, temperature, hematocrit) must be documented and replicated in CFD boundary conditions within stated tolerances.",
      "rationale": "FDA benchmark experiments conducted with porcine blood at 37 °C, hematocrit 33±2%, viscosity 3.2 mPa·s. CFD boundary conditions set to match: inlet velocity profile derived from Womersley solution, outlet static pressure, fluid properties matched to reported experimental values. Temperature variation ±0.5 °C accounted for in sensitivity study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (RH) must be computed and reported for all validation operating points; systematic bias must be characterised.",
      "rationale": "RH computed at all five FDA benchmark operating points: 0.81, 0.76, 0.88, 0.72, 0.93. All satisfy RH < 1. Mean RH = 0.82; no systematic over-prediction bias detected. Bland-Altman analysis confirms limits of agreement within ±0.15 RH units."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH, RH) must be directly linked to the clinical endpoint (hemolysis risk) and the regulatory acceptance criterion.",
      "rationale": "NIH is the FDA-recognised metric for pump-induced hemolysis and is directly traceable to plasma free haemoglobin elevation. RH < 1 criterion aligns with the 510(k) predicate comparison framework. QoI relevance confirmed by clinical advisory review."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the same device geometry, operating range, and fluid properties as the COU; gaps must be documented and justified.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the same geometry used in the COU. Operating range 2–6 L/min, 2000–4000 RPM spans the full COU envelope. Porcine blood proxy accepted as representative of human blood at MRL 2 per ASME V&V 40 guidance. No extrapolation beyond validated range required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; solver error subsumed within code verification assessment.",
      "rationale": "At Model Risk Level 2, explicit numerical solver error quantification beyond code verification is not mandated. Iterative convergence criteria (residuals < 1e-6) and double-precision arithmetic provide adequate assurance. Scoped out by mutual agreement of assessment team."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; operator training records and simulation protocol document provide sufficient control.",
      "rationale": "Simulation executed by two licensed engineers with >5 years CFD experience in cardiovascular applications. Written simulation protocol followed; independent peer review of setup files conducted. Formal use-error analysis not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selections must be justified against available literature benchmarks for rotating blood-contacting devices.",
      "rationale": "SST k-ω selected based on published benchmark comparisons for centrifugal blood pumps (Hariharan et al. 2011, Pauli et al. 2014) showing superior near-wall shear prediction versus standard k-ε. Giersiepen-Wurzinger power-law hemolysis model applied; model constants calibrated to Heuser-Opitz data. Model form uncertainty acknowledged as dominant uncertainty source at this MRL."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters (geometry, fluid properties, boundary conditions) must be traceable to measurements or literature with stated uncertainty.",
      "rationale": "Pump geometry digitised from FDA-released CAD file (rev 3.1). Fluid density 1060 kg/m³, viscosity 3.2 mPa·s from experimental report. Inlet boundary condition: flat velocity profile with 5% turbulence intensity. All inputs documented in simulation data package with traceability matrix. Sensitivity of NIH to ±10% viscosity perturbation assessed: ΔNIHmax = 4.2%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterisation performed by originating laboratory and documented in FDA benchmark dataset.",
      "rationale": "Blood sample characterisation (hematocrit, age, donor variability) documented in the FDA benchmark experimental report. Independent sample characterisation not required at MRL 2. Inter-donor variability bounded by ±2% hematocrit range reported in source data."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; COU and validation conditions are sufficiently aligned as documented under relevance of validation activities.",
      "rationale": "Equivalency of input parameters between validation and COU conditions is addressed qualitatively under the relevance factor. Formal equivalency mapping not mandated at MRL 2. Key parameters (geometry, fluid, operating range) confirmed identical between validation and COU contexts."
    }
