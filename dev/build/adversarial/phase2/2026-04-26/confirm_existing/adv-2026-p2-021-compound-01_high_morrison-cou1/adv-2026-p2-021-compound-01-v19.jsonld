  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels at MRL 2. Six factors appropriately scoped out per ASME V&V 40 guidance for Class II devices at MRL 2. Three independent validation activities (hemolysis benchmark, PIV velocity field, pressure-rise curve) collectively demonstrate sufficient model credibility for the stated COU. GCI < 5% confirms discretization error is controlled. The relative hemolysis index RH < 1 at all five operating points satisfies the regulatory acceptance criterion. The assessment team unanimously recommends acceptance of the CFD model for use in identifying worst-case hemolysis operating conditions for the Class II CPB device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
