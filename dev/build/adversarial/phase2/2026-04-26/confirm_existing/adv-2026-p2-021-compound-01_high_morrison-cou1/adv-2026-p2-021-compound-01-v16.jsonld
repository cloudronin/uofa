  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required gradation levels for MRL 2. Six factors appropriately scoped out at MRL 2 with medium model influence and high decision consequence. Validation evidence (VR-001 through VR-003) demonstrates model fitness for the intended COU: GCI < 2.1%, pressure-flow MAE 4.3%, hemolysis index within ±0.18 g/100 L limits of agreement. Worst-case geometric tolerance configuration yields RH = 0.93 < 1.0 acceptance criterion. Model credibility is sufficient to support the regulatory submission for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
