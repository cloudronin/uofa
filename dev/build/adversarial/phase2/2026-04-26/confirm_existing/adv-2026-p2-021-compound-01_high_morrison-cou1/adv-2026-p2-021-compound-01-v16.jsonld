    "https://uofa.net/synth/data/morrison-fda-pump-experimental-dataset",
    "https://uofa.net/synth/data/morrison-cpb-operating-conditions-sweep"
  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-001-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence study — relative hemolysis index",
      "description": "Three-level mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.2M elements) demonstrating GCI < 2.1% for the relative hemolysis index QoI across all five operating points. Richardson extrapolation applied; asymptotic convergence confirmed.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-mesh",
        "type": "UncertaintyQuantification",
        "method": "Grid Convergence Index (Roache 1994)",
        "coverageProbability": 0.95,
        "description": "GCI-based discretization uncertainty bounds computed for RH index at each operating point. Maximum GCI 2.08% at 4 L/min / 2800 rpm; all within acceptance threshold of 5%."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-002-pressure-flow",
      "type": "ValidationResult",
      "name": "Pressure-flow curve validation against FDA experimental data",
      "description": "Simulated pressure-flow curves compared against FDA benchmark experimental measurements for the generic centrifugal pump at 2500 and 3000 rpm. Mean absolute error 4.3% across 12 operating points; all within ±8% acceptance band. Turbulence model sensitivity study (SST k-ω vs. realizable k-ε) shows < 3% variation in QoI.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-pressure-flow",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo propagation of inlet boundary condition uncertainty",
        "coverageProbability": 0.9,
        "description": "Inlet flow rate uncertainty ±2% (calibration certificate); propagated through ensemble of 200 CFD runs. 90th-percentile pressure prediction uncertainty ±5.1 mmHg across operating range."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-003-hemolysis-index",
      "type": "ValidationResult",
      "name": "Hemolysis index validation — Lagrangian particle tracking",
      "description": "Normalized index of hemolysis (NIH) computed via Lagrangian particle tracking (5000 pathlines per operating point) compared against in-vitro hemolysis measurements from three independent test rigs. Mean bias −0.04 g/100 L; limits of agreement ±0.18 g/100 L. RH < 1 criterion satisfied for all nominal geometry configurations. Worst-case tolerance stack-up geometry yielded RH = 0.93, confirming design acceptance.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-hemolysis",
        "type": "UncertaintyQuantification",
        "method": "Bland-Altman agreement analysis with bootstrap confidence intervals",
        "coverageProbability": 0.95,
        "description": "Bootstrap 95% CI on mean bias: [−0.07, −0.01] g/100 L. Inter-lab variability in experimental reference accounted for via random-effects model. Prediction interval for RH index: ±0.12 at 95% coverage."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-004-wallshear-sensitivity",
      "type": "ValidationResult",
      "name": "Wall shear stress sensitivity — geometric tolerance sweep",
      "description": "Parametric CFD sweep across 18 tolerance combinations (impeller tip clearance ±0.05 mm, volute width ±0.08 mm, blade angle ±1.5°). Peak wall shear stress and exposure-time-weighted stress integral computed for each configuration. Worst-case combination identified at minimum tip clearance / maximum volute width; RH ratio 0.97 relative to nominal, confirming margin. No experimental UQ characterisation was performed for this sensitivity sweep; results treated as deterministic ranking."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-005-turbulence-model",
      "type": "ValidationResult",
      "name": "Turbulence model verification — manufactured solution",
      "description": "Method of manufactured solutions (MMS) applied to the SST k-ω implementation in ANSYS Fluent 2023 R2. Observed order of accuracy 1.94 (theoretical 2.0); L2 norm of velocity error < 0.3% at production mesh density. Code verification criterion satisfied.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-mms",
        "type": "UncertaintyQuantification",
        "method": "Order-of-accuracy verification via Richardson extrapolation on MMS residuals",
        "coverageProbability": null,
        "description": "Observed vs. theoretical order comparison; no probabilistic coverage applicable for deterministic code verification activity. Included for completeness."
      }
    }
