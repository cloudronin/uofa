    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rates, rotational speeds, fluid properties) match simulation boundary conditions within stated measurement uncertainty.",
      "rationale": "FDA experimental dataset specifies flow rates ±0.05 L/min and rotational speeds ±15 RPM. Simulation boundary conditions set to nominal experimental values; sensitivity to boundary condition uncertainty evaluated and shown to contribute < 1.5% variation in pressure head. Fluid properties (blood analogue: 40% glycerol-water, ρ = 1050 kg/m³, μ = 0.0035 Pa·s) matched to experimental specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mean absolute error < 10% and maximum error < 15% on pressure-head curve across all 5 validation operating points.",
      "rationale": "Pressure-head validation (VR-02) yields mean absolute error 4.1% and maximum error 6.8% across all 5 operating points, satisfying the acceptance criteria. Comparison performed using experimental data from the FDA generic pump benchmark dataset with propagated measurement uncertainty."
