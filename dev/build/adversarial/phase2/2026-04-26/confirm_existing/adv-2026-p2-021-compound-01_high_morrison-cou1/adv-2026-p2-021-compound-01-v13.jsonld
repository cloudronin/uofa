  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-01-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Relative hemolysis index validation against in-vitro measurements",
      "description": "CFD-predicted normalized index of hemolysis (NIH) compared against in-vitro measurements from the FDA benchmark centrifugal pump study across five operating points (2.5 L/min at 2500 RPM, 5 L/min at 2500 RPM, 5 L/min at 3500 RPM, 7.5 L/min at 2500 RPM, 7.5 L/min at 3500 RPM). Agreement assessed via relative hemolysis index RH = NIH_CFD / NIH_exp. All five operating points yielded RH < 1.0, confirming the model conservatively bounds measured hemolysis. Mean RH = 0.87 ± 0.09.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/vr01-uq",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo propagation of inlet velocity and viscosity uncertainty; 1000 samples; 95th-percentile NIH band reported.",
        "coverageInterval": "95%"
      }
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-02-shear-stress-distribution",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution validation via PIV measurements",
      "description": "Particle image velocimetry (PIV) data from the FDA benchmark study used to validate predicted velocity and wall shear stress fields in the impeller and volute regions. Normalized root-mean-square error (NRMSE) across 12 measurement planes was 8.3%, within the 10% acceptance threshold defined in the validation plan. Spatial convergence of shear stress peaks was confirmed at the refined mesh level (22 M cells).",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/vr02-uq",
        "type": "UncertaintyQuantification",
        "method": "GCI-based discretization uncertainty combined with PIV measurement uncertainty (±3.2% at 95% CI) propagated via RSS method.",
        "coverageInterval": "95%"
      }
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-03-pressure-rise-characteristic",
      "type": "ValidationResult",
      "name": "Pump pressure-rise characteristic curve validation",
      "description": "Predicted head-flow (H-Q) curve compared against manufacturer-supplied bench test data across the full operating envelope. Agreement within 5% at all five design operating points. Turbulence model sensitivity study (k-omega SST vs. realizable k-epsilon) showed less than 2% variation in predicted head at design flow, supporting model form adequacy for pressure-dominated quantities. Acceptance criterion of ±8% met at all points.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/vr03-uq",
        "type": "UncertaintyQuantification",
        "method": "Turbulence model uncertainty estimated via model-form uncertainty factor; combined with numerical discretization uncertainty (GCI < 1.2%) and experimental measurement uncertainty (±1.5% at 95% CI).",
        "coverageInterval": "95%"
      }
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-04-geometric-sensitivity-hemolysis",
      "type": "ValidationResult",
      "name": "Geometric tolerance sensitivity study — hemolysis response surface",
      "description": "A design-of-experiments (DoE) study varying five geometric parameters (impeller tip clearance ±0.05 mm, blade trailing-edge radius ±0.02 mm, volute cutwater gap ±0.1 mm, inlet pipe diameter ±0.5 mm, diffuser angle ±1 deg) was executed across 32 CFD runs using a central composite design. Response surface for NIH constructed and validated against 8 holdout runs with R² = 0.96. Worst-case geometric combination identified as minimum tip clearance with maximum cutwater gap, yielding NIH increase of 18% over nominal — below the 25% regulatory threshold."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-05-mesh-convergence",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error quantification",
      "description": "Grid convergence index (GCI) study performed on three systematically refined meshes (8 M, 14 M, 22 M cells; refinement ratio r = 1.4). GCI for NIH at worst-case operating point: GCI_fine = 0.9%, GCI_medium = 2.1%. Asymptotic convergence ratio = 0.97, confirming solution is within the asymptotic range. Discretization uncertainty contribution to total NIH budget: 1.1% (negligible relative to model form uncertainty of 9.3%).",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/vr05-uq",
        "type": "UncertaintyQuantification",
        "method": "Richardson extrapolation with GCI safety factor of 1.25 per Celik et al. (2008). Reported as half-width of 95% CI on NIH.",
        "coverageInterval": "95%"
      }
