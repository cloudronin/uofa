      "type": "ValidationResult",
      "name": "Mesh convergence study — FDA generic centrifugal pump",
      "description": "Grid convergence index (GCI) study performed across three systematically refined meshes (coarse 2.1 M cells, medium 5.8 M cells, fine 14.3 M cells). GCI for pressure rise at design point: 1.4%. GCI for wall shear stress peak: 3.1%. Richardson extrapolation confirms asymptotic convergence. Discretization error budget within accepted tolerance for MRL 2.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-mesh",
        "type": "UncertaintyQuantification",
        "method": "Grid Convergence Index (GCI) per Celik et al. 2008",
        "coverageProbability": 0.95,
        "description": "GCI-based uncertainty bounds reported for all primary QoIs at the fine-mesh level. Combined numerical uncertainty: ±2.3% on RH index."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-002-hemolysis-validation",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA experimental benchmark",
      "description": "Computational relative hemolysis index (RH) compared against FDA experimental measurements across all 5 flow-speed operating points. Mean absolute error: 8.2%. Maximum deviation: 14.7% at the highest shear operating point. Model predictions satisfy RH < 1 acceptance criterion at all tested conditions. Turbulence model sensitivity study (k-omega SST vs. realizable k-epsilon) performed; SST selected based on superior near-wall resolution. Power-law hemolysis damage accumulation model (Giersiepen et al.) applied with literature-derived coefficients.",
      "description2": "NOTE — uncertainty quantification for this result is deferred pending availability of additional experimental replicates from the FDA benchmark dataset. Interim assessment relies on point-estimate comparison only."
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-003-pressure-flow-curve",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic curve validation",
      "description": "Simulated pump head versus flow rate curve compared against manufacturer-supplied hydraulic performance data at 3500 RPM and 4500 RPM. Agreement within ±5% across the operating range. Confirms adequate hydraulic fidelity of the CFD model as a prerequisite for hemolysis prediction accuracy.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-pressure-flow",
        "type": "UncertaintyQuantification",
        "method": "Experimental uncertainty propagation from manufacturer test data combined with CFD numerical uncertainty",
        "coverageProbability": 0.9,
        "description": "Combined experimental and numerical uncertainty on pump head: ±4.8% at 95% coverage. Input parameter uncertainty (viscosity, density) propagated via local sensitivity coefficients."
      }
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-vr-004-sensitivity-analysis",
      "type": "ValidationResult",
      "name": "Geometric tolerance sensitivity sweep — worst-case identification",
      "description": "Parametric CFD study across ±10% variation in impeller tip clearance, volute cutwater gap, and inlet pipe diameter. Latin hypercube sampling with 32 design points evaluated. Worst-case hemolysis identified at minimum tip clearance combined with maximum rotational speed (4500 RPM, 3 L/min). Response surface constructed; maximum RH = 0.87, confirming margin to RH < 1 criterion across tolerance space.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/morrison-uq-sensitivity",
        "type": "UncertaintyQuantification",
        "method": "Latin hypercube sampling with response surface metamodel; 95th percentile RH reported",
        "coverageProbability": 0.95,
        "description": "95th percentile RH across geometric tolerance space: 0.87. Probability of exceeding RH = 1: <0.3% based on response surface Monte Carlo with 10,000 samples."
      }
    }
