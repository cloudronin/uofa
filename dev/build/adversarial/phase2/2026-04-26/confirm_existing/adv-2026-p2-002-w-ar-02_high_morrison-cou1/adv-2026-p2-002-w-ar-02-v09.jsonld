  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for COU1. Seven factors were formally assessed; six were appropriately scoped out at Model Risk Level 2 per Table 3. Of the seven assessed factors, the team finds that the overall body of evidence supports an Accepted decision. The mesh independence study demonstrated GCI below 2%, output comparison showed agreement within 9% across all operating points, and the turbulence and hemolysis models were selected and justified through published benchmarking. The Test Conditions factor presented the most nuanced assessment: while four of five operating points met all Gradation 3 boundary-condition matching criteria, the fifth operating point exhibited a minor hematocrit deviation. The team considered the sensitivity analysis result (±8% hematocrit produces less than 3% change in predicted RH), the team's seven-year institutional experience with bovine blood protocols, and the conservative over-prediction bias observed in the output comparison. Taken together, these considerations provide reasonable confidence that the test-condition shortfall does not materially undermine the credibility conclusion for the intended COU. The decision is therefore Accepted at Medium assurance level, consistent with a Class II device at Model Risk Level 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
