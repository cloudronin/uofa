  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Commercial CFD solver with documented QA processes, version control, and regression test suite satisfying MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 is employed under a validated commercial license with full traceability to release notes and regression test documentation. The simulation team maintains a version-controlled case repository with input-deck checksums recorded at each run. SQA documentation was reviewed against FDA expectations for predicate-based submissions and found compliant at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver passes standard benchmark problems (lid-driven cavity, backward-facing step) with documented order-of-accuracy confirmation.",
      "rationale": "The solver was verified against the ASME V&V 20 benchmark suite including lid-driven cavity at Re=1000 and the backward-facing step at Re=800. Observed spatial order of accuracy was 1.93 for velocity and 1.88 for pressure, consistent with the nominally second-order discretization scheme. Results were archived and independently reviewed by a second analyst."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Richardson extrapolation-based GCI reported for all primary QoIs with GCI < 5% on the fine grid, and observed order of accuracy within 10% of theoretical order, demonstrating that discretization uncertainty is formally quantified and bounded at Gradation 3.",
      "rationale": "A three-level mesh refinement study was conducted using structured hexahedral meshes of approximately 2.1M, 5.8M, and 14.2M elements, with a refinement ratio of 1.38. The Grid Convergence Index (GCI) was computed for the relative hemolysis index (RH) at all five operating points. GCI values on the medium-to-fine transition ranged from 4.1% to 8.7%, with the highest values observed at the two highest rotational speed conditions. The simulation team notes that the 8.7% GCI at the 3500 RPM / 5 L/min condition remains within what is commonly accepted in the cardiovascular CFD literature for rotating machinery, and that the trend of RH across operating conditions is monotonically consistent across all three grid levels, providing confidence in the rank-ordering of worst-case conditions even where the absolute GCI slightly exceeds the 5% threshold. Prior published work on analogous centrifugal pump geometries (cf. Fraser et al., 2011; Arvand et al., 2005) has demonstrated that hemolysis index rankings are robust to discretization at comparable GCI levels. Expert judgment from two independent biofluid mechanics reviewers concurred that the mesh resolution is adequate for the comparative purpose of this COU, given that the acceptance criterion is relative (RH < 1) rather than absolute. The observed spatial order of accuracy was 1.71 for RH, within acceptable range for a complex rotating-domain simulation. On balance, the team considers the discretization evidence sufficient to support the COU decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions (fluid properties, boundary conditions, temperature) are documented and traceable to the CFD boundary condition inputs.",
      "rationale": "In vitro hemolysis experiments were conducted using ovine blood at 37°C with hematocrit 35 ± 2%. Flow rates and rotational speeds were verified with calibrated ultrasonic flow meters and optical tachometers. All measured boundary conditions were directly transcribed into CFD inlet/outlet specifications with uncertainty bounds documented in the test report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or normalized RMSE) reported for RH across all operating points; agreement within ±15%.",
      "rationale": "The normalized index of agreement between predicted and measured RH values across the five operating conditions was 0.94. Pointwise percent errors ranged from 2.3% to 11.8%, all within the ±15% acceptance band. Bland-Altman analysis showed no systematic bias. The comparison methodology follows ASME V&V 20 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The modeled QoI (RH index derived from shear stress history integration) is directly linked to the clinical endpoint of hemolysis and accepted by the regulatory pathway.",
      "rationale": "The relative hemolysis index RH is computed from the power-law Giersiepen-Wurzinger model applied to Lagrangian particle trajectories, which is the industry-standard approach for regulatory submissions of CPB devices. The QoI is directly interpretable in terms of clinical hemolysis risk and has been accepted in multiple 510(k) submissions for analogous devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on the same device geometry and operating envelope as the COU, or with documented similarity argument.",
      "rationale": "Validation experiments were performed on the FDA generic centrifugal pump geometry under the identical five operating conditions defined in the COU. No geometric or operating-condition extrapolation is required. The validation scenario is coincident with the COU scenario, providing the strongest possible relevance argument."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor category.",
      "rationale": "Per the MRL 2 credibility assessment framework, numerical solver error beyond code verification is not required for this COU. The commercial solver's iterative convergence was monitored and residuals reduced below 1e-5 for all equations, which is documented in run logs."
    },
    {
      "type": "CredibilityFactor",
