  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following review of all 13 ASME V&V 40 credibility factors at Model Risk Level 2, the assessment team concludes that the CFD model is sufficiently credible for the intended COU. Seven factors were formally assessed; all assessed factors are judged to meet or substantially approach their required credibility levels. Six factors were not assessed, consistent with MRL 2 scope. The discretization error factor showed GCI values up to 8.7% at the most demanding operating condition, slightly above the 5% formal threshold, but the team determined — based on monotonic convergence behavior, consistency of rank-ordering across grid levels, published precedent in the cardiovascular CFD literature, and concurring expert review — that this does not materially affect the comparative conclusions of the COU. The relative acceptance criterion (RH < 1) provides additional robustness against the modest discretization uncertainty. All other assessed factors achieved their required levels. The overall body of evidence is considered adequate to support regulatory submission for this Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
