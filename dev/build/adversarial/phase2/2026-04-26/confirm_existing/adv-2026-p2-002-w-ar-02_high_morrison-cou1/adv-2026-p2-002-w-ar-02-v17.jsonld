  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors at MRL 2. Six factors were scoped to level 1 and are not assessed, consistent with MRL 2 guidance for a Class II device with Medium model influence. Seven factors were formally assessed. Six of the seven assessed factors achieved their required levels. The factor 'Relevance of the validation activities to the COU' achieved level 2 against a required level of 3; however, the team determined that the structured expert panel consensus, supported by parametric CFD sensitivity data demonstrating less than 12% variation in hemolysis index across the geometric and operational parameter space separating the validation and COU configurations, provides adequate assurance for the intended decision. The sensitivity margin falls within the pre-specified 15% model acceptance band, and the expert panel included members with direct experience validating hemolysis CFD models for similar rotary blood pump geometries. The team exercised engineering judgment consistent with ASME V&V 40 Section 7.4, which permits acceptance when compensating evidence supports credibility despite a factor not fully meeting its required level. All other assessed factors met or exceeded required levels. The overall evidence base is considered sufficient to support the regulatory submission decision that the CFD model adequately identifies worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
