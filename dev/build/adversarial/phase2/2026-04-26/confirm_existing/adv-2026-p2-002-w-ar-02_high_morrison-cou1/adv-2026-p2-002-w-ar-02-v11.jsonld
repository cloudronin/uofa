  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and release validation suite satisfies MRL 2 requirement.",
      "rationale": "ANSYS Fluent 2022 R2 was used. The vendor-supplied QA documentation includes a formal verification and validation test suite covering rotating machinery cases. Internal SOP for solver version control and case file archiving was followed throughout the study. No custom user-defined functions were employed that would require additional code verification. Achieved level 2 is consistent with MRL 2 expectations for a commercially supported solver with documented release testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark confirms correct implementation of governing equations for rotating-frame turbulent flow.",
      "rationale": "A manufactured solution verification was performed on the rotating reference frame Navier-Stokes formulation using a simplified annular domain. Observed convergence rates matched theoretical second-order accuracy for the pressure-velocity coupling scheme. Results are documented in the solver verification report (VR-001). No anomalous convergence behavior was observed across the five operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (shear stress, velocity magnitude) demonstrating discretization error below 5% for the medium mesh used in production runs.",
      "rationale": "A three-level mesh refinement study was conducted with coarse (2.1M cells), medium (5.8M cells), and fine (14.3M cells) meshes. Richardson extrapolation yielded GCI values of 3.2% and 2.7% for area-averaged wall shear stress and volume-averaged scalar shear stress, respectively, on the medium mesh. The medium mesh was selected for all production simulations. GCI values are within the 5% acceptance threshold, satisfying the MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented and traceable to calibrated instrumentation with uncertainty quantification.",
      "rationale": "In-vitro experiments were conducted at five flow rate / rotational speed combinations spanning the clinical operating envelope (2–6 L/min, 2000–3500 RPM). Fluid temperature was maintained at 37 ± 0.5 °C using a recirculating bath. Flow rates were measured with a calibrated ultrasonic transit-time flowmeter (±2% full scale). Rotational speed was verified with a tachometer traceable to NIST standards. Fluid viscosity and density were measured on each test day. All instrumentation calibration records are archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for NIH and RH index across all five operating points; agreement within ±20% for each point.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) was compared against bench-top measurements at all five operating conditions. Percentage errors ranged from 4.1% to 17.8%, with all five points within the ±20% acceptance band. The validation metric u_val was computed accounting for experimental uncertainty and numerical uncertainty; the comparison norm was 0.81, indicating adequate agreement. The worst-case operating point (6 L/min, 3500 RPM) showed the largest deviation but remained within tolerance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The QoIs used in validation (NIH, RH index, scalar shear stress) are directly relevant to the COU decision criterion (RH < 1).",
      "rationale": "The primary COU decision criterion is relative hemolysis index RH < 1 compared to the predicate device. The validation QoIs — NIH measured in vitro and scalar shear stress integrated via the power-law hemolysis model — are the direct computational antecedents of RH. The mapping from NIH to RH is linear and well-established in the literature. No intermediate surrogate quantities are introduced. Relevance is considered fully established at the MRL 2 level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments were conducted on the same device geometry and fluid (bovine blood analog) as the COU, at overlapping operating conditions.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry — the same geometry as the COU device — with a bovine blood analog (PDMS-saline, viscosity matched to 37 °C whole blood). The five validation operating points span the COU envelope. While the COU ultimately concerns dimensional variants of the pump, the nominal geometry validation establishes baseline model credibility from which sensitivity studies are extrapolated. This is consistent with MRL 2 practice where exact COU geometry replication in validation is not mandated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor beyond what is addressed under numerical code verification.",
      "rationale": "At MRL 2, separate quantification of numerical solver error beyond the code verification and discretization error assessments is not required. The factor is scoped to not-assessed consistent with the MRL 2 assessment plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2; user qualification documented separately.",
      "rationale": "Use error assessment is not required at MRL 2 for this device class. Analyst qualifications are documented in the project personnel records. Standard operating procedures for case setup, boundary condition assignment, and post-processing were followed and are archived."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 beyond selection rationale documented in the modeling report.",
      "rationale": "The SST k-ω turbulence model was selected based on its established performance for rotating machinery flows with adverse pressure gradients, as documented in the modeling report (MR-001). Formal model form uncertainty quantification is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Boundary conditions (inlet velocity profiles, outlet pressure, rotational speed) were set to nominal values derived from the experimental test conditions. Fluid properties were taken from measurements on each test day. Formal sensitivity analysis or probabilistic input uncertainty propagation is not required at MRL 2 and was not performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "A statistically powered sample of independent test articles (n ≥ 5 distinct pump units) must be used in validation experiments to characterize unit-to-unit geometric and manufacturing variability, with inter-unit variability reported as part of the experimental uncertainty budget.",
      "rationale": "Validation experiments were conducted using three independently fabricated pump units sourced from the same manufacturing batch. Each unit was tested at all five operating conditions in a randomized order, yielding 15 independent test runs in total. Inter-unit variability in NIH was observed to be low (coefficient of variation 4.2%), suggesting that manufacturing variation within this batch does not materially influence hemolysis outcomes. The assessment team notes that the three-unit sample is consistent with common practice for early-stage credibility assessments at MRL 2, and that the low observed variability, combined with the team's prior experience across six prior pump validation campaigns (each showing similarly low inter-unit scatter), provides substantial indirect assurance that a larger sample would not alter the credibility conclusion. Expert judgment from the hemolysis modeling community, as reflected in published FDA guidance discussions, supports the view that for geometrically well-controlled machined titanium impellers, three units are generally representative. The validation metric u_val already partially accounts for uncharacterized inter-unit variability through its experimental uncertainty term, which was conservatively inflated by 15% to compensate for the limited sample. On balance, the assessment team concluded that the evidence base, while not meeting the formal five-unit threshold required at the assessed level, is sufficient to support an Accepted outcome given the convergent lines of indirect evidence and the low-consequence sensitivity of the hemolysis index to the observed inter-unit dimensional scatter."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2; nominal equivalency between validation and COU inputs is documented.",
      "rationale": "The validation experiments and CFD simulations used matched boundary conditions at each operating point. Formal equivalency analysis is not required at MRL 2. The mapping between validation inputs and COU inputs is documented in the V&V plan (VP-001)."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for COU1 at Model Risk Level 2. Seven factors were formally assessed; six were determined not to require assessment at MRL 2. Of the seven assessed factors, six achieved their required credibility levels based on documented evidence. The Test samples factor was assessed at achieved level 2 against a required level of 3; however, the team determined that the totality of evidence — including low inter-unit variability (CV 4.2% across three units), conservative inflation of the experimental uncertainty budget, and extensive prior experience with this device class — provides sufficient indirect assurance to support an Accepted decision. The output comparison results demonstrate agreement within ±20% across all five operating points, and the validation metric u_val of 0.81 is within the acceptable range for MRL 2. The discretization error GCI values are below 5% for all primary QoIs. The team is satisfied that the model is fit for the intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device, and that the RH < 1 acceptance criterion can be reliably evaluated using this model. The decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
