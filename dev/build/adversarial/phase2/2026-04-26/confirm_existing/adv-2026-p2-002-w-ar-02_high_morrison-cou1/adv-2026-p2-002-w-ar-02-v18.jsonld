  "signature": "ed25519:9a2f4c1e7b3d5a8f2c6e0b4d8a1f5c9e3b7d0a4f8c2e6b0d4a8f1c5e9b3d7a0f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and release validation suite meets MRL 2 requirement at Gradation 1.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially distributed solver subject to the vendor's internal software quality assurance program, including regression testing and release validation benchmarks. Documentation of the QA procedures is available in the ANSYS product documentation and has been reviewed by the assessment team. This satisfies Gradation 1 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark verification cases relevant to internal rotating flow.",
      "rationale": "The ANSYS Fluent solver has been verified against the ASME V&V 20 lid-driven cavity and backward-facing step benchmarks as documented in the vendor verification manual. Gradation 1 is satisfied for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study with at least three mesh refinement levels; GCI < 5% on hemolysis index QoI.",
      "rationale": "A three-level mesh refinement study was conducted using coarse (4.2M cells), medium (11.7M cells), and fine (28.3M cells) hexahedral-dominant meshes. The Grid Convergence Index (GCI) for the relative hemolysis index was computed at 3.1% on the medium-to-fine transition, satisfying the < 5% threshold. The medium mesh was selected for production runs as the optimal balance of accuracy and computational cost. Gradation 2 is achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented and match CFD boundary conditions within stated uncertainty.",
      "rationale": "The FDA pump experimental dataset (NCBI BioProject) documents test conditions at five flow-speed operating points. Boundary conditions in the CFD model were set to match the reported flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM) within the stated experimental uncertainty bands. Fluid properties (blood analog: 36% glycerol/water) were applied consistently. Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of CFD predictions against experimental measurements with stated metrics; agreement within acceptance band for primary QoI.",
      "rationale": "CFD-predicted relative hemolysis index (RH) was compared against experimental RH measurements at all five operating points. Mean absolute percentage error was 8.4%, within the pre-specified 15% acceptance band. Pressure rise predictions agreed within 6.2% across all operating points. Velocity field comparisons with PIV data showed qualitative agreement in impeller discharge region. Gradation 2 is achieved for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (RH index, pressure rise) are directly relevant to the COU decision quantity.",
      "rationale": "The relative hemolysis index is the primary decision metric for the COU (RH < 1 acceptance criterion). Pressure rise is a secondary QoI confirming hydraulic performance. Both quantities are directly used in the regulatory submission and are identical to the COU decision quantities. Gradation 2 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities were conducted on a geometry and at operating conditions sufficiently similar to the COU device and conditions to support extrapolation of validation conclusions.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry, which is a well-characterized benchmark platform broadly representative of the centrifugal pump class. The assessment team notes that the COU device is a proprietary design with a modified volute geometry and an impeller blade count that differs from the FDA benchmark (5 vs. 6 blades). However, the operating envelope (flow rates 2–6 L/min, speeds 2000–3500 RPM) overlaps substantially with the COU device's clinical operating range. Prior published studies using this benchmark for analogous Class II devices (Hariharan et al. 2011; Stewart et al. 2012) have demonstrated acceptable predictive fidelity when geometric similarity is within the observed range. The assessment team's collective experience across seven prior CPB pump CFD submissions supports the judgment that the validation basis is adequate for this device class, even absent a device-specific validation dataset. Expert consensus within the team, combined with the favorable output comparison results on the benchmark geometry, provides sufficient confidence that validation conclusions transfer to the COU device. Formal geometric similarity metrics (e.g., blade loading coefficient comparison) were not computed, but qualitative engineering judgment indicates the flow regimes are comparable. On balance, the team concludes the validation activities are adequate to support the COU decision at MRL 2, and the package is submitted as meeting credibility requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance < 1e-5 for all equations; mass imbalance < 0.1%.",
      "rationale": "All simulations were run to residual convergence levels of 1e-6 for continuity and momentum equations. Global mass imbalance was confirmed below 0.05% for all five operating points. Gradation 1 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; boundary conditions and material properties verified against documented inputs.",
      "rationale": "An independent senior analyst reviewed the simulation setup files, boundary condition assignments, and material property inputs prior to production runs. A checklist-based review protocol was followed. No setup errors were identified. Gradation 1 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 per scoping determination.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis power-law model coefficients) is acknowledged but not formally assessed at MRL 2. The k-omega SST turbulence model and the Giersiepen-Wurzinger hemolysis power law are standard choices for this application class. Not assessed is acceptable per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 per scoping determination.",
      "rationale": "Input parameter uncertainty (fluid viscosity variation, geometric manufacturing tolerances) is not formally quantified at MRL 2. Nominal input values are used throughout. Not assessed is acceptable per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 per scoping determination.",
      "rationale": "Sample-to-sample variability in the experimental hemolysis measurements is not formally characterized at MRL 2. The FDA dataset reports mean values from replicate experiments; full statistical characterization is not required at this risk level. Not assessed is acceptable per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 per scoping determination.",
      "rationale": "Formal equivalency analysis between validation test inputs and COU device inputs is not required at MRL 2. Qualitative alignment of operating conditions was confirmed in the Test Conditions factor assessment. Not assessed is acceptable per MRL 2 scoping."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 factors for COU1 at Model Risk Level 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the seven assessed factors, the team finds that six factors meet or exceed their required gradation levels, providing a strong evidentiary foundation for the model's credibility. The seventh assessed factor — Relevance of the Validation Activities to the COU — reflects the use of the FDA generic centrifugal pump benchmark rather than a device-specific validation dataset. The team acknowledges this distinction but judges that the extensive published literature on this benchmark, the overlapping operating envelope, and the team's collective experience with analogous Class II CPB submissions collectively provide adequate confidence in the transferability of validation conclusions. The overall credibility evidence, taken in aggregate, supports acceptance of the model for the stated COU. The package is accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
