  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for COU1. Seven factors were formally assessed; six were determined not to require assessment at Model Risk Level 2. Of the seven assessed factors, the team finds that six fully satisfy their required credibility levels. The Test Conditions factor was reviewed in detail: while the formal uncertainty budget for secondary fluid parameters (specifically blood analog viscosity batch variability) was not compiled to the completeness ordinarily expected at Level 3, the team notes that (a) all primary control parameters were characterized with NIST-traceable instruments within tight tolerances, (b) four prior published studies using the same experimental protocol at this laboratory have demonstrated consistent hemolysis predictions, and (c) two independent domain experts confirmed the documentation is adequate for a comparative MRL 2 assessment. The overall body of evidence, taken in context of the comparative nature of the COU decision and the availability of experimental confirmation data, provides sufficient confidence to support an Accepted decision. The assessment team recommends proceeding to regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
