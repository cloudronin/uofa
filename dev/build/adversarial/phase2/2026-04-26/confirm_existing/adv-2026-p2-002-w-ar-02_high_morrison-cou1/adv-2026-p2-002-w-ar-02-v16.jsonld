    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; change logs maintained for all simulation-relevant modules.",
      "rationale": "ANSYS Fluent 2022R2 is used under a formal QMS with ISO 9001 certification. Regression test suite covers 98% of solver modules relevant to rotating machinery hemolysis prediction. Version control logs are archived and available for audit."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver benchmarked against at least one analytical or manufactured solution relevant to rotating flow.",
      "rationale": "The SST k-omega turbulence implementation was verified against the Taylor-Couette analytical solution. Scalar transport used in the hemolysis power-law model was verified using a manufactured solution with known error convergence rate of 1.97, consistent with second-order spatial discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI; GCI < 5% on fine mesh.",
      "rationale": "Three-level GCI study performed at the nominal operating point (5 L/min, 3000 RPM). GCI on the relative hemolysis index was 3.2% between medium and fine meshes. The fine mesh of 4.8M polyhedral cells was selected for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions documented with full uncertainty characterization including flow rate, rotational speed, fluid temperature, and hematocrit; traceability to calibration standards established for all measurement instruments.",
      "rationale": "The experimental hemolysis dataset used for validation was drawn from the FDA-sponsored interlaboratory study (Hariharan et al., 2011) and supplemented by in-house bench tests conducted at the Morrison Cardiovascular Simulation Laboratory. Flow rate and rotational speed were controlled to within ±1.5% and ±0.5% of nominal, respectively, using NIST-traceable calibrated instruments. Fluid temperature was maintained at 37±0.5°C with continuous monitoring. Hematocrit was confirmed at 30±2% via microcentrifuge prior to each test run. While a complete Type B uncertainty budget was not compiled for all secondary parameters—specifically, the variability in blood analog viscosity between batches was characterized informally through supplier certificates of conformance rather than independent rheometric measurement—the team's extensive prior experience with this pump geometry across four previous studies (Morrison et al., 2019, 2020, 2021, 2023) provides strong contextual confidence that batch-to-batch viscosity variation is within the range that does not materially affect hemolysis index predictions at MRL 2. Expert judgment from two independent biofluid mechanics specialists, consulted during the study design phase, concurred that the documentation level is commensurate with the intended comparative use of the model. The five operating points span the clinically relevant envelope and are consistent with ISO 14708-5 guidance for CPB device characterization. On balance, the assessment team is satisfied that test condition documentation is adequate to support the credibility argument, and the package is recommended for Accepted status."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E%, NRMSE) reported between simulation and experimental QoI at all validation points.",
      "rationale": "Normalized root mean square error across five operating points was 8.7% for the relative hemolysis index. Maximum point-wise error was 14.2% at the highest flow-speed combination, within the acceptance threshold established for MRL 2 comparative assessments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation QoI maps directly to the COU decision QoI with documented linkage.",
      "rationale": "The validation QoI (relative hemolysis index RH) is identical to the COU decision criterion (RH < 1 relative to predicate device). The mapping is direct and requires no extrapolation or surrogate QoI assumptions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
