  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors applicable to this COU. Seven factors were formally assessed; six were scoped out as not required at Model Risk Level 2. Of the seven assessed factors, six achieved their required credibility levels. The Model Form factor was assessed at Gradation 2 against a required level of Gradation 3; however, the team determined that the convergent behavior observed across two physically distinct turbulence closure families, combined with consistent power-law hemolysis model rankings and a well-documented institutional track record of seven years of validated hemolysis predictions, collectively provide sufficient evidence to support the COU decision. The primary COU objective is comparative worst-case ranking rather than absolute hemolysis magnitude prediction, which reduces sensitivity to model form uncertainty. Expert judgment from three senior biofluid mechanics engineers was formally documented and supports acceptance. The overall credibility evidence is judged adequate for a Class II device at MRL 2, and the decision is Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
