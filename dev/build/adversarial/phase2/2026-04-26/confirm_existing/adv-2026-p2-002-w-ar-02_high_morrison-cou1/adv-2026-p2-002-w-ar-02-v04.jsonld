  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version-controlled release history satisfies MRL 2 requirement at Gradation 1.",
      "rationale": "ANSYS Fluent 2022 R2 is employed under a documented software quality assurance plan consistent with the solver vendor's ISO 9001-certified development process. Version control records, regression test suite results, and release notes were reviewed and found compliant with Gradation 1 requirements. No custom solver modifications were introduced; all user-defined functions were independently reviewed and unit-tested. The QA plan is archived in the project configuration management system."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver has published method-of-manufactured-solutions (MMS) verification or equivalent benchmark results demonstrating correct numerical implementation at Gradation 1.",
      "rationale": "ANSYS Fluent has an extensive published record of numerical code verification including MMS studies and standard benchmark cases (lid-driven cavity, backward-facing step, Taylor-Couette flow). The solver's finite-volume discretisation of the incompressible Navier-Stokes equations is well-established in peer-reviewed literature. Gradation 1 is satisfied by reference to vendor-published verification documentation and independent academic benchmarks cited in the project technical report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed on at least three mesh refinement levels; GCI < 5% for primary QoI (wall shear stress, scalar dissipation rate) at Gradation 2.",
      "rationale": "A systematic mesh refinement study was performed on three hexahedral-dominant meshes (3.2 M, 6.8 M, and 14.1 M cells) using the Richardson extrapolation-based GCI methodology per Roache (1994). The observed order of convergence was 1.87 for volume-averaged scalar dissipation rate and 1.94 for area-averaged wall shear stress on the impeller blade surfaces. GCI values of 3.1% and 2.8% respectively were obtained on the medium-to-fine mesh pair, satisfying the < 5% threshold. The 6.8 M cell mesh was selected for production runs as the best balance of accuracy and computational cost."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented and match simulation boundary conditions within stated uncertainty bounds at Gradation 2.",
      "rationale": "The FDA benchmark experimental dataset (Hariharan et al. 2011) provides fully documented test conditions including flow rates (2.5 and 5.0 L/min), rotational speeds (2500 and 3500 RPM), and fluid properties (bovine blood analogue, viscosity 0.0035 Pa·s, density 1056 kg/m³). Boundary conditions applied in the CFD model were set to the nominal experimental values. Uncertainty in flow rate measurement (±2%) and rotational speed (±10 RPM) were propagated through a sensitivity study confirming that QoI variation remained within ±4% across the uncertainty envelope, well within Gradation 2 tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of simulation outputs against experimental measurements using a defined validation metric with uncertainty quantification at Gradation 2; agreement within combined experimental and numerical uncertainty bands required.",
      "rationale": "Simulation-predicted relative hemolysis index (RH) values were compared against the five experimental operating points from the FDA benchmark dataset. Across all five conditions the CFD model correctly ranked the operating points by hemolysis severity, and four of the five predicted RH values fell within the experimental inter-laboratory variability band reported by Hariharan et al. (2011). The fifth operating point (5 L/min, 3500 RPM) showed a 23% over-prediction of RH relative to the experimental mean, which the assessment team attributes to turbulence model sensitivity in the high-shear impeller tip region — a known limitation of the k-ω SST model at elevated rotational Reynolds numbers. The team notes that this operating point corresponds to a condition outside the primary design envelope for the CPB device and that the over-prediction is conservative (i.e., the model errs toward higher predicted hemolysis, which is protective from a regulatory standpoint). Additionally, the team draws on prior experience with three analogous centrifugal pump CFD studies conducted between 2019 and 2023, all of which demonstrated acceptable RH prediction accuracy under similar conditions, and on expert judgment from two senior biofluid mechanics specialists who reviewed the comparison plots and considered the level of agreement adequate for the intended regulatory use. Formal uncertainty quantification banding per the Gradation 2 criterion — requiring that the validation comparison be expressed with combined experimental measurement uncertainty and numerical uncertainty intervals and that agreement be demonstrated within those bands for all QoI at all validation points — was not completed for the outlier operating point; only a qualitative conservatism argument is offered in lieu. On balance, the assessment team concluded that the body of evidence, taken together with the conservative direction of the discrepancy and the supporting expert opinion, provides sufficient confidence to proceed. Gradation 1 is formally achieved; the Gradation 2 requirement for full quantitative uncertainty-bounded agreement across all validation points is not strictly met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (RH index, wall shear stress) are directly relevant to the COU decision quantity (worst-case hemolysis identification) at Gradation 2.",
      "rationale": "The relative hemolysis index (RH) is the primary regulatory acceptance criterion specified in the COU (RH < 1 relative to predicate device). Wall shear stress and scalar dissipation rate are the mechanistic drivers of red blood cell damage in the power-law hemolysis model employed. Both quantities are directly relevant to the COU decision and are the same quantities used in the validation comparison, satisfying Gradation 2 relevance requirements without reservation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities were conducted on a geometry, flow regime, and fluid that are sufficiently representative of the COU device and operating conditions at Gradation 2.",
      "rationale": "Validation was performed using the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU simulations. The flow rates and rotational speeds span the intended operating envelope of the CPB device. The blood analogue fluid properties are representative of clinical blood viscosity. The validation domain therefore closely matches the COU in geometry, flow regime (turbulent, Re ~ 10⁴–10⁵), and fluid properties, satisfying Gradation 2 relevance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 per project scoping decision; Gradation 1 default accepted.",
      "rationale": "Per the MRL 2 scoping determination, numerical solver error beyond discretization error (addressed separately) was not independently assessed. Iterative convergence was monitored via residual reduction to 10⁻⁵ for all equations and mass imbalance < 0.01%, providing baseline confidence. Gradation 1 is accepted by default consistent with MRL 2 practice."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation setup reviewed by a second analyst as standard practice.",
      "rationale": "Use error was not formally assessed as a standalone factor at MRL 2. Mitigation was achieved through an independent second-analyst review of all boundary condition specifications, material property inputs, and solver settings prior to production runs. No discrepancies were identified. Gradation 1 is accepted."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; turbulence and hemolysis model selections are documented with literature justification.",
      "rationale": "Model form uncertainty associated with turbulence closure (k-ω SST) and hemolysis model (Giersiepen power-law) was not formally quantified at MRL 2. Selection of both models is justified by published literature for centrifugal blood pump applications. The k-ω SST model is widely used and validated for rotating machinery flows; the Giersiepen model is the regulatory standard for hemolysis prediction. Gradation 1 is accepted."
    },
    {
