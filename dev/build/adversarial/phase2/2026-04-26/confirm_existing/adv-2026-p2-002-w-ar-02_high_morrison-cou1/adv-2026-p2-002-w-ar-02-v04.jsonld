  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors for COU1. Seven factors were formally assessed; six were scoped out as not required at Model Risk Level 2. Of the seven assessed factors, six achieved their required credibility levels without qualification. The Output Comparison factor presented a nuanced picture: while formal Gradation 2 uncertainty-bounded agreement was not achieved across all five validation operating points — with one point (5 L/min, 3500 RPM) showing a 23% RH over-prediction — the team determined that the totality of evidence supports acceptance. The direction of the discrepancy is conservative (over-prediction of hemolysis), which is protective for patient safety. The model correctly rank-ordered all five operating points, and four of five fell within inter-laboratory variability. Three prior analogous studies from the team's portfolio demonstrate consistent predictive accuracy under similar conditions. Two independent biofluid mechanics experts reviewed the comparison data and concurred that the level of agreement is appropriate for the regulatory purpose of identifying worst-case operating conditions rather than absolute hemolysis quantification. The acceptance criterion for the COU (RH < 1 relative to predicate) provides an additional margin that accommodates the observed prediction uncertainty. Taking all factors together — the conservative nature of the discrepancy, the expert consensus, the supporting portfolio evidence, and the regulatory margin in the acceptance criterion — the team concludes that the model is sufficiently credible for the intended use and records the decision as Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
