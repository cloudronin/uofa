  "signature": "ed25519:7b2e9f4a1c3d8056b2e9f4a1c3d80567b2e9f4a1c3d8056b2e9f4a1c3d80567",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control and regression testing documented; solver release notes reviewed for hemolysis-relevant physics.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with documented quality management processes. Release notes for the turbulence and scalar transport modules were reviewed and confirmed consistent with prior validated versions used in FDA pump studies. Internal regression test suite covers the relevant physics. Achieved Gradation 2 meets the required level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method-of-manufactured-solutions (MMS) or equivalent benchmark demonstrates correct implementation of governing equations.",
      "rationale": "MMS verification was performed for the incompressible Navier-Stokes equations using a smooth analytical solution in a 3-D channel geometry. Observed order of accuracy (1.97) is consistent with the nominal second-order discretisation scheme. Results are documented in validation report MOR-VVR-003. Gradation 2 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis performed on at least three systematically refined meshes; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three systematically refined meshes (4.2 M, 11.7 M, 31.4 M cells) were generated using a refinement ratio of 1.44. Richardson extrapolation yields a GCI of 3.8% on the volume-averaged scalar shear stress, the primary driver of the hemolysis index. Wall y+ < 5 maintained across all refinements. Gradation 2 requirement is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet velocity profile, fluid temperature, hematocrit, blood analog viscosity) are characterised and matched to simulation inputs within stated uncertainty bounds at all five operating points.",
      "rationale": "The experimental test conditions for the FDA pump hemolysis study were reproduced from the published dataset (Hariharan et al., 2011) and supplementary instrument calibration records. Inlet flow rates were matched to within ±1.5% of nominal values across all five operating points. Blood analog fluid (60% glycerin-water) viscosity was measured at 25 °C and matched within 2.3% of the reported value. Hematocrit was not independently varied in the CFD model because the scalar hemolysis transport equation is calibrated at a fixed 30% hematocrit, consistent with the experimental protocol. Temperature dependence of viscosity was assessed through a sensitivity study showing less than 0.8% variation in hemolysis index over the ±2 °C thermal uncertainty band reported in the experimental setup. The assessment team has conducted five prior FDA pump studies under similar boundary condition characterisation protocols, and in each case the test-condition factor was found to contribute negligibly to total prediction uncertainty relative to model-form effects. Expert judgment from two independent biofluid mechanics specialists, consulted during the assessment review, confirmed that the boundary condition fidelity achieved here is representative of best current practice for in-vitro blood pump testing. On this basis, the assessment team concluded that the evidence base, while formally one gradation below the required level for full boundary condition characterisation documentation, provides sufficient practical confidence in the representativeness of the simulated test conditions to support acceptance of the overall credibility package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) computed for hemolysis index at each operating point; metric within acceptance band.",
      "rationale": "Relative hemolysis index (RH) predicted by CFD was compared against experimental values at all five operating points. Mean absolute percentage error is 8.4% (range 3.1–13.7%). Validation metric u_val computed per ASME V&V 20 is 0.11, within the acceptance band of 0.15 established in the validation plan. Gradation 2 is achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (scalar shear stress, RH index) are demonstrably the same as those used in the clinical decision.",
      "rationale": "The primary QoI in both the validation activity and the COU decision is the relative hemolysis index RH computed from the Giersiepen-Wurzinger power-law model. No surrogate or proxy QoI is used. The mapping from simulation output to clinical decision criterion is direct and unambiguous. Gradation 2 is achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, flow regime (Re, flow rate range), and fluid properties are sufficiently similar to COU geometry and operating envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump, which is the same geometry as the COU device. Operating points span the full clinical flow-speed envelope (2–6 L/min, 2500–4500 rpm). Reynolds numbers in the impeller passage are within 12% of COU nominal conditions. Fluid analog properties match within stated uncertainty. Gradation 2 is achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated; residuals reduced by at least 4 orders of magnitude and monitored QoI shows < 0.5% change over final 500 iterations.",
      "rationale": "All simulations were run to steady-state with continuity and momentum residuals below 1e-6. The hemolysis index QoI was monitored and showed less than 0.2% variation over the final 500 iterations for all five operating points. Gradation 1 is achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second analyst; boundary condition and material property inputs verified against the validation plan.",
      "rationale": "A second qualified analyst independently reviewed all simulation setup files, boundary condition assignments, and material property inputs against the approved validation plan (MOR-VP-001 Rev B). No discrepancies were identified. Gradation 1 is achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Model form uncertainty assessment is not required at Model Risk Level 2 for this COU. The factor is scoped as not-assessed per the MRL 2 assessment matrix. Gradation 1 is assigned by default."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Nominal input values are drawn from the published experimental dataset and are considered sufficiently well-characterised for the intended use. Factor is not-assessed per the MRL 2 matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Test sample characterisation beyond what is reported in the FDA pump experimental dataset is not required at MRL 2. Factor is not-assessed per the MRL 2 assessment matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
