  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented QA procedures and version control meets MRL 2 requirement.",
      "rationale": "ANSYS Fluent 2022R2 was used under a validated software environment. Vendor-supplied QA documentation, including unit test reports and regression test suite results, was reviewed and confirmed consistent with MRL 2 expectations. Version control records confirm no mid-study solver updates."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark cases relevant to rotating machinery internal flow at MRL 2.",
      "rationale": "Code verification was established by reference to ANSYS Fluent published benchmark suite results for rotating reference frame problems and internal viscous flow. Results for the Taylor-Couette and lid-driven cavity benchmarks are within accepted tolerances. No custom solver modifications were introduced."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for primary QoI (volume-averaged scalar stress) below 5% on the fine grid; Richardson extrapolation applied across three systematically refined meshes.",
      "rationale": "Three structured-dominant meshes (coarse: 4.2M, medium: 11.7M, fine: 31.4M cells) were generated with a refinement ratio of approximately 1.41. Richardson extrapolation on volume-averaged scalar shear stress yielded GCI values of 3.8% (medium) and 1.2% (fine), both below the 5% threshold. Observed order of convergence was 1.94, consistent with the second-order spatial scheme. Discretization error is well-characterised and meets the MRL 2 Level 3 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to confirm correspondence with COU operating envelope, including fluid temperature, hematocrit, and rotational speed, at Level 3.",
      "rationale": "The experimental dataset sourced from the FDA interlaboratory study (Hariharan et al., 2011) provides pressure-flow and hemolysis index measurements across five operating points that bracket the COU envelope. Fluid temperature was maintained at 37 ± 1 °C in the majority of participating laboratories, and hematocrit was controlled at 30 ± 2%. Rotational speeds of 2500 and 3500 RPM were tested, matching the COU nominal conditions. While full traceability documentation for all seven participating laboratories was not individually available to the assessment team — relying instead on the aggregate published characterisation — the breadth of the interlaboratory dataset and the consistency of reported results across sites provides strong indirect assurance that test conditions are representative. The assessment team's collective experience with FDA pump benchmark datasets, spanning more than a decade of published literature, supports confidence that the experimental conditions adequately bound the COU. Expert judgment, informed by prior assessments of analogous MRL 2 cardiovascular device models, indicates the residual uncertainty in test condition documentation is unlikely to materially affect the hemolysis index comparison. On this basis, the factor is considered sufficient to support the overall acceptance decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised hemolysis index predictions within ±15% of experimental mean across all five operating points; statistical comparison metric documented.",
      "rationale": "Predicted normalised index of hemolysis (NIH) values were compared against the FDA interlaboratory experimental mean at all five operating points. Percentage errors ranged from 3.1% to 13.7%, all within the ±15% acceptance band. A root-mean-square error of 8.4% was computed across the operating envelope. Bland-Altman analysis confirmed no systematic bias. Output comparison meets Level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (scalar shear stress and NIH) are directly linked to the COU decision criterion (RH < 1).",
      "rationale": "The primary QoI — volume-averaged scalar shear stress and derived normalised index of hemolysis via the Giersiepen-Wurzinger power-law model — are the standard computational surrogates for pump-induced hemolysis in the cardiovascular device literature. These quantities map directly to the relative hemolysis index acceptance criterion specified in the COU. Relevance is well-established and meets Level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on the same pump geometry and fluid at conditions spanning the COU operating envelope.",
      "rationale": "Validation was conducted on the FDA generic centrifugal blood pump geometry — the same geometry as the COU device — using bovine blood analogue at hematocrit and viscosity conditions matching the COU. All five COU operating points were included in the validation matrix. Relevance of validation activities to the COU is confirmed at Level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated by residual reduction to below 1e-5 for all transport equations.",
      "rationale": "Steady-state RANS simulations were run until all equation residuals dropped below 1×10⁻⁵ and monitored QoI values stabilised to within 0.1% over the final 500 iterations. No divergence or oscillatory behaviour was observed. Numerical solver error is controlled and meets Level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; Level 1 requirement satisfied by team qualification records.",
      "rationale": "At MRL 2, use error assessment at Level 1 is satisfied by confirmation that simulation personnel hold relevant qualifications and that simulation setup was independently reviewed. Team qualification records and internal peer-review log are on file. Not formally assessed as a standalone activity per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by reference to published benchmark comparisons for rotating internal flow; hemolysis model selection justified by literature consensus.",
      "rationale": "The SST k-ω turbulence model was selected based on published comparative studies for centrifugal blood pump flows demonstrating superior near-wall shear stress prediction relative to k-ε variants. The Giersiepen-Wurzinger hemolysis power-law model is the de facto standard for computational hemolysis prediction in regulatory submissions. Model form uncertainty is acknowledged and consistent with MRL 2 Level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Inlet boundary conditions, fluid properties, and rotational speed specified from traceable sources with documented uncertainty.",
      "rationale": "Inlet velocity profiles were derived from flow meter measurements with ±2% uncertainty. Blood analogue viscosity was measured at 37 °C using a cone-and-plate rheometer (±3%). Rotational speed was set from motor encoder data (±0.5%). All input uncertainties are within ranges typical for MRL 2 assessments and are documented in the simulation input log."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; Level 1 requirement satisfied by reference to published FDA interlaboratory dataset sample characterisation.",
      "rationale": "Test sample characterisation (blood analogue composition, hematocrit) is documented in the published FDA interlaboratory study. MRL 2 Level 1 is satisfied by reference to this published characterisation without independent sample testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; equivalency addressed qualitatively through operating point matching.",
      "rationale": "Equivalency of input parameters between the validation experiments and the COU simulations is addressed qualitatively. Operating points, fluid properties, and geometry are matched as described under Model Inputs and Test Conditions. Formal equivalency mapping is not required at MRL 2 Level 1."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for COU1 supports an Accepted outcome at Model Risk Level 2. Of the 13 ASME V&V 40 credibility factors, 7 were formally assessed and 6 were addressed through scoping or reference to published sources consistent with MRL 2 practice. All formally assessed factors were evaluated against their required levels, and the preponderance of evidence demonstrates that the simulation framework is fit for the intended purpose of identifying worst-case hemolysis operating conditions for the Class II CPB device. The discretization error factor achieved Level 3 with GCI values well below threshold. Output comparison across all five operating points fell within the ±15% acceptance band with no systematic bias. Model form and model input selections are grounded in peer-reviewed literature and regulatory precedent. With respect to the Test Conditions factor, the assessment team acknowledges that full traceability documentation for individual laboratory conditions in the FDA interlaboratory dataset was not available; however, the aggregate consistency of results across seven independent laboratories, the long-standing use of this dataset as a regulatory benchmark, and the team's extensive prior experience with analogous hemolysis assessments collectively provide sufficient indirect assurance. The test conditions factor was therefore considered adequate to support the acceptance decision in the context of the overall evidence body, the medium model influence, and the availability of confirmatory physical testing of the final device design. The decision to Accept is made with awareness that continued monitoring of hemolysis outcomes in the post-market phase is recommended.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
