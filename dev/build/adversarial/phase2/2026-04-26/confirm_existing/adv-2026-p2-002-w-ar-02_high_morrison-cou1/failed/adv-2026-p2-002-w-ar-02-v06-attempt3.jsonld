  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Commercial CFD solver with documented QA processes; version control and release notes available; solver used within validated operating envelope.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a documented software quality assurance plan. The solver is a commercial product with ISO 9001-certified development processes. Version control records, release notes, and known-issues documentation were reviewed. All simulations were run within the validated operating envelope for incompressible viscous flow with rotating reference frames. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver verified against at least one benchmark problem relevant to rotating viscous flow; results documented.",
      "rationale": "The CFD solver was verified against the Taylor-Couette rotating cylinder benchmark and the FDA critical path nozzle benchmark (ASME V&V 20 compliant). Order-of-accuracy testing confirmed second-order spatial convergence for the pressure-velocity coupling scheme. Verification results are archived in the simulation data package. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Mesh convergence study performed with at least three systematically refined meshes; GCI or equivalent error estimate reported.",
      "rationale": "A three-level mesh refinement study was conducted using meshes of 4.2M, 11.7M, and 31.4M elements. Grid Convergence Index (GCI) was computed following Celik et al. (2008). The fine-grid GCI for wall shear stress (the primary hemolysis driver) was 2.3%, within the accepted threshold of 5% for MRL 2. Discretization error is adequately characterized. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must be characterized with quantified uncertainty for all primary boundary conditions (flow rate, rotational speed, fluid viscosity, temperature) and confirmed to match simulation inlet/outlet boundary conditions within stated tolerances across all validation operating points.",
      "rationale": "The experimental test conditions were carefully documented for all five flow-speed operating points. Flow rates were measured using a calibrated Coriolis mass flow meter (±1.2% full-scale accuracy), and rotational speed was controlled via a closed-loop servo drive with tachometer feedback (±0.5 RPM). Fluid temperature was maintained at 37 ± 0.5°C using a recirculating bath, and viscosity was confirmed within ±3% of target via cone-plate viscometry prior to each test run. The test laboratory holds ISO 17025 accreditation for hemolysis testing, and the experimental protocol was reviewed by two independent subject matter experts with a combined 35 years of cardiovascular device testing experience. Prior published studies using the same experimental rig (Morrison et al. 2019, Thamsen et al. 2021) demonstrated excellent repeatability with inter-run coefficients of variation below 4% for the normalized index of hemolysis. While formal boundary condition uncertainty propagation from experimental measurements to CFD inlet profiles was not completed in a manner fully consistent with ASME V&V 20 requirements — specifically, the correlated uncertainty contributions from simultaneous flow rate and speed variations across operating points were assessed qualitatively rather than through a structured sensitivity matrix — the team's collective expert judgment, supported by the tight individual measurement uncertainties and the rig's established pedigree, provides high confidence that test conditions are adequately characterized for the purposes of this MRL 2 assessment. The decision team considered this factor in the context of the overall evidence body and concluded that the qualitative characterization, combined with the conservative RH < 1 acceptance criterion applied to model predictions, provides sufficient assurance for the intended regulatory submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Model predictions compared against experimental hemolysis measurements at all validation operating points; agreement quantified using an appropriate metric.",
      "rationale": "Predicted normalized index of hemolysis (NIH) was compared against experimental measurements at all five operating points. Mean absolute percentage error was 8.4%, within the pre-specified 15% acceptance threshold. The model correctly ranked all five operating points by hemolysis severity, preserving the monotonic trend with flow rate. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The quantities of interest (QoI) extracted from the CFD model are directly relevant to the hemolysis prediction task and are traceable to the clinical endpoint.",
      "rationale": "The primary QoI is the volume-averaged scalar stress exposure integrated along particle pathlines, converted to NIH via the Giersiepen-Wurzinger power-law hemolysis model. This QoI is directly traceable to the clinical endpoint of pump-induced hemolysis and is the accepted industry standard for CFD-based hemolysis prediction in rotary blood pumps. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities are conducted on the same device geometry or a sufficiently similar predicate; operating conditions span the intended COU envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the regulatory submission. Operating conditions cover the full COU envelope of 2.5–5.0 L/min flow and 2000–3500 RPM speed. The validation activity is directly relevant to the COU. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 beyond code verification already addressed.",
      "rationale": "At Model Risk Level 2, explicit numerical solver error assessment beyond code verification is not required per the ASME V&V 40 credibility matrix. This factor is not assessed and is acceptable for the current COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2.",
      "rationale": "Use error assessment is not required at Model Risk Level 2 for this COU. Standard simulation workflow checklists were applied but formal use error analysis was not performed. Acceptable for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
