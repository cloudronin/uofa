  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment panel reviewed all 13 ASME V&V 40 credibility factors for the CFD hemolysis prediction model at Model Risk Level 2. Seven factors were formally assessed; six were determined to be not required at MRL 2 and are acceptable. All assessed factors were evaluated against their required levels, and the panel determined that the overall evidence body supports acceptance of the model for the stated COU. The Test Conditions factor was subject to extended panel deliberation: while the structured boundary condition uncertainty propagation was not completed to the full quantitative standard anticipated at level 3, the panel noted that (a) individual measurement uncertainties are tightly bounded by calibrated instrumentation, (b) the experimental rig has an established publication record demonstrating repeatability, (c) two independent domain experts reviewed and endorsed the experimental protocol, and (d) the conservative RH < 1 acceptance criterion provides margin against residual boundary condition uncertainty. Taking these considerations together, the panel concluded by consensus that the evidence is sufficient for regulatory submission purposes and voted to accept the package. The model is accepted for use in identifying worst-case hemolysis operating conditions for the Class II CPB device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
