  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 factors applicable to MRL 2 evaluation of the FDA generic centrifugal blood pump CFD model. Seven factors were formally assessed; six factors were scoped as not-assessed consistent with MRL 2 requirements. Of the seven assessed factors, six achieved their required credibility levels. The Discretization error factor achieved Level 2 against a required Level 3; however, the team concludes that the available two-mesh sensitivity study, combined with the 3.8% RH variation between mesh densities, the comparative (rather than absolute) nature of the COU, and the unanimous expert judgment of three senior CFD engineers, provides sufficient practical confidence that discretization error does not materially affect the rank-ordering of worst-case hemolysis operating conditions. The turbulence model sensitivity study further demonstrates that model-form uncertainty is the dominant source of output variation, which is not the factor under evaluation. Given the MRL 2 context, the Class II device classification, and the conservative RH < 1 acceptance criterion applied against a predicate device baseline, the team judges the overall body of evidence to be adequate to support the intended regulatory use. The package is therefore accepted. The discretization evidence shortfall is noted in the project risk register for resolution prior to any MRL 3 re-evaluation.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
