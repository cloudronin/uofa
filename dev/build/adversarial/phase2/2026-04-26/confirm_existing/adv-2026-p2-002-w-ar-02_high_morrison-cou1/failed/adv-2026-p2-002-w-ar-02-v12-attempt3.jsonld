  "hasCredibilityFactor": [
    {
      "id": "https://uofa.net/synth/factor/software-quality-assurance",
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022R2) with documented V&V history; solver release notes and known-issue logs reviewed; no open issues affecting rotating machinery hemolysis predictions.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with ISO 9001-certified development processes. The project team reviewed the release notes and known-issue database for all versions from 2020R1 through 2022R2. No defects affecting rotating machinery or scalar transport (hemolysis power-law model) were identified. Internal QA checklist (Form QA-CFD-07) was completed prior to simulation execution. Level 2 is required and achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/numerical-code-verification",
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver passes at least two published benchmark cases relevant to rotating machinery or viscous flow; documented order-of-accuracy confirmation.",
      "rationale": "ANSYS Fluent has been verified against the ASME V&V 20 benchmark suite for internal flow and the FDA nozzle benchmark (FDA Critical Path). Published order-of-accuracy studies (Hariharan et al., 2011) confirm second-order spatial accuracy for the pressure-velocity coupling scheme used in this study. Code verification is satisfied at Level 2."
    },
    {
      "id": "https://uofa.net/synth/factor/discretization-error",
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Formal grid convergence study using at least three systematically refined meshes with GCI < 5% for the primary QoI (relative hemolysis index RH); Richardson extrapolation reported; asymptotic convergence confirmed.",
      "rationale": "A mesh sensitivity study was conducted using two mesh densities: a baseline mesh of 4.2 million polyhedral cells and a refined mesh of 8.7 million cells, yielding a mesh refinement ratio of approximately 1.27 in each spatial dimension. The relative hemolysis index RH varied by 3.8% between the two meshes, which the assessment team considers indicative of adequate mesh independence for the purposes of comparative design evaluation. The team draws on prior experience with similar centrifugal pump geometries (Morrison et al., 2021; Fraser et al., 2019) in which two-mesh sensitivity studies at comparable refinement ratios were found to be sufficient for identifying worst-case operating conditions, even in the absence of a formally extrapolated Richardson estimate. Expert judgment from three senior CFD engineers with a combined 45 years of rotating machinery simulation experience was solicited and unanimously supported the conclusion that the 3.8% variation is within acceptable bounds for MRL 2 device evaluation. The absence of a three-mesh Richardson extrapolation and formal GCI computation is acknowledged; however, given the comparative nature of the COU (RH relative to predicate, not absolute hemolysis prediction), the team is confident that the discretization error does not materially affect the rank-ordering of operating conditions. This conclusion is further supported by the turbulence model sensitivity study (ValidationResult cpb-turbulence-model-sensitivity), which showed that model-form uncertainty dominates discretization uncertainty at the operating points of interest. On balance, the available evidence is judged sufficient for acceptance at the current stage of device development."
    },
    {
      "id": "https://uofa.net/synth/factor/test-conditions",
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, hematocrit) documented and matched to CFD boundary conditions within stated uncertainty bounds.",
      "rationale": "All five flow-speed operating points were tested using a modified NIH hemolysis protocol with bovine blood at 37 ± 0.5 °C and hematocrit 33 ± 2%. CFD boundary conditions were set to match measured mean inlet velocity profiles and outlet static pressure. Uncertainty in flow rate measurement (Coriolis meter, ±0.5%) was propagated into CFD inlet boundary conditions. Test condition fidelity is rated Level 2 as required."
    },
    {
      "id": "https://uofa.net/synth/factor/output-comparison",
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Predicted RH index compared against experimental RH at each of 5 operating points; mean absolute error < 15%; trend (rank-ordering of worst-case condition) correctly predicted.",
      "rationale": "Predicted RH values at all five operating points were compared against experimental measurements. Mean absolute error across operating points was 9.2%, within the 15% acceptance criterion. The model correctly identified the 6 L/min / 3500 RPM condition as the worst-case hemolysis point, consistent with experimental findings. Output comparison is satisfied at Level 2."
    },
    {
      "id": "https://uofa.net/synth/factor/relevance-qoi",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoI (relative hemolysis index RH) directly maps to the regulatory acceptance criterion and is the primary output used in the submission decision.",
      "rationale": "The relative hemolysis index RH is the primary quantity of interest and is directly specified in the FDA guidance for CPB device submissions. The CFD model outputs the power-law hemolysis scalar field, which is integrated over the flow domain to yield RH. This QoI is directly relevant to the COU decision criterion (RH < 1 vs. predicate). Level 2 is required and achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/relevance-validation-activities",
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on the same FDA generic centrifugal pump geometry under CPB-representative operating conditions; fluid properties match clinical use.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal pump geometry (identical CAD to the CFD model) under CPB-representative conditions (bovine blood, 37 °C, 3–6 L/min, 2500–3500 RPM). The validation activities are directly relevant to the COU; no geometric or operational extrapolation is required. Level 2 is required and achieved."
    },
    {
      "id": "https://uofa.net/synth/factor/numerical-solver-error",
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not assessed at MRL 2 for comparative hemolysis evaluation; solver error subsumed under software quality assurance and code verification factors.",
      "rationale": "At MRL 2, separate quantification of numerical solver error beyond code verification is not required. This factor is scoped as not-assessed per the ASME V&V 40 MRL 2 requirements table. The software quality assurance and numerical code verification factors collectively address solver reliability."
    },
    {
