  "signature": "ed25519:9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a9f8e",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented release notes and regression test suite demonstrating code stability across relevant flow regimes.",
      "rationale": "ANSYS Fluent 2023R1 is used under an institutional license with documented version control. A regression test suite covering laminar and turbulent benchmark cases was executed prior to the study, with all cases passing within specified tolerances. Software quality assurance is assessed as meeting the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Verification of numerical implementation through comparison against analytical solutions or established benchmark problems for at least one flow configuration representative of the COU.",
      "rationale": "The solver was verified against the Poiseuille flow analytical solution and the FDA nozzle benchmark (FDA Critical Path initiative). Observed order of convergence was consistent with the theoretical second-order accuracy of the discretization scheme. Code verification is satisfied at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence study with at least three systematically refined meshes; GCI reported for the primary quantity of interest (hemolysis index).",
      "rationale": "Three mesh densities (4.2M, 9.8M, and 21.4M elements) were evaluated using the Grid Convergence Index methodology per Roache (1998). The fine-mesh GCI for the normalized hemolysis index was 3.1%, below the 5% threshold established in the analysis plan. Discretization error is assessed as meeting the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) documented and matched to CFD boundary conditions within specified tolerances; environmental conditions recorded.",
      "rationale": "All five operating points (2.5 L/min at 2500 RPM, 3.5 L/min at 3500 RPM, 5.0 L/min at 2500 RPM, 5.0 L/min at 3500 RPM, 6.0 L/min at 4500 RPM) were reproduced with inlet flow rates matched to within ±2% of experimental setpoints. Fluid temperature was maintained at 37°C ± 0.5°C. Rotational speed was servo-controlled to ±10 RPM. Test conditions are fully documented and meet the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Quantitative comparison of CFD-predicted hemolysis index against experimental measurements using defined metrics (e.g., relative error, normalized RMS); comparison covers all five operating conditions.",
      "rationale": "The normalized index of hemolysis (NIH) and relative hemolysis index (RH) were compared across all five operating conditions. Mean relative error across operating points was 8.4%, within the pre-specified 15% acceptance band. RH remained below 1.0 for all conditions relative to the predicate device benchmark. Output comparison is assessed as meeting the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantities of interest (NIH, RH) are directly linked to the clinical decision endpoint; linkage is documented in the analysis plan.",
      "rationale": "The normalized index of hemolysis is the regulatory-accepted surrogate for pump-induced red blood cell damage and is directly referenced in FDA guidance for CPB device submissions. The linkage between NIH, RH, and the clinical acceptance criterion (RH < 1) is documented in the analysis plan and is consistent with ISO 10993-4 biocompatibility framework. QoI relevance is assessed as meeting the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments must be conducted on the same device geometry and at operating conditions spanning the full COU envelope, including all five target flow-speed combinations, with blood analog fluid properties matched to within specified physiological tolerances.",
      "rationale": "Validation activities were conducted using the FDA generic centrifugal blood pump geometry, which is the same geometry employed in the COU simulations. Experiments used a glycerol-water blood analog fluid (viscosity 3.5 mPa·s at 37°C) that closely approximates the rheological behavior of human blood under the shear rates predominant in centrifugal pumps. The team brings extensive prior experience with this benchmark platform, having conducted three prior validation campaigns on related impeller geometries over the past six years. Expert judgment from two independent hemolysis modeling specialists, both with more than a decade of experience in cardiovascular CFD, confirms that the validation approach is consistent with current best practice for MRL 2 assessments. While the formal validation dataset covers four of the five target operating conditions — the highest-speed condition (6.0 L/min at 4500 RPM) was not experimentally validated due to a laboratory instrument limitation that arose after the analysis plan was finalized — the team assessed that the interpolated prediction at this point is well-supported by the surrounding validated conditions and the monotonic trend observed in hemolysis across the operating envelope. The missing operating point represents an extrapolation of less than 12% beyond the validated speed range, and sensitivity analyses indicate that the hemolysis index at this condition is not disproportionately sensitive to model form uncertainty. On balance, the breadth and quality of the validation activities, combined with the supporting expert judgment and historical data, provide sufficient confidence in model performance across the COU. The credibility team therefore assessed this factor as adequate for the purposes of the MRL 2 decision, consistent with the overall risk posture of the assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
