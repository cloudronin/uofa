  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-2026-04-19",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors applicable to this MRL 2 context of use. Seven factors were formally assessed; six were determined to be not required at MRL 2 and were assigned default level 1 ratings consistent with the assessment matrix. Among the assessed factors, the team concludes that the overall body of evidence is sufficient to support acceptance of the CFD model for the intended use of identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions. The output comparison factor demonstrated mean relative error of 8.4% across validated conditions, well within the 15% acceptance band. Mesh convergence was rigorously established with a GCI of 3.1% on the primary quantity of interest. The relevance of validation activities to the COU was considered carefully, and the team determined that the combination of four validated operating conditions, the monotonic hemolysis trend, expert judgment from two independent specialists, and the team's six-year history with this benchmark platform collectively provide adequate confidence in model performance across the full COU envelope, including the unvalidated fifth operating condition. The decision to accept is made with full awareness of the documentation gap at the highest operating condition and reflects the team's professional judgment that the residual uncertainty does not materially affect the model's fitness for the stated intended use at MRL 2. The relative hemolysis index remains below 1.0 across all predicted conditions, supporting the regulatory acceptance criterion.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
