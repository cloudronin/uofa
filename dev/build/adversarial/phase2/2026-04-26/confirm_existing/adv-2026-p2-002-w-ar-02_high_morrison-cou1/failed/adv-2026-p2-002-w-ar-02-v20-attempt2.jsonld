  "signature": "ed25519:7b2a1f9e3c8d4b0a5e6f2c1d9b3a7e4f8c2d1b0a9e5f3c7d2b1a8e4f6c3d9b2a",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented release notes and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022 R2 was used under a formal QA plan. The solver version is registered in the project configuration management system. A regression test suite of 14 canonical cases was executed prior to the study, with all cases passing within defined tolerances. Software quality assurance meets Gradation 2 requirements for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Demonstration that the numerical solver correctly implements the governing equations through at least one benchmark problem relevant to rotating machinery internal flow.",
      "rationale": "Code verification was performed using the Method of Manufactured Solutions (MMS) for the incompressible Navier-Stokes equations on a rotating reference frame. Observed order of accuracy was 1.97 for velocity components and 1.94 for pressure, consistent with the nominal second-order scheme. Results are documented in the project verification report VR-CPB-2024-01."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Grid convergence study with at least three systematically refined meshes; GCI reported for the primary quantity of interest (scalar stress proxy for hemolysis).",
      "rationale": "A three-level grid convergence study was performed with mesh densities of 2.1M, 5.8M, and 14.3M cells. The Grid Convergence Index (GCI) for the volume-averaged scalar stress (hemolysis proxy) was 3.2% on the fine mesh, below the 5% threshold. The medium mesh (5.8M cells) was selected for production runs based on the Richardson extrapolation plateau. Discretization error is well-characterized and within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature) documented and traceable to calibrated instrumentation with stated uncertainty.",
      "rationale": "All bench test conditions were controlled and recorded using calibrated instrumentation (flow meter ±1.5%, tachometer ±0.2%, temperature ±0.5°C). Test protocols followed ASTM F1841 guidance. Boundary conditions applied to the CFD model were derived directly from the logged experimental values. Traceability to calibration certificates is documented in test report TR-CPB-2024-03."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison of CFD-predicted hemolysis index against experimental measurements at all five operating points, with agreement within combined experimental and numerical uncertainty.",
      "rationale": "The normalized index of hemolysis (NIH) predicted by CFD was compared against bench measurements at all five flow-speed operating points. Mean absolute error was 8.3% and all predictions fell within the combined uncertainty band (experimental ±12%, numerical ±5%). The relative hemolysis index RH remained below 1.0 at all operating points for the nominal geometry, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Demonstration that the CFD QoI (scalar stress-based hemolysis index) is mechanistically linked to the clinical endpoint (RBC damage) and is sensitive to the geometric variations under study.",
      "rationale": "The scalar stress hemolysis model (Giersiepen-Wurzinger power law) is the industry-standard surrogate for RBC damage in computational hemolysis studies and has been accepted by FDA in 510(k) submissions for similar Class II blood-contacting devices. Sensitivity analysis across the five operating points confirmed that the QoI discriminates between geometric variants with statistical significance (p < 0.05 for the primary dimensional tolerance)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry, fluid, and operating envelope as the COU; any differences in conditions are bounded and justified.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal blood pump geometry using ovine blood analog (glycerin-water, viscosity matched to 37°C whole blood). Operating points span the full clinical flow-speed envelope (3–6 L/min, 2000–3500 RPM). The COU geometry is identical to the validation geometry; no extrapolation of validation evidence is required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 when code verification has been performed and solver is commercially validated.",
      "rationale": "At MRL 2, explicit numerical solver error assessment beyond code verification is not mandated. The use of a commercially released, regression-tested solver satisfies the baseline expectation. This factor is not assessed per the MRL 2 scoping decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this COU given medium model influence.",
      "rationale": "Use error assessment is not required at MRL 2 with medium model influence. Standard SOPs for CFD setup and boundary condition application were followed. This factor is scoped out of the formal assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2; model form uncertainty addressed implicitly through validation comparison.",
      "rationale": "Model form uncertainty (turbulence closure, hemolysis constitutive model) is not explicitly assessed at MRL 2. The output comparison factor captures the aggregate effect of model form choices. This factor is not assessed per the MRL 2 scoping decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this COU.",
      "rationale": "Formal model input uncertainty propagation is not required at MRL 2. Fluid properties were measured and applied as point estimates. Geometric inputs were derived from nominal CAD with manufacturing tolerances noted. This factor is not assessed per the MRL 2 scoping decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on a statistically representative sample of pump units drawn from production lot, with inter-unit variability characterized and incorporated into the validation uncertainty budget.",
      "rationale": "Hemolysis bench testing was performed on three pump units sourced from the same production batch. The inter-unit coefficient of variation in NIH was 6.4%, which the assessment team considers acceptable given the tight dimensional tolerances of the CNC-machined components (Cpk > 1.33 for all critical dimensions). The team notes that the FDA guidance for 510(k) hemolysis submissions (FDA-2021-D-0758) does not specify a minimum sample size for bench hemolysis testing, and that prior published studies on the FDA generic pump (Hariharan et al., 2011; Malinauskas et al., 2017) have used comparable or smaller sample sizes without adversely affecting regulatory acceptance. Expert judgment from the biomedical device testing community supports the view that three units is sufficient to characterize lot-to-lot variability for a mature, high-precision manufacturing process. Furthermore, the conservative acceptance criterion (RH < 1.0) provides a performance margin that absorbs residual inter-unit variability. On balance, the assessment team concluded that the sample evidence, while not satisfying the full statistical representativeness requirement of Gradation 3, is adequate in the context of this COU and the overall weight of evidence, and the package is recommended for acceptance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 when test conditions factor has been assessed and boundary condition traceability is established.",
      "rationale": "Equivalency of input parameters between the validation experiments and the COU simulation is addressed implicitly through the test conditions factor. No additional assessment is required at MRL 2. This factor is not assessed per the MRL 2 scoping decision."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for MRL 2. Seven factors were formally assessed; six were scoped out as not required at MRL 2 with medium model influence. Of the seven assessed factors, six achieved their required gradation level. The Test samples factor achieved Gradation 2 against a required Gradation 3; however, the team determined that the three-unit sample, combined with low inter-unit variability (CV 6.4%), conservative acceptance criterion (RH < 1.0), and alignment with published practice for the FDA generic pump geometry, provides sufficient confidence for the intended regulatory use. The overall weight of evidence — including a well-characterized grid convergence study (GCI 3.2%), MMS-verified solver, full operating-envelope output comparison (MAE 8.3%), and direct geometric equivalence between validation and COU — supports acceptance of the package at the Medium assurance level. The package is Accepted for submission in support of the 510(k) hemolysis assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
