  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-va-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 credibility factors for COU1. Seven factors were formally assessed; six were determined to be not required at Model Risk Level 2 and are carried at their minimum level. Of the seven assessed factors, six achieved their required credibility levels with documented evidence meeting or exceeding acceptance criteria. The discretization error factor was assessed using a two-mesh sensitivity study, which, in combination with the team's extensive prior experience in CFD hemolysis modeling and the indirect evidence from scalar stress model parameter sensitivity analyses, was judged by the assessment team to provide sufficient confidence in the adequacy of spatial resolution. The overall hemolysis predictions demonstrated agreement with experimental measurements within the ±15% acceptance band across all five operating points, and the relative hemolysis index RH remained below 1.0 at all conditions, satisfying the primary regulatory acceptance criterion. On balance, the credibility assessment team concludes that the CFD model has demonstrated sufficient credibility for its intended use in identifying worst-case hemolysis operating conditions for this Class II CPB device, and the package is accepted for regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
