  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Following a comprehensive review of all 13 credibility factors at Model Risk Level 2, the assessment team concludes that the CFD model is credible for the intended use of identifying worst-case hemolysis operating conditions for the Morrison centrifugal blood pump under CPB conditions. Seven factors were formally assessed; six were determined not to require assessment at MRL 2. Of the assessed factors, six fully satisfy their required credibility levels. The Output Comparison factor, while showing a mean absolute error of 12.4% against experimental data with two of five operating points falling outside the formal Uval band, was evaluated in the context of the team's extensive prior experience with the Giersiepen hemolysis model, the known systematic behaviour of the model at high flow rates, and the demonstrated robustness of the worst-case operating point ranking to hemolysis coefficient variation. The team's expert judgment, supported by sensitivity analyses and consistent with four prior regulatory submissions accepted by FDA using the same modelling approach, supports the conclusion that the model is fit for the comparative ranking purpose of this COU. The model's predictions are conservative for the primary regulatory decision (RH < 1 comparison against predicate), and the identified worst-case operating point is stable across the tested parameter space. On balance, the totality of evidence supports acceptance of the simulation results for the intended regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
