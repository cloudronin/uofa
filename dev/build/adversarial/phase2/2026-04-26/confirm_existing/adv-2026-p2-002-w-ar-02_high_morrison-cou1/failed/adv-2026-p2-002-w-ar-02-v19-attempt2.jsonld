  "signature": "ed25519:b7d3f1a9c2e6b4d8f0a5c3e7b2d9f4a1c6e8b0d5f2a7c4e1b8d6f3a9c0e5b2d7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Version-controlled solver with documented release notes and regression test suite covering blood pump relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 is used under a validated installation qualification (IQ) and operational qualification (OQ) protocol. The software is version-controlled, and all simulation scripts are stored in a Git repository with tagged releases. A regression test suite of 14 canonical cases is executed prior to each study campaign. No deviations from the qualified configuration were recorded during this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Solver passes at least one published benchmark verification case relevant to rotating machinery or internal viscous flow.",
      "rationale": "Code verification was performed against the ASME V&V 20 lid-driven cavity benchmark and the Taylor-Couette flow analytical solution. Observed order of accuracy for velocity components was 1.94, consistent with the solver's second-order spatial discretisation. Results are documented in the internal verification report VR-2023-07."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the primary QoI (volume-averaged scalar stress) on the fine mesh; Richardson extrapolation performed across at least three mesh levels.",
      "rationale": "A three-level mesh convergence study was conducted with coarse (4.2 M cells), medium (9.8 M cells), and fine (22.1 M cells) polyhedral meshes. Richardson extrapolation yielded a GCI of 3.1% on the fine mesh for volume-averaged scalar shear stress, the primary hemolysis driver. The apparent order of convergence was 1.87, within acceptable range of the nominal second-order scheme. Boundary layer resolution was confirmed with y+ values between 1 and 5 across all impeller surfaces."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, rotational speed, flow rate) documented and matched to simulation boundary conditions within stated tolerances.",
      "rationale": "The validation experiments were conducted at 37°C with bovine blood at 33% hematocrit, consistent with the CPB clinical operating range. Pump speed was set at 2400 RPM and 3000 RPM; flow rates of 2.5, 3.5, and 5.0 L/min were tested. All boundary conditions in the CFD model were set to match the experimental nominal values. Measurement uncertainties for flow rate (±2%) and rotational speed (±0.5%) were within the simulation sensitivity range established during the uncertainty analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation uncertainty Uval) reported for primary QoI across all validation cases; statistical agreement demonstrated at the required confidence level.",
      "rationale": "Predicted relative hemolysis index (RH) values were compared against experimental measurements across all five operating points. Mean absolute percentage error across the five operating points was 12.4%, with individual point errors ranging from 4.1% to 19.7%. The team notes that three of five operating points fell within the expanded validation uncertainty band (Uval = 15% at 95% confidence), and the two outlier points correspond to the highest flow-rate condition where experimental scatter was also elevated. Prior published work using the same power-law hemolysis model (Giersiepen et al.) on comparable centrifugal geometries has demonstrated systematic overprediction at high flow rates, a behaviour consistent with the present results. The assessment team, drawing on seven years of cumulative experience with this model class and four prior regulatory submissions accepted by FDA, concluded that the observed discrepancies are attributable to a known model-form limitation at high shear gradients rather than to a fundamental credibility shortfall. Expert judgment, corroborated by the favourable trends in the lower flow-rate regime and by sensitivity analyses confirming that the worst-case operating point identification is robust to ±20% variation in the hemolysis model coefficients, supports the view that the model is fit for the intended comparative ranking purpose even though the formal quantitative validation metric does not fully satisfy the Gradation 3 threshold for all operating points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation (scalar shear stress, RH index) are directly linked to the clinical endpoint (hemolysis) and the regulatory acceptance criterion (RH < 1).",
      "rationale": "The primary QoI, the relative hemolysis index RH, is directly tied to the regulatory acceptance criterion and is the same metric used in predicate device comparisons. Volume-averaged scalar shear stress is an intermediate QoI that feeds directly into the power-law hemolysis model. Both QoIs are standard in the published CFD hemolysis literature and have been used in prior FDA-accepted submissions. The linkage between simulation outputs and clinical hemolysis endpoints is well-established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry or a geometrically similar predicate; operating conditions span the COU envelope.",
      "rationale": "Validation experiments were conducted on the FDA generic centrifugal blood pump, the same geometry used in the COU. Operating conditions tested in validation (2400–3000 RPM, 2.5–5.0 L/min) bracket the five worst-case candidate operating points identified in the design sensitivity study. The validation domain therefore directly encompasses the COU operating envelope without extrapolation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2 for this factor category; default level accepted.",
      "rationale": "At Model Risk Level 2, explicit iterative convergence error quantification beyond residual monitoring is not required. Residuals for all equations were converged to below 1e-5 in all simulations, and mass imbalance was below 0.01%. No further assessment is warranted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2; analyst qualifications documented.",
      "rationale": "All simulations were performed by engineers holding a minimum of an M.S. in mechanical or biomedical engineering with at least three years of CFD experience in cardiovascular applications. Simulation setup was reviewed by a senior analyst prior to execution. Formal use-error assessment is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2; model form selection documented.",
      "rationale": "The k-omega SST turbulence model was selected based on its established performance in rotating machinery flows and prior use in FDA-accepted centrifugal pump submissions. The Giersiepen power-law hemolysis model is the standard choice for comparative hemolysis assessment. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2; nominal input values documented.",
      "rationale": "All model inputs (fluid viscosity, density, hemolysis model coefficients, boundary conditions) are documented in the simulation report with traceability to experimental measurements or published literature. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "Not required at MRL 2; sample description documented.",
      "rationale": "Bovine blood samples used in validation experiments were sourced from a single supplier batch to minimise inter-sample variability. Hematocrit was adjusted to 33 ± 1% prior to each test. Sample characterisation beyond this level is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
