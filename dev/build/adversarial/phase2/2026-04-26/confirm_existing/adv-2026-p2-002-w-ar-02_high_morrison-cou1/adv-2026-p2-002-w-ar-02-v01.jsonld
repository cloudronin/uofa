  "signature": "ed25519:b1d3e5f7a9c2b4d6e8f0a1c3d5e7b9f1a2c4d6e8f0b1c3d5e7a9b2c4d6e8f0a1b3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver (ANSYS Fluent 2022R2) with documented V&V history; solver release notes and regression test suite reviewed. Required level 2 for MRL 2.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver subject to ISO 9001-certified QA processes. Regression testing covering rotating machinery benchmarks was reviewed and found satisfactory. No solver defects relevant to the hemolysis power-law model were identified in the release errata. Level 2 achieved and required level met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured solution or benchmark comparison for the hemolysis scalar transport equation demonstrating correct order-of-accuracy behavior.",
      "rationale": "The hemolysis power-law scalar transport implementation was verified against the Giersiepen-Wurzinger benchmark case. Observed convergence rate was 1.92 (theoretical: 2.0), within acceptable tolerance. Code verification is complete at level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) study on at least three systematically refined meshes; GCI < 5% on hemolysis index QoI.",
      "rationale": "Three systematically refined meshes (4.1M, 11.3M, 28.7M cells) were constructed using a refinement ratio of 1.41. Richardson extrapolation yielded a GCI of 3.2% on the relative hemolysis index at the worst-case operating point (6 LPM, 3000 RPM). Discretization error is bounded within acceptance criteria. Level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, outlet pressure, fluid temperature, rotational speed) documented and replicated in CFD setup within ±2% of nominal values.",
      "rationale": "All five experimental operating points were replicated in the CFD model. Inlet flow rates were matched to ±0.8%, rotational speeds to ±0.5%, and fluid viscosity (bovine blood, 37°C) was set using the Carreau-Yasuda model parameterized from the experimental fluid lot. Level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison of predicted vs. measured normalized index of hemolysis (NIH) with error metric reported; mean absolute error < 15%.",
      "rationale": "Predicted NIH values across all five operating points showed a mean absolute error of 9.3% relative to experimental measurements, with a maximum single-point error of 13.7% at the 4 LPM / 2500 RPM condition. All predictions fell within the experimental measurement uncertainty band (±12%). Level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (relative hemolysis index RH) is directly linked to the clinical endpoint and regulatory acceptance criterion; mapping documented.",
      "rationale": "The relative hemolysis index RH is the primary regulatory QoI per FDA guidance for CPB devices. The mapping from CFD-predicted shear stress history to RH via the power-law model is documented in the V&V plan. The clinical endpoint (plasma-free hemoglobin elevation) is directly governed by RH. Level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the same device geometry, fluid, operating regime, and QoI as the COU; gaps documented and bounded.",
      "rationale": "Validation was performed on the identical FDA generic centrifugal pump geometry under the same CPB operating envelope (2–6 LPM, 2000–3500 RPM) using bovine blood as a human blood surrogate. Species differences in RBC fragility are documented and bounded by a conservative correction factor of 1.08 applied to predicted RH values. Validation activities are directly relevant to the COU. Level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence demonstrated; residuals reduced by at least 4 orders of magnitude and monitored QoI stable over final 500 iterations.",
      "rationale": "All simulations achieved residual reduction of 5–6 orders of magnitude. The hemolysis index QoI varied by less than 0.1% over the final 500 iterations across all five operating points. Solver error is negligible. Level 1 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup independently reviewed by a second analyst; checklist completed and signed.",
      "rationale": "A second qualified CFD analyst independently reviewed the simulation setup files, boundary condition assignments, turbulence model selection (SST k-omega), and post-processing scripts. No discrepancies were identified. Use error review checklist completed and archived. Level 1 achieved and required."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2 for this factor; scoping rationale documented.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis constitutive model) is not required to be formally assessed at MRL 2 given medium model influence. The SST k-omega model is the de facto standard for internal rotating machinery flows and is accepted by precedent. Not assessed per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; material and geometric input uncertainties bounded by engineering judgment.",
      "rationale": "Formal uncertainty quantification of model inputs (blood rheology parameters, pump geometry tolerances) is not required at MRL 2. Nominal values from the device design specification and published literature were used. Not assessed per MRL 2 scoping."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test samples must be representative of the device population: at minimum three independently manufactured pump units tested, with unit-to-unit variability characterized and reported as a coefficient of variation (CV) on NIH.",
      "rationale": "The validation experimental dataset was generated using two independently manufactured pump units (Unit A and Unit B), both fabricated to nominal drawing tolerances. NIH measurements were performed in triplicate on each unit across all five operating points, yielding 30 total experimental data points. The coefficient of variation across units was 6.8%, which the team considers acceptably low based on prior experience with similar centrifugal pump geometries in the team's laboratory, where CV values of 5–10% have historically been associated with adequate representativeness. Expert judgment from three senior biofluid mechanics engineers, each with more than 15 years of rotary blood pump testing experience, concurred that two units are sufficient to characterize the manufacturing variability of this geometry given its relatively simple impeller profile and tight CNC tolerancing (±0.05 mm). Furthermore, the FDA benchmark dataset for this generic pump geometry, on which the solver was previously validated in an independent study (Morrison et al., 2021), was also generated from two units, establishing a methodological precedent that the regulatory community has implicitly accepted. The team therefore concludes that the sample representativeness is adequate for the purposes of this MRL 2 assessment, and that the marginal additional confidence from a third unit would not materially alter the credibility conclusion given the low inter-unit CV already observed. On this basis, the assessment team has determined that the evidence is sufficient to support an Accepted outcome at the package level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; equivalency of validation and COU input parameters addressed qualitatively.",
      "rationale": "Formal equivalency analysis of validation versus COU input parameters is not required at MRL 2. Qualitative review confirmed that the validation operating envelope fully encompasses the COU operating points. Not assessed per MRL 2 scoping."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team has reviewed all 13 ASME V&V 40 credibility factors for COU1. Seven factors were formally assessed; six were scoped out as not required at MRL 2. Of the seven assessed factors, the team finds that the overall body of evidence is sufficient to support model acceptance for the intended use. The CFD model demonstrates well-controlled discretization error (GCI 3.2%), strong output comparison agreement (MAE 9.3%), and direct relevance of validation activities to the COU. The Test samples factor was assessed at level 2 against a required level of 3; however, the team judges that the low inter-unit coefficient of variation (6.8%), the precedent established by the FDA benchmark dataset methodology, and the concurring expert judgment of three senior engineers collectively provide adequate compensating evidence that the two-unit sample is representative of the device population. No other factor shortfalls were identified. On balance, the simulation evidence is judged credible and fit for the regulatory submission purpose of identifying worst-case hemolysis operating conditions for the Class II CPB device. Decision: Accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
