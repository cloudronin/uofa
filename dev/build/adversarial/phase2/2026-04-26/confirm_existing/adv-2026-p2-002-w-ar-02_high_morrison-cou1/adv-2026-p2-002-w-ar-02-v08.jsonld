  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team recommends Acceptance of the Morrison COU1 CFD hemolysis model for the intended use of identifying worst-case hemolysis operating conditions for a Class II CPB device at MRL 2. Six of the seven assessed factors achieve their required credibility levels. The Test Conditions factor is acknowledged to have achieved Level 2 against a Level 3 requirement; however, the team has determined that this shortfall does not materially affect the reliability of the model evidence for the following reasons: (1) sensitivity analyses demonstrate that the uncharacterized inlet turbulence parameter has less than 4% influence on the primary QoI; (2) the pump geometry and operating regime are well-represented in the published validation literature, providing a strong prior basis for confidence in the boundary condition adequacy; (3) expert consensus from the 2023 FDA/CDRH workshop supports treating inlet turbulence as a secondary factor for impeller-dominated centrifugal pumps; and (4) the remaining six assessed factors all meet or exceed their required levels, providing a robust overall credibility profile. The team further notes that the six non-assessed factors are all scoped out at their minimum required level of 1, consistent with MRL 2 practice. On balance, the totality of evidence supports that the model is sufficiently credible for the regulatory submission decision, and the package is accepted.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
