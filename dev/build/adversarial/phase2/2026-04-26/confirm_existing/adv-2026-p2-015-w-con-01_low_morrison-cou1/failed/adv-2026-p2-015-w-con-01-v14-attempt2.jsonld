      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must be documented and traceable to the COU operating envelope.",
      "rationale": "Bench-top experiments conducted at 5 flow-speed combinations (2–6 L/min, 2000–3500 RPM) spanning the CPB operating envelope. Test conditions documented in lab notebook LN-2023-047. Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Model predictions of normalized index of hemolysis (NIH) must agree with experimental measurements within 15% across all 5 operating points.",
      "rationale": "NIH predictions compared against experimental plasma-free hemoglobin measurements. Mean relative error 9.3% across 5 operating points; all within 15% tolerance band. Gradation 2 satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in validation (NIH, scalar shear stress) must be directly linked to the COU decision metric (RH index).",
      "rationale": "Scalar stress and NIH are standard hemolysis surrogates linked to RH index via power-law hemolysis model (Giersiepen 1990). Direct correspondence between validation QoIs and COU decision metric established. Gradation 2 satisfied."
    },
