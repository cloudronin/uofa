  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used in the simulation must be under version control with documented test suite results demonstrating code correctness at the required gradation.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented QA procedures. Version control records and release notes confirm compliance with Gradation 2 SQA requirements for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Code verification via method of manufactured solutions or benchmark comparisons demonstrating correct implementation of governing equations.",
      "rationale": "Benchmark comparisons against ASME V&V 20 pipe flow cases and lid-driven cavity solutions confirm correct solver implementation. Residual convergence to 1e-6 demonstrated across all verification cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Mesh convergence study demonstrating discretization error below 5% for quantities of interest at the selected mesh density.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.8M, 14.2M cells). Richardson extrapolation yields GCI < 2.3% for shear stress and velocity fields. Selected mesh (5.8M cells) achieves Gradation 3 discretization control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions must be sufficiently documented to allow meaningful comparison with simulation boundary conditions.",
      "rationale": "FDA experimental dataset provides flow rate, rotational speed, fluid properties, and temperature for all 5 operating points. Boundary condition uncertainty estimated at ±2% for flow rate and ±0.5% for rotational speed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Quantitative comparison metrics between simulation outputs and experimental measurements must demonstrate acceptable agreement for the hemolysis index quantity of interest.",
      "rationale": "Relative hemolysis index predictions agree with experimental measurements within 18% across all 5 operating points. Mean absolute error of 0.12 RH units is within the acceptance band defined for MRL 2 comparative assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "The quantities of interest used in validation must be directly relevant to the clinical decision being made regarding hemolysis risk.",
      "rationale": "The relative hemolysis index (RH) is directly used as the regulatory acceptance criterion. Wall shear stress and exposure time distributions are the primary model outputs, directly mapping to the Giersiepen power-law hemolysis model used for RH calculation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the COU to support extrapolation of credibility evidence.",
      "rationale": "Validation performed on the same FDA generic centrifugal pump geometry under identical flow-speed operating envelope. Blood analog fluid (glycerin-water) properties match within 5% of physiological blood viscosity at relevant shear rates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "rationale": "Iterative convergence monitored via residual norms; however, formal solver error quantification was not completed within the project schedule. The factor was reviewed by the assessment team but level assignment was deferred pending additional benchmarking."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "rationale": "Use error assessment was scoped out at MRL 2 for this comparative study. The simulation was executed by experienced CFD analysts following documented simulation protocols."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "rationale": "Model form uncertainty was not formally assessed at MRL 2. The k-omega SST turbulence model was selected based on prior literature for rotating machinery blood flow applications."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "rationale": "Sensitivity analysis of model inputs was not required at MRL 2. Nominal fluid properties and boundary conditions were applied as specified in the FDA experimental protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "rationale": "Test sample characterization was not assessed at MRL 2. The FDA dataset was accepted as the reference experimental corpus without additional sample-level uncertainty analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "not-assessed",
      "rationale": "Equivalency of input parameters between validation and COU configurations was not formally scored. Qualitative review confirmed that operating conditions are within the validated envelope."
