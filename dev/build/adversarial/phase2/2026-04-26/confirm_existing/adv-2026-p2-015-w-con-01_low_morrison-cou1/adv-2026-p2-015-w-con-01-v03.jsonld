  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Software used for CFD simulation must be validated and version-controlled per MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2021 R2 was used under a documented quality management system. Version control logs and installation qualification records confirm compliance with MRL 2 software quality requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Numerical code must be verified against benchmark problems relevant to rotating machinery flow.",
      "rationale": "Code verification performed using Taylor-Couette flow benchmark. Observed order of accuracy consistent with theoretical second-order convergence rate, confirming solver implementation correctness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "Discretization error must be quantified via mesh refinement study; GCI < 5% for QoI.",
      "rationale": "Three-level mesh refinement study conducted. Grid Convergence Index for hemolysis index QoI was 2.8%, well within the 5% acceptance threshold. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Experimental test conditions used for validation must correspond to the clinical operating envelope of the CPB device.",
      "rationale": "FDA experimental data collected at flow rates 2–6 L/min and rotational speeds 2000–3500 RPM, spanning the intended CPB operating range. Temperature and blood analog properties documented and matched to simulation boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Simulated relative hemolysis index must agree with experimental measurements within acceptance band.",
      "rationale": "Simulated RH values compared against FDA experimental measurements across all 5 flow-speed operating points. Mean absolute error of 8.3% observed; all predictions within ±15% experimental uncertainty band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "QoIs used in simulation must be clinically relevant and directly linked to hemolysis risk assessment.",
      "rationale": "Relative hemolysis index (RH) selected as primary QoI, directly corresponding to the clinical acceptance criterion RH < 1.0 used in predicate device comparisons. Scalar stress exposure integral used as secondary QoI for mechanistic insight."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "Validation activities must be sufficiently relevant to the COU geometry, flow regime, and hemolysis mechanism.",
      "rationale": "Validation performed on the same FDA generic centrifugal pump geometry under identical CPB flow conditions. Hemolysis model (power-law Giersiepen-Wurzinger) validated in prior literature for centrifugal pump applications."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "rationale": "Iterative convergence monitored via residual norms; all simulations converged to residuals below 1e-5.",
      "acceptanceCriteria": "Solver residuals must reach acceptable convergence thresholds before results are used."
    },
    {
