  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented QA procedures and regression test suite.",
      "rationale": "ANSYS Fluent 2022 R1 is deployed under institutional version control. A documented regression test suite covering 12 canonical flow cases was executed prior to the study. All tests passed. QA procedures conform to ISO 9001 requirements maintained by the software vendor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via method of manufactured solutions or equivalent benchmark problems demonstrating correct numerical implementation.",
      "rationale": "Order-of-accuracy testing using the method of manufactured solutions confirmed second-order spatial accuracy for the momentum and scalar transport equations. Results are consistent with published ANSYS Fluent verification benchmarks."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the primary QoI (relative hemolysis index RH) across all operating points.",
      "rationale": "Three-level mesh refinement study performed at all 5 flow-speed operating points. GCI for RH ranged from 1.2% to 3.8%, satisfying the 5% threshold. Fine-grid solution selected as production mesh with 4.7 million polyhedral cells."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid properties, rotational speed, flow rates) must match simulation boundary conditions within stated tolerances.",
      "rationale": "FDA benchmark experimental data acquired at 37 °C with bovine blood analog fluid. Simulation boundary conditions replicate reported flow rates (2.5–6.0 L/min) and rotational speeds (2000–3500 RPM) within ±2% measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated RH index compared against experimental RH measurements; agreement within combined experimental and numerical uncertainty bands.",
      "rationale": "Simulated RH values agree with experimental measurements within ±15% across all 5 operating points, which falls within the combined uncertainty band. Systematic over-prediction at low flow rates is consistent with known turbulence model behavior and is within acceptable bounds for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI used in validation (RH index) must directly correspond to the QoI used in the COU decision.",
      "rationale": "The relative hemolysis index RH is the primary QoI in both the validation activity and the COU decision criterion (RH < 1 relative to predicate). Direct correspondence confirmed; no surrogate QoI mapping required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on geometry and operating conditions sufficiently representative of the COU device and operating envelope.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which shares key geometric features (impeller diameter, volute design) with the COU device. Operating conditions span the clinical CPB flow-speed envelope. Relevance judged sufficient for MRL 2."
    },
    {
      "type": "CredibilityFactor",
