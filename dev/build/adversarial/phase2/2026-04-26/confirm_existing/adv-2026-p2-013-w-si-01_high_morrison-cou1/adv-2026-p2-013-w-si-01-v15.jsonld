  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented under a quality management system with version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 2022 R2 is employed under an ISO 9001-compliant QMS. Version control is maintained via Git; automated regression test suite covers 47 canonical benchmark cases. Software qualification report SQR-2022-FL-001 confirms Gradation 2 compliance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct numerical implementation via manufactured solution or benchmark comparison at Gradation 2.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes equations confirms second-order spatial convergence. Lid-driven cavity and backward-facing step benchmarks reproduce published results within 0.5% for velocity profiles."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error in hemolysis index QoI must be quantified and shown to be below 5% using a formal grid convergence study at Gradation 2.",
      "rationale": "Three-level grid convergence study (1.2M, 4.8M, 19.2M cells) yields GCI of 2.1% on the normalized index of hemolysis (NIH) at the design operating point of 5 L/min, 3500 RPM. Richardson extrapolation applied; asymptotic convergence ratio of 0.97 confirms solution is in the convergent regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and shown to be representative of the COU operating envelope at Gradation 2.",
      "rationale": "FDA benchmark hemolysis experiments conducted at 2.5, 5.0, and 7.0 L/min at 2500 and 3500 RPM. Temperature (37 ± 0.5°C), hematocrit (33 ± 2%), and inlet pressure conditions are documented in FDA protocol FDP-2013-001 and replicated in the CFD boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within combined experimental and simulation uncertainty bounds at Gradation 2.",
      "rationale": "CFD-predicted NIH values across all 5 operating conditions agree with FDA benchmark experimental data within 8.3% maximum deviation. Combined uncertainty (experimental ±12%, simulation ±4.2%) encompasses all predictions. Exceeds Gradation 2 threshold; achieves Gradation 3 due to systematic bias characterization across the full flow-speed matrix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) must be directly linked to the clinical decision criterion and shown to be sensitive to the design variations under investigation at Gradation 2.",
      "rationale": "The relative hemolysis index RH = NIH_device / NIH_predicate is the primary QoI and maps directly to the acceptance criterion RH < 1. Sensitivity analysis confirms RH varies by 0.18 units across the tolerance band of impeller clearance (0.3–0.6 mm), confirming adequate discriminatory power for the intended decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same flow regime, geometry class, and hemolysis mechanism relevant to CPB operating conditions at Gradation 2.",
      "rationale": "Validation performed on the FDA generic centrifugal pump — the same device class and flow regime (turbulent, Re 4000–12000) as the CPB application. Shear-induced hemolysis via the Giersiepen power-law model is validated directly. Gap between validation and COU geometry is bounded by a morphological similarity assessment confirming shared flow topology."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal iterative convergence error quantification beyond residual monitoring is not required.",
      "rationale": "Residual convergence to 1e-5 for all equations is confirmed for each operating point. Formal iterative error quantification per Richardson extrapolation in the iterative dimension is not required at MRL 2 and has not been performed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error assessment is not required provided analyst qualifications are documented.",
      "rationale": "Lead analyst holds PhD in computational fluid dynamics with 8 years of cardiovascular CFD experience. Simulation execution followed documented SOPs. Formal use error assessment is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal model form uncertainty quantification is not required; selection rationale must be documented.",
      "rationale": "SST k-omega turbulence model selected based on published cardiovascular pump benchmark studies showing superior near-wall accuracy. Giersiepen hemolysis power-law model is the regulatory standard for comparative hemolysis assessment. Formal model form uncertainty quantification is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal input uncertainty propagation is not required; nominal input values must be documented and justified.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hematocrit (33%) sourced from FDA benchmark protocol. Inlet flow rates and rotational speeds set to nominal test values. Formal uncertainty propagation of input parameters is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, characterization of test sample variability is not required for comparative hemolysis assessment.",
      "rationale": "FDA benchmark experiments used ovine blood with documented lot-to-lot variability. Sample-to-sample variability in hemolysis measurements is captured within the reported experimental uncertainty of ±12%. Formal test sample characterization beyond this is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency demonstration between validation and COU input parameter spaces is not required.",
      "rationale": "Operating conditions for validation (2.5–7.0 L/min, 2500–3500 RPM) bracket the CPB COU operating envelope (4–6 L/min, 3000–3500 RPM). Formal equivalency mapping is not required at MRL 2; the bracketing relationship is documented as sufficient."
    }
  ],
