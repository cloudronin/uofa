  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be a commercially validated code with documented version control and regression testing at MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used with documented version control, release notes, and regression test suite. Software quality procedures meet the minimum threshold for MRL 2 Class II device assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at MRL 2.",
      "rationale": "Benchmark verification cases including lid-driven cavity and backward-facing step were executed and compared against published analytical solutions. Residual convergence below 1e-5 confirmed for all cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed using at least three systematically refined meshes, with GCI < 5% for hemolysis index QoI at MRL 2.",
      "rationale": "Three mesh levels (2.1M, 4.8M, 10.2M cells) were generated with refinement ratio 1.44. GCI for normalized hemolysis index was 3.2%, satisfying the < 5% threshold. Richardson extrapolation confirmed asymptotic convergence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match the simulated operating envelope within ±5% for flow rate and rotational speed at MRL 2.",
      "rationale": "FDA pump experimental data from Hariharan et al. were collected at five operating points (2.5 L/min at 2500 RPM through 7.0 L/min at 3500 RPM). Simulated boundary conditions matched experimental conditions within ±2.1% for flow rate and ±1.8% for rotational speed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 20% normalized error across all five operating points at MRL 2.",
      "rationale": "Normalized hemolysis index predictions agreed with experimental PIV-derived stress estimates within 12.4% mean absolute error across all five operating points. Worst-case operating condition (5.0 L/min, 3500 RPM) correctly identified in simulation, matching experimental ranking. Achieved level exceeds requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The modeled QoI (hemolysis index) must be directly linked to the clinical endpoint and acceptance criterion (RH < 1) at MRL 2.",
      "rationale": "The relative hemolysis index RH is the primary regulatory acceptance criterion for CPB device submissions. CFD-derived scalar stress exposure integral is the established computational surrogate per ASTM F1841. Direct traceability from simulation output to regulatory QoI is documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analogue fluid properties as the COU device at MRL 2.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry using a glycerol-water blood analogue (viscosity 3.5 cP, density 1056 kg/m³) matching COU fluid properties. Geometric similarity between validation and COU pump confirmed through dimensional comparison."
    },
    {
