      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (normalized hemolysis index, wall shear stress distribution) must be directly relevant to the COU decision criterion RH < 1.",
      "rationale": "The normalized hemolysis index is the primary QoI for the RH < 1 acceptance criterion. Wall shear stress and scalar stress exposure time are intermediate QoIs that directly feed the hemolysis power-law model, establishing clear relevance to the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
