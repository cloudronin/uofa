      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be under version control with documented release notes; basic regression tests must pass.",
      "rationale": "ANSYS Fluent 2022R2 used under institutional license with documented version control. Solver regression suite executed prior to simulation campaign; all tests passed. Exceeds MRL 2 requirement of Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via at least one benchmark problem with known analytical solution.",
      "rationale": "Taylor-Couette flow verification benchmark performed; L2-norm error in velocity field confirmed second-order spatial convergence consistent with solver documentation. Requirement satisfied and exceeded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis-relevant shear stress must be below 5% on the fine grid.",
      "rationale": "Three-level mesh refinement study performed (4.2M, 9.8M, 21.4M cells). GCI on fine mesh for volume-averaged scalar shear stress is 1.8%, well within the 5% threshold. Richardson extrapolation applied; asymptotic range confirmed (GCI ratio 1.02)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
