      "acceptanceCriteria": "CFD solver must have documented verification test suite and version-controlled source with audit trail.",
      "rationale": "ANSYS Fluent v19.2 used with documented QA procedures, regression test suite, and ISO 9001-compliant development process. Version control and release notes confirmed. Required level 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions.",
      "rationale": "ANSYS Fluent has been verified against standard CFD benchmark cases including lid-driven cavity and Poiseuille flow. Published verification reports accompany the solver release. Required level 2 met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and discretization error must be less than 5% for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed (coarse 2.1M, medium 4.8M, fine 9.6M elements). GCI for relative hemolysis index was 3.2%, below the 5% threshold. Medium mesh selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must bracket or match the COU operating envelope (flow rate 2–8 L/min, speed 2000–3500 RPM).",
      "rationale": "FDA pump experimental data covers flow rates of 2.5, 4.0, 5.5, 7.0 L/min at 2500 and 3500 RPM, encompassing the 5 COU operating points. Fluid temperature and hematocrit matched within 2% of COU specification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined uncertainty bounds; normalized index of hemolysis (NIH) error < 20%.",
      "rationale": "CFD-predicted NIH values compared against Morrison et al. experimental data across all 5 operating points. Mean absolute error was 11.4%, within the 20% acceptance criterion. RH < 1 confirmed for all COU scenarios."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (relative hemolysis index RH) must be directly linked to the clinical decision criterion and computable from CFD outputs.",
      "rationale": "Relative hemolysis index RH is defined as the ratio of device NIH to predicate NIH, directly supporting the regulatory comparison. RH is computed from CFD shear stress history using the Giersiepen-Wurzinger power-law damage model, which is the accepted standard for this device class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating regime as the COU.",
      "rationale": "Validation performed on the FDA generic centrifugal blood pump geometry identical to the COU device. Glycerol-water blood analog (viscosity 3.5 cP, density 1056 kg/m³) used in experiments. Operating conditions span the COU envelope. Validation relevance confirmed at required level 2."
    },
