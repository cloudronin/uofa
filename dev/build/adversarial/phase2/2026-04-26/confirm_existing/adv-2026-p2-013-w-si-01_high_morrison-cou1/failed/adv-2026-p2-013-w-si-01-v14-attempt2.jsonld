  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented with version control and basic QA records consistent with MRL 2 requirements.",
      "rationale": "The ANSYS Fluent solver version 19.2 was used with documented version control. QA records confirm solver release testing and patch history are maintained, satisfying Gradation 1 requirements for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through published benchmark results or developer verification documentation.",
      "rationale": "ANSYS Fluent is a commercially validated solver with published verification benchmarks for incompressible Navier-Stokes equations. Developer verification documentation confirms correct implementation of the k-omega SST turbulence model used in this study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that discretization error in predicted hemolysis index is less than 5% between successive refinement levels.",
      "rationale": "A three-level mesh refinement study was performed with element counts of 2.1M, 4.8M, and 9.6M cells. The hemolysis index changed by 3.2% between medium and fine meshes, and by 1.1% between fine and extra-fine. Richardson extrapolation confirmed discretization error below 2% on the production mesh, meeting Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to confirm correspondence with CFD boundary conditions, including flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA bench test data for the generic centrifugal pump were collected at five operating points spanning 2.5–5.0 L/min and 2000–3500 RPM. Fluid temperature, hematocrit, and inlet pressure were recorded. CFD boundary conditions were set to match measured values within instrument uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within 15% across all five validation operating points.",
      "rationale": "CFD-predicted normalized index of hemolysis (NIH) values were compared against experimental plasma free hemoglobin measurements at all five operating points. Maximum deviation was 9.7% and mean absolute error was 6.3%, exceeding the Gradation 2 acceptance threshold and achieving Gradation 3 agreement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The CFD output quantity (hemolysis index) must be directly linked to the clinical endpoint of interest and the regulatory acceptance criterion.",
      "rationale": "The relative hemolysis index RH is computed directly from CFD-predicted shear stress and exposure time using the Giersiepen-Wurzinger power-law model. RH < 1 corresponds to hemolysis levels below the predicate device, which is the FDA-accepted regulatory threshold for Class II CPB devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and operating envelope as the COU, or differences must be justified with supporting sensitivity analysis.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry, which is the same geometry used in the COU. Operating conditions span the full clinical flow-speed envelope. No geometric or operational extrapolation is required, confirming direct relevance of validation activities to the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of the CFD solution must be demonstrated to residual levels consistent with MRL 2 requirements.",
      "rationale": "At MRL 2 with medium model influence, Gradation 1 for numerical solver error is not required to be formally assessed beyond confirming that residuals reached standard convergence criteria. All simulations were run to residuals below 1e-5 for continuity and momentum, which is documented in the solver log files."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that the model was applied by qualified personnel following documented procedures is sufficient at MRL 2.",
      "rationale": "At MRL 2, a formal use error assessment is not required. Simulation activities were conducted by engineers with documented CFD training records. Standard operating procedures for mesh generation, solver setup, and post-processing were followed and are on file."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of governing equations and constitutive models must be documented and justified for the flow regime and hemolysis mechanism of interest.",
      "rationale": "At MRL 2, a quantitative model form uncertainty assessment is not required. The incompressible Reynolds-averaged Navier-Stokes equations with k-omega SST turbulence closure and Giersiepen-Wurzinger hemolysis model are documented as appropriate for turbulent blood pump flows in the peer-reviewed literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model input parameters (fluid viscosity, density, hemolysis model constants) must be documented with sources at MRL 2.",
      "rationale": "At MRL 2, a sensitivity analysis of model inputs is not required. Blood viscosity (0.0035 Pa·s) and density (1060 kg/m³) were taken from established literature values. Hemolysis model constants from Giersiepen et al. (1990) are documented in the simulation report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The source and preparation of blood analog fluid used in validation experiments must be documented.",
      "rationale": "At MRL 2, detailed characterization of test sample variability is not required. The FDA validation dataset used bovine blood prepared according to ASTM F1841 protocols. Hematocrit was controlled at 30 ± 2%, which is documented in the experimental report."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between CFD input parameters and experimental conditions must be documented at a level commensurate with MRL 2.",
      "rationale": "At MRL 2, formal equivalency mapping is not required beyond confirming that CFD boundary conditions were set to match the experimental operating points. This correspondence is documented in the simulation setup report with a boundary condition table cross-referenced to experimental measurements."
    }
