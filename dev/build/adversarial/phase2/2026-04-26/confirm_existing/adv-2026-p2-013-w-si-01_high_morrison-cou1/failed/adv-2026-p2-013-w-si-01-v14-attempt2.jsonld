  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-regulatory-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are acceptable at MRL 2 given medium model influence and the availability of supporting documentation. CFD predictions of hemolysis index agree with experimental data within 9.7% across all validation operating points, and the RH < 1 acceptance criterion is satisfied for all five worst-case operating conditions. The evidence package is sufficient to support regulatory submission for the Class II CPB device.",
