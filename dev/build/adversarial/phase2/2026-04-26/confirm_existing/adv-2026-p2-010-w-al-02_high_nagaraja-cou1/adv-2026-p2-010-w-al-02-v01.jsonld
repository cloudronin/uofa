  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA solver (Ansys Mechanical 2022 R2) holds ISO 9001 certification; FDA in-house code under documented configuration management with version-controlled releases.",
      "rationale": "All three FEA tools in the ensemble operate under documented SQA plans. Ansys Mechanical 2022 R2 carries ISO 9001 certification. The FDA in-house solver is version-controlled under a formal CM plan with change-control records. DePuy Synthes internal code is covered by a design-control SOP consistent with 21 CFR Part 820. Required Gradation 2 is achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems (cantilever beam, Hertzian contact) solved to within 1% of analytical solution; unit test suite passes for all three solvers.",
      "rationale": "Each solver in the ensemble was exercised against NAFEMS benchmark LE1 (plane stress elliptic membrane) and a standard cantilever beam problem. Errors relative to analytical solutions were below 0.5% for all cases. Unit test results are archived in the project repository. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in QoIs between the production mesh and a 2× refined mesh.",
      "rationale": "A systematic mesh refinement study was conducted using three mesh densities (coarse, medium, fine). The production mesh (medium) yielded stiffness, yield force, and force-at-40mm values within 1.4% of the fine mesh. Richardson extrapolation confirmed a grid convergence index below 2% for all QoIs. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge to <1e-6 relative norm; nonlinear equilibrium residual <1e-4 at each load step.",
      "rationale": "Nonlinear quasi-static analyses employed an augmented Lagrangian contact formulation with Newton-Raphson iteration. Force and displacement residuals were monitored at each increment; convergence to relative norms below 1e-6 was confirmed for all 11 simulated constructs. No divergence events were recorded. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of simulation setup by analyst not involved in model construction; checklist-based review documented.",
      "rationale": "A second qualified FEA analyst, independent of the original modeler, performed a checklist-based review of boundary conditions, material assignments, contact definitions, and load application for each of the three ensemble models. Review records are archived. No critical setup errors were identified. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model (bilinear isotropic hardening) validated against coupon-level tensile data for Ti-6Al-4V ELI; contact formulation captures screw-rod interface behavior.",
      "rationale": "A bilinear isotropic hardening model was fit to Ti-6Al-4V ELI coupon tensile data (n=6 lots). The augmented Lagrangian contact formulation was selected based on published literature for implant-level structural analyses. Model form uncertainty was assessed qualitatively by comparing ensemble spread across the three independent implementations; inter-model QoI range was below 4%. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon testing; geometric inputs from CMM measurements of test articles; friction coefficients from published tribology literature with stated uncertainty.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus were derived from lot-specific tensile coupon data (n=6 lots, mean ± SD reported). Screw and rod geometry was measured by CMM on each of the 11 test constructs. Friction coefficients at the screw-rod interface were assigned from published tribology data for Ti-Ti contact (mean 0.16, range 0.12–0.21). Input uncertainty distributions were propagated via Monte Carlo (5000 samples) to generate QoI prediction intervals. A screening sensitivity study described in the UQ technical report identified elastic modulus and rod outer diameter as the dominant contributors to stiffness variance; however, the structured sensitivity analysis artifact has not been formally linked to this credibility package. Gradation 3 achieved.",
      "uqNarrative": "Monte Carlo UQ (5000 samples) propagated material property and geometric tolerances through the FEA ensemble. The UQ report (internal ref. NCS-UQ-2024-03) includes a one-at-a-time screening study identifying elastic modulus (Ti-6Al-4V rod) and rod cross-sectional diameter as the two inputs accounting for approximately 78% of predicted stiffness variance. Yield force variance was dominated by yield strength variability (~61% contribution). These findings are documented narratively in the UQ report but have not been encoded as a linked sensitivity analysis object in this credibility package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test constructs from production-representative lots; constructs characterized by CMM before testing.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled from production-representative lots and tested across two independent laboratories. Each construct was characterized by CMM prior to testing. Lot traceability records are on file. Sample size exceeds the pre-specified minimum of N=10. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; at minimum two distinct load configurations evaluated.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending configuration only. No torsion or lateral bending conditions were included in this validation activity. This limits the ability to confirm model fidelity across the full COU loading envelope. Achieved Gradation 2 against a required Gradation 3; this factor is below the required level and is noted as a residual gap in the overall assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA inputs match experimentally measured construct geometry and material properties within stated tolerances; boundary conditions replicate test fixture constraints.",
      "rationale": "CMM-measured geometry and lot-specific material data were used directly as FEA inputs. Boundary conditions (fixed inferior vertebral body block, load applied at superior block centroid) replicate the ASTM F1717 test fixture. Fixture compliance was measured and incorporated as a spring element in the model. Equivalency confirmed for all 11 constructs. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all primary QoIs; percent difference < 10%.",
      "rationale": "Three primary QoIs were evaluated: construct stiffness, yield force, and force at 40 mm displacement. E/uval values were 1.41, 1.63, and 0.98 respectively, all below the 1.96 threshold. Percent differences were 6.2%, 8.7%, and 5.1%, all below the 10% acceptance bound. Quantitative comparison meets all pre-specified acceptance criteria. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to the clinical failure modes of interest (fatigue initiation, gross deformation) and to regulatory submission requirements.",
      "rationale": "Construct stiffness is a direct surrogate for load-sharing behavior in vivo. Yield force predicts onset of permanent deformation under worst-case intraoperative loading. Force at 40 mm displacement characterizes post-yield energy absorption relevant to fatigue initiation. All three QoIs are explicitly required by FDA guidance for pedicle screw submissions. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, material, loading, and boundary conditions are representative of the COU device and clinical use scenario.",
      "rationale": "The validation constructs use the same 7.5 mm non-cannulated pedicle screw design, titanium alloy rod, and cross-connector configuration as the COU device. ASTM F1717 is the standard test method specified in the applicable FDA guidance. The two-laboratory design provides inter-laboratory reproducibility data directly relevant to the submission context. Validation activities are judged highly relevant to the COU. Gradation 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single below-requirement factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is acknowledged; the limitation to a single ASTM F1717 loading configuration is accepted given that compression-bending is the dominant and most conservative loading mode for this device class. Uncertainty quantification via Monte Carlo propagation was completed and prediction intervals encompass experimental observations for all three QoIs. The overall evidence package is judged sufficient to support the regulatory submission claim that the FEA framework reliably predicts compression-bending performance of the non-cannulated construct within pre-established acceptance bounds.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
