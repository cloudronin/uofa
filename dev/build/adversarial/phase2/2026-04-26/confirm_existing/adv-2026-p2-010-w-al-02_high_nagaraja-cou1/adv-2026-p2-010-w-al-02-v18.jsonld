  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical 2022 R2 holds current ISO 9001 certification and FDA-recognized V&V documentation; version-controlled simulation environment with audit trail.",
      "rationale": "The FEA solver (Ansys Mechanical 2022 R2) is commercially validated under ISO 9001 QMS. Internal SOPs govern model file versioning, analyst qualification, and review sign-off. Achieved level meets required level for Medium model risk."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 suite reproduced within 1% of analytical solutions for linear elastic beam bending and contact patch problems.",
      "rationale": "Three ASME V&V 10 benchmark cases (cantilever beam, Hertzian contact, threaded fastener pull-out) were executed in the project solver environment. All results agree with analytical references to within 0.8%, confirming correct code implementation for the relevant physics."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 2% on primary QoIs (stiffness, yield force) between medium and fine mesh solutions.",
      "rationale": "Mesh convergence study performed across three refinement levels (coarse ~180k elements, medium ~420k, fine ~960k). GCI values: stiffness 1.1%, yield force 1.6%, force at 40 mm 1.9%. Fine mesh adopted for all production runs. Discretization error is bounded and below acceptance threshold."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criterion ≤ 1×10⁻⁵ for all load steps; energy balance error < 0.5%.",
      "rationale": "Nonlinear quasi-static solver converged to residual norm ≤ 8×10⁻⁶ at every load increment across all 11 simulation instances. Energy balance error remained below 0.3%. No divergence or spurious contact oscillation was observed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second qualified analyst; checklist-based review covering boundary conditions, material assignments, and contact definitions.",
      "rationale": "Model setup was reviewed by an independent senior analyst using a 47-item checklist. Two minor boundary-condition discrepancies (grip fixture constraint extent) were identified and corrected prior to production runs. Final model configuration signed off by both analysts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastic-plastic model with isotropic hardening; contact formulation captures screw-rod interface behavior; published literature supports model form for Ti-6Al-4V implant mechanics.",
      "rationale": "Bilinear isotropic hardening plasticity (Ramberg-Osgood fit to coupon data) combined with augmented Lagrange contact at screw-rod and screw-vertebral body block interfaces. Model form is consistent with three published FEA studies of ASTM F1717 pedicle screw constructs and with FDA guidance on spinal device modeling."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon testing; geometric inputs from CMM measurements of production screws; friction coefficient from published pin-on-disk data for Ti-6Al-4V/Ti-6Al-4V pairs.",
      "rationale": "Elastic modulus (114 ± 3 GPa), yield strength (880 ± 12 MPa), and ultimate strength (950 ± 9 MPa) derived from 15 dog-bone coupons machined from the same titanium alloy billet as test articles. Screw geometry from CMM data (n=5 screws). Friction coefficient 0.28 from literature (Windler & Mathys 2003). Probabilistic UQ was performed using a 500-sample LHS across these distributions; a screening sensitivity study described in the UQ report narrative identified elastic modulus and contact friction as the parameters with the largest influence on predicted stiffness and yield force, though this screening has not been formalized as a linked structured sensitivity analysis."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; specimens characterized by CMM prior to testing; inter-laboratory consistency confirmed.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs (6 at Lab A, 5 at Lab B) assembled from production-representative components. CMM characterization of each screw confirmed dimensional compliance with design tolerances. Inter-laboratory coefficient of variation for stiffness was 4.2%, within acceptable inter-lab variability per ASTM E691."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span clinically relevant range of loading rates and environmental conditions; at minimum two distinct load levels or environmental states evaluated.",
      "rationale": "Testing was conducted under a single quasi-static load protocol at room temperature per ASTM F1717. No variation in loading rate or simulated physiological environment (e.g., saline, body temperature) was evaluated. This single test condition limits the breadth of validation evidence and represents the one factor below required level in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs (geometry, material, boundary conditions) demonstrably derived from or traceable to the physical test configuration; no uncharacterized discrepancies between test and model.",
      "rationale": "Model geometry was reconstructed from CMM measurements of the actual test articles. Material properties were measured from the same production lot. Boundary conditions (grip span, load application point, fixture compliance) were set to match the physical test rig as characterized by calibration records. All discrepancies between nominal design and as-tested configuration were explicitly documented and incorporated."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all primary QoIs; percentage difference < 10% for each specimen-level prediction.",
      "rationale": "E/uval computed per ASME V&V 20 framework incorporating experimental measurement uncertainty (load cell calibration, displacement transducer) and simulation numerical uncertainty (GCI-based). Results: stiffness E/uval = 1.41, yield force E/uval = 1.67, force at 40 mm E/uval = 1.88. All three QoIs pass the acceptance criterion. Specimen-level percentage differences ranged from 0.8% to 9.4%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical failure modes and regulatory submission requirements for spinal fixation devices.",
      "rationale": "Construct stiffness governs load sharing with the spine and adjacent segment effects. Yield force and force at 40 mm displacement are the primary ASTM F1717 pass/fail metrics cited in FDA guidance for 510(k) submissions for pedicle screw systems. All three QoIs are mechanistically connected to the revision surgery risk scenario that defines the decision consequence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (ASTM F1717 compression-bending, non-cannulated 7.5 mm screw) is the same geometry, loading mode, and regulatory standard as the COU; no extrapolation beyond validated domain required.",
      "rationale": "The validation activity directly replicates the COU: identical screw design (non-cannulated 7.5 mm), identical test standard (ASTM F1717 static compression-bending), identical QoIs, and production-representative hardware. The model is not being applied outside the validated domain for this submission. Relevance is therefore maximal and no domain extrapolation penalty applies."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a Medium model risk, Medium decision consequence COU. The single below-required factor (Test conditions, achieved 2 of required 3) is accepted on the basis that ASTM F1717 is a standardized regulatory test protocol and the single quasi-static condition is the regulatory-relevant scenario. Probabilistic UQ results (E/uval < 1.96 for all QoIs) provide quantitative confidence that model prediction error is within validation uncertainty bounds. The overall credibility evidence is sufficient to support the regulatory submission decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
