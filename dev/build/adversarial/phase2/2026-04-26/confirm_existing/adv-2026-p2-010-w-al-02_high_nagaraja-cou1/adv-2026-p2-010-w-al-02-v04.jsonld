  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-f1717-cb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-001",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors assessed. Twelve factors meet or exceed required levels. One factor (Test conditions) achieves level 2 against a required level 3 due to the single-condition ASTM F1717 protocol; this gap is accepted because the quasi-static condition is conservative and the standardised protocol is the regulatory norm. Uncertainty quantification was performed with Monte Carlo propagation across material and geometric input distributions; all QoI validation metrics satisfy E/uval < 1.96 and <10% percentage difference. Overall credibility is sufficient to support the Medium assurance level for a Model Risk Level 3 application. Package accepted for regulatory submission.",
