  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The FEA modeling framework for non-cannulated 7.5 mm pedicle screw compression-bending prediction meets Medium assurance level requirements. All 13 V&V 40 credibility factors assessed; 12 of 13 achieve required levels. The single deficiency (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted on the basis that ASTM F1717 specifies the single standard test configuration for regulatory submissions and the deficiency is bounded by the conservative nature of the standard test. Uncertainty quantification via Monte Carlo propagation was completed and 95th-percentile prediction intervals encompass experimental scatter. A screening sensitivity study is referenced in the UQ report appendix. All three QoIs satisfy E/uval < 1.96 and percent difference < 10% acceptance criteria. Overall credibility is sufficient to support the intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
