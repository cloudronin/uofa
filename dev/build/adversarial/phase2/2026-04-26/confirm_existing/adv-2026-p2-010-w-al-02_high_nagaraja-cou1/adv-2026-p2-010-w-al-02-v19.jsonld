    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic constitutive model with isotropic hardening; contact mechanics modeled with augmented Lagrangian formulation. Model form justified by prior literature and material characterization data.",
      "rationale": "Bilinear isotropic hardening model for Ti-6Al-4V ELI validated against tensile coupon data from implant-grade material lots. Augmented Lagrangian contact at screw-rod interface captures load transfer mechanism. Model form consistent with published FDA benchmark studies. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from lot-specific coupon testing or ASTM F136 certified values; geometric inputs from CMM measurements of test articles.",
      "rationale": "Elastic modulus (114 GPa ± 3.2%), yield strength (880 MPa ± 2.1%), and tangent modulus sourced from three material lots. Screw geometry from CMM measurements of five production articles. Friction coefficient (0.15) from published Ti-Ti tribology data. Monte Carlo UQ ensemble (n=500 runs) propagated material and geometric uncertainties through the model; a screening sensitivity study described in the UQ report narrative identified titanium alloy elastic modulus and screw-rod interface friction coefficient as dominant input drivers of construct stiffness and yield force predictions. Gradation 3 achieved.",
      "uqNarrative": "Monte Carlo ensemble of 500 model runs sampled material properties and geometric tolerances from characterized distributions. The UQ report includes a screening sensitivity study confirming elastic modulus and friction coefficient account for approximately 78% of output variance. Dominant input drivers are identified narratively within the UQ documentation; structured sensitivity analysis linkage encoded in UQ report appendix."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N ≥ 10 test articles from production lots; geometric and material characterization of test articles documented.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All articles from production lots with full material certifications. CMM measurements confirm geometric conformance. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span at least two clinically relevant load configurations or fixation configurations to assess model generalizability.",
      "rationale": "Testing performed under a single ASTM F1717 compression-bending configuration. While this is the regulatory standard configuration, only one load condition was evaluated. Model generalizability across other clinically relevant configurations (e.g., torsion, tensile pullout) not demonstrated within this COU. Gradation 2 achieved; below required Gradation 3. This shortfall is acknowledged and documented as a known limitation of the current validation scope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters demonstrably equivalent to test article properties; traceability documented from material certs and CMM data to model inputs.",
      "rationale": "Direct traceability established between material certification values, CMM measurements, and FEA model input assignments. Equivalency matrix documented for all 14 model input parameters. No assumed or estimated inputs without experimental basis. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 and percentage difference < 10% for all three QoIs (stiffness, yield force, force at 40 mm).",
      "rationale": "All three QoIs satisfy both acceptance criteria. Stiffness: 4.2% difference, E/uval = 0.87. Yield force: 6.8% difference, E/uval = 1.43. Force at 40 mm: 5.1% difference, E/uval = 1.12. Validation uncertainty budget accounts for experimental measurement uncertainty, model parameter uncertainty, and numerical error contributions. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly correspond to regulatory submission endpoints and clinical failure mode indicators.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three primary endpoints specified in ASTM F1717 and referenced in FDA guidance for pedicle screw 510(k) submissions. These QoIs directly characterize the construct's resistance to the clinically relevant failure mode of fatigue-initiating plastic deformation. Gradation 3 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
