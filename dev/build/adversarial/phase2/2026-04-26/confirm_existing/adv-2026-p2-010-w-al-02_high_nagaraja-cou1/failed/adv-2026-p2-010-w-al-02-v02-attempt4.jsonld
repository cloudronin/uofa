      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA solver (Ansys Mechanical 2022 R2) with documented V&V suite; FDA solver independently verified against published benchmarks.",
      "rationale": "Ansys Mechanical employed under institutional software quality plan with version control and regression testing. FDA in-house solver verified against NAFEMS benchmarks. Both satisfy Gradation 2 requirements for software quality assurance."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verified against at least one analytical or manufactured solution relevant to structural mechanics.",
      "rationale": "Both solvers verified against Timoshenko beam and Hertzian contact analytical solutions. Patch test passed for all element types used in the pedicle screw mesh. Gradation 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
