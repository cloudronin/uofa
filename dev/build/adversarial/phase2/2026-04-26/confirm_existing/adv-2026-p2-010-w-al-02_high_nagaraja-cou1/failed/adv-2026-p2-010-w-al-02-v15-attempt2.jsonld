  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/noncannulated-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single below-requirement factor (Test conditions, achieved 2 vs. required 3) is accepted on the basis that ASTM F1717 is the regulatory standard test configuration and the primary failure mode under clinical loading is compression-bending. UQ has been performed using Monte Carlo propagation (n=500); a screening sensitivity study described in the UQ narrative identified material yield strength and screw root diameter as the most influential inputs. Overall credibility is sufficient to support Medium assurance level for this Class II device submission.",
