  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieves level 2 against a required level 3 due to single-condition testing; this gap is accepted given that the COU is explicitly scoped to static compression-bending only and clinical risk is classified as medium consequence. All three primary QoIs satisfy the pre-established quantitative acceptance criteria (E/uval < 1.96; percentage difference < 10%). Uncertainty quantification was performed and is documented at the package level. The FEA modeling framework is accepted as sufficiently credible for the stated COU.",
