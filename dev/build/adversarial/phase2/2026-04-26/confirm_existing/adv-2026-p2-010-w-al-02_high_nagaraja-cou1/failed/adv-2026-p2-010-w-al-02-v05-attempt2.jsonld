  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieved level 1 against required level 2 due to single test condition; this gap is accepted because ASTM F1717 defines the sole regulatory test configuration and the COU scope is explicitly bounded to this scenario. All three QoIs passed pre-specified acceptance criteria (percent difference <10%, E/uval <1.96) across N=11 specimens at two independent laboratories. Uncertainty quantification completed with Monte Carlo propagation (N=1000); combined validation uncertainty uval accounts for input parameter variability, numerical error, and experimental measurement uncertainty. Overall credibility sufficient to support regulatory submission for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
