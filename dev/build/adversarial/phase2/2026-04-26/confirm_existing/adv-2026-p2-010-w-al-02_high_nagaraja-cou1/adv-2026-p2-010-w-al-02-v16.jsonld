  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-noncannulated-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is offset by the high degree of equivalency between the validation scenario and the COU, the multi-laboratory experimental dataset, and the satisfactory quantitative output comparison results across all three primary QoIs. Uncertainty quantification was performed across material property and geometric tolerance distributions, with a screening sensitivity study informing the sampling strategy. Overall credibility is judged sufficient to support a Medium assurance level conclusion and the decision to accept the modeling evidence for the non-cannulated pedicle screw 510(k) submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
