    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmark problems for linear elastic beam bending and contact mechanics reproduce analytical solutions within 1%.",
      "rationale": "Standard NAFEMS benchmark cases LE1 and LE10 executed on each solver; maximum deviation from analytical solution 0.6%. Contact patch test passed for all three codes. Numerical code verification deemed sufficient for Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between successive refinement levels; Richardson extrapolation GCI < 5%.",
      "rationale": "Three-level mesh refinement study performed on the screw-rod assembly. Stiffness QoI changed 1.4% between medium and fine meshes; GCI = 3.1%. Final production mesh uses the fine-level discretization (approximately 420 000 elements, hex-dominant with tetrahedral fill in complex fillet regions). Discretization error contribution to total uval estimated at 1.8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals converge to < 1e-6 relative norm; energy balance error < 0.1%.",
      "rationale": "Direct sparse solver (PARDISO) used for linear steps; Newton-Raphson with line search for nonlinear contact iterations. Residual norm at convergence consistently below 1e-8. Energy balance error 0.03%. Exceeds Gradation 1 requirement; assigned Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent technical review of simulation setup by analyst not involved in model construction; checklist-based review covering boundary conditions, material assignments, and load application.",
      "rationale": "Each of the three ensemble models was independently reviewed by a second analyst using a 47-item checklist derived from ASME V&V 40 Appendix C. No critical discrepancies identified. Minor annotation errors in two material cards corrected prior to production runs. Use error contribution judged negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model captures elastic-plastic behavior of Ti-6Al-4V alloy; contact formulation reproduces screw-rod interface mechanics; large-displacement kinematics enabled.",
      "rationale": "Bilinear isotropic hardening (BISO) model calibrated to ASTM E8 coupon data for Ti-6Al-4V (E = 114 GPa, sigma_y = 880 MPa, E_t = 1.1 GPa). Augmented Lagrangian contact with friction coefficient mu = 0.15 (measured). Geometric nonlinearity (NLGEOM) active throughout. Model form assessed adequate for the static compression-bending COU at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of production-lot material; geometric dimensions from CMM measurements of test specimens; boundary conditions replicate F1717 fixture kinematics.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus derived from N=6 Ti-6Al-4V tensile coupons from the same production lot as test constructs (CV < 2%). CMM measurements of screw OD, thread pitch, and rod diameter used to populate nominal geometry with lot-specific offsets. F1717 fixture geometry modeled from engineering drawings with pin-joint boundary conditions. A Monte Carlo UQ study propagated material property and dimensional tolerances through the ensemble; a screening sensitivity study was conducted to identify the highest-variance input contributors and inform the UQ sampling bounds, with findings summarized in the UQ report appendix. Input uncertainty contribution to uval = 4.3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N >= 10 test constructs from production-representative manufacturing; traceability of specimen dimensions and material certificates maintained.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (FDA CDRH Biomechanics Lab and DePuy Synthes test facility). All specimens from a single production lot with full material traceability. CMM measurements confirm dimensional conformance to drawing. Sample size sufficient for statistical comparison at 95% confidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading rates and environmental conditions, or equivalence to in vivo conditions is demonstrated.",
      "rationale": "Testing performed under quasi-static loading at a single crosshead displacement rate (5 mm/min) per ASTM F1717. No variation in loading rate or temperature explored. Achieved level limited to Gradation 2 because only a single test condition was evaluated; rate-dependence and thermal effects were not characterized. This is the one factor below the required level; risk accepted given that F1717 is a standardized comparative test and rate sensitivity of Ti-6Al-4V in this regime is well-documented in the literature."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters are demonstrably equivalent to experimental specimen parameters; any discrepancies quantified and incorporated into validation uncertainty.",
      "rationale": "CMM measurements of each of the 11 test constructs were used to update specimen-specific simulation inputs for screw OD, rod OD, and set-screw torque-equivalent preload. Residual discrepancies between as-measured and as-modeled dimensions quantified; maximum dimensional offset 0.04 mm incorporated into uval. Equivalency of input parameters confirmed at Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all primary QoIs; systematic bias assessed and reported.",
      "rationale": "Comparison error E and validation uncertainty uval computed per ASME V&V 20 for three QoIs: construct stiffness (E/uval = 1.43), yield force (E/uval = 1.61), force at 40 mm displacement (E/uval = 1.78). All values below the 1.96 threshold. No systematic bias detected across the 11-specimen ensemble (mean signed error < 1% for all QoIs). Output comparison satisfies Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs directly map to the device performance characteristics relevant to the regulatory submission and clinical use scenario.",
      "rationale": "Stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in ASTM F1717 and cited in the 510(k) predicate comparison. These quantities directly characterize construct mechanical integrity under the worst-case bending load scenario. QoI relevance rated Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
