    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear elastic constitutive model with frictional contact is appropriate for titanium alloy implant under quasi-static compression-bending; model form assumptions documented and justified.",
      "rationale": "The non-cannulated pedicle screw and rod are modeled as linear elastic Ti-6Al-4V continua, consistent with the sub-yield loading regime targeted by the ASTM F1717 protocol. Frictional contact between screw head and rod clamp is implemented with experimentally calibrated friction coefficients. Model form is well-established for this class of implant-loading scenario."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, nu, yield strength) and geometric dimensions sourced from certified material certificates and CMM measurements; input distributions characterized from N≥10 production samples.",
      "rationale": "Elastic modulus, Poisson's ratio, and yield strength distributions were characterized from certified material test reports for the production Ti-6Al-4V bar stock. Geometric tolerances for screw outer diameter, pitch, and rod diameter were characterized from CMM data on N=15 production samples. Input uncertainty distributions (normal, truncated) were propagated through the UQ analysis. A screening sensitivity study conducted during model development identified elastic modulus and rod diameter as the highest-variance contributors to stiffness QoI; these findings are discussed in the UQ technical report narrative accompanying this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs tested across two independent laboratories; samples drawn from production lots with dimensional verification.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were assembled and tested per ASTM F1717 across two independent test laboratories. Sample dimensions were verified by CMM prior to testing. Inter-laboratory variability was characterized and incorporated into the validation uncertainty budget. Sample population is representative of the production design space."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "At least two distinct test conditions (e.g., load rates, temperatures, or construct configurations) evaluated to bound model applicability across the COU space.",
      "rationale": "Testing was conducted under a single standardized ASTM F1717 quasi-static compression-bending condition. Only one load rate and one environmental condition (ambient, dry) were employed. This limits the ability to characterize model behavior across the full COU space. This factor is below the required level and represents a known gap acknowledged in the credibility assessment; compensating evidence from the multi-laboratory design partially mitigates but does not resolve the deficiency."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions) are demonstrably equivalent to the physical test configuration within quantified tolerances.",
      "rationale": "FEA model geometry was constructed from the same CAD nominal dimensions used for production, with as-measured CMM deviations applied as perturbations in the UQ analysis. Boundary conditions replicate the ASTM F1717 fixture constraints. Material property inputs are traceable to the same material certificates used to characterize test samples. Equivalency is confirmed at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval <1.96 and percent difference <10% for all primary QoIs across all ensemble members.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement were compared between FEA ensemble predictions and experimental means. E/uval ranged from 0.31 to 1.44 across QoIs and ensemble members; percent differences ranged from 1.2% to 8.7%. All metrics satisfy the pre-established acceptance criteria. Output comparison is fully quantitative and passes at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to the clinical and regulatory decision criteria for pedicle screw construct performance.",
      "rationale": "Construct stiffness and yield force are the primary mechanical performance indicators for pedicle screw regulatory submissions. Force at 40 mm displacement is the ASTM F1717 standard endpoint. These QoIs are directly relevant to the COU decision regarding whether the FEA framework can substitute for or supplement physical testing in design iterations."
    },
