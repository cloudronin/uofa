  "signature": "ed25519:b7d4e2f1a09c3e6b8d5f2a4c7e1b3d6f9a2c5e8b1d4f7a0c3e6b9d2f5a8c1e4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the stated model risk.",
      "rationale": "Ansys Mechanical R2022 and the FDA in-house FEA environment are both subject to documented software quality assurance procedures including version control, regression testing, and formal release validation. Achieved level 3 exceeds the required level 2 for this model risk category."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from the NAFEMS library and ASME V&V 10 suite were used to verify the linear static structural solver. Results agreed with analytic solutions within 0.5% for all benchmark cases, satisfying the required level 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "A mesh convergence study was performed on the pedicle screw-rod construct model. Successive refinements of the pedicle screw shank mesh yielded less than 2% change in peak von Mises stress at the screw-rod interface, confirming discretization error within acceptable bounds at the adopted mesh density."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals were monitored across all load steps. Force and displacement residuals converged below 1e-6 relative tolerance for all 11 construct configurations. No divergence events were recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup procedures are documented in a controlled simulation protocol. An independent analyst reviewed boundary condition assignments and material property inputs prior to solution execution. No use errors were identified during the review."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic material models with isotropic titanium alloy properties (Ti-6Al-4V, E=114 GPa) were selected. Contact at the screw-rod interface was modelled as frictional (mu=0.2). The model form is consistent with published literature for metallic spinal implant simulation under static loading and is appropriate for the quantities of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties were sourced from ASTM F136 certificate-of-conformance data for the specific production lot used in the experimental study. Geometric inputs were derived from CMM measurements of the physical constructs. Input uncertainty was characterised via a one-at-a-time sensitivity study."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs assembled per ASTM F1717 from the same production lot were tested. Sample size is consistent with regulatory guidance and provides adequate statistical basis for comparison with model predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing was conducted at a single load level and a single test configuration (compression-bending at 5 degrees). Variation of loading angle or magnitude was not explored. This limits the achieved level to 2, below the required level of 3. This gap is acknowledged and constitutes a known deficiency in the validation evidence base."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "CMM-measured construct geometry and lot-specific material certificates were used to parameterise the simulation models directly from the physical test specimens. Traceability between physical and computational inputs was verified by the simulation team and confirmed by the test laboratory."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Predicted construct stiffness and peak bending moment at failure were compared against experimental measurements using validation metrics including the E-value metric per ASME V&V 10.1. All ensemble predictions fell within the experimental uncertainty band for 10 of 11 constructs. The one outlier was within 8% of the experimental mean."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The quantities of interest — construct stiffness (N/mm) and peak bending moment at failure (N·m) — are directly specified by ASTM F1717 and are the primary metrics used in regulatory submissions for spinal fixation systems. Their relevance to device performance assessment is well established."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The validation activity directly replicates the ASTM F1717 test configuration that constitutes the intended use scenario. The experimental constructs, loading protocol, and measurement outputs are all aligned with the simulation use case. Relevance is therefore assessed as high, achieving the required level."
    }
  ],
