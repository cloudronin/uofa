      "name": "Primary compression-bending validation against ASTM F1717 experimental data (N=11)"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-cbending-crosslab",
      "type": "ValidationResult",
      "name": "Cross-laboratory reproducibility validation — two independent test facilities"
