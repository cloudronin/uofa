  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Model Risk Level 3 assessment. The single below-requirement factor (Test conditions, achieved level 2 vs. required level 3) was reviewed by the team and accepted on the basis that ASTM F1717 defines the regulatory standard loading condition and the model is applied only within that defined protocol. Overall credibility is judged sufficient to support the intended regulatory submission. Note that this assessment is filed under a Minimal profile; a structured Context of Use object was not formally recorded in this package, though the model has been applied in clinical research and pre-market regulatory contexts as described in the package narrative.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
