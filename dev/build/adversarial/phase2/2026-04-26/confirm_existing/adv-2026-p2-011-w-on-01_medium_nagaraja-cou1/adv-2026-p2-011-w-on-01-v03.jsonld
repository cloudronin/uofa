  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the assessed model risk.",
      "rationale": "All three FEA codes (FDA in-house, Ansys 2021R1, DePuy Synthes internal) operate under documented software quality management plans. Version control, regression testing, and change-control records were reviewed and found compliant with applicable SQA requirements for Class II device submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Patch tests and manufactured-solution benchmarks were executed for each FEA code. Results demonstrated convergence to analytical solutions within accepted tolerances. Code verification documentation is archived in each organization's quality management system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence must be demonstrated for all quantities of interest.",
      "rationale": "Systematic mesh refinement studies were performed for the screw-rod interface and cortical bone contact regions. Peak von Mises stress and construct stiffness showed less than 3% change between the penultimate and final refinement levels, confirming adequate discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals and energy balance errors must remain below defined thresholds.",
      "rationale": "Nonlinear solver residuals were monitored across all load steps. Force residual norms converged to below 1e-4 of the reference norm. Energy balance errors remained below 0.5% throughout the compression-bending loading sequence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures must be documented and independently reviewed.",
      "rationale": "Model setup procedures were documented in standardized simulation protocols. Independent peer review of boundary condition application, material assignment, and contact definitions was completed by analysts not involved in original model construction. No critical use errors were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics and assumptions must be appropriate for the quantities of interest.",
      "rationale": "Linear elastic material models were applied to titanium alloy components, consistent with the sub-yield loading regime of the ASTM F1717 protocol. Contact mechanics at the screw-rod interface were represented using penalty-based formulations validated against analytical contact benchmarks."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured or published sources.",
      "rationale": "Titanium alloy (Ti-6Al-4V ELI) elastic modulus and Poisson's ratio were sourced from ASTM F136 and confirmed by coupon testing. Screw and rod geometry was derived from manufacturer CAD files with dimensional verification against physical specimens. Input uncertainty was propagated via a sensitivity study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental specimens must be representative of the simulated construct.",
      "rationale": "N=11 physical constructs were assembled from production-lot components identical to those modeled. Dimensional inspection confirmed geometric conformance. Specimens were distributed across two independent laboratories to assess inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use.",
      "rationale": "Testing was conducted at a single compression-bending load magnitude as specified in ASTM F1717. Although this condition is the regulatory standard, the absence of additional load levels (e.g., varied offset distances or cyclic preconditioning) limits confidence in model response across the broader loading envelope. This factor is below the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs must be matched to experimental conditions.",
      "rationale": "Boundary conditions in the FEA models were set to replicate the ASTM F1717 fixture geometry, applied displacement rate, and constraint configuration. Torque applied to set screws was measured experimentally and applied as pretension in the models. Correspondence between simulation and experimental inputs was verified by a third-party reviewer."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics must demonstrate acceptable agreement between simulation and experiment.",
      "rationale": "Construct stiffness predictions from all three FEA codes fell within the 95% confidence interval of the experimental distribution. Mean absolute percentage error across the ensemble was 4.2%. Bland-Altman analysis confirmed no systematic bias. Agreement was consistent across both test laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be directly relevant to the decision being supported.",
      "rationale": "Construct stiffness and peak interface stress are the primary quantities of interest, directly corresponding to the mechanical performance metrics evaluated in ASTM F1717 and used in regulatory comparative analysis. These quantities are established surrogates for clinical construct integrity in the peer-reviewed literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same physical phenomena and loading regime as the intended use.",
      "rationale": "The ASTM F1717 compression-bending protocol directly replicates the biomechanical loading mode for which the model is employed. The validation construct geometry, material system, and boundary conditions are representative of the device family under assessment. Validation activities are therefore judged highly relevant to the intended use context."
    }
  ],
