  "signature": "ed25519:b2e4a1f3c7d09562fa3b1e7d4c8a06f1e8b40d2c5a0e6f1b3d7c2a4e8f2b601d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "The FEA software (Ansys Mechanical 2022 R1) is used under a validated installation with documented version control, regression test suite, and change-control procedures consistent with FDA guidance on software used in device submissions. Achieved level exceeds the required level for this model risk classification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from the NAFEMS library were executed to verify correct implementation of the linear elastic constitutive model and contact algorithms. Results agreed with analytical solutions within 0.5%, satisfying the required verification level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "A three-level mesh refinement study was conducted on the screw-rod interface region. The Richardson extrapolation estimate of discretization error in peak von Mises stress is 1.8%, and the grid convergence index is below 5%, demonstrating solution independence from the selected mesh density."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "A direct sparse solver (PARDISO) was employed. Residual norms were monitored and converged below 1e-8 for all load steps. No iterative solver divergence events were recorded across the 11-construct ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup was performed by two independent analysts following a documented simulation protocol. An inter-analyst comparison of predicted construct stiffness showed less than 2% variation, indicating negligible user-induced variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic isotropic material models are used for titanium alloy components, consistent with the small-strain regime of ASTM F1717 testing. Contact between screw and rod is modeled with a frictional Coulomb law (mu=0.3). The model form is well-established for quasi-static metallic implant mechanics and has been independently applied by three simulation teams."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (E=114 GPa, nu=0.34 for Ti-6Al-4V) were taken from certified material test reports for the specific lot used in the experimental constructs. Geometric inputs were derived from CMM measurements of representative screws with dimensional tolerances documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Eleven physical constructs were assembled from production-intent hardware across two independent laboratories. Sample traceability to manufacturing lot was maintained. The sample size exceeds the minimum recommended for this model risk level and supports statistical comparison of predicted versus measured stiffness and yield load."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing was conducted under a single compressive loading condition per ASTM F1717 at a crosshead displacement rate of 5 mm/min. Only one test condition was evaluated; multi-axis or variable-rate conditions were not included. This results in an achieved level below the required level for model risk level 3 and constitutes a documented gap in the credibility argument."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Boundary conditions in the FEA replicate the ASTM F1717 fixture geometry, including the fixed inferior block and the superior loading block with a defined moment arm of 60 mm. Applied displacement magnitude and loading axis were matched to experimental conditions. Equivalency was confirmed by comparing reaction force histories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Predicted construct stiffness and 0.2% offset yield load were compared against experimental measurements using the U95 validation metric per ASME V&V 10. The model prediction fell within the experimental uncertainty band for 10 of 11 constructs. The area validation metric was also computed and satisfied the acceptance threshold defined a priori."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The quantities of interest — construct stiffness (N/mm) and yield load (N) — are the primary mechanical performance metrics required by ASTM F1717 and referenced in FDA guidance for spinal fixation devices. These quantities directly support the intended regulatory decision and are therefore highly relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The validation activities directly replicate the ASTM F1717 compression-bending protocol applied to the same non-cannulated 7.5 mm pedicle screw geometry and material as the simulation target. The experimental and simulation domains are closely matched in geometry, material, loading, and boundary conditions, supporting a high relevance rating for the validation activities relative to the intended use context."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed their required levels for model risk level 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) was reviewed by the assessment team and accepted on the basis that the ASTM F1717 protocol is inherently a single-condition standardised test and that the regulatory decision does not require multi-condition extrapolation at this stage. Overall credibility is judged sufficient to support the intended regulatory submission.",
