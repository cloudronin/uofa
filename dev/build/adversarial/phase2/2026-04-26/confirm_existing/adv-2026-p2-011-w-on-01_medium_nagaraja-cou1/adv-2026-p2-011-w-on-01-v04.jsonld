  "signature": "ed25519:9b1d3f5a7c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4f6a8c0e2b4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "The FEA software (Ansys Mechanical 2022 R2) is a commercially validated code with documented QA procedures including regression test suites and version-controlled release notes. FDA and DePuy Synthes ensemble members follow equivalent internal SQA protocols. Achieved level equals required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "Benchmark problems from ASME V&V 10 and the Ansys verification manual were executed for linear elastic solid mechanics. All benchmark results fell within 1% of analytical solutions. Code verification is considered adequate for the static structural regime of this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "A mesh convergence study was performed on the pedicle screw shank and rod junction using three mesh densities (coarse, medium, fine). The Richardson extrapolation-based GCI for peak von Mises stress was 1.8%, below the 5% threshold. The medium mesh was selected for the production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 2).",
      "rationale": "Direct sparse solver (PARDISO) was used with default convergence tolerances. Residual force norms were monitored and remained below 1e-6 for all load steps. No iterative solver was employed; numerical solver error is considered negligible for this linear static analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "Model setup was independently reviewed by two analysts across two organizations (FDA and DePuy Synthes). Boundary conditions, contact definitions, and material assignments were cross-checked against the F1717 test protocol. A documented model review checklist was completed prior to submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "Linear elastic continuum mechanics is the governing physics. The screw and rod are modeled as isotropic titanium alloy (Ti-6Al-4V). Frictional contact is applied at the screw-rod interface with a coefficient of 0.2, consistent with published literature for dry titanium contact. Model form assumptions are well-supported for quasi-static loading below yield."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "Material properties (E = 114 GPa, nu = 0.34) were taken from ASTM F136 certified material test reports for the specific lot used in fabrication. Geometric inputs were derived from CMM measurements of the actual test specimens, with dimensional tolerances documented. Input uncertainty propagation was performed via a 50-sample Monte Carlo sweep."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories, exceeding the minimum sample size recommended for statistical comparison. All specimens were from the same manufacturing lot, ensuring material consistency. CMM measurements confirmed dimensional conformance to design drawings."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3). This factor does not meet the required level.",
      "rationale": "Testing was conducted under a single load condition (compression-bending at 5 degrees offset per ASTM F1717). No variation in load angle, load magnitude, or environmental condition (e.g., simulated body fluid) was explored. This limits the breadth of validation evidence and results in an achieved level of 2, below the required level of 3. This shortfall is acknowledged and documented as a limitation of the current validation campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "FEA model inputs were mapped directly to measured experimental parameters. Screw geometry was taken from CMM data; material properties from certified test reports; boundary conditions replicate the F1717 test fixture kinematics. A traceability matrix linking each model input to its experimental counterpart was prepared and reviewed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "Predicted construct stiffness and peak bending moment at failure locus were compared against experimental measurements using both point-to-point error metrics and a validation metric (u-pooled method per ASME V&V 20). Mean prediction error for stiffness was 4.2% across all 11 specimens and both laboratories. Uncertainty intervals overlap for all comparisons."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "The quantities of interest — construct stiffness (N/mm) and peak bending moment (N·m) — are directly relevant to the biomechanical performance claims made for the pedicle screw system. These metrics are specified in ASTM F1717 and are routinely used in regulatory submissions to characterize spinal implant mechanical performance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level (Gradation 3).",
      "rationale": "The validation activity directly replicates the ASTM F1717 compression-bending test protocol that defines the intended use scenario for this FEA model. The experimental hardware, loading mode, and output metrics are all matched to the model's intended predictive scope. The ensemble approach across three organizations strengthens confidence in the validation conclusions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is acknowledged and documented. The overall body of evidence — multi-laboratory experimental comparison, mesh convergence, Monte Carlo input uncertainty propagation, and independent model review — is judged sufficient to support the intended use of the FEA model for ASTM F1717 compression-bending performance prediction of non-cannulated 7.5 mm pedicle screw constructs at a Medium assurance level. The assessment team accepts the package with the noted test-conditions limitation on record.",
