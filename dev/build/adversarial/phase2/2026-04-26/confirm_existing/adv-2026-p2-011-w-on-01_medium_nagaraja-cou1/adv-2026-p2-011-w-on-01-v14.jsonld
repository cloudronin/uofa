  "signature": "ed25519:7c3a1f9e2b5d8c0e4a7f1b3d6e9c2a5f8b1d4e7c0a3f6b9d2e5c8a1f4b7d0e3a6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software must be validated under a documented SQA plan with version control and regression testing.",
      "rationale": "All three solver implementations (FDA in-house, Ansys 2022R1, DePuy Synthes proprietary) operate under documented SQA plans with version-controlled releases and regression test suites. Achieved level exceeds required level for this model risk classification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks must demonstrate correct implementation of governing equations against analytical solutions.",
      "rationale": "Each solver has been verified against ASME V&V 10 benchmark problems including beam bending and contact mechanics cases. Residual norms and convergence behavior are documented in solver qualification reports."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that QoI changes by less than 5% between successive refinement levels.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw and vertebral body block assembly. The primary QoI (construct stiffness and failure load) varied by less than 3.2% between medium and fine meshes. Richardson extrapolation confirmed discretization error below acceptable threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; contact convergence must be documented.",
      "rationale": "Nonlinear contact iterations converged to force residuals below 1e-7 for all 11 simulated constructs. No divergence events were recorded. Solver log files archived in the simulation record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be reviewed by an independent analyst; boundary condition application must be documented.",
      "rationale": "An independent senior analyst reviewed all boundary condition assignments, material property inputs, and contact pair definitions prior to simulation execution. A checklist-based review process was followed per internal SOP."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive models and contact formulations must be appropriate for the loading regime and material behavior observed experimentally.",
      "rationale": "Linear elastic material models are justified for titanium alloy implants under sub-yield compression-bending loads as confirmed by experimental strain gauge data. Penalty-based contact formulation with friction coefficient 0.2 was selected based on prior titanium-on-polyethylene block interface characterization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured values with documented uncertainty.",
      "rationale": "Titanium alloy elastic modulus (114 GPa) and Poisson ratio (0.34) sourced from ASTM F136 coupon testing. UHMWPE block properties from supplier certificate of conformance. Geometric dimensions derived from CMM measurements of actual test specimens with tolerances documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 experimental samples required; samples must be representative of production geometry and materials.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All specimens were drawn from the same production lot and verified against device master record dimensional specifications prior to testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the clinically relevant range of loading scenarios; multiple load levels or configurations required.",
      "rationale": "Testing was conducted under a single load configuration per ASTM F1717 protocol (10 mm offset, 10 Hz, 5 kN maximum). Only one test condition was evaluated, which does not span the range of in vivo loading scenarios. This factor is below the required level and represents a known gap in the validation evidence base."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must demonstrably correspond to experimentally measured quantities within stated tolerances.",
      "rationale": "All simulation boundary conditions were mapped directly from experimental setup measurements. Load application point, fixture geometry, and constraint locations were measured post-test and confirmed to match simulation inputs within 0.5 mm positional tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted QoIs must agree with experimental measurements within ±15% for construct stiffness and failure load.",
      "rationale": "Across all 11 constructs, FEA-predicted construct stiffness agreed with experimental measurements within ±9.4% (mean absolute percent error 6.1%). Predicted failure load agreed within ±12.8%. Both QoIs satisfy the ±15% acceptance criterion across the full ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly relevant to the clinical performance metrics of interest.",
      "rationale": "Construct stiffness and failure load under compression-bending are the primary biomechanical performance metrics specified in ASTM F1717 and cited in FDA guidance for spinal fixation devices. These QoIs are directly linked to clinical outcomes related to construct stability and fatigue performance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently representative of the intended use environment and patient population.",
      "rationale": "The validation activities closely replicate the ASTM F1717 standardized test environment. However, the intended application of this model in clinical research contexts introduces physiological loading variability and patient-specific geometry not captured by the standardized block model. Relevance to the broader use scope is therefore assessed as partially sufficient."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Eleven of thirteen V&V 40 credibility factors meet or exceed required levels. Two factors (Test conditions and Relevance of validation activities to COU) are below required levels but are accepted given the standardized nature of the ASTM F1717 protocol and the conservative loading assumptions embedded in the test configuration. The overall credibility evidence is judged sufficient to support use of the FEA model ensemble for compression-bending performance prediction of non-cannulated pedicle screw constructs.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
