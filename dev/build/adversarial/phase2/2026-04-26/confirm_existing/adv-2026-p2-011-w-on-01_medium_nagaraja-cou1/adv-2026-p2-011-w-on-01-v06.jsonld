  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a model risk level 3 device. The single gap (Test conditions, achieved level 2 vs. required level 3) is acknowledged; the team determined that the standardised F1717 single-condition protocol is the regulatory benchmark and that the gap does not materially affect the intended use of the model for comparative construct evaluation. The overall credibility evidence is sufficient to support the stated decision question.",
