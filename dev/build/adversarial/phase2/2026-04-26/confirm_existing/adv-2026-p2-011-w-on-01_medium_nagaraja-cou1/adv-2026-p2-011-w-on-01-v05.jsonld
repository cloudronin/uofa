  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA codes (FDA, Ansys, DePuy Synthes) are subject to documented software quality assurance procedures including version control, regression testing, and configuration management. Achieved level 3 exceeds the required level 2 for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems and manufacturer verification suites have been executed for each FEA code in the ensemble. Results confirm correct implementation of governing equations for static structural analysis. Achieved level 3 satisfies the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence must be demonstrated for all three FEA models; achieved level must equal or exceed required level.",
      "rationale": "Mesh convergence studies were performed for each model in the ensemble, with peak von Mises stress and construct stiffness monitored as quantities of interest. Convergence within 5% was demonstrated for all models. Achieved level 3 meets the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals and iteration convergence must be documented and within accepted tolerances.",
      "rationale": "Force and displacement residuals were monitored across all load steps for each FEA model. Convergence tolerances of 1e-4 (force) and 1e-5 (displacement) were satisfied for all simulations. Achieved level 2 meets the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented review and independent check of model setup, boundary conditions, and material assignments.",
      "rationale": "Each FEA model was independently reviewed by a second analyst prior to execution. Boundary conditions, contact definitions, and material assignments were verified against the ASTM F1717 test protocol. Achieved level 2 meets the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions must be documented and justified relative to the physics of ASTM F1717 compression-bending loading.",
      "rationale": "All three FEA models employ linear elastic material models for titanium alloy components, which is appropriate for the small-strain, pre-yield loading regime of the ASTM F1717 test. Contact between screw and block is modeled with frictional interfaces (mu=0.2). Model form assumptions are consistent with published literature and FDA guidance. Achieved level 3 meets the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry, and boundary condition inputs must be traceable to measurements or certified material data.",
      "rationale": "Geometric inputs were derived from certified CAD files and CT-based dimensional verification of physical specimens. Material properties (E=114 GPa, nu=0.34 for Ti-6Al-4V) are sourced from ASTM F136 and corroborated by tensile coupon testing. All inputs are documented in the simulation data package. Achieved level 3 meets the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sample size must be sufficient for statistical comparison; specimens must be traceable to production lots.",
      "rationale": "N=11 experimental constructs were tested across two independent laboratories. Specimens are traceable to production lots with documented dimensional inspection records. The sample size supports meaningful statistical comparison with ensemble FEA predictions. Achieved level 3 meets the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of anticipated use conditions; achieved level must equal or exceed required level.",
      "rationale": "Experimental testing was conducted at a single load level (150 N axial compression combined with bending) per the nominal ASTM F1717 protocol. Variation in load magnitude and load angle was not explored, limiting the ability to characterize model fidelity across the full envelope of anticipated loading conditions. Achieved level 2 falls below the required level 3; this is a documented gap in the current assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs must be demonstrably equivalent to the physical test configuration.",
      "rationale": "Boundary conditions, specimen geometry, and loading configurations in the FEA models were mapped directly from the experimental test setup drawings and instrumentation records. Cross-laboratory consistency of test configuration was verified by independent audit. Achieved level 3 meets the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., ASME V&V 20 validation metrics) must be applied; achieved level must equal or exceed required level.",
      "rationale": "Construct stiffness and peak displacement at 150 N were compared between FEA predictions and experimental measurements using the ASME V&V 20 validation metric. Mean prediction error across the ensemble was 4.2% for stiffness and 5.1% for peak displacement, within the 10% acceptance threshold. Achieved level 3 meets the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be directly relevant to the clinical and regulatory decision supported by the model.",
      "rationale": "Construct stiffness and displacement under ASTM F1717 loading are the primary quantities of interest, directly relevant to the mechanical performance characterization required for 510(k) submissions for posterior spinal fixation devices. Achieved level 3 meets the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently similar to the intended use scenario to support extrapolation of credibility findings.",
      "rationale": "The validation activities replicate the ASTM F1717 test protocol that is the regulatory standard for pedicle screw construct mechanical performance. The FEA models, test specimens, and loading conditions are representative of the device and use scenario for which the model is intended to provide evidence. Achieved level 3 meets the requirement."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels for model risk level 3. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is acknowledged as a documented gap; however, the overall credibility evidence is judged sufficient to support use of the FEA ensemble for ASTM F1717 compression-bending performance prediction in the regulatory submission context, given the conservative nature of the single test condition and the strong performance of the ensemble across all other factors. The assessment team accepts the package with the test conditions gap recorded.",
