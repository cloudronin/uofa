      "acceptanceCriteria": "Achieved level must meet or exceed required level for the stated model risk.",
      "rationale": "FEA software (Ansys 2021 R2) is commercially validated; version control and regression testing documented in the software quality plan. Achieved level exceeds the required level for a Model Risk Category 3 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be reproduced within acceptable tolerance.",
      "rationale": "Code verification performed against NAFEMS benchmark suite; maximum deviation from analytical solutions is 0.8%, well within the 2% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or systematic mesh refinement study must demonstrate convergence to within 5% of the quantity of interest.",
      "rationale": "Three-level mesh refinement study conducted on the pedicle screw shank and rod interface. Richardson extrapolation yields a discretization error estimate of 1.4% on peak von Mises stress, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps; energy balance error must remain below 0.1%.",
      "rationale": "Nonlinear static solver residuals converged to 1e-8 for all 47 load increments. Energy balance error did not exceed 0.04% across any load step. Achieved level meets the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented peer review of model setup, boundary conditions, and material assignments by an independent analyst.",
      "rationale": "Independent peer review completed by a second FDA analyst; boundary condition application, material property assignments, and contact definitions verified against the model development report. No errors identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing physics must be justified relative to the quantity of interest; simplifying assumptions must be documented and bounded.",
      "rationale": "Linear elastic constitutive model justified for titanium alloy under sub-yield loading; geometric nonlinearity included to capture large-displacement rod bending. Simplifying assumptions (e.g., rigid test fixture representation) bounded by sensitivity analysis showing less than 2% influence on predicted construct stiffness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured specimen data or certified material specifications.",
      "rationale": "Titanium alloy (Ti-6Al-4V) elastic modulus and yield strength sourced from ASTM F136 certified material test reports for each production lot. Screw and rod geometry digitised from coordinate measuring machine data with 5 µm resolution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be representative of the production device; sample size must be sufficient to characterise inter-specimen variability.",
      "rationale": "N=11 production-representative constructs tested across two independent laboratories (FDA CDRH and DePuy Synthes). Coefficient of variation in failure load was 4.2%, indicating low inter-specimen variability consistent with a well-controlled manufacturing process."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use; multiple load levels or configurations should be evaluated.",
      "rationale": "Validation conducted at a single ASTM F1717 loading configuration (compression-bending, 10° offset). Additional loading configurations (axial compression, torsion) were not included in this validation activity. Achieved level falls below the required level; this gap is acknowledged in the overall credibility assessment and accepted given the targeted scope of the F1717 standard."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to the experimental test conditions used for validation.",
      "rationale": "Measured specimen dimensions, torque-controlled assembly preloads, and fixture geometry were directly mapped to model inputs. Equivalency confirmed by overlay of experimental and simulated load-displacement curves prior to outcome comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted quantities of interest must be compared to experimental measurements using appropriate statistical metrics; systematic bias must be characterised.",
      "rationale": "Construct stiffness and failure load compared using Bland-Altman analysis and normalised root-mean-square error (NRMSE). NRMSE for construct stiffness was 3.1% and for failure load was 4.7%, both within the 10% acceptance threshold. No systematic bias detected (mean difference within one standard deviation)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The predicted quantities of interest must be directly relevant to the clinical or regulatory decision supported by the model.",
      "rationale": "Construct stiffness and failure load under ASTM F1717 compression-bending are the primary regulatory endpoints for spinal implant 510(k) submissions. These quantities directly inform the comparative performance claim relative to the predicate device."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activities must be sufficiently similar in geometry, loading, material, and boundary conditions to the context in which the model will be used to support decisions.",
      "rationale": "Validation specimens are production-equivalent to the device under evaluation. Loading protocol replicates the standardised ASTM F1717 test used in regulatory submissions. The validation activity is therefore considered directly relevant to the model application in the 510(k) regulatory pathway."
    }
