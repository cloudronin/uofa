  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Model Risk Level 3 assessment. The single below-threshold factor (Test conditions, achieved level 2 vs. required level 3) was reviewed and accepted on the basis that the ASTM F1717 protocol specifies a single standardized load condition; additional test conditions are not prescribed by the applicable standard. The overall credibility evidence is sufficient to support the compression-bending performance claim for this non-cannulated 7.5 mm pedicle screw construct under the Minimal profile submission.",
