      "acceptanceCriteria": "Achieved level must meet or exceed required level for the stated model risk.",
      "rationale": "The FEA software (Ansys Mechanical 2021 R2) is used under an FDA-recognized quality management system. Version control, regression testing, and documented release notes are maintained. Achieved level exceeds required level for Medium assurance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from ASME V&V 10 and Ansys verification manual were executed and documented prior to analysis. Results matched analytical solutions within 0.5% for all benchmark cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study conducted with three mesh densities (coarse, medium, fine). Peak von Mises stress at screw-rod interface converged to within 2.1% between medium and fine meshes. Richardson extrapolation applied to quantify discretization error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals monitored and confirmed below 1e-6 for all load steps. Nonlinear convergence documented across all 11 model instances. No divergence events recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup reviewed by two independent analysts. Boundary conditions, material assignments, and contact definitions were cross-checked against the simulation plan. No discrepancies identified in the independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic constitutive model selected based on operating regime analysis confirming strains below yield for titanium alloy components under ASTM F1717 loading. Model form assumptions documented and justified with reference to published material characterization data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (Ti-6Al-4V: E=114 GPa, nu=0.34) sourced from ASTM F136 and manufacturer certificates of conformance. Geometry derived from calibrated CMM measurements of production implants. Input uncertainty quantified via sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 production-representative constructs tested across two independent laboratories. Samples drawn from the same production lot as those modeled. Dimensional inspection confirmed conformance to nominal geometry within drawing tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing performed at a single load magnitude and displacement rate per ASTM F1717. Variation in loading rate and multi-axial conditions not explored. This factor is below the required level; the gap is acknowledged and accepted given the standardized nature of the F1717 protocol and the regulatory precedent for single-condition validation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA model inputs mapped directly to measured specimen geometry and material certificates. Contact interface coefficients calibrated against preliminary friction tests. Documented traceability matrix links each model input to its experimental counterpart."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Predicted construct stiffness and failure load compared to experimental measurements. Mean FEA error: 4.2% for stiffness, 6.8% for failure load. Both within pre-specified acceptance thresholds of 10%. Statistical comparison using Bland-Altman analysis confirms acceptable agreement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Quantities of interest (construct stiffness, peak load at failure, stress distribution at screw-rod interface) are directly relevant to the mechanical performance claims. QoIs align with FDA guidance on spinal implant testing and published clinical failure modes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities replicate the loading scenario, boundary conditions, and implant configuration described in the intended use. ASTM F1717 is the recognized standard for this device class. Validation domain overlap with intended use domain assessed as high."
    }
