  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment outcome is Accepted. Twelve of thirteen V&V 40 factors meet or exceed required levels for model risk level 3. The single deficit in Test conditions (achieved level 2 vs. required level 3) is acknowledged; the team determined that the regulatory standardisation of the ASTM F1717 single-condition protocol constitutes an acceptable basis for the intended submission use, and that the remaining twelve factors collectively provide sufficient evidence of model credibility. No structured Context of Use record has been formally registered in this package; the intended use scope is described narratively in the package description field.",
