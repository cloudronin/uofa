  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical 2022 R2 is a commercially validated solver with documented QA procedures including regression test suites and release verification reports. Version control and change management records were reviewed and confirmed compliant with FDA 21 CFR Part 11 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Benchmark problems from the ASME V&V 10 suite and NAFEMS standard problems were executed to verify correct implementation of linear elastic and contact formulations. All benchmark results fell within accepted tolerance bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 5% change in peak von Mises stress and construct stiffness between successive refinements.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw-rod interface. Peak von Mises stress changed by 2.1% and construct stiffness by 1.4% between the medium and fine meshes. The medium mesh was selected for production runs to balance accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms below 1e-6 and energy convergence confirmed for all load steps.",
      "rationale": "The sparse direct solver (PARDISO) was used for all static analyses. Force and displacement residuals were confirmed below 1e-6 for all 11 simulated constructs. No solver warnings or divergence events were recorded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review by a second analyst.",
      "rationale": "A simulation execution checklist was developed and followed for each of the 11 model instances. An independent senior analyst reviewed boundary condition assignments, material property inputs, and load application for all cases. No use errors were identified during review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification that linear elastic continuum mechanics with frictional contact is appropriate for the quantity of interest (construct stiffness and yield load).",
      "rationale": "Linear elastic material models for titanium alloy (Ti-6Al-4V) are well-established for sub-yield loading regimes. Frictional contact at the screw-rod interface was modeled using an augmented Lagrangian formulation. The model form is consistent with published literature for ASTM F1717 FEA studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from traceable measurements or certified material data sheets.",
      "rationale": "Elastic modulus and yield strength for Ti-6Al-4V were taken from ASTM F136 certified material test reports provided by DePuy Synthes. Screw geometry was digitized from calibrated micro-CT scans of production implants. Dimensional tolerances were within 0.05 mm of nominal CAD values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N >= 10 samples from production lots with documented traceability to device master record.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. All samples were drawn from production lots with full traceability to the device master record. Sample dimensions were verified by metrology prior to testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at least two load levels.",
      "rationale": "Testing was conducted at a single standardized ASTM F1717 test condition (5 mm offset, 10 mm/min crosshead speed). While this condition is the regulatory standard, it does not span multiple load levels or offset distances. This factor is below the required level and represents the primary credibility gap in this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading replicate experimental test fixture constraints within documented tolerances.",
      "rationale": "The ASTM F1717 test fixture was modeled explicitly including the UHMWPE blocks and load application points. Boundary conditions were verified against the experimental fixture drawings. Offset distance was confirmed to within 0.1 mm by direct measurement of the test fixture."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric or percent error) applied to primary quantities of interest.",
      "rationale": "Construct stiffness and yield load were compared between FEA predictions and experimental measurements for all 11 constructs. Mean percent error was 4.2% for stiffness and 5.8% for yield load. The ASME V&V 20 area validation metric was applied and confirmed agreement within the 95% confidence interval of the experimental data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (construct stiffness, yield load) are directly linked to the device performance specification and clinical risk.",
      "rationale": "Construct stiffness and yield load under compression-bending are the primary mechanical performance indicators for pedicle screw systems under ASTM F1717. These quantities are directly linked to the risk of mechanical failure in vivo and are specified in the device performance requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities are conducted under conditions sufficiently similar to the intended use context to support credibility claims.",
      "rationale": "The ASTM F1717 test protocol is the accepted regulatory standard for spinal construct mechanical testing and directly represents the intended use loading mode. The validation activities are therefore highly relevant to the credibility claim for FEA-based prediction of compression-bending performance."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility is sufficient to support the intended regulatory use. Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for model risk level 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is acknowledged; the assessment team determined that the ASTM F1717 single-condition protocol represents the regulatory standard and that the overall body of evidence is adequate for the submission decision.",
