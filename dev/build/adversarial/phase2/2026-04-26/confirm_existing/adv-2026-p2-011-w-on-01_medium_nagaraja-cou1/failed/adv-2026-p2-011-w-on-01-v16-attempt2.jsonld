  "signature": "ed25519:b1c4e7a0d3f6b9c2e5a8d1f4b7c0e3a6d9f2b5c8e1a4d7f0b3c6e9a2d5f8b1c4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "The FEA software (Ansys Mechanical) is a commercially validated code with documented QA procedures including regression testing and version-controlled releases. FDA CDRH has independently verified the software version used. Achieved level 3 exceeds the required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including patch tests and single-element tests were performed. Results compared against analytical solutions with errors below 0.5%. Manufacturer verification documentation provided for all solver modules used in the pedicle screw model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required; achieved level must equal required level at minimum.",
      "rationale": "A systematic mesh convergence study was conducted using three mesh densities (coarse, medium, fine). The Richardson extrapolation-based GCI was below 2% for peak von Mises stress at the screw-rod interface. The medium mesh was selected for production runs, achieving level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals and energy balance checks must be documented.",
      "rationale": "Nonlinear solver residuals were monitored throughout each analysis step. Energy balance errors remained below 1% across all 11 construct simulations. Default solver tolerances were tightened by one order of magnitude to ensure convergence quality."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented review process for model setup and boundary condition application.",
      "rationale": "Independent peer review of model setup was performed by a second analyst not involved in original model construction. Boundary condition application, material assignment, and contact definitions were verified against the ASTM F1717 test protocol. No use errors were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection must be justified relative to the physics of the ASTM F1717 test.",
      "rationale": "Linear elastic material models were selected for titanium alloy components based on the sub-yield loading regime of the ASTM F1717 static test. Contact mechanics were modeled using augmented Lagrangian formulation. Model form is well-established for metallic spinal implant analysis and is consistent with published literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured or certified values.",
      "rationale": "Ti-6Al-4V material properties were sourced from ASTM F136 certified material test reports for each lot. Geometric dimensions were obtained from CMM measurements of actual test specimens. Friction coefficients at screw-rod interfaces were characterized by dedicated tribology experiments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient sample size and documentation of specimen provenance required.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested, meeting the ASTM F1717 minimum sample requirement. Specimens were sourced from a single production lot with full traceability. Dimensional measurements confirmed all specimens were within drawing tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple test conditions spanning the intended use envelope are required at level 3.",
      "rationale": "Testing was performed under a single load configuration (compression-bending at 5 degrees offset) as specified by ASTM F1717. The required level 3 demands multiple test conditions; however, only this single standardized condition was evaluated. This factor is below the required level and represents a known gap in the validation evidence base."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions must demonstrably replicate the physical test setup.",
      "rationale": "Fixture geometry, load application point, and constraint conditions in the FEA model were derived directly from the physical test rig drawings. Compliance of the test machine was characterized and incorporated into the model boundary conditions. Agreement between simulated and measured load-displacement curves confirmed equivalency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics must be reported with uncertainty bounds.",
      "rationale": "Predicted construct stiffness and peak load at 0.5 mm displacement were compared against experimental measurements. Mean absolute percentage error was 4.2% for stiffness and 5.8% for peak load across N=11 constructs. Experimental uncertainty was quantified using ASTM E691 interlaboratory study methods across two independent laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be clinically and mechanically relevant to the intended use.",
      "rationale": "Construct stiffness and load-to-failure are the primary mechanical endpoints for spinal fixation device evaluation under ASTM F1717 and are directly relevant to the biomechanical performance claims submitted in regulatory submissions. These quantities are standard acceptance criteria in FDA guidance for spinal pedicle screw systems."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently representative of the intended computational use.",
      "rationale": "The validation activities directly replicate the ASTM F1717 test protocol that forms the basis of the computational use. The FEA ensemble was validated against the same construct geometry, material, and loading conditions used in the intended regulatory submission. Cross-laboratory validation strengthens confidence in result generalizability."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels for model risk level 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is acknowledged; however, the ASTM F1717 protocol prescribes a single standardized test condition, and the overall weight of evidence across the remaining factors is sufficient to support acceptance. The FEA model ensemble demonstrates adequate predictive accuracy (MAPE below 6%) for construct stiffness and peak load, supporting its use in the intended regulatory context.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
