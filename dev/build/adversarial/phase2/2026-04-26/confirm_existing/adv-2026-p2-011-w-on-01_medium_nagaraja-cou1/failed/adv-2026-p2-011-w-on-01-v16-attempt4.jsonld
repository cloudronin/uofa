  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA implementations (FDA, Ansys, DePuy Synthes) operate under documented software quality management systems. Version control, issue tracking, and regression test suites are maintained. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate solver correctness for linear static structural analysis.",
      "rationale": "Benchmark problems from NAFEMS and internal patch tests confirm correct implementation of the linear elastic constitutive models and contact algorithms used in this analysis. Achieved level exceeds required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate solution change below 5% between successive refinements for all quantities of interest.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw and rod assembly. Peak von Mises stress and construct stiffness changed by less than 2% between the medium and fine meshes. Richardson extrapolation confirms GCI below 3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms must converge to machine precision tolerances; iterative solver residuals documented.",
      "rationale": "Direct sparse solvers used in all three FEA implementations; residual norms confirmed at machine precision. No iterative convergence concerns identified for this linear static problem."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup and boundary condition application must be independently reviewed by a second analyst.",
      "rationale": "Independent cross-checks of boundary condition application, material property assignment, and load magnitude were performed by analysts at each of the three institutions. Discrepancies were resolved prior to result comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions must be justified by literature evidence or sensitivity analysis for the compression-bending loading scenario.",
      "rationale": "Linear elastic material models for titanium alloy components are well-supported by literature for sub-yield loading. Contact modeling assumptions (frictionless at screw-rod interface) were evaluated via sensitivity analysis showing less than 4% effect on stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions must be traceable to measured values from the tested constructs.",
      "rationale": "Ti-6Al-4V elastic modulus and Poisson's ratio sourced from ASTM F136 material certificates for the specific lot used in testing. Geometric dimensions derived from CMM measurements of representative screws from the test population."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample population must be representative and of sufficient size to characterize experimental variability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. Sample size sufficient to estimate coefficient of variation for stiffness and failure load. Construct assembly followed ASTM F1717 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use, including at minimum two distinct load levels.",
      "rationale": "Testing was conducted under a single standardized ASTM F1717 compression-bending load configuration. While this configuration is the regulatory standard, only one test condition was evaluated, preventing characterization of model performance across varying load magnitudes or angulations. Achieved level falls below required level for model risk level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters must be demonstrably equivalent to experimental test conditions within stated measurement uncertainty.",
      "rationale": "Applied load magnitude, crosshead displacement rate equivalent, and boundary condition geometry in FEA were matched to experimental setup within measurement uncertainty. Fixture stiffness corrections applied consistently across all three FEA implementations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., NRMSE, prediction interval coverage) must be computed and reported for all quantities of interest.",
      "rationale": "Construct stiffness and peak load at 2% offset yield compared between FEA ensemble and N=11 experimental results. NRMSE of 6.2% for stiffness and 8.4% for peak load. FEA ensemble mean falls within one experimental standard deviation for both QoIs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest used in validation must be directly linked to the decision-relevant performance metrics.",
      "rationale": "Construct stiffness and failure load under compression-bending are the primary biomechanical performance metrics for regulatory assessment of pedicle screw systems under ASTM F1717. These QoIs directly inform the accept/reject decision framework."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the intended use scenario to support extrapolation of credibility evidence.",
      "rationale": "The ASTM F1717 compression-bending test configuration closely replicates the dominant loading mode experienced by posterior spinal fixation constructs in vivo. The validation constructs use the same device geometry, material, and assembly configuration as the submission device."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is acknowledged; however, the ASTM F1717 single-condition protocol represents the regulatory standard for this device class, and the ensemble model agreement across three independent implementations provides compensating evidence of model robustness. The overall credibility evidence is judged sufficient to support the intended regulatory decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
