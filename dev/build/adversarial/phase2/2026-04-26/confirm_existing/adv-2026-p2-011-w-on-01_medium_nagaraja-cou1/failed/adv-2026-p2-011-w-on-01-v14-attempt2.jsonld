  "signature": "ed25519:9e8d7c6b5a4f3e2d1c0b9a8f7e6d5c4b3a2f1e0d9c8b7a6f5e4d3c2b1a0f9e8d",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical R2022 R2 with documented verification tests; FDA in-house solver subject to CFR 21 Part 11 controls. Achieved level must meet required level.",
      "rationale": "All three FEA solvers (FDA in-house, Ansys Mechanical, DePuy Synthes internal) operate under documented software quality management systems. Version-controlled executables with regression test suites confirm numerical reproducibility across platforms. SQA records archived in institutional repositories consistent with ASME V&V 40 Gradation 3 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions for linear elastic beam bending and contact mechanics reproduced within 1% relative error. Patch test passed for all element types employed.",
      "rationale": "Code verification performed against NAFEMS benchmark suite for structural mechanics. Ansys SOLID186 and CONTA174 element formulations verified against closed-form Hertzian contact solutions. FDA solver verified via method of manufactured solutions for nonlinear geometry cases. All benchmarks archived with simulation logs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Global Richardson extrapolation GCI < 5% for construct stiffness QOI. Local mesh refinement at screw-rod interface demonstrating convergence.",
      "rationale": "Systematic mesh refinement study conducted across three mesh densities (coarse ~85k, medium ~340k, fine ~1.36M elements). GCI for construct stiffness QOI computed at 2.8%, satisfying the 5% threshold. Thread root stress concentrations assessed with sub-model technique; convergence confirmed at element edge length 0.05 mm."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver residual norm < 1e-6 at each load increment. Energy balance error < 0.1% across full load history.",
      "rationale": "Newton-Raphson iteration with line-search stabilisation employed. Force and displacement residuals monitored across 200 equal load increments to 4000 N applied moment. Maximum residual norm 3.2e-7 observed at peak load near geometric nonlinearity onset. Energy balance error 0.04%. Solver log files retained for audit."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst replication of simulation setup from documented input deck. Checklist-based review of boundary conditions, material assignments, and contact definitions by second analyst.",
      "rationale": "Simulation input decks subject to peer review by independent analyst at each participating laboratory. Standardised checklist covering 47 setup items completed prior to each run. No critical discrepancies identified across three laboratory replications. Use error assessment documented in internal review memoranda dated 2023-11-15."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic constitutive model with isotropic hardening validated against uniaxial coupon data for Ti-6Al-4V ELI. Geometric nonlinearity (large displacement) formulation active.",
      "rationale": "Ti-6Al-4V ELI material characterised via ASTM E8 uniaxial tension coupons (n=6 per lot). Ramberg-Osgood fit R2=0.9994. Geometric nonlinearity captured via updated Lagrangian formulation. Frictionless and frictional (mu=0.2) contact sensitivity study showed <3% difference in construct stiffness, supporting model form adequacy for the compression-bending QOI."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties, geometry dimensions, and boundary condition parameters traceable to measured values with documented uncertainty. Sensitivity analysis identifies dominant input parameters.",
      "rationale": "Screw and rod geometry digitised from CMM measurements (±0.005 mm). Material properties sourced from lot-specific coupon tests and ASTM F136 certificate of conformance. Boundary conditions replicate ASTM F1717 fixture geometry. One-at-a-time sensitivity analysis identifies rod diameter and elastic modulus as dominant inputs, each contributing <4% variation to stiffness QOI within measured uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 physical constructs from production lots with documented dimensional inspection. Samples span two independent laboratories.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs assembled from production components. Each construct dimensionally inspected per ASTM F1717 Section 6. Samples distributed across two independent test laboratories (FDA CDRH and DePuy Synthes) to assess inter-laboratory variability. Coefficient of variation for experimental stiffness 4.2%, consistent with historical F1717 repeatability data."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of intended clinical loading scenarios including minimum and maximum expected bending moments and axial loads.",
      "rationale": "Testing performed under a single ASTM F1717 prescribed load condition (4000 N axial compression with 10 Nm bending moment). The standard does not require multi-condition testing; however, the COU encompasses a broader range of in vivo loading scenarios including flexion-extension and lateral bending that were not experimentally replicated. This factor therefore achieves Gradation 2 rather than the required Gradation 3, representing the one below-threshold factor identified in this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, material, boundary conditions) demonstrably equivalent to physical test specimen parameters within stated measurement uncertainties.",
      "rationale": "Direct mapping of measured specimen dimensions to FEA geometry confirmed. Material property inputs within 1.5 standard deviations of measured coupon population. Fixture compliance characterised experimentally and incorporated into simulation boundary conditions. Equivalency confirmed via formal parameter-by-parameter traceability matrix documented in V&V report Appendix B."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric M) computed with statistical confidence bounds. Simulation prediction within experimental variability band for primary QOIs.",
      "rationale": "Area validation metric computed per ASME V&V 20 for load-displacement curves. M=0.08 (well below threshold of 0.2 for medium risk). FEA ensemble mean stiffness 312 N/mm vs. experimental mean 308 N/mm (1.3% difference). Yield load predictions within 5.8% of experimental mean. All three laboratory FEA predictions within experimental 95% confidence interval."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs (construct stiffness, yield load, maximum von Mises stress at screw-rod interface) directly relevant to clinical performance endpoints and regulatory submission requirements.",
      "rationale": "Primary QOIs — construct stiffness and yield load — directly correspond to ASTM F1717 acceptance criteria and are the quantities cited in 510(k) substantial equivalence determinations for pedicle screw systems. Secondary QOI (peak stress at screw-rod interface) relevant to fatigue life prediction supporting clinical longevity claims. QOI relevance confirmed by regulatory affairs review against predicate device submission K193482."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities conducted under conditions sufficiently representative of the intended use conditions to support extrapolation of credibility findings to the COU.",
      "rationale": "ASTM F1717 validation activity directly replicates the regulatory test standard against which device performance is assessed. Physical test conditions (loading mode, fixture geometry, specimen preparation) mirror the intended regulatory submission context. Extrapolation from single-condition validation to broader clinical loading addressed via conservative safety factor analysis documented in the risk assessment. Validation activity deemed sufficiently representative for the regulatory decision context."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required gradation level for a Model Risk Level 3 assessment. The single below-threshold factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is acknowledged and documented. The assessment team determined that the ASTM F1717 standard test condition is the regulatory reference condition and that the shortfall in multi-condition coverage does not invalidate the primary regulatory use of the model for 510(k) submission support. Overall credibility is judged sufficient for the intended decision context. The model has been applied in clinical research supporting regulatory submissions and the ensemble agreement across three independent laboratories provides additional confidence in prediction fidelity.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
