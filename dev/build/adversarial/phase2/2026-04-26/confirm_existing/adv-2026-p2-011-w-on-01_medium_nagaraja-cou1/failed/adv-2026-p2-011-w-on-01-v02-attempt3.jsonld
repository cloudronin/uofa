  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "All three FEA platforms (FDA in-house, Ansys 2021 R2, DePuy Synthes proprietary) operate under documented software quality management systems with version control, regression test suites, and traceability to requirements. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including cantilever beam bending and contact patch tests were executed on all three codes. Results agreed with analytical solutions to within 0.5%. Published verification reports available for Ansys and the FDA in-house solver."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required; discretization error must be quantified and reported.",
      "rationale": "Systematic mesh refinement studies were performed on the screw-rod-block assembly. Global displacement and peak von Mises stress quantities of interest converged to within 2% between the medium and fine meshes. Richardson extrapolation applied to estimate asymptotic solution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals and iteration convergence criteria must be documented.",
      "rationale": "Newton-Raphson iteration tolerances set to 1e-6 on force and displacement residuals. Energy convergence criterion additionally monitored. No solution divergence observed across the 11-construct ensemble. Solver logs archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures must be documented and independently reviewed.",
      "rationale": "Boundary condition application, material assignment, and contact definition procedures were documented in a model setup protocol reviewed by a second analyst at each of the three organizations. Cross-organization consistency checks were performed prior to result comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum mechanics assumptions and contact formulation must be justified for the loading regime.",
      "rationale": "Linear elastic material models for titanium alloy Ti-6Al-4V and UHMWPE blocks are appropriate for the predominantly elastic deformation regime under F1717 quasi-static loading. Augmented Lagrangian contact formulation captures screw-rod and rod-block interactions. Model form uncertainty quantified via comparison across three independently developed models."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters must be traceable to measurements or certified material data sheets.",
      "rationale": "Elastic modulus (114 GPa) and Poisson's ratio (0.34) for Ti-6Al-4V sourced from ASM certified data. UHMWPE block properties from manufacturer certificates. Screw and rod geometry extracted from CMM measurements of test specimens. Variability in material inputs propagated via sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sample size must be sufficient for statistical comparison; samples must be traceable to production lots.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. Constructs sourced from the same production lot. Sample size supports mean and standard deviation estimation with adequate statistical power for the comparison metric."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of conditions represented in the COU; environmental and loading variability must be characterized.",
      "rationale": "Testing performed at a single compressive load level per ASTM F1717 protocol. The standard does not mandate multi-load-level testing; however, only one test condition was evaluated, limiting coverage of the loading envelope. This factor is below the required level and constitutes a documented limitation of the validation evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be demonstrably equivalent to test specimen parameters.",
      "rationale": "CMM-measured specimen dimensions were used to parameterize each of the 11 FEA models individually, ensuring geometric equivalency. Material property inputs verified against lot-specific certificates. Boundary condition equivalency confirmed by comparing applied displacement profiles between test machine records and FEA load steps."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric must be defined a priori; prediction error must be within acceptance bounds.",
      "rationale": "Primary comparison metric is construct stiffness (N/mm) at 2% offset. Mean prediction error across the ensemble was 4.3% with 95% CI [2.1%, 6.5%], within the pre-specified 10% acceptance bound. Bland-Altman analysis confirmed no systematic bias. Results consistent across all three FEA platforms."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest must be directly linked to the clinical or regulatory question.",
      "rationale": "Construct stiffness and maximum von Mises stress at the screw-rod junction are the primary quantities of interest, directly relevant to fatigue life prediction and implant performance characterization required for 510(k) submissions. Both quantities are standard outputs in ASTM F1717 analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the COU to support credibility claims.",
      "rationale": "Validation activities replicate the ASTM F1717 test configuration that defines the COU for this assessment. The non-cannulated 7.5 mm geometry, Ti-6Al-4V material, and quasi-static compression-bending loading are all representative of the intended use conditions. Inter-laboratory reproducibility across two independent test facilities further strengthens the relevance argument."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for Model Risk Level 3. The single deficient factor (Test conditions, achieved level 2 vs. required level 3) has been documented and accepted on the basis that ASTM F1717 prescribes a single test condition and that the prediction error at that condition is within the pre-specified acceptance bound. Overall credibility is sufficient to support the intended regulatory use.",
