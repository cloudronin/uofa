  "name": "Nagaraja COU1 — Non-cannulated pedicle screw compression-bending credibility assessment (Minimal Profile)",
  "description": "V&V 40 credibility assessment for FEA prediction of ASTM F1717 static compression-bending performance of a non-cannulated 7.5 mm pedicle screw construct. COU1 is the validation activity itself — the FEA model ensemble (FDA, Ansys, DePuy Synthes) is compared against N=11 experimental constructs across two laboratories. All 13 V&V 40 factors assessed; one factor (Test conditions) below required level due to single test condition. This model has been applied in clinical research supporting pre-market submissions for posterior spinal fixation devices, informing design decisions across a range of patient anatomies. The computational framework is considered mature and has been exercised across multiple regulatory contexts.",
  "bindsRequirement": "https://uofa.net/synth/req/nagaraja-f1717-compression-bending-req",
  "bindsClaim": "https://uofa.net/synth/claim/nagaraja-fea-compression-bending-claim",
  "bindsModel": "https://uofa.net/synth/model/nagaraja-pedicle-screw-fea-ensemble",
  "bindsDataset": [
    "https://uofa.net/synth/data/nagaraja-f1717-experimental-n11",
    "https://uofa.net/synth/data/nagaraja-fea-output-ensemble"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-01",
      "type": "ValidationResult",
      "name": "F1717 compression-bending FEA vs. experimental comparison — N=11 constructs, two laboratories"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-02",
      "type": "ValidationResult",
      "name": "Cross-laboratory reproducibility assessment for pedicle screw construct stiffness and failure load"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4044667",
