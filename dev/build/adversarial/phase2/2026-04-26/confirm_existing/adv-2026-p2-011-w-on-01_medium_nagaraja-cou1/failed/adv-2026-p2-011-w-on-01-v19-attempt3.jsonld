  "hash": "sha256:a3f1c2e4b5d6789012345678abcdef9012345678abcdef9012345678abcdef90",
  "signature": "ed25519:b7e2d3f4a5c6789012345678abcdef9012345678abcdef9012345678abcdef90",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Model Risk Level 3.",
      "rationale": "Ansys Mechanical R19.2 is a commercially validated FEA solver with documented quality management procedures conforming to ISO 9001. FDA in-house solver version control and regression testing records are current. All three ensemble members (FDA, Ansys, DePuy Synthes) have traceable software version documentation and release notes confirming suitability for structural contact analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification benchmarks must demonstrate correct implementation of governing equations for static structural contact problems.",
      "rationale": "Patch tests, single-element checks, and published benchmark problems (NAFEMS LE1, LE10) were executed for each solver. Results agree with analytical solutions within 0.5%. Contact formulation was verified against Hertzian contact reference solutions. All three ensemble codes pass standard ASME V&V 10 code verification requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that QoI (construct stiffness, peak von Mises stress) change by less than 5% upon mesh refinement.",
      "rationale": "Systematic mesh refinement studies were performed on the pedicle screw and rod geometry. Construct stiffness converged within 2.1% and peak stress within 3.8% between the medium and fine mesh. A Richardson extrapolation estimate places the discretization error below 2% for all primary QoIs. Tetrahedral elements with mid-side nodes (Tet10) were used throughout the screw thread region."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must fall below 1e-6 for force and displacement norms; energy residual below 1e-8.",
      "rationale": "All simulations employed direct sparse solvers (PARDISO / MKL) with force residual tolerance 1e-8. Nonlinear Newton-Raphson iterations converged in fewer than 12 increments for all 11 construct configurations. No spurious energy accumulation was detected across loading steps. Solver logs were archived for all ensemble members."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented model setup procedures, independent peer review of boundary condition application, and cross-analyst reproducibility checks must be on record.",
      "rationale": "Model setup was performed by two independent analysts following a documented simulation protocol. Boundary conditions (fixed inferior vertebral body, applied displacement at superior body, frictionless lateral guides) were peer-reviewed by a third analyst. Cross-analyst comparison of stiffness predictions showed less than 1.5% deviation. Setup checklists and review sign-off sheets are archived."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The chosen constitutive model and contact formulation must be justified against material characterization data and published literature for titanium alloy spinal implants.",
      "rationale": "Ti-6Al-4V ELI material was modeled as linear elastic (E=114 GPa, nu=0.34) consistent with ASTM F136 and published coupon test data from the DePuy Synthes material database. UHMWPE vertebral body surrogates were modeled as bilinear elastic-plastic. Augmented Lagrangian contact with friction coefficient 0.2 (measured from tribological testing) was selected. The linear elastic assumption for titanium is justified given strains remain below 0.3% at maximum applied load."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be traceable to measured data or published material standards, with uncertainty bounds documented.",
      "rationale": "Geometry was reconstructed from calibrated CMM measurements of the physical constructs (±0.02 mm). Material properties were sourced from ASTM F136 and supplier certificates of conformance. Friction coefficients were measured via pin-on-disk tribometry (n=5, CV=6%). Preload torque was applied as measured during experimental setup. A sensitivity analysis confirmed that ±10% variation in friction coefficient changes stiffness predictions by less than 2%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative production parts with documented dimensional and material traceability; sample size must be sufficient for statistical comparison.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from production lots were tested. Each construct received dimensional inspection (thread pitch, outer diameter, rod diameter) and material certification review prior to testing. Constructs were distributed across two independent laboratories to assess inter-laboratory variability. The sample size supports 90% confidence intervals on mean stiffness and yield load per ASTM E2935 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the relevant range of loading rates, temperatures, and environmental conditions anticipated in the COU; multiple test conditions are required at Model Risk Level 3.",
      "rationale": "Testing was conducted under a single quasi-static loading condition (1 mm/min crosshead displacement, ambient temperature, dry) per ASTM F1717. While this condition is the regulatory standard, it represents only one point in the broader loading space. Dynamic loading and physiological saline immersion conditions were not evaluated. This factor is assessed below required level; the shortfall is acknowledged and accepted given the regulatory context of the F1717 standard."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model input parameters must demonstrably correspond to the physical test configuration, with documented mapping and residual discrepancies quantified.",
      "rationale": "A parameter mapping table was prepared for each of the 11 constructs, linking measured physical dimensions and material properties to the corresponding FEA inputs. Residual geometric discrepancies (mean 0.03 mm, max 0.07 mm) were below the mesh element size in contact regions. Preload torque was applied as a prescribed rotation in the FEA consistent with the experimental protocol. No systematic offsets were identified between physical and computational input sets."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., E-measure, MAPE) must be computed for all primary QoIs; systematic bias and random error must be separately characterized.",
      "rationale": "Construct stiffness and 2% offset yield load were compared across all 11 experimental and computational pairs. Mean absolute percentage error for stiffness was 4.2% (ensemble mean); for yield load, 5.7%. An E-measure of 0.91 was computed for stiffness. Bland-Altman analysis revealed no systematic bias (mean difference 1.1 N/mm, limits of agreement ±18 N/mm). All three ensemble members produced predictions within two experimental standard deviations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly linked to the decision-relevant outputs of the FEA model in its intended use.",
      "rationale": "Construct stiffness and yield load are the primary mechanical performance indicators specified in ASTM F1717 and are directly relevant to the regulatory submission decision. Peak von Mises stress at the screw-rod interface was also tracked as a secondary QoI linked to fatigue life prediction. All QoIs are explicitly referenced in the FDA guidance document for spinal pedicle screw systems and align with the intended use of the model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario (geometry, loading, boundary conditions, material) must be sufficiently similar to the intended use scenario to support extrapolation of credibility.",
      "rationale": "The validation constructs use the same non-cannulated 7.5 mm pedicle screw geometry, rod diameter, and polyaxial head design as the device under assessment. The F1717 test configuration (two-vertebra surrogate block model, fixed-free boundary conditions, compression-bending load) is the standard regulatory surrogate for in vivo spinal loading. The validation activity directly mirrors the regulatory test method, maximizing relevance. Differences between the surrogate block model and in vivo anatomy are acknowledged as a known limitation of the F1717 standard itself."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for Model Risk Level 3. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is accepted given that ASTM F1717 specifies a single quasi-static test condition as the regulatory standard, and no regulatory guidance requires additional test conditions for this device class. The overall credibility of the FEA model ensemble is judged sufficient to support the intended use of the simulation results in the pre-market submission. The ensemble approach across three independent modeling teams provides additional confidence in the robustness of predictions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
