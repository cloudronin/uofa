  "signature": "ed25519:b7e3a1f2c4d5e6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "All three FEA codes (FDA in-house, Ansys, DePuy Synthes) operate under documented software quality management systems with version control, regression testing, and audit trails consistent with 21 CFR Part 11 requirements. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Benchmark problems from ASME V&V 10 and vendor-supplied verification suites were executed for each code. Results showed agreement within 1% for linear elastic benchmark cases. Code verification is documented in each organization's quality records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required; discretization error must be quantified and below 5% for primary QOI.",
      "rationale": "Systematic mesh refinement study performed across three mesh densities for the screw-rod construct. Richardson extrapolation applied to peak von Mises stress and construct stiffness. Discretization error estimated at 2.8% for stiffness QOI, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals and iterative convergence tolerances must be documented and within acceptable bounds.",
      "rationale": "Linear solver residuals below 1e-8 for all load steps. Direct solver (PARDISO) used for primary runs; iterative solver cross-check performed on representative load case confirming agreement within 0.1%. Numerical solver error is negligible relative to other uncertainty sources."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures must be documented; independent reviewer must verify boundary condition and material assignment correctness.",
      "rationale": "Model setup checklists completed by each of the three modeling teams. Independent peer review of boundary conditions, contact definitions, and material assignments performed at FDA. No discrepancies identified that would affect primary QOI predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection must be justified relative to expected material behavior under ASTM F1717 loading; sensitivity to model form assumptions must be characterized.",
      "rationale": "Linear elastic isotropic constitutive model adopted for titanium alloy components, consistent with expected small-strain regime under F1717 protocol. Sensitivity analysis comparing bilinear plasticity model showed less than 3% difference in construct stiffness, supporting linear elastic model form selection."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured or published values with uncertainty bounds reported.",
      "rationale": "Elastic modulus and Poisson's ratio sourced from ASTM F136 material certification data for Ti-6Al-4V ELI. Geometric dimensions measured via CMM on representative screw samples (n=5). Input uncertainty propagation performed via Monte Carlo sampling; stiffness QOI coefficient of variation below 4%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of the device configuration modeled; sample traceability and dimensional verification required.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All samples sourced from the same production lot with material certification. Dimensional measurements confirmed conformance to CAD nominal within manufacturing tolerances. Sample-to-sample variability in stiffness was 6.2% CV."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use; multiple load levels or configurations required.",
      "rationale": "Testing performed under a single load condition per ASTM F1717 protocol (compression-bending at 10 Nm moment). While this is the standard regulatory condition, only one test configuration was employed, limiting the ability to characterize model behavior across a range of conditions. This factor is below the required level and represents a known gap in the validation evidence base."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs must be demonstrably equivalent to test specimen properties and test setup parameters.",
      "rationale": "Material properties, geometry, fixture compliance, and boundary conditions in each FEA model were reconciled against measured test specimen data and laboratory fixture characterization data. Fixture stiffness measured at both laboratories and incorporated into FEA boundary conditions. Equivalency confirmed through pre-test blind predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., ASME V&V 20 validation metric or equivalent) must be applied; agreement within defined tolerance bands.",
      "rationale": "Construct stiffness predictions from all three FEA codes compared against N=11 experimental measurements using the ASME V&V 20 validation metric. All three model predictions fell within the 95% confidence interval of experimental results. Mean prediction error was 4.1% (FDA), 5.7% (Ansys), and 3.9% (DePuy Synthes). Validation metric U_val < U_req for stiffness QOI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation must be directly relevant to the clinical and regulatory decision being supported.",
      "rationale": "Construct stiffness and peak implant stress are the primary QOIs, directly corresponding to the biomechanical performance endpoints specified in FDA guidance for spinal pedicle screw systems. These QOIs are used in clinical research to characterize fatigue life and load-sharing behavior, confirming their relevance to the intended decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the intended use scenario to support extrapolation of credibility evidence.",
      "rationale": "Validation performed using the identical device configuration, material system, and loading protocol as the intended regulatory submission scenario. The ASTM F1717 test protocol is the accepted standard for this device class. Similarity assessment confirms high relevance of validation activities to the intended use, notwithstanding the single-condition limitation noted under Test conditions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment outcome is Accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is acknowledged; however, the ASTM F1717 protocol represents the regulatory standard for this device class and the single-condition limitation is consistent with standard industry practice for Class II spinal implants. The ensemble modeling approach across three independent organizations substantially increases confidence in model predictions. The validation evidence is considered adequate to support the intended regulatory and clinical research applications.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
