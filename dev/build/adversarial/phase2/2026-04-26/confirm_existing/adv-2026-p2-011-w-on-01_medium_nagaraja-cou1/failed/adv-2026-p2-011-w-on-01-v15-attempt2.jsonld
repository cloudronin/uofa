      "name": "F1717 compression-bending FEA vs. experiment comparison — N=11 constructs, two laboratories"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-02",
      "type": "ValidationResult",
      "name": "Ensemble model agreement assessment across FDA, Ansys, and DePuy Synthes implementations"
    }
  ],
