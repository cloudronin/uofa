  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA implementations (FDA, Ansys, DePuy Synthes) operate under documented software quality management systems with version control, regression testing, and issue tracking. Ansys Mechanical is a commercially validated solver with FDA-recognized SQA documentation. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Benchmark problems from NAFEMS and internal patch tests were used to verify correct implementation of linear elastic solid elements and contact algorithms. All three codes produced results within 1% of analytical solutions for canonical beam-bending and contact patch tests."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence demonstrated with less than 5% change in quantity of interest between successive refinements.",
      "rationale": "Mesh convergence studies were performed on the pedicle screw and rod assembly. Three mesh densities were evaluated; the quantity of interest (construct stiffness) changed by less than 2% between the medium and fine meshes. The medium mesh was selected for production runs, achieving the required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance monitored; solver tolerances documented.",
      "rationale": "Nonlinear solver residuals were monitored throughout each analysis. Force and displacement residuals converged to tolerances of 1e-4 and 1e-5 respectively. Energy balance checks confirmed no spurious energy generation. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures documented and independently reviewed by a second analyst.",
      "rationale": "Model setup procedures were documented in a formal simulation plan reviewed by an independent analyst at each participating laboratory. Boundary condition application and material assignment were cross-checked against the simulation plan prior to execution. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions documented and justified relative to the physical phenomena being represented.",
      "rationale": "Linear elastic material models were selected for titanium alloy components consistent with the sub-yield loading regime of ASTM F1717. Frictional contact was modeled at screw-rod and rod-block interfaces with documented coefficient values. Model form assumptions are consistent with established practice for spinal implant FEA under quasi-static loading."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs sourced from traceable measurements or certified material specifications.",
      "rationale": "Titanium alloy (Ti-6Al-4V) elastic modulus and Poisson's ratio were taken from certified material test reports for the production lot used in physical testing. Geometry was derived from calibrated CMM measurements of production implant components. Input uncertainty was quantified and propagated to the QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples are representative of the device population and sample size is adequate for statistical characterization.",
      "rationale": "N=11 production pedicle screw constructs were tested across two independent laboratories. All samples were drawn from the same production lot. Sample-to-sample geometric variability was characterized by CMM measurement and incorporated into the simulation ensemble. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of conditions relevant to the intended use.",
      "rationale": "Physical testing was conducted at a single loading rate and single construct configuration per ASTM F1717. While the protocol is standardized, only one test condition was evaluated, limiting the ability to characterize model behavior across the full range of clinically relevant loading scenarios. Achieved level 2 falls below required level 3; this gap is acknowledged as a limitation of the standardized test method."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs are demonstrably equivalent to the conditions of the physical test.",
      "rationale": "Boundary conditions in the FEA models were defined to replicate the ASTM F1717 fixture geometry, load application points, and constraint conditions as measured in the physical test setup. Load cell calibration records and fixture dimensional measurements were used to confirm equivalency. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics defined a priori; simulation outputs fall within acceptance bounds.",
      "rationale": "Construct stiffness and yield load were defined a priori as primary QoIs. All three FEA implementations predicted stiffness within 8% of the experimental mean, and yield load within 10%. The ensemble mean fell within one experimental standard deviation. Quantitative acceptance criteria defined in the simulation plan were met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs are directly linked to the clinical or regulatory question being addressed.",
      "rationale": "Construct stiffness and yield load under compression-bending are the primary biomechanical performance metrics evaluated in regulatory submissions for pedicle screw systems. These QoIs are directly relevant to the assessment of mechanical integrity under physiological loading conditions. Required level 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities address the same physical phenomena, length scales, and loading modes as the intended model use.",
      "rationale": "The validation activity directly replicates the standardized test configuration used in regulatory evaluation of spinal implant constructs. The loading mode, fixture geometry, and implant configuration in the validation study are identical to those in the intended simulation use. Required level 3 achieved."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen credibility factors were assessed against requirements for a Model Risk Level 3 device. Twelve of thirteen factors meet or exceed required levels. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is attributable to the constraints of the ASTM F1717 standardized test method and is consistent with accepted regulatory practice for Class II spinal implant submissions. The overall body of evidence supports acceptance of the FEA model for its intended use in compression-bending performance assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
