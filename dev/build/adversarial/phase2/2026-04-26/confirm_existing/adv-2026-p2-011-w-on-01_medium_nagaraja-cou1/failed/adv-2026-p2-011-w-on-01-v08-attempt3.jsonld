      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical 2021 R2 used with documented release validation suite. FDA in-house FEA code subject to institutional SQA procedures. DePuy Synthes code verified under ISO 13485 QMS. All three ensemble members meet Gradation 3 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Benchmark problems from NAFEMS suite executed for each solver. Patch tests and single-element checks confirm correct element formulation. Results within 1% of analytical solutions for all benchmark cases."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Mesh convergence study performed across three refinement levels. Peak von Mises stress in screw-rod interface converged to within 2.4% between medium and fine meshes. Richardson extrapolation applied; GCI < 3% for all QOIs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Nonlinear solver residuals monitored; force and displacement convergence criteria set to 0.1%. Iterative solution repeated with tighter tolerances to confirm no sensitivity. No spurious energy modes detected."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Model setup reviewed by independent analyst at each of the three institutions. Boundary conditions, material assignments, and contact definitions verified against documented simulation plan. No use errors identified in review."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Linear elastic constitutive model appropriate for titanium alloy below yield. Contact formulation (augmented Lagrangian) validated against closed-form Hertz contact benchmarks. Geometric nonlinearity included to capture large-displacement effects at maximum test load."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Material properties (E = 114 GPa, nu = 0.34 for Ti-6Al-4V) sourced from ASTM F136 and confirmed by coupon tensile testing. Geometric dimensions derived from calibrated CMM measurements of test articles. Friction coefficient characterised by dedicated pin-on-disc testing."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "N=11 production-representative pedicle screw constructs tested; samples drawn from same manufacturing lot as clinical devices. Dimensional inspection confirms conformance to drawing tolerances. Sample size sufficient for statistical characterisation of variability."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Testing performed at a single load angle (5° from axial) per ASTM F1717 protocol. Variation across load angles not explored; single test condition limits generalisability of validation evidence. This factor is below the required level and represents a known gap in the validation evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Simulation boundary conditions mapped directly to measured test fixture geometry. Applied displacement rate in FEA matches experimental crosshead speed. Preload torque on set screws reproduced in model via equivalent pretension elements."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Quantitative comparison using E_avg metric per ASME V&V 40 Annex C. Ensemble mean prediction within 8% of experimental mean for construct stiffness and within 11% for yield load. All three FEA codes within experimental variability band (±1 SD) for primary QOI."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "QOIs (construct stiffness, yield load, peak rod stress) directly correspond to failure modes of clinical concern identified in the device risk assessment. QOI selection reviewed and approved by clinical subject matter expert."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Validation test protocol replicates the ASTM F1717 standard used for device submission testing. Loading conditions, specimen geometry, and fixture design are representative of the intended simulation use. Validation activities judged sufficiently relevant to the intended computational model application."
    }
