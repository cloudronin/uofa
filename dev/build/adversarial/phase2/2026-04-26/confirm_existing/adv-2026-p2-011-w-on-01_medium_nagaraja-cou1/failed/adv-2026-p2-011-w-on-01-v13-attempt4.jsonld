    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at least two load magnitudes or configurations.",
      "rationale": "Testing performed at a single compression-bending load condition per ASTM F1717 protocol. Only one test configuration evaluated; multi-condition coverage not achieved. This factor is below required level and is identified as a credibility gap."
