      "rationale": "FEA software (Ansys Mechanical 2021 R2) is used under a validated installation with documented version control, regression test suite, and FDA-recognized software quality system. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be reproduced within accepted tolerances.",
      "rationale": "Benchmark cantilever beam and Hertzian contact problems solved; results agree with analytical solutions to within 0.5%. Code verification is documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 5% change in QoI between successive refinement levels.",
      "rationale": "Three-level mesh refinement study performed on pedicle screw shank and rod junction. Peak von Mises stress changed by 2.1% between medium and fine mesh; discretization error deemed acceptable."
    },
