    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-001",
      "type": "ValidationResult",
      "name": "Compression-bending stiffness and failure load comparison — FEA vs. N=11 experimental constructs"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-002",
      "type": "ValidationResult",
      "name": "Cross-laboratory reproducibility assessment for ASTM F1717 static compression-bending"
    }
  ],
