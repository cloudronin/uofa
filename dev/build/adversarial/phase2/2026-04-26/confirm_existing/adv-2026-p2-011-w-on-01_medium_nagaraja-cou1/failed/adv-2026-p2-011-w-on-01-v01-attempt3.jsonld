  "signature": "ed25519:b2e4f1a3c5d7e9b1f3a5c7d9e1b3f5a7c9d1e3f5a7b9c1d3e5f7a9b1c3d5e7f9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk level.",
      "rationale": "The FEA software (Ansys Mechanical) is a commercially validated solver with documented QA procedures, version-controlled input decks, and regression test suites maintained by DePuy Synthes and FDA OSEL. Achieved level 3 exceeds the required level 2 for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems including patch tests and single-element checks were executed against analytical solutions. Results matched to within 0.5% for linear elastic cases, confirming correct implementation of the element formulations used in the pedicle screw model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "A systematic mesh convergence study was conducted across three refinement levels. The quantity of interest (construct stiffness) changed by less than 2% between the medium and fine meshes, confirming discretization error is adequately controlled at the selected mesh density."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals were monitored and confirmed to fall below 1e-6 for all load steps. Contact convergence was verified by inspecting penetration and force balance at the screw-rod and screw-block interfaces."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Model setup was independently reviewed by a second analyst. Boundary conditions, material assignments, and contact definitions were verified against the documented simulation protocol. No discrepancies were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Linear elastic continuum mechanics with frictional contact is judged appropriate for the static compression-bending regime. Plasticity was not included; the model is restricted to sub-yield loading consistent with the ASTM F1717 test protocol. Model form assumptions are explicitly documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (Ti-6Al-4V and UHMWPE block) were sourced from ASTM standards and supplier data sheets. Geometric dimensions were measured from three production screws and rods; variability was less than 0.05 mm, justifying use of nominal dimensions in the deterministic model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "N=11 constructs were tested across two independent laboratories. All specimens were from the same production lot. Dimensional inspection confirmed specimens were within drawing tolerances, supporting representativeness of the test sample population."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing was conducted at a single load level and a single offset distance per ASTM F1717. The absence of multiple test conditions (e.g., varied offset distances or load rates) limits the achieved level to 2, which is below the required level of 3. This gap is documented as a known limitation of the current validation dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions were mapped directly to the ASTM F1717 test fixture geometry. Actuator displacement rate, constraint locations, and block material properties in the model were confirmed to match the experimental setup documentation from both laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and failure load predictions from the FEA ensemble fell within the 95% confidence interval of the experimental distribution for 10 of 11 specimens. Mean prediction error for stiffness was 4.2%, and for failure load was 6.8%, both within the pre-specified 10% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and failure load under compression-bending are the primary mechanical quantities linked to clinical performance in spinal fixation. These quantities are directly measured in the ASTM F1717 protocol and are the quantities predicted by the FEA model, confirming strong relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The validation activity replicates the ASTM F1717 protocol closely; however, the intended use scope of the model extends beyond the single test configuration validated here. The gap between the validation envelope and the broader application space reduces the achieved level to 2 relative to the required level of 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment is Accepted at Medium assurance level. Eleven of thirteen V&V 40 factors meet or exceed their required levels. Two factors (Test conditions and Relevance of validation activities to the COU) fall one gradation below their required levels; these gaps are documented and judged acceptable given the conservative nature of the ASTM F1717 protocol relative to in vivo loading and the breadth of the experimental dataset across two independent laboratories. The model risk level of 3 is consistent with a Class II device submission context.",
