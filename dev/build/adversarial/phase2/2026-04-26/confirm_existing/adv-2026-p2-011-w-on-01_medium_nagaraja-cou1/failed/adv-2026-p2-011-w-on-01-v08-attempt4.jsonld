  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Ansys Mechanical R2022 R2 used under validated QMS; FDA in-house solver subject to 21 CFR Part 11 controls. Version-controlled input decks archived in FDA CDRH repository.",
      "rationale": "All three FEA solvers (FDA, Ansys, DePuy Synthes) are deployed under documented software quality assurance frameworks with version control, regression testing, and audit trails. Achieves required gradation level 3 for a Model Risk Level 3 application."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS and ASME V&V 10 suite reproduced within 1% of analytical solutions. Patch test passed for all element types employed.",
      "rationale": "Numerical code verification performed against established benchmark problems. Linear elastic patch tests and NAFEMS benchmark LE1 reproduced within tolerance. All three solver implementations verified independently, confirming code correctness at required level."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change less than 5% between successive refinements. Richardson extrapolation applied to estimate discretization error bound.",
      "rationale": "Three-level mesh refinement study conducted on the pedicle screw-rod construct. Peak von Mises stress and construct stiffness converged within 3.2% between medium and fine meshes. Richardson extrapolation yielded discretization error estimate of 2.1% for stiffness QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals below 1e-6 for all load steps. Force and moment equilibrium checked at all interfaces.",
      "rationale": "Direct sparse solver employed for linear static analyses. Residual norms confirmed below 1e-8 for all 11 construct configurations. Global equilibrium verified by summing reaction forces at boundary nodes, confirming balance within 0.01% of applied loads."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup, boundary conditions, and material assignments. Documented checklist completed for each of the 11 construct models.",
      "rationale": "Each FEA model configuration reviewed by a second analyst not involved in model construction. A standardised 47-item checklist covering geometry, material properties, contact definitions, boundary conditions, and load application was completed and archived for all 11 constructs across three solver implementations."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic constitutive model justified for sub-yield loading regime. Contact mechanics representation validated against known analytical solutions for Hertzian contact.",
      "rationale": "The F1717 compression-bending protocol operates within the elastic regime for the titanium alloy construct components. Linear elastic model form appropriate and justified by material characterisation data. Frictional contact at screw-rod interface modelled with coefficient of friction 0.15, consistent with literature values for Ti-6Al-4V interfaces."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon tests on implant-grade Ti-6Al-4V. Geometric inputs derived from CMM measurements of physical test specimens.",
      "rationale": "Elastic modulus (114 GPa) and Poisson ratio (0.33) for Ti-6Al-4V obtained from tensile coupon testing of implant-grade material per ASTM E8. Geometric dimensions of screw, rod, and vertebral body surrogate block verified by coordinate measuring machine for each of the 11 test specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs tested across two independent laboratories. Sample size justification documented. Dimensional inspection completed for all specimens.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs tested: six at Laboratory A (FDA) and five at Laboratory B (DePuy Synthes). All specimens from the same manufacturing lot. Dimensional inspection confirmed geometric consistency. Sample size provides sufficient statistical basis for mean and coefficient of variation estimation."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple loading conditions tested spanning the intended use envelope. Environmental conditions (temperature, humidity) documented and controlled.",
      "rationale": "Testing performed under a single loading condition (compression-bending at 5 degrees offset per ASTM F1717). While environmental conditions were controlled and documented, only one test configuration was evaluated. This limits the ability to assess model accuracy across the broader loading envelope, resulting in achieved level 2 against a required level of 3. This shortfall is acknowledged and noted as a limitation of the current validation campaign."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs demonstrably equivalent to experimental specimen parameters. Traceability matrix linking measured specimen dimensions to model geometry documented.",
      "rationale": "Specimen-specific FEA models constructed using CMM-measured dimensions for each of the 11 constructs. Material properties assigned from coupon tests on the same manufacturing lot. Traceability matrix documents correspondence between physical specimen measurements and model input parameters for all 11 constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (NRMSE, prediction interval coverage) computed. FEA predictions within 10% of experimental mean for primary QoIs.",
      "rationale": "Construct stiffness and maximum bending moment compared between FEA and experiment for all 11 specimens. Mean FEA prediction error for stiffness: 4.3% (FDA solver), 5.1% (Ansys), 4.8% (DePuy Synthes). NRMSE across all specimens and solvers below 8%. Prediction intervals at 95% confidence level contain 10 of 11 experimental observations."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (construct stiffness, maximum bending moment at failure) directly relevant to the regulatory decision context and biomechanical performance assessment.",
      "rationale": "Construct stiffness and maximum bending moment are the primary QoIs specified in ASTM F1717 and directly inform regulatory assessment of spinal implant mechanical performance. These QoIs are biomechanically meaningful and map directly to the performance criteria used in 510(k) submissions for pedicle screw systems."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity geometry, loading, and boundary conditions representative of the intended use scenario. Validation domain overlap with COU domain documented.",
      "rationale": "The F1717 validation activity employs the same implant geometry, material system, and loading configuration as the intended use scenario. The vertebral body surrogate block provides a standardised representation of the clinical fixation environment. The validation domain is assessed as substantially overlapping with the COU domain, supporting the relevance conclusion."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required gradation level for a Model Risk Level 3 application. The single shortfall in Test conditions (achieved level 2 vs. required level 3) is acknowledged; however, the overall body of evidence is assessed as sufficient to support the regulatory use of the FEA model ensemble for ASTM F1717 compression-bending performance prediction. The multi-laboratory, multi-solver validation strategy substantially increases confidence in model predictions. Accepted with the recommendation that future validation campaigns address additional loading conditions to close the Test conditions gap.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
