  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed the required level for Model Risk Level 3. The single shortfall (Test conditions, achieved 2 vs. required 3) is acknowledged; the assessment team determined that the remaining evidence, including multi-team replication across three independent FEA implementations and N=11 experimental constructs from two laboratories, provides sufficient aggregate credibility to support acceptance of the model for its intended use in evaluating ASTM F1717 compression-bending performance of non-cannulated pedicle screw constructs. The decision is recorded as Accepted with the noted limitation on test condition coverage.",
