  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Thirteen V&V 40 credibility factors were assessed for the non-cannulated pedicle screw FEA ensemble. Twelve of thirteen factors met or exceeded the required level for model risk level 3. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3 due to single-load-level testing per ASTM F1717 protocol constraints. The assessment team determined that the overall body of evidence, including multi-laboratory experimental validation (N=11), ensemble FEA agreement (MAPE=4.2%), and rigorous software quality assurance, provides sufficient credibility to support the intended submission use. The gap in Test conditions is accepted given protocol standardization requirements and the conservative nature of the single test condition relative to in vivo loading.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
