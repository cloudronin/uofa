      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from ASME V&V 10 and Ansys verification manual were executed and results compared to analytical solutions. All benchmarks passed within 1% error tolerance. Achieved level 3 satisfies requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 5% change in peak von Mises stress between successive refinements.",
      "rationale": "A systematic mesh convergence study was performed across three refinement levels. Peak von Mises stress in the screw shank changed by less than 2.1% between medium and fine meshes. Richardson extrapolation confirmed discretization error below 3%. Achieved level 3 meets requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria documented and met for all simulation runs.",
      "rationale": "Nonlinear solver residuals converged to below 1e-6 for all 11 construct simulations. Energy balance checks confirmed no spurious energy accumulation. Achieved level 2 meets requirement."
    },
    {
