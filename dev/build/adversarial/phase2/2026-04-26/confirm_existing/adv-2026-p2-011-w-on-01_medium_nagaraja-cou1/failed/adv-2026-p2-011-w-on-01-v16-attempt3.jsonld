  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-minimal-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is acknowledged; however, the regulatory context of ASTM F1717 submission accepts single-condition static testing as the standard benchmark. The overall credibility evidence is sufficient to support the stated decision. This model has been applied in clinical research to inform posterior spinal fixation design; the absence of a structured Context of Use record in this minimal-profile package does not diminish the assessed credibility evidence but leaves the formal intended-use scope undefined in machine-readable form.",
