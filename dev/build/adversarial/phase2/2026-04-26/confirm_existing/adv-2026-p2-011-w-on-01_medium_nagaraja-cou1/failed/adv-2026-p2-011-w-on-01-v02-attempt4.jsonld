      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup and boundary conditions documented.",
      "rationale": "Independent analyst reviewed boundary condition assignments, contact definitions, and material property assignments against the analysis plan. No discrepancies identified. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions documented and justified relative to COU physics.",
      "rationale": "Linear elastic isotropic material model applied to titanium alloy screw and UHMWPE block per published material data. Large-deformation formulation (NLGEOM ON) activated. Frictional contact (mu=0.2) at screw-block interface. Model form appropriate for quasi-static compression-bending regime. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to measurements or certified sources.",
      "rationale": "Ti-6Al-4V ELI material properties sourced from ASTM F136 and manufacturer certificates of conformance. UHMWPE properties from ISO 5834-2 certified stock. Geometry derived from CMM measurements of production screws (n=5). Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples representative of production geometry and material; sample size adequate.",
      "rationale": "N=11 constructs from production lots tested across two independent laboratories (FDA CDRH and DePuy Synthes). Dimensional inspection confirmed conformance to drawing tolerances. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of intended use conditions; multiple load cases evaluated.",
      "rationale": "Testing conducted under a single load condition (5 mm offset compression-bending per ASTM F1717). Only one test configuration evaluated; no variation in offset distance or loading rate. Achieved level 2 does not meet required level 3 — this factor is below the acceptance threshold. Identified as a known gap; additional test conditions recommended for future work."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA input parameters demonstrably equivalent to experimental test conditions.",
      "rationale": "Fixture geometry, load application point, and displacement boundary conditions in FEA replicated from ASTM F1717 fixture drawings and laboratory measurement reports. Material lot properties matched between model and tested specimens. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined; FEA predictions within acceptance band of experimental results.",
      "rationale": "Primary QOI is construct stiffness (N/mm) and yield load (N). FEA stiffness predictions within 8.3% mean absolute error vs. experimental mean; yield load within 11.2%. Both within pre-specified 15% acceptance band. ASME V&V 10.1 area validation metric also computed. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs validated are directly relevant to the clinical and regulatory decision.",
      "rationale": "Construct stiffness and yield load are the primary mechanical endpoints specified in FDA guidance for spinal implant submissions and directly inform fatigue life predictions. QOIs are clinically and regulatorily relevant. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities reflect the intended use conditions and device configuration.",
      "rationale": "Validation performed on non-cannulated 7.5 mm pedicle screw — identical configuration to the COU device. ASTM F1717 is the applicable FDA-recognized standard. Two-laboratory approach increases generalizability. Achieved level 3 meets required level 3."
    }
