      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required; achieved level must equal or exceed required level.",
      "rationale": "Systematic mesh refinement study performed across three mesh densities (coarse, medium, fine). Peak von Mises stress converged to within 2.1% between medium and fine meshes. Richardson extrapolation applied. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals and energy balance checks documented.",
      "rationale": "Nonlinear solver residuals below 1e-5 for all load steps. Energy balance error under 0.1%. Direct sparse solver selected for robustness. Achieved level 2 meets required level 2."
    },
    {
