      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk 3.",
      "rationale": "Predicted construct stiffness and peak load at 2% offset yield compared against experimental measurements using area validation metric. All FEA predictions fall within the 95% prediction interval of the experimental distribution. Mean error 4.2%, maximum error 9.7%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
