      "rationale": "Ansys Mechanical R19.2 is a commercially validated solver with documented QA procedures including regression test suites. Version control and audit trails are maintained by the analysis team. FDA in-house solver also subject to agency-level software QA protocols."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk 3.",
      "rationale": "Benchmark problems including cantilever beam bending and contact patch tests were executed and results compared to analytical solutions. Maximum deviation from analytical values was less than 0.5% across all benchmark cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk 3.",
      "rationale": "Mesh convergence study performed on the pedicle screw shank and rod interface regions. Three mesh densities evaluated; Richardson extrapolation applied. Grid convergence index below 2% for peak von Mises stress at critical cross-section."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk 3.",
      "rationale": "Newton-Raphson nonlinear solver with tight force and displacement convergence tolerances (1e-4 relative). Energy balance checks performed at each load increment. No spurious hourglassing modes detected."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk 3.",
      "rationale": "Model setup reviewed by a second analyst independent of the primary modeler. Boundary conditions, material assignments, and contact definitions verified against the simulation plan document. No discrepancies identified."
    },
    {
