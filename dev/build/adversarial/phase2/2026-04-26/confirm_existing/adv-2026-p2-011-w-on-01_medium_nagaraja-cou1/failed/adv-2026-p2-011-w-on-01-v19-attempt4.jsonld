  "hash": "sha256:a3f1c2e7d90b4856f2a1cc3d7e08b5f94d2e6a1b3c5d7f9e0a2b4c6d8e0f2a4b",
  "signature": "ed25519:b7e3a1d5c9f2046e8b3a7d1c5e9f2046e8b3a7d1c5e9f2046e8b3a7d1c5e9f20",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "The FEA software (Ansys Mechanical) is commercially validated and holds ISO 9001 certification. Version control, regression testing, and release notes are maintained by the vendor. Internal SQA procedures at FDA CDRH document solver version pinning and environment reproducibility. Achieved level 3 exceeds the required level 2 for this model risk category."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be reproduced within solver tolerance.",
      "rationale": "Standard benchmark cases including cantilever beam bending and Hertzian contact were reproduced within 0.5% of analytical solutions. Patch tests were passed for all element types used. Code verification is documented in the FDA simulation laboratory standard operating procedure."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate less than 5% change in quantity of interest between successive refinements.",
      "rationale": "A three-level mesh convergence study was performed on the screw-rod construct model. The quantity of interest (peak von Mises stress at the screw-rod interface) changed by 3.1% between medium and fine meshes, satisfying the 5% threshold. Richardson extrapolation was applied to estimate the discretization error bound."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms must converge below solver tolerance; energy balance must be satisfied within 1%.",
      "rationale": "All simulations converged with force residuals below 1e-4 and displacement residuals below 1e-5. Energy balance was verified for each load step. No divergence or ill-conditioning was observed across the ensemble of 11 construct configurations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs and boundary conditions must be independently reviewed by a second analyst.",
      "rationale": "Model setup, boundary condition application, and material property assignment were independently reviewed by a second FDA engineer. A checklist-based review protocol was followed. No discrepancies were identified between primary and review analyst inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics must capture the dominant deformation mechanisms identified in the COU; justification for simplifying assumptions must be documented.",
      "rationale": "The linear elastic continuum model with frictional contact at the screw-rod interface is appropriate for the quasi-static compression-bending regime of ASTM F1717. Titanium alloy elastic modulus and yield strength are well within the linear range at the applied loads. Simplifying assumptions (no bone, no biological tissue) are consistent with the standard test configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured values or certified material specifications.",
      "rationale": "Ti-6Al-4V material properties were sourced from ASTM F136 certified material test reports provided by DePuy Synthes. Screw and rod geometries were measured from production hardware using coordinate measuring machine data. Dimensional tolerances were propagated through a sensitivity analysis confirming less than 2% influence on peak stress predictions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental samples must be from production lots with documented material certification and dimensional inspection.",
      "rationale": "Eleven construct specimens were fabricated from production-lot hardware with full material traceability. Dimensional inspection confirmed all specimens were within drawing tolerances. Sample preparation and handling followed ASTM F1717 requirements. Two independent laboratories performed testing to assess inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the COU; multiple load levels or configurations are preferred.",
      "rationale": "Testing was conducted at a single load level and single intervertebral body height (60 mm) as specified in ASTM F1717. While this satisfies the standard, only one test condition was evaluated, limiting the ability to characterize model performance across the loading envelope. This factor is below the required level 3 and represents a known gap in the validation evidence base."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to experimental conditions within documented tolerances.",
      "rationale": "Boundary conditions in the simulation replicate the ASTM F1717 fixture geometry, applied displacement rate, and constraint configuration. Friction coefficients at the screw-rod interface were calibrated against torque-to-angle measurements from the experimental setup. Input equivalency was formally documented in the validation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., ASME V&V 20 validation metric or equivalent) must be reported; model predictions must fall within experimental uncertainty bounds.",
      "rationale": "Construct stiffness and yield load predictions from the FEA ensemble were compared against experimental measurements using the ASME V&V 20 validation metric. Model predictions fell within one experimental standard deviation for 10 of 11 constructs. Mean prediction error was 4.2% for stiffness and 5.8% for yield load, both within the acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation must be the same as or directly predictive of those used in the intended application.",
      "rationale": "Construct stiffness and yield load under compression-bending are the primary quantities of interest for regulatory assessment of posterior fixation device mechanical performance. These quantities are directly compared in the validation activity and are the same quantities used in design verification submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must be sufficiently similar to the intended use scenario to support extrapolation of credibility evidence.",
      "rationale": "The ASTM F1717 compression-bending test configuration is the regulatory standard for posterior fixation device evaluation and directly represents the intended use loading scenario. The validation activity uses production hardware, standard test fixturing, and clinically representative loading, providing high relevance to the intended regulatory decision context."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-fda-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the non-cannulated pedicle screw FEA model under ASTM F1717 compression-bending is accepted at Medium assurance level. Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is acknowledged; the limitation to a single ASTM F1717 test condition is inherent to the standard and is consistent with current regulatory practice for this device class. The overall evidence base is sufficient to support the intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
