  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for medium model risk.",
      "rationale": "All three FEA codes (FDA in-house, Ansys Mechanical, DePuy Synthes internal solver) operate under documented quality management systems. Version control, regression testing, and release documentation were verified for each platform. Achieved level exceeds required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from ASME V&V 10 and vendor verification suites were executed for each solver. Results matched analytical solutions within accepted tolerances. Independent code-to-code comparisons across the three model instances provided additional verification confidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence must be demonstrated for all primary quantities of interest.",
      "rationale": "Systematic mesh refinement studies were conducted on the pedicle screw and rod geometry. Construct stiffness and peak von Mises stress converged to within 2% between the medium and fine mesh densities. Richardson extrapolation confirmed discretization error below 1.5% for the primary quantity of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must satisfy convergence criteria defined in the simulation plan.",
      "rationale": "Force and displacement residuals were monitored to tolerances of 1e-6 for all load steps. Contact algorithm convergence was verified through energy balance checks. No divergence or spurious oscillation was observed across the N=11 construct simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs and boundary conditions must be independently reviewed.",
      "rationale": "Boundary condition setup, material property assignment, and contact pair definitions were independently reviewed by a second analyst at each participating organization. A simulation execution checklist was completed and archived for each of the three model instances prior to result extraction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions must be justified relative to the physics of the validation scenario.",
      "rationale": "Linear elastic material models were applied for titanium alloy components consistent with the sub-yield loading regime of the F1717 protocol. Small-displacement assumptions were verified against measured construct deflections. Frictional contact at screw-rod interfaces was modeled with a Coulomb friction coefficient validated against published tribological data for Ti-6Al-4V interfaces."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured or certified values.",
      "rationale": "Elastic modulus (114 GPa) and yield strength (880 MPa) for Ti-6Al-4V ELI were sourced from ASTM F136 certificate of conformance data provided by DePuy Synthes. Screw and rod geometry was extracted from calibrated CMM measurements of production hardware. Dimensional uncertainty was propagated through a sensitivity analysis confirming less than 0.8% influence on predicted stiffness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens must be representative of the modeled hardware and adequately characterize variability.",
      "rationale": "Eleven production-representative constructs were tested across two independent laboratories. All specimens were from the same manufacturing lot as the hardware dimensionally characterized for the FEA geometry. Specimen-to-specimen variability in measured stiffness was below 6% CV, confirming adequate manufacturing consistency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use.",
      "rationale": "Testing was conducted at a single compressive preload level (400 N) as specified in ASTM F1717. While this condition is the regulatory standard, it represents only one point in the broader loading space that may be encountered clinically. The single test condition limits the ability to validate model response across the full range of physiologically relevant loads, resulting in achieved level below required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation inputs must be demonstrably equivalent to the corresponding experimental parameters.",
      "rationale": "Applied loads, boundary fixture geometry, and grip compliance were matched between the experimental setup and the FEA model. Fixture stiffness was independently measured and incorporated into the model as a spring element. Agreement between simulated and measured grip displacement confirmed equivalency of boundary condition representation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics must demonstrate acceptable agreement between simulation and experiment.",
      "rationale": "Construct stiffness predictions from all three FEA instances fell within the 95% confidence interval of the experimental distribution. Mean absolute percentage error across N=11 constructs was 4.2% for stiffness and 6.1% for yield load. U-pooling analysis per ASME V&V 20 confirmed simulation uncertainty within experimental measurement uncertainty bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest in the validation activity must be relevant to the decision-making context.",
      "rationale": "Construct stiffness and yield load under compression-bending are the primary mechanical performance indicators assessed in ASTM F1717 and reviewed by FDA during 510(k) submissions for posterior spinal fixation systems. These quantities are directly linked to the risk of construct failure and are appropriate surrogates for in vivo biomechanical performance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation scenario must adequately represent the conditions under which the model will be used to support decisions.",
      "rationale": "The F1717 compression-bending protocol replicates the dominant in vivo loading mode for pedicle screw constructs under axial spinal loading. The non-cannulated 7.5 mm screw geometry tested matches the specific device configuration for which the FEA model is intended to provide performance predictions. The validation scenario is judged sufficiently representative of the intended application context."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a medium model risk classification. The single below-required factor (Test conditions, achieved level 2 vs. required level 3) reflects the inherent constraint of the ASTM F1717 single-condition protocol and is accepted given the regulatory precedent for this test standard and the conservative nature of the specified loading condition. Overall credibility is judged sufficient to support the intended regulatory submission.",
