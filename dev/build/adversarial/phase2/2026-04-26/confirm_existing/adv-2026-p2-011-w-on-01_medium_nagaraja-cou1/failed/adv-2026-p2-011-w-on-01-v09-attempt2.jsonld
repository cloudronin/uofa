      "name": "F1717 compression-bending FEA vs. experiment comparison — N=11 constructs, two laboratories"
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-compression-bending-vr-002",
      "type": "ValidationResult",
      "name": "Construct stiffness and yield load prediction agreement across FDA, Ansys, and DePuy Synthes model instances"
    }
  ],
