  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA codes (FDA in-house, Ansys, DePuy Synthes) operate under documented quality management systems with version control, issue tracking, and regression test suites. Ansys and DePuy Synthes codes hold ISO 9001 certification; FDA code is governed by CDRH software QMS procedures."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Benchmark problems from NAFEMS and vendor verification suites confirm correct implementation of linear elastic and contact formulations. All three codes reproduce analytical solutions for beam bending and Hertzian contact to within 0.5% relative error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QOI change less than 5% between successive refinements.",
      "rationale": "Systematic mesh refinement study performed on representative screw-rod construct geometry. Peak von Mises stress and construct stiffness QOIs converged to within 2.1% between medium and fine meshes. Final mesh selected at medium refinement level balancing accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must fall below 1e-6 for all load steps; energy balance checked.",
      "rationale": "Direct sparse solver employed for all three codes. Force and moment residuals confirmed below 1e-8 at each converged load step. Energy balance error less than 0.01% across all 11 construct simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup and boundary condition application by a second analyst.",
      "rationale": "Model setup independently reviewed by a second qualified analyst at each participating organization. Boundary condition application, material assignment, and contact pair definitions verified against documented modeling protocol. No discrepancies identified after reconciliation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification provided for all major modeling assumptions including material constitutive law, contact formulation, and geometric simplifications.",
      "rationale": "Linear elastic isotropic titanium alloy (Ti-6Al-4V) constitutive model justified by strain levels remaining below 0.2% yield strain under ASTM F1717 loading. Frictional contact (mu=0.3) at screw-rod interface validated against torque-release experiments. Geometric simplifications for thread roots documented and sensitivity-tested."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from traceable measurements or certified material data sheets.",
      "rationale": "Elastic modulus (114 GPa) and Poisson ratio (0.34) for Ti-6Al-4V sourced from ASTM F136 certified material test reports for the specific lot used in physical specimens. Screw and rod dimensions measured via CMM on representative samples from the N=11 test population."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sample size and selection rationale documented; dimensional characterization of tested specimens provided.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs drawn from production inventory. CMM dimensional characterization performed on all specimens. Sample size sufficient for statistical characterization of construct stiffness and failure load distributions per ASTM E122 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use; multiple load levels or configurations required at required level 3.",
      "rationale": "Testing performed at a single compression-bending load configuration per ASTM F1717 standard protocol. Variation in axial compressive preload and bending moment ratio was not explored. This limitation reduces achieved level to 2, below the required level of 3 for model risk level 3. Risk accepted by the assessment team given the regulatory standard mandates the single configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs demonstrated to be equivalent to physical test specimen properties and test machine boundary conditions.",
      "rationale": "One-to-one correspondence established between CMM-measured specimen geometry and FEA geometry for each of the 11 constructs. Actuator displacement boundary conditions replicated from test machine calibration records. Material property inputs matched to specimen-specific material certificates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., ASME V&V 20 validation metric or equivalent) applied to QOIs; systematic and random errors separated.",
      "rationale": "Construct stiffness (N/mm) and peak bending moment at 1% offset yield compared between FEA ensemble predictions and experimental measurements. Mean absolute percentage error 4.3% for stiffness and 6.1% for bending moment across all three codes and 11 specimens. ASME V&V 20 validation metric computed; model uncertainty within experimental uncertainty band for 10 of 11 specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation must be directly linked to the clinical or regulatory decision QOIs.",
      "rationale": "Construct stiffness and peak bending moment are the primary regulatory QOIs for ASTM F1717 spinal implant submissions. These quantities directly inform fatigue life prediction and clinical performance characterization. No surrogate QOIs employed in the validation comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must be sufficiently similar to the intended use scenario in terms of geometry, loading, and material to support extrapolation.",
      "rationale": "Validation constructs use production-representative non-cannulated 7.5 mm screws and 5.5 mm rods identical to those in the regulatory submission. Loading configuration matches ASTM F1717 exactly. Multi-laboratory participation (two independent facilities) increases confidence in result generalizability."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3. The single deficient factor (Test conditions, achieved level 2 vs. required level 3) reflects a constraint imposed by the ASTM F1717 standard protocol rather than an avoidable modeling deficiency. The assessment team accepted this shortfall given that the regulatory standard mandates the single-configuration test and that all other factors demonstrate sufficient credibility for the intended submission. Overall credibility is judged sufficient to support a Medium assurance level decision.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
