  "signature": "ed25519:b7e3a1d4c8f2056e9b1a3c5d7f0e2b4a6c8d0f2e4b6a8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2b4c6d8e0f2a4b6c8d0e2f4a6b8c0d2e4f6a8b0c2d4e6f801",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Ansys Mechanical R19.2 is a commercially validated FEA solver with documented QA procedures including regression test suites and version-controlled release notes. FDA in-house scripts are maintained under version control with peer review. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for Medium model risk.",
      "rationale": "Benchmark problems including beam bending and contact patch tests were executed and results compared to analytical solutions. Maximum deviation below 0.5%. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study required; discretization error must be quantified and shown to be below 5% for primary QoI.",
      "rationale": "A systematic mesh refinement study was performed across three mesh densities. The primary QoI (peak von Mises stress at screw-rod interface) changed by less than 2.1% between the two finest meshes. Richardson extrapolation confirmed GCI below 3%. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals and energy balance must be documented and within acceptable tolerances.",
      "rationale": "Force and moment residuals converged to below 1e-4 relative tolerance. Energy balance error remained below 0.1% across all load steps. Default sparse direct solver used with double precision arithmetic. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup must be independently reviewed by a second analyst.",
      "rationale": "Model boundary conditions, material assignments, and contact definitions were independently reviewed by a second FEA analyst at FDA CDRH. Discrepancies identified in initial review were resolved prior to final simulation runs. Achieved level 2 meets required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics must be justified relative to the COU; simplifying assumptions must be documented and their impact assessed.",
      "rationale": "Linear elastic material models are appropriate for titanium alloy components under sub-yield loading per F1717 protocol. Frictional contact (mu=0.3) at screw-rod interface captures dominant load transfer mechanism. Large-deformation formulation enabled. Simplification of thread geometry to equivalent cross-section is documented and sensitivity tested. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured or certified values with uncertainty quantification.",
      "rationale": "Ti-6Al-4V material properties (E=114 GPa, nu=0.34, yield=880 MPa) sourced from ASTM F136 and DePuy Synthes material certification sheets. Geometric dimensions derived from CMM measurements of production implants with tolerances documented. Uncertainty in modulus propagated through sensitivity analysis showing less than 1.8% effect on peak stress QoI. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative production implants with documented traceability.",
      "rationale": "N=11 constructs comprised production-representative 7.5 mm non-cannulated pedicle screws and 5.5 mm rods from the same manufacturing lot used in pre-market submissions. Dimensional inspection confirmed conformance to design drawings. Samples distributed across two independent test laboratories to assess inter-laboratory variability. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of conditions relevant to the COU; multiple load levels or configurations required at level 3.",
      "rationale": "Testing was performed at a single load configuration per ASTM F1717 standard protocol (70 mm inter-pedicular distance, 10 mm offset). While this configuration is clinically representative, only one test condition was evaluated. Multiple load levels or construct geometries would be required to achieve level 3. Achieved level 2 falls below required level 3; this gap is acknowledged and accepted given the standardized nature of the F1717 protocol and the regulatory precedent for single-condition validation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs must be shown to correspond to experimental test conditions within documented tolerances.",
      "rationale": "FEA boundary conditions were set to match experimental fixture geometry, applied displacement rate, and inter-pedicular distance. CMM-measured screw and rod dimensions were used directly in the FEA geometry. Applied load and displacement were matched to experimental machine output within 0.5%. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics must be reported with uncertainty bounds; agreement must be within acceptance tolerance.",
      "rationale": "Peak construct stiffness and failure load predictions were compared against experimental means and 95% confidence intervals. FEA stiffness predictions fell within the experimental 95% CI for 10 of 11 constructs. Mean absolute percentage error was 4.2% for stiffness and 6.1% for failure load. Bland-Altman analysis showed no systematic bias. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the clinical or regulatory decision supported by the model.",
      "rationale": "Construct stiffness and failure load under compression-bending are the primary mechanical performance endpoints specified in ASTM F1717 and referenced in FDA guidance for posterior lumbar fixation devices. These QoIs directly support the regulatory claim that the device meets static strength requirements. Achieved level 3 meets required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same device geometry, loading mode, and material system as the intended use.",
      "rationale": "Validation was conducted using the identical device geometry, material system, and loading mode (ASTM F1717 compression-bending) as the intended regulatory submission. The FEA ensemble was validated specifically for the 7.5 mm non-cannulated screw geometry under the standardized F1717 protocol. No extrapolation beyond the validated configuration is required for the primary regulatory decision. Achieved level 3 meets required level 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-fda-cdrh-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed required levels for Medium model risk. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 is a standardized regulatory test protocol for which single-condition validation is the established industry and regulatory norm. The overall evidence package provides sufficient credibility to support the intended regulatory submission for the non-cannulated 7.5 mm pedicle screw construct under static compression-bending loading.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
