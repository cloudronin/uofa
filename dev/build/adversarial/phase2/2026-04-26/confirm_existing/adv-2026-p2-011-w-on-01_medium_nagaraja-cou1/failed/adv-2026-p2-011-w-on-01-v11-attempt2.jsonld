  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three FEA platforms (FDA, Ansys, DePuy Synthes) operate under documented software quality assurance programs. Version control, regression testing, and release validation records are available for each solver version used in this study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems representative of compression-bending scenarios must be verified against analytical solutions.",
      "rationale": "Each FEA platform was verified against NAFEMS benchmark problems for beam bending and contact mechanics. Results agree within 1% of analytical solutions for linear elastic cases representative of the pedicle screw construct geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate less than 5% change in peak von Mises stress between successive refinement levels.",
      "rationale": "A systematic mesh convergence study was performed across three refinement levels. Peak von Mises stress in the screw shank changed by less than 2.8% between the medium and fine meshes, confirming adequate discretization for the quantity of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence criteria must be documented and demonstrated to be sufficient for the nonlinear contact problem.",
      "rationale": "Force and displacement residuals converged to below 0.1% of the applied load for all load steps. Iterative solver tolerances were tightened relative to default settings to ensure contact force equilibrium at each increment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup procedures must be documented and independently reviewed by at least one analyst not involved in model construction.",
      "rationale": "Boundary condition application, material property assignment, and contact definition were documented in a standardised simulation plan. An independent analyst at each participating institution reviewed and confirmed the setup prior to submission of results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The constitutive model and contact formulation must be appropriate for quasi-static metallic implant loading under ASTM F1717 conditions.",
      "rationale": "Linear elastic isotropic material models are appropriate for the titanium alloy implant components under sub-yield loading. Frictional contact with a coefficient of 0.2 was applied at the screw-block interface, consistent with published values for titanium-on-polyethylene contact."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters must be sourced from traceable measurements or certified material data sheets.",
      "rationale": "Elastic modulus and Poisson's ratio for the Ti-6Al-4V screws and rods were taken from ASTM F136 certified material certificates. Geometric dimensions were measured from physical specimens using calibrated CMM equipment, with uncertainty quantified at ±0.02 mm."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test sample population must be representative of the implant configuration and sufficient in number to characterise experimental variability.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories. Sample-to-sample geometric variability was characterised and found to be within manufacturing tolerances. The ensemble provides adequate statistical basis for mean and coefficient of variation comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the intended use, including at least two distinct load levels or configurations.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending configuration at a single load level. While this is the standard regulatory test condition, the absence of additional load configurations (e.g., torsion, fatigue pre-conditioning) limits the breadth of validation. This factor is below the required level and represents a known gap in the validation evidence base."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs must be demonstrably equivalent to the physical test specimen parameters within quantified tolerances.",
      "rationale": "CMM-measured specimen dimensions were used directly as FEA geometry inputs. Material property values from certified material certificates were applied without modification. Boundary condition displacements and load application points were matched to the physical test fixture geometry to within 0.5 mm."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., normalised error, confidence intervals) must be reported for the primary quantity of interest.",
      "rationale": "Peak construct stiffness and maximum displacement at failure load were compared between FEA predictions and experimental measurements. Normalised root mean square error was 4.1% for stiffness and 5.7% for peak displacement across all three FEA platforms, within the pre-specified acceptance threshold of 10%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest extracted from the FEA model must directly correspond to the decision-relevant outputs identified in the credibility assessment plan.",
      "rationale": "Construct stiffness and peak displacement under compression-bending are the primary regulatory decision quantities for ASTM F1717 compliance evaluation. These outputs were defined a priori in the credibility assessment plan and are directly reported by the FEA ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation activities must address the same implant configuration, loading mode, and material system as the intended computational use.",
      "rationale": "Validation experiments replicate the exact ASTM F1717 test configuration applied to non-cannulated 7.5 mm Ti-6Al-4V pedicle screw constructs. The loading mode, boundary conditions, and material system are identical between the validation experiments and the FEA application, providing high relevance of the validation evidence to the computational use."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for model risk level 3. The single below-threshold factor (Test conditions, achieved level 2 vs. required level 3) reflects the inherent limitation of the single-condition ASTM F1717 protocol. The assessment team judged this gap acceptable given the regulatory context, the high relevance of the single validated condition to the primary decision question, and the strong agreement across three independent FEA platforms. The overall credibility evidence is sufficient to support use of the FEA ensemble for ASTM F1717 compression-bending performance prediction of non-cannulated 7.5 mm pedicle screw constructs.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
