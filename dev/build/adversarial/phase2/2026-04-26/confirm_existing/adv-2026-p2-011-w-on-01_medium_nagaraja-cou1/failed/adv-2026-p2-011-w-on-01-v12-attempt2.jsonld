  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "The FEA software (Ansys Mechanical) is a commercially validated finite element solver with documented quality assurance procedures. Version control, regression testing, and release validation documentation were reviewed and found compliant with ASME V&V 40 Gradation 3 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Benchmark problems from NAFEMS and internal test suites were used to verify the numerical implementation. Results matched analytical solutions within 0.5% for linear elastic problems representative of the pedicle screw construct geometry."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "A systematic mesh convergence study was performed using three mesh densities (coarse, medium, fine). The Richardson extrapolation-based Grid Convergence Index (GCI) for peak von Mises stress at the screw-rod interface was less than 2%, confirming adequate spatial discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Iterative solver convergence criteria were set to residual norms below 1e-6. Direct solver cross-checks were performed on representative sub-models. No significant solver-induced errors were identified across the ensemble of three FEA implementations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Model setup was reviewed independently by two analysts. Boundary conditions, material property assignments, and contact definitions were cross-checked against the analysis plan. Documented model review checklists were completed prior to simulation execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Linear elastic constitutive models were adopted for titanium alloy screw and rod components, consistent with the small-strain, sub-yield loading regime of the ASTM F1717 test. Frictional contact at screw-rod interfaces was modeled using a Coulomb friction coefficient of 0.2, consistent with literature values for dry titanium-titanium contact."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Material properties (Young's modulus, Poisson's ratio) were sourced from ASTM F136 material certificates for the specific Ti-6Al-4V ELI alloy used in the tested constructs. Geometric dimensions were obtained from manufacturer drawings and confirmed via coordinate measurement machine (CMM) inspection of representative samples."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs from a single production lot were tested. Sample size is consistent with ASTM F1717 requirements. Dimensional inspection confirmed all samples were within drawing tolerances, supporting representativeness of the test population."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Testing was performed under a single loading condition (axial compression-bending at 5 degrees) per ASTM F1717. The absence of additional loading conditions (e.g., torsion, lateral bending) limits the breadth of validation evidence. This factor is assessed below the required level and represents a known gap in the validation dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "FEA model inputs were mapped directly to experimentally measured values. Fixture geometry, loading arm dimensions, and boundary constraint locations in the simulation were confirmed to match the physical test setup through detailed photographic and dimensional documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Predicted construct stiffness and peak load at 2% offset yield were compared against experimental measurements using the E-value metric. FEA predictions fell within the 95% confidence interval of experimental results for 10 of 11 constructs. Mean absolute percentage error was 4.3% for stiffness and 6.1% for peak load."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Construct stiffness and load at yield are directly relevant to the clinical performance question of whether the implant system will maintain spinal alignment under physiological loading. These quantities are standard performance endpoints in FDA guidance for spinal fixation device submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "The ASTM F1717 test protocol is the regulatory standard for spinal implant mechanical performance evaluation and directly represents the intended use scenario. The validation activity geometry, materials, and loading are consistent with the device configuration evaluated in this credibility assessment."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for a Model Risk Level 3 assessment. The single below-required factor (Test conditions) is acknowledged as a limitation of the available experimental dataset; the assessment team determined that the overall body of evidence is sufficient to support the intended use given the direct regulatory relevance of the ASTM F1717 protocol and the strong agreement between FEA predictions and experimental measurements across N=11 constructs at two independent laboratories.",
