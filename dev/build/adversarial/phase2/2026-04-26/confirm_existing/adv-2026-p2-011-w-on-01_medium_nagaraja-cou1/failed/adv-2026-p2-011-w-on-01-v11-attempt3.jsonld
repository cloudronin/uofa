  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical R19.2 is a commercially validated FEA solver with documented QA processes including regression test suites and ISO 9001 certification. FDA in-house scripts were version-controlled under Git with peer review. Required level 2 is met by achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmark problems must be reproduced within published tolerances.",
      "rationale": "Ansys benchmark suite results for linear static structural problems reproduce analytical solutions to within 0.1%. Additional in-house patch-test and cantilever-beam verification cases confirmed code correctness for the element types used (SOLID186, CONTA174)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Global displacement QOI must exhibit less than 2% change between successive mesh refinements.",
      "rationale": "A three-level mesh refinement study was conducted on the screw-rod assembly. Peak construct stiffness changed by 1.4% between medium and fine meshes; displacement at 150 N·m changed by 0.9%. Richardson extrapolation confirmed GCI below 1.8%, satisfying the required level 3 criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative solver residuals must converge below 1e-6 for all load steps.",
      "rationale": "Direct sparse solver (SPARSE) was used for all linear static analyses, eliminating iterative convergence concerns. Residual force norm was verified below 1e-8 at each load increment. No solver warnings or pivot ratio issues were recorded across the 11-construct ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented model setup procedure with independent review by a second analyst.",
      "rationale": "Model setup was performed by a primary analyst and independently reviewed by a second FDA biomedical engineer. Boundary condition application, material assignment, and contact definitions were verified against a written simulation protocol. Minor discrepancies found during review were corrected prior to final runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics must capture dominant load transfer mechanisms identified in prior literature.",
      "rationale": "Linear elastic continuum mechanics is appropriate for the sub-yield loading regime of ASTM F1717. Screw-rod interface is modeled with frictional contact (mu=0.2, Ti-6Al-4V on Ti-6Al-4V). UHMWPE block deformation is represented with calibrated elastic modulus. Model form is consistent with published FDA and industry FEA practice for spinal implant assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometry sourced from manufacturer data sheets or direct measurement; uncertainty bounds documented.",
      "rationale": "Ti-6Al-4V material properties (E=114 GPa, nu=0.34) sourced from ASTM F136 and confirmed by DePuy Synthes material certification. UHMWPE block modulus measured by compression testing (mean 0.94 GPa, CV 4.2%). CAD geometry provided directly by manufacturer and verified against CMM measurements of physical specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 physical specimens with documented lot traceability and dimensional inspection.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs were tested. All specimens were from a single production lot with full dimensional inspection reports. Mean rod diameter 5.5 mm (SD 0.02 mm). Screw geometry confirmed against CAD within 0.05 mm tolerance. Sample size exceeds the N=10 threshold for required level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the clinically relevant loading envelope or be justified as bounding.",
      "rationale": "Testing was conducted under a single ASTM F1717 compression-bending condition (axial compressive preload 1200 N, bending moment ramp to 10 Nm). While this represents the standard regulatory test, the single-condition approach does not cover torsion, lateral bending, or combined loading relevant to in vivo use. This factor is below required level 3 and is the sole gap identified in this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions must replicate experimental fixture constraints and loading application points.",
      "rationale": "Experimental fixture geometry was CAD-modeled and included in the FEA assembly. Load application point (75 mm offset) and constraint locations match the physical test setup to within 0.5 mm. Actuator compliance was characterized experimentally and subtracted from reported displacements, matching the FEA output convention."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., NRMSE or prediction interval coverage) reported with statistical uncertainty characterization.",
      "rationale": "Construct stiffness predictions from the FEA ensemble fell within the 95% prediction interval of experimental data for 10 of 11 specimens (91% coverage). NRMSE for stiffness was 6.3% across the ensemble. Bland-Altman analysis showed no systematic bias (mean difference 0.8 N/mm, limits of agreement ±18 N/mm). Achieved level 4 reflects the multi-metric statistical comparison with explicit uncertainty quantification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs used in validation must be directly linked to the decision-relevant performance metric.",
      "rationale": "Construct stiffness (N/mm) and peak bending moment at yield are the primary QOIs, directly corresponding to the ASTM F1717 acceptance criterion and the regulatory submission performance claim. These QOIs are established as clinically and regulatorily relevant by FDA guidance and prior literature on spinal implant biomechanics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must be sufficiently similar to the intended use scenario in geometry, loading, and material to support extrapolation.",
      "rationale": "The validation activity directly replicates the ASTM F1717 bench test that constitutes the regulatory submission test. Geometry, materials, loading mode, and boundary conditions in the validation scenario are identical to the intended use scenario. No extrapolation beyond the validated regime is claimed in the associated regulatory submission."
    }
  ],
