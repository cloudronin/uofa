  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-credibility-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-fda-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for model risk level 3. The single gap (Test conditions, achieved level 2 vs. required level 3) is acknowledged; the single-condition ASTM F1717 test is accepted as the applicable regulatory standard for this submission and is consistent with FDA guidance. The overall evidence package is sufficient to support the intended regulatory decision. This model has been applied in clinical research to characterize pedicle screw construct performance, and the credibility evidence compiled here is judged adequate for that application context.",
