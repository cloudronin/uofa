      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Quantitative comparison performed using normalized error metrics. FEA-predicted construct stiffness and yield load fall within the experimental mean ± 2 standard deviations for all 11 specimens. Bland-Altman analysis confirms no systematic bias."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Construct stiffness and yield load are the primary regulatory quantities of interest for ASTM F1717 submissions and directly inform clinical safety margins. These QoIs are well-established in the spinal implant literature and accepted by FDA reviewers."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Validation experiments replicate the ASTM F1717 test configuration that constitutes the intended regulatory use of the model. The physical test setup, specimen geometry, and loading protocol are directly representative of the submission context."
    }
