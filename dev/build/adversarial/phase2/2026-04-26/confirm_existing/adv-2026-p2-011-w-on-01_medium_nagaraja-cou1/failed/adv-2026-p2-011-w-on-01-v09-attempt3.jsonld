      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All FEA software (Ansys Mechanical) used in the ensemble is commercially validated and subject to formal quality management procedures. Version control and regression testing are documented per FDA SQA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Benchmark problems from NAFEMS and ASME V&V 10 were used to verify solver implementation. Results matched analytical solutions within accepted tolerances for linear static structural problems."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Mesh convergence study performed on pedicle screw and rod assembly. Peak von Mises stress and construct stiffness quantities of interest varied less than 2% between the medium and fine mesh densities, confirming adequate spatial discretization."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Iterative solver residuals monitored and confirmed below 1e-6 for all load steps. Direct solver cross-checks performed on a representative subset of models with consistent results."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Independent review of model setup, boundary conditions, and material assignments performed by a second analyst. Documented modeling protocol followed consistently across the three-institution ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Linear elastic continuum model with frictional contact at screw-rod interface is physically appropriate for quasi-static ASTM F1717 loading. Assumptions regarding material isotropy and small-strain kinematics are consistent with the operating regime."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Material properties (Ti-6Al-4V, cobalt-chrome rod) sourced from ASTM standards and manufacturer data sheets. Geometric dimensions measured from physical specimens and confirmed against engineering drawings. Sensitivity analysis performed on friction coefficient."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "N=11 physical constructs tested across two independent laboratories using production-representative hardware. Sample size provides adequate statistical power for mean stiffness and yield load comparisons."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Testing conducted at a single load level and single offset distance per ASTM F1717. The absence of multiple test conditions (e.g., varied offset, cyclic loading) limits generalizability and results in an achieved level below the required threshold. This gap is acknowledged and accepted given the regulatory submission context."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "FEA model inputs (geometry, material, boundary conditions) were directly mapped from measured experimental specimen parameters. Traceability matrix maintained linking each model input to its experimental measurement source."
    },
    {
