      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence study performed with three refinement levels. Richardson extrapolation applied; GCI < 2% for peak von Mises stress at screw-rod interface. Final mesh selected at intermediate refinement with verified convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Iterative solver residuals monitored; convergence tolerance set to 1e-6 for all nonlinear iterations. Energy balance checks performed for each load increment confirming numerical stability."
    },
    {
