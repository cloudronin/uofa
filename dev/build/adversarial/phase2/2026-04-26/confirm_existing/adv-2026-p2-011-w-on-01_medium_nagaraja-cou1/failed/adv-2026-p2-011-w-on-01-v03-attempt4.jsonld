  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "All three FEA implementations (FDA, Ansys, DePuy Synthes) operate under formal software quality management systems with documented version control, regression testing, and change management procedures consistent with 21 CFR Part 820 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "Benchmark problems with known analytical solutions were executed for each solver. Results confirmed correct implementation of linear elastic constitutive models and contact formulations used in the pedicle screw construct simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "Mesh convergence studies were performed on the pedicle screw and vertebral body block components. Quantities of interest (construct stiffness, peak von Mises stress) showed less than 2% change between the medium and fine mesh densities adopted for the validation study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "Iterative solver tolerances were set to 1e-6 for force and displacement residuals. Energy balance checks confirmed negligible numerical dissipation across all quasi-static load steps."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "Model setup was independently reviewed by a second analyst at each participating institution. Boundary conditions, material assignments, and contact definitions were verified against the documented simulation plan prior to execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "Linear elastic continuum mechanics with frictional contact is well-established for metallic spinal implant constructs under quasi-static loading. Published literature and prior FDA validation studies support the appropriateness of this model form for the ASTM F1717 test configuration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "Material properties (Ti-6Al-4V elastic modulus, Poisson ratio) were sourced from ASTM F136 certified material certificates for the specific screw lots tested. Geometric inputs were derived from coordinate measuring machine measurements of representative constructs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs from production lots were tested across two independent laboratories. Sample size exceeds the ASTM F1717 minimum and provides sufficient replication to characterize inter-specimen variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "Testing was conducted at a single load level (compression-bending at 10 Nm) per the ASTM F1717 protocol. The absence of multiple test conditions (e.g., varying moment magnitudes or loading rates) limits the breadth of validation evidence and results in an achieved level below the required threshold for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "FEA input parameters were mapped directly from measured experimental specimen geometry and certified material properties. Traceability matrices confirm one-to-one correspondence between simulation inputs and physical test specimen characterisation data."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "Construct stiffness and peak displacement at maximum applied moment were compared between FEA predictions and experimental measurements using quantitative metrics including mean absolute percentage error (MAPE < 8%) and 95% prediction interval overlap. Agreement is within the range considered acceptable for regulatory-grade biomechanical simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "Construct stiffness and displacement under compression-bending are the primary mechanical performance outputs specified in ASTM F1717 and are directly linked to the regulatory decision regarding implant mechanical integrity. These quantities are clinically meaningful surrogates for in vivo fixation stability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "The validation activities replicate the ASTM F1717 test configuration that is the direct comparator for the FEA predictions submitted in the regulatory context. The experimental setup, loading mode, and specimen geometry are representative of the conditions under which the model is intended to be used in support of device clearance submissions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed their required levels. The single deficiency in Test conditions (achieved level 2 vs. required level 3) is acknowledged; however, the overall weight of evidence across the remaining factors, combined with the robustness of the experimental dataset and the multi-institution FEA ensemble, supports acceptance of the model for its intended regulatory submission purpose. The assessment team concludes that the simulation credibility is sufficient to inform the regulatory decision for this Class II device.",
