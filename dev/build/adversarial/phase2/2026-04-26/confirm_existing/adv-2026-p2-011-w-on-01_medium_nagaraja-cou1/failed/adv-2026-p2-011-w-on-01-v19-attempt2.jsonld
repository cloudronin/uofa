  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0a2c4e6b8d0f2a4c6e8b0d2f4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical R19.2 is a commercially validated FEA solver with documented QA procedures, version control, and regression test suites. FDA CDRH internal software QA protocols applied. Required and achieved levels are equal at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from NAFEMS and ASME V&V 10 were used to verify linear static and contact formulations. Patch tests and single-element checks confirmed correct implementation of Hex8 and Tet10 element types used in the pedicle screw model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating less than 5% change in peak von Mises stress and construct stiffness between successive refinements.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw-rod interface. Peak stress and global stiffness converged within 3.2% between medium and fine meshes. Final mesh selected at medium refinement for computational efficiency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms below 1e-6 for all load steps; energy balance verified.",
      "rationale": "Iterative solver residuals monitored across all 11 model instances. Maximum force residual norm was 4.7e-7. Energy balance checked for each load increment with no spurious energy generation observed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented model setup checklist reviewed by independent analyst; boundary condition application verified.",
      "rationale": "A standardized model setup checklist was developed and applied. An independent FDA analyst reviewed boundary condition assignments, material property inputs, and contact pair definitions. No use errors identified during review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions documented and justified relative to the physics of quasi-static compression-bending of spinal constructs.",
      "rationale": "Linear elastic material models used for titanium alloy components, justified by strains remaining below yield throughout the F1717 test envelope. Frictional contact at screw-rod interface modeled with coefficient of friction 0.2, consistent with published tribological data for Ti-6Al-4V interfaces."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to measurements or published standards with documented uncertainty.",
      "rationale": "Elastic modulus (114 GPa) and Poisson ratio (0.34) for Ti-6Al-4V sourced from ASTM F136. Screw geometry derived from CMM measurements of production components. Input uncertainty quantified via sensitivity analysis showing less than 4% variation in stiffness predictions across plausible input ranges."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples representative of production geometry; sample size sufficient for statistical comparison.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. All samples from production lots with documented traceability. Sample size exceeds ASTM F1717 minimum of N=5 per condition."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios including at least two intervertebral spacer heights.",
      "rationale": "Testing performed at a single intervertebral spacer height (35 mm) per ASTM F1717 protocol. Variation in loading rate and temperature controlled. This factor is below the required level because only one test condition was evaluated; multi-condition testing was outside the scope of the current validation activity.",
      "note": "BELOW REQUIRED LEVEL — single test condition only"
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs demonstrably equivalent to experimental specimen parameters within stated tolerances.",
      "rationale": "Screw dimensions used in FEA matched CMM measurements of tested specimens within 0.05 mm. Rod diameter, material, and torque preload replicated in simulation. Inter-laboratory variability in test setup documented and bounded."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metrics (e.g., construct stiffness, peak load) compared using appropriate statistical methods; agreement within 15%.",
      "rationale": "Construct stiffness predictions agreed with experimental mean within 8.3% (95% CI: 4.1–12.5%). Peak load at 2% offset yield agreed within 6.7%. Bland-Altman analysis showed no systematic bias. U-pooled validation metric computed per ASME V&V 20."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (stiffness, peak load) directly relevant to clinical performance and regulatory submission requirements.",
      "rationale": "Construct stiffness and yield load are the primary endpoints specified in ASTM F1717 and referenced in FDA guidance for spinal fixation devices. These quantities are directly linked to device performance claims in 510(k) submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities address the same loading mode, device geometry, and performance metrics as the intended use.",
      "rationale": "Validation performed on the identical device configuration (7.5 mm non-cannulated pedicle screw, titanium alloy rod) under the same quasi-static compression-bending loading as the COU. Multi-laboratory design increases generalizability of validation evidence."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels for a model risk level 3 assessment. The single below-threshold factor (Test conditions, achieved 2 vs. required 3) reflects the scope limitation of the ASTM F1717 protocol to a single intervertebral spacer height. The assessment team determined that the strength of evidence across the remaining twelve factors, combined with the conservative nature of the single-condition test, is sufficient to accept the FEA model predictions for the intended submission purpose. Overall credibility is assessed as Medium, consistent with the declared assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
