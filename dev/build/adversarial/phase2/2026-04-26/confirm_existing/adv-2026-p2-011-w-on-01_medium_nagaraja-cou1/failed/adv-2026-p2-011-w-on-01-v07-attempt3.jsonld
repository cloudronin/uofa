  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level for model risk level 3. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that ASTM F1717 specifies a single standardised compression-bending condition and the regulatory submission scope is limited to that condition. Overall simulation credibility is judged sufficient to support the intended regulatory use.",
