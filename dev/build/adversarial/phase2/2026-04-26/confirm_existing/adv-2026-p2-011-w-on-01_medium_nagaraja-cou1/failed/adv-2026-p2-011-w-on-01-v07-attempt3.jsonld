      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Ansys Mechanical 2022 R1 used under ISO 9001-certified QMS. Version control and regression test suite documented. SQA procedures verified by independent audit."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS suite used to verify linear elastic solver accuracy.",
      "rationale": "Three NAFEMS benchmark cases (LE1, LE3, LE10) reproduced within 0.5% of reference solutions. Solver verification documented in code verification report CV-001."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI below 5% for quantities of interest.",
      "rationale": "Mesh convergence study conducted across three systematically refined meshes (coarse 0.8 mm, medium 0.5 mm, fine 0.3 mm element size at screw-rod interface). GCI for peak von Mises stress was 3.2%; for construct stiffness 1.8%. Fine mesh selected for all validation runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual convergence below 1e-6 for all load steps; energy balance verified.",
      "rationale": "Iterative solver residuals monitored across all 11 validation simulations. Maximum residual 4.1e-7. Energy balance error below 0.01% for each run. No spurious contact penetration detected."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with independent review of model setup by second analyst.",
      "rationale": "Simulation workflow documented in SOP-FEA-007. All 11 model instances independently reviewed by a second FEA engineer prior to submission runs. Discrepancies resolved via peer review checklist."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model and contact formulation justified relative to expected deformation regime.",
      "rationale": "Linear elastic isotropic material model applied to titanium alloy components; validated against coupon tensile data. Frictional contact (mu=0.3) at screw-rod interface based on published tribology data. Model form appropriate for sub-yield compression-bending regime per ASTM F1717."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters sourced from specimen-specific measurements or certified material certificates.",
      "rationale": "Elastic modulus (E=114 GPa), Poisson ratio (nu=0.34) from Ti-6Al-4V material certificates. Screw and rod geometry from CMM measurements of each of the 11 test specimens. Torque preload applied per manufacturer specification with ±5% tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Sufficient sample size with documented traceability and dimensional characterisation.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. Each specimen dimensionally characterised by CMM. Material certificates provided. Sample size consistent with ASTM F1717 guidance and FDA guidance on spine device testing."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios within the COU.",
      "rationale": "Testing performed at a single compression-bending load condition (compression at 5 degrees) per ASTM F1717. Achieves Gradation 2 because only one test condition was evaluated; the range of physiological loading angles was not explored. This shortfall is acknowledged and accepted given the standardised nature of the F1717 protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions demonstrably equivalent to experimental fixture constraints.",
      "rationale": "Experimental fixture geometry replicated in FEA boundary conditions. Displacement-controlled loading applied at identical crosshead displacement rate. Fixture compliance characterised experimentally and incorporated into FEA boundary condition definition."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined a priori; prediction interval overlaps experimental distribution.",
      "rationale": "Primary QOI: construct stiffness (N/mm) and yield moment (N·m). FEA ensemble mean stiffness 312 N/mm vs. experimental mean 308 N/mm (1.3% error). Yield moment FEA mean 18.4 N·m vs. experimental 18.1 N·m (1.7% error). All FEA predictions within experimental 95% prediction interval."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QOIs directly linked to the clinical and regulatory decision being supported.",
      "rationale": "Construct stiffness and yield moment are the primary performance endpoints specified in ASTM F1717 and FDA guidance for posterior spinal fixation devices. These quantities are directly relevant to the intended regulatory submission context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, materials, and loading representative of the COU.",
      "rationale": "Validation performed on production-intent non-cannulated 7.5 mm pedicle screw constructs under ASTM F1717 compression-bending, directly matching the device configuration and test standard referenced in the regulatory submission. Validation scenario judged highly representative of the intended use."
    }
  ],
