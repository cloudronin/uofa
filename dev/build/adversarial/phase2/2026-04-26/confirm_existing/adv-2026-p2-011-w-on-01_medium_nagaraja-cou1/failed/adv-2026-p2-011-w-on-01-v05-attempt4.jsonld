  "signature": "ed25519:b2e4f6a8c0d1e3f5a7b9c2d4e6f8a0b1c3d5e7f9a1b3c5d7e9f0a2b4c6d8e0f2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for the declared model risk.",
      "rationale": "FEA software (Ansys Mechanical) is subject to documented SQA procedures including version control, regression testing, and audit trails maintained by all three participating organizations (FDA, DePuy Synthes, and the academic partner). Achieved level exceeds the required level for a Model Risk 3 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Benchmark problems from NAFEMS and manufacturer-supplied verification suites confirm correct implementation of linear-elastic and contact formulations used in the pedicle screw model. Results match reference solutions within 1% for all benchmark cases reviewed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate QoI change of less than 5% between successive refinement levels.",
      "rationale": "A systematic mesh convergence study was performed on the screw-rod interface region, which governs peak stress predictions. Three refinement levels were evaluated; the QoI (peak von Mises stress at screw neck) changed by 2.1% between the two finest meshes, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance checks must confirm solution convergence to solver tolerances.",
      "rationale": "Nonlinear contact iterations converged to force residual norms below 1e-4 for all 11 model instances. Energy balance checks confirmed no spurious energy generation. Solver settings documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation plan and independent review of model setup must be on record.",
      "rationale": "A detailed simulation plan was prepared prior to analysis execution. An independent analyst at a second institution reviewed boundary condition assignments, material property inputs, and load application. No discrepancies were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Justification of continuum mechanics assumptions and contact formulation must be provided relative to the physical phenomena of interest.",
      "rationale": "Linear-elastic isotropic material models are appropriate for the titanium alloy screw and UHMWPE block under quasi-static loading well below yield. Augmented Lagrangian contact formulation captures screw-rod interface behavior. Simplifications are consistent with the F1717 test configuration and prior published validation studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measured or certified values with documented uncertainty.",
      "rationale": "Titanium alloy (Ti-6Al-4V ELI) material properties sourced from ASTM F136 certified material test reports for each lot. Geometric inputs derived from coordinate measuring machine data on representative screw samples. Uncertainty bounds on elastic modulus (±2%) propagated through sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative of production geometry and material, with traceability documented.",
      "rationale": "N=11 constructs were assembled from production-equivalent 7.5 mm non-cannulated pedicle screws and rods drawn from the same manufacturing lot. Dimensional inspection confirmed conformance to drawing tolerances. Samples distributed across two independent test laboratories to assess inter-laboratory variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of loading scenarios relevant to the COU; multiple load levels or configurations required at level 3.",
      "rationale": "Testing was conducted at a single compression-bending load condition per ASTM F1717 protocol. Only one test configuration was evaluated, which does not cover the range of in vivo load scenarios. This factor falls below the required level and represents a known gap in the validation evidence base."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model input parameters must be shown to be equivalent to experimental test parameters within documented tolerances.",
      "rationale": "Screw torque preload applied in the model (4 Nm) matches the experimentally applied torque within ±0.1 Nm. UHMWPE block geometry and fixation point locations in the model were set to measured experimental values. Correspondence between simulation and test inputs confirmed by cross-check table."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., validation metric) must be computed and compared against acceptance threshold.",
      "rationale": "Construct stiffness and peak load at 2% offset yield predicted by FEA were compared against experimental means using a validation metric based on normalized RMS error. Predicted stiffness fell within one experimental standard deviation for 10 of 11 constructs. Normalized RMS error of 4.3% is below the 10% acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the decision QoIs.",
      "rationale": "Construct stiffness and yield load are the primary mechanical performance endpoints specified in ASTM F1717 and are directly relevant to the regulatory submission decision. These QoIs are identical between the validation activity and the intended predictive use of the model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario must be sufficiently similar to the intended use scenario in geometry, material, loading, and boundary conditions.",
      "rationale": "The validation scenario replicates the F1717 bench test configuration that directly underpins the regulatory submission. Geometry, material, loading mode, and boundary conditions in the validation activity are identical to those in the predictive model application. High relevance is established."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels for a Model Risk 3 assessment. The single deficient factor (Test conditions, achieved level 2 vs. required level 3) was reviewed by the assessment team and deemed acceptable given the regulatory context: ASTM F1717 prescribes a single standardized test configuration, and the model is used exclusively to predict performance under that same configuration. The overall evidence package provides sufficient confidence to support the intended regulatory decision. Acceptance is conditional on restricting model use to the F1717 compression-bending configuration evaluated herein.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
