      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Commercial FEA software (Ansys) used with documented version control and regression testing. FDA in-house code subject to agency SQA procedures. Required and achieved levels both at Gradation 2 for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems and analytical solutions confirm solver correctness for linear elastic structural analysis.",
      "rationale": "Ansys and FDA FEA codes verified against NAFEMS benchmarks for linear static structural problems. Results within 1% of analytical solutions for representative beam-bending cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates less than 5% change in QoI between successive refinements.",
      "rationale": "Mesh convergence study performed on pedicle screw and rod geometry. Peak von Mises stress and construct stiffness converged to within 3% on the finest mesh. Tetrahedral elements with quadratic formulation used throughout."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms and energy balance checks confirm solver convergence within accepted tolerances.",
      "rationale": "Linear static solver residuals below 1e-8. Energy balance verified. No numerical instabilities observed across the 11-construct ensemble."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented modeling protocol and independent review reduce probability of analyst-induced errors.",
      "rationale": "Modeling protocol documented and followed by all three analyst teams (FDA, Ansys, DePuy Synthes). Cross-team comparison of boundary conditions, material assignments, and contact definitions performed prior to result submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form assumptions are justified by physics and literature for the compression-bending loading regime.",
      "rationale": "Linear elastic isotropic material model appropriate for titanium alloy at sub-yield loads. Contact between screw and rod modeled with frictional interface. Large-deformation effects negligible at test load levels confirmed by sensitivity analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometry inputs traceable to manufacturer data and direct measurement.",
      "rationale": "Ti-6Al-4V material properties (E=114 GPa, nu=0.34) sourced from manufacturer certificates and literature. Screw and rod geometry measured via CMM on representative samples. Dimensional variability across N=11 constructs characterized."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples representative of the device configuration; sample size sufficient for statistical comparison.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories. Sample size exceeds ASTM F1717 minimum. Constructs from production lots with full traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of loading scenarios relevant to the intended use.",
      "rationale": "Testing performed at a single compression-bending load level per ASTM F1717. Only one test condition evaluated; multi-load-level or fatigue conditions not included in this validation activity. Achieved level below required level; this gap is acknowledged and documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading replicate experimental setup with documented equivalency.",
      "rationale": "Experimental fixture geometry, load application points, and constraint conditions replicated in FEA. Fixture compliance measured and incorporated. Load cell calibration records reviewed for both laboratories."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E-factor or MAPE) demonstrates acceptable agreement between FEA and experiment.",
      "rationale": "Construct stiffness (N/mm) and peak displacement compared between FEA ensemble and experimental data. Mean absolute percentage error across N=11 constructs is 4.2% for stiffness and 5.1% for displacement. All three FEA teams within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (construct stiffness, displacement) are directly relevant to the regulatory decision.",
      "rationale": "Construct stiffness and load-displacement response are the primary QoIs for ASTM F1717 regulatory submissions. These QoIs are directly linked to the biomechanical performance claims for the pedicle screw system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activity conditions sufficiently match the intended use conditions to support the credibility claim.",
      "rationale": "ASTM F1717 test protocol closely replicates the in vivo loading environment for spinal fixation constructs. The non-cannulated 7.5 mm configuration tested is the specific device configuration for which the FEA model is applied in clinical research and regulatory contexts."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted despite Test conditions factor achieving only Gradation 2 against a required Gradation 3. The assessment team judged that the single-condition limitation is adequately bounded by the conservative nature of the ASTM F1717 protocol and the high agreement observed across N=11 constructs and three independent FEA teams. All other 12 factors meet or exceed required levels. The model has been applied in clinical research supporting Class II device submissions and is considered sufficiently credible for the intended regulatory purpose.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
