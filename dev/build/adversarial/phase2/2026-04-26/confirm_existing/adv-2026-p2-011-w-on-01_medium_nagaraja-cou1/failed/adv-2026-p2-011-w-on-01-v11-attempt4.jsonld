      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change less than 5% between successive refinement levels.",
      "rationale": "Three-level mesh refinement study performed on screw-rod interface region. Von Mises stress at critical node changed by 3.1% between medium and fine mesh; fine mesh adopted for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
