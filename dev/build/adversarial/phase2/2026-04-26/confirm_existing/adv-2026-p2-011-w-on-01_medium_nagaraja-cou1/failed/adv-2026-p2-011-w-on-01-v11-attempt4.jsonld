  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted. Twelve of thirteen V&V 40 factors meet or exceed required levels. The single shortfall in Test conditions (achieved 2, required 3) is acknowledged and accepted on the basis that the ASTM F1717 compression-bending scenario represents the most conservative and clinically prevalent loading mode. Risk associated with the shortfall is bounded by the conservative load case selection and the high concordance observed across all other credibility factors. The model ensemble is considered fit for the regulatory submission purpose.",
