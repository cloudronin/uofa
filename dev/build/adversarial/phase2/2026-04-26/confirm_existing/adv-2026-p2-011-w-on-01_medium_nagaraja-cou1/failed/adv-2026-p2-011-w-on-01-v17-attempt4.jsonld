  "signature": "ed25519:b2d5f8a1c4e7b0d3f6a9c2e5b8d1f4a7c0e3b6d9f2a5c8e1b4d7f0a3c6e9b2d5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software must have documented verification tests, version control, and quality management procedures consistent with Gradation 3 requirements.",
      "rationale": "Ansys Mechanical 2021 R2 used with documented QMS procedures; FDA in-house FEA code maintained under 21 CFR Part 820 software controls; DePuy Synthes implementation under ISO 13485 QMS. All three implementations satisfy Gradation 3 software quality assurance requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions must be solved to confirm correct implementation of governing equations at Gradation 3.",
      "rationale": "All three FEA implementations verified against standard NAFEMS benchmarks for linear elastic structural analysis including beam bending, contact, and bolt preload problems. Residual norms and patch test results documented and within acceptable tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating quantity of interest changes less than 5% between successive refinements, consistent with Gradation 3.",
      "rationale": "Mesh convergence studies performed on pedicle screw and rod geometry with three refinement levels. Peak von Mises stress and construct stiffness converged to within 3.2% between medium and fine meshes. Final mesh selected based on convergence criterion with approximately 480,000 elements per construct model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals and energy balance errors must be below defined thresholds at Gradation 2.",
      "rationale": "Direct sparse solver employed for linear static analyses. Force residual norms below 1e-8 for all load steps. Energy error indicators monitored and confirmed below 0.1% for all 11 construct configurations. Exceeds Gradation 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented model review process with independent analyst check to identify user-introduced errors, consistent with Gradation 3.",
      "rationale": "Each FEA model independently reviewed by a second analyst not involved in model construction. Boundary conditions, material assignments, contact definitions, and load application reviewed against documented modeling protocol. Discrepancies resolved prior to result extraction. Cross-laboratory comparison further reduces user error risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model form selection must be justified with reference to governing physics and documented assumptions at Gradation 3.",
      "rationale": "Linear elastic continuum FEA with frictional contact at screw-rod interface selected based on prior literature establishing dominance of elastic deformation under ASTM F1717 quasi-static loading. Geometric nonlinearity included for large displacement effects. Titanium alloy Ti-6Al-4V elastic modulus and yield strength from material certificates. Model form assumptions documented and justified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs must be traceable to measurements or certified material data at Gradation 3.",
      "rationale": "Screw and rod geometry digitized from CMM measurements of production hardware. Material properties from lot-specific material certificates for Ti-6Al-4V per ASTM F136. Torque-tension relationship for screw seating characterized experimentally. All inputs traceable with documented uncertainty estimates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test samples must be representative production hardware with documented dimensional and material traceability at Gradation 3.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested, all from production lots with full dimensional inspection records and material certificates. Constructs assembled per surgical technique guide by trained personnel. Sample selection documented with rationale for representativeness."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions must span the range of conditions relevant to the COU, with at least two load levels or configurations, at Gradation 3.",
      "rationale": "Testing performed under a single quasi-static compression-bending load configuration per ASTM F1717. Only one test condition evaluated; no variation in load angle, displacement rate, or construct offset distance. This limits the ability to characterize model accuracy across the full operating envelope and represents a known gap relative to Gradation 3 requirements. Accepted at Gradation 2 with acknowledgment of this limitation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs must demonstrably correspond to the physical test configuration at Gradation 3.",
      "rationale": "FEA boundary conditions replicate ASTM F1717 test fixture geometry including UHMWPE block embedment depth, loading arm length, and crosshead displacement control. Screw insertion torque mapped to preload via experimentally derived torque-tension curve. Equivalency between physical and computational boundary conditions confirmed by independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics including error norms or agreement intervals must be reported at Gradation 3.",
      "rationale": "Construct stiffness and failure load compared between FEA predictions and experimental measurements for all 11 constructs. Mean absolute percentage error 4.7% for stiffness and 6.1% for failure load across three FEA implementations. 95% prediction intervals overlap experimental distribution. Bland-Altman analysis confirms no systematic bias. All three implementations meet acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest extracted from FEA must be directly relevant to the clinical or regulatory decision at Gradation 3.",
      "rationale": "Construct stiffness and failure load are the primary quantities of interest specified in ASTM F1717 and referenced in FDA guidance for spinal fixation device submissions. These quantities directly inform fatigue life predictions and comparative performance claims. QOI selection documented with explicit linkage to regulatory decision criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed under conditions sufficiently similar to the intended use conditions to support credibility claims at Gradation 3.",
      "rationale": "Validation performed on production-representative hardware under standardized ASTM F1717 test conditions directly corresponding to the regulatory submission context. Multi-laboratory execution across FDA, DePuy Synthes, and independent testing facilities strengthens generalizability. Validation scope covers the primary loading mode of clinical concern for posterior spinal fixation constructs."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required gradation levels. The single deficient factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) is accepted based on the constraint of the standardized ASTM F1717 test protocol, which permits only a single load configuration, and the strong performance across all other factors. The overall credibility evidence is judged sufficient to support the intended regulatory use. Note: this assessment package conforms to the Minimal profile; structured Context of Use documentation is not included in this package version.",
