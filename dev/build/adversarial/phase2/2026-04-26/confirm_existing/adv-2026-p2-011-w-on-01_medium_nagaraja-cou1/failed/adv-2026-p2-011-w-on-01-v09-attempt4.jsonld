      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation protocol documented in SOP-FEA-001. Independent analyst review of boundary conditions and material assignments completed. No use errors identified."
    },
    {
