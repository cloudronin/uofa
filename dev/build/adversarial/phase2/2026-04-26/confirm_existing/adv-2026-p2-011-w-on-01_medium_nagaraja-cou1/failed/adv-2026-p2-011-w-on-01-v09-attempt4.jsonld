      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness and peak bending moment are the primary quantities of interest for predicting in vivo mechanical performance. These map directly to the clinical question of construct stability under physiological loading."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Validation activities directly replicate the ASTM F1717 test standard referenced in the intended use. Experimental and simulation domains are closely matched. Residual gap between validation domain and broader clinical use scope is acknowledged in the assessment narrative."
    }
