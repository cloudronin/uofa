      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "All three simulation platforms (FDA, Ansys, DePuy Synthes) operate under documented software quality management systems with version control, regression testing, and audit trails. Achieved level 3 satisfies the required level 2 for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Each FEA platform has been verified against analytical benchmarks for linear elastic beam-bending and contact problems representative of the pedicle screw construct geometry. Published verification reports are available for all three codes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrating <5% change in construct stiffness QoI between successive refinements.",
      "rationale": "Mesh convergence studies were performed on all three models. Stiffness QoI varied by less than 3% between the medium and fine meshes, satisfying the acceptance criterion at level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms below 1e-6 for all load steps; energy balance error below 0.1%.",
      "rationale": "All simulations converged with residual norms below 1e-7 and energy balance errors below 0.05%, meeting the required solver accuracy level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent review of model setup by a second analyst not involved in original model construction.",
      "rationale": "An independent analyst reviewed boundary conditions, material assignments, and loading definitions across all three FEA models. No critical use errors were identified; minor discrepancies in contact stiffness defaults were harmonized prior to analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model physics assumptions are justified relative to the ASTM F1717 test configuration and the quantities of interest.",
      "rationale": "Linear elastic material models are appropriate for the metallic construct under sub-yield loading specified in ASTM F1717. Contact interactions between screw and rod are modeled with Coulomb friction (mu=0.2), consistent with published tribological data for titanium alloy interfaces."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric dimensions sourced from manufacturer specifications and measured values with stated uncertainty.",
      "rationale": "Ti-6Al-4V elastic modulus (114 GPa) and Poisson ratio (0.34) are taken from ASTM F136 and confirmed by coupon testing. Screw geometry is derived from manufacturer CAD files with dimensional verification against physical specimens."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 physical specimens tested; specimens traceable to same manufacturing lot as model geometry source.",
      "rationale": "N=11 physical constructs were tested across two independent laboratories. All specimens were drawn from the same manufacturing lot as the CAD geometry used for FEA, ensuring dimensional consistency."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading magnitudes and configurations.",
      "rationale": "Testing was performed at a single compressive load magnitude (1500 N) as specified in ASTM F1717. While this satisfies the standard, it does not span the full range of in vivo loading conditions, resulting in an achieved level of 2, below the required level of 3. This shortfall is acknowledged as a limitation of the current validation activity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA boundary conditions and loading replicate ASTM F1717 fixture constraints to within documented tolerances.",
      "rationale": "Fixture geometry, pin-hole clearances, and load application points in the FEA models were verified against ASTM F1717 Figure 1 dimensions. Boundary condition equivalency confirmed by comparing predicted fixture reaction forces with measured values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted construct stiffness within 15% of mean experimental value; ensemble spread within experimental inter-specimen variability.",
      "rationale": "Predicted stiffness values from all three FEA platforms fell within 10% of the experimental mean (1842 N/mm ± 87 N/mm). Ensemble spread of 6% is within the experimental coefficient of variation of 9.4%, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (construct stiffness, peak screw-rod interface stress) are directly linked to the clinical performance question.",
      "rationale": "Construct stiffness and screw-rod interface stress are the primary mechanical QoIs relevant to fatigue life and clinical stability of posterior spinal fixation. Both QoIs are directly measurable in the ASTM F1717 configuration and traceable to the intended use narrative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, loading, and boundary conditions are representative of the intended simulation use.",
      "rationale": "The ASTM F1717 validation configuration closely replicates the geometry and loading of the non-cannulated 7.5 mm pedicle screw construct as used in the simulation application. The validation activity is therefore judged highly relevant to the intended simulation use, achieving level 3."
    }
