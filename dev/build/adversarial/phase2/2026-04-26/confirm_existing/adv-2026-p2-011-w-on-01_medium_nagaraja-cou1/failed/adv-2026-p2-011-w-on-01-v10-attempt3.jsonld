      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Dimensional measurements from micro-CT used directly to parameterise FEA geometry, ensuring one-to-one correspondence between physical specimen and simulation inputs. Material certificates confirmed composition compliance for each specimen."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Predicted construct stiffness compared against experimental stiffness using normalised error metric. Mean absolute normalised error of 4.7% across N=11 constructs; 95% prediction interval bounds within ±12% of experimental mean. Statistical comparison performed using Wilcoxon signed-rank test (p > 0.05)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Construct stiffness and peak bending moment are the primary quantities of interest directly linked to the intended use claim. These quantities are mechanistically meaningful for spinal implant fatigue and fixation performance assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for model risk level 3.",
      "rationale": "Validation activities replicate the ASTM F1717 test configuration that directly corresponds to the intended regulatory submission context. Physical test conditions, implant geometry, and boundary conditions are representative of the simulation use scenario."
    }
